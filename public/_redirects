# Cloudflare Pages redirects
# 404s are handled via a 404.html file at the root — no redirect rule needed

# /playoffs → current round page. Server-side 302, no "Redirecting..." flash.
/playoffs   /playoffs/2026   302
/playoffs/  /playoffs/2026   302

# /games/:id → handled by functions/games/[id].ts (injects OG metadata per game)
# Fallback for /games/ root without ID
/games/     /games/index.html    200

# /stats/leaderboards → /stats/skaters (URL rename, May 2026)
/stats/leaderboards   /stats/skaters   301
/stats/leaderboards/  /stats/skaters   301

# /cards → removed May 2026, canvas card generation moved to player pages
/cards    /stats/skaters   301
/cards/   /stats/skaters   301

# /_dev/* → not for public consumption; redirect to home in production
/_dev/*   /   302
