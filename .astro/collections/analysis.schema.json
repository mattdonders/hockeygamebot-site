{
  "$ref": "#/definitions/analysis",
  "definitions": {
    "analysis": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "og_image": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "published",
            "draft"
          ],
          "default": "draft"
        },
        "author": {
          "type": "string",
          "default": "Matt Donders"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "date"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}