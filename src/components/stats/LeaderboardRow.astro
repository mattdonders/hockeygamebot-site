---
// LeaderboardRow — one ranked row in a stats leaderboard table.
// Site-layer tokens (Space Grotesk). Value + percentile badge on right.

interface Props {
  rank: number;
  displayName: string;
  teamAbbrev: string;
  pos: string;
  /** Display value (e.g. "2.85", "45"). Already formatted string. */
  value: string;
  /** Percentile 0–100 vs same position group. Shown as colored dot. */
  pct: number;
  /** Optional: link to player page when slug is available. */
  href?: string;
}

const { rank, displayName, teamAbbrev, pos, value, pct, href } = Astro.props;

// Pct tier for dot color
const dotColor = pct >= 90 ? '#00c078' : pct >= 70 ? '#60a5fa' : pct >= 40 ? '#8a8a82' : '#e8002d';

const Tag = href ? 'a' : 'div';
---
<Tag class="lr" href={href}>
  <span class="lr-rank">{rank}</span>
  <span class="lr-name">{displayName}</span>
  <span class="lr-meta">
    <span class="lr-pos">{pos}</span>
    <span class="lr-team">{teamAbbrev}</span>
  </span>
  <span class="lr-value">{value}</span>
  <span class="lr-dot" style={`background:${dotColor};`} title={`${Math.round(pct)}th pct`}></span>
</Tag>

<style>
  .lr {
    display: grid;
    grid-template-columns: 32px 1fr auto auto 14px;
    align-items: center;
    gap: 0 12px;
    padding: 9px 14px;
    border-bottom: 1px solid var(--site-border, #1c1c1c);
    font-family: var(--font-site-body, sans-serif);
    color: var(--site-white, #f5f5f5);
    text-decoration: none;
    transition: background 0.1s;
  }

  a.lr:hover { background: var(--site-card, #0f0f0f); cursor: pointer; }

  .lr-rank {
    font-family: var(--font-mono, monospace);
    font-size: 12px;
    color: var(--site-muted, #555);
    text-align: right;
  }

  .lr-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--site-white, #f5f5f5);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lr-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--site-muted, #555);
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .lr-pos {
    background: var(--site-border, #1c1c1c);
    padding: 1px 5px;
    border-radius: var(--radius-sm, 2px);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .lr-value {
    font-family: var(--font-site-display, sans-serif);
    font-weight: 700;
    font-size: 16px;
    font-variant-numeric: tabular-nums;
    color: var(--site-white, #f5f5f5);
    text-align: right;
    white-space: nowrap;
  }

  .lr-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-pill, 999px);
    flex: none;
  }
</style>
