---
// PlayerHero — player identity header for stats player pages.
// Card-dark surface (--card-bg), Barlow Condensed.
// Team logo from NHL CDN (same source as teams.astro).

interface Props {
  firstName: string;
  lastName: string;
  displayName: string;
  teamAbbrev: string;
  pos: string;
  /** Optional: hex team color for the accent rule. Falls back to --hgb-red. */
  teamColor?: string;
}

const { firstName, lastName, displayName, teamAbbrev, pos, teamColor } = Astro.props;
const logoUrl = `https://assets.nhle.com/logos/nhl/svg/${teamAbbrev}_light.svg`;
const accentColor = teamColor ?? 'var(--hgb-red)';
---
<div class="ph-hero" style={`--accent: ${accentColor};`}>
  <div class="ph-accent-bar"></div>
  <img class="ph-logo" src={logoUrl} alt={teamAbbrev} loading="lazy" />
  <div class="ph-identity">
    <div class="ph-pos-team">
      <span class="ph-badge">{pos}</span>
      <span class="ph-team">{teamAbbrev}</span>
    </div>
    <div class="ph-name">
      <span class="ph-first">{firstName}</span>
      <span class="ph-last">{lastName}</span>
    </div>
  </div>
</div>

<style>
  .ph-hero {
    background: var(--card-bg, #0d0d14);
    color: var(--card-text, #efeee8);
    font-family: var(--font-card-display, 'Barlow Condensed', sans-serif);
    display: flex;
    align-items: center;
    gap: var(--sp-18, 18px);
    padding: var(--sp-20, 20px) var(--sp-24, 24px);
    border-radius: var(--radius-md, 3px);
    position: relative;
    overflow: hidden;
    border-left: 6px solid var(--accent, var(--hgb-red));
  }

  .ph-accent-bar {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 6px;
    background: var(--accent, var(--hgb-red));
  }

  .ph-logo {
    width: 72px;
    height: 72px;
    flex: none;
    object-fit: contain;
  }

  .ph-identity { display: flex; flex-direction: column; gap: 6px; }

  .ph-pos-team {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--card-muted, #8a8a82);
  }

  .ph-badge {
    background: var(--card-panel-bg, rgba(255,255,255,0.04));
    border: 1px solid var(--card-rule, rgba(255,255,255,0.14));
    border-radius: var(--radius-sm, 2px);
    padding: 2px 6px;
    color: var(--card-text, #efeee8);
  }

  .ph-name {
    display: flex;
    align-items: baseline;
    gap: 10px;
    line-height: 1;
  }

  .ph-first {
    font-size: 28px;
    font-weight: 600;
    color: var(--card-muted, #8a8a82);
  }

  .ph-last {
    font-size: 44px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--card-text, #efeee8);
  }

  @media (max-width: 640px) {
    .ph-last { font-size: 32px; }
    .ph-first { font-size: 22px; }
    .ph-logo { width: 52px; height: 52px; }
  }
</style>
