---
// GameRow — compact game card in the site grid style.
// Source: .gc (game card) pattern in Claude Design website UI kit.
// Site-layer tokens (Oswald scores, Space Grotesk labels).

interface Props {
  homeTeam: string;
  awayTeam: string;
  homeScore: number;
  awayScore: number;
  state: 'live' | 'final' | 'fut';
  /** e.g. "P2 · 08:41" for live, "APR 22" for fut */
  stateLabel?: string;
  homeXG?: number;
  awayXG?: number;
  homeSOG?: number;
  awaySOG?: number;
}

const {
  homeTeam, awayTeam,
  homeScore, awayScore,
  state, stateLabel,
  homeXG, awayXG,
  homeSOG, awaySOG,
} = Astro.props;

const isFinal = state === 'final';
const homeWins = isFinal && homeScore > awayScore;
const awayWins = isFinal && awayScore > homeScore;
const homeLoser = isFinal && homeScore < awayScore;
const awayLoser = isFinal && awayScore < homeScore;

const stateMap = { live: 'LIVE', final: 'FINAL', fut: 'UPCOMING' };
const displayLabel = stateLabel ?? stateMap[state];
const logoBase = 'https://assets.nhle.com/logos/nhl/svg';
---
<div class={`gr gr--${state}`}>
  <div class="gr-top">
    <span class={`gr-state gr-state--${state}`}>
      {state === 'live' && <span class="gr-dot"></span>}
      {displayLabel}
    </span>
    {(homeSOG !== undefined) && (
      <span class="gr-colhead">
        <span></span>
        <span>SOG</span>
        {homeXG !== undefined && <span>xG</span>}
        <span>G</span>
      </span>
    )}
  </div>

  {/* Away team row */}
  <div class={`gr-row ${awayLoser ? 'gr-row--loser' : ''}`}>
    <span class="gr-tm">
      <img src={`${logoBase}/${awayTeam}_light.svg`} alt={awayTeam} width="28" height="28" />
      <span class="gr-abbr">{awayTeam}</span>
    </span>
    {homeSOG !== undefined && <span class="gr-cell">{awaySOG ?? '–'}</span>}
    {homeXG  !== undefined && <span class="gr-cell gr-cell--xg">{awayXG?.toFixed(2) ?? '–'}</span>}
    <span class="gr-score">{state === 'fut' ? '–' : awayScore}</span>
  </div>

  {/* Home team row */}
  <div class={`gr-row ${homeLoser ? 'gr-row--loser' : ''}`}>
    <span class="gr-tm">
      <img src={`${logoBase}/${homeTeam}_light.svg`} alt={homeTeam} width="28" height="28" />
      <span class="gr-abbr">{homeTeam}</span>
    </span>
    {homeSOG !== undefined && <span class="gr-cell">{homeSOG ?? '–'}</span>}
    {homeXG  !== undefined && <span class="gr-cell gr-cell--xg">{homeXG?.toFixed(2) ?? '–'}</span>}
    <span class="gr-score">{state === 'fut' ? '–' : homeScore}</span>
  </div>
</div>

<style>
  .gr {
    background: var(--site-card, #0f0f0f);
    border: 1px solid var(--site-border, #1c1c1c);
    border-radius: var(--radius-md, 3px);
    padding: 12px 14px;
    font-family: var(--font-site-body, sans-serif);
    transition: border-color 0.15s, background 0.15s;
    cursor: pointer;
  }
  /* Use --site-dim for hover bg — inverts correctly under [data-mode="light"]. */
  .gr:hover { border-color: var(--site-border2, #252525); background: var(--site-dim, #2e2e2e); }

  .gr-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .gr-state {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .gr-state--live  { color: var(--status-live, #00e5ff); }
  .gr-state--final { color: var(--site-muted, #555); }
  .gr-state--fut   { color: var(--status-fut, #ffca28); }

  .gr-dot {
    width: 6px; height: 6px;
    border-radius: var(--radius-pill, 999px);
    background: currentColor;
    animation: grPulse 1.8s ease-out infinite;
  }
  @keyframes grPulse {
    0%   { box-shadow: 0 0 0 0 rgba(0,229,255,0.55); }
    70%  { box-shadow: 0 0 0 8px rgba(0,229,255,0); }
    100% { box-shadow: 0 0 0 0 rgba(0,229,255,0); }
  }

  .gr-colhead {
    display: grid;
    grid-template-columns: 1fr repeat(3, 34px);
    gap: 4px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--site-dim, #2e2e2e);
    text-align: right;
  }

  .gr-row {
    display: grid;
    grid-template-columns: 1fr repeat(3, 34px);
    align-items: center;
    gap: 4px;
    padding: 7px 0;
    /* --site-border inverts: dark #1c1c1c / light rgba(13,13,20,.12) */
    border-top: 1px solid var(--site-border, #1c1c1c);
  }
  .gr-row:first-of-type { border-top: none; }

  .gr-row--loser .gr-abbr,
  .gr-row--loser .gr-score { color: var(--site-muted, #555); }
  .gr-row--loser img { opacity: 0.35; filter: grayscale(0.4); }

  .gr-tm { display: flex; align-items: center; gap: 10px; min-width: 0; }

  .gr-abbr {
    font-family: var(--font-site-display, sans-serif);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.06em;
    color: var(--site-white, #f5f5f5);
  }

  .gr-cell {
    font-family: var(--font-mono, monospace);
    font-size: 11px;
    color: var(--site-text, #999);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .gr-cell--xg { color: var(--status-live, #00e5ff); }

  .gr-score {
    font-family: var(--font-site-display, sans-serif);
    font-weight: 700;
    font-size: 22px;
    font-variant-numeric: tabular-nums;
    color: var(--site-white, #f5f5f5);
    text-align: right;
  }
</style>
