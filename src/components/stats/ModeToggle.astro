---
// ModeToggle — dark/light mode icon button.
// Icon visibility is driven entirely by CSS targeting html[data-mode],
// which is set by the anti-FOUC script before any CSS renders.
// No JS required for initial paint — zero flicker.
---
<button class="mt-btn" id="mode-toggle"
        aria-label="Toggle light/dark mode" title="Toggle light/dark mode">

  <!-- Sun: visible in dark mode — click to switch to light -->
  <svg class="mt-sun" width="15" height="15" viewBox="0 0 16 16"
       fill="none" stroke="currentColor" stroke-width="1.5"
       stroke-linecap="round" aria-hidden="true">
    <circle cx="8" cy="8" r="3"/>
    <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.22 3.22l1.41 1.41M11.36 11.36l1.42 1.42M12.78 3.22l-1.41 1.41M4.64 11.36l-1.42 1.42"/>
  </svg>

  <!-- Moon: visible in light mode — click to switch to dark -->
  <svg class="mt-moon" width="15" height="15" viewBox="0 0 16 16"
       fill="currentColor" aria-hidden="true">
    <path d="M8 2a4 4 0 0 0 6 6 6 6 0 1 1-6-6z"/>
  </svg>

</button>

<script>
  const btn = document.getElementById('mode-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const current = document.documentElement.dataset.mode;
      const next = current === 'light' ? 'dark' : 'light';
      document.documentElement.dataset.mode = next;
      try {
        localStorage.setItem('hgb-mode', next);
      } catch (_) {
        // Private/strict mode — toggle works visually but won't persist
      }
    });
  }
</script>

<style is:global>
  /*
   * Icon visibility via html[data-mode].
   * The anti-FOUC script sets this attribute before CSS renders,
   * so the correct icon is visible from first paint — no JS needed here.
   */
  html:not([data-mode="light"]) .mt-moon { display: none; }
  html[data-mode="light"]       .mt-sun  { display: none; }
</style>

<style>
  .mt-btn {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: var(--radius-md, 3px);
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    transition: color 0.12s, border-color 0.12s;
  }
  /* Topbar is always #000 regardless of mode, so these values hold for both */
  .mt-btn:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.4);
  }
</style>
