---
import ModeToggle from './ModeToggle.astro';
// PageHeader — sticky topbar for HGB stats pages.
// Source: .topbar pattern in Claude Design website UI kit.
// TODO SS-8: add STATS to nav when stats site merges into main branch.

interface Props {
  activePage: 'scores' | 'stats' | 'teams' | 'playoffs' | 'support';
}
const { activePage } = Astro.props;

const navItems = [
  { href: '/',             label: 'Scores',   key: 'scores'   },
  { href: '/teams',        label: 'Teams',    key: 'teams'    },
  { href: '/playoffs/2026', label: 'Playoffs', key: 'playoffs' },
  { href: '/support',      label: 'Support',  key: 'support'  },
  // TODO SS-8: add { href: '/stats', label: 'Stats', key: 'stats' }
];
---
<header class="ph-topbar">
  <a href="/" class="ph-brand">
    <span class="ph-puck"></span>
    HockeyGameBot
  </a>
  <nav class="ph-nav">
    {navItems.map(item => (
      <a href={item.href} class={item.key === activePage ? 'active' : ''}>
        {item.label}
      </a>
    ))}
  </nav>
  <div class="ph-spacer"></div>
  <ModeToggle />
  <slot />
</header>

<style>
  .ph-topbar {
    height: var(--topbar-h, 44px);
    background: #000;
    border-bottom: 1px solid var(--site-border, #1c1c1c);
    display: flex;
    align-items: center;
    padding: 0 18px;
    gap: 14px;
    position: sticky;
    top: 0;
    z-index: 20;
    font-family: var(--font-site-body, sans-serif);
  }

  .ph-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #fff;
    font-family: var(--font-site-display, sans-serif);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    flex: none;
  }

  .ph-puck {
    width: 14px;
    height: 14px;
    border-radius: var(--radius-pill, 999px);
    background: var(--hgb-red, #E8002D);
    box-shadow: inset 0 0 0 2px #000;
    flex: none;
  }

  .ph-nav {
    display: flex;
    gap: 4px;
    margin-left: 22px;
  }

  .ph-nav a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 6px 12px;
    border: 1px solid transparent;
    border-radius: var(--radius-md, 3px);
    transition: color 0.12s, border-color 0.12s;
  }

  .ph-nav a:hover { color: #fff; border-color: rgba(255,255,255,0.2); }
  .ph-nav a.active { color: #fff; border-color: rgba(255,255,255,0.3); }

  .ph-spacer { flex: 1; }

  @media (max-width: 640px) {
    .ph-topbar { height: var(--topbar-h-mobile, 48px); padding: 0 12px; }
    .ph-nav { margin-left: 8px; }
    .ph-nav a { padding: 5px 8px; }
  }
</style>
