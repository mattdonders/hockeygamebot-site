---
// SectionEyebrow — small tracked-uppercase section label.
// Source: .eye-red and .eye classes in Claude Design website UI kit.

interface Props {
  label: string;
  color?: 'red' | 'cyan' | 'muted';
}
const { label, color = 'red' } = Astro.props;
---
<span class={`eyebrow eyebrow--${color}`}>{label}</span>

<style>
  .eyebrow {
    display: inline-block;
    font-family: var(--font-site-body, sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .eyebrow--red  { color: var(--hgb-red, #E8002D); }
  .eyebrow--cyan { color: var(--status-live, #00e5ff); }
  .eyebrow--muted { color: var(--site-muted, #555); }
</style>
