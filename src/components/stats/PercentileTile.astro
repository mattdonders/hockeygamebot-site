---
// PercentileTile — analytics percentile cell for the stats site.
// Background color encodes the percentile (the tile IS the visualization).
// Gradient stops match _GRADIENT_STOPS[mode] in generate_player_grid_card.py
// exactly, so site tiles agree visually with Python card exports.
//
// Dark piecewise:  0–50: poor(232,0,45)→neutral(58,58,66)  50–100: neutral→elite(0,192,120)
// Light piecewise: 0–50: poor(232,0,45)→neutral(207,206,198) 50–100: neutral→elite(0,168,107)

interface Props {
  label: string;
  /** Formatted raw value to display large (e.g. "+2.85", "1.84"). */
  rawVal: string;
  /** Percentile 0–100. Drives background + text color. */
  pct: number;
  /** Selects gradient stop set. Must match page data-mode. Defaults "dark". */
  mode?: 'dark' | 'light';
}

const { label, rawVal, pct, mode = 'dark' } = Astro.props;

// Gradient stops keyed by mode — source: _GRADIENT_STOPS in generate_player_grid_card.py
const STOPS = {
  dark:  { poor: [232, 0, 45], neutral: [58, 58, 66],   elite: [0, 192, 120] },
  light: { poor: [232, 0, 45], neutral: [207, 206, 198], elite: [0, 168, 107] },
} as const;

function tileColors(p: number, m: 'dark' | 'light'): { bg: string; text: string } {
  const clamped = Math.max(0, Math.min(100, p));
  const { poor, neutral, elite } = STOPS[m];

  let a: readonly number[], b: readonly number[], t: number;
  if (clamped <= 50) {
    t = clamped / 50;
    a = poor; b = neutral;
  } else {
    t = (clamped - 50) / 50;
    a = neutral; b = elite;
  }

  const r  = Math.round(a[0] + (b[0] - a[0]) * t);
  const g  = Math.round(a[1] + (b[1] - a[1]) * t);
  const bl = Math.round(a[2] + (b[2] - a[2]) * t);

  // Rec. 709 approximate luminance — matches Python card _gradient_color()
  const lum = 0.2126 * r + 0.7152 * g + 0.0722 * bl;
  const text = lum > 150 ? '#0d0d14' : '#efeee8';
  const bg = `#${r.toString(16).padStart(2, '0')}${g.toString(16).padStart(2, '0')}${bl.toString(16).padStart(2, '0')}`;

  return { bg, text };
}

const { bg, text } = tileColors(pct, mode);
const pctLabel = `${Math.round(pct)}`;
---
<div class="ptile" style={`background:${bg}; color:${text};`}>
  <span class="ptile-label">{label}</span>
  <span class="ptile-val">{rawVal}</span>
  <span class="ptile-pct">{pctLabel}</span>
</div>

<style>
  .ptile {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 10px 12px 8px;
    border-radius: var(--radius-sm, 2px);
    min-height: 88px;
    font-family: var(--font-card-display, 'Barlow Condensed', sans-serif);
  }

  .ptile-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.75;
    line-height: 1;
  }

  .ptile-val {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    text-align: center;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ptile-pct {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    opacity: 0.65;
    text-align: right;
    line-height: 1;
  }

  .ptile-pct::after { content: 'th'; font-size: 8px; }
</style>
