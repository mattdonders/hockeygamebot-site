---
// PercentileTile — analytics percentile cell for the stats site.
// Background color encodes the percentile (the tile IS the visualization).
//
// 5-segment piecewise (2024-04 site revision): stretches the green zone so
// outlier players (97-100th) feel rare vs. merely-good (75-90th).
// Dark-mode tiles add a glow at 97th+ to signal "legendary" status.
//
// Text colors are FIXED per mode (not derived from tile bg luminance).
// Dark mode: dark forest label/pct + near-white value. Light mode: dark-with-opacity
// label/pct + pure dark value. This eliminates chromatic noise from the bg-luminance
// switch that would otherwise fire in the elite→legendary transition range.
//
// Trade-off: dark-mode label/pct are low-contrast on dark-tier tiles (poor/neutral).
// The value number (near-white) remains readable everywhere — acceptable for those tiers.
//
// TODO: Update _GRADIENT_STOPS in generate_player_grid_card.py to match these
// stops; the Python card currently uses the old 2-stop table and will drift.

interface Props {
  label: string;
  /** Formatted raw value to display large (e.g. "+2.85", "1.84"). */
  rawVal: string;
  /** Percentile 0–100. Drives background color. */
  pct: number;
  /** Selects gradient stop set. Must match page data-mode. Defaults "dark". */
  mode?: 'dark' | 'light';
}

const { label, rawVal, pct, mode = 'dark' } = Astro.props;

// 6-stop table. Breakpoints: 0 | 50 | 75 | 90 | 97 | 100
// Light stops are cream-calibrated (~20% desaturated) so greens sit well on #efeee8.
const STOPS = {
  dark: {
    poor:      [232,   0,  45],   // 0th   — brand red
    neutral:   [ 58,  58,  66],   // 50th  — dark panel gray
    muted:     [  0, 110,  82],   // 75th  — muted teal-green
    mid:       [  0, 158, 100],   // 90th  — medium green
    elite:     [  0, 192, 120],   // 97th  — bright green
    legendary: [  0, 215, 135],   // 100th — rare/celebratory
  },
  light: {
    poor:      [232,   0,  45],
    neutral:   [207, 206, 198],   // 50th  — warm gray (matches cream)
    muted:     [ 42, 140,  96],   // 75th  — desaturated teal
    mid:       [ 22, 152,  97],   // 90th  — muted mid-green
    elite:     [  8, 160, 100],   // 97th  — muted bright green
    legendary: [  3, 172, 108],   // 100th — cream-compatible celebratory
  },
} as const;

function tileColors(p: number, m: 'dark' | 'light'): { bg: string; glow: boolean } {
  const clamped = Math.max(0, Math.min(100, p));
  const s = STOPS[m];

  let a: readonly number[], b: readonly number[], t: number;
  if      (clamped <=  50) { a = s.poor;    b = s.neutral;   t = clamped / 50; }
  else if (clamped <=  75) { a = s.neutral; b = s.muted;     t = (clamped -  50) / 25; }
  else if (clamped <=  90) { a = s.muted;   b = s.mid;       t = (clamped -  75) / 15; }
  else if (clamped <=  97) { a = s.mid;     b = s.elite;     t = (clamped -  90) /  7; }
  else                      { a = s.elite;  b = s.legendary; t = (clamped -  97) /  3; }

  const r  = Math.round(a[0] + (b[0] - a[0]) * t);
  const g  = Math.round(a[1] + (b[1] - a[1]) * t);
  const bl = Math.round(a[2] + (b[2] - a[2]) * t);
  const bg = `#${r.toString(16).padStart(2, '0')}${g.toString(16).padStart(2, '0')}${bl.toString(16).padStart(2, '0')}`;

  return { bg, glow: clamped >= 97 };
}

// Fixed text colors per mode — decoupled from tile background.
// Dark: dark forest label + near-white value (hero number).
// Light: dark-with-opacity label + pure dark value.
const TEXT = {
  // Dark: opaque deep forest (#001f14) — ~7:1 simplified ratio against legendary green.
  // Opacity-based label was blending into bright green bg and losing contrast.
  dark:  { label: '#001f14',                value: '#efeee8',  pct: 'rgba(0, 31, 20, 0.72)'  },
  light: { label: 'rgba(13, 13, 20, 0.58)', value: '#0d0d14',  pct: 'rgba(13, 13, 20, 0.52)' },
} as const;

const { bg, glow } = tileColors(pct, mode);
const tc = TEXT[mode];
const tileStyle = (glow && mode === 'dark')
  ? `background:${bg}; box-shadow: 0 0 12px ${bg}40;`
  : `background:${bg};`;
const pctRounded = Math.round(pct);
const m10 = pctRounded % 10, m100 = pctRounded % 100;
const pctSuffix = (m100 >= 11 && m100 <= 13) ? 'TH'
  : m10 === 1 ? 'ST'
  : m10 === 2 ? 'ND'
  : m10 === 3 ? 'RD'
  : 'TH';
---
<div class="ptile" style={tileStyle}>
  <span class="ptile-label" style={`color:${tc.label};`}>{label}</span>
  <span class="ptile-val"   style={`color:${tc.value};`}>{rawVal}</span>
  <span class="ptile-pct"   style={`color:${tc.pct};`}>{pctRounded}<span class="ptile-pct-sup">{pctSuffix}</span></span>
</div>

<style>
  .ptile {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 10px 12px 8px;
    border-radius: var(--radius-sm, 2px);
    min-height: 88px;
    font-family: var(--font-card-display, 'Barlow Condensed', sans-serif);
  }

  .ptile-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    line-height: 1;
    /* opacity handled via rgba in inline color — not here */
  }

  .ptile-val {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    text-align: center;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ptile-pct {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-align: right;
    line-height: 1;
    /* opacity handled via rgba in inline color — not here */
  }

  .ptile-pct-sup { font-size: 10px; }
</style>
