---
/**
 * Anti-FOUC script — shared across /stats/** pages.
 *
 * Sets `document.documentElement.dataset.mode` BEFORE CSS evaluates so the
 * correct light/dark palette paints on first frame — zero flash.
 *
 * Contract
 * --------
 *   1. Read `localStorage['hgb-mode']` (user preference).
 *   2. Fall back to `prefers-color-scheme` (system preference).
 *   3. Fall back to 'dark' on any error (Safari private-mode localStorage
 *      throws a SecurityError; keep the try/catch for that path).
 *
 * Must remain inline (`is:inline`) — a separate <script src> defeats the
 * point by deferring execution past the first paint.
 *
 * Include once per page in <head>, BEFORE any stylesheet.
 */
---
<script is:inline>
  (function() {
    try {
      var saved = localStorage.getItem('hgb-mode');
      var system = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      document.documentElement.dataset.mode = saved || system;
    } catch (_) {
      document.documentElement.dataset.mode = 'dark';
    }
  })();
</script>
