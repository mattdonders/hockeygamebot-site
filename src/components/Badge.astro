---
/**
 * Badge.astro — Canonical Category Badge Component
 * ============================================================
 * Display-only labels for classifying content: game state, article
 * tags, broadcast type, milestone type, strength state, etc.
 * NOT interactive — never clickable. For interactive chips, use
 * ChipGroup.astro instead.
 *
 * Replaces 7+ inline badge variant patterns found in the
 * 2026-05-27 chips/pills/badges audit.
 *
 * CANONICAL SPEC: hgb-docs/CHIPS.md (sections 4, 7)
 * COLOR/TYPOGRAPHY: hgb-docs/BRAND.md (§1, §2) and BRAND_LIGHT.md
 *
 * USAGE
 * --------------------------------------------------------------
 *   <!-- Default outlined badge -->
 *   <Badge label="5v5" />
 *
 *   <!-- Solid / emphasis -->
 *   <Badge kind="solid" label="PP" />
 *
 *   <!-- Live game indicator -->
 *   <Badge kind="live" label="LIVE" />
 *
 *   <!-- Milestone badge -->
 *   <Badge kind="mile" label="50 GOALS" />
 *
 *   <!-- Momentum hot/cold -->
 *   <Badge kind="hot"  label="+3 STREAK" />
 *   <Badge kind="cold" label="L5" />
 *
 *   <!-- Custom class for layout spacing -->
 *   <Badge kind="ot" label="OT" className="my-badge" />
 *
 * KIND REFERENCE
 * --------------------------------------------------------------
 *   default  → outlined, muted text (generic content type)
 *   solid    → black bg, white text (emphasis / primary)
 *   red      → red bg, white text (alert / HGB-branded)
 *   hot      → green tint, green text (positive momentum)
 *   cold     → red tint, red text (negative momentum)
 *   ot       → orange tint, orange text (OT/SO qualifier)
 *   live     → cyan tint, cyan text (live game)
 *   final    → muted outlined (final game state)
 *   mile     → gold tint, gold text (milestone achievement)
 *   matchup  → black bg, white text, smaller (strength line items)
 */

type BadgeKind =
  | 'default'
  | 'solid'
  | 'red'
  | 'hot'
  | 'cold'
  | 'ot'
  | 'live'
  | 'final'
  | 'mile'
  | 'matchup';

interface Props {
  /** Visual treatment. Default: 'default' (outlined, muted). */
  kind?: BadgeKind;
  label: string;
  className?: string;
}

const { kind = 'default', label, className } = Astro.props;
const cls = ['cat-badge', kind !== 'default' ? `cat-badge--${kind}` : '', className]
  .filter(Boolean)
  .join(' ');
---

<span class={cls}>{label}</span>

<style is:global>
  /* GLOBAL — mirrors Table.astro/ChipGroup.astro/StatusPill.astro pattern.
     Class names are namespaced to `.cat-badge` to avoid collisions with
     any existing `.badge` utility class. See CHIPS.md §4 for the full spec. */

  .cat-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--body);        /* Barlow — condensed is unreadable at 10px */
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid var(--ink-14);
    color: var(--ink-48);
    background: transparent;
    line-height: 1;
    border-radius: 0;               /* Sharp corners — HGB editorial geometry */
  }

  /* ── Kind modifiers ──────────────────────────────────────────────────────── */

  /* solid — inverted: dark bg, light text. Used for emphasis / active state. */
  .cat-badge--solid {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }

  /* red — HGB brand red. Used for alerts, negative states, brand-first tags. */
  .cat-badge--red {
    background: var(--red);
    color: #fff;
    border-color: var(--red);
  }

  /* hot — positive momentum, streaks, performance upside. */
  .cat-badge--hot {
    color: var(--status-goal, #00E676);
    border-color: rgba(0, 230, 118, 0.4);
    background: rgba(0, 230, 118, 0.06);
  }

  /* cold — negative momentum, struggles, performance downside. */
  .cat-badge--cold {
    color: var(--red, #E8002D);
    border-color: rgba(232, 0, 45, 0.4);
    background: rgba(232, 0, 45, 0.06);
  }

  /* ot — overtime / shootout qualifier. Orange tone matches status-ot. */
  .cat-badge--ot {
    color: var(--status-ot, #FF9800);
    border-color: rgba(255, 152, 0, 0.4);
    background: rgba(255, 152, 0, 0.07);
  }

  /* live — live game indicator on tiles and cards. Cyan matches status-live. */
  .cat-badge--live {
    color: var(--status-live, #00E5FF);
    border-color: rgba(0, 229, 255, 0.4);
    background: rgba(0, 229, 255, 0.05);
  }

  /* final — completed game state. Subtle — game is done, not prominent. */
  .cat-badge--final {
    color: var(--status-final, var(--ink-48));
    border-color: var(--ink-14);
  }

  /* mile — milestone achievement. Gold tone signals accomplishment. */
  .cat-badge--mile {
    color: #b08400;
    border-color: rgba(255, 213, 74, 0.4);
    background: rgba(255, 213, 74, 0.08);
  }

  /* matchup — compact inline strength/matchup label (e.g., "5v5", "PP").
     Slightly smaller and tighter than the default badge. */
  .cat-badge--matchup {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
    font-size: 9px;
    padding: 2px 7px;
  }
</style>
