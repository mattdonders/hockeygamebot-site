---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const links = [
  { href: '/stats/explore',      label: 'Labs'         },
  { href: '/stats/edge-compare', label: 'Edge Compare' },
  { href: '/cards',              label: 'Studio'       },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<nav class="explore-subnav" aria-label="Explore section">
  <div class="explore-subnav-inner">
    {links.map(l => (
      <a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a>
    ))}
  </div>
</nav>

<style>
.explore-subnav {
  background: var(--surface, #fff);
  border-bottom: 1px solid var(--ink-14, rgba(13,13,20,0.14));
  overflow-x: auto;
}
.explore-subnav-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}
.explore-subnav a {
  font-family: var(--body);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 8px 14px;
  border: 1px solid var(--ink-14, rgba(13,13,20,0.14));
  border-right: none;
  color: var(--ink-48, rgba(13,13,20,0.48));
  white-space: nowrap;
  text-decoration: none;
  transition: background 0.1s, color 0.1s;
}
.explore-subnav a:last-child {
  border-right: 1px solid var(--ink-14, rgba(13,13,20,0.14));
}
.explore-subnav a:hover {
  background: var(--ink-06, rgba(13,13,20,0.06));
  color: var(--ink, #0d0d14);
}
.explore-subnav a.active {
  background: var(--ink, #0d0d14);
  color: var(--bg, #EFEEE8);
  border-color: var(--ink, #0d0d14);
}
@media (max-width: 640px) {
  .explore-subnav-inner { padding: 0 16px; }
  .explore-subnav a { padding: 7px 10px; font-size: 9px; }
}
</style>
