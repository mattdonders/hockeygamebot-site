---
/**
 * SkaterTableV2.astro — Demo wrapper proving HGBTable works with real skater data.
 *
 * Passes the same player data as /stats/skaters to HGBTable, wiring up:
 *   - Sorting (default: Points desc)
 *   - Chips filter (All / Fwds / Def)
 *   - Number-min filter (Min GP)
 *   - Global search (name + team)
 *   - Row click → /stats/player/:slug
 *   - CSV export
 *   - defaultHidden columns (WAR, Rating)
 *   - mobileHidden columns (Goals, Assists, TOI, S/60, WAR)
 */
import type { PlayerSummary } from '../../lib/stats-loader';
import SkaterTableV2Island from './SkaterTableV2Island';

interface Props {
  players: PlayerSummary[];
}

const { players } = Astro.props;

// Shape into a serializable format for the React island
const rows = players.map(p => ({
  display_name: p.display_name,
  team_abbrev:  p.team_abbrev,
  pos:          p.pos,
  pos_group:    p.pos_group as 'F' | 'D',
  gp:           p.gp,
  goals:        p.goals ?? 0,
  assists:      p.assists ?? 0,
  points:       (p.goals ?? 0) + (p.assists ?? 0),
  toi_avg_sec:  p.toi_avg_sec,
  ixg60:        p.rates_per_60?.ixg ?? 0,
  shots60:      p.rates_per_60?.shots ?? 0,
  hgb_war:      p.war ?? null,
  hgb_rating_percentile: p.hgb_rating_percentile ?? null,
  slug:         p.slug,
}));
---

<SkaterTableV2Island data={rows} client:load />
