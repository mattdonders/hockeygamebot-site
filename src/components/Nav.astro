---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function active(href: string): string {
  if (href === '/') return currentPath === '/' ? 'active' : '';
  // /stats is active for both /stats/* and /analytics/*
  if (href === '/stats') {
    return currentPath.startsWith('/stats') || currentPath.startsWith('/analytics') ? 'active' : '';
  }
  return currentPath.startsWith(href) ? 'active' : '';
}
---

<nav class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="wordmark">Hockey<span class="dot"></span>Gamebot</a>
    <div class="nav-status" id="nav-status" style="display:none">
      <span class="pip" id="nav-pip"></span>
      <span id="nav-status-text"></span>
    </div>
    <nav class="nav-links">
      <a href="/" class={active('/')}>Home</a><span class="sep"> · </span>
      <a href="/scoreboard" class={active('/scoreboard')}>Scoreboard</a><span class="sep"> · </span>
      <a href="/playoffs/2026" class={active('/playoffs')}>Playoffs</a><span class="sep"> · </span>
      <a href="/stats" class={active('/stats')}>Stats</a><span class="sep"> · </span>
      <a href="/cards" class={active('/cards')}>Cards</a><span class="sep"> · </span>
      <a href="/teams" class={active('/teams')}>Teams</a><span class="sep"> · </span>
      <a href="/support" class={active('/support')}>Support</a><span class="sep"> · </span>
      <a href="/account" class={active('/account')}>Account</a>
    </nav>
  </div>
</nav>

<style is:global>
.nav {
  background: var(--bg);
  border-bottom: 1px solid var(--ink-14);
  position: sticky;
  top: 0;
  z-index: 50;
}
.nav .wrap.nav-inner {
  display: flex;
  align-items: center;
  height: 60px;
}
.wordmark {
  font-family: var(--display);
  font-weight: 800;
  font-size: 21px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  display: inline-flex;
  align-items: center;
  line-height: 1;
  color: var(--ink);
  text-decoration: none;
}
.wordmark .dot {
  width: 6px;
  height: 6px;
  background: var(--red);
  border-radius: 50%;
  margin: 0 7px;
  display: inline-block;
  transform: translateY(-1px);
}
.nav-status {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  margin-left: 20px;
  font-family: var(--mono);
  font-size: 10.5px;
  color: var(--ink-48);
  letter-spacing: 0.04em;
}
.nav-status .pip {
  width: 6px;
  height: 6px;
  background: var(--red);
  border-radius: 50%;
  animation: nav-pip-pulse 1.4s infinite;
}
@keyframes nav-pip-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.25; }
}
.nav-links {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 0;
  font-family: var(--body);
  font-weight: 600;
  font-size: 11.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.nav-links a {
  padding: 5px 12px;
  color: var(--ink-48);
  text-decoration: none;
  transition: color .15s;
}
.nav-links a:hover,
.nav-links a.active { color: var(--ink); }
.nav-links .sep { color: var(--ink-20); }

@media (max-width: 768px) {
  .nav-links { display: none; }
}
</style>
