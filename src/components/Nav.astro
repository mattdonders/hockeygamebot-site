---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function active(href: string): string {
  if (href === '/') return currentPath === '/' ? 'active' : '';
  return currentPath.startsWith(href) ? 'active' : '';
}

const statsActive = active('/stats') ? 'active' : '';
---

<nav class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="wordmark">Hockey<span class="dot"></span>Gamebot</a>
    <div class="nav-status" id="nav-status" style="display:none">
      <span class="pip" id="nav-pip"></span>
      <span id="nav-status-text"></span>
    </div>

    <!-- Desktop nav -->
    <nav class="nav-links" id="nav-links">
      <a href="/" class={active('/')}>Home</a><span class="sep"> · </span>
      <a href="/scoreboard" class={active('/scoreboard')}>Scoreboard</a><span class="sep"> · </span>
      <a href="/playoffs/2026" class={active('/playoffs')}>Playoffs</a><span class="sep"> · </span>

      <!-- Stats dropdown -->
      <div class={`nav-dropdown ${statsActive}`}>
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          Stats <span class="nav-caret">▾</span>
        </button>
        <div class="nav-dropdown-menu" role="menu">
          <a href="/stats" role="menuitem">Overview</a>
          <a href="/stats/leaderboards" role="menuitem">Leaderboards</a>
          <a href="/stats/lines" role="menuitem">Lines</a>
          <a href="/stats/wowy" role="menuitem">WOWY</a>
          <a href="/stats/interactive" role="menuitem" class="nav-dropdown-beta">Interactive <span class="beta-pill">beta</span></a>
        </div>
      </div>
      <span class="sep"> · </span>

      <a href="/cards" class={active('/cards')}>Cards</a><span class="sep"> · </span>
      <a href="/teams" class={active('/teams')}>Teams</a><span class="sep"> · </span>
      <a href="/support" class={active('/support')}>Support</a><span class="sep"> · </span>
      <a href="/account" class={active('/account')}>Account</a>
    </nav>

    <!-- Mobile hamburger -->
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
    <a href="/" class={active('/')}>Home</a>
    <a href="/scoreboard" class={active('/scoreboard')}>Scoreboard</a>
    <a href="/playoffs/2026" class={active('/playoffs')}>Playoffs</a>
    <div class="nav-mobile-group">
      <span class="nav-mobile-label">Stats</span>
      <a href="/stats" class={active('/stats') && currentPath === '/stats' ? 'active' : ''}>Overview</a>
      <a href="/stats/leaderboards" class={active('/stats/leaderboards')}>Leaderboards</a>
      <a href="/stats/lines" class={active('/stats/lines')}>Lines</a>
      <a href="/stats/wowy" class={active('/stats/wowy')}>WOWY</a>
      <a href="/stats/interactive" class={active('/stats/interactive')}>Interactive</a>
    </div>
    <a href="/cards" class={active('/cards')}>Cards</a>
    <a href="/teams" class={active('/teams')}>Teams</a>
    <a href="/support" class={active('/support')}>Support</a>
    <a href="/account" class={active('/account')}>Account</a>
  </div>
</nav>

<style is:global>
/* ── Base nav ── */
.nav {
  background: var(--bg);
  border-bottom: 1px solid var(--ink-14);
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav .wrap.nav-inner {
  display: flex;
  align-items: center;
  height: 60px;
}
.wordmark {
  font-family: var(--display);
  font-weight: 800;
  font-size: 21px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  display: inline-flex;
  align-items: center;
  line-height: 1;
  color: var(--ink);
  text-decoration: none;
  flex-shrink: 0;
}
.wordmark .dot {
  width: 6px; height: 6px;
  background: var(--red);
  border-radius: 50%;
  margin: 0 7px;
  display: inline-block;
  transform: translateY(-1px);
}
.nav-status {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  margin-left: 20px;
  font-family: var(--mono);
  font-size: 10.5px;
  color: var(--ink-48);
  letter-spacing: 0.04em;
}
.nav-status .pip {
  width: 6px; height: 6px;
  background: var(--red);
  border-radius: 50%;
  animation: nav-pip-pulse 1.4s infinite;
}
@keyframes nav-pip-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.25; }
}

/* ── Desktop nav links ── */
.nav-links {
  margin-left: auto;
  display: flex;
  align-items: center;
  font-family: var(--body);
  font-weight: 600;
  font-size: 11.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.nav-links > a {
  padding: 5px 12px;
  color: var(--ink-48);
  text-decoration: none;
  transition: color .15s;
}
.nav-links > a:hover,
.nav-links > a.active { color: var(--ink); }
.nav-links .sep { color: var(--ink-20); }

/* ── Stats dropdown ── */
.nav-dropdown {
  position: relative;
  display: inline-flex;
  align-items: center;
}
.nav-dropdown-trigger {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 12px;
  color: var(--ink-48);
  background: none;
  border: none;
  cursor: pointer;
  font-family: var(--body);
  font-weight: 600;
  font-size: 11.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: color .15s;
}
.nav-dropdown-trigger:hover,
.nav-dropdown.active .nav-dropdown-trigger { color: var(--ink); }
.nav-caret {
  font-size: 9px;
  opacity: 0.5;
  transition: transform .15s;
}
.nav-dropdown.open .nav-caret { transform: rotate(180deg); }

.nav-dropdown-menu {
  display: none;
  position: absolute;
  top: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  min-width: 160px;
  background: var(--surface);
  border: 1.5px solid var(--ink-14);
  box-shadow: 0 4px 16px var(--ink-10);
  z-index: 200;
  flex-direction: column;
}
.nav-dropdown.open .nav-dropdown-menu { display: flex; }
.nav-dropdown-menu a {
  padding: 10px 16px;
  color: var(--ink-56);
  font-family: var(--body);
  font-weight: 600;
  font-size: 11.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  transition: background .1s, color .1s;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 8px;
}
.nav-dropdown-menu a:hover { background: var(--bg); color: var(--ink); }
.nav-dropdown-menu a.active { color: var(--ink); }
.beta-pill {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.08em;
  padding: 1px 5px;
  background: var(--ink-10);
  color: var(--ink-48);
  text-transform: uppercase;
}

/* ── Hamburger button ── */
.nav-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 36px;
  height: 36px;
  margin-left: auto;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
}
.nav-hamburger span {
  display: block;
  height: 2px;
  background: var(--ink);
  border-radius: 1px;
  transition: transform .2s, opacity .2s;
}
.nav-hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.nav-hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── Mobile menu ── */
.nav-mobile {
  display: none;
  flex-direction: column;
  border-top: 1px solid var(--ink-14);
  background: var(--bg);
  padding: 8px 0 16px;
}
.nav-mobile.open { display: flex; }
.nav-mobile > a,
.nav-mobile-group a {
  padding: 10px 24px;
  color: var(--ink-48);
  font-family: var(--body);
  font-weight: 600;
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  transition: color .1s;
}
.nav-mobile > a:hover,
.nav-mobile > a.active,
.nav-mobile-group a:hover,
.nav-mobile-group a.active { color: var(--ink); }
.nav-mobile-group { display: flex; flex-direction: column; }
.nav-mobile-label {
  padding: 12px 24px 4px;
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-32);
}
.nav-mobile-group a { padding-left: 36px; }

/* ── Responsive ── */
@media (max-width: 768px) {
  .nav-links  { display: none; }
  .nav-hamburger { display: flex; }
}
</style>

<script>
// Dropdown toggle
document.querySelectorAll('.nav-dropdown').forEach(dropdown => {
  const trigger = dropdown.querySelector('.nav-dropdown-trigger');
  trigger?.addEventListener('click', e => {
    e.stopPropagation();
    dropdown.classList.toggle('open');
    trigger.setAttribute('aria-expanded', String(dropdown.classList.contains('open')));
  });
});

// Hamburger toggle
const hamburger = document.getElementById('nav-hamburger');
const mobileMenu = document.getElementById('nav-mobile');
hamburger?.addEventListener('click', () => {
  const open = mobileMenu?.classList.toggle('open');
  hamburger.setAttribute('aria-expanded', String(!!open));
});

// Close dropdown + mobile on outside click
document.addEventListener('click', () => {
  document.querySelectorAll('.nav-dropdown.open').forEach(d => {
    d.classList.remove('open');
    d.querySelector('.nav-dropdown-trigger')?.setAttribute('aria-expanded', 'false');
  });
});
</script>
