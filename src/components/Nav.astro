---
import { STATS_NAV_ITEMS, STATS_NAV_GROUP_LABELS, type StatsNavGroupId, isStatsNavItemActive, isStatsSectionActive } from '../lib/stats-nav';

const DROPDOWN_GROUPS: StatsNavGroupId[] = ['core', 'tools', 'history', 'studio', 'pwhl'];
const statsDropdownGroups = DROPDOWN_GROUPS
  .map(g => ({ label: STATS_NAV_GROUP_LABELS[g], items: STATS_NAV_ITEMS.filter(i => i.group === g) }))
  .filter(g => g.items.length > 0);

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function active(href: string): string {
  if (href === '/') return currentPath === '/' ? 'active' : '';
  return currentPath.startsWith(href) ? 'active' : '';
}

const statsActive = isStatsSectionActive(currentPath) ? 'active' : '';
const gamesActive = (active('/scoreboard') || active('/results') || active('/puck-passport')) ? 'active' : '';
const analysisActive = (active('/analysis') || active('/methodology')) ? 'active' : '';
const projectionsActive = (active('/projections') || active('/playoffs')) ? 'active' : '';
---

<!-- Flash prevention: read localStorage before first paint to avoid FOUC -->
<script is:inline>
  (function() {
    try {
      // Dark mode disabled until full pass is complete — force light for all visitors
      document.documentElement.setAttribute('data-theme', 'light');
    } catch(e) {
      document.documentElement.setAttribute('data-theme', 'light');
    }
  })();
</script>

<nav class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="wordmark">hockey<span style="color: var(--hgb-red)">gamebot</span></a>
    <div class="nav-status" id="nav-status" style="display:none">
      <span class="pip" id="nav-pip"></span>
      <span id="nav-status-text"></span>
    </div>

    <!-- Desktop nav -->
    <nav class="nav-links" id="nav-links">
      <a href="/" class={active('/')}>Home</a><span class="sep"> · </span>

      <!-- Games dropdown -->
      <div class={`nav-dropdown ${gamesActive}`}>
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          Games <span class="nav-caret">▾</span>
        </button>
        <div class="nav-dropdown-menu" role="menu">
          <a href="/results" role="menuitem" class={active('/results')}>Recent Games</a>
          <a href="/scoreboard" role="menuitem" class={active('/scoreboard')}>Live Scoreboard</a>
          <a href="/puck-passport" role="menuitem" class={active('/puck-passport')}>Puck Passport</a>
        </div>
      </div>
      <span class="sep"> · </span>

      <!-- Projections dropdown -->
      <div class={`nav-dropdown ${projectionsActive}`}>
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          Projections <span class="nav-caret">▾</span>
        </button>
        <div class="nav-dropdown-menu" role="menu">
          <a href="/projections" role="menuitem" class={active('/projections')}>Season Projections</a>
          <a href="/playoffs/2026" role="menuitem" class={active('/playoffs')}>Playoff Projections</a>
        </div>
      </div>
      <span class="sep"> · </span>

      <!-- Stats dropdown -->
      <div class={`nav-dropdown ${statsActive}`}>
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          Stats <span class="nav-caret">▾</span>
        </button>
        <div class="nav-dropdown-menu" role="menu">
          {statsDropdownGroups.map(({ label, items }) => (
            <Fragment>
              <span class="dd-group-label">{label}</span>
              {items.map(item => (
                <a href={item.href} role="menuitem" class={isStatsNavItemActive(item, currentPath) ? 'active' : ''}>
                  {item.label}{item.badge && <span class="beta-pill">{item.badge}</span>}
                </a>
              ))}
            </Fragment>
          ))}
        </div>
      </div>
      <span class="sep"> · </span>

      <!-- Analysis dropdown -->
      <div class={`nav-dropdown ${analysisActive}`}>
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          Analysis <span class="nav-caret">▾</span>
        </button>
        <div class="nav-dropdown-menu" role="menu">
          <a href="/analysis" role="menuitem" class={active('/analysis')}>Articles</a>
          <a href="/methodology" role="menuitem" class={active('/methodology')}>Methodology</a>
        </div>
      </div>
      <span class="sep"> · </span>

      <a href="/teams" class={active('/teams')}>Teams</a><span class="sep"> · </span>
      <a href="/support" class={active('/support')}>Support</a><span class="sep"> · </span>
      <a href="/account" class={active('/account')}>Account</a>

      <!-- Theme toggle — hidden until dark mode pass is complete -->
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" style="display:none">
        <!-- Moon: shown in light mode -->
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <!-- Sun: shown in dark mode -->
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile hamburger -->
    <button class="theme-toggle theme-toggle-mobile" id="theme-toggle-mobile" aria-label="Toggle dark mode">
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
    </button>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
    <a href="/" class={active('/')}>Home</a>
    <div class="nav-mobile-group">
      <span class="nav-mobile-label">Games</span>
      <a href="/results" class={active('/results')}>Recent Games</a>
      <a href="/scoreboard" class={active('/scoreboard')}>Live Scoreboard</a>
      <a href="/puck-passport" class={active('/puck-passport')}>Puck Passport</a>
    </div>
    <div class="nav-mobile-group">
      <span class="nav-mobile-label">Projections</span>
      <a href="/projections" class={active('/projections')}>Season Projections</a>
      <a href="/playoffs/2026" class={active('/playoffs')}>Playoff Projections</a>
    </div>
    <div class="nav-mobile-group">
      <span class="nav-mobile-label">Stats</span>
      {STATS_NAV_ITEMS.map((item) => (
        <a href={item.href} class={isStatsNavItemActive(item, currentPath) ? 'active' : ''}>{item.label}</a>
      ))}
    </div>
    <div class="nav-mobile-group">
      <span class="nav-mobile-label">Analysis</span>
      <a href="/analysis" class={active('/analysis')}>Articles</a>
      <a href="/methodology" class={active('/methodology')}>Methodology</a>
    </div>
    <a href="/teams" class={active('/teams')}>Teams</a>
    <a href="/support" class={active('/support')}>Support</a>
    <a href="/account" class={active('/account')}>Account</a>
  </div>
</nav>

<style is:global>
/* ─────────────────────────────────────────────────────────────
   GLOBAL TOKEN DEFAULTS
   These are the fallback light-mode tokens. Each page's own
   :root block re-declares the same values. The dark mode
   block below (html[data-theme="dark"]) overrides both with
   higher specificity (0-1-1 > 0-0-1).
   ───────────────────────────────────────────────────────────── */
:root {
  --bg:      #EFEEE8;
  --bg-2:    #E8E7E0;
  --surface: #FFFFFF;
  --ink:     #0d0d14;
  --red:     #E8002D;

  --ink-03:  rgba(13,13,20,0.03);
  --ink-04:  rgba(13,13,20,0.04);
  --ink-06:  rgba(13,13,20,0.06);
  --ink-10:  rgba(13,13,20,0.10);
  --ink-14:  rgba(13,13,20,0.14);
  --ink-20:  rgba(13,13,20,0.20);
  --ink-32:  rgba(13,13,20,0.32);
  --ink-48:  rgba(13,13,20,0.48);
  --ink-56:  rgba(13,13,20,0.56);
  --ink-72:  rgba(13,13,20,0.72);
  --ink-86:  rgba(13,13,20,0.86);

  --display: 'Barlow Condensed', sans-serif;
  --body:    'Barlow', sans-serif;
  --mono:    'JetBrains Mono', monospace;
  --nav-height: 60px;
}

/* ─────────────────────────────────────────────────────────────
   DARK MODE OVERRIDES
   Selector specificity (0-1-1) beats any :root (0-0-1) or
   body/element definitions, so these always win when the
   attribute is set — regardless of page-level :root blocks.
   ───────────────────────────────────────────────────────────── */
html[data-theme="dark"] {
  --bg:      #1c1c1f;
  --bg-2:    #272729;   /* lifted tinted surface (was light cream) */
  --surface: #262629;
  --ink:     #ede9e1;
  --red:     #ff3d50;   /* softer on dark bg; brand red stays in logo/brand elements */

  --ink-03:  rgba(237,233,225,0.03);
  --ink-04:  rgba(237,233,225,0.04);
  --ink-06:  rgba(237,233,225,0.06);
  --ink-10:  rgba(237,233,225,0.10);
  --ink-14:  rgba(237,233,225,0.14);
  --ink-20:  rgba(237,233,225,0.20);
  --ink-32:  rgba(237,233,225,0.42);  /* bumped from 0.32 → better readability */
  --ink-48:  rgba(237,233,225,0.60);  /* bumped from 0.48 → better readability */
  --ink-56:  rgba(237,233,225,0.68);
  --ink-72:  rgba(237,233,225,0.82);
  --ink-86:  rgba(237,233,225,0.92);
}

/* ─────────────────────────────────────────────────────────────
   DARK MODE TARGETED FIXES
   Elements that use var(--ink) as a dark background surface
   (inverted card pattern: dark bg + light text) need explicit
   overrides since --ink flips to cream in dark mode.
   ───────────────────────────────────────────────────────────── */
html[data-theme="dark"] footer,
html[data-theme="dark"] .cta-card {
  background: #111113;
}

/* Positive stat green: dark #14803c is illegible on dark bg */
html[data-theme="dark"] .rapm-val.pos,
html[data-theme="dark"] .stat-val.war-pos,
html[data-theme="dark"] .peer-rapm.pos,
html[data-theme="dark"] .gl-win,
html[data-theme="dark"] .gl-imp.pos {
  color: #22c55e;
}

/* Team logo: remove the cream bg square; SVG logos read on dark card surface */
html[data-theme="dark"] .team-logo {
  background: transparent;
  border-color: transparent;
}

/* ─────────────────────────────────────────────────────────────
   THEME TOGGLE BUTTON
   ───────────────────────────────────────────────────────────── */
.theme-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  margin-left: 10px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-48);
  transition: color .15s;
  padding: 0;
  flex-shrink: 0;
}
.theme-toggle:hover { color: var(--ink); }
.theme-toggle svg { width: 15px; height: 15px; }

/* Icon visibility: moon shown in light, sun shown in dark */
.icon-sun  { display: none; }
.icon-moon { display: block; }
html[data-theme="dark"] .icon-sun  { display: block; }
html[data-theme="dark"] .icon-moon { display: none; }

/* Mobile toggle: visible only on mobile breakpoint */
.theme-toggle-mobile {
  display: none;
  margin-left: auto;
  margin-right: 4px;
}
@media (max-width: 768px) {
  .theme-toggle-mobile { display: inline-flex; }
}

/* ── Base nav ── */
.nav {
  background: var(--bg);
  border-bottom: 1px solid var(--ink-14);
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav .wrap.nav-inner {
  display: flex;
  align-items: center;
  height: var(--nav-height);
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}
@media (max-width: 480px) {
  .nav .wrap.nav-inner { padding: 0 16px; }
}
.wordmark {
  font-family: var(--display);
  font-weight: 800;
  font-size: 21px;
  letter-spacing: 0.04em;
  text-transform: lowercase;
  display: inline-flex;
  align-items: center;
  line-height: 1;
  color: var(--site-white);
  text-decoration: none;
  flex-shrink: 0;
}
.nav-status {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  margin-left: 20px;
  font-family: var(--body);  /* Barlow — nav status label text, not numeric */
  font-weight: 600;
  font-size: 10.5px;
  color: var(--ink-48);
  letter-spacing: 0.04em;
}
.nav-status .pip {
  width: 6px; height: 6px;
  background: var(--red);
  border-radius: 50%;
  animation: nav-pip-pulse 1.4s infinite;
}
@keyframes nav-pip-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.25; }
}

/* ── Desktop nav links ── */
.nav-links {
  margin-left: auto;
  display: flex;
  align-items: center;
  font-family: var(--body);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.nav-links > a {
  padding: 5px 12px;
  color: var(--ink-48);
  text-decoration: none;
  transition: color .15s;
}
.nav-links > a:hover,
.nav-links > a.active { color: var(--ink); }
.nav-links .sep { color: var(--ink-20); }

/* ── Stats dropdown ── */
.nav-dropdown {
  position: relative;
  display: inline-flex;
  align-items: center;
}
.nav-dropdown-trigger {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 12px;
  color: var(--ink-48);
  background: none;
  border: none;
  cursor: pointer;
  font-family: var(--body);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: color .15s;
}
.nav-dropdown-trigger:hover,
.nav-dropdown.active .nav-dropdown-trigger { color: var(--ink); }
.nav-caret {
  font-size: 9px;
  opacity: 0.5;
  transition: transform .15s;
}
.nav-dropdown.open .nav-caret { transform: rotate(180deg); }

.nav-dropdown-menu {
  display: none;
  position: absolute;
  top: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  min-width: 160px;
  background: var(--surface);
  border: 1.5px solid var(--ink-14);
  box-shadow: 0 4px 16px var(--ink-10);
  z-index: 200;
  flex-direction: column;
}
.nav-dropdown.open .nav-dropdown-menu { display: flex; }
.nav-dropdown-menu a {
  padding: 10px 16px;
  color: var(--ink-56);
  font-family: var(--body);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  transition: background .1s, color .1s;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 8px;
}
.nav-dropdown-menu a:hover { background: var(--bg); color: var(--ink); }
.nav-dropdown-menu a.active { color: var(--ink); }
.dd-group-label {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-32);
  padding: 8px 16px 4px;
  pointer-events: none;
}
.nav-dropdown-menu a + .dd-group-label {
  border-top: 1px solid var(--ink-06);
  padding-top: 10px;
  margin-top: 4px;
}
.nav-dropdown-menu {
  min-width: 180px;
}
.beta-pill {
  font-family: var(--body);  /* Barlow — badge label, not numeric */
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.08em;
  padding: 1px 5px;
  background: var(--ink-10);
  color: var(--ink-48);
  text-transform: uppercase;
}

/* ── Hamburger button ── */
.nav-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 36px;
  height: 36px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
}
.nav-hamburger span {
  display: block;
  height: 2px;
  background: var(--ink);
  border-radius: 1px;
  transition: transform .2s, opacity .2s;
}
.nav-hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.nav-hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── Mobile menu ── */
.nav-mobile {
  display: none;
  flex-direction: column;
  border-top: 1px solid var(--ink-14);
  background: var(--bg);
  padding: 8px 0 16px;
}
.nav-mobile.open { display: flex; }
.nav-mobile > a,
.nav-mobile-group a {
  padding: 10px 24px;
  color: var(--ink-48);
  font-family: var(--body);
  font-weight: 600;
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  transition: color .1s;
}
.nav-mobile > a:hover,
.nav-mobile > a.active,
.nav-mobile-group a:hover,
.nav-mobile-group a.active { color: var(--ink); }
.nav-mobile-group { display: flex; flex-direction: column; }
.nav-mobile-label {
  padding: 12px 24px 4px;
  font-family: var(--body);  /* Barlow — mobile nav group label, not numeric */
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-32);
}
.nav-mobile-group a { padding-left: 36px; }

/* ── Responsive ── */
@media (max-width: 768px) {
  .nav-links  { display: none; }
  .nav-hamburger { display: flex; }
}
</style>

<script>
// Dropdown toggle — close all others when opening one
const allDropdowns = document.querySelectorAll('.nav-dropdown');
allDropdowns.forEach(dropdown => {
  const trigger = dropdown.querySelector('.nav-dropdown-trigger');
  trigger?.addEventListener('click', e => {
    e.stopPropagation();
    const isOpen = dropdown.classList.contains('open');
    // Close all dropdowns first
    allDropdowns.forEach(d => {
      d.classList.remove('open');
      d.querySelector('.nav-dropdown-trigger')?.setAttribute('aria-expanded', 'false');
    });
    // Toggle the clicked one
    if (!isOpen) {
      dropdown.classList.add('open');
      trigger.setAttribute('aria-expanded', 'true');
    }
  });
});

// Hamburger toggle
const hamburger = document.getElementById('nav-hamburger');
const mobileMenu = document.getElementById('nav-mobile');
hamburger?.addEventListener('click', () => {
  const open = mobileMenu?.classList.toggle('open');
  hamburger.setAttribute('aria-expanded', String(!!open));
  hamburger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  mobileMenu?.setAttribute('aria-hidden', String(!open));
});

// Close dropdown + mobile on outside click
document.addEventListener('click', () => {
  document.querySelectorAll('.nav-dropdown.open').forEach(d => {
    d.classList.remove('open');
    d.querySelector('.nav-dropdown-trigger')?.setAttribute('aria-expanded', 'false');
  });
});

// Theme toggle
function applyTheme(theme: string) {
  document.documentElement.setAttribute('data-theme', theme);
  try { localStorage.setItem('hgb-theme', theme); } catch(e) {}
}

function toggleTheme() {
  const current = document.documentElement.getAttribute('data-theme');
  applyTheme(current === 'dark' ? 'light' : 'dark');
}

document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
</script>
