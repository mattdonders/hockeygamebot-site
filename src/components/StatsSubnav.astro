---
import { getStatsNavItemsForSubnav, isStatsNavItemActive } from '../lib/stats-nav';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const links = getStatsNavItemsForSubnav();
---

<nav class="stats-subnav" aria-label="Stats section">
  <div class="stats-subnav-inner">
    {links.map(l => (
      <a href={l.href} class={isStatsNavItemActive(l, currentPath) ? 'active' : ''}>
        {l.label}{l.badge && <span class="subnav-badge">{l.badge}</span>}
      </a>
    ))}
  </div>
</nav>

<style>
.stats-subnav {
  position: sticky;
  top: var(--nav-height, 60px);
  z-index: 90;
  background:
    linear-gradient(90deg, var(--surface, #fff) 30%, rgba(255,255,255,0)) left center / 28px 100% no-repeat local,
    linear-gradient(270deg, var(--surface, #fff) 30%, rgba(255,255,255,0)) right center / 28px 100% no-repeat local,
    linear-gradient(90deg, rgba(13,13,20,0.18), rgba(13,13,20,0)) left center / 16px 100% no-repeat scroll,
    linear-gradient(270deg, rgba(13,13,20,0.18), rgba(13,13,20,0)) right center / 16px 100% no-repeat scroll,
    var(--surface, #fff);
  border-bottom: 1px solid var(--ink-14, rgba(13,13,20,0.14));
  overflow-x: auto;
  scrollbar-width: none;
}
.stats-subnav::-webkit-scrollbar { display: none; }
.stats-subnav-inner {
  display: flex;
  flex-wrap: nowrap;
  gap: 0;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}
.stats-subnav a {
  font-family: var(--body);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 8px 14px;
  border: 1px solid var(--ink-14, rgba(13,13,20,0.14));
  border-right: none;
  color: var(--ink-48, rgba(13,13,20,0.48));
  white-space: nowrap;
  text-decoration: none;
  transition: background 0.1s, color 0.1s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.stats-subnav a:last-child {
  border-right: 1px solid var(--ink-14, rgba(13,13,20,0.14));
}
.stats-subnav a:hover {
  background: var(--ink-06, rgba(13,13,20,0.06));
  color: var(--ink, #0d0d14);
}
.stats-subnav a.active {
  background: var(--ink, #0d0d14);
  color: var(--bg, #EFEEE8);
  border-color: var(--ink, #0d0d14);
}
.subnav-badge {
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.08em;
  opacity: 0.65;
}
@media (max-width: 640px) {
  .stats-subnav-inner { padding: 0 16px; }
  .stats-subnav a { padding: 7px 10px; font-size: 9px; }
}
</style>
