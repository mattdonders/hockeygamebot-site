---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const links = [
  { href: '/stats/skaters', label: 'Skaters'        },
  { href: '/stats/goalies', label: 'Goalies'         },
  { href: '/stats/teams',   label: 'Teams'           },
  { href: '/stats/lines',   label: 'Lines'           },
  { href: '/stats/impact',  label: 'Impact'          },
  { href: '/stats/wowy',    label: 'WOWY'            },
  { href: '/stats/series',  label: 'Playoff Series'  },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<nav class="stats-subnav" aria-label="Stats section">
  <div class="stats-subnav-inner">
    {links.map(l => (
      <a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a>
    ))}
  </div>
</nav>

<style>
.stats-subnav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--surface, #fff);
  border-bottom: 1px solid var(--ink-14, rgba(13,13,20,0.14));
  overflow-x: auto;
  scrollbar-width: none;
}
.stats-subnav::-webkit-scrollbar { display: none; }
.stats-subnav-inner {
  display: flex;
  flex-wrap: nowrap;
  gap: 0;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}
.stats-subnav a {
  font-family: var(--body);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 8px 14px;
  border: 1px solid var(--ink-14, rgba(13,13,20,0.14));
  border-right: none;
  color: var(--ink-48, rgba(13,13,20,0.48));
  white-space: nowrap;
  text-decoration: none;
  transition: background 0.1s, color 0.1s;
}
.stats-subnav a:last-child {
  border-right: 1px solid var(--ink-14, rgba(13,13,20,0.14));
}
.stats-subnav a:hover {
  background: var(--ink-06, rgba(13,13,20,0.06));
  color: var(--ink, #0d0d14);
}
.stats-subnav a.active {
  background: var(--ink, #0d0d14);
  color: var(--bg, #EFEEE8);
  border-color: var(--ink, #0d0d14);
}
@media (max-width: 640px) {
  .stats-subnav-inner { padding: 0 16px; }
  .stats-subnav a { padding: 7px 10px; font-size: 9px; }
}
</style>
