---
import { getStatsNavGroupsForSubnav, isStatsNavItemActive } from '../lib/stats-nav';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const groups = getStatsNavGroupsForSubnav();
---

<nav class="stats-subnav" aria-label="Stats section">
  <div class="stats-subnav-inner">
    {groups.map(({ group, label, items }) => (
      <div class="sn-group">
        <span class={`sn-label${group === 'pwhl' ? ' sn-label--pwhl' : ''}`}>{label}</span>
        {items.map(item => (
          <a href={item.href} class={isStatsNavItemActive(item, currentPath) ? 'active' : ''}>
            {item.label}{item.badge && <span class="subnav-badge">{item.badge}</span>}
          </a>
        ))}
      </div>
    ))}
  </div>
</nav>

<style>
.stats-subnav {
  position: sticky;
  top: var(--nav-height, 60px);
  z-index: 90;
  background:
    linear-gradient(90deg, var(--surface, #fff) 30%, rgba(255,255,255,0)) left center / 28px 100% no-repeat local,
    linear-gradient(270deg, var(--surface, #fff) 30%, rgba(255,255,255,0)) right center / 28px 100% no-repeat local,
    linear-gradient(90deg, rgba(13,13,20,0.18), rgba(13,13,20,0)) left center / 16px 100% no-repeat scroll,
    linear-gradient(270deg, rgba(13,13,20,0.18), rgba(13,13,20,0)) right center / 16px 100% no-repeat scroll,
    var(--surface, #fff);
  border-bottom: 1px solid var(--ink-14, rgba(13,13,20,0.14));
  overflow-x: auto;
  scrollbar-width: none;
}
.stats-subnav::-webkit-scrollbar { display: none; }

.stats-subnav-inner {
  display: flex;
  flex-wrap: nowrap;
  align-items: stretch;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}

/* Group container */
.sn-group {
  display: flex;
  align-items: stretch;
  flex-shrink: 0;
}
.sn-group + .sn-group {
  border-left: 1px solid var(--ink-10, rgba(13,13,20,0.10));
  margin-left: 4px;
  padding-left: 2px;
}

/* Group label */
.sn-label {
  display: flex;
  align-items: center;
  padding: 0 6px 0 10px;
  font-family: var(--mono);
  font-size: 8.5px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-32, rgba(13,13,20,0.32));
  white-space: nowrap;
  flex-shrink: 0;
  user-select: none;
}
.sn-label--pwhl { color: #1763a0; }

/* Nav links */
.stats-subnav a {
  font-family: var(--body);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0 12px;
  height: 38px;
  color: var(--ink-48, rgba(13,13,20,0.48));
  white-space: nowrap;
  text-decoration: none;
  transition: background 0.1s, color 0.1s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.stats-subnav a:hover {
  background: var(--ink-06, rgba(13,13,20,0.06));
  color: var(--ink, #0d0d14);
}
.stats-subnav a.active {
  color: var(--ink, #0d0d14);
  box-shadow: inset 0 -2px 0 var(--red, #E8002D);
}
.subnav-badge {
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.08em;
  opacity: 0.65;
}

@media (max-width: 640px) {
  .stats-subnav-inner { padding: 0 16px; }
  .stats-subnav a { padding: 0 8px; font-size: 9px; }
  .sn-label { padding: 0 4px 0 8px; font-size: 8px; }
}
</style>
