---
interface Props {
  eyebrow: string;
  statLine?: string;
  ghost?: string;
}

const { eyebrow, statLine, ghost } = Astro.props;
---
<section class="mast">
  {ghost && <div class="mast-ghost">{ghost}</div>}
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div class="mast-eyebrow"><span class="pip"></span>{eyebrow}</div>
      {statLine && <div>{statLine}</div>}
    </div>
    <div class="mast-card">
      <h1 class="mast-headline"><slot name="headline" /></h1>
      <p class="mast-lede"><slot name="lede" /></p>
      <slot />
    </div>
  </div>
</section>
