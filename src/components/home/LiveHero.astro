---
/**
 * LiveHero — dense featured-game panel for /home-v2.
 *
 * Layer 1 shipped a 3-bar right pane (SHOTS / xG / TILT). SITE-HOME-015
 * refined it; SITE-HOME-016 polish pass follows:
 *   • Right pane is 4 bars: SHOTS · 5V5 xG · xG · ALL · WIN PROBABILITY
 *     (stat bars now flex-distribute evenly across full vertical height).
 *   • Game state (PP / EN / SO / 4v4 / 3v3) renders as the FIRST meta chip
 *     on the right side of the head row — color-coded per state type,
 *     with a subtle tint + tracked font. 5v5 (or unset) shows no chip at
 *     all; the LIVE line stays clean: `● Live · Period 2 · 08:41`.
 *   • Goal feed caps at 4-6 chips with "+ N more" overflow placeholder.
 *     Goal chips sport a running-score pill (top-right, cyan-bordered);
 *     PBP (last-events) chips use left-accent-stripe only — softer bg and
 *     smaller type so the two tiers read as visually distinct at a glance.
 *   • A persistent "Latest Activity" card occupies the rightmost footer
 *     slot regardless of goal count — pulsing cyan header, top-3 non-goal
 *     events from last_events.
 *
 * Structure:
 *   1. lh-head — LIVE cyan badge (ringPulse) + period/clock +
 *                right-aligned meta chip group (state chip FIRST, then
 *                broadcast/series chips).
 *   2. lh-body 1.2fr / 1fr grid:
 *      • lh-scoreblock: 3-col teams row + period-by-period table
 *      • lh-stats: 4 horizontal stat bars evenly distributed
 *   3. footer-strip: goal chips + PBP fill chips + Latest Activity card
 *
 * Losing team gets dim abbrev + score + 0.4-opacity/0.5-grayscale logo.
 * Active period cell in the PBP table gets cyan treatment.
 */

export interface TeamPane {
  abbrev: string;
  record: string;
  score: number;
  accent: string;
  logo: string;
  pbp: number[]; // [P1, P2, P3, OT]
}

export interface StatPair {
  home: number;
  away: number;
  unit?: string;
}

export interface GoalEntry {
  period: number;
  clock: string;
  team: string;
  scorer: string;
  goal_number?: number;
  assists: string[];
  score_after: string;
  strength?: string;
  overturned?: boolean;
  review_reason?: string;
}

/** Last-events strip (fallback when goal_feed has < 2 entries).
 *  Known `type` values: PP_START | PP_END | PK_START | PK_END |
 *  PENALTY | TIMEOUT | SHOT. Stored as a plain string to keep the
 *  .astro frontmatter cheap to parse. */
export interface LastEventEntry {
  period: number;
  clock: string;
  type: string;
  team?: string;
  player?: string;
  reason?: string;
  danger?: string; // "low" | "medium" | "high"
}

/** Inline strength-state chip on the LIVE line (null / 5v5 = hidden). */
export interface StrengthState {
  state: string;        // PP | EN | SO | 4v4 | 3v3 | 5v5
  team?: string;        // e.g. "BUF" — required for PP
  clock?: string;       // e.g. "0:47" remaining
}

export interface FeaturedGame {
  status: 'live' | 'final' | 'scheduled';
  period: number;
  clock: string;
  meta_chips: string[];
  strength_state?: StrengthState | null;
  home: TeamPane;
  away: TeamPane;
  stats: {
    shots: StatPair;
    xg_5v5: StatPair;
    xg: StatPair;
    wp: StatPair;
  };
  goal_feed: GoalEntry[];
  last_events?: LastEventEntry[];
}

interface Props {
  game: FeaturedGame;
}

const { game } = Astro.props;
const { home, away, stats } = game;

// Who's losing? Loser gets dimmed. Tie = no loser.
const homeLoser = home.score < away.score;
const awayLoser = away.score < home.score;

// Period-by-period row: show period numbers 1-3 and OT column.
// Active period gets `active` class; future periods get `dim` (shown as "–").
const PBP_COLS = [1, 2, 3, 4]; // indices 0..3 → P1, P2, P3, OT
function pbpCellClass(periodIdx: number): string {
  const period1based = periodIdx + 1;
  if (period1based === game.period) return 'cell active';
  // If the period hasn't happened yet in this game, dim it.
  if (period1based > game.period) return 'cell dim';
  return 'cell';
}
function pbpCellValue(value: number, periodIdx: number): string {
  const period1based = periodIdx + 1;
  if (period1based > game.period) return '–';
  return String(value);
}

// Bar widths: avoid divide-by-zero.
function pct(a: number, b: number): [string, string] {
  const sum = a + b;
  if (sum <= 0) return ['50%', '50%'];
  return [`${(a / sum) * 100}%`, `${(b / sum) * 100}%`];
}
const [shotsL, shotsR] = pct(stats.shots.home, stats.shots.away);
const [xg5L, xg5R] = pct(stats.xg_5v5.home, stats.xg_5v5.away);
const [xgL, xgR] = pct(stats.xg.home, stats.xg.away);
const [wpL, wpR] = pct(stats.wp.home, stats.wp.away);

function fmtClock(): string {
  return `Live · Period ${game.period} · ${game.clock}`;
}

/**
 * Resolve the right-side strength-state chip (first item in the meta
 * chip group). 5v5 and unset both suppress the chip entirely — the
 * user's eye shouldn't have to parse a "5v5 is normal" chip.
 *
 * Returned `colorVar` + `tintVar` are used for inline CSS variable
 * overrides; a single `.chip.state-chip` rule consumes them for border,
 * text, and background-tint.
 */
type StateChip = { text: string; colorVar: string; tintVar: string } | null;
function resolveStrengthChip(s?: StrengthState | null): StateChip {
  if (!s) return null;
  const state = (s.state || '').toUpperCase();
  if (!state || state === '5V5') return null;

  // Format: "TEAM STATE CLOCK" with any missing parts trimmed.
  const parts = [s.team, state, s.clock].filter(Boolean);
  const text = parts.join(' ');

  // Color rules (per SITE-HOME-016 spec):
  //   PP             → cyan (--status-live)     advantage energy
  //   EN             → orange (--status-ot)     high-stakes
  //   4v4 / 3v3      → blue (--status-intermission)
  //   SO             → red (--hgb-red)
  // tintVar is a 5%-alpha rgba of the same hue — subtle readability boost
  // without the chip screaming at the rest of the meta strip.
  let colorVar = 'var(--status-live)';
  let tintVar = 'rgba(0, 229, 255, 0.05)';
  if (state === 'EN') {
    colorVar = 'var(--status-ot)';
    tintVar = 'rgba(255, 152, 0, 0.05)';
  } else if (state === '4V4' || state === '3V3') {
    colorVar = 'var(--status-intermission)';
    tintVar = 'rgba(96, 165, 250, 0.05)';
  } else if (state === 'SO') {
    colorVar = 'var(--hgb-red)';
    tintVar = 'rgba(232, 0, 45, 0.05)';
  }

  return { text, colorVar, tintVar };
}
const stateChip = resolveStrengthChip(game.strength_state);
---
<section class="live-hero" aria-label="Featured live game">

  <!-- head row -->
  <div class="lh-head">
    <div class="badge">
      <span class="dot" aria-hidden="true"></span>
      <span>{fmtClock()}</span>
    </div>
    <div class="meta">
      {stateChip && (
        <span
          class="chip state-chip"
          style={`--sc-color:${stateChip.colorVar};--sc-tint:${stateChip.tintVar};`}
        >
          {stateChip.text}
        </span>
      )}
      {game.meta_chips.map((chip) => (
        <span class="chip">{chip}</span>
      ))}
    </div>
  </div>

  <div class="lh-body">

    <!-- score + period line -->
    <div class="lh-scoreblock">
      <div class="lh-teams">
        <div class:list={['lh-t', { loser: homeLoser }]}>
          <img src={home.logo} alt={`${home.abbrev} logo`} />
          <div class="tbl">
            <span class="abbr">{home.abbrev}</span>
            <span class="rec">{home.record}</span>
          </div>
          <span class="score">{home.score}</span>
        </div>
        <div class="lh-sep" aria-hidden="true">·</div>
        <div class:list={['lh-t', 'right', { loser: awayLoser }]}>
          <span class="score">{away.score}</span>
          <div class="tbl right">
            <span class="abbr">{away.abbrev}</span>
            <span class="rec">{away.record}</span>
          </div>
          <img src={away.logo} alt={`${away.abbrev} logo`} />
        </div>
      </div>

      <!-- period-by-period line -->
      <div class="pbp" role="table" aria-label="Period by period">
        <div class="h first"></div>
        <div class="h">1</div>
        <div class="h">2</div>
        <div class="h">3</div>
        <div class="h">OT</div>
        <div class="h">T</div>

        <div class:list={['tm', { loser: homeLoser }]}>
          <img src={home.logo} alt="" />{home.abbrev}
        </div>
        {PBP_COLS.map((_p, idx) => (
          <div class={pbpCellClass(idx)}>{pbpCellValue(home.pbp[idx] ?? 0, idx)}</div>
        ))}
        <div class="cell tot">{home.score}</div>

        <div class:list={['tm', { loser: awayLoser }]}>
          <img src={away.logo} alt="" />{away.abbrev}
        </div>
        {PBP_COLS.map((_p, idx) => (
          <div class={pbpCellClass(idx)}>{pbpCellValue(away.pbp[idx] ?? 0, idx)}</div>
        ))}
        <div class="cell tot">{away.score}</div>
      </div>
    </div>

    <!-- stats sidebar — 4 bars: SHOTS · 5V5 xG · xG · ALL · WIN PROBABILITY -->
    <div class="lh-stats">
      <div class="lh-stat">
        <div class:list={['vl', { dim: homeLoser }]}>{stats.shots.home}</div>
        <div class="lbl">Shots on Goal</div>
        <div class:list={['vr', { dim: awayLoser }]}>{stats.shots.away}</div>
        <div class="bar" style={`--hc:${home.accent};--ac:${away.accent};`}>
          <div class="l" style={`width:${shotsL};`}></div>
          <div class="r" style={`width:${shotsR};`}></div>
        </div>
      </div>

      <div class="lh-stat">
        <div class:list={['vl', { dim: homeLoser }]}>{stats.xg_5v5.home.toFixed(2)}</div>
        <div class="lbl">5v5 xG</div>
        <div class:list={['vr', { dim: awayLoser }]}>{stats.xg_5v5.away.toFixed(2)}</div>
        <div class="bar" style={`--hc:${home.accent};--ac:${away.accent};`}>
          <div class="l" style={`width:${xg5L};`}></div>
          <div class="r" style={`width:${xg5R};`}></div>
        </div>
      </div>

      <div class="lh-stat">
        <div class:list={['vl', { dim: homeLoser }]}>{stats.xg.home.toFixed(2)}</div>
        <div class="lbl">xG · All</div>
        <div class:list={['vr', { dim: awayLoser }]}>{stats.xg.away.toFixed(2)}</div>
        <div class="bar cyan">
          <div class="l" style={`width:${xgL};`}></div>
          <div class="r" style={`width:${xgR};`}></div>
        </div>
      </div>

      <div class="lh-stat">
        <div class:list={['vl', { dim: homeLoser }]}>{stats.wp.home}{stats.wp.unit ?? '%'}</div>
        <div class="lbl">Win Probability</div>
        <div class:list={['vr', { dim: awayLoser }]}>{stats.wp.away}{stats.wp.unit ?? '%'}</div>
        <div class="bar" style={`--hc:${home.accent};--ac:${away.accent};`}>
          <div class="l" style={`width:${wpL};`}></div>
          <div class="r" style={`width:${wpR};`}></div>
        </div>
      </div>
    </div>

    <!--
      Footer strip — goal chips + last-events fallback.

      Server always renders BOTH the full goal chip list (data-chip-kind="goal")
      and the full last-events list (data-chip-kind="last"). A client script
      elsewhere on the page decides the visible set based on:
         • ?goals=N query param (dev override)
         • available chip slots (cap 4-6)

      Default (no param) shows goal chips only, plus a "+ N more" placeholder
      chip in the last slot if goals overflow the cap. The last-events chips
      stay hidden. When goals < 2, last-events fill the remaining slots.
    -->
    <div
      class="goal-feed"
      aria-label="Scoring summary"
      data-max-slots="6"
      data-min-slots="4"
      data-goal-count={game.goal_feed.length}
      data-last-count={(game.last_events ?? []).length}
    >
      {game.goal_feed.map((g, idx) => (
        <div
          class:list={['goal-chip', { overturned: g.overturned }]}
          data-chip-kind="goal"
          data-chip-idx={idx}
        >
          {/* Running-score pill, top-right. For overturned: OVERTURNED
              badge replaces the score pill and takes red styling. */}
          <span class:list={['score-pill', { overturned: g.overturned }]}>
            {g.overturned ? 'OVERTURNED' : g.score_after}
          </span>
          <div class="t">
            <span>P{g.period} · {g.clock} · {g.team}</span>
          </div>
          <div class="p">
            {g.scorer}{g.goal_number ? ` (${g.goal_number})` : ''}
          </div>
          {g.overturned ? (
            <div class="rev">⊘ {g.review_reason ?? 'Reviewed'}</div>
          ) : (
            <div class="a">
              {g.assists.length > 0 ? `A: ${g.assists.join(', ')}` : 'Unassisted'}
              {g.strength ? ` · ${g.strength}` : ''}
            </div>
          )}
        </div>
      ))}

      <!-- "+ N more · open game" placeholder chip — shown when goals overflow
           the visible cap. Client script toggles display + sets data-more-n. -->
      <div
        class="goal-chip more-chip"
        data-chip-kind="more"
        data-layer3-hook="open-game-modal"
        hidden
      >
        <div class="t"><span>More</span></div>
        {/* TODO: Layer 3 — open game modal on click */}
        <div class="p">+<span data-more-n>0</span> more</div>
        <div class="a">open game</div>
      </div>

      <!-- Last-events strip (fallback). Hidden unless the visible set
           includes fewer than 2 goal chips; each chip's `data-ev-type`
           drives its colored left border via CSS attribute selectors. -->
      {(game.last_events ?? []).map((e, idx) => {
        const evType = (e.type || '').toUpperCase();
        const dangerHigh = evType === 'SHOT' && (e.danger || '').toLowerCase() === 'high';
        const evClass = dangerHigh ? `${evType}_HIGH` : evType;
        const title =
          evType === 'PP_START' ? 'POWER PLAY' :
          evType === 'PP_END'   ? 'PP ENDED'   :
          evType === 'PK_START' ? 'PENALTY KILL' :
          evType === 'PK_END'   ? 'PK ENDED'   :
          evType === 'PENALTY'  ? 'PENALTY'    :
          evType === 'TIMEOUT'  ? 'TIMEOUT'    :
          evType === 'SHOT'     ? 'SHOT'       :
          evType;
        const dangerLabel =
          dangerHigh ? 'high-danger shot' :
          (evType === 'SHOT' && e.danger) ? `${e.danger}-danger shot` : undefined;
        return (
          <div
            class="last-chip"
            data-chip-kind="last"
            data-chip-idx={idx}
            data-ev-type={evClass}
            hidden
          >
            <div class="t">
              <span>P{e.period} · {e.clock}</span>
            </div>
            <div class="p">
              {title}{e.team ? ` · ${e.team}` : ''}{e.player ? ` · ${e.player}` : ''}
            </div>
            {(e.reason || dangerLabel) && (
              <div class="a">
                {e.player && e.reason ? `${e.player} · ${e.reason}` :
                 e.reason ? e.reason :
                 dangerLabel}
              </div>
            )}
          </div>
        );
      })}
    </div>

  </div>
</section>

<style>
  .live-hero {
    background: var(--site-card);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    margin-top: 6px;
    overflow: hidden;
  }

  /* ── head ─────────────────────────────────────────────────────── */
  .lh-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 22px;
    border-bottom: 1px solid #1a1a1a;
    background: #0b0b0b;
    gap: 14px;
    flex-wrap: wrap;
  }

  .badge {
    color: var(--status-live);
    font-family: var(--font-site-body);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .badge .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--status-live);
    box-shadow: 0 0 0 0 rgba(0, 229, 255, 0.55);
    animation: ringPulse 1.8s ease-out infinite;
  }

  @keyframes ringPulse {
    0%   { box-shadow: 0 0 0 0 rgba(0, 229, 255, 0.55); }
    70%  { box-shadow: 0 0 0 10px rgba(0, 229, 255, 0); }
    100% { box-shadow: 0 0 0 0 rgba(0, 229, 255, 0); }
  }

  .meta {
    color: #666;
    font-family: var(--font-site-body);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .chip {
    border: 1px solid var(--site-border2);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    color: #bbb;
  }

  /* State chip (first in meta group) — color-coded per state type via
     per-chip CSS variable overrides. 5v5 suppresses rendering upstream. */
  .chip.state-chip {
    border-color: var(--sc-color, var(--status-live));
    color: var(--sc-color, var(--status-live));
    background: var(--sc-tint, transparent);
    font-weight: 700;
  }

  /* ── body layout ──────────────────────────────────────────────── */
  .lh-body {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 0;
  }

  .lh-scoreblock {
    padding: 26px 30px;
    border-right: 1px solid #1a1a1a;
  }

  .lh-teams {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  .lh-t {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .lh-t.right {
    justify-content: flex-end;
  }

  .lh-t img {
    width: 64px;
    height: 64px;
    flex: none;
  }

  .tbl {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tbl.right {
    text-align: right;
  }

  .lh-t .abbr {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--site-white);
    letter-spacing: 0.06em;
  }

  .lh-t .rec {
    color: #666;
    font-family: var(--font-site-body);
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .lh-t .score {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 84px;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--site-white);
    margin-left: 14px;
  }

  .lh-t.right .score {
    margin-left: 0;
    margin-right: 14px;
  }

  .lh-t.loser .abbr,
  .lh-t.loser .score {
    color: var(--site-muted);
  }

  .lh-t.loser img {
    opacity: 0.4;
    filter: grayscale(0.5);
  }

  .lh-sep {
    color: var(--site-border2);
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 42px;
    text-align: center;
  }

  /* ── period-by-period line ───────────────────────────────────── */
  .pbp {
    margin-top: 22px;
    border-top: 1px solid #1a1a1a;
    padding-top: 16px;
    display: grid;
    grid-template-columns: 1fr repeat(4, 48px) 68px;
    gap: 6px;
    align-items: center;
  }

  .pbp .h {
    color: var(--site-muted);
    font-family: var(--font-site-body);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    text-align: center;
  }
  .pbp .h.first { text-align: left; }

  .pbp .tm {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--site-white);
  }
  .pbp .tm img {
    width: 18px;
    height: 18px;
  }
  .pbp .tm.loser { color: var(--site-muted); }
  .pbp .tm.loser img { opacity: 0.35; }

  .pbp .cell {
    text-align: center;
    font-family: var(--font-site-display);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-size: 14px;
    color: #ccc;
    padding: 4px 0;
    border: 1px solid #1a1a1a;
    border-radius: var(--radius-sm);
    background: #0a0a0a;
  }
  .pbp .cell.active {
    color: var(--status-live);
    border-color: rgba(0, 229, 255, 0.35);
    box-shadow: inset 0 0 0 1px rgba(0, 229, 255, 0.12);
  }
  .pbp .cell.dim { color: #333; }
  .pbp .cell.tot {
    color: var(--site-white);
    background: #141414;
    font-size: 16px;
  }

  /* ── live sidebar ─────────────────────────────────────────────── */
  /* Stat bars distribute evenly across the full vertical height of the
     body pane — `space-evenly` gives each row equal breathing room top
     and bottom so the pane doesn't feel top-heavy at wider viewports.
     Padding mirrors the scoreblock's vertical rhythm (26px). No explicit
     gap: space-evenly handles row spacing. */
  .lh-stats {
    padding: 26px 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    background: #0c0c0c;
  }

  .lh-stat {
    display: grid;
    grid-template-columns: 52px 1fr 52px;
    align-items: center;
    row-gap: 4px;
    column-gap: 10px;
  }

  .lh-stat .vl,
  .lh-stat .vr {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-size: 17px;
    color: var(--site-white);
  }
  .lh-stat .vl { text-align: left; }
  .lh-stat .vr { text-align: right; }
  .lh-stat .vl.dim,
  .lh-stat .vr.dim { color: var(--site-muted); }

  .lh-stat .lbl {
    text-align: center;
    color: #666;
    font-family: var(--font-site-body);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .lh-stat .bar {
    grid-column: 1 / -1;
    display: flex;
    height: 5px;
    background: #151515;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  /* Team-accent split bar — colors threaded via CSS vars from team.accent */
