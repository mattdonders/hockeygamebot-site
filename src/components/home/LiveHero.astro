---
/**
 * LiveHero — dense featured-game panel for /home-v2.
 *
 * Layer 1 shipped a 3-bar right pane (SHOTS / xG / TILT). SITE-HOME-015
 * refined it; 016 added the always-on Latest Activity card; 017 collapses
 * the footer model:
 *   • Right pane is 4 bars: SHOTS · 5V5 xG · xG · ALL · WIN PROBABILITY
 *     (stat bars flex-distribute evenly across full vertical height).
 *   • Game state (PP / EN / SO / 4v4 / 3v3) renders as the FIRST meta chip
 *     on the right side of the head row — color-coded per state type,
 *     with a subtle tint + tracked font. 5v5 (or unset) suppresses the
 *     chip — the LIVE line stays clean: `● Live · Period 2 · 08:41`.
 *   • Goal feed caps at 5 visible + "+ N more" overflow placeholder.
 *     Latest Activity card absorbs whatever footer width the goals don't
 *     use — see Section B in the SITE-HOME-017 spec for the slot matrix.
 *   • The PBP-chip fallback (added in 015) is gone. Latest Activity is
 *     the canonical "what else is going on" surface; it shifts density
 *     mode (narrow / medium / wide / very-wide / max) based on slots.
 *   • Max-mode (0 visible goals) shows a header summary line on the
 *     Latest Activity card with shots + xG totals.
 *
 * Structure:
 *   1. lh-head — LIVE cyan badge (ringPulse) + period/clock +
 *                right-aligned meta chip group (state chip FIRST, then
 *                broadcast/series chips).
 *   2. lh-body 1.2fr / 1fr grid:
 *      • lh-scoreblock: 3-col teams row + period-by-period table
 *      • lh-stats: 4 horizontal stat bars evenly distributed
 *   3. footer-strip: goal chips + "+N more" + Latest Activity card
 *
 * Losing team gets dim abbrev + score + 0.4-opacity/0.5-grayscale logo.
 * Active period cell in the PBP table gets cyan treatment.
 */

export interface TeamPane {
  abbrev: string;
  record: string;
  score: number;
  accent: string;
  logo: string;
  pbp: number[]; // [P1, P2, P3, OT]
}

export interface StatPair {
  home: number;
  away: number;
  unit?: string;
}

export interface GoalEntry {
  period: number;
  clock: string;
  team: string;
  scorer: string;
  goal_number?: number;
  assists: string[];
  score_after: string;
  strength?: string;
  overturned?: boolean;
  review_reason?: string;
}

/** Latest Activity card source. Known `type` values:
 *  PP_START | PP_END | PK_START | PK_END | PENALTY | TIMEOUT | SHOT.
 *  Stored as a plain string to keep the .astro frontmatter cheap to parse. */
export interface LastEventEntry {
  period: number;
  clock: string;
  type: string;
  team?: string;
  player?: string;
  reason?: string;
  danger?: string; // "low" | "medium" | "high"
}

/** Inline strength-state chip on the LIVE line (null / 5v5 = hidden). */
export interface StrengthState {
  state: string;        // PP | EN | SO | 4v4 | 3v3 | 5v5
  team?: string;        // e.g. "BUF" — required for PP
  clock?: string;       // e.g. "0:47" remaining
}

export interface FeaturedGame {
  status: 'live' | 'final' | 'scheduled';
  period: number;
  clock: string;
  meta_chips: string[];
  strength_state?: StrengthState | null;
  home: TeamPane;
  away: TeamPane;
  stats: {
    shots: StatPair;
    xg_5v5: StatPair;
    xg: StatPair;
    wp: StatPair;
  };
  goal_feed: GoalEntry[];
  last_events?: LastEventEntry[];
}

interface Props {
  game: FeaturedGame;
}

const { game } = Astro.props;
const { home, away, stats } = game;

// Who's losing? Loser gets dimmed. Tie = no loser.
const homeLoser = home.score < away.score;
const awayLoser = away.score < home.score;

// Period-by-period row: show period numbers 1-3 and OT column.
// Active period gets `active` class; future periods get `dim` (shown as "–").
const PBP_COLS = [1, 2, 3, 4]; // indices 0..3 → P1, P2, P3, OT
function pbpCellClass(periodIdx: number): string {
  const period1based = periodIdx + 1;
  if (period1based === game.period) return 'cell active';
  // If the period hasn't happened yet in this game, dim it.
  if (period1based > game.period) return 'cell dim';
  return 'cell';
}
function pbpCellValue(value: number, periodIdx: number): string {
  const period1based = periodIdx + 1;
  if (period1based > game.period) return '–';
  return String(value);
}

// Bar widths: avoid divide-by-zero.
function pct(a: number, b: number): [string, string] {
  const sum = a + b;
  if (sum <= 0) return ['50%', '50%'];
  return [`${(a / sum) * 100}%`, `${(b / sum) * 100}%`];
}
const [shotsL, shotsR] = pct(stats.shots.home, stats.shots.away);
const [xg5L, xg5R] = pct(stats.xg_5v5.home, stats.xg_5v5.away);
const [xgL, xgR] = pct(stats.xg.home, stats.xg.away);
const [wpL, wpR] = pct(stats.wp.home, stats.wp.away);

function fmtClock(): string {
  return `Live · Period ${game.period} · ${game.clock}`;
}

/**
 * Resolve the right-side strength-state chip (first item in the meta
 * chip group). 5v5 and unset both suppress the chip entirely — the
 * user's eye shouldn't have to parse a "5v5 is normal" chip.
 *
 * Returned `colorVar` + `tintVar` are used for inline CSS variable
 * overrides; a single `.chip.state-chip` rule consumes them for border,
 * text, and background-tint.
 */
type StateChip = { text: string; colorVar: string; tintVar: string } | null;
function resolveStrengthChip(s?: StrengthState | null): StateChip {
  if (!s) return null;
  const state = (s.state || '').toUpperCase();
  if (!state || state === '5V5') return null;

  // Format: "TEAM STATE CLOCK" with any missing parts trimmed.
  const parts = [s.team, state, s.clock].filter(Boolean);
  const text = parts.join(' ');

  // Color rules (per SITE-HOME-016 spec):
  //   PP             → cyan (--status-live)     advantage energy
  //   EN             → orange (--status-ot)     high-stakes
  //   4v4 / 3v3      → blue (--status-intermission)
  //   SO             → red (--hgb-red)
  // tintVar is a 5%-alpha rgba of the same hue — subtle readability boost
  // without the chip screaming at the rest of the meta strip.
  let colorVar = 'var(--status-live)';
  let tintVar = 'rgba(0, 229, 255, 0.05)';
  if (state === 'EN') {
    colorVar = 'var(--status-ot)';
    tintVar = 'rgba(255, 152, 0, 0.05)';
  } else if (state === '4V4' || state === '3V3') {
    colorVar = 'var(--status-intermission)';
    tintVar = 'rgba(96, 165, 250, 0.05)';
  } else if (state === 'SO') {
    colorVar = 'var(--hgb-red)';
    tintVar = 'rgba(232, 0, 45, 0.05)';
  }

  return { text, colorVar, tintVar };
}
const stateChip = resolveStrengthChip(game.strength_state);

/**
 * Latest Activity card payload — full normalized list of non-goal events.
 * The page-level inline script trims the visible count + sets the column
 * count via a `data-density` attribute, so we ship up to 9 items here
 * (max-mode max). Detail fields (player, team, reason, danger) are kept
 * so denser modes can opt-in to richer rows via CSS selectors.
 */
type LatestItem = {
  period: number;
  clock: string;
  label: string;
  evClass: string;
  team?: string;
  player?: string;
  reason?: string;
};
function buildLatestItems(events: LastEventEntry[]): LatestItem[] {
  const out: LatestItem[] = [];
  for (const e of events) {
    const evType = (e.type || '').toUpperCase();
    const dangerHigh = evType === 'SHOT' && (e.danger || '').toLowerCase() === 'high';
    const evClass = dangerHigh ? `${evType}_HIGH` : evType;
    const label =
      evType === 'PP_START' ? 'POWER PLAY' :
      evType === 'PP_END'   ? 'PP ENDED'   :
      evType === 'PK_START' ? 'PENALTY KILL' :
      evType === 'PK_END'   ? 'PK ENDED'   :
      evType === 'PENALTY'  ? 'PENALTY'    :
      evType === 'TIMEOUT'  ? 'TIMEOUT'    :
      evType === 'SHOT'     ? (dangerHigh ? 'HIGH-DANGER SHOT' : 'SHOT') :
      evType;
    out.push({
      period: e.period,
      clock: e.clock,
      label,
      evClass,
      team: e.team,
      player: e.player,
      reason: e.reason,
    });
    if (out.length >= 9) break;
  }
  return out;
}
const latestItems = buildLatestItems(game.last_events ?? []);

/**
 * Max-mode summary line (rendered server-side, conditionally shown via
 * CSS when `data-density="max"`). Matches the design: shots (whole) and
 * xG (2-decimal) totals so a glance at the card answers "what's the
 * game state right now" even with zero scored content.
 */
const maxSummary = `${stats.shots.home}-${stats.shots.away} SHOTS  ·  ${stats.xg.home.toFixed(2)}-${stats.xg.away.toFixed(2)} xG`;
---
<section class="live-hero" aria-label="Featured live game">

  <!-- head row -->
  <div class="lh-head">
    <div class="badge">
      <span class="dot" aria-hidden="true"></span>
      <span>{fmtClock()}</span>
    </div>
    <div class="meta">
      {stateChip && (
        <span
          class="chip state-chip"
          style={`--sc-color:${stateChip.colorVar};--sc-tint:${stateChip.tintVar};`}
        >
          {stateChip.text}
        </span>
      )}
      {game.meta_chips.map((chip) => (
        <span class="chip">{chip}</span>
      ))}
    </div>
  </div>

  <div class="lh-body">

    <!-- score + period line -->
    <div class="lh-scoreblock">
      <div class="lh-teams">
        <div class:list={['lh-t', { loser: homeLoser }]}>
          <img src={home.logo} alt={`${home.abbrev} logo`} />
          <div class="tbl">
            <span class="abbr">{home.abbrev}</span>
            <span class="rec">{home.record}</span>
          </div>
          <span class="score">{home.score}</span>
        </div>
        <div class="lh-sep" aria-hidden="true">·</div>
        <div class:list={['lh-t', 'right', { loser: awayLoser }]}>
          <span class="score">{away.score}</span>
          <div class="tbl right">
            <span class="abbr">{away.abbrev}</span>
            <span class="rec">{away.record}</span>
          </div>
          <img src={away.logo} alt={`${away.abbrev} logo`} />
        </div>
      </div>

      <!-- period-by-period line -->
      <div class="pbp" role="table" aria-label="Period by period">
        <div class="h first"></div>
        <div class="h">1</div>
        <div class="h">2</div>
        <div class="h">3</div>
        <div class="h">OT</div>
        <div class="h">T</div>

        <div class:list={['tm', { loser: homeLoser }]}>
          <img src={home.logo} alt="" />{home.abbrev}
        </div>
        {PBP_COLS.map((_p, idx) => (
          <div class={pbpCellClass(idx)}>{pbpCellValue(home.pbp[idx] ?? 0, idx)}</div>
        ))}
        <div class="cell tot">{home.score}</div>

        <div class:list={['tm', { loser: awayLoser }]}>
          <img src={away.logo} alt="" />{away.abbrev}
        </div>
        {PBP_COLS.map((_p, idx) => (
          <div class={pbpCellClass(idx)}>{pbpCellValue(away.pbp[idx] ?? 0, idx)}</div>
        ))}
        <div class="cell tot">{away.score}</div>
      </div>
    </div>

    <!-- stats sidebar — 4 bars: SHOTS · 5V5 xG · xG · ALL · WIN PROBABILITY -->
    <div class="lh-stats">
      <div class="lh-stat">
        <div class:list={['vl', { dim: homeLoser }]}>{stats.shots.home}</div>
        <div class="lbl">Shots on Goal</div>
        <div class:list={['vr', { dim: awayLoser }]}>{stats.shots.away}</div>
        <div class="bar" style={`--hc:${home.accent};--ac:${away.accent};`}>
          <div class="l" style={`width:${shotsL};`}></div>
          <div class="r" style={`width:${shotsR};`}></div>
        </div>
      </div>

      <div class="lh-stat">
        <div class:list={['vl', { dim: homeLoser }]}>{stats.xg_5v5.home.toFixed(2)}</div>
        <div class="lbl">5v5 xG</div>
        <div class:list={['vr', { dim: awayLoser }]}>{stats.xg_5v5.away.toFixed(2)}</div>
        <div class="bar" style={`--hc:${home.accent};--ac:${away.accent};`}>
          <div class="l" style={`width:${xg5L};`}></div>
          <div class="r" style={`width:${xg5R};`}></div>
        </div>
      </div>

      <div class="lh-stat">
        <div class:list={['vl', { dim: homeLoser }]}>{stats.xg.home.toFixed(2)}</div>
        <div class="lbl">xG · All</div>
        <div class:list={['vr', { dim: awayLoser }]}>{stats.xg.away.toFixed(2)}</div>
        <div class="bar cyan">
          <div class="l" style={`width:${xgL};`}></div>
          <div class="r" style={`width:${xgR};`}></div>
        </div>
      </div>

      <div class="lh-stat">
        <div class:list={['vl', { dim: homeLoser }]}>{stats.wp.home}{stats.wp.unit ?? '%'}</div>
        <div class="lbl">Win Probability</div>
        <div class:list={['vr', { dim: awayLoser }]}>{stats.wp.away}{stats.wp.unit ?? '%'}</div>
        <div class="bar" style={`--hc:${home.accent};--ac:${away.accent};`}>
          <div class="l" style={`width:${wpL};`}></div>
          <div class="r" style={`width:${wpR};`}></div>
        </div>
      </div>
    </div>

    <!--
      Footer strip — goal chips + "+N more" overflow + Latest Activity.

      Layer 1.7 collapsed the 1.5-era PBP-chip fallback. The footer is
      always:  [ goal chips … ]  [ + N more? ]  [ Latest Activity ]
      where Latest Activity flex-grows to absorb whatever width the goal
      chips don't use. The inline page script clamps `goalsToShow` from
      `?goals=N`, computes `slotsForLatest`, and stamps a
      `data-density="hidden|narrow|medium|wide|very-wide|max"` attribute
      on the Latest Activity card so its CSS adapts (column count, event
      count, header summary). 6-slot footer is the target.
    -->
    <div
      class="goal-feed"
      aria-label="Scoring summary"
      data-max-slots="6"
      data-goal-count={game.goal_feed.length}
    >
      {game.goal_feed.map((g, idx) => (
        <div
          class:list={['goal-chip', { overturned: g.overturned }]}
          data-chip-kind="goal"
          data-chip-idx={idx}
        >
          {/* Running-score pill, top-right. For overturned: OVERTURNED
              badge replaces the score pill and takes red styling. */}
          <span class:list={['score-pill', { overturned: g.overturned }]}>
            {g.overturned ? 'OVERTURNED' : g.score_after}
          </span>
          <div class="t">
            <span>P{g.period} · {g.clock} · {g.team}</span>
          </div>
          <div class="p">
            {g.scorer}{g.goal_number ? ` (${g.goal_number})` : ''}
          </div>
          {g.overturned ? (
            <div class="rev">⊘ {g.review_reason ?? 'Reviewed'}</div>
          ) : (
            <div class="a">
              {g.assists.length > 0 ? `A: ${g.assists.join(', ')}` : 'Unassisted'}
              {g.strength ? ` · ${g.strength}` : ''}
            </div>
          )}
        </div>
      ))}

      <!-- "+ N more · open game" placeholder chip — shown when goals overflow
           the visible cap. Client script toggles display + sets data-more-n. -->
      <div
        class="goal-chip more-chip"
        data-chip-kind="more"
        data-layer3-hook="open-game-modal"
        hidden
      >
        <div class="t"><span>More</span></div>
        {/* TODO: Layer 3 — open game modal on click */}
        <div class="p">+<span data-more-n>0</span> more</div>
        <div class="a">open game</div>
      </div>

      <!--
        Latest Activity card — flex-grows to absorb whatever footer width
        the goal chips don't use. The inline page script stamps the card
        with `data-density="…"` based on slot count; CSS rules below key
        column count + visible-event count off that attribute. Pulsing
        cyan header dot reuses the `ringPulse` animation.
      -->
      <div
        class="latest-card"
        aria-label="Latest activity"
        data-chip-kind="latest"
        data-density="narrow"
      >
        <div class="lh-latest-head">
          <span class="lh-latest-head-l">
            <span class="dot" aria-hidden="true"></span>
            <span>Latest Activity</span>
          </span>
          <span class="lh-latest-summary" aria-hidden="true">{maxSummary}</span>
        </div>
        {latestItems.length > 0 ? (
          <ul class="lh-latest-body">
            {latestItems.map((it, idx) => (
              <li
                class="lh-latest-row"
                data-ev-type={it.evClass}
                data-row-idx={idx}
              >
                <span class="tstamp">P{it.period} · {it.clock}</span>
                <span class="label">{it.label}</span>
                {(it.team || it.player) && (
                  <span class="who">
                    {it.team ?? ''}{it.team && it.player ? ' · ' : ''}{it.player ?? ''}
                  </span>
                )}
                {it.reason && <span class="reason">{it.reason}</span>}
              </li>
            ))}
          </ul>
        ) : (
          <div class="lh-latest-empty">No activity yet</div>
        )}
      </div>
    </div>

  </div>
</section>

<style>
  .live-hero {
    background: var(--site-card);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    margin-top: 6px;
    overflow: hidden;
  }

  /* ── head ─────────────────────────────────────────────────────── */
  .lh-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 22px;
    border-bottom: 1px solid #1a1a1a;
    background: #0b0b0b;
    gap: 14px;
    flex-wrap: wrap;
  }

  .badge {
    color: var(--status-live);
    font-family: var(--font-site-body);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .badge .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--status-live);
    box-shadow: 0 0 0 0 rgba(0, 229, 255, 0.55);
    animation: ringPulse 1.8s ease-out infinite;
  }

  @keyframes ringPulse {
    0%   { box-shadow: 0 0 0 0 rgba(0, 229, 255, 0.55); }
    70%  { box-shadow: 0 0 0 10px rgba(0, 229, 255, 0); }
    100% { box-shadow: 0 0 0 0 rgba(0, 229, 255, 0); }
  }

  .meta {
    color: #666;
    font-family: var(--font-site-body);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .chip {
    border: 1px solid var(--site-border2);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    color: #bbb;
  }

  /* State chip (first in meta group) — color-coded per state type via
     per-chip CSS variable overrides. 5v5 suppresses rendering upstream. */
  .chip.state-chip {
    border-color: var(--sc-color, var(--status-live));
    color: var(--sc-color, var(--status-live));
    background: var(--sc-tint, transparent);
    font-weight: 700;
  }

  /* ── body layout ──────────────────────────────────────────────── */
  .lh-body {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 0;
  }

  .lh-scoreblock {
    padding: 26px 30px;
    border-right: 1px solid #1a1a1a;
  }

  .lh-teams {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  .lh-t {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .lh-t.right {
    justify-content: flex-end;
  }

  .lh-t img {
    width: 64px;
    height: 64px;
    flex: none;
  }

  .tbl {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tbl.right {
    text-align: right;
  }

  .lh-t .abbr {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--site-white);
    letter-spacing: 0.06em;
  }

  .lh-t .rec {
    color: #666;
    font-family: var(--font-site-body);
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .lh-t .score {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 84px;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--site-white);
    margin-left: 14px;
  }

  .lh-t.right .score {
    margin-left: 0;
    margin-right: 14px;
  }

  .lh-t.loser .abbr,
  .lh-t.loser .score {
    color: var(--site-muted);
  }

  .lh-t.loser img {
    opacity: 0.4;
    filter: grayscale(0.5);
  }

  .lh-sep {
    color: var(--site-border2);
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 42px;
    text-align: center;
  }

  /* ── period-by-period line ───────────────────────────────────── */
  .pbp {
    margin-top: 22px;
    border-top: 1px solid #1a1a1a;
    padding-top: 16px;
    display: grid;
    grid-template-columns: 1fr repeat(4, 48px) 68px;
    gap: 6px;
    align-items: center;
  }

  .pbp .h {
    color: var(--site-muted);
    font-family: var(--font-site-body);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    text-align: center;
  }
  .pbp .h.first { text-align: left; }

  .pbp .tm {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--site-white);
  }
  .pbp .tm img {
    width: 18px;
    height: 18px;
  }
  .pbp .tm.loser { color: var(--site-muted); }
  .pbp .tm.loser img { opacity: 0.35; }

  .pbp .cell {
    text-align: center;
    font-family: var(--font-site-display);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-size: 14px;
    color: #ccc;
    padding: 4px 0;
    border: 1px solid #1a1a1a;
    border-radius: var(--radius-sm);
    background: #0a0a0a;
  }
  .pbp .cell.active {
    color: var(--status-live);
    border-color: rgba(0, 229, 255, 0.35);
    box-shadow: inset 0 0 0 1px rgba(0, 229, 255, 0.12);
  }
  .pbp .cell.dim { color: #333; }
  .pbp .cell.tot {
    color: var(--site-white);
    background: #141414;
    font-size: 16px;
  }

  /* ── live sidebar ─────────────────────────────────────────────── */
  /* Stat bars distribute evenly across the full vertical height of the
     body pane — `space-evenly` gives each row equal breathing room top
     and bottom so the pane doesn't feel top-heavy at wider viewports.
     Padding mirrors the scoreblock's vertical rhythm (26px). No explicit
     gap: space-evenly handles row spacing. */
  .lh-stats {
    padding: 26px 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    background: #0c0c0c;
  }

  .lh-stat {
    display: grid;
    grid-template-columns: 52px 1fr 52px;
    align-items: center;
    row-gap: 4px;
    column-gap: 10px;
  }

  .lh-stat .vl,
  .lh-stat .vr {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-size: 17px;
    color: var(--site-white);
  }
  .lh-stat .vl { text-align: left; }
  .lh-stat .vr { text-align: right; }
  .lh-stat .vl.dim,
  .lh-stat .vr.dim { color: var(--site-muted); }

  .lh-stat .lbl {
    text-align: center;
    color: #666;
    font-family: var(--font-site-body);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .lh-stat .bar {
    grid-column: 1 / -1;
    display: flex;
    height: 5px;
    background: #151515;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  /* Team-accent split bar — colors threaded via CSS vars from team.accent */
  .lh-stat .bar .l { background: var(--hc, var(--hgb-red)); }
  .lh-stat .bar .r { background: var(--ac, #2a2a2a); }

  /* Cyan variant for one callout bar (xG · All) — matches design reference */
  .lh-stat .bar.cyan .l { background: var(--status-live); }
  .lh-stat .bar.cyan .r { background: #1a4050; }

  /* ── footer strip (goal chips + Latest Activity) ──────────────── */
  /* Flex row, no wrap. Goal chips have flex-basis 0 + min-width 0 (slot-
     share via flex-grow). Latest Activity is sized via flex-grow set by
     the page script — it absorbs whatever room the goal chips leave.
     The strip has a stable min-height so the footer never visibly
     stretches across `?goals=N` variants — goal chips center-align in
     the row and Latest content overflows hidden if it tries to grow. */
  .goal-feed {
    grid-column: 1 / -1;
    border-top: 1px solid #1a1a1a;
    padding: 14px 24px;
    display: flex;
    gap: 14px;
    overflow-x: hidden;
    background: #0a0a0a;
    min-height: 152px;
    align-items: stretch;
  }

  /* Honor the native `hidden` attribute even when a .goal-chip.more-chip
     rule declares display:flex (which would otherwise win over the UA
     stylesheet). Scoped to footer-strip chips only. */
  .goal-feed [hidden] { display: none !important; }

  /* Goal chip — solid border + running-score pill top-right. flex-basis
     of 0 + flex-grow 1 makes each visible chip claim an equal share of
     the slots NOT consumed by Latest Activity. */
  .goal-chip {
    flex: 1 1 0;
    min-width: 0;
    max-width: 320px;
    border-radius: var(--radius-md);
    padding: 9px 12px;
    position: relative;
    border: 1px solid var(--site-border);
    background: var(--site-card);
    padding-right: 58px; /* reserve room for the score-pill absolute position */
  }

  .goal-chip .t {
    display: flex;
    justify-content: space-between;
    color: #666;
    font-family: var(--font-site-body);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    min-width: 0;
  }
  .goal-chip .t > span {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    min-width: 0;
  }

  /* Running-score pill on goal chips — cyan accent, top-right anchor. */
  .goal-chip .score-pill {
    position: absolute;
    top: 8px;
    right: 10px;
    padding: 2px 8px;
    border: 1px solid rgba(0, 229, 255, 0.35);
    border-radius: 999px;
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 12px;
    color: var(--status-live);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
    line-height: 1.3;
    background: rgba(0, 229, 255, 0.05);
  }
  .goal-chip .score-pill.overturned {
    color: var(--hgb-red);
    border-color: rgba(232, 0, 45, 0.4);
    background: rgba(232, 0, 45, 0.06);
    font-size: 9px;
    letter-spacing: 0.12em;
    padding: 2px 6px;
  }

  .goal-chip .p {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 14px;
    color: var(--site-white);
    margin-top: 4px;
    letter-spacing: 0.02em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Single-line clamp on player + assists lines so the chip stays a
     consistent 3-line height across viewport widths (no 1200px wrap to
     a 4-line chip that would push the footer taller). */
  .goal-chip .a {
    color: #888;
    font-family: var(--font-site-body);
    font-size: 11px;
    margin-top: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .goal-chip.overturned {
    background: repeating-linear-gradient(45deg, #160b0b, #160b0b 6px, #0f0707 6px, #0f0707 12px);
    border-color: rgba(232, 0, 45, 0.4);
  }
  .goal-chip.overturned .p {
    color: #ff7b8a;
    text-decoration: line-through;
    text-decoration-color: rgba(255, 123, 138, 0.6);
  }
  .goal-chip .rev {
    color: var(--hgb-red);
    font-family: var(--font-site-body);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* "+ N more · open game" truncation placeholder. Clickable styling
     now; wire-up is Layer 3. */
  .goal-chip.more-chip {
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    background: transparent;
    border-style: dashed;
    transition: border-color 120ms ease, background 120ms ease;
  }
  .goal-chip.more-chip:hover {
    border-color: var(--site-border2);
    background: #0d0d0d;
  }
  .goal-chip.more-chip .t { justify-content: center; }
  .goal-chip.more-chip .p { margin-top: 2px; }

  /* ── Latest Activity card ─────────────────────────────────────────
     Flex-grow is set by the inline page script via inline style based on
     remaining slot count (0..6). Internal layout adapts via the
     `data-density` attribute (narrow / medium / wide / very-wide / max).
     Hidden entirely when goals + "+N more" already use all 6 slots.

     Height parity: goal chips set the footer's natural height (~95px for
     a 3-line chip). The card's own height is capped by `goal-feed` since
     all chips share a flex row — goal chips that grow taller than the
     card's content force visual stretch onto the card; the card never
     forces growth on goal chips because it overflows internally. */
  .latest-card {
    flex: 1 1 0;
    min-width: 0;
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    padding: 8px 14px;
    background: var(--site-card);
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: hidden;            /* card never forces parent flex to grow */
    align-self: stretch;         /* match the row's natural height */
  }

  /* Header — label + dot. The summary span is hidden by default and only
     surfaces in max mode (see density rules near the bottom). */
  .lh-latest-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    color: var(--status-live);
    font-family: var(--font-site-body);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .lh-latest-head-l {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .lh-latest-head .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--status-live);
    box-shadow: 0 0 0 0 rgba(0, 229, 255, 0.55);
    animation: ringPulse 1.8s ease-out infinite;
    flex: none;
  }
  .lh-latest-summary {
    display: none;  /* shown only at data-density="max" */
    color: #888;
    font-family: var(--font-mono, ui-monospace, SFMono-Regular, Consolas, monospace);
    font-size: 10px;
    letter-spacing: 0.08em;
    font-variant-numeric: tabular-nums;
    text-transform: none;
  }

  /* Body grid. column count controlled by data-density. The card's
     overall height is anchored to the goal-chip row height (~70px body);
     overflow is hidden so additional rows don't force the footer taller.
     `lh-latest-body` height is capped via height: 100% + min-height: 0 so
     it claims whatever the parent .latest-card grants it (which is
     determined by the flex row's tallest sibling, i.e. the goal chip). */
  .lh-latest-body {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: min-content;
    gap: 0;
    min-height: 0;
    overflow: hidden;
  }

  /* Row layout — single tight line by default. `who` reveals inline (not
     stacked) at wider densities so row height stays ~22px regardless of
     mode. Default grid is 2-col so narrow has more room for the label;
     wider modes opt in to a 3-col grid where `who` claims the right
     column. */
  .lh-latest-row {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-areas: "tstamp label";
    column-gap: 10px;
    align-items: baseline;
    padding: 4px 0;
    border-bottom: 1px solid #1a1a1a;
    font-family: var(--font-site-body);
    min-width: 0;
    line-height: 1.3;
  }
  .lh-latest-row:last-child { border-bottom: none; padding-bottom: 0; }
  .lh-latest-row:first-child { padding-top: 0; }

  .lh-latest-row .tstamp {
    grid-area: tstamp;
    color: #666;
    font-family: var(--font-mono, ui-monospace, SFMono-Regular, Consolas, monospace);
    font-size: 10px;
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
    flex: none;
    white-space: nowrap;
  }

  .lh-latest-row .label {
    grid-area: label;
    font-family: var(--font-site-body);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-align: right;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: #bbb;
    min-width: 0;
  }

  /* `who` lives inline at the right of each row (after the label) at
     densities ≥ medium. We pack TEAM · player into a single right-aligned
     auto column so row height never grows beyond a single-line baseline. */
  .lh-latest-row .who {
    grid-area: who;
    display: none;
    color: #888;
    font-family: var(--font-site-body);
    font-size: 10px;
    letter-spacing: 0.04em;
    text-align: right;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 140px;
  }
  /* Reason lives in its own column past the label. Hidden by default; the
     wide+ modes reveal it inline as a third right-aligned cell. */
  .lh-latest-row .reason {
    display: none;
  }

  /* Label color keyed to event type. */
  .lh-latest-row[data-ev-type="PP_START"] .label,
  .lh-latest-row[data-ev-type="PP_END"] .label,
  .lh-latest-row[data-ev-type="PK_START"] .label,
  .lh-latest-row[data-ev-type="PK_END"] .label {
    color: var(--status-live);
  }
  .lh-latest-row[data-ev-type="PENALTY"] .label { color: var(--status-danger); }
  .lh-latest-row[data-ev-type="SHOT_HIGH"] .label { color: var(--status-ot); }
  .lh-latest-row[data-ev-type="TIMEOUT"] .label { color: #bbb; }

  .lh-latest-empty {
    color: var(--site-muted);
    font-family: var(--font-site-body);
    font-size: 11px;
    text-align: center;
    padding: 12px 0;
  }

  /* ── Latest Activity density modes ────────────────────────────────
     Slot allocation matrix from SITE-HOME-017 §B/§C:

       slots │ columns │ events │ row detail
       ──────┼─────────┼────────┼────────────────────────────────
       1     │ 1       │ 3      │ tstamp + label (default)
       2     │ 1       │ 4      │ + player line where present
       3     │ 2       │ 6      │ + player + danger/reason
       4     │ 2       │ 6      │ same as 3, more breathing room
       5     │ 2-3     │ 8      │ full event detail (auto-fit)
       6     │ 3       │ 9      │ full detail + max-mode header

     `data-density` is set by the inline page script. Out-of-DOM rows
     are hidden via `nth-child` selectors; column count is grid-driven. */

  /* Hidden — page script sets when goals fill all 6 slots. */
  .latest-card[data-density="hidden"] { display: none; }

  /* Density rules — column count + visible-row count. Row height stays
     ~22px across all modes; total card body height stays ≤ 3 rows worth
     so the footer's overall height never grows beyond the goal-chip
     row's natural height. */

  /* Narrow (1 slot) — 3 events, single column. The 3rd row is what makes
     the card occasionally taller than a 3-line goal chip; that's still
     within the ~150px footer budget. */
  .latest-card[data-density="narrow"] .lh-latest-body { grid-template-columns: 1fr; }
  .latest-card[data-density="narrow"] .lh-latest-row:nth-child(n+4) { display: none; }
  /* Tighten row spacing in narrow so 3 events fit within a goal-chip's
     row height without forcing the row tall. */
  .latest-card[data-density="narrow"] .lh-latest-row { padding: 3px 0; }

  /* Medium (2 slots) — 4 events laid out 2-col × 2-row to keep card
     height in step with narrow (3 rows × 1 col); inline `who` revealed. */
  .latest-card[data-density="medium"] .lh-latest-body {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 16px;
  }
  .latest-card[data-density="medium"] .lh-latest-row:nth-child(n+5) { display: none; }
  .latest-card[data-density="medium"] .lh-latest-row {
    grid-template-columns: auto 1fr auto;
    grid-template-areas: "tstamp label who";
  }
  .latest-card[data-density="medium"] .lh-latest-row .who { display: block; }

  /* Wide (3 slots) — 6 events, 2-col grid, inline `who`. */
  .latest-card[data-density="wide"] .lh-latest-body {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 18px;
  }
  .latest-card[data-density="wide"] .lh-latest-row:nth-child(n+7) { display: none; }
  .latest-card[data-density="wide"] .lh-latest-row {
    grid-template-columns: auto 1fr auto;
    grid-template-areas: "tstamp label who";
  }
  .latest-card[data-density="wide"] .lh-latest-row .who { display: block; }

  /* Very-wide (5 slots) — 6 events, auto-fit grid (renders as 2-3 cols
     depending on parent width). Inline `who` revealed. */
  .latest-card[data-density="very-wide"] .lh-latest-body {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    column-gap: 22px;
  }
  .latest-card[data-density="very-wide"] .lh-latest-row:nth-child(n+9) { display: none; }
  .latest-card[data-density="very-wide"] .lh-latest-row {
    grid-template-columns: auto 1fr auto;
    grid-template-areas: "tstamp label who";
  }
  .latest-card[data-density="very-wide"] .lh-latest-row .who { display: block; }

  /* Max (6 slots, 0 goals) — 9 events, 3-col, inline `who` + header
     summary line revealed. */
  .latest-card[data-density="max"] .lh-latest-body {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: 26px;
  }
  .latest-card[data-density="max"] .lh-latest-row {
    grid-template-columns: auto 1fr auto;
    grid-template-areas: "tstamp label who";
  }
  .latest-card[data-density="max"] .lh-latest-row .who { display: block; }
  .latest-card[data-density="max"] .lh-latest-summary { display: inline; }

  /* ── responsive ──────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .lh-body { grid-template-columns: 1fr; }
    .lh-scoreblock { border-right: none; border-bottom: 1px solid #1a1a1a; }
  }

  @media (max-width: 640px) {
    .lh-scoreblock { padding: 20px 18px; }
    .lh-t img { width: 44px; height: 44px; }
    .lh-t .abbr { font-size: 18px; }
    .lh-t .score { font-size: 56px; margin-left: 8px; }
    .lh-t.right .score { margin-right: 8px; }
    .lh-sep { font-size: 30px; }
    .pbp { grid-template-columns: 1fr repeat(4, 36px) 52px; gap: 4px; }
    .pbp .cell { font-size: 12px; }
    .pbp .cell.tot { font-size: 14px; }
    .lh-stats { padding: 16px 18px; }
  }
</style>
