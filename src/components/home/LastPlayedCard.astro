---
/**
 * LastPlayedCard — memorial wrapper around ArtifactGame for the
 * offseason mode (SITE-HOME-05).
 *
 * Why a wrapper instead of just rendering ArtifactGame directly
 * --------------------------------------------------------------
 * The framing is what makes this card feel "memorial" rather than
 * "another recap card". Without the eyebrow + the section header
 * "LAST GAME PLAYED" the card would look like a stranded recap.
 *
 * The wrapper adds:
 *   - "LAST GAME · YYYY STANLEY CUP G7" eyebrow above the card
 *   - A subtle border glow effect to elevate the card
 *   - A small "LOOKING BACK" tag in the corner
 *
 * Decision worth user review: separate component vs reuse ArtifactGame
 * with a `memorial: true` prop. Wrapper feels right because the framing
 * is structural (a section header + spacing context), not internal to
 * the artifact card itself. Easier to evolve independently later.
 */

import ArtifactGame, { type Props as ArtifactGameProps } from './artifacts/ArtifactGame.astro';

interface Props {
  /** Memorial framing line, e.g. "LAST GAME PLAYED · 2026 STANLEY CUP · GAME 7". */
  memorial_eyebrow: string;
  /** Game payload — passed straight through to ArtifactGame. */
  game_data: ArtifactGameProps;
  /** Free-form kind tag — informational, used to nudge the framing copy. */
  kind?: string;
}

const { memorial_eyebrow, game_data, kind } = Astro.props;

// Sub-eyebrow framing — varies based on kind. SCF gets the most weight,
// preseason a more matter-of-fact line, regular-season a dim one.
const subFraming =
  kind === 'scf_g7'
    ? 'The book closes here. Until October.'
    : kind === 'preseason'
    ? 'Last meaningful exhibition before opening night.'
    : kind === 'regular'
    ? 'Final game on the regular-season ledger.'
    : 'The last game on the books.';
---
<section class="last-played" aria-label="Last game played">
  <header class="lp-head">
    <span class="lp-tick" aria-hidden="true">▍</span>
    <div class="lp-headtext">
      <h2 class="lp-h2">{memorial_eyebrow}</h2>
      <p class="lp-sub">{subFraming}</p>
    </div>
    <span class="lp-tag mono">LOOKING BACK</span>
  </header>

  <div class="lp-frame">
    <ArtifactGame {...game_data} />
  </div>
</section>

<style>
  .last-played {
    margin: 0 0 28px;
  }

  .lp-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: start;
    gap: 14px;
    margin-bottom: 12px;
  }
  .lp-tick {
    color: var(--hgb-red);
    font-size: 18px;
    line-height: 1;
    margin-top: 4px;
  }
  .lp-headtext {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .lp-h2 {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 16px;
    color: var(--site-white);
    margin: 0;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .lp-sub {
    font-family: var(--font-site-body);
    color: #888;
    font-size: 12.5px;
    margin: 0;
    font-style: italic;
  }

  .lp-tag {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: var(--status-ot);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 1px solid #2a2018;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    background: rgba(255, 152, 0, 0.05);
    align-self: start;
  }

  /* Memorial frame — adds a subtle gold-leaf border to elevate the
     wrapped ArtifactGame. The card itself keeps its original chrome. */
  .lp-frame {
    border: 1px solid rgba(255, 152, 0, 0.18);
    border-radius: var(--radius-md);
    padding: 4px;
    background:
      linear-gradient(180deg, rgba(255, 152, 0, 0.04), transparent 50%);
    box-shadow: 0 0 32px rgba(255, 152, 0, 0.05);
  }

  @media (max-width: 720px) {
    .lp-head {
      grid-template-columns: auto 1fr;
    }
    .lp-tag { grid-column: 1 / -1; justify-self: start; }
    .lp-h2 { font-size: 14px; }
  }
</style>
