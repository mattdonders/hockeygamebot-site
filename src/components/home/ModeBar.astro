---
/**
 * ModeBar — three-toggle bar that flips between Live / Recap / Tomorrow.
 *
 * Live  → ?mode=live
 * Recap → ?mode=recap
 * Tomorrow → disabled stub (href="#") until Layer 5
 *
 * Right side: mono telemetry line — static placeholder this layer.
 * Layer 6 will wire real auto-refresh + artifact counts.
 */

type Mode = 'live' | 'recap' | 'tomorrow';

interface Props {
  mode: Mode;
  /** Static telemetry copy; override when live data is wired. */
  telemetry?: string;
  /**
   * Number of artifacts fired tonight — drives the auto-built telemetry
   * line when an explicit `telemetry` prop isn't supplied. Layer 6+ will
   * pass a live count from the polling service; for now this comes from
   * `live_moments.length` in the mock fixture. Falls back to a static
   * placeholder when undefined.
   */
  artifactsCount?: number;
}

const {
  mode,
  telemetry,
  artifactsCount,
} = Astro.props;

const refreshLine = 'AUTO-REFRESH · 02s';
const computedTelemetry =
  telemetry ??
  (artifactsCount !== undefined
    ? `${refreshLine} · ${artifactsCount} ARTIFACT${artifactsCount === 1 ? '' : 'S'} FIRED TONIGHT`
    : `${refreshLine} · ARTIFACTS FIRED TONIGHT`);

const toggles: Array<{ key: Mode; label: string; href: string; disabled: boolean }> = [
  { key: 'live', label: 'Live now', href: '?mode=live', disabled: false },
  { key: 'recap', label: "Last night's recap", href: '?mode=recap', disabled: false },
  { key: 'tomorrow', label: "Tomorrow's slate", href: '#', disabled: true },
];
---
<div class="mode-bar" role="tablist" aria-label="Mode">
  <div class="toggles">
    {toggles.map((t) => (
      <a
        class:list={['toggle', { active: t.key === mode, disabled: t.disabled }]}
        href={t.disabled ? undefined : t.href}
        role="tab"
        aria-selected={t.key === mode ? 'true' : 'false'}
        aria-disabled={t.disabled ? 'true' : undefined}
        tabindex={t.disabled ? -1 : 0}
      >
        <span class="dot" aria-hidden="true">{t.key === mode ? '●' : '○'}</span>
        <span>{t.label}</span>
      </a>
    ))}
  </div>
  <span class="telemetry mono" aria-hidden="true">{computedTelemetry}</span>
</div>

<style>
  .mode-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 12px 14px;
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    background: #0a0a0a;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }

  .toggles {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border: 1px solid #222;
    border-radius: var(--radius-md);
    color: #888;
    font-family: var(--font-site-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .toggle:hover:not(.disabled),
  .toggle:focus-visible:not(.disabled) {
    color: var(--site-white);
    border-color: #333;
    outline: none;
  }

  .toggle.active {
    color: var(--site-white);
    border-color: #333;
    background: #141414;
  }

  .toggle.disabled {
    color: #3a3a3a;
    border-color: #151515;
    cursor: not-allowed;
    pointer-events: none;
  }

  .toggle .dot {
    font-size: 10px;
    color: currentColor;
  }

  .telemetry {
    font-family: var(--font-mono);
    color: #555;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .mode-bar { padding: 10px; }
    .toggle { padding: 5px 8px; font-size: 10px; letter-spacing: 0.1em; }
    .telemetry { font-size: 9px; }
  }
</style>
