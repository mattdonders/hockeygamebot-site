---
/**
 * TomorrowHero — hero card for `?mode=tomorrow`.
 *
 * Layout (mirrors RecapHero's "big card on the left, supporting on right"
 * skeleton — but tomorrow's "supporting" is the featured matchup itself
 * because there's no game-of-night hero to anchor against):
 *
 *   ┌──────────────────────┬───────────────────────┐
 *   │ TOMORROW · APR 26    │  ┌─────────────────┐  │
 *   │ 8 GAMES SCHEDULED    │  │ ArtifactMatchup │  │
 *   │ 4 series in action   │  └─────────────────┘  │
 *   │                      │                       │
 *   │ Dim secondary copy:  │                       │
 *   │ "Predictions update  │                       │
 *   │ at 4 AM ET cron."    │                       │
 *   └──────────────────────┴───────────────────────┘
 *
 * The featured matchup is just a reused ArtifactMatchup card. The hero's
 * job is to set the date stamp + game count framing — the actual
 * matchup card carries the visual weight.
 */

import ArtifactMatchup, { type Props as ArtifactMatchupProps } from './artifacts/ArtifactMatchup.astro';

interface Props {
  /** Big eyebrow line — "TOMORROW · APR 26 · 8 GAMES SCHEDULED". */
  date_label: string;
  /** Long-form blurb under the date — e.g. "Predictions update at 4am ET." */
  blurb?: string;
  /** Featured matchup data, passed straight to ArtifactMatchup. */
  featured: ArtifactMatchupProps;
}

const {
  date_label,
  blurb = 'Predictions refresh at 4 AM ET. Tap any game tile for the full preview.',
  featured,
} = Astro.props;
---
<section class="tomorrow-hero" aria-label="Tomorrow's slate hero">
  <div class="th-left">
    <span class="th-eyebrow-red">UPCOMING · TOMORROW</span>
    <h2 class="th-date">{date_label}</h2>
    <p class="th-blurb">{blurb}</p>
    <div class="th-microsign">
      <span class="th-tick" aria-hidden="true">▍</span>
      <span class="th-microsign-text">FEATURED MATCHUP</span>
    </div>
  </div>
  <div class="th-right">
    <ArtifactMatchup {...featured} />
  </div>
</section>

<style>
  .tomorrow-hero {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 18px;
    margin-bottom: 22px;
  }

  @media (max-width: 1024px) {
    .tomorrow-hero {
      grid-template-columns: 1fr;
    }
  }

  .th-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 14px;
    padding: 24px 28px;
    border: 1px solid var(--site-border);
    background: linear-gradient(180deg, #0c0c0c 0%, #090909 100%);
    border-radius: var(--radius-md);
  }

  .th-eyebrow-red {
    color: var(--hgb-red);
    font-family: var(--font-site-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .th-date {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 36px;
    line-height: 1.05;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--site-white);
    margin: 0;
  }

  .th-blurb {
    color: #888;
    font-family: var(--font-site-body);
    font-size: 13.5px;
    line-height: 1.5;
    max-width: 480px;
    margin: 0;
  }

  .th-microsign {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
  }
  .th-tick {
    color: var(--status-live);
    font-size: 14px;
    line-height: 1;
  }
  .th-microsign-text {
    font-family: var(--font-site-body);
    font-weight: 700;
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #888;
  }

  .th-right {
    /* The wrapper just lets ArtifactMatchup expand to fill its column —
       no additional chrome here, the artifact already has its own border. */
    display: block;
  }

  @media (max-width: 720px) {
    .th-date { font-size: 28px; }
    .th-blurb { font-size: 12.5px; }
  }
</style>
