---
/**
 * SummerStorylines — placeholder section for offseason mode (SITE-HOME-05).
 *
 * V1 ships text-only stub cards. The cards are intentionally rough — the
 * spec is explicit that the offseason page is "the most iterated-on
 * later" and we're shipping a basic V1.
 *
 * Each storyline renders as a simple card with:
 *   - Headline (Trade Tracker / Free Agency / 2026 Draft)
 *   - Subtitle (one-line context)
 *   - CTA (text link with arrow — non-functional in V1)
 *
 * Layer 6+ will swap these for real artifact cards once the trade /
 * free-agency / draft pipelines exist.
 */

import type { OffseasonStoryline } from '../../lib/auto-mode-schemas';

interface Props {
  storylines: OffseasonStoryline[];
  heading?: string;
}

const { storylines, heading } = Astro.props;
const headingText = heading ?? 'Summer storylines';

// Tag color picker — keep cohesive with the rest of the page tokens.
function kindStyles(kind: string): { tag: string; tone: string } {
  switch (kind) {
    case 'trades':
      return { tag: 'TRADE WIRE', tone: 'cyan' };
    case 'fa':
      return { tag: 'FREE AGENCY', tone: 'green' };
    case 'draft':
      return { tag: 'DRAFT BOARD', tone: 'gold' };
    default:
      return { tag: 'STORYLINE', tone: 'neutral' };
  }
}
---
<section class="summer-storylines" aria-label="Summer storylines">
  <header class="ss-head">
    <span class="ss-tick" aria-hidden="true">▍</span>
    <h2 class="ss-h2">{headingText}</h2>
    <span class="ss-meta mono">PLACEHOLDER · WIRES UP V2</span>
  </header>

  <div class="ss-grid">
    {storylines.map((s) => {
      const { tag, tone } = kindStyles(s.kind);
      return (
        <article class={`ss-card ss-card--${tone}`} data-storyline-kind={s.kind}>
          <div class="ss-tag">{tag}</div>
          <h3 class="ss-headline">{s.headline}</h3>
          <p class="ss-subtitle">{s.subtitle}</p>
          <a class="ss-cta" href="#" aria-label={`${s.headline} — coming soon`}>
            {s.cta}
          </a>
        </article>
      );
    })}
  </div>
</section>

<style>
  .summer-storylines {
    margin: 0 0 28px;
  }

  .ss-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .ss-tick {
    color: var(--hgb-red);
    font-size: 14px;
    line-height: 1;
  }
  .ss-h2 {
    flex: 1;
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 14px;
    color: var(--site-white);
    margin: 0;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .ss-meta {
    font-family: var(--font-mono);
    color: #555;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ss-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }
  @media (max-width: 900px) { .ss-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .ss-grid { grid-template-columns: 1fr; } }

  .ss-card {
    background: #0f0f0f;
    border: 1px solid #1c1c1c;
    border-radius: var(--radius-md);
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 168px;
    position: relative;
    transition: border-color 0.15s, transform 0.15s, background 0.15s;
  }
  .ss-card:hover {
    border-color: #2a2a2a;
    background: #131313;
    transform: translateY(-1px);
  }

  .ss-tag {
    font-family: var(--font-site-body);
    font-weight: 700;
    font-size: 9.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #888;
  }
  .ss-card--cyan .ss-tag { color: var(--status-live); }
  .ss-card--green .ss-tag { color: var(--status-goal); }
  .ss-card--gold .ss-tag { color: var(--status-scheduled); }

  .ss-headline {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 22px;
    line-height: 1.05;
    letter-spacing: 0.04em;
    color: var(--site-white);
    margin: 0;
    text-transform: uppercase;
  }

  .ss-subtitle {
    font-family: var(--font-site-body);
    color: #888;
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
  }

  .ss-cta {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ccc;
    text-decoration: none;
    border-top: 1px dashed #1c1c1c;
    padding-top: 10px;
    transition: color 0.15s;
  }
  .ss-cta:hover { color: var(--site-white); }

  /* Card accent strip on hover — picks up the kind's tone. */
  .ss-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 2px;
    background: transparent;
    border-radius: var(--radius-md) 0 0 var(--radius-md);
    transition: background 0.15s;
  }
  .ss-card:hover.ss-card--cyan::before { background: var(--status-live); }
  .ss-card:hover.ss-card--green::before { background: var(--status-goal); }
  .ss-card:hover.ss-card--gold::before { background: var(--status-scheduled); }
</style>
