---
/**
 * Topbar — 44px sticky dark topbar for /home-v2.
 *
 * Matches docs/designs/ui_kits/website/index.html:
 *   - puck dot (14px) + HOCKEYGAMEBOT wordmark (Oswald 700, 0.12em)
 *   - nav pills: SCORES / TEAMS / STATS / PLAYOFFS / SUPPORT
 *   - date pill on right (mono, e.g. "APR 24 · 2026")
 *
 * Active-page detection:
 *   The consuming page passes `active` = one of the nav keys.
 *   /home-v2 marks "scores" as the active pill for Layer 1.
 */

export type NavKey = 'scores' | 'teams' | 'stats' | 'playoffs' | 'support';

interface Props {
  active?: NavKey;
  dateLabel?: string;
}

const { active = 'scores', dateLabel } = Astro.props;

// Build-time date fallback — matches design "APR 24 · 2026" format.
const today = new Date();
const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
const computedDate = `${MONTHS[today.getUTCMonth()]} ${today.getUTCDate()} · ${today.getUTCFullYear()}`;
const date = dateLabel ?? computedDate;

const NAV: Array<{ key: NavKey; label: string; href: string }> = [
  { key: 'scores', label: 'Scores', href: '/home-v2' },
  { key: 'teams', label: 'Teams', href: '/teams' },
  { key: 'stats', label: 'Stats', href: '/stats' },
  { key: 'playoffs', label: 'Playoffs', href: '/playoffs/2026' },
  { key: 'support', label: 'Support', href: '/support' },
];
---
<header class="hgb-topbar">
  <div class="brand">
    <span class="puck" aria-hidden="true"></span>
    <span class="wordmark">HockeyGameBot</span>
  </div>
  <nav class="nav" aria-label="Primary">
    {NAV.map((item) => (
      <a
        href={item.href}
        class:list={['nav-pill', { active: item.key === active }]}
        aria-current={item.key === active ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
  <div class="spacer"></div>
  <span class="date mono">{date}</span>
</header>

<style>
  .hgb-topbar {
    height: 44px;
    background: #000;
    border-bottom: 1px solid var(--site-border);
    display: flex;
    align-items: center;
    padding: 0 18px;
    gap: 14px;
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .puck {
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: var(--hgb-red);
    box-shadow: inset 0 0 0 2px #000;
    flex: none;
  }

  .wordmark {
    color: #fff;
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .nav {
    display: flex;
    gap: 4px;
    margin-left: 22px;
  }

  .nav-pill {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-family: var(--font-site-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 6px 12px;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    transition: color 0.15s, border-color 0.15s;
  }

  .nav-pill:hover,
  .nav-pill:focus-visible {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.2);
    outline: none;
  }

  .nav-pill.active {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }

  .spacer {
    flex: 1;
  }

  .date {
    color: #666;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 4px 10px;
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
  }

  @media (max-width: 720px) {
    .hgb-topbar { padding: 0 12px; gap: 10px; }
    .nav { margin-left: 10px; gap: 2px; overflow-x: auto; }
    .nav-pill { padding: 5px 8px; font-size: 10px; letter-spacing: 0.1em; }
    .date { display: none; }
  }
</style>
