---
/**
 * OffseasonHero — countdown card for `?mode=offseason` (SITE-HOME-05).
 *
 * Lean V1 per the spec — "the most iterated-on later". Big numeral
 * (days until opening night), supporting context (training camp opens,
 * opening night date), nothing fancy.
 *
 * Layout (matches the design's hero patterns — left sets context,
 * right anchors the eye):
 *
 *   ┌───────────────────────────────┐
 *   │ OFFSEASON · 47 DAYS UNTIL     │
 *   │ PUCK DROP                     │
 *   │                               │
 *   │ ╔═══════════════════════╗     │
 *   │ ║                       ║     │
 *   │ ║         47            ║     │
 *   │ ║         DAYS          ║     │
 *   │ ║                       ║     │
 *   │ ╚═══════════════════════╝     │
 *   │                               │
 *   │ TRAINING CAMP · SEPT 18 2026  │
 *   │ OPENING NIGHT  · OCT 8 2026   │
 *   └───────────────────────────────┘
 *
 * Decision worth user review: big numeral vs progress bar vs both.
 * V1 ships big numeral only — easiest to scan, hardest to misread, no
 * data point about WHERE we are in the offseason (no "season ended
 * date" in the data so a progress bar would be relative-only).
 */

import type { OffseasonCountdown } from '../../lib/auto-mode-schemas';

interface Props {
  /** Big eyebrow line. */
  eyebrow: string;
  countdown: OffseasonCountdown;
}

const { eyebrow, countdown } = Astro.props;
---
<section class="offseason-hero" aria-label="Offseason countdown">
  <span class="oh-eyebrow-red">{eyebrow}</span>

  <div class="oh-bigwrap">
    <div class="oh-bignum" aria-hidden="true">{countdown.days}</div>
    <div class="oh-biglabel">DAYS UNTIL OPENING NIGHT</div>
  </div>

  <dl class="oh-stamps">
    <div class="oh-stamp">
      <dt class="oh-stamp-k">TRAINING CAMP OPENS</dt>
      <dd class="oh-stamp-v">{countdown.training_camp_date}</dd>
    </div>
    <div class="oh-stamp">
      <dt class="oh-stamp-k">OPENING NIGHT</dt>
      <dd class="oh-stamp-v">{countdown.opening_night}</dd>
    </div>
  </dl>
</section>

<style>
  .offseason-hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    padding: 28px 32px 32px;
    border: 1px solid var(--site-border);
    background:
      radial-gradient(circle at 70% 0%, rgba(0, 229, 255, 0.05) 0%, transparent 60%),
      linear-gradient(180deg, #0c0c0c 0%, #090909 100%);
    border-radius: var(--radius-md);
    margin-bottom: 22px;
  }

  .oh-eyebrow-red {
    color: var(--hgb-red);
    font-family: var(--font-site-body);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .oh-bigwrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    width: 100%;
    padding: 24px 0 18px;
    border-top: 1px solid #1a1a1a;
    border-bottom: 1px solid #1a1a1a;
    background: radial-gradient(ellipse at center, rgba(0, 229, 255, 0.04) 0%, transparent 70%);
  }

  .oh-bignum {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 132px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--site-white);
    /* Subtle inner glow to match the broadcast feel of the hero. */
    text-shadow: 0 0 60px rgba(0, 229, 255, 0.15);
    font-variant-numeric: tabular-nums;
  }

  .oh-biglabel {
    font-family: var(--font-site-body);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.32em;
    color: #777;
    text-transform: uppercase;
  }

  .oh-stamps {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    width: 100%;
    margin: 0;
  }

  .oh-stamp {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 14px;
    border: 1px solid #1c1c1c;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.01);
  }
  .oh-stamp-k {
    font-family: var(--font-site-body);
    font-weight: 700;
    font-size: 9.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #777;
    margin: 0;
  }
  .oh-stamp-v {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 17px;
    letter-spacing: 0.05em;
    color: var(--site-white);
    margin: 0;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .offseason-hero { padding: 22px 18px 24px; }
    .oh-bignum { font-size: 92px; }
    .oh-stamps { grid-template-columns: 1fr; }
  }
</style>
