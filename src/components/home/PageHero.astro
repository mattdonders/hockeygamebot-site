---
/**
 * PageHero — title block that sits under the playoff strip.
 *
 * Matches docs/designs/ui_kits/website/index.html `.page`:
 *   - red eyebrow  (e.g. "Live Now · 3 games in progress")
 *   - h1          (Oswald 700, 44px)
 *   - sub paragraph
 *
 * Voice: per docs/designs/README.md — short declarative headlines,
 * first-person plural in the system voice ("Built by one fan"). The
 * default sub text is carried verbatim from the design reference.
 */

interface Props {
  eyebrow: string;
  title?: string;
  sub?: string;
}

const {
  eyebrow,
  title = 'Every NHL game. Every shot. Every night.',
  sub = "Real-time scores with shots on goal, expected goals (xG) and goal-wash reviews the moment the call happens. Built by one fan, powered by Python, the NHL's public feed, and a lot of coffee.",
} = Astro.props;
---
<section class="page-hero">
  <span class="eyebrow-red">{eyebrow}</span>
  <h1>{title}</h1>
  <p class="sub">{sub}</p>
</section>

<style>
  .page-hero {
    padding: 22px 0 0;
  }

  .eyebrow-red {
    color: var(--hgb-red);
    font-family: var(--font-site-body);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
  }

  h1 {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 44px;
    line-height: 1.05;
    letter-spacing: 0.01em;
    color: var(--site-white);
    margin: 6px 0 4px;
  }

  .sub {
    color: #888;
    font-family: var(--font-site-body);
    font-size: 14px;
    line-height: 1.55;
    max-width: 620px;
    margin: 0 0 22px;
  }

  @media (max-width: 640px) {
    h1 { font-size: 30px; }
    .sub { font-size: 13px; }
  }
</style>
