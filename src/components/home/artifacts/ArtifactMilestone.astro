---
/**
 * ArtifactMilestone — gold/ceremonial career-or-season milestone card.
 *
 * Data contract (matches design `art-mile`):
 *   - eyebrow      — short qualifier, e.g. "Career · Assists"
 *   - num.value    — main numeral (e.g. "1000" or "50")
 *   - num.suffix   — small superscript suffix (e.g. "th" or "G")
 *   - what         — what was achieved, multi-line OK (e.g. "Crosby joins\nthe 1,000-A club")
 *   - who          — attribution line, UPPERCASE, e.g. "SIDNEY CROSBY · PIT · APR 23 · VS BOS"
 *   - rank         — left side of arc row, e.g. "14TH ALL-TIME"
 *   - dotsTotal    — total dots in arc; rendered as `dotsLit` filled + remainder muted
 *   - dotsLit      — count of "lit" dots (ceremony — how many at this tier)
 *
 * Python card-generator note: same component drives the @HockeyGameBot
 * Twitter milestone post (1200×675 PNG, slightly different copy injected).
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  eyebrow: string;
  num: { value: string; suffix?: string };
  /** Multi-line allowed via "\n". */
  what: string;
  who: string;
  rank: string;
  dotsTotal: number;
  dotsLit: number;
}

const { tag, byline, eyebrow, num, what, who, rank, dotsTotal, dotsLit } = Astro.props;

const lit = Math.max(0, Math.min(dotsTotal, dotsLit));
const muted = Math.max(0, dotsTotal - lit);
const whatLines = what.split('\n');
---
<ArtifactShell variantClass="art-mile" tag={tag} byline={byline}>
  <div class="art-mile__ehead">{eyebrow}</div>
  <div class="art-mile__num">
    {num.value}
    {num.suffix && <span class="art-mile__th">{num.suffix}</span>}
  </div>
  <div class="art-mile__what">
    {whatLines.map((line, i) => (
      <Fragment>
        {i > 0 && <br />}{line}
      </Fragment>
    ))}
  </div>
  <div class="art-mile__who">{who}</div>
  <div class="art-mile__arc">
    <span style="color: #ffd54a;">{rank}</span>
    <span class="art-mile__dots">
      {Array.from({ length: lit }).map(() => <span></span>)}
      {Array.from({ length: muted }).map(() => <span class="mt"></span>)}
    </span>
  </div>
</ArtifactShell>

<style is:global>
  .art-mile {
    background: #120e03;
    border: 1px solid #3d2d08;
    padding: 22px 22px 40px;
    position: relative;
    overflow: hidden;
  }
  .art-mile::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 20%, rgba(255, 213, 74, 0.12), transparent 55%);
    pointer-events: none;
  }
  .art-mile__ehead {
    position: relative; z-index: 1;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; color: #ffd54a;
    letter-spacing: 0.22em; text-transform: uppercase;
    margin-top: 14px; margin-bottom: 8px;
  }
  .art-mile__num {
    position: relative; z-index: 1;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 84px; color: #ffd54a;
    font-variant-numeric: tabular-nums; letter-spacing: -0.02em;
    line-height: 0.9;
  }
  .art-mile__th {
    font-size: 26px; color: #b28e28; margin-left: 4px; letter-spacing: 0;
  }
  .art-mile__what {
    position: relative; z-index: 1;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 20px; color: #fff; margin-top: 6px;
    letter-spacing: 0.01em; text-transform: uppercase;
    line-height: 1.1;
  }
  .art-mile__who {
    position: relative; z-index: 1;
    font-family: var(--font-mono); font-size: 11px;
    color: #ba9644; margin-top: 10px;
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .art-mile__arc {
    position: relative; z-index: 1;
    margin-top: 18px; display: flex; align-items: center; gap: 10px;
    font-size: 11.5px; color: #998144;
    font-family: var(--font-mono); letter-spacing: 0.05em;
    flex-wrap: wrap;
  }
  .art-mile__dots {
    display: flex; gap: 4px; flex-wrap: wrap;
  }
  .art-mile__dots span {
    width: 18px; height: 4px; background: #ffd54a; border-radius: 1px;
  }
  .art-mile__dots span.mt { background: #3d2d08; }
</style>
