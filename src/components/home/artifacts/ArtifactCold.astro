---
/**
 * ArtifactCold — red/punishing player slump card.
 *
 * Data contract (matches design `art-cold`):
 *   - eyebrow — qualifier, e.g. "12 GAMES · NO GOALS"
 *   - name    — player display name (BIG, Oswald 700)
 *   - sub     — team/pos/window line
 *   - bigStat — value + unit (e.g. "−0.87" + "HGB / 60\nLAST 12")
 *   - context — narrative paragraph; supports {bold} via simple b tags
 *   - sparkline — array of values 0..1 (height fractions)
 *
 * Python card-generator note: "context" copy is generated by the bot's
 * SocialWriter (Anthropic Haiku via core/social_writer.py). The site
 * rendering is identical — it just receives the prerendered string.
 * Allow simple <b>…</b> highlights but no other HTML.
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  eyebrow: string;
  name: string;
  sub: string;
  bigStat: { value: string; unit: string };
  /** Allows <b>…</b> bolding; rendered with `set:html`. No other tags. */
  context: string;
  /** Each value 0..1 — bar heights. Recommended length 5-12. */
  sparkline: number[];
}

const { tag, byline, eyebrow, name, sub, bigStat, context, sparkline } = Astro.props;
---
<ArtifactShell variantClass="art-cold" tag={tag} byline={byline}>
  <div class="art-cold__ehead">{eyebrow}</div>
  <div class="art-cold__name">{name}</div>
  <div class="art-cold__sub">{sub}</div>
  <div class="art-cold__big">
    <div class="art-cold__n">{bigStat.value}</div>
    <div class="art-cold__unit" set:html={bigStat.unit.replace(/\n/g, '<br>')}></div>
  </div>
  <div class="art-cold__ctx" set:html={context}></div>
  <div class="art-cold__spark">
    {sparkline.map((h) => (
      <div class="art-cold__b" style={`height:${Math.max(4, Math.min(100, Math.round(h * 100)))}%;`}></div>
    ))}
  </div>
</ArtifactShell>

<style is:global>
  .art-cold {
    background:
      radial-gradient(circle at 0% 100%, rgba(232, 0, 45, 0.14), transparent 60%),
      #120a0d;
    border: 1px solid #3b1a26;
    padding: 22px 22px 40px;
  }
  .art-cold__ehead {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; color: var(--hgb-red);
    letter-spacing: 0.22em; text-transform: uppercase;
    margin-top: 14px; margin-bottom: 6px;
  }
  .art-cold__name {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 30px; color: #fff; letter-spacing: 0.01em;
    line-height: 1; text-transform: uppercase;
  }
  .art-cold__sub {
    font-family: var(--font-mono); font-size: 10.5px;
    color: #a66a7a; letter-spacing: 0.06em; margin-top: 5px;
    text-transform: uppercase;
  }
  .art-cold__big {
    display: flex; align-items: baseline; gap: 8px; margin-top: 20px;
  }
  .art-cold__n {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 56px; color: var(--hgb-red);
    font-variant-numeric: tabular-nums; line-height: 1;
    letter-spacing: -0.02em;
  }
  .art-cold__unit {
    font-family: var(--font-mono); font-size: 11px;
    color: #a66a7a; text-transform: uppercase; letter-spacing: 0.15em;
    line-height: 1.2;
  }
  .art-cold__ctx {
    margin-top: 12px; font-family: var(--font-site-body);
    font-size: 12.5px; color: #b89aa3; line-height: 1.5;
  }
  .art-cold__ctx b { color: #f5d0d8; font-weight: 600; }
  .art-cold__spark {
    margin-top: 14px; height: 28px;
    display: flex; align-items: flex-start; gap: 3px;
  }
  .art-cold__b {
    background: var(--hgb-red); border-radius: 1px;
    width: 14px; flex: 0 0 14px; opacity: 0.85;
  }
</style>
