---
/**
 * ArtifactClinch — red-alert playoff clinch card.
 *
 * Data contract (matches design `art-clinch`):
 *   - tagText        — top-row label, e.g. "BRUINS · LAST NIGHT · OT WINNER"
 *   - eyebrow        — small red header above main, e.g. "CLINCHED · ATLANTIC"
 *   - headline       — main caps headline, multi-line via "\n" (e.g. "2ND STRAIGHT\nDIVISION TITLE.")
 *   - by             — small attribution, e.g. "vs PIT · 4-3 OT · D. PASTRNAK OT1 02:14"
 *   - bigNum         — huge background numeral (e.g. "Y2") — pure decoration
 *   - pills          — array of small mono-style chips (record, status, magic#)
 *
 * Python card-generator note: this is a redesign of the existing clinch
 * card script in scripts/generate_clinch_card.py. Rendering target stays
 * 800×418 PNG; this web tile is a compact 6-col adaptation.
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  tagText: string;
  eyebrow: string;
  /** Multi-line allowed via "\n". Renders as <br>-joined. */
  headline: string;
  by: string;
  bigNum: string;
  pills: string[];
}

const { tag, byline, tagText, eyebrow, headline, by, bigNum, pills } = Astro.props;
const headlineLines = headline.split('\n');
---
<ArtifactShell variantClass="art-clinch" tag={tag} byline={byline} height={330}>
  <div class="art-clinch__num-big">{bigNum}</div>
  <div class="art-clinch__cl-tag"><span class="art-clinch__d"></span>{tagText}</div>
  <div class="art-clinch__clinched">
    <span class="art-clinch__a">{eyebrow}</span>
    {headlineLines.map((line, i) => (
      <Fragment>
        {i > 0 && <br />}{line}
      </Fragment>
    ))}
  </div>
  <div class="art-clinch__by">{by}</div>
  {pills.length > 0 && (
    <div class="art-clinch__details">
      {pills.map((p) => (
        <span class="art-clinch__pill">{p}</span>
      ))}
    </div>
  )}
</ArtifactShell>

<style is:global>
  .art-clinch {
    background: linear-gradient(180deg, #2d0713, #0d0507);
    border: 1px solid #5a1428;
    padding: 22px 22px 40px;
    position: relative;
    overflow: hidden;
  }
  .art-clinch::before {
    content: "";
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      45deg,
      rgba(232, 0, 45, 0.03), rgba(232, 0, 45, 0.03) 2px,
      transparent 2px, transparent 8px
    );
  }
  .art-clinch__cl-tag {
    position: relative; z-index: 1;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 10px; color: #fff;
    letter-spacing: 0.22em; text-transform: uppercase;
    margin-top: 14px;
    display: flex; align-items: center; gap: 10px;
  }
  .art-clinch__d {
    width: 9px; height: 9px; border-radius: 999px;
    background: var(--hgb-red);
    box-shadow: 0 0 0 3px rgba(232, 0, 45, 0.18);
    flex: none;
  }
  .art-clinch__clinched {
    position: relative; z-index: 1;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 48px; color: #fff;
    letter-spacing: -0.01em; line-height: 0.95;
    margin-top: 14px; text-transform: uppercase;
  }
  .art-clinch__a {
    display: block;
    color: var(--hgb-red); font-size: 16px;
    letter-spacing: 0.14em; margin-bottom: 6px;
  }
  .art-clinch__by {
    position: relative; z-index: 1;
    margin-top: 14px;
    font-family: var(--font-mono); font-size: 11px;
    color: #df8090; letter-spacing: 0.08em;
  }
  .art-clinch__num-big {
    position: absolute; right: -14px; top: -10px;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 220px; line-height: 1;
    color: rgba(232, 0, 45, 0.09);
    letter-spacing: -0.04em;
    pointer-events: none;
    user-select: none;
  }
  .art-clinch__details {
    position: relative; z-index: 1;
    margin-top: 18px; display: flex; gap: 8px; flex-wrap: wrap;
  }
  .art-clinch__pill {
    font-family: var(--font-mono); font-size: 10.5px;
    color: #fff; padding: 4px 8px;
    border: 1px solid rgba(232, 0, 45, 0.5);
    border-radius: 2px; letter-spacing: 0.06em;
    background: rgba(232, 0, 45, 0.1);
  }
</style>
