---
/**
 * ArtifactThreeStars — three stars of the game (gold/silver/bronze).
 *
 * Visual: stacked rows for #1 / #2 / #3. Each row has a position numeral
 * (large), player name, team chip, and a stat line. Position-1 row uses
 * gold, #2 silver, #3 bronze. Game context at the bottom in muted mono.
 *
 * Data contract:
 *   - eyebrow      — "THREE STARS · POSTGAME"
 *   - context      — "BOS 4 · PIT 3 OT · APR 23"
 *   - stars[3]     — exactly three stars
 *   - stars[].name — player display name
 *   - stars[].team — team abbrev (3 chars)
 *   - stars[].pos  — short pos label, "C" / "RW" / "G"
 *   - stars[].stat — stat line — for skaters "1G 2A · +1.7 HGB",
 *                    for goalies "36/38 · .947 SV%"
 *
 * Python card-generator note: this is the @HockeyGameBot final tweet
 * "three stars" — runs on game_end. Same data, different copy.
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';

export interface Star {
  name: string;
  team: string;
  pos: string;
  stat: string;
}

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  eyebrow: string;
  context: string;
  stars: [Star, Star, Star];
}

const { tag, byline, eyebrow, context, stars } = Astro.props;

const TIER = [
  { color: '#ffd54a', label: 'GOLD' },
  { color: '#c9c9d4', label: 'SILVER' },
  { color: '#cd853f', label: 'BRONZE' },
];
---
<ArtifactShell variantClass="art-stars" tag={tag} byline={byline}>
  <div class="art-stars__ehead">{eyebrow}</div>
  <div class="art-stars__rows">
    {stars.map((s, i) => (
      <div class="art-stars__r" style={`--tier:${TIER[i].color};`}>
        <div class="art-stars__rank">
          <span class="art-stars__rn">{i + 1}</span>
          <span class="art-stars__tier">{TIER[i].label}</span>
        </div>
        <div class="art-stars__body">
          <div class="art-stars__nm">{s.name}</div>
          <div class="art-stars__sub">
            <span class="art-stars__chip">{s.team}</span>
            <span class="art-stars__pos">{s.pos}</span>
          </div>
        </div>
        <div class="art-stars__stat">{s.stat}</div>
      </div>
    ))}
  </div>
  <div class="art-stars__ctx">{context}</div>
</ArtifactShell>

<style is:global>
  .art-stars {
    background:
      radial-gradient(ellipse at 100% 0%, rgba(255, 213, 74, 0.10), transparent 55%),
      #100c03;
    border: 1px solid #2e2208;
    padding: 22px 22px 42px;
  }
  .art-stars__ehead {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; color: #ffd54a;
    letter-spacing: 0.22em; text-transform: uppercase;
    margin-top: 14px; margin-bottom: 12px;
  }
  .art-stars__rows {
    display: flex; flex-direction: column; gap: 8px;
  }
  .art-stars__r {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 10px 8px;
    border-left: 3px solid var(--tier);
    background: rgba(255, 255, 255, 0.02);
  }
  .art-stars__rank {
    display: flex; flex-direction: column; align-items: flex-start;
    line-height: 1;
  }
  .art-stars__rn {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 32px; color: var(--tier);
    font-variant-numeric: tabular-nums; line-height: 0.9;
    letter-spacing: -0.02em;
  }
  .art-stars__tier {
    font-family: var(--font-mono); font-size: 8.5px;
    color: var(--tier); margin-top: 4px;
    letter-spacing: 0.16em; opacity: 0.9;
  }
  .art-stars__body { display: flex; flex-direction: column; gap: 4px; }
  .art-stars__nm {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 18px; color: #fff; letter-spacing: 0.02em;
    text-transform: uppercase; line-height: 1;
  }
  .art-stars__sub { display: flex; gap: 8px; align-items: center; }
  .art-stars__chip {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9px; color: #fff;
    letter-spacing: 0.14em; text-transform: uppercase;
    background: rgba(255, 213, 74, 0.18);
    border: 1px solid rgba(255, 213, 74, 0.35);
    padding: 2px 6px;
    border-radius: 1px;
  }
  .art-stars__pos {
    font-family: var(--font-mono); font-size: 10px;
    color: #b28e28; letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .art-stars__stat {
    font-family: var(--font-mono); font-size: 11.5px;
    color: var(--tier); letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
    text-align: right;
    text-transform: uppercase;
  }
  .art-stars__ctx {
    margin-top: 14px;
    font-family: var(--font-mono); font-size: 10.5px;
    color: #6b5a25; letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
