---
/**
 * ArtifactLine — three-player line combination card (purple).
 *
 * Data contract (matches design `art-line`):
 *   - eyebrow  — qualifier, e.g. "TOP LINE · 5V5 · SEASON LEADER"
 *   - title    — full line name like "Lehkonen – Necas – MacKinnon"
 *   - context  — small italic team/TOI note like "COL · 560 TOI"
 *   - players  — exactly 3 player tiles (LW / C / RW order)
 *   - players[].number — visible big stat (e.g. "+25" — usage at 5v5 GF)
 *   - players[].name   — last name only
 *   - players[].pos    — "LW · #62"
 *   - players[].emphasized — true to highlight as the "anchor"
 *   - stats    — exactly 4 stat tiles
 *   - stats[].green — color the value in green (positive marker)
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';

export interface LinePlayer {
  number: string;
  name: string;
  pos: string;
  emphasized?: boolean;
}

export interface LineStat {
  k: string;
  v: string;
  green?: boolean;
}

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  eyebrow: string;
  title: string;
  context: string;
  players: [LinePlayer, LinePlayer, LinePlayer];
  stats: [LineStat, LineStat, LineStat, LineStat];
}

const { tag, byline, eyebrow, title, context, players, stats } = Astro.props;
---
<ArtifactShell variantClass="art-line" tag={tag} byline={byline} height={330}>
  <div class="art-line__ehead">{eyebrow}</div>
  <div class="art-line__ltag">{title}<span class="art-line__tm">{context}</span></div>
  <div class="art-line__trio">
    {players.map((p) => (
      <div class:list={['art-line__p', { emp: p.emphasized }]}>
        <div class="art-line__num">{p.number}</div>
        <div class="art-line__nm">{p.name}</div>
        <div class="art-line__pos">{p.pos}</div>
      </div>
    ))}
  </div>
  <div class="art-line__stats-row">
    {stats.map((s) => (
      <div class="art-line__c">
        <div class="art-line__k">{s.k}</div>
        <div class:list={['art-line__v', { green: s.green }]}>{s.v}</div>
      </div>
    ))}
  </div>
</ArtifactShell>

<style is:global>
  .art-line {
    background: linear-gradient(160deg, #0b0b13, #0e0e18);
    border: 1px solid #26224a;
    padding: 20px 22px 40px;
    position: relative;
  }
  .art-line__ehead {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; color: #a699ff;
    letter-spacing: 0.22em; text-transform: uppercase;
    margin-top: 14px; margin-bottom: 8px;
  }
  .art-line__ltag {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 22px; color: var(--site-white);
    letter-spacing: 0.01em; text-transform: uppercase;
    line-height: 1.15;
  }
  .art-line__tm {
    color: #a699ff; font-family: var(--font-mono);
    font-size: 12px; margin-left: 8px; letter-spacing: 0.06em;
    font-weight: 500;
  }
  .art-line__trio {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    gap: 12px; margin-top: 18px;
  }
  .art-line__p {
    text-align: center; padding: 12px 8px;
    background: rgba(122, 103, 255, 0.05);
    border: 1px solid rgba(122, 103, 255, 0.18);
    border-radius: 2px;
  }
  .art-line__p.emp {
    background: rgba(122, 103, 255, 0.12);
    border-color: rgba(122, 103, 255, 0.35);
  }
  .art-line__num {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 24px; color: #fff;
    font-variant-numeric: tabular-nums; line-height: 1;
  }
  .art-line__p.emp .art-line__num { color: #a699ff; }
  .art-line__nm {
    font-family: var(--font-site-display); font-weight: 600;
    font-size: 12px; color: #e2d9ff;
    letter-spacing: 0.02em; margin-top: 8px; text-transform: uppercase;
  }
  .art-line__pos {
    font-family: var(--font-mono); font-size: 10px;
    color: #7a67ff; margin-top: 2px;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .art-line__stats-row {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 6px; margin-top: 16px; padding-top: 14px;
    border-top: 1px solid rgba(122, 103, 255, 0.18);
  }
  .art-line__c { text-align: center; }
  .art-line__k {
    font-family: var(--font-mono); font-size: 9px;
    color: #6b5ea8; letter-spacing: 0.12em; text-transform: uppercase;
  }
  .art-line__v {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 17px; color: #fff;
    font-variant-numeric: tabular-nums; margin-top: 3px;
  }
  .art-line__v.green { color: #00e676; }
</style>
