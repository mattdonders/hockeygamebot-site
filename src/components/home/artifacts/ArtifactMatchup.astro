---
/**
 * ArtifactMatchup — pre-game preview card (cyan).
 *
 * Data contract (matches design `art-match`):
 *   - eyebrow — qualifier line, e.g. "Tonight · 10:30 ET · VGK @ EDM · Game 2 R1"
 *   - home / away — abbrev, name, record, accentColor
 *   - timeLabel — center column big time, e.g. "10:30 PM ET"
 *   - keyMatchupTitle — "Key matchup · HGB edge"
 *   - matchups — array of {left, right} player pairs (max 2 to fit height)
 *
 * Python card-generator note: drives the @HockeyGameBot pre-game tweet
 * 1-2h before puck drop. `keyMatchupTitle` could swap for "Goalie battle"
 * etc. — the model picks the angle.
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';
import TeamLogo from '../TeamLogo.astro';

export interface MatchupSide {
  abbrev: string;
  name: string;
  record: string;
  accentColor: string;
  /**
   * Logo URL — kept for back-compat with existing mock JSON, but no
   * longer rendered. The component now renders inline SVG via the
   * shared `TeamLogo` keyed off `abbrev`. Safe to omit.
   */
  logo?: string;
}

export interface MatchupPair {
  left: { name: string; meta: string };
  right: { name: string; meta: string };
  centerLabel?: string;
}

export interface SeasonSeries {
  /**
   * 'current' — teams have already played this season; show series-to-date.
   * 'last_season' — first meeting; show prior-season summary as historical context.
   */
  scope: 'current' | 'last_season';
  /** Free-form summary line, e.g. "BOS leads 2-1 · last meeting BOS 4-2 (Oct 18)". */
  summary: string;
}

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  eyebrow: string;
  home: MatchupSide;
  away: MatchupSide;
  timeLabel: string;
  /** Optional venue label — renders muted, BELOW the time in the center column. */
  venue?: string;
  keyMatchupTitle: string;
  matchups: MatchupPair[];
  /**
   * Optional season-series summary. Renders below the Key Matchup block.
   * `scope` chooses the framing label so users know whether the line is
   * current-season ("SEASON SERIES") or historical-context ("LAST SEASON").
   */
  season_series?: SeasonSeries;
}

const { tag, byline, eyebrow, home, away, timeLabel, venue, keyMatchupTitle, matchups, season_series } = Astro.props;
---
<ArtifactShell variantClass="art-match" tag={tag} byline={byline}>
  <div class="art-match__ehead">{eyebrow}</div>
  <div class="art-match__vs">
    <div class="art-match__sq">
      <TeamLogo abbr={home.abbrev} size={72} class="art-match__logo" />
      <div class="art-match__abbr">{home.name}</div>
      <div class="art-match__rec">{home.record}</div>
    </div>
    <div class="art-match__mid">
      <span class="art-match__vs-label">VS</span>
      <span class="art-match__time">{timeLabel}</span>
      {venue && <span class="art-match__venue">{venue}</span>}
    </div>
    <div class="art-match__sq">
      <TeamLogo abbr={away.abbrev} size={72} class="art-match__logo" />
      <div class="art-match__abbr">{away.name}</div>
      <div class="art-match__rec">{away.record}</div>
    </div>
  </div>
  <div class="art-match__keymatch">
    <div class="art-match__k">{keyMatchupTitle}</div>
    {matchups.map((m) => (
      <div class="art-match__pair">
        <span class="art-match__p">
          {m.left.name} <span class="art-match__s">{m.left.meta}</span>
        </span>
        <span class="art-match__c">{m.centerLabel ?? 'vs'}</span>
        <span class="art-match__p right">
          <span class="art-match__s">{m.right.meta}</span> {m.right.name}
        </span>
      </div>
    ))}
  </div>
  {season_series && (
    <div class="art-match__series" data-scope={season_series.scope}>
      <span class="art-match__series-k">
        {season_series.scope === 'last_season' ? 'LAST SEASON' : 'SEASON SERIES'}
      </span>
      <span class="art-match__series-v">{season_series.summary}</span>
    </div>
  )}
</ArtifactShell>

<style is:global>
  .art-match {
    background: #090f10;
    border: 1px solid #0d3037;
    padding: 20px 22px 40px;
    position: relative;
  }
  .art-match__ehead {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 11px; color: #22d3ee;
    letter-spacing: 0.2em; text-transform: uppercase;
    margin-top: 14px; margin-bottom: 12px;
    line-height: 1.35;
  }
  .art-match__vs {
    display: grid; grid-template-columns: 1fr auto 1fr;
    gap: 16px; align-items: center;
  }
  .art-match__sq { display: flex; flex-direction: column; align-items: center; }
  /* TeamLogo wrapper — size locked via the `size` prop on the
     component (72px hero). Background/border treatments removed in
     favor of the inline SVG mark itself; NHL `_dark.svg` variants
     are designed to read against dark surfaces. */
  .art-match .art-match__logo { margin-bottom: 8px; }
  .art-match__abbr {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 22px; color: #fff;
    letter-spacing: 0.04em; text-transform: uppercase;
  }
  .art-match__rec {
    font-family: var(--font-mono); font-size: 10.5px;
    color: #6ca5ad; margin-top: 3px;
  }
  /*
   * Center column visual hierarchy (Layer 5.5 polish):
   *   VS  ← architectural anchor (slightly larger, bold cyan)
   *   7:00 PM ET  ← time (smaller, supporting)
   *   TD GARDEN  ← venue (small, muted, contextual)
   *
   * Per-rationale: the team-vs-team relationship is the headline; the
   * exact start time is supporting context.
   */
  .art-match__mid {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
  }
  .art-match__vs-label {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 14px; letter-spacing: 0.24em;
    color: #22d3ee; text-transform: uppercase;
    line-height: 1;
  }
  .art-match__time {
    font-family: var(--font-mono); font-size: 12px;
    color: #cbd5d8; margin-top: 2px;
    font-weight: 500; letter-spacing: 0.04em;
    line-height: 1.1;
  }
  .art-match__venue {
    font-family: var(--font-mono); font-size: 9px;
    color: #6ca5ad; letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.1; margin-top: 2px;
  }
  .art-match__keymatch {
    margin-top: 18px; padding-top: 14px;
    border-top: 1px solid #0d3037;
  }
  .art-match__k {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; color: #22d3ee;
    letter-spacing: 0.18em; text-transform: uppercase;
    margin-bottom: 8px;
  }
  .art-match__pair {
    display: grid; grid-template-columns: 1fr 40px 1fr;
    gap: 10px; align-items: center;
    padding: 7px 0; border-bottom: 1px dashed #0d3037;
  }
  .art-match__pair:last-child { border-bottom: 0; }
  .art-match__p {
    font-family: var(--font-site-display); font-weight: 600;
    font-size: 12px; color: #eee; letter-spacing: 0.015em;
  }
  .art-match__p.right { text-align: right; }
  .art-match__s {
    color: #6ca5ad; font-family: var(--font-mono);
    font-weight: 400; font-size: 10.5px; margin-left: 4px;
  }
  .art-match__c {
    text-align: center;
    font-family: var(--font-mono); font-size: 10px;
    color: #22d3ee; letter-spacing: 0.08em;
  }

  /*
   * Season-series row — single line, key/value layout. Renders below the
   * Key Matchup block. Two scopes:
   *
   *   scope="current"     → "SEASON SERIES" label
   *   scope="last_season" → "LAST SEASON" label (italicized to read
   *                          historical, not current)
   *
   * Subtle separator above using the same dashed border pattern as the
   * pair rows, so it reads as a contextual footnote rather than a
   * separate section.
   */
  .art-match__series {
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px dashed #0d3037;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
  }
  .art-match__series-k {
    color: #22d3ee;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    flex: none;
  }
  .art-match__series[data-scope="last_season"] .art-match__series-k {
    color: #6ca5ad;
    font-style: italic;
  }
  .art-match__series-v {
    color: #cbd5d8;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
</style>
