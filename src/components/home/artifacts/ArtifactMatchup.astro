---
/**
 * ArtifactMatchup — pre-game preview card (cyan).
 *
 * Data contract (matches design `art-match`):
 *   - eyebrow — qualifier line, e.g. "Tonight · 10:30 ET · VGK @ EDM · Game 2 R1"
 *   - home / away — abbrev, name, record, accentColor
 *   - timeLabel — center column big time, e.g. "10:30 PM ET"
 *   - keyMatchupTitle — "Key matchup · HGB edge"
 *   - matchups — array of {left, right} player pairs (max 2 to fit height)
 *
 * Python card-generator note: drives the @HockeyGameBot pre-game tweet
 * 1-2h before puck drop. `keyMatchupTitle` could swap for "Goalie battle"
 * etc. — the model picks the angle.
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';

export interface MatchupSide {
  abbrev: string;
  name: string;
  record: string;
  accentColor: string;
  /**
   * Optional team logo URL — when present, renders the real SVG instead
   * of the accent-colored abbreviation circle. Default to assets.nhle CDN
   * `_dark.svg` for dark surfaces.
   */
  logo?: string;
}

export interface MatchupPair {
  left: { name: string; meta: string };
  right: { name: string; meta: string };
  centerLabel?: string;
}

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  eyebrow: string;
  home: MatchupSide;
  away: MatchupSide;
  timeLabel: string;
  keyMatchupTitle: string;
  matchups: MatchupPair[];
}

const { tag, byline, eyebrow, home, away, timeLabel, keyMatchupTitle, matchups } = Astro.props;
---
<ArtifactShell variantClass="art-match" tag={tag} byline={byline}>
  <div class="art-match__ehead">{eyebrow}</div>
  <div class="art-match__vs">
    <div class="art-match__sq">
      {home.logo ? (
        <img class="art-match__logo art-match__logo--img" src={home.logo} alt={`${home.abbrev} logo`} loading="lazy" />
      ) : (
        <div class="art-match__logo" style={`background:${home.accentColor};color:#000;`}>{home.abbrev}</div>
      )}
      <div class="art-match__abbr">{home.name}</div>
      <div class="art-match__rec">{home.record}</div>
    </div>
    <div class="art-match__mid">
      VS
      <span class="art-match__time">{timeLabel}</span>
    </div>
    <div class="art-match__sq">
      {away.logo ? (
        <img class="art-match__logo art-match__logo--img" src={away.logo} alt={`${away.abbrev} logo`} loading="lazy" />
      ) : (
        <div class="art-match__logo" style={`background:${away.accentColor};color:#000;`}>{away.abbrev}</div>
      )}
      <div class="art-match__abbr">{away.name}</div>
      <div class="art-match__rec">{away.record}</div>
    </div>
  </div>
  <div class="art-match__keymatch">
    <div class="art-match__k">{keyMatchupTitle}</div>
    {matchups.map((m) => (
      <div class="art-match__pair">
        <span class="art-match__p">
          {m.left.name} <span class="art-match__s">{m.left.meta}</span>
        </span>
        <span class="art-match__c">{m.centerLabel ?? 'vs'}</span>
        <span class="art-match__p right">
          <span class="art-match__s">{m.right.meta}</span> {m.right.name}
        </span>
      </div>
    ))}
  </div>
</ArtifactShell>

<style is:global>
  .art-match {
    background: #090f10;
    border: 1px solid #0d3037;
    padding: 20px 22px 40px;
    position: relative;
  }
  .art-match__ehead {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; color: #22d3ee;
    letter-spacing: 0.22em; text-transform: uppercase;
    margin-top: 14px; margin-bottom: 10px;
  }
  .art-match__vs {
    display: grid; grid-template-columns: 1fr auto 1fr;
    gap: 16px; align-items: center;
  }
  .art-match__sq { display: flex; flex-direction: column; align-items: center; }
  .art-match__logo {
    width: 48px; height: 48px;
    background: #1a1a1a; border-radius: 50%;
    margin-bottom: 8px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 14px; color: #eee; letter-spacing: 0.06em;
  }
  /* Real-logo variant — strips the placeholder circle background and
     lets the SVG itself be the visual. NHL logos are designed to read
     against dark backgrounds when using the _dark.svg variant. */
  .art-match__logo--img {
    background: transparent;
    border-radius: 0;
    object-fit: contain;
  }
  .art-match__abbr {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 22px; color: #fff;
    letter-spacing: 0.04em; text-transform: uppercase;
  }
  .art-match__rec {
    font-family: var(--font-mono); font-size: 10.5px;
    color: #6ca5ad; margin-top: 3px;
  }
  .art-match__mid {
    text-align: center;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 10px; letter-spacing: 0.2em;
    color: #22d3ee; text-transform: uppercase;
  }
  .art-match__time {
    display: block;
    font-family: var(--font-mono); font-size: 16px;
    color: #e5e5e5; margin-top: 6px;
    font-weight: 400; letter-spacing: 0.04em;
  }
  .art-match__keymatch {
    margin-top: 18px; padding-top: 14px;
    border-top: 1px solid #0d3037;
  }
  .art-match__k {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; color: #22d3ee;
    letter-spacing: 0.18em; text-transform: uppercase;
    margin-bottom: 8px;
  }
  .art-match__pair {
    display: grid; grid-template-columns: 1fr 40px 1fr;
    gap: 10px; align-items: center;
    padding: 7px 0; border-bottom: 1px dashed #0d3037;
  }
  .art-match__pair:last-child { border-bottom: 0; }
  .art-match__p {
    font-family: var(--font-site-display); font-weight: 600;
    font-size: 12px; color: #eee; letter-spacing: 0.015em;
  }
  .art-match__p.right { text-align: right; }
  .art-match__s {
    color: #6ca5ad; font-family: var(--font-mono);
    font-weight: 400; font-size: 10.5px; margin-left: 4px;
  }
  .art-match__c {
    text-align: center;
    font-family: var(--font-mono); font-size: 10px;
    color: #22d3ee; letter-spacing: 0.08em;
  }
</style>
