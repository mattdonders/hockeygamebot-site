---
/**
 * ArtifactGame — compact game-result card with mini WP chart.
 *
 * Data contract (matches design `art-game`):
 *   - state.label  — "FINAL" / "FINAL · OT" / "P3 04:23"
 *   - home / away  — abbrev, name, xg, isLoser, accentColor (hex)
 *   - score.home / score.away — integer goals
 *   - wp.events — number of events represented in the polyline
 *   - wp.finalLabel — "BOS 100% FINAL"
 *   - wp.poly — array of {t,p} points (0..1, p=home WP)
 *   - wp.goals — array of {t, side: 'home'|'away'} markers
 *
 * Python card-generator note: `wp.poly` and `wp.goals` will come from D1
 * `events` table (game_state snapshots). The site never computes WP — that
 * lives in the Python bot (core/wp_model.py).
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';

export interface GameSidePropsExpose {
  abbrev: string;
  name: string;
  xg: string;
  /** Hex color for tabs/logo accents — e.g. "#FCB514" */
  accentColor: string;
  isLoser?: boolean;
}

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  state: { label: string };
  home: GameSidePropsExpose;
  away: GameSidePropsExpose;
  score: { home: number; away: number };
  wp: {
    events: number;
    finalLabel: string;
    /** Winner-side accent color (hex) — drives polyline + goal dots. */
    color: string;
    poly: Array<{ t: number; p: number }>;
    goals: Array<{ t: number; side: 'home' | 'away' }>;
  };
}

const { tag, byline, state, home, away, score, wp } = Astro.props;

// Build polyline path. Coord space: x ∈ [0, 600], y ∈ [0, 52].
// p=1 (home wins) at top (y=0), p=0 at bottom (y=52). Mid (50%) at y=26.
const W = 600;
const H = 52;
const toPoint = (pt: { t: number; p: number }) => {
  const x = pt.t * W;
  const y = (1 - pt.p) * H;
  return [x, y];
};

const points = wp.poly.map(toPoint);
const linePath = points.length
  ? 'M' + points.map(([x, y]) => `${x.toFixed(1)},${y.toFixed(1)}`).join(' L')
  : 'M0,26';
const fillPath = points.length
  ? linePath + ` L${W},${H} L0,${H} Z`
  : '';

const gradId = `wpgrad-${Math.floor(Math.random() * 1e6).toString(36)}`;

// Resolve goal-marker positions by interpolating along the poly.
function interpAt(t: number) {
  if (!points.length) return [t * W, H / 2];
  if (t <= wp.poly[0].t) return points[0];
  if (t >= wp.poly[wp.poly.length - 1].t) return points[points.length - 1];
  for (let i = 1; i < wp.poly.length; i++) {
    const a = wp.poly[i - 1];
    const b = wp.poly[i];
    if (t <= b.t) {
      const f = (t - a.t) / Math.max(b.t - a.t, 1e-9);
      const ax = points[i - 1][0];
      const ay = points[i - 1][1];
      const bx = points[i][0];
      const by = points[i][1];
      return [ax + (bx - ax) * f, ay + (by - ay) * f];
    }
  }
  return points[points.length - 1];
}

const goalDots = wp.goals.map((g) => {
  const [x, y] = interpAt(g.t);
  return { x, y, side: g.side };
});
---
<ArtifactShell variantClass="art-game" tag={tag} byline={byline}>
  <div class="art-game__teams">
    <div class:list={['art-game__side', 'l', { loser: home.isLoser }]}>
      <div class="art-game__logo" style={`background:${home.accentColor};color:#000;`}>{home.abbrev}</div>
      <div class="art-game__abbr">{home.name}</div>
      <div class="art-game__xg">{home.xg}</div>
    </div>
    <div class="art-game__vs">
      <span class="art-game__fstate">{state.label}</span>{score.home} – {score.away}
    </div>
    <div class:list={['art-game__side', 'r', { loser: away.isLoser }]}>
      <div class="art-game__logo" style={`background:${away.accentColor};color:#000;`}>{away.abbrev}</div>
      <div class="art-game__abbr">{away.name}</div>
      <div class="art-game__xg" style={away.isLoser ? 'color:#777' : undefined}>{away.xg}</div>
    </div>
  </div>

  <div class="art-game__wpwrap">
    <div class="art-game__wp-lbl">
      <span>WIN PROBABILITY · {wp.events} EVENTS</span>
      <b>{wp.finalLabel}</b>
    </div>
    <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" role="img" aria-label="Win probability over game">
      <defs>
        <linearGradient id={gradId} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color={`${wp.color}55`} />
          <stop offset="100%" stop-color={`${wp.color}00`} />
        </linearGradient>
      </defs>
      <line x1="0" y1="26" x2={W} y2="26" stroke="#252525" stroke-dasharray="2 4" />
      <line x1={W * (1 / 3)} y1="0" x2={W * (1 / 3)} y2={H} stroke="#1e1e1e" stroke-dasharray="2 3" />
      <line x1={W * (2 / 3)} y1="0" x2={W * (2 / 3)} y2={H} stroke="#1e1e1e" stroke-dasharray="2 3" />
      {fillPath && <path d={fillPath} fill={`url(#${gradId})`} />}
      <path d={linePath} stroke={wp.color} stroke-width="1.8" fill="none" />
      {goalDots.map((g) => (
        <circle
          cx={g.x.toFixed(1)}
          cy={g.y.toFixed(1)}
          r={g.side === 'home' ? '3' : '3'}
          fill={g.side === 'home' ? wp.color : '#999'}
        />
      ))}
    </svg>
  </div>
</ArtifactShell>

<style is:global>
  .art-game { background: #0d0d0d; padding: 18px 18px 40px; }
  .art-game__teams { display: grid; grid-template-columns: 1fr 90px 1fr; align-items: center; margin-top: 26px; }
  .art-game__side { display: flex; flex-direction: column; gap: 2px; align-items: center; }
  .art-game__side.l { align-items: flex-start; }
  .art-game__side.r { align-items: flex-end; }
  .art-game__logo {
    width: 48px; height: 48px;
    background: #1a1a1a; border-radius: 50%;
    margin-bottom: 6px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 12px; color: #fff; letter-spacing: 0.06em;
  }
  .art-game__abbr {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 18px; color: var(--site-white); letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .art-game__xg {
    font-family: var(--font-mono); font-size: 10px;
    color: var(--hgb-red); letter-spacing: 0.04em; margin-top: 2px;
  }
  .art-game__side.loser .art-game__logo { opacity: 0.4; }
  .art-game__side.loser .art-game__abbr { color: #666; }
  .art-game__vs {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 26px; color: #fff; text-align: center;
    letter-spacing: 0.04em; font-variant-numeric: tabular-nums;
  }
  .art-game__fstate {
    display: block; color: #888;
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 10px; letter-spacing: 0.18em; margin-bottom: 4px;
    text-transform: uppercase;
  }
  .art-game__wpwrap { margin-top: 20px; padding-top: 16px; border-top: 1px solid #1a1a1a; }
  .art-game__wp-lbl {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9px; letter-spacing: 0.2em; color: #555;
    text-transform: uppercase;
    margin-bottom: 6px;
    display: flex; justify-content: space-between;
  }
  .art-game__wp-lbl b { color: var(--hgb-red); font-weight: 700; }
  .art-game__wpwrap svg { width: 100%; height: 52px; display: block; }
</style>
