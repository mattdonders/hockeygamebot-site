---
/**
 * ArtifactHatTrick — gold celebration card for a 3-goal game.
 *
 * Visual: matches the gold/ceremonial palette of ArtifactMilestone but the
 * hero treatment is the player NAME (not a numeral). Three goal-time pills
 * track the moments. Uses three small puck dots as a celebratory unit.
 *
 * Data contract:
 *   - eyebrow      — short qualifier, e.g. "PLAYOFFS · GAME 4"
 *   - name         — player display name (BIG, Oswald 700)
 *   - sub          — team/pos/meta line, e.g. "BOS · #88 · RW"
 *   - goals        — exactly 3 goal moments
 *   - goals[].period — 1 / 2 / 3 / 4 (OT)
 *   - goals[].clock  — "04:23"
 *   - context      — final/score line, e.g. "vs PIT · 6-3 · 2A · +3.4 HGB"
 *
 * Python card-generator note: fires from goal handler when goals_in_game
 * hits 3 for the same player. Same data + tweet copy via SocialWriter.
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';

export interface HatTrickGoal {
  period: number; /* 1..5 (5=SO) */
  clock: string;
}

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  eyebrow: string;
  name: string;
  sub: string;
  goals: [HatTrickGoal, HatTrickGoal, HatTrickGoal];
  context: string;
}

const { tag, byline, eyebrow, name, sub, goals, context } = Astro.props;

const periodLabel = (p: number) => {
  if (p <= 3) return `P${p}`;
  if (p === 4) return 'OT';
  if (p === 5) return 'SO';
  return `P${p}`;
};
---
<ArtifactShell variantClass="art-hat" tag={tag} byline={byline}>
  <div class="art-hat__ehead">{eyebrow}</div>
  <div class="art-hat__bigline">HAT TRICK</div>
  <div class="art-hat__name">{name}</div>
  <div class="art-hat__sub">{sub}</div>
  <div class="art-hat__pucks" aria-hidden="true">
    <span></span><span></span><span></span>
  </div>
  <div class="art-hat__goals">
    {goals.map((g, i) => (
      <div class="art-hat__g">
        <div class="art-hat__gn">
          <span class="art-hat__gn-light" aria-hidden="true">🚨</span>
          <span class="art-hat__gn-num">GOAL {i + 1}</span>
        </div>
        <div class="art-hat__gp">{periodLabel(g.period)} <span class="art-hat__gc">{g.clock}</span></div>
      </div>
    ))}
  </div>
  <div class="art-hat__ctx">{context}</div>
</ArtifactShell>

<style is:global>
  .art-hat {
    background:
      radial-gradient(ellipse at 50% 0%, rgba(255, 213, 74, 0.18), transparent 55%),
      #120e03;
    border: 1px solid #3d2d08;
    padding: 22px 22px 40px;
    position: relative;
    overflow: hidden;
  }
  .art-hat__ehead {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; color: #ffd54a;
    letter-spacing: 0.22em; text-transform: uppercase;
    margin-top: 14px; margin-bottom: 6px;
  }
  .art-hat__bigline {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 18px; color: #b28e28;
    letter-spacing: 0.32em; text-transform: uppercase;
    margin-bottom: 4px;
  }
  .art-hat__name {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 32px; color: #fff;
    letter-spacing: 0.01em; line-height: 1;
    text-transform: uppercase;
  }
  .art-hat__sub {
    font-family: var(--font-mono); font-size: 10.5px;
    color: #ba9644; letter-spacing: 0.08em; margin-top: 5px;
    text-transform: uppercase;
  }
  .art-hat__pucks {
    margin-top: 14px;
    display: flex; gap: 8px;
  }
  .art-hat__pucks span {
    width: 14px; height: 14px; border-radius: 999px;
    background: #ffd54a;
    box-shadow: 0 0 0 3px rgba(255, 213, 74, 0.18);
  }
  .art-hat__goals {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    gap: 8px; margin-top: 14px;
  }
  .art-hat__g {
    background: rgba(255, 213, 74, 0.06);
    border: 1px solid rgba(255, 213, 74, 0.22);
    border-radius: 2px;
    padding: 10px 8px;
    text-align: center;
  }
  .art-hat__gn {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 11px; color: #b28e28;
    letter-spacing: 0.18em;
    display: flex; align-items: center; justify-content: center;
    gap: 4px;
  }
  /* The goal-light emoji can render at different intrinsic sizes
     across platforms (Apple ≈ 14px, Win ≈ 13px). Force 12px so the
     three pills line up cleanly across renderers. */
  .art-hat__gn-light {
    font-size: 12px;
    line-height: 1;
    /* Color emojis ignore CSS color, so a slight gold drop-shadow
       gives the lights a subtle ceremonial halo to match the card. */
    filter: drop-shadow(0 0 3px rgba(255, 213, 74, 0.45));
  }
  .art-hat__gn-num {
    line-height: 1;
  }
  .art-hat__gp {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 16px; color: #fff;
    letter-spacing: 0.04em; margin-top: 4px;
    font-variant-numeric: tabular-nums;
  }
  .art-hat__gc {
    color: #ffd54a; font-family: var(--font-mono);
    font-size: 12px; font-weight: 500; margin-left: 4px;
    letter-spacing: 0.02em;
  }
  .art-hat__ctx {
    margin-top: 14px;
    font-family: var(--font-mono); font-size: 11px;
    color: #ba9644; letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
