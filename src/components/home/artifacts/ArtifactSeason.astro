---
/**
 * ArtifactSeason — player-season summary card.
 *
 * Data contract (matches design `art-season`):
 *   - eyebrow      — header, e.g. "SEASON CARD · FORWARD"
 *   - player.name  — display name, e.g. "C. McDavid"
 *   - player.meta  — meta line, "EDM · C · 2025–26"
 *   - score.value  — big stat tile value (e.g. "+2.29")
 *   - score.label  — under-tile label (e.g. "AVG HGB · #1 / 476")
 *   - statsHtml    — short prose row with optional <b> bolding
 *   - sparkline    — array of {h: 0..1, neg?: bool} bars (24-bar season trace)
 *   - games        — exactly 3 signature games (best/best/worst convention)
 *
 * Python card-generator note: same data shape feeds the existing
 * scripts/cards/generate_player_season_card.py — keep these props in sync.
 */

import ArtifactShell, { type ArtifactTag, type ArtifactByline } from './ArtifactShell.astro';

export interface SeasonGameRow {
  date: string;
  /** "vs WSH" or "@ SJS" + " W 5-1 · 2G 2A" */
  text: string;
  /** Optional small-grey line tail like "W 5-1 · 2G 2A" (rendered with separator). */
  tail?: string;
  value: string;
  pos?: boolean;
  neg?: boolean;
}

export interface Props {
  tag?: ArtifactTag;
  byline?: ArtifactByline;
  eyebrow: string;
  player: { name: string; meta: string };
  score: { value: string; label: string };
  /** Allows <b>...</b> tags only. */
  statsHtml: string;
  sparkline: Array<{ h: number; neg?: boolean }>;
  games: [SeasonGameRow, SeasonGameRow, SeasonGameRow];
}

const { tag, byline, eyebrow, player, score, statsHtml, sparkline, games } = Astro.props;
---
<ArtifactShell variantClass="art-season" tag={tag} byline={byline} height={340}>
  <div class="art-season__ehead">{eyebrow}</div>
  <div class="art-season__top">
    <div>
      <div class="art-season__nm">{player.name}</div>
      <div class="art-season__meta">{player.meta}</div>
    </div>
    <div class="art-season__score-tile">
      <div class="art-season__v">{score.value}</div>
      <div class="art-season__k">{score.label}</div>
    </div>
  </div>
  <div class="art-season__rule"></div>
  <div class="art-season__stats" set:html={statsHtml}></div>
  <div class="art-season__spark">
    {sparkline.map((b) => (
      <div
        class:list={['art-season__b', { neg: b.neg }]}
        style={`height:${Math.max(4, Math.min(100, Math.round(b.h * 100)))}%;`}
      ></div>
    ))}
  </div>
  <div class="art-season__games-h">
    <span>SIGNATURE GAMES</span>
    <span style="color:#555;">BEST / WORST</span>
  </div>
  <div class="art-season__games">
    {games.map((g) => (
      <div class="art-season__g">
        <span class="art-season__d">{g.date}</span>
        <span class="art-season__t">
          {g.text}{g.tail && <span class="art-season__r"> {g.tail}</span>}
        </span>
        <span class:list={['art-season__gv', { pos: g.pos, neg: g.neg }]}>{g.value}</span>
      </div>
    ))}
  </div>
</ArtifactShell>

<style is:global>
  .art-season { background: #0a0a0a; padding: 22px; }
  .art-season__ehead {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; letter-spacing: 0.22em; text-transform: uppercase;
    color: #555; margin-top: 12px; margin-bottom: 6px;
  }
  .art-season__top {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 14px;
  }
  .art-season__nm {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 28px; color: #fff; line-height: 1;
    letter-spacing: 0.01em; text-transform: uppercase;
  }
  .art-season__meta {
    font-family: var(--font-mono); font-size: 10.5px;
    color: #666; margin-top: 5px; letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .art-season__score-tile {
    background: #00e676; color: #041d0f;
    padding: 10px 14px; text-align: center;
    border-radius: 2px; min-width: 116px;
  }
  .art-season__v {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 26px; line-height: 1;
    font-variant-numeric: tabular-nums; letter-spacing: -0.01em;
  }
  .art-season__k {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 8.5px; letter-spacing: 0.14em; text-transform: uppercase;
    margin-top: 3px; opacity: 0.75;
  }
  .art-season__rule { height: 2px; background: var(--hgb-red); margin: 12px 0; }
  .art-season__stats {
    font-family: var(--font-mono); font-size: 11px;
    color: #888; letter-spacing: 0.04em; margin-bottom: 8px;
  }
  .art-season__stats b { color: #f5f5f5; font-weight: 500; }
  .art-season__spark {
    height: 38px; display: flex; align-items: flex-end; gap: 2px; margin-top: 4px;
  }
  .art-season__b {
    background: #00e676; border-radius: 1px; width: 5px; flex: 0 0 5px;
  }
  .art-season__b.neg { background: var(--hgb-red); opacity: 0.8; }
  .art-season__games-h {
    font-family: var(--font-site-display); font-weight: 700;
    font-size: 9.5px; letter-spacing: 0.22em; color: #555;
    text-transform: uppercase; margin-top: 14px;
    display: flex; justify-content: space-between;
  }
  .art-season__games {
    margin-top: 6px; display: flex; flex-direction: column; gap: 3px;
  }
  .art-season__g {
    display: grid; grid-template-columns: 64px 1fr 60px;
    gap: 10px; font-size: 12px; align-items: baseline;
  }
  .art-season__d { font-family: var(--font-mono); font-size: 10.5px; color: #666; }
  .art-season__t {
    font-family: var(--font-site-display); font-weight: 600;
    color: #ddd; letter-spacing: 0.015em;
  }
  .art-season__r {
    color: #888; font-family: var(--font-mono); font-weight: 400; font-size: 10.5px;
  }
  .art-season__gv {
    text-align: right;
    font-family: var(--font-site-display); font-weight: 700;
    font-variant-numeric: tabular-nums; letter-spacing: 0.02em;
    color: #ddd;
  }
  .art-season__gv.pos { color: #00e676; }
  .art-season__gv.neg { color: var(--hgb-red); }
</style>
