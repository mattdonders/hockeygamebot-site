---
const SERIES = {
  east: [
    { higher: "CAR", lower: "OTT", higherSeed: 1, lowerSeed: 6, card: "series_prediction_CARvsOTT_dark_grouped.png", seriesCode: "A" },
    { higher: "BUF", lower: "BOS", higherSeed: 2, lowerSeed: 5, card: "series_prediction_BUFvsBOS_dark_grouped.png", seriesCode: "B" },
    { higher: "TBL", lower: "MTL", higherSeed: 3, lowerSeed: 4, card: "series_prediction_TBLvsMTL_dark_grouped.png", seriesCode: "C" },
    { higher: "PIT", lower: "PHI", higherSeed: 7, lowerSeed: 8, card: "series_prediction_PITvsPHI_dark_grouped.png", seriesCode: "D" },
  ],
  west: [
    { higher: "COL", lower: "LAK", higherSeed: 1, lowerSeed: 8, card: null, seriesCode: "E", tbd: true },
    { higher: "DAL", lower: "MIN", higherSeed: 2, lowerSeed: 3, card: "series_prediction_DALvsMIN_dark_grouped.png", seriesCode: "F" },
    { higher: "VGK", lower: "UTA", higherSeed: 4, lowerSeed: 5, card: "series_prediction_VGKvsUTA_dark_grouped.png", seriesCode: "G" },
    { higher: "EDM", lower: "ANA", higherSeed: 6, lowerSeed: 7, card: null, seriesCode: "H", tbd: true },
  ],
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>2026 Stanley Cup Playoffs — Round 1 Predictions · HockeyGameBot</title>
  <meta name="description" content="Model predictions for every 2026 Stanley Cup Playoffs first-round series. Blend model: 60/40 Elo/xGF.">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="apple-touch-icon" href="/favicon-180x180.png">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; }
body { background: #0d0d14; color: #fff; font-family: 'Space Grotesk', sans-serif; min-height: 100vh; }

/* ── Topbar ── */
.topbar { height: 52px; background: #0d0d14; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; padding: 0 24px; gap: 16px; position: sticky; top: 0; z-index: 100; }
.brand { font-family: 'Oswald', sans-serif; font-size: 22px; font-weight: 700; color: #fff; letter-spacing: 0.1em; text-decoration: none; }
.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 6px; }
.topbar-link { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; color: rgba(255,255,255,0.7); text-decoration: none; padding: 5px 10px; border: 1px solid rgba(255,255,255,0.2); border-radius: 3px; transition: color 0.15s, border-color 0.15s; white-space: nowrap; line-height: 1; display: inline-flex; align-items: center; }
.topbar-link:hover { color: #fff; border-color: rgba(255,255,255,0.5); }
.topbar-link--active { color: #E8002D; border-color: rgba(232,0,45,0.4); }
.topbar-link--active:hover { color: #E8002D; border-color: #E8002D; }
.topbar-link--support { gap: 5px; }
.topbar-link--support:hover { color: #fff; border-color: rgba(255,255,255,0.5); }
.support-heart { opacity: 0.6; transition: opacity 0.15s; flex-shrink: 0; }
.topbar-link--support:hover .support-heart { opacity: 1; }

/* ── Hero ── */
.hero { padding: 40px 24px 28px; border-bottom: 1px solid rgba(255,255,255,0.07); }
.hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.18em; color: #E8002D; text-transform: uppercase; margin-bottom: 8px; }
.hero-title { font-family: 'Oswald', sans-serif; font-size: 32px; font-weight: 700; letter-spacing: 0.04em; line-height: 1.1; margin-bottom: 10px; }
.hero-meta { font-size: 13px; color: rgba(255,255,255,0.4); letter-spacing: 0.08em; text-transform: uppercase; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.hero-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: rgba(255,255,255,0.25); }

/* ── Content ── */
.content { max-width: 1200px; margin: 0 auto; padding: 32px 24px 64px; }

/* ── Conference sections ── */
.conference { margin-bottom: 48px; }
.conference-header { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; color: rgba(255,255,255,0.35); text-transform: uppercase; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.07); }

/* ── Series grid ── */
.series-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

/* ── Series card ── */
.series-card { background: #111118; border: 1px solid rgba(255,255,255,0.07); border-radius: 6px; overflow: hidden; }
.series-card img { width: 100%; display: block; }
.series-card-footer { padding: 12px 14px; display: flex; align-items: center; justify-content: space-between; gap: 8px; border-top: 1px solid rgba(255,255,255,0.06); }
.series-matchup { font-size: 12px; font-weight: 700; letter-spacing: 0.06em; color: rgba(255,255,255,0.8); }
.series-matchup span { color: rgba(255,255,255,0.35); font-weight: 400; margin: 0 4px; }
.series-status { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; color: rgba(255,255,255,0.35); text-transform: uppercase; }
.series-status.live { color: #4ade80; }
.series-status.complete { color: rgba(255,255,255,0.5); }

/* ── TBD placeholder ── */
.series-tbd { aspect-ratio: 16/9; background: rgba(255,255,255,0.03); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; }
.series-tbd-label { font-size: 11px; font-weight: 700; letter-spacing: 0.14em; color: rgba(255,255,255,0.2); text-transform: uppercase; }
.series-tbd-teams { font-family: 'Oswald', sans-serif; font-size: 20px; font-weight: 700; color: rgba(255,255,255,0.15); letter-spacing: 0.06em; }

/* ── Responsive ── */
@media (max-width: 700px) {
  .hero { padding: 28px 16px 20px; }
  .hero-title { font-size: 24px; }
  .content { padding: 24px 16px 48px; }
  .series-grid { grid-template-columns: 1fr; }
  .topbar { padding: 0 16px; }
}
</style>
</head>
<body>

<div class="topbar">
  <a href="/" class="brand">HGB</a>
  <div class="topbar-right">
    <a href="/playoffs" class="topbar-link topbar-link--active">PLAYOFFS</a>
    <a href="/teams" class="topbar-link">TEAMS</a>
    <a href="/support" class="topbar-link topbar-link--support" aria-label="Support HockeyGameBot">
      <svg class="support-heart" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      <span>SUPPORT</span>
    </a>
  </div>
</div>

<div class="hero">
  <div class="hero-eyebrow">2026 Stanley Cup Playoffs</div>
  <div class="hero-title">Round 1 Predictions</div>
  <div class="hero-meta">
    <span>Pre-series model predictions</span>
    <div class="hero-meta-dot"></div>
    <span>Games begin April 18</span>
  </div>
</div>

<div class="content">
  {(['east', 'west'] as const).map(conf => (
    <div class="conference">
      <div class="conference-header">
        {conf === 'east' ? 'Eastern Conference' : 'Western Conference'}
      </div>
      <div class="series-grid">
        {SERIES[conf].map(s => (
          <div class="series-card" data-higher={s.higher} data-lower={s.lower}>
            {s.card
              ? <img src={`/playoffs/2026/${s.card}`} alt={`${s.higher} vs ${s.lower} series prediction`} loading="lazy" />
              : <div class="series-tbd">
                  <div class="series-tbd-teams">{s.higher} · {s.lower}</div>
                  <div class="series-tbd-label">Matchup TBD</div>
                </div>
            }
            <div class="series-card-footer">
              <div class="series-matchup">
                #{s.higherSeed} {s.higher}<span>vs</span>#{s.lowerSeed} {s.lower}
              </div>
              <div class="series-status" data-status={`${s.higher}-${s.lower}`}>
                Begins Apr 18
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}
</div>

<script>
async function loadSeriesStatus() {
  try {
    const res = await fetch('https://api-web.nhle.com/v1/playoff-series/carousel/20252026');
    if (!res.ok) return;
    const data = await res.json();
    const round1 = data.rounds?.find((r: any) => r.roundNumber === 1);
    if (!round1) return;

    for (const series of round1.series) {
      const top = series.topSeedTeam?.abbrev;
      const bot = series.bottomSeedTeam?.abbrev;
      const topW = series.topSeedTeam?.wins ?? 0;
      const botW = series.bottomSeedTeam?.wins ?? 0;
      if (!top || !bot) continue;

      // Find the status element by matching either team order
      const el = document.querySelector(`[data-status="${top}-${bot}"]`) ||
                 document.querySelector(`[data-status="${bot}-${top}"]`);
      if (!el) continue;

      if (topW === 0 && botW === 0) {
        el.textContent = 'Begins Apr 18';
      } else if (topW === 4) {
        el.textContent = `${top} wins 4-${botW}`;
        el.classList.add('complete');
      } else if (botW === 4) {
        el.textContent = `${bot} wins 4-${topW}`;
        el.classList.add('complete');
      } else {
        const leader = topW > botW ? top : bot;
        const ahead = Math.max(topW, botW);
        const behind = Math.min(topW, botW);
        el.textContent = `${leader} leads ${ahead}-${behind}`;
        el.classList.add('live');
      }
    }
  } catch (e) {
    // silently fail — static text remains
  }
}

loadSeriesStatus();
</script>

</body>
</html>
