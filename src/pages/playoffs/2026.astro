// ── card helpers (server-side) ────────────────────────────────────────────────
function buildCardSegs(s: typeof SERIES[0]) {
  if ((s as any).tbd || !s.a.dist.length) return [];
  const [a4,a5,a6,a7] = s.a.dist;
  const [b4,b5,b6,b7] = s.b.dist;
  const hc = s.a.color, lc = s.b.color;
  const raw = [
    { w:a4, c:mixHex(hc,'#000000',32), label:`${s.a.abbr} in 4`, boundary:false },
    { w:a5, c:mixHex(hc,'#000000',18), label:`${s.a.abbr} in 5`, boundary:false },
    { w:a6, c:hc,                       label:`${s.a.abbr} in 6`, boundary:false },
    { w:a7, c:mixHex(hc,'#ffffff',14), label:`${s.a.abbr} in 7`, boundary:false },
    { w:b7, c:mixHex(lc,'#ffffff',14), label:`${s.b.abbr} in 7`, boundary:true  },
    { w:b6, c:lc,                       label:`${s.b.abbr} in 6`, boundary:false },
    { w:b5, c:mixHex(lc,'#000000',18), label:`${s.b.abbr} in 5`, boundary:false },
    { w:b4, c:mixHex(lc,'#000000',32), label:`${s.b.abbr} in 4`, boundary:false },
  ];
  const maxW = Math.max(...raw.map(x => x.w));
  return raw.filter(sg => sg.w > 0).map(sg => ({ ...sg, isSmall: sg.w <= 6, isMax: sg.w === maxW }));
}

function mostLikely(s: typeof SERIES[0]) {
  if ((s as any).tbd || !s.a.dist.length) return null;
  const all = [
    ...s.a.dist.map((v,i) => ({ label:`${s.a.abbr} in ${i+4}`, v })),
    ...s.b.dist.map((v,i) => ({ label:`${s.b.abbr} in ${i+4}`, v })),
  ];
  return all.reduce((best, x) => x.v > best.v ? x : best);
}

function winPct(dist: number[]) { return dist.reduce((s,v) => s+v, 0); }

const eastSeries = SERIES.filter(s => s.conf === 'East');
const westSeries = SERIES.filter(s => s.conf === 'West');
