// ── helpers ───────────────────────────────────────────────────────────────────
function mixHex(hex: string, target: string, amount: number): string {
  if (!hex.startsWith('#') || hex.length < 7) return hex;
  const p = (h: string, o: number) => parseInt(h.slice(o, o + 2), 16);
  const r1=p(hex,1), g1=p(hex,3), b1=p(hex,5);
  const r2=p(target,1), g2=p(target,3), b2=p(target,5);
  const t = amount / 100;
  const r=Math.round(r1+(r2-r1)*t), g=Math.round(g1+(g2-g1)*t), b=Math.round(b1+(b2-b1)*t);
  return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
}

// ── data ──────────────────────────────────────────────────────────────────────
const SERIES = [
  // ── East ──────────────────────────────────────────────────────────────────
  {
    id: 'car-ott', conf: 'East', miniBadge: 'East · M1 vs WC2',
    games: [null,null,null,null,null,null,null] as (string|null)[],
    a: { abbr:'CAR', name:'Carolina Hurricanes', color:'#CC0000',
         seed:'Metro · 1', seedFull:'Metropolitan · 1st', dist:[8,16,16,18] },
    b: { abbr:'OTT', name:'Ottawa Senators',     color:'#E31837',
         seed:'Atl · WC2', seedFull:'Atlantic · Wild Card 2', dist:[5,9,15,13] },
  },
  {
    id: 'buf-bos', conf: 'East', miniBadge: 'East · A1 vs WC1',
    games: [null,null,null,null,null,null,null] as (string|null)[],
    a: { abbr:'BUF', name:'Buffalo Sabres', color:'#003087',
         seed:'Atl · 1', seedFull:'Atlantic · 1st', dist:[10,19,18,18] },
    b: { abbr:'BOS', name:'Boston Bruins',  color:'#FCB514',
         seed:'Atl · WC1', seedFull:'Atlantic · Wild Card 1', dist:[4,8,12,12] },
  },
  {
    id: 'tbl-mtl', conf: 'East', miniBadge: 'East · A2 vs A3',
    games: [null,null,null,null,null,null,null] as (string|null)[],
    a: { abbr:'TBL', name:'Tampa Bay Lightning',   color:'#0038A8',
         seed:'Atl · 2', seedFull:'Atlantic · 2nd', dist:[11,20,18,18] },
    b: { abbr:'MTL', name:'Montréal Canadiens',    color:'#AF1E2D',
         seed:'Atl · 3', seedFull:'Atlantic · 3rd', dist:[4,7,12,11] },
  },
  {
    id: 'pit-phi', conf: 'East', miniBadge: 'East · M2 vs M3',
    games: [null,null,null,null,null,null,null] as (string|null)[],
    a: { abbr:'PIT', name:'Pittsburgh Penguins',   color:'#FCB514',
         seed:'Met · 2', seedFull:'Metropolitan · 2nd', dist:[6,13,14,16] },
    b: { abbr:'PHI', name:'Philadelphia Flyers',   color:'#F74902',
         seed:'Met · 3', seedFull:'Metropolitan · 3rd', dist:[7,12,17,14] },
