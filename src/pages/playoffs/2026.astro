<style is:global>
/* ── TOKENS ── */
:root {
  --bg:      #EFEEE8;
  --surface: #FFFFFF;
  --ink:     #0d0d14;
  --ink-72:  rgba(13,13,20,0.72);
  --ink-56:  rgba(13,13,20,0.56);
  --ink-04:  rgba(13,13,20,0.04);
  --ink-48:  rgba(13,13,20,0.48);
  --ink-32:  rgba(13,13,20,0.32);
  --ink-20:  rgba(13,13,20,0.20);
  --ink-14:  rgba(13,13,20,0.14);
  --ink-10:  rgba(13,13,20,0.10);
  --ink-06:  rgba(13,13,20,0.06);
  --red:     #E8002D;
  --grid-line: rgba(13,13,20,0.04);
  --display: "Barlow Condensed", sans-serif;
  --body:    "Barlow", sans-serif;
  --mono:    "JetBrains Mono", monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
/* CSS rules with display:* override the default [hidden]{display:none}. Force it back. */
[hidden] { display: none !important; }
html { -webkit-font-smoothing: antialiased; }
body { background: var(--bg); color: var(--ink); font-family: var(--body); min-height: 100vh; font-size: 14px; line-height: 1.4; }
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }

/* ── NAV ── */
.nav { background: var(--bg); border-bottom: 1px solid var(--ink-14); position: sticky; top: 0; z-index: 50; }
.nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 32px; height: 52px; display: flex; align-items: center; gap: 20px; }
.wordmark { font-family: var(--display); font-weight: 800; font-size: 20px; letter-spacing: 0.04em; text-transform: uppercase; text-decoration: none; color: var(--ink); display: inline-flex; align-items: center; }
.wordmark .dot { width: 6px; height: 6px; background: var(--red); border-radius: 50%; margin: 0 6px; display: inline-block; }
.nav-links { margin-left: auto; display: flex; align-items: center; gap: 0; font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; }
.nav-links a { padding: 5px 12px; color: var(--ink-48); text-decoration: none; }
.nav-links a:hover, .nav-links a.active { color: var(--ink); }
.nav-links .sep { color: var(--ink-20); }

/* ── MASTHEAD ── */
.mast {
  position: relative; overflow: hidden;
  padding: 56px 0 48px;
  border-bottom: 2px solid var(--ink);
  background-color: var(--bg);
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 96px 96px;
}
.mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.mast-corners .corner { position: absolute; width: 16px; height: 16px; }
.mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 0 32px; }
.mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 28px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
.mast-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; }
.mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; flex-shrink: 0; }
.mast-meta { font-size: 10px; opacity: 0.6; text-align: right; font-family: var(--mono); }
.mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 32px 36px 28px; position: relative; }
.mast-headline { font-family: var(--display); font-weight: 800; text-transform: uppercase; font-size: clamp(36px,5vw,56px); line-height: 0.92; letter-spacing: -0.01em; }
.mast-sub { font-family: var(--mono); font-size: 12px; color: var(--ink-48); margin-top: 10px; letter-spacing: 0.04em; }

/* ── BRACKET ── */
.bracket-wrap { display: grid; grid-template-columns: 1fr 80px 1fr; gap: 0; margin-top: 20px; border-top: 1px solid var(--ink-10); }
.b-conf { display: flex; gap: 0; overflow: hidden; }
.b-conf.west { flex-direction: row-reverse; }
.b-col { display: flex; flex-direction: column; border-right: 1px solid var(--ink-06); min-width: 0; }
.b-conf.west .b-col { border-right: none; border-left: 1px solid var(--ink-06); }
.b-col-hd { font-family: var(--mono); font-size: 9px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-32); text-align: center; padding: 6px 4px 5px; border-bottom: 1px solid var(--ink-10); background: var(--bg); flex-shrink: 0; }
.b-team { display: flex; align-items: center; gap: 7px; padding: 8px 12px; border-bottom: 1px solid var(--ink-06); border-left: 3px solid transparent; flex-shrink: 0; }
.b-team:last-child { border-bottom: none; }
.b-team.elim { opacity: 0.28; }
.b-team.winner { }
.b-logo { width: 22px; height: 22px; object-fit: contain; flex-shrink: 0; }
.b-abbr { font-family: var(--display); font-weight: 800; font-size: 18px; letter-spacing: 0.02em; flex: 1; min-width: 0; line-height: 1; }
.b-wins { font-family: var(--display); font-weight: 800; font-size: 18px; font-variant-numeric: tabular-nums; color: var(--ink-32); line-height: 1; }
.b-team.winner .b-wins { color: var(--ink-72); }
.b-team.elim .b-wins { color: var(--ink-20); }
.b-elim-tag { font-family: var(--mono); font-size: 9px; letter-spacing: 0.08em; color: var(--ink-32); }
.b-pair-gap { height: 8px; background: var(--bg); border-bottom: 1px solid var(--ink-06); flex-shrink: 0; }
.b-tbd { display: flex; align-items: center; justify-content: center; flex: 1; padding: 12px 8px; }
.b-tbd-inner { font-family: var(--mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-20); border: 1px dashed var(--ink-14); padding: 3px 8px; }
.b-scf { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; padding: 16px 8px; background: var(--bg); }
.b-scf-icon { font-size: 24px; line-height: 1; }
.b-scf-lbl { font-family: var(--mono); font-size: 8px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32); text-align: center; }
/* Footer model note */
.bracket-foot { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.04em; padding: 8px 20px 6px; text-align: right; }

/* Cup strip */
.cup-strip { border-top: 1px solid var(--ink-10); padding: 14px 20px 0; }
.cup-strip-label { display: flex; align-items: baseline; gap: 12px; margin-bottom: 12px; }
.cup-strip-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-48); }
.cup-strip-note { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); letter-spacing: 0.04em; }
.cup-strip-teams { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
@media (max-width: 700px) { .cup-strip-teams { grid-template-columns: repeat(2, 1fr); } }
.cup-team { display: flex; align-items: center; gap: 8px; }
.cup-rank { font-family: var(--mono); font-size: 10px; color: var(--ink-20); min-width: 14px; font-variant-numeric: tabular-nums; }
.cup-logo { width: 22px; height: 22px; object-fit: contain; flex-shrink: 0; }
.cup-info { display: flex; flex-direction: column; flex: 1; min-width: 0; }
.cup-abbr { font-family: var(--display); font-weight: 800; font-size: 14px; letter-spacing: 0.02em; line-height: 1; }
.cup-pct { font-family: var(--mono); font-weight: 700; font-size: 11px; font-variant-numeric: tabular-nums; }
.cup-bar-wrap { flex: 1; height: 3px; background: var(--ink-06); overflow: hidden; align-self: center; }
.cup-bar-fill { height: 100%; opacity: 0.7; }

/* ── CONTENT LAYOUT ── */
.content { max-width: 1200px; margin: 0 auto; padding: 40px 32px 100px; }
.conf-block { margin-bottom: 52px; }
.section-label {
  font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--ink-32); margin: 0 0 16px;
  display: flex; align-items: center; gap: 10px;
}
.section-label .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; flex-shrink: 0; }
.section-label::after { content: ''; flex: 1; height: 1px; background: var(--ink-14); }
.series-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.pending-strip { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px; }

/* ── SERIES CARD ── */
.hgb-card {
  position: relative; display: block; padding: 0;
  background: var(--surface);
  border: 1px solid var(--ink-14);
  border-left: 4px solid var(--hgb-team-a, var(--ink-14));
  box-shadow: 0 1px 3px rgba(13,13,20,0.06);
  color: var(--ink); text-decoration: none; cursor: pointer; text-align: left;
  width: 100%; font-family: inherit;
  transition: transform 220ms cubic-bezier(.2,.8,.2,1), border-color 220ms ease, box-shadow 220ms ease;
  overflow: hidden;
}
.hgb-card:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(13,13,20,0.10); }
.hgb-card:focus-visible { outline: 2px solid rgba(232,0,45,0.6); outline-offset: 2px; }
.hgb-card__inner { padding: 18px 20px 16px; }

/* Cards render server-side with real data from hgb-api (build-time fetch) —
   no placeholder numbers, no fade-in needed. A client-side loadModelData()
   still runs to pick up cron updates that happened after the last build. */

/* meta strip */
.hgb-card__meta { display: flex; align-items: center; gap: 10px; font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 12px; }
.hgb-mini-badge { padding: 2px 6px; border: 1px solid var(--ink-14); color: var(--ink-32); background: transparent; }

/* teams row */
.hgb-card__teams { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 10px; margin-bottom: 12px; }
.hgb-card__team { display: flex; align-items: center; gap: 10px; min-width: 0; }
.hgb-card__team--b { flex-direction: row-reverse; text-align: right; }
.hgb-card__logo { width: 36px; height: 36px; object-fit: contain; flex-shrink: 0; }
.hgb-card__ids { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.hgb-card__seed { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.12em; text-transform: uppercase; }
.hgb-card__abbr { font-family: var(--display); font-weight: 800; font-size: 20px; line-height: 0.9; letter-spacing: 0.02em; color: var(--team-color, var(--ink)); }
.hgb-card__pct { font-family: var(--mono); font-weight: 700; font-size: 22px; line-height: 0.85; color: var(--ink); letter-spacing: -0.01em; font-variant-numeric: tabular-nums; display: inline-flex; align-items: baseline; gap: 2px; }
.hgb-card__pct small { font-size: 12px; color: var(--ink-48); }
.hgb-card__vs { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.2em; padding: 0 4px; align-self: center; }

/* distribution bar */
.hgb-card__bar { display: flex; height: 24px; overflow: hidden; background: var(--ink-06); border-top: 1px solid var(--ink-10); border-bottom: 1px solid var(--ink-10); margin-bottom: 12px; }
.hgb-card__seg { position: relative; background: var(--c); flex: var(--w) 0 0; display: flex; align-items: center; justify-content: center; }
.hgb-card__seg + .hgb-card__seg { border-left: 1px solid rgba(239,238,232,0.7); }
.hgb-card__seg[data-boundary] { border-left: 2px solid rgba(13,13,20,0.25) !important; }
.hgb-card__seg-val { font-family: var(--mono); font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.95); font-variant-numeric: tabular-nums; text-shadow: 0 1px 3px rgba(0,0,0,0.5); }
.hgb-card__seg--small .hgb-card__seg-val { display: none; }
.hgb-card__seg--max .hgb-card__seg-val { font-size: 15px; }
.hgb-card__bar .hgb-card__seg[data-dominant] .hgb-card__seg-val { font-size: 18px; }

/* footer */
.hgb-card__foot { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; padding: 10px 20px 14px; border-top: 1px solid var(--ink-06); }
.hgb-card__foot-col { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
.hgb-card__foot-col--right { text-align: right; align-items: flex-end; }
.hgb-card__foot-label { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.12em; text-transform: uppercase; }
.hgb-card__foot-val { font-family: var(--mono); font-size: 12px; color: var(--ink); letter-spacing: 0.01em; white-space: nowrap; font-variant-numeric: tabular-nums; }
.hgb-card__foot-val strong { color: var(--hgb-team-a); }

/* TBD */
.series-tbd { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 20px; min-height: 76px; background: var(--ink-04); border: 1px dashed var(--ink-14); }
.series-tbd-teams { font-family: var(--display); font-weight: 700; font-size: 16px; color: var(--ink-20); letter-spacing: 0.06em; }
.series-tbd-sep { color: var(--ink-32); font-family: var(--mono); font-size: 10px; }
.series-tbd-label { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.14em; text-transform: uppercase; border: 1px solid var(--ink-14); padding: 3px 7px; }

/* ── MODAL ── */
.hgb-modal { position: fixed; inset: 0; z-index: 200; display: flex; align-items: flex-end; justify-content: center; pointer-events: none; }
.hgb-modal.is-open { pointer-events: auto; }
.hgb-modal__scrim { position: absolute; inset: 0; background: rgba(13,13,20,0.55); backdrop-filter: blur(4px); opacity: 0; transition: opacity 320ms ease; }
.hgb-modal.is-open .hgb-modal__scrim { opacity: 1; }
.hgb-modal__sheet {
  position: relative; width: 100%; max-width: 860px; max-height: 94vh;
  overflow-y: auto;
  background: var(--surface);
  border: 1px solid var(--ink); border-bottom: none;
  border-radius: 0;
  box-shadow: 0 -8px 40px rgba(13,13,20,0.15);
  transform: translateY(60px); opacity: 0;
  transition: transform 420ms cubic-bezier(.2,.8,.2,1), opacity 260ms ease;
  scrollbar-width: thin;
  scrollbar-color: var(--ink-14) transparent;
}
.hgb-modal__sheet::-webkit-scrollbar { width: 6px; }
.hgb-modal__sheet::-webkit-scrollbar-track { background: transparent; }
.hgb-modal__sheet::-webkit-scrollbar-thumb { background: var(--ink-14); border-radius: 3px; }
.hgb-modal__sheet::-webkit-scrollbar-thumb:hover { background: var(--ink-32); }
.hgb-modal.is-animating .hgb-modal__sheet { overflow: hidden; }
.hgb-modal.is-open .hgb-modal__sheet { transform: translateY(0); opacity: 1; }

.hgb-modal__handle { position: absolute; top: 10px; left: 50%; transform: translateX(-50%); width: 42px; height: 4px; background: var(--ink-14); border: none; cursor: grab; z-index: 3; transition: background 200ms, width 200ms; }
.hgb-modal__handle:hover { background: var(--ink-32); width: 56px; }

/* modal util bar */
.hgb-util { position: relative; z-index: 2; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 22px 28px 14px; border-bottom: 1px solid var(--ink-14); }
.hgb-util__group { display: flex; align-items: center; gap: 10px; }
.hgb-mono { font-family: var(--mono); font-size: 10px; line-height: 1.2; color: var(--ink-48); letter-spacing: 0.1em; text-transform: uppercase; }
.hgb-badge { display: inline-flex; align-items: center; padding: 4px 8px; border: 1px solid var(--ink-14); font-family: var(--mono); font-size: 9px; font-weight: 600; color: var(--ink-48); letter-spacing: 0.18em; text-transform: uppercase; background: transparent; }
.hgb-modal__close { width: 28px; height: 28px; border: 1px solid var(--ink-14); background: transparent; color: var(--ink-48); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 150ms ease; }
.hgb-modal__close:hover { color: var(--ink); border-color: var(--ink); background: var(--ink-06); }
.hgb-modal__share { width: 28px; height: 28px; border: 1px solid var(--ink-14); background: transparent; color: var(--ink-48); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 150ms ease; }
.hgb-modal__share:hover { color: var(--red); border-color: rgba(232,0,45,0.4); background: rgba(232,0,45,0.06); }
.hgb-modal__share.is-copied { color: #16a34a; border-color: rgba(22,163,74,0.4); background: rgba(22,163,74,0.06); }

/* matchup header */
.hgb-matchup { position: relative; z-index: 2; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 28px; padding: 24px 28px 28px; border-bottom: 1px solid var(--ink-14); }
.hgb-team { display: flex; align-items: center; gap: 18px; }
.hgb-team--b { flex-direction: row-reverse; text-align: right; }
.hgb-team__logo { width: 60px; height: 60px; object-fit: contain; }
.hgb-team__meta { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
.hgb-team__seed { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 4px; display: inline-flex; align-items: center; gap: 6px; }
.hgb-team__seed::before { content: ''; width: 10px; height: 2px; background: var(--team-color); display: inline-block; }
.hgb-team--b .hgb-team__seed { justify-content: flex-end; }
.hgb-team--b .hgb-team__seed::before { display: none; }
.hgb-team--b .hgb-team__seed::after { content: ''; width: 10px; height: 2px; background: var(--team-color); display: inline-block; }
.hgb-team__abbr { font-family: var(--display); font-weight: 800; font-size: 32px; line-height: 0.9; letter-spacing: 0.02em; color: var(--team-color, var(--ink)); }
.hgb-team__name { font-family: var(--body); font-size: 12px; line-height: 1.3; color: var(--ink-48); }
.hgb-matchup__center { display: flex; flex-direction: column; align-items: center; gap: 6px; min-width: 92px; }
.hgb-matchup__vs { font-family: var(--mono); font-size: 13px; color: var(--ink-32); letter-spacing: 0.28em; padding: 0 8px; }
.hgb-matchup__score { display: flex; flex-direction: column; align-items: center; gap: 6px; }
.hgb-matchup__score-nums { display: flex; align-items: center; gap: 10px; font-family: var(--display); font-weight: 800; font-size: 44px; line-height: 0.9; letter-spacing: 0.02em; font-variant-numeric: tabular-nums; }
.hgb-matchup__score-a, .hgb-matchup__score-b { color: var(--ink-32); }
.hgb-matchup__score-a.is-lead { color: var(--hgb-team-a); }
.hgb-matchup__score-b.is-lead { color: var(--hgb-team-b); }
.hgb-matchup__score-sep { color: var(--ink-32); font-size: 30px; }
.hgb-matchup__status { font-family: var(--mono); font-size: 9px; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-48); }
.hgb-matchup__status.is-lead-a { color: var(--hgb-team-a); }
.hgb-matchup__status.is-lead-b { color: var(--hgb-team-b); }

/* series tracker */
.hgb-tracker { position: relative; z-index: 2; padding: 22px 28px 24px; display: flex; flex-direction: column; gap: 14px; border-bottom: 1px solid var(--ink-14); }
.hgb-tracker__grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; max-width: 560px; width: 100%; margin: 0 auto; }
.hgb-tracker__game { aspect-ratio: 1; border: 1px solid var(--ink-14); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; min-height: 52px; background: var(--ink-04); }
.hgb-tracker__game--played { background: var(--c); border-color: var(--c); }
.hgb-tracker__game--next { border-color: var(--ink); background: var(--ink-06); }
.hgb-tracker__winner { font-family: var(--display); font-weight: 700; font-size: 12px; line-height: 1; color: #fff; letter-spacing: 0.04em; }
.hgb-tracker__num { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.14em; text-transform: uppercase; }
.hgb-tracker__game--played .hgb-tracker__num { color: rgba(255,255,255,0.75); }
.hgb-tracker__game--next .hgb-tracker__num { color: var(--ink-56); }
.hgb-tracker__meta { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; padding: 0 2px; }
.hgb-tracker__next { display: flex; align-items: baseline; gap: 8px; }
.hgb-tracker__next-label { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.18em; text-transform: uppercase; }
.hgb-tracker__next-val { font-family: var(--mono); font-size: 13px; color: var(--ink); letter-spacing: 0.02em; font-variant-numeric: tabular-nums; }
.hgb-tracker__advance { display: flex; align-items: baseline; gap: 18px; }
.hgb-tracker__adv-item { display: inline-flex; align-items: baseline; gap: 6px; font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.14em; text-transform: uppercase; }
.hgb-tracker__adv-num { font-family: var(--display); font-weight: 800; font-size: 18px; line-height: 1; color: var(--team-color); letter-spacing: 0.02em; font-variant-numeric: tabular-nums; }

/* win probability */
.hgb-wp { position: relative; z-index: 2; padding: 28px 28px 32px; display: flex; flex-direction: column; align-items: center; gap: 16px; border-bottom: 1px solid var(--ink-14); }
.hgb-wp__label { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.22em; text-transform: uppercase; }
.hgb-wp__row { width: 100%; position: relative; display: grid; grid-template-columns: 1fr 1fr; align-items: center; }
.hgb-wp__row::before { content: ''; position: absolute; top: 8%; bottom: 8%; left: 50%; width: 1px; background: var(--ink-14); }
.hgb-wp__side { display: flex; align-items: baseline; justify-content: center; gap: 4px; line-height: 1; }
.hgb-wp__num { font-family: var(--display); font-weight: 800; font-size: 84px; line-height: 0.85; color: var(--ink); letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
.hgb-wp__pct { font-family: var(--display); font-weight: 700; font-size: 28px; line-height: 1; color: var(--team-color); }

/* distribution chart */
.hgb-dist { position: relative; z-index: 2; padding: 28px 28px 40px; border-top: 1px solid var(--ink-14); }
.hgb-dist__head { margin-bottom: 20px; }
.hgb-dist__h { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-48); }
.hgb-dist__body { display: grid; grid-template-columns: 32px 1fr; gap: 18px; }
.hgb-dist__y { display: flex; flex-direction: column; justify-content: space-between; font-family: var(--mono); font-size: 10px; color: var(--ink-32); text-align: right; height: 280px; font-variant-numeric: tabular-nums; }
.hgb-dist__y span::after { content: ''; display: inline-block; width: 4px; height: 1px; background: var(--ink-20); margin-left: 4px; vertical-align: middle; }
.hgb-dist__y .hgb-dist__y-0 { color: var(--ink-48); font-weight: 600; }
.hgb-dist__y .hgb-dist__y-0::after { background: var(--ink-32); width: 6px; }
.hgb-dist__plot { position: relative; height: 280px; display: grid; grid-template-columns: repeat(4, 1fr); }
.hgb-dist__plot::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(to bottom,
    transparent 12.5%, rgba(13,13,20,0.03) 12.5%, rgba(13,13,20,0.03) calc(12.5% + 1px), transparent calc(12.5% + 1px),
    transparent 25%,   rgba(13,13,20,0.03) 25%,   rgba(13,13,20,0.03) calc(25% + 1px),   transparent calc(25% + 1px),
    transparent 37.5%, rgba(13,13,20,0.03) 37.5%, rgba(13,13,20,0.03) calc(37.5% + 1px), transparent calc(37.5% + 1px),
    transparent 62.5%, rgba(13,13,20,0.03) 62.5%, rgba(13,13,20,0.03) calc(62.5% + 1px), transparent calc(62.5% + 1px),
    transparent 75%,   rgba(13,13,20,0.03) 75%,   rgba(13,13,20,0.03) calc(75% + 1px),   transparent calc(75% + 1px),
    transparent 87.5%, rgba(13,13,20,0.03) 87.5%, rgba(13,13,20,0.03) calc(87.5% + 1px), transparent calc(87.5% + 1px)
  );
  pointer-events: none;
}
.hgb-dist__plot::after { content: ''; position: absolute; left: 0; right: 0; top: 50%; height: 1px; background: var(--ink-20); z-index: 3; }
.hgb-dist__col { position: relative; display: grid; grid-template-rows: 1fr 28px 1fr; z-index: 1; }
.hgb-dist__half { position: relative; display: flex; justify-content: center; overflow: visible; }
.hgb-dist__half--top { align-items: flex-end; }
.hgb-dist__half--bot { align-items: flex-start; }
.hgb-dist__bar {
  position: relative; width: 54px; max-width: 60%;
  height: 0;
  transition: height 700ms cubic-bezier(.2,.8,.2,1) var(--delay, 0ms);
  background: linear-gradient(to top, color-mix(in srgb, var(--team-color), #000 10%), color-mix(in srgb, var(--team-color), #fff 12%));
  border-radius: 1px 1px 0 0;
}
.hgb-modal.is-open .hgb-dist__bar { height: var(--v); }
.hgb-dist__bar--a { --team-color: var(--hgb-team-a); }
.hgb-dist__bar--b { --team-color: var(--hgb-team-b); border-radius: 0 0 1px 1px; background: linear-gradient(to bottom, color-mix(in srgb, var(--team-color), #000 10%), color-mix(in srgb, var(--team-color), #fff 12%)); }
.hgb-dist__bar::after { content: ''; position: absolute; left: -5px; right: -5px; top: -1px; height: 2px; background: color-mix(in srgb, var(--team-color), #fff 25%); box-shadow: 0 0 12px color-mix(in srgb, var(--team-color), transparent 40%); }
.hgb-dist__bar--b::after { top: auto; bottom: -1px; }
.hgb-dist__bar--max { box-shadow: 0 -10px 40px -8px var(--team-color); }
.hgb-dist__bar--b.hgb-dist__bar--max { box-shadow: 0 10px 40px -8px var(--team-color); }
.hgb-dist__cap { position: absolute; left: 50%; transform: translateX(-50%); font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--team-color); font-variant-numeric: tabular-nums; white-space: nowrap; letter-spacing: 0.02em; opacity: 0; transition: opacity 300ms ease calc(var(--delay, 0ms) + 500ms); }
.hgb-modal.is-open .hgb-dist__cap { opacity: 1; }
.hgb-dist__bar--a .hgb-dist__cap { bottom: calc(100% + 8px); }
.hgb-dist__bar--b .hgb-dist__cap { top: calc(100% + 8px); }
.hgb-dist__bar--max .hgb-dist__cap::before { content: '★ '; font-family: var(--body); font-size: 10px; opacity: 0.85; }
.hgb-dist__axis { display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.12em; text-transform: uppercase; }

/* telemetry row */
.hgb-tel { position: relative; z-index: 2; display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid var(--ink-14); }
.hgb-tel__cell { padding: 18px 22px 22px; display: flex; flex-direction: column; gap: 8px; border-right: 1px solid var(--ink-14); position: relative; }
.hgb-tel__cell:last-child { border-right: none; }
.hgb-tel__label { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.14em; text-transform: uppercase; }
.hgb-tel__big { font-family: var(--display); font-weight: 800; font-size: 24px; line-height: 1; color: var(--ink); font-variant-numeric: tabular-nums; }
.hgb-tel__unit { font-family: var(--body); font-size: 11px; color: var(--ink-48); margin-left: 4px; }

/* modal entry animations */
.hgb-modal.is-open .hgb-util,
.hgb-modal.is-open .hgb-matchup,
.hgb-modal.is-open .hgb-tracker,
.hgb-modal.is-open .hgb-wp,
.hgb-modal.is-open .hgb-dist,
.hgb-modal.is-open .hgb-tel { animation: hgb-rise 480ms cubic-bezier(.2,.8,.2,1) backwards; }
.hgb-modal.is-open .hgb-util    { animation-delay: 120ms; }
.hgb-modal.is-open .hgb-matchup { animation-delay: 180ms; }
.hgb-modal.is-open .hgb-tracker { animation-delay: 220ms; }
.hgb-modal.is-open .hgb-wp      { animation-delay: 260ms; }
.hgb-modal.is-open .hgb-dist    { animation-delay: 320ms; }
.hgb-modal.is-open .hgb-tel     { animation-delay: 400ms; }
@keyframes hgb-rise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

/* Seed label: two spans (short + long). Wider viewports show long; mobile
   rule inside the @media block swaps to short. MUST be before the @media
   block or the default-wins-by-source-order rule kills the mobile override. */
.hgb-team__seed .short-seed { display: none; }
.hgb-team__seed .long-seed { display: inline; }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  /* Bracket — scroll horizontally rather than try to reflow complex 3-col structure */
  .bracket-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .bracket-wrap > * { min-width: 560px; }
  .mast { padding: 36px 0 32px; }
  .mast-headline { font-size: clamp(28px, 6vw, 48px); }
}
@media (max-width: 700px) {
  .nav-links { display: none; }
  .nav-inner { padding: 0 20px; }
  .content { padding: 28px 20px 60px; }
  .mast-inner { padding: 0 20px; }
  .mast-card { padding: 24px 20px 20px; }
  .mast-top { flex-direction: column; align-items: flex-start; gap: 6px; }
  .mast-meta { text-align: left; }
  .series-grid, .pending-strip { grid-template-columns: 1fr; gap: 12px; }

  /* Cards — tighter */
  .hgb-card__inner { padding: 14px 14px 12px; }
  .hgb-card__teams { gap: 8px; margin-bottom: 10px; }
  .hgb-card__logo { width: 24px; height: 24px; }
  .hgb-card__abbr { font-size: 18px; }
  .hgb-card__pct { font-size: 20px; }
  .hgb-card__pct small { font-size: 11px; }
  .hgb-card__bar { height: 20px; margin-bottom: 10px; }
  .hgb-card__foot { padding: 8px 14px 12px; gap: 8px; }
  .hgb-card__foot-val { font-size: 11px; }

  /* modal: cap height, smooth scroll */
  .hgb-modal__sheet {
    max-height: 92dvh;
    -webkit-overflow-scrolling: touch;
  }

  .hgb-matchup { gap: 14px; padding: 14px 18px 22px; }
  .hgb-team__logo { width: 44px; height: 44px; }
  .hgb-team__abbr { font-size: 24px; }
  /* Compress long seed labels on mobile */
  .hgb-team__seed .long-seed { display: none; }
  .hgb-team__seed .short-seed { display: inline; }
  .hgb-team__name { font-size: 11px; }
  .hgb-matchup__score-nums { font-size: 34px; }
  .hgb-wp { padding: 20px 20px 24px; }
  .hgb-wp__num { font-size: 56px; }
  .hgb-dist { padding: 20px 16px 32px; }
  .hgb-dist__plot { height: 200px; }
  .hgb-dist__y { height: 200px; }
  .hgb-dist__bar { width: 36px; }
  .hgb-dist__body { gap: 10px; }
  .hgb-tracker { padding: 18px 16px 20px; }
  .hgb-tracker__grid { gap: 5px; }
  .hgb-tracker__meta { flex-direction: column; align-items: flex-start; gap: 10px; }
  .hgb-tel { grid-template-columns: 1fr 1fr; }
  .hgb-tel__cell:nth-child(2) { border-right: none; }
  .hgb-tel__cell:nth-child(-n+2) { border-bottom: 1px solid var(--ink-14); }
  .hgb-util { padding: 18px 18px 12px; }
}
@media (max-width: 480px) {
  .nav-inner { padding: 0 16px; }
  .content { padding: 20px 16px 48px; }
  .mast-inner { padding: 0 16px; }
  .mast-card { padding: 20px 16px 16px; }
  .mast-headline { font-size: clamp(26px, 7vw, 40px); }
  .mast-sub { font-size: 11px; }
  .hgb-card__abbr { font-size: 16px; }
  .hgb-card__pct { font-size: 18px; }
}
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="wordmark">Hockey<span class="dot"></span>Gamebot</a>
    <nav class="nav-links">
      <a href="/">Home</a><span class="sep"> · </span>
      <a href="/scoreboard">Scoreboard</a><span class="sep"> · </span>
      <a href="/playoffs/2026" class="active">Playoffs</a><span class="sep"> · </span>
      <a href="/stats">Stats</a><span class="sep"> · </span>
      <a href="/teams">Teams</a><span class="sep"> · </span>
      <a href="/support">Support</a>
    </nav>
  </div>
</nav>

<section class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div class="mast-eyebrow"><span class="pip"></span>HockeyGameBot · Model Projections</div>
      <div class="mast-meta" id="page-meta-strong">{latestUpdate ? `Updated ${new Date(latestUpdate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}` : 'Blended model'}</div>
    </div>
    <div class="mast-card">
      <h1 class="mast-headline">2026 Stanley Cup Playoffs</h1>

      <!-- BRACKET -->
      <div class="bracket-wrap">

        <!-- EAST (reads left → right) -->
        <div class="b-conf east">
          <!-- R1 -->
          <div class="b-col" style="flex:2">
            <div class="b-col-hd">R1 East</div>
            {[
              ['CAR','OTT'], ['PHI','PIT'], null,
              ['BUF','BOS'], ['MTL','TBL'],
            ].map(pair => pair === null
              ? <div class="b-pair-gap"></div>
              : (() => {
                  const [ta, tb] = pair as [string,string];
                  const s = seriesByTeams.get(`${ta}-${tb}`) ?? seriesByTeams.get(`${tb}-${ta}`);
                  const wonA = r1Winners.get(ta); const wonB = r1Winners.get(tb);
                  const ma = TEAM_META[ta]!; const mb = TEAM_META[tb]!;
                  const winsA = s?.games.filter(g => g === ta).length ?? 0;
                  const winsB = s?.games.filter(g => g === tb).length ?? 0;
                  return (<>
                    <div class={`b-team${wonA === true ? ' winner' : wonA === false ? ' elim' : ''}`} style={`border-left-color:${ma.color}`}>
                      <img class="b-logo" src={`https://assets.nhle.com/logos/nhl/svg/${ta}_light.svg`} alt={ta} />
                      <span class="b-abbr">{ta}</span>
                      <span class="b-wins">{winsA}</span>
                    </div>
                    <div class={`b-team${wonB === true ? ' winner' : wonB === false ? ' elim' : ''}`} style={`border-left-color:${mb.color}`}>
                      <img class="b-logo" src={`https://assets.nhle.com/logos/nhl/svg/${tb}_light.svg`} alt={tb} />
                      <span class="b-abbr">{tb}</span>
                      <span class="b-wins">{winsB}</span>
                    </div>
                  </>);
                })()
            )}
          </div>
          <!-- R2 -->
          <div class="b-col" style="flex:1.6">
            <div class="b-col-hd">R2</div>
            {[['CAR','PHI'], null, ['BUF','MTL']].map(pair => {
              if (pair === null) return <div class="b-pair-gap" style="flex:1"></div>;
              const [ta, tb] = pair as [string,string];
              const s = getR2Series(ta, tb);
              const ma = TEAM_META[ta]!; const mb = TEAM_META[tb]!;
              const winsA = s?.games.filter(g => g === ta).length ?? 0;
              const winsB = s?.games.filter(g => g === tb).length ?? 0;
              return (<>
                <div class="b-team" style={`border-left-color:${ma.color};flex:1`}>
                  <img class="b-logo" src={`https://assets.nhle.com/logos/nhl/svg/${ta}_light.svg`} alt={ta} />
                  <span class="b-abbr">{ta}</span>
                  <span class="b-wins" style={`color:${ma.color}`}>{winsA}</span>
                </div>
                <div class="b-team" style={`border-left-color:${mb.color};flex:1`}>
                  <img class="b-logo" src={`https://assets.nhle.com/logos/nhl/svg/${tb}_light.svg`} alt={tb} />
                  <span class="b-abbr">{tb}</span>
                  <span class="b-wins" style={`color:${mb.color}`}>{winsB}</span>
                </div>
              </>);
            })}
          </div>
          <!-- ECF -->
          <div class="b-col" style="flex:1">
            <div class="b-col-hd">ECF</div>
            <div class="b-tbd" style="flex:1"><div class="b-tbd-inner">TBD</div></div>
          </div>
        </div>

        <!-- CENTER: SCF -->
        <div class="b-scf">
          <div class="b-scf-icon">🏆</div>
          <div class="b-scf-lbl">Stanley<br/>Cup<br/>Final</div>
        </div>

        <!-- WEST (reads right → left) -->
        <div class="b-conf west">
          <!-- R1 -->
          <div class="b-col" style="flex:2">
            <div class="b-col-hd">R1 West</div>
            {[
              ['COL','LAK'], ['MIN','DAL'], null,
              ['VGK','UTA'], ['ANA','EDM'],
            ].map(pair => pair === null
              ? <div class="b-pair-gap"></div>
              : (() => {
                  const [ta, tb] = pair as [string,string];
                  const s = seriesByTeams.get(`${ta}-${tb}`) ?? seriesByTeams.get(`${tb}-${ta}`);
                  const wonA = r1Winners.get(ta); const wonB = r1Winners.get(tb);
                  const ma = TEAM_META[ta]!; const mb = TEAM_META[tb]!;
                  const winsA = s?.games.filter(g => g === ta).length ?? 0;
                  const winsB = s?.games.filter(g => g === tb).length ?? 0;
                  return (<>
                    <div class={`b-team${wonA === true ? ' winner' : wonA === false ? ' elim' : ''}`} style={`border-left-color:${ma.color}`}>
                      <img class="b-logo" src={`https://assets.nhle.com/logos/nhl/svg/${ta}_light.svg`} alt={ta} />
                      <span class="b-abbr">{ta}</span>
                      <span class="b-wins">{winsA}</span>
                    </div>
                    <div class={`b-team${wonB === true ? ' winner' : wonB === false ? ' elim' : ''}`} style={`border-left-color:${mb.color}`}>
                      <img class="b-logo" src={`https://assets.nhle.com/logos/nhl/svg/${tb}_light.svg`} alt={tb} />
                      <span class="b-abbr">{tb}</span>
                      <span class="b-wins">{winsB}</span>
                    </div>
                  </>);
                })()
            )}
          </div>
          <!-- R2 -->
          <div class="b-col" style="flex:1.6">
            <div class="b-col-hd">R2</div>
            {[['COL','MIN'], null, ['VGK','ANA']].map(pair => {
              if (pair === null) return <div class="b-pair-gap" style="flex:1"></div>;
              const [ta, tb] = pair as [string,string];
              const s = getR2Series(ta, tb);
              const ma = TEAM_META[ta]!; const mb = TEAM_META[tb]!;
              const winsA = s?.games.filter(g => g === ta).length ?? 0;
              const winsB = s?.games.filter(g => g === tb).length ?? 0;
              return (<>
                <div class="b-team" style={`border-left-color:${ma.color};flex:1`}>
                  <img class="b-logo" src={`https://assets.nhle.com/logos/nhl/svg/${ta}_light.svg`} alt={ta} />
                  <span class="b-abbr">{ta}</span>
                  <span class="b-wins" style={`color:${ma.color}`}>{winsA}</span>
                </div>
                <div class="b-team" style={`border-left-color:${mb.color};flex:1`}>
                  <img class="b-logo" src={`https://assets.nhle.com/logos/nhl/svg/${tb}_light.svg`} alt={tb} />
                  <span class="b-abbr">{tb}</span>
                  <span class="b-wins" style={`color:${mb.color}`}>{winsB}</span>
                </div>
              </>);
            })}
          </div>
          <!-- WCF -->
          <div class="b-col" style="flex:1">
            <div class="b-col-hd">WCF</div>
            <div class="b-tbd" style="flex:1"><div class="b-tbd-inner">TBD</div></div>
          </div>
        </div>

      </div><!-- /bracket-wrap -->
      <!-- Cup odds strip -->
      {cupRanked.length > 0 && (
        <div class="cup-strip">
          <div class="cup-strip-label">
            <span class="cup-strip-eyebrow">~Cup Win %</span>
            <span class="cup-strip-note">estimated · assumes equal odds in ECF + SCF</span>
          </div>
          <div class="cup-strip-teams">
            {cupRanked.map((t, i) => (
              <div class="cup-team">
                <span class="cup-rank">{i + 1}</span>
                <img class="cup-logo" src={`https://assets.nhle.com/logos/nhl/svg/${t.abbr}_light.svg`} alt={t.abbr} />
                <div class="cup-info">
                  <span class="cup-abbr" style={`color:${t.color}`}>{t.abbr}</span>
                  <span class="cup-pct" style={`color:${t.color}`}>{t.pct}%</span>
                </div>
                <div class="cup-bar-wrap">
                  <div class="cup-bar-fill" style={`width:${t.pct * 4}%;background:${t.color}`}></div>
                </div>
              </div>
            ))}
          </div>
          <div class="bracket-foot">Series win % · 10,000 Monte Carlo simulations per series · 60/40 Elo/xGF blend</div>
        </div>
      )}
    </div>
  </div>
</section>

<div class="content">
  {SERIES.length === 0 && (
    <div class="section-label" style="color: var(--ink-48)">
      Predictions loading — please refresh in a moment.
    </div>
  )}
  {/* Round 2 */}
  {(SERIES_R2.length > 0) && ([['East', eastSeriesR2], ['West', westSeriesR2]] as const).map(([label, series]) => (
    series.length > 0 && (
    <div class="conf-block">
      <div class="section-label"><span class="pip"></span>{label}ern Conference · <span style="color:var(--red)">Round 2</span></div>
      <div class="series-grid">
        {series.map(s => {
          const segs = buildCardSegs(s);
          const ml = mostLikely(s);
          const pctA = s.a.winPct;
          const pctB = s.b.winPct;
          return (
            <button class="hgb-card" data-id={s.id} style={`--hgb-team-a: ${s.a.color}; --hgb-team-b: ${s.b.color};`} aria-label={`${s.a.abbr} vs ${s.b.abbr} — click for series details`}>
              <div class="hgb-card__inner">
                <header class="hgb-card__meta"><span class="hgb-mini-badge">{s.miniBadge}</span></header>
                <div class="hgb-card__teams">
                  <div class="hgb-card__team" style={`--team-color: ${s.a.color}`}>
                    <img src={`https://assets.nhle.com/logos/nhl/svg/${s.a.abbr}_light.svg`} alt={s.a.abbr} class="hgb-card__logo" loading="lazy" />
                    <div class="hgb-card__ids"><span class="hgb-card__seed">{s.a.seed}</span><span class="hgb-card__abbr">{s.a.abbr}</span></div>
                    <span class="hgb-card__pct" style="margin-left: auto">{pctA}<small>%</small></span>
                  </div>
                  <span class="hgb-card__vs">vs</span>
                  <div class="hgb-card__team hgb-card__team--b" style={`--team-color: ${s.b.color}`}>
                    <img src={`https://assets.nhle.com/logos/nhl/svg/${s.b.abbr}_light.svg`} alt={s.b.abbr} class="hgb-card__logo" loading="lazy" />
                    <div class="hgb-card__ids"><span class="hgb-card__seed">{s.b.seed}</span><span class="hgb-card__abbr">{s.b.abbr}</span></div>
                    <span class="hgb-card__pct" style="margin-right: auto">{pctB}<small>%</small></span>
                  </div>
                </div>
              </div>
              <div class="hgb-card__bar">
                {segs.map(seg => (
                  <div class="hgb-card__seg" style={`--c:${seg.c};--w:${seg.w}`} data-boundary={seg.boundary ? '' : undefined} data-dominant={seg.w >= 95 ? '' : undefined} class:list={[seg.isSmall && 'hgb-card__seg--small', seg.isMax && 'hgb-card__seg--max']}>
                    {!seg.isSmall && <span class="hgb-card__seg-val">{seg.w}%</span>}
                  </div>
                ))}
              </div>
              <footer class="hgb-card__foot">
                <div class="hgb-card__foot-col">
                  <span class="hgb-card__foot-label">Next Game</span>
                  <span class="hgb-card__foot-val" data-next-game data-iso={s.nextGameUTC ?? ''}>{s.nextGameUTC ? '' : 'TBD'}</span>
                </div>
                {ml && <div class="hgb-card__foot-col hgb-card__foot-col--right">
                  <span class="hgb-card__foot-label">Most Likely</span>
                  <span class="hgb-card__foot-val"><strong>{ml.label.split(' in ')[0]}</strong> in {ml.label.split(' in ')[1]} · {ml.v}%</span>
                </div>}
              </footer>
            </button>
          );
        })}
      </div>
    </div>
    )
  ))}

  {/* Round 1 */}
  {([['East', eastSeries], ['West', westSeries]] as const).map(([label, series]) => (
    <div class="conf-block">
      <div class="section-label"><span class="pip"></span>{label}ern Conference · Round 1 <span style="font-family:var(--mono);font-size:9px;opacity:0.5;letter-spacing:0.08em">(COMPLETE)</span></div>
      <div class="series-grid">
        {series.map(s => {
          const segs = buildCardSegs(s);
          const ml = mostLikely(s);
          const pctA = s.a.winPct;
          const pctB = s.b.winPct;
          return (
            <button
              class="hgb-card"
              data-id={s.id}
              style={`--hgb-team-a: ${s.a.color}; --hgb-team-b: ${s.b.color};`}
              aria-label={`${s.a.abbr} vs ${s.b.abbr} — click to open series details`}
            >
              <div class="hgb-card__inner">
                <header class="hgb-card__meta">
                  <span class="hgb-mini-badge">{s.miniBadge}</span>
                </header>

                <div class="hgb-card__teams">
                  <div class="hgb-card__team" style={`--team-color: ${s.a.color}`}>
                    <img src={`https://assets.nhle.com/logos/nhl/svg/${s.a.abbr}_light.svg`} alt={s.a.abbr} class="hgb-card__logo" loading="lazy" />
                    <div class="hgb-card__ids">
                      <span class="hgb-card__seed">{s.a.seed}</span>
                      <span class="hgb-card__abbr">{s.a.abbr}</span>
                    </div>
                    <span class="hgb-card__pct" style="margin-left: auto">{pctA}<small>%</small></span>
                  </div>
                  <span class="hgb-card__vs">vs</span>
                  <div class="hgb-card__team hgb-card__team--b" style={`--team-color: ${s.b.color}`}>
                    <img src={`https://assets.nhle.com/logos/nhl/svg/${s.b.abbr}_light.svg`} alt={s.b.abbr} class="hgb-card__logo" loading="lazy" />
                    <div class="hgb-card__ids">
                      <span class="hgb-card__seed">{s.b.seed}</span>
                      <span class="hgb-card__abbr">{s.b.abbr}</span>
                    </div>
                    <span class="hgb-card__pct" style="margin-right: auto">{pctB}<small>%</small></span>
                  </div>
                </div>
              </div>

              <div class="hgb-card__bar">
                {segs.map(seg => (
                  <span
                    class={`hgb-card__seg${seg.isSmall ? ' hgb-card__seg--small' : ''}`}
                    style={`--c: ${seg.c}; --w: ${seg.w}`}
                    data-boundary={seg.boundary ? 'true' : undefined}
                    title={`${seg.label} · ${seg.w}%`}
                  >
                    <span class="hgb-card__seg-val">{seg.w}</span>
                  </span>
                ))}
              </div>

              <footer class="hgb-card__foot">
                <div class="hgb-card__foot-col">
                  <span class="hgb-card__foot-label">Next Game</span>
                  <span class="hgb-card__foot-val" data-next-game data-iso={s.nextGameUTC ?? ''}>{s.nextGameUTC ? '' : 'TBD'}</span>
                </div>
                <div class="hgb-card__foot-col hgb-card__foot-col--right">
                  <span class="hgb-card__foot-label">Most Likely</span>
                  <span class="hgb-card__foot-val">
                    <strong>{ml?.label.split(' in ')[0]}</strong> in {ml?.label.split(' in ')[1]} · {ml?.v}%
                  </span>
                </div>
              </footer>
            </button>
          );
        })}
      </div>

    </div>
  ))}
</div>

<!-- ── Shared modal (populated via JS on card click) ── -->
<div class="hgb-modal" id="hgb-modal" role="dialog" aria-modal="true" aria-label="Series details">
  <div class="hgb-modal__scrim" data-hgb-close></div>
  <section class="hgb-modal__sheet">
    <button class="hgb-modal__handle" data-hgb-close aria-label="Close"></button>

    <header class="hgb-util">
      <div class="hgb-util__group">
        <span class="hgb-badge">Projection</span>
        <span class="hgb-mono">10,000 sims · blended model</span>
      </div>
      <div class="hgb-util__group">
        <span class="hgb-mono" data-field="round-label"></span>
        <button class="hgb-modal__share" id="hgb-share-btn" aria-label="Share this series prediction" title="Share">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        </button>
        <button class="hgb-modal__close" data-hgb-close aria-label="Close modal">
          <svg viewBox="0 0 14 14" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 3L11 11M11 3L3 11"/></svg>
        </button>
      </div>
    </header>

    <div class="hgb-matchup">
      <div class="hgb-team" style="--team-color: var(--hgb-team-a)">
        <img src="" alt="" class="hgb-team__logo" data-field="logo-a">
        <div class="hgb-team__meta">
          <span class="hgb-team__seed" data-field="seed-a"></span>
          <span class="hgb-team__abbr" data-field="abbr-a"></span>
          <span class="hgb-team__name" data-field="name-a"></span>
        </div>
      </div>

      <div class="hgb-matchup__center">
        <span class="hgb-matchup__vs" id="matchup-vs">VS</span>
        <div class="hgb-matchup__score" id="matchup-score" hidden>
          <div class="hgb-matchup__score-nums">
            <span class="hgb-matchup__score-a" data-field="score-a">0</span>
            <span class="hgb-matchup__score-sep">–</span>
            <span class="hgb-matchup__score-b" data-field="score-b">0</span>
          </div>
          <span class="hgb-matchup__status" data-field="series-status"></span>
        </div>
      </div>

      <div class="hgb-team hgb-team--b" style="--team-color: var(--hgb-team-b)">
        <img src="" alt="" class="hgb-team__logo" data-field="logo-b">
        <div class="hgb-team__meta">
          <span class="hgb-team__seed" data-field="seed-b"></span>
          <span class="hgb-team__abbr" data-field="abbr-b"></span>
          <span class="hgb-team__name" data-field="name-b"></span>
        </div>
      </div>
    </div>

    <!-- series tracker — shown only when series has started -->
    <div class="hgb-tracker" id="hgb-tracker" hidden>
      <div class="hgb-tracker__grid" id="hgb-tracker-grid"></div>
      <div class="hgb-tracker__meta">
        <div class="hgb-tracker__next" id="hgb-tracker-next">
          <span class="hgb-tracker__next-label">Next</span>
          <span class="hgb-tracker__next-val" data-field="next-game"></span>
        </div>
        <div class="hgb-tracker__advance">
          <span class="hgb-tracker__adv-item" style="--team-color: var(--hgb-team-a)">
            <span class="hgb-tracker__adv-num" data-field="advance-a"></span>
            <span data-field="advance-label-a"></span>
          </span>
          <span class="hgb-tracker__adv-item" style="--team-color: var(--hgb-team-b)">
            <span class="hgb-tracker__adv-num" data-field="advance-b"></span>
            <span data-field="advance-label-b"></span>
          </span>
        </div>
      </div>
    </div>

    <div class="hgb-wp">
      <span class="hgb-wp__label" data-field="wp-label">Series Win Probability</span>
      <div class="hgb-wp__row">
        <div class="hgb-wp__side" style="--team-color: var(--hgb-team-a)">
          <span class="hgb-wp__num" data-field="wp-a"></span>
          <span class="hgb-wp__pct">%</span>
        </div>
        <div class="hgb-wp__side" style="--team-color: var(--hgb-team-b)">
          <span class="hgb-wp__num" data-field="wp-b"></span>
          <span class="hgb-wp__pct">%</span>
        </div>
      </div>
    </div>

    <div class="hgb-dist">
      <div class="hgb-dist__head">
        <h3 class="hgb-dist__h">Series Length Distribution</h3>
      </div>
      <div class="hgb-dist__body">
        <div class="hgb-dist__y">
          <span id="y-top"></span><span></span><span></span><span></span>
          <span class="hgb-dist__y-0">0</span>
          <span></span><span></span><span></span><span id="y-bot"></span>
        </div>
        <div class="hgb-dist__plot" id="hgb-plot"></div>
      </div>
    </div>

    <div class="hgb-tel">
      <div class="hgb-tel__cell">
        <span class="hgb-tel__label">Most Likely</span>
        <div class="hgb-tel__val"><span class="hgb-tel__big" data-field="most-likely"></span></div>
      </div>
      <div class="hgb-tel__cell">
        <span class="hgb-tel__label" data-field="tel-2-label">Sweep Odds</span>
        <div class="hgb-tel__val"><span class="hgb-tel__big" data-field="tel-2-val"></span><span class="hgb-tel__unit" data-field="tel-2-unit">%</span></div>
      </div>
      <div class="hgb-tel__cell">
        <span class="hgb-tel__label" data-field="tel-3-label">Goes Seven</span>
        <div class="hgb-tel__val"><span class="hgb-tel__big" data-field="goes-seven"></span><span class="hgb-tel__unit" data-field="tel-3-unit">%</span></div>
      </div>
      <div class="hgb-tel__cell">
        <span class="hgb-tel__label" data-field="tel-4-label">Expected Length</span>
        <div class="hgb-tel__val"><span class="hgb-tel__big" data-field="exp-length"></span><span class="hgb-tel__unit" data-field="tel-4-unit">games</span></div>
      </div>
    </div>
  </section>
</div>

<!-- Series data for client-side modal population -->
<script id="hgb-series-json" type="application/json" set:html={JSON.stringify(SERIES)}></script>

<script>
// ── Data ──────────────────────────────────────────────────────────────────────
const SERIES = JSON.parse(document.getElementById('hgb-series-json')!.textContent!);

// ── Module-scope state ────────────────────────────────────────────────────────
// Declared here (above openModal) so the deep-link call below the wire-up block
// never hits the TDZ — `let` bindings are not accessible before their declaration.
let openSeriesId: string | null = null;

// ── Helpers ───────────────────────────────────────────────────────────────────
const logoFor = (abbr: string) => `https://assets.nhle.com/logos/nhl/svg/${abbr}_light.svg`;
const winTotal = (dist: number[]) => dist.reduce((s: number, v: number) => s + v, 0);
const darker  = (hex: string, pct: number) => `color-mix(in srgb, ${hex}, #000 ${pct}%)`;
const lighter = (hex: string, pct: number) => `color-mix(in srgb, ${hex}, #fff ${pct}%)`;

function findMax(s: any) {
  const all = [
    ...s.a.dist.map((v: number, i: number) => ({ team: 'a', game: i + 4, v })),
    ...s.b.dist.map((v: number, i: number) => ({ team: 'b', game: i + 4, v })),
  ];
  return all.filter((x: any) => x.v > 0).reduce((m: any, x: any) => x.v > m.v ? x : m);
}

function seriesState(s: any) {
  const wA = s.games.filter((g: any) => g === s.a.abbr).length;
  const wB = s.games.filter((g: any) => g === s.b.abbr).length;
  const played = wA + wB;
  const hasStarted = played > 0;
  let leader = 'tied', status = 'Series tied';
  if (wA > wB) { leader = 'a'; status = `${s.a.abbr} leads`; }
  else if (wB > wA) { leader = 'b'; status = `${s.b.abbr} leads`; }
  if (wA === 4 || wB === 4) {
    status = `${wA === 4 ? s.a.abbr : s.b.abbr} wins series`;
  }
  return { wA, wB, played, hasStarted, leader, status };
}

// ── Modal population ──────────────────────────────────────────────────────────
const modal = document.getElementById('hgb-modal')!;
const plot = document.getElementById('hgb-plot')!;
const tracker = document.getElementById('hgb-tracker')!;
const trackerGrid = document.getElementById('hgb-tracker-grid')!;
const matchupVs = document.getElementById('matchup-vs')!;
const matchupScore = document.getElementById('matchup-score')!;

function setField(name: string, val: string) {
  document.querySelectorAll(`[data-field="${name}"]`).forEach(el => {
    if ((el as HTMLImageElement).tagName === 'IMG') (el as HTMLImageElement).src = val;
    else el.textContent = val;
  });
}

function renderTracker(s: any) {
  const state = seriesState(s);
  return [0,1,2,3,4,5,6].map(i => {
    const winner = s.games[i];
    const g = i + 1;
    if (winner) {
      const team = winner === s.a.abbr ? s.a : s.b;
      return `<div class="hgb-tracker__game hgb-tracker__game--played" style="--c: ${team.color}">
        <span class="hgb-tracker__winner">${winner}</span>
        <span class="hgb-tracker__num">G${g}</span>
      </div>`;
    } else if (i === state.played) {
      return `<div class="hgb-tracker__game hgb-tracker__game--next"><span class="hgb-tracker__num">G${g}</span></div>`;
    }
    return `<div class="hgb-tracker__game"><span class="hgb-tracker__num">G${g}</span></div>`;
  }).join('');
}

function openModal(id: string) {
  const s = SERIES.find((x: any) => x.id === id);
  if (!s || s.tbd) return;

  modal.style.setProperty('--hgb-team-a', s.a.color);
  modal.style.setProperty('--hgb-team-b', s.b.color);

  // Authoritative win pct (matches card + social card). Fall back to summing
  // dist only if the API didn't provide it — those values can differ by 1%
  // due to independent 2-decimal rounding.
  const winA = Number.isFinite(s.a.winPct) ? s.a.winPct : winTotal(s.a.dist);
  const winB = Number.isFinite(s.b.winPct) ? s.b.winPct : winTotal(s.b.dist);
  const max = findMax(s);
  const mlTeam = max.team === 'a' ? s.a : s.b;
  const state = seriesState(s);

  // header
  setField('round-label', s.miniBadge.toUpperCase());
  setField('logo-a', logoFor(s.a.abbr));
  setField('logo-b', logoFor(s.b.abbr));
  setField('abbr-a', s.a.abbr); setField('abbr-b', s.b.abbr);
  setField('name-a', s.a.name); setField('name-b', s.b.name);
  // Seed label has two spans — short (mobile) + long (desktop). CSS picks which to show.
  for (const side of ['a', 'b'] as const) {
    const el = document.querySelector<HTMLElement>(`[data-field="seed-${side}"]`);
    if (el) el.innerHTML = `<span class="short-seed">${s[side].seed}</span><span class="long-seed">${s[side].seedFull}</span>`;
  }

  // VS or score
  if (state.hasStarted) {
    matchupVs.hidden = true;
    matchupScore.hidden = false;
    const scoreA = document.querySelector('[data-field="score-a"]')!;
    const scoreB = document.querySelector('[data-field="score-b"]')!;
    const statusEl = document.querySelector('[data-field="series-status"]')!;
    scoreA.textContent = String(state.wA);
    scoreB.textContent = String(state.wB);
    scoreA.classList.toggle('is-lead', state.leader === 'a');
    scoreB.classList.toggle('is-lead', state.leader === 'b');
    statusEl.textContent = state.status;
    statusEl.classList.toggle('is-lead-a', state.leader === 'a');
    statusEl.classList.toggle('is-lead-b', state.leader === 'b');
  } else {
    matchupVs.hidden = false;
    matchupScore.hidden = true;
  }

  // tracker — always show (pre-series shows Game 1 time + 4 wins needed)
  tracker.hidden = false;
  trackerGrid.innerHTML = renderTracker(s);
  const nextDiv = document.getElementById('hgb-tracker-next')!;
  const nextIso = s.nextGameUTC ?? s._nextGameUTC;  // server-side OR client-overlay
  if (nextIso) {
    nextDiv.hidden = false;
    setField('next-game', formatNextGame(nextIso, state.played + 1));
  } else {
    nextDiv.hidden = true;
  }
  setField('advance-a', String(4 - state.wA));
  setField('advance-b', String(4 - state.wB));
  setField('advance-label-a', `${s.a.abbr} to advance`);
  setField('advance-label-b', `${s.b.abbr} to advance`);

  // WP — when the series is decided, show 100/0 and label it as final
  const isComplete = !!s.is_complete;
  if (isComplete && s.winner) {
    setField('wp-label', 'Series Result');
    if (s.winner === s.a.abbr) { setField('wp-a', '100'); setField('wp-b', '0'); }
    else                        { setField('wp-a', '0');   setField('wp-b', '100'); }
  } else {
    setField('wp-label', state.hasStarted ? 'Series Win Probability · Current' : 'Series Win Probability');
    setField('wp-a', String(winA));
    setField('wp-b', String(winB));
  }

  // distribution chart — auto-scale
  const scale = Math.max(20, ...s.a.dist, ...s.b.dist);
  // fill y-axis labels (top to bottom: scale, ¾, ½, ¼, 0, ¼, ½, ¾, scale)
  const yLabels = modal.querySelectorAll<HTMLElement>('.hgb-dist__y span');
  [scale, Math.round(scale*0.75), Math.round(scale*0.5), Math.round(scale*0.25),
   0,
   Math.round(scale*0.25), Math.round(scale*0.5), Math.round(scale*0.75), scale
  ].forEach((v, i) => {
    const el = yLabels[i];
    if (!el) return;
    // replace text node only, preserve ::after pseudo content
    el.childNodes.forEach(n => { if (n.nodeType === 3) n.textContent = v === 0 ? '' : String(v); });
    if (!el.childNodes.length) el.textContent = v === 0 ? '' : String(v);
  });

  // (plot height − 28px axis label) / 2 — matches CSS: 280px desktop, 200px mobile
  const plotH = window.innerWidth < 700 ? 200 : 280;
  const HALF_PX = Math.round((plotH - 28) / 2);
  let html = '';
  for (let g = 4; g <= 7; g++) {
    const i = g - 4;
    const va = s.a.dist[i], vb = s.b.dist[i];
    const pxA = va > 0 ? Math.max(4, Math.round((va / scale) * HALF_PX)) : 0;
    const pxB = vb > 0 ? Math.max(4, Math.round((vb / scale) * HALF_PX)) : 0;
    const dA = 60 + i * 80, dB = 80 + i * 80;
    const maxA = max.team === 'a' && max.game === g ? ' hgb-dist__bar--max' : '';
    const maxB = max.team === 'b' && max.game === g ? ' hgb-dist__bar--max' : '';
    const barA = va > 0
      ? `<div class="hgb-dist__bar hgb-dist__bar--a${maxA}" style="--v: ${pxA}px; --delay: ${dA}ms"><span class="hgb-dist__cap" style="--delay: ${dA}ms">${va}%</span></div>`
      : '';
    const barB = vb > 0
      ? `<div class="hgb-dist__bar hgb-dist__bar--b${maxB}" style="--v: ${pxB}px; --delay: ${dB}ms"><span class="hgb-dist__cap" style="--delay: ${dB}ms">${vb}%</span></div>`
      : '';
    html += `<div class="hgb-dist__col">
      <div class="hgb-dist__half hgb-dist__half--top">${barA}</div>
      <div class="hgb-dist__axis">G${g}</div>
      <div class="hgb-dist__half hgb-dist__half--bot">${barB}</div>
    </div>`;
  }

  // telemetry — complete series shows final facts, not probabilities
  if (isComplete && s.winner && s.winner_in) {
    setField('most-likely', `${s.winner} in ${s.winner_in}`);
    setField('tel-2-label', 'Final');
    const finalScoreA = s.games.filter((g: any) => g === s.a.abbr).length;
    const finalScoreB = s.games.filter((g: any) => g === s.b.abbr).length;
    setField('tel-2-val', `${Math.max(finalScoreA, finalScoreB)}–${Math.min(finalScoreA, finalScoreB)}`);
    setField('tel-2-unit', '');     // score has no unit
    setField('tel-3-label', 'Went Seven');
    setField('goes-seven', s.winner_in === 7 ? 'Yes' : 'No');
    setField('tel-3-unit', '');
    setField('tel-4-label', 'Series Length');
    setField('exp-length', `${s.winner_in}`);
    setField('tel-4-unit', 'games');
  } else {
    setField('most-likely', `${mlTeam.abbr} in ${max.game}`);
    if (!state.hasStarted) {
      setField('tel-2-label', 'Sweep Odds');
      setField('tel-2-val', String(s.a.dist[0] + s.b.dist[0]));
    } else {
      const leaderTeam = state.leader === 'a' ? s.a : s.b;
      setField('tel-2-label', `${leaderTeam.abbr} Sweep`);
      setField('tel-2-val', String(leaderTeam.dist[0]));
    }
    setField('tel-2-unit', '%');
    setField('tel-3-label', 'Goes Seven');
    setField('goes-seven', String(s.a.dist[3] + s.b.dist[3]));
    setField('tel-3-unit', '%');
    const total = winA + winB;
    const expLen = total > 0
      ? ([4,5,6,7].reduce((sum: number, g: number, i: number) => sum + g * (s.a.dist[i] + s.b.dist[i]), 0) / total).toFixed(1)
      : '—';
    setField('exp-length', expLen);
    setField('tel-4-label', state.hasStarted ? 'Exp. Remaining' : 'Expected Length');
    setField('tel-4-unit', 'games');
  }

  // animate — re-trigger if already open
  // Insert bars AFTER removing is-open so transitions fire from height:0 on new elements
  const wasOpen = modal.classList.contains('is-open');
  if (wasOpen) { modal.classList.remove('is-open'); void modal.offsetWidth; }
  plot.innerHTML = html;
  // Force a reflow so the browser registers height:0 before adding is-open
  void plot.offsetWidth;
  modal.classList.add('is-open', 'is-animating');
  setTimeout(() => modal.classList.remove('is-animating'), 1400);

  // scroll to top of sheet
  modal.querySelector('.hgb-modal__sheet')!.scrollTop = 0;

  // Move focus into the modal so keyboard + screen-reader users land in context.
  // Use the close button — first actionable control, and tabbing from here
  // enters the focus trap cleanly.
  modal.querySelector<HTMLElement>('.hgb-modal__close')?.focus();

  openSeriesId = id;
  // deep-link
  history.pushState({ series: id }, '', `?series=${id}`);
}

function closeModal() {
  openSeriesId = null;
  modal.classList.remove('is-open', 'is-animating');
  history.pushState({}, '', location.pathname);
}

// ── Focus trap ────────────────────────────────────────────────────────────────
function trapFocus(e: KeyboardEvent) {
  if (!modal.classList.contains('is-open') || e.key !== 'Tab') return;
  const focusable = Array.from(modal.querySelectorAll<HTMLElement>(
    'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
  )).filter(el => !el.hasAttribute('hidden') && el.offsetParent !== null);
  if (!focusable.length) return;
  const first = focusable[0], last = focusable[focusable.length - 1];
  if (e.shiftKey) {
    if (document.activeElement === first) { e.preventDefault(); last.focus(); }
  } else {
    if (document.activeElement === last) { e.preventDefault(); first.focus(); }
  }
}

// ── Share button — native share on mobile, Twitter intent on desktop ─────────
const shareBtn = document.getElementById('hgb-share-btn') as HTMLButtonElement | null;
shareBtn?.addEventListener('click', async (e) => {
  e.stopPropagation();
  if (!openSeriesId) return;
  const s = SERIES.find((x: any) => x.id === openSeriesId);
  if (!s) return;

  const url = `https://hockeygamebot.com/playoffs/2026?series=${openSeriesId}`;
  const wpA = Number.isFinite(s.a.winPct) ? s.a.winPct : s.a.dist.reduce((t: number, v: number) => t + v, 0);
  const wpB = Number.isFinite(s.b.winPct) ? s.b.winPct : s.b.dist.reduce((t: number, v: number) => t + v, 0);
  const text = `${s.a.abbr} ${wpA}% vs ${s.b.abbr} ${wpB}% — HockeyGameBot's prediction for ${s.a.abbr}/${s.b.abbr}.`;

  // Prefer native share on mobile / supporting browsers
  if (navigator.share) {
    try {
      await navigator.share({ title: `${s.a.abbr} vs ${s.b.abbr} — HockeyGameBot`, text, url });
      return;
    } catch (_) { /* user cancelled — fall through to copy */ }
  }

  // Desktop fallback: open Twitter intent in a popup. Falls back to
  // clipboard copy if popup blocked.
  const intent = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;
  const w = window.open(intent, '_blank', 'width=550,height=420,noopener');
  if (!w) {
    try {
      await navigator.clipboard.writeText(`${text} ${url}`);
      shareBtn.classList.add('is-copied');
      setTimeout(() => shareBtn.classList.remove('is-copied'), 1800);
    } catch (_) {}
  }
});

// ── Wire up ───────────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLElement>('.hgb-card').forEach(card => {
  card.addEventListener('click', () => openModal(card.dataset.id!));
});
document.querySelectorAll('[data-hgb-close]').forEach(el => {
  el.addEventListener('click', closeModal);
});
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeModal();
  trapFocus(e);
});

// deep-link on load
const initId = new URLSearchParams(location.search).get('series');
if (initId) openModal(initId);

// back/forward
window.addEventListener('popstate', (e) => {
  if (e.state?.series) openModal(e.state.series);
  else closeModal();
});

// ── Live updates ──────────────────────────────────────────────────────────────

// Format the next-game line in the browser's local time zone. Detect the tz
// abbreviation (e.g. "MST", "EDT") and append it so users in different zones
// still know what they're looking at.
function formatNextGame(iso: string, gameNum: number): string {
  const dt = new Date(iso);
  const mon = dt.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  const time = dt.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
  // timeZoneName: short → returns things like "EDT", "PST", "MST"
  const tzPart = dt.toLocaleTimeString(undefined, { timeZoneName: 'short' }).split(' ').pop() || '';
  return `Game ${gameNum} · ${mon}, ${time} ${tzPart}`;
}

// Server-side render of the card footer can't know the browser's TZ, so we
// bake the ISO string into data-iso and let the client hydrate on load.
function hydrateLocalNextGame() {
  document.querySelectorAll<HTMLElement>('[data-iso]').forEach(el => {
    const iso = el.getAttribute('data-iso');
    if (!iso) return;
    // Guess game number from played-so-far on the parent card. We can't read
    // SERIES server-side on the client, so use the simplest thing: the parent
    // card's data-id → series state → played count + 1.
    const card = el.closest<HTMLElement>('.hgb-card');
    if (!card) return;
    const id = card.dataset.id;
    const s = SERIES.find((x: any) => x.id === id);
    if (!s) return;
    const state = seriesState(s);
    el.textContent = formatNextGame(iso, state.played + 1);
  });
}

/**
 * Fetch blended model predictions from hgb-api and overlay onto SERIES.
 *
 * Updates win probability distributions (dist_a, dist_b) and per-game winners
 * (games[]) for every series in the payload. Morning cron (4am ET) + GAME_END
 * piggyback both write to this endpoint, so this fetch is the source of truth
 * for the WP numbers shown in the modal.
 *
 * Fails silently — if hgb-api is unreachable or returns an error, the site
 * falls back to the hardcoded `SERIES` array and loads normally.
 */
async function loadModelData() {
  try {
    const res = await fetch('https://api.hockeygamebot.com/v1/playoffs/round/1');
    if (!res.ok) return;
    const data = await res.json();

    // Match by series_id first, then fall back to team pair — round 2+ matchups
    // may have different ids than what we hardcoded but the same two teams.
    for (const snap of (data.series ?? [])) {
      let s = SERIES.find((x: any) => x.id === snap.series_id);
      if (!s) {
        s = SERIES.find((x: any) =>
          (x.a.abbr === snap.team_a && x.b.abbr === snap.team_b) ||
          (x.a.abbr === snap.team_b && x.b.abbr === snap.team_a)
        );
      }
      if (!s) continue;

      // Map API's team_a / team_b to our a / b by abbrev (API orders by Elo).
      if (snap.team_a === s.a.abbr) {
        s.a.dist = snap.dist_a;
        s.b.dist = snap.dist_b;
      } else if (snap.team_a === s.b.abbr) {
        s.a.dist = snap.dist_b;
        s.b.dist = snap.dist_a;
      }

      if (Array.isArray(snap.games)) s.games = snap.games;
      s.is_complete = !!snap.is_complete;
      s.winner = snap.winner ?? null;
      s.winner_in = snap.winner_in ?? null;
      if (snap.next_game_utc) s._nextGameUTC = snap.next_game_utc;
      if (Number.isFinite(snap.win_pct_a) && Number.isFinite(snap.win_pct_b)) {
        // Map to SERIES a/b same way as dist
        if (snap.team_a === s.a.abbr) { s.a.winPct = snap.win_pct_a; s.b.winPct = snap.win_pct_b; }
        else                           { s.a.winPct = snap.win_pct_b; s.b.winPct = snap.win_pct_a; }
      }
    }

    // Staleness indicator in page header
    if (data.latest_update) {
      const dt = new Date(data.latest_update);
      const time = dt.toLocaleTimeString('en-US', { timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit' });
      const date = dt.toLocaleDateString('en-US', { timeZone: 'America/New_York', month: 'short', day: 'numeric' });
      const strong = document.getElementById('page-meta-strong');
      if (strong) strong.textContent = `Updated ${date} · ${time} ET`;
    }

    for (const s of SERIES) {
      if ((s as any).tbd) continue;
      const card = document.querySelector<HTMLElement>(`.hgb-card[data-id="${s.id}"]`);
      if (card) rebuildCard(card, s);
    }

    if (openSeriesId) openModal(openSeriesId);
  } catch (_) { /* server-side render already showed API data (or a skeleton) */ }
}

/**
 * Re-render the distribution bar + foot line of a card with fresh dist data.
 * Keeps the card in the DOM (so the click handler survives) rather than
 * re-rendering the grid.
 */
function rebuildCard(card: HTMLElement, s: any) {
  const bar = card.querySelector<HTMLElement>('.hgb-card__bar');
  const foot = card.querySelector<HTMLElement>('.hgb-card__foot');
  if (!bar || !foot || !s.a.dist?.length || !s.b.dist?.length) return;

  const mixHex = (hex: string, target: string, amount: number): string => {
    if (!hex.startsWith('#') || hex.length < 7) return hex;
    const p = (h: string, o: number) => parseInt(h.slice(o, o + 2), 16);
    const r1 = p(hex,1), g1 = p(hex,3), b1 = p(hex,5);
    const r2 = p(target,1), g2 = p(target,3), b2 = p(target,5);
    const t = amount / 100;
    const r = Math.round(r1+(r2-r1)*t), g = Math.round(g1+(g2-g1)*t), b = Math.round(b1+(b2-b1)*t);
    return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
  };

  const [a4,a5,a6,a7] = s.a.dist;
  const [b4,b5,b6,b7] = s.b.dist;
  const hc = s.a.color, lc = s.b.color;
  const raw = [
    { w:a4, c:mixHex(hc,'#000000',32), label:`${s.a.abbr} in 4`, boundary:false },
    { w:a5, c:mixHex(hc,'#000000',18), label:`${s.a.abbr} in 5`, boundary:false },
    { w:a6, c:hc,                       label:`${s.a.abbr} in 6`, boundary:false },
    { w:a7, c:mixHex(hc,'#ffffff',14), label:`${s.a.abbr} in 7`, boundary:false },
    { w:b7, c:mixHex(lc,'#ffffff',14), label:`${s.b.abbr} in 7`, boundary:true  },
    { w:b6, c:lc,                       label:`${s.b.abbr} in 6`, boundary:false },
    { w:b5, c:mixHex(lc,'#000000',18), label:`${s.b.abbr} in 5`, boundary:false },
    { w:b4, c:mixHex(lc,'#000000',32), label:`${s.b.abbr} in 4`, boundary:false },
  ];
  const segs = raw.filter(sg => sg.w > 0);
  bar.innerHTML = segs.map(seg => {
    const isSmall = seg.w <= 6;
    return `<span class="hgb-card__seg${isSmall ? ' hgb-card__seg--small' : ''}"
                  style="--c: ${seg.c}; --w: ${seg.w}"
                  ${seg.boundary ? 'data-boundary="true"' : ''}
                  title="${seg.label} · ${seg.w}%"><span class="hgb-card__seg-val">${seg.w}</span></span>`;
  }).join('');

  // Update win% numerals — use authoritative winPct from API (matches card output)
  const pctA = Number.isFinite(s.a.winPct) ? s.a.winPct : s.a.dist.reduce((t: number, v: number) => t + v, 0);
  const pctB = Number.isFinite(s.b.winPct) ? s.b.winPct : s.b.dist.reduce((t: number, v: number) => t + v, 0);
  const pctEls = card.querySelectorAll<HTMLElement>('.hgb-card__pct');
  if (pctEls[0]) pctEls[0].innerHTML = `${pctA}<small>%</small>`;
  if (pctEls[1]) pctEls[1].innerHTML = `${pctB}<small>%</small>`;

  // Rebuild two-column footer: left = Next Game, right = Most Likely (or Winner)
  let nextHtml: string;
  if (s.is_complete) {
    nextHtml = `<span class="hgb-card__foot-label">Result</span>
                <span class="hgb-card__foot-val">${s.winner} in ${s.winner_in}</span>`;
  } else {
    const iso = s.nextGameUTC ?? s._nextGameUTC;
    const nextTxt = iso ? formatNextGame(iso, seriesState(s).played + 1) : 'TBD';
    nextHtml = `<span class="hgb-card__foot-label">Next Game</span>
                <span class="hgb-card__foot-val" data-next-game>${nextTxt}</span>`;
  }

  let rightHtml: string;
  if (s.is_complete) {
    rightHtml = `<span class="hgb-card__foot-label">Series Winner</span>
                 <span class="hgb-card__foot-val"><strong>${s.winner}</strong></span>`;
  } else {
    const all = [
      ...s.a.dist.map((v: number, i: number) => ({ label:`${s.a.abbr} in ${i+4}`, v })),
      ...s.b.dist.map((v: number, i: number) => ({ label:`${s.b.abbr} in ${i+4}`, v })),
    ];
    const ml = all.reduce((best: any, x: any) => x.v > best.v ? x : best);
    const [team, num] = ml.label.split(' in ');
    rightHtml = `<span class="hgb-card__foot-label">Most Likely</span>
                 <span class="hgb-card__foot-val"><strong>${team}</strong> in ${num} · ${ml.v}%</span>`;
  }

  foot.innerHTML = `
    <div class="hgb-card__foot-col">${nextHtml}</div>
    <div class="hgb-card__foot-col hgb-card__foot-col--right">${rightHtml}</div>
  `;
}

// Server-side Astro rendered the card footers with UTC ISO strings in data-iso
// attributes. Convert to the browser's local time zone on load.
hydrateLocalNextGame();

// Optional refresh: if cron ran after the last CF Pages build, loadModelData
// overlays fresh numbers. Otherwise it's a no-op (same data).
loadModelData();
</script>

</body>
</html>
