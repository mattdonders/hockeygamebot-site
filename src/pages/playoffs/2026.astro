---
// ── helpers ───────────────────────────────────────────────────────────────────
function mixHex(hex: string, target: string, amount: number): string {
  if (!hex.startsWith('#') || hex.length < 7) return hex;
  const p = (h: string, o: number) => parseInt(h.slice(o, o + 2), 16);
  const r1=p(hex,1), g1=p(hex,3), b1=p(hex,5);
  const r2=p(target,1), g2=p(target,3), b2=p(target,5);
  const t = amount / 100;
  const r=Math.round(r1+(r2-r1)*t), g=Math.round(g1+(g2-g1)*t), b=Math.round(b1+(b2-b1)*t);
  return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
}

// Static team metadata. Colors & seed labels are hardcoded because they don't
// live in the API payload (intentionally — the cron shouldn't care about UI).
// OTT & ANA use gold overrides instead of their primaries because CAR/OTT and
// EDM/ANA share near-identical reds/oranges and need visual separation on the
// distribution bars.
const TEAM_META: Record<string, { name: string; color: string; conf: string; seed: string; seedFull: string }> = {
  CAR: { name: 'Carolina Hurricanes',    color: '#CC0000', conf: 'East', seed: 'Metro · 1',  seedFull: 'Metropolitan · 1st' },
  OTT: { name: 'Ottawa Senators',        color: '#C2912C', conf: 'East', seed: 'Atl · WC2',  seedFull: 'Atlantic · Wild Card 2' },
  BUF: { name: 'Buffalo Sabres',         color: '#003087', conf: 'East', seed: 'Atl · 1',    seedFull: 'Atlantic · 1st' },
  BOS: { name: 'Boston Bruins',          color: '#FCB514', conf: 'East', seed: 'Atl · WC1',  seedFull: 'Atlantic · Wild Card 1' },
  TBL: { name: 'Tampa Bay Lightning',    color: '#0038A8', conf: 'East', seed: 'Atl · 2',    seedFull: 'Atlantic · 2nd' },
  MTL: { name: 'Montréal Canadiens',     color: '#AF1E2D', conf: 'East', seed: 'Atl · 3',    seedFull: 'Atlantic · 3rd' },
  PIT: { name: 'Pittsburgh Penguins',    color: '#FCB514', conf: 'East', seed: 'Met · 2',    seedFull: 'Metropolitan · 2nd' },
  PHI: { name: 'Philadelphia Flyers',    color: '#F74902', conf: 'East', seed: 'Met · 3',    seedFull: 'Metropolitan · 3rd' },
  DAL: { name: 'Dallas Stars',           color: '#006847', conf: 'West', seed: 'Cen · 2',    seedFull: 'Central · 2nd' },
  MIN: { name: 'Minnesota Wild',         color: '#A6192E', conf: 'West', seed: 'Cen · 3',    seedFull: 'Central · 3rd' },
  VGK: { name: 'Vegas Golden Knights',   color: '#B4975A', conf: 'West', seed: 'Pac · 1',    seedFull: 'Pacific · 1st' },
  UTA: { name: 'Utah Hockey Club',       color: '#69B3E7', conf: 'West', seed: 'Pac · WC1',  seedFull: 'Pacific · Wild Card 1' },
  COL: { name: 'Colorado Avalanche',     color: '#6F263D', conf: 'West', seed: 'Cen · 1',    seedFull: 'Central · 1st' },
  LAK: { name: 'Los Angeles Kings',      color: '#A2AAAD', conf: 'West', seed: 'Pac · WC2',  seedFull: 'Pacific · Wild Card 2' },
  EDM: { name: 'Edmonton Oilers',        color: '#FF4C00', conf: 'West', seed: 'Pac · 2',    seedFull: 'Pacific · 2nd' },
  ANA: { name: 'Anaheim Ducks',          color: '#FCD116', conf: 'West', seed: 'Pac · 3',    seedFull: 'Pacific · 3rd' },
};

// ── Round-aware labels ───────────────────────────────────────────────────────
const ROUND_LABELS: Record<number, string> = {
  1: 'First Round',
  2: 'Conference Semifinals',
  3: 'Conference Finals',
  4: 'Stanley Cup Final',
};

// Per-matchup color overrides. TEAM_META already shifts OTT/ANA preemptively
// for R1 clashes. For R2, when two teams' default colors are too similar, we
// override one team's color *just for that matchup*. Keys are sorted abbrev
// pairs ("ABC|XYZ") so lookup is order-independent.
const MATCHUP_COLOR_OVERRIDES: Record<string, { team: string; color: string }[]> = {
  // Both red — push MTL toward its alternate light-blue.
  'CAR|MTL': [{ team: 'MTL', color: '#192168' }],
  // Both gold — push PIT toward its alternate black/white. Use a deep gold-leaning
  // gray so it stays visually distinct from BOS gold.
  'BOS|PIT': [{ team: 'PIT', color: '#CFC493' }],
};
function matchupKey(a: string, b: string) {
  return [a, b].sort().join('|');
}
function colorFor(abbr: string, opponent: string): string {
  const base = TEAM_META[abbr]?.color ?? '#888888';
  const overrides = MATCHUP_COLOR_OVERRIDES[matchupKey(abbr, opponent)];
  const hit = overrides?.find(o => o.team === abbr);
  return hit ? hit.color : base;
}

// ── BUILD-TIME FETCH: hgb-api is the source of truth for everything dynamic ──
// distributions, win %, per-game winners, next-game times, staleness. No
// hardcoded placeholder numbers — the page renders with real data on first
// paint or a skeleton state if the API is unreachable at build time.
type ApiSeries = {
  series_id: string; round: number; season: string;
  team_a: string; team_b: string;
  win_pct_a: number; win_pct_b: number;
  dist_a: number[]; dist_b: number[];
  games: (string | null)[];
  is_complete: boolean; winner: string | null; winner_in: number | null;
  next_game_utc: string | null;
  updated_at: string;
};

// Carousel R2 series — used to seed R2 placeholder cards when hgb-api hasn't
// yet generated model data for round 2 (CAR + COL lock in first via division
// winners). Shape: NHL playoff-series/carousel response.
type CarouselSeries = {
  seriesLetter: string;
  topSeed: { abbrev: string };
  bottomSeed: { abbrev: string };
};

let apiSeries: ApiSeries[] = [];
let apiSeriesR2: ApiSeries[] = [];
let carouselR1: CarouselSeries[] = [];
let carouselR2: CarouselSeries[] = [];
let currentRound = 1;
let latestUpdate: string | null = null;
try {
  const res = await fetch('https://api.hockeygamebot.com/v1/playoffs/round/1');
  if (res.ok) {
    const data = await res.json();
    apiSeries = data.series ?? [];
    latestUpdate = data.latest_update ?? null;
  }
} catch (_) {
  // If hgb-api is unreachable at build time, the page still renders. Client-side
  // loadModelData() will fill in later.
}
try {
  const res = await fetch('https://api.hockeygamebot.com/v1/playoffs/round/2');
  if (res.ok) {
    const data = await res.json();
    apiSeriesR2 = data.series ?? [];
  }
} catch (_) { /* ok if R2 not seeded */ }
try {
  const res = await fetch('https://api-web.nhle.com/v1/playoff-series/carousel/20252026');
  if (res.ok) {
    const data = await res.json();
    currentRound = data.currentRound ?? 1;
    const r1 = (data.rounds ?? []).find((r: any) => r.roundNumber === 1);
    if (r1) carouselR1 = r1.series ?? [];
    const r2 = (data.rounds ?? []).find((r: any) => r.roundNumber === 2);
    if (r2) carouselR2 = r2.series ?? [];
  }
} catch (_) { /* fall back to round 1 only */ }

// ── R2 → R1 feeder mapping ─────────────────────────────────────────────────
// Standard NHL bracket; the API does not expose feeder fields so hardcode.
//   I → A (1-vs-WC1) winner vs D (2-vs-3 Metro) winner    (East)
//   J → B (1-vs-WC2) winner vs C (2-vs-3 Atlantic) winner (East)
//   K → E (1-vs-WC1) winner vs H (2-vs-3 Pacific) winner  (West)
//   L → F (1-vs-WC2) winner vs G (2-vs-3 Central) winner  (West)
const R2_FEEDERS: Record<string, [string, string]> = {
  I: ['A', 'D'],
  J: ['B', 'C'],
  K: ['E', 'H'],
  L: ['F', 'G'],
};

// Find the R1 series for a given letter; return its two team abbrevs and
// whether the series is already complete (winner known) per hgb-api data.
function r1FeederFor(letter: string): { a: string; b: string; winner: string | null } | null {
  const car = carouselR1.find(c => c.seriesLetter === letter);
  if (!car) return null;
  const a = car.topSeed.abbrev;
  const b = car.bottomSeed.abbrev;
  // Cross-reference hgb-api R1 to detect winner. Match by team set so we
  // don't depend on team_a/team_b ordering.
  const api = apiSeries.find(s =>
    (s.team_a === a && s.team_b === b) || (s.team_a === b && s.team_b === a)
  );
  const winner = api?.is_complete ? api.winner : null;
  return { a, b, winner };
}

// Render label for the TBD slot in an R2 placeholder.
// - If we can't resolve feeders, fall back to "Series {letter}".
// - If the OTHER R1 feeder is already complete, just show the winner.
// - Otherwise, "Winner of {A}/{B}".
function feederLabel(r2Letter: string, lockedAbbr: string | null): string {
  const feeders = R2_FEEDERS[r2Letter];
  if (!feeders) return `Series ${r2Letter}`;
  const [letterA, letterB] = feeders;
  const feedA = r1FeederFor(letterA);
  const feedB = r1FeederFor(letterB);
  // Pick the feeder that does NOT contain the locked R2 team.
  let other: { a: string; b: string; winner: string | null } | null = null;
  if (lockedAbbr && feedA && (feedA.a === lockedAbbr || feedA.b === lockedAbbr)) {
    other = feedB;
  } else if (lockedAbbr && feedB && (feedB.a === lockedAbbr || feedB.b === lockedAbbr)) {
    other = feedA;
  } else {
    // No locked side — return both feeders if we have them, else generic.
    other = feedA ?? feedB;
  }
  if (!other) return `Series ${r2Letter}`;
  if (other.winner) return other.winner;
  return `Winner of ${other.a}/${other.b}`;
}

// Derive a UI-ready SERIES array. Team metadata comes from TEAM_META; dynamic
// state from the API payload. Series_id pattern is `hs-ls` lowercased (Elo order).
const SERIES = apiSeries.map(s => {
  const a = TEAM_META[s.team_a] ?? null;
  const b = TEAM_META[s.team_b] ?? null;
  if (!a || !b) return null;
  const colorA = colorFor(s.team_a, s.team_b);
  const colorB = colorFor(s.team_b, s.team_a);
  return {
    id: s.series_id,
    round: 1,
    conf: a.conf,
    miniBadge: `${a.conf === 'East' ? 'East' : 'West'} · ${a.seed.split(' · ')[1] ?? a.seed} vs ${b.seed.split(' · ')[1] ?? b.seed}`,
    games: s.games,
    is_complete: s.is_complete,
    winner: s.winner,
    winner_in: s.winner_in,
    nextGameUTC: s.next_game_utc,
    tbd: false,
    a: { abbr: s.team_a, name: a.name, color: colorA, seed: a.seed, seedFull: a.seedFull,
         dist: s.dist_a, winPct: s.win_pct_a },
    b: { abbr: s.team_b, name: b.name, color: colorB, seed: b.seed, seedFull: b.seedFull,
         dist: s.dist_b, winPct: s.win_pct_b },
  };
}).filter((x): x is NonNullable<typeof x> => x !== null);

// ── R2 SERIES ─────────────────────────────────────────────────────────────────
// Build the R2 series list. Prefer hgb-api model data; fall back to the NHL
// carousel (which exposes which teams have locked in via series letters J/K/L/M
// before the model has had a chance to spin a prediction). TBD slots render as
// pull-quote placeholder cards.
type R2Card = {
  id: string;
  round: 2;
  conf: 'East' | 'West';
  miniBadge: string;
  games: (string | null)[];
  is_complete: boolean;
  winner: string | null;
  winner_in: number | null;
  nextGameUTC: string | null;
  tbd: boolean;
  awaitingFromLetter?: string;  // "Winner of A" placeholder anchor when team_b is TBD
  a: { abbr: string; name: string; color: string; seed: string; seedFull: string; dist: number[]; winPct: number };
  b: { abbr: string; name: string; color: string; seed: string; seedFull: string; dist: number[]; winPct: number };
};

const TBD_META = {
  abbr: 'TBD', name: 'To Be Determined', color: '#3a3a48',
  seed: 'TBD', seedFull: 'To Be Determined',
};

function buildR2FromApi(s: ApiSeries): R2Card | null {
  const a = TEAM_META[s.team_a];
  const b = TEAM_META[s.team_b];
  // If either is "TBD" or unknown, treat as carousel-style placeholder.
  if (!a || !b) return null;
  const colorA = colorFor(s.team_a, s.team_b);
  const colorB = colorFor(s.team_b, s.team_a);
  return {
    id: s.series_id,
    round: 2,
    conf: a.conf as 'East' | 'West',
    miniBadge: `${a.conf === 'East' ? 'East' : 'West'} · R2`,
    games: s.games,
    is_complete: s.is_complete,
    winner: s.winner,
    winner_in: s.winner_in,
    nextGameUTC: s.next_game_utc,
    tbd: false,
    a: { abbr: s.team_a, name: a.name, color: colorA, seed: a.seed, seedFull: a.seedFull,
         dist: s.dist_a, winPct: s.win_pct_a },
    b: { abbr: s.team_b, name: b.name, color: colorB, seed: b.seed, seedFull: b.seedFull,
         dist: s.dist_b, winPct: s.win_pct_b },
  };
}

function buildR2FromCarousel(c: CarouselSeries): R2Card | null {
  // The carousel exposes topSeed + bottomSeed. Either may be TBD. Pick the
  // locked team as `a` (so single-color matchups always show the locked team
  // on the left); the placeholder occupies `b`.
  const top = c.topSeed.abbrev, bot = c.bottomSeed.abbrev;
  const topMeta = TEAM_META[top];
  const botMeta = TEAM_META[bot];
  // Determine conference from whichever side is locked.
  const conf = (topMeta?.conf ?? botMeta?.conf ?? 'East') as 'East' | 'West';
  // Build the card. Awaiting-side metadata uses the placeholder.
  const aLocked = !!topMeta;
  const bLocked = !!botMeta;
  if (!aLocked && !bLocked) {
    // Both TBD — render double placeholder.
    return {
      id: `tbd-tbd-${c.seriesLetter.toLowerCase()}`,
      round: 2,
      conf,
      miniBadge: `R2 · Series ${c.seriesLetter}`,
      games: [null, null, null, null, null, null, null],
      is_complete: false, winner: null, winner_in: null, nextGameUTC: null,
      tbd: true,
      awaitingFromLetter: c.seriesLetter,
      a: { ...TBD_META, dist: [0,0,0,0], winPct: 0 },
      b: { ...TBD_META, dist: [0,0,0,0], winPct: 0 },
    };
  }
  const lockedAbbr = aLocked ? top : bot;
  const lockedMeta = aLocked ? topMeta! : botMeta!;
  const id = `${lockedAbbr.toLowerCase()}-tbd-${c.seriesLetter.toLowerCase()}`;
  return {
    id,
    round: 2,
    conf: lockedMeta.conf as 'East' | 'West',
    miniBadge: `${lockedMeta.conf === 'East' ? 'East' : 'West'} · Series ${c.seriesLetter}`,
    games: [null, null, null, null, null, null, null],
    is_complete: false, winner: null, winner_in: null, nextGameUTC: null,
    tbd: true,
    awaitingFromLetter: c.seriesLetter,
    a: { abbr: lockedAbbr, name: lockedMeta.name, color: lockedMeta.color,
         seed: lockedMeta.seed, seedFull: lockedMeta.seedFull, dist: [0,0,0,0], winPct: 0 },
    b: { ...TBD_META, dist: [0,0,0,0], winPct: 0 },
  };
}

let SERIES_R2: R2Card[] = [];
if (apiSeriesR2.length > 0) {
  // Have model data — use it. For any API entry with team_b === "TBD" or unknown,
  // fall back to carousel placeholder for that letter.
  SERIES_R2 = apiSeriesR2.map(s => {
    const built = buildR2FromApi(s);
    if (built) return built;
    // API entry exists but one side is TBD — try to find a matching carousel entry
    // (match by locked team) and synthesize a placeholder.
    const locked = TEAM_META[s.team_a] ? s.team_a : (TEAM_META[s.team_b] ? s.team_b : null);
    if (!locked) return null;
    const car = carouselR2.find(c => c.topSeed.abbrev === locked || c.bottomSeed.abbrev === locked);
    if (!car) return null;
    return buildR2FromCarousel(car);
  }).filter((x): x is R2Card => x !== null);
} else if (carouselR2.length > 0) {
  // No model data yet — derive placeholders from NHL carousel.
  SERIES_R2 = carouselR2.map(buildR2FromCarousel).filter((x): x is R2Card => x !== null);
}

const r1AllComplete = SERIES.length > 0 && SERIES.every(s => s.is_complete);
const showR2 = SERIES_R2.length > 0;
// Eyebrow round indicator shows whenever any R2 series has BOTH seeds locked
// (or NHL has officially advanced currentRound). Strictly waiting for
// currentRound > 1 misses the window between conference-final-game-7 and the
// carousel update, when a fully-set R2 matchup is already known.
const r2HasFullMatchup = SERIES_R2.some(s => !s.tbd);
const showRoundIndicator = currentRound > 1 || (showR2 && r2HasFullMatchup);
const indicatorRound = currentRound > 1 ? currentRound : 2;
const currentRoundLabel = ROUND_LABELS[currentRound] ?? 'Stanley Cup Playoffs';
const indicatorLabel = ROUND_LABELS[indicatorRound] ?? currentRoundLabel;

// ── card helpers (server-side) ────────────────────────────────────────────────
type AnyCard = (typeof SERIES)[0] | R2Card;

function buildCardSegs(s: AnyCard) {
  if (!s.a.dist.length) return [];
  const [a4,a5,a6,a7] = s.a.dist;
  const [b4,b5,b6,b7] = s.b.dist;
  const hc = s.a.color, lc = s.b.color;
  const raw = [
    { w:a4, c:mixHex(hc,'#000000',32), label:`${s.a.abbr} in 4`, boundary:false },
    { w:a5, c:mixHex(hc,'#000000',18), label:`${s.a.abbr} in 5`, boundary:false },
    { w:a6, c:hc,                       label:`${s.a.abbr} in 6`, boundary:false },
    { w:a7, c:mixHex(hc,'#ffffff',14), label:`${s.a.abbr} in 7`, boundary:false },
    { w:b7, c:mixHex(lc,'#ffffff',14), label:`${s.b.abbr} in 7`, boundary:true  },
    { w:b6, c:lc,                       label:`${s.b.abbr} in 6`, boundary:false },
    { w:b5, c:mixHex(lc,'#000000',18), label:`${s.b.abbr} in 5`, boundary:false },
    { w:b4, c:mixHex(lc,'#000000',32), label:`${s.b.abbr} in 4`, boundary:false },
  ];
  const maxW = Math.max(...raw.map(x => x.w));
  return raw.filter(sg => sg.w > 0).map(sg => ({ ...sg, isSmall: sg.w <= 6, isMax: sg.w === maxW }));
}

function mostLikely(s: AnyCard) {
  if (!s.a.dist.length) return null;
  const all = [
    ...s.a.dist.map((v: number, i: number) => ({ label:`${s.a.abbr} in ${i+4}`, v })),
    ...s.b.dist.map((v: number, i: number) => ({ label:`${s.b.abbr} in ${i+4}`, v })),
  ];
  return all.reduce((best, x) => x.v > best.v ? x : best);
}

const eastSeries = SERIES.filter(s => s.conf === 'East');
const westSeries = SERIES.filter(s => s.conf === 'West');
