const SERIES = {
  east: [
    {
      higher: "CAR", lower: "OTT", higherSeed: 1, lowerSeed: 6, conf: "East",
      higherName: "Carolina Hurricanes", lowerName: "Ottawa Senators",
      higherColor: "#CC0000", lowerColor: "#E31837",
      higherPct: 59, lowerPct: 41,
      dist: { "4": { h: 8.0, l: 5.0 }, "5": { h: 16.0, l: 9.0 }, "6": { h: 16.0, l: 15.0 }, "7": { h: 18.0, l: 13.0 } },
    },
    {
      higher: "BUF", lower: "BOS", higherSeed: 2, lowerSeed: 5, conf: "East",
      higherName: "Buffalo Sabres", lowerName: "Boston Bruins",
      higherColor: "#003087", lowerColor: "#FCB514",
      higherPct: 65, lowerPct: 35,
      dist: { "4": { h: 10.0, l: 4.0 }, "5": { h: 19.0, l: 8.0 }, "6": { h: 18.0, l: 12.0 }, "7": { h: 18.0, l: 12.0 } },
    },
    {
      higher: "TBL", lower: "MTL", higherSeed: 3, lowerSeed: 4, conf: "East",
      higherName: "Tampa Bay Lightning", lowerName: "Montréal Canadiens",
      higherColor: "#0038A8", lowerColor: "#AF1E2D",
      higherPct: 66, lowerPct: 34,
      dist: { "4": { h: 11.0, l: 4.0 }, "5": { h: 20.0, l: 7.0 }, "6": { h: 18.0, l: 12.0 }, "7": { h: 18.0, l: 11.0 } },
    },
    {
      higher: "PIT", lower: "PHI", higherSeed: 7, lowerSeed: 8, conf: "East",
      higherName: "Pittsburgh Penguins", lowerName: "Philadelphia Flyers",
      higherColor: "#FCB514", lowerColor: "#F74902",
      higherPct: 49, lowerPct: 51,
      dist: { "4": { h: 6.0, l: 7.0 }, "5": { h: 13.0, l: 12.0 }, "6": { h: 14.0, l: 17.0 }, "7": { h: 16.0, l: 14.0 } },
    },
  ],
  west: [
    {
      higher: "COL", lower: "LAK", higherSeed: 1, lowerSeed: 8, conf: "West",
      higherName: "Colorado Avalanche", lowerName: "Los Angeles Kings",
      higherColor: "#6F263D", lowerColor: "#A2AAAD",
      higherPct: null, lowerPct: null, dist: null, tbd: true,
    },
    {
      higher: "DAL", lower: "MIN", higherSeed: 2, lowerSeed: 3, conf: "West",
      higherName: "Dallas Stars", lowerName: "Minnesota Wild",
      higherColor: "#006847", lowerColor: "#A6192E",
      higherPct: 53, lowerPct: 47,
      dist: { "4": { h: 7.0, l: 6.0 }, "5": { h: 14.0, l: 11.0 }, "6": { h: 15.0, l: 16.0 }, "7": { h: 17.0, l: 14.0 } },
    },
    {
      higher: "VGK", lower: "UTA", higherSeed: 4, lowerSeed: 5, conf: "West",
      higherName: "Vegas Golden Knights", lowerName: "Utah Hockey Club",
      higherColor: "#B4975A", lowerColor: "#69B3E7",
      higherPct: 57, lowerPct: 43,
      dist: { "4": { h: 8.0, l: 5.0 }, "5": { h: 16.0, l: 9.0 }, "6": { h: 16.0, l: 15.0 }, "7": { h: 17.0, l: 13.0 } },
    },
    {
      higher: "EDM", lower: "ANA", higherSeed: 6, lowerSeed: 7, conf: "West",
      higherName: "Edmonton Oilers", lowerName: "Anaheim Ducks",
      higherColor: "#FF4C00", lowerColor: "#F47A38",
      higherPct: null, lowerPct: null, dist: null, tbd: true,
    },
  ],
};

// Build 8 segments for a series: H4 H5 H6 H7 | L7 L6 L5 L4
function buildSegments(s: any) {
  if (!s.dist) return [];
  const d = s.dist;
  const hc = s.higherColor;
  const lc = s.lowerColor;
  const segs = [
    { w: d["4"].h, c: `color-mix(in srgb, ${hc}, #000 30%)`, label: `${s.higher} in 4`, boundary: false },
    { w: d["5"].h, c: `color-mix(in srgb, ${hc}, #000 15%)`, label: `${s.higher} in 5`, boundary: false },
    { w: d["6"].h, c: hc,                                     label: `${s.higher} in 6`, boundary: false },
    { w: d["7"].h, c: `color-mix(in srgb, ${hc}, #fff 10%)`, label: `${s.higher} in 7`, boundary: false },
    { w: d["7"].l, c: `color-mix(in srgb, ${lc}, #fff 10%)`, label: `${s.lower} in 7`,  boundary: true  },
    { w: d["6"].l, c: lc,                                     label: `${s.lower} in 6`,  boundary: false },
    { w: d["5"].l, c: `color-mix(in srgb, ${lc}, #000 15%)`, label: `${s.lower} in 5`,  boundary: false },
    { w: d["4"].l, c: `color-mix(in srgb, ${lc}, #000 30%)`, label: `${s.lower} in 4`,  boundary: false },
  ];
  const maxW = Math.max(...segs.map(sg => sg.w));
  return segs.map(sg => ({ ...sg, isMax: sg.w === maxW, isSmall: sg.w <= 6 }));
}

function mostLikely(s: any) {
  if (!s.dist) return null;
  const d = s.dist;
  const candidates = [
    { label: `${s.higher} in 4`, pct: d["4"].h },
    { label: `${s.higher} in 5`, pct: d["5"].h },
    { label: `${s.higher} in 6`, pct: d["6"].h },
    { label: `${s.higher} in 7`, pct: d["7"].h },
    { label: `${s.lower} in 7`,  pct: d["7"].l },
    { label: `${s.lower} in 6`,  pct: d["6"].l },
    { label: `${s.lower} in 5`,  pct: d["5"].l },
    { label: `${s.lower} in 4`,  pct: d["4"].l },
  ];
  return candidates.reduce((a, b) => b.pct > a.pct ? b : a);
}

const allSeries = [...SERIES.east, ...SERIES.west];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>2026 Stanley Cup Playoffs — Round 1 Predictions · HockeyGameBot</title>
  <meta name="description" content="Model predictions for every 2026 Stanley Cup Playoffs first-round series.">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="apple-touch-icon" href="/favicon-180x180.png">
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --hgb-bg: #0d0d14;
  --hgb-surface: #15151e;
  --hgb-border: rgba(255,255,255,0.06);
  --hgb-border-strong: rgba(255,255,255,0.12);
  --hgb-border-bright: rgba(255,255,255,0.22);
  --hgb-text: #ebe9e6;
  --hgb-text-2: #a8a8b4;
  --hgb-text-3: #6a6a78;
  --hgb-text-4: #494957;
  --hgb-font-display: 'Oswald', sans-serif;
  --hgb-font-body: 'Space Grotesk', sans-serif;
  --hgb-font-mono: 'JetBrains Mono', ui-monospace, monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { -webkit-font-smoothing: antialiased; }
body { background: var(--hgb-bg); color: var(--hgb-text); font-family: var(--hgb-font-body); min-height: 100vh; }

/* ── Topbar ── */
.topbar { height: 52px; background: var(--hgb-bg); border-bottom: 1px solid var(--hgb-border-strong); display: flex; align-items: center; padding: 0 24px; gap: 16px; position: sticky; top: 0; z-index: 100; }
.brand { font-family: var(--hgb-font-display); font-size: 22px; font-weight: 700; color: #fff; letter-spacing: 0.1em; text-decoration: none; }
.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 6px; }
.topbar-link { font: 600 10px/1 var(--hgb-font-mono); letter-spacing: 0.1em; color: var(--hgb-text-3); text-decoration: none; padding: 5px 10px; border: 1px solid var(--hgb-border-strong); border-radius: 3px; transition: color 0.15s, border-color 0.15s; white-space: nowrap; display: inline-flex; align-items: center; text-transform: uppercase; }
.topbar-link:hover { color: var(--hgb-text); border-color: var(--hgb-border-bright); }
.topbar-link--active { color: #E8002D; border-color: rgba(232,0,45,0.35); }
.topbar-link--support { gap: 5px; }
.support-heart { opacity: 0.5; transition: opacity 0.15s; flex-shrink: 0; }
.topbar-link--support:hover .support-heart { opacity: 1; }

/* ── Hero ── */
.hero { padding: 40px 24px 28px; border-bottom: 1px solid var(--hgb-border); }
.hero-eyebrow { font: 600 11px/1 var(--hgb-font-mono); letter-spacing: 0.18em; color: #E8002D; text-transform: uppercase; margin-bottom: 10px; }
.hero-title { font: 700 32px/1.1 var(--hgb-font-display); letter-spacing: 0.04em; margin-bottom: 10px; }
.hero-meta { font: 500 12px/1 var(--hgb-font-mono); color: var(--hgb-text-3); letter-spacing: 0.08em; text-transform: uppercase; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.hero-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--hgb-text-4); }

/* ── Content ── */
.content { max-width: 1200px; margin: 0 auto; padding: 32px 24px 80px; }
.conference { margin-bottom: 48px; }
.conference-header { font: 600 10px/1 var(--hgb-font-mono); letter-spacing: 0.2em; color: var(--hgb-text-4); text-transform: uppercase; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid var(--hgb-border); display: flex; align-items: center; gap: 12px; }
.conference-header::after { content: ''; flex: 1; height: 1px; background: var(--hgb-border); }
.series-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

/* ── Series card (V4) ── */
.hgb-card {
  position: relative; display: block; padding: 20px 20px 18px;
  background: linear-gradient(180deg, #181821 0%, #13131c 100%);
  border: 1px solid var(--hgb-border-strong); border-radius: 10px;
  color: inherit; text-decoration: none; cursor: pointer;
  transition: transform 220ms cubic-bezier(.2,.8,.2,1), border-color 220ms ease, box-shadow 220ms ease;
  overflow: hidden;
}
.hgb-card:hover { transform: translateY(-2px); border-color: var(--hgb-border-bright); box-shadow: 0 10px 30px -12px rgba(0,0,0,0.5); }
.hgb-card::before {
  content: ''; position: absolute; inset: 0;
  background-image: radial-gradient(circle at center, rgba(255,255,255,0.018) 1px, transparent 1px);
  background-size: 18px 18px; pointer-events: none;
}
.hgb-card::after {
  content: ''; position: absolute; left: 0; top: 20px; bottom: 20px;
  width: 2px; background: linear-gradient(to bottom, var(--hgb-team-a), var(--hgb-team-b)); opacity: 0.8;
}
.hgb-card > * { position: relative; z-index: 1; }

/* Card meta strip */
.hgb-card__meta {
  display: flex; justify-content: space-between; align-items: center;
  font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4);
  letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 16px;
}
.hgb-mini-badge {
  padding: 3px 7px; border: 1px solid var(--hgb-border-strong);
  border-radius: 2px; color: var(--hgb-text-3); background: rgba(255,255,255,0.02);
}

/* Teams row */
.hgb-card__teams { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 12px; margin-bottom: 18px; }
.hgb-card__team { display: flex; align-items: center; gap: 12px; min-width: 0; }
.hgb-card__team--b { flex-direction: row-reverse; text-align: right; }
.hgb-card__logo { width: 38px; height: 38px; object-fit: contain; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4)); flex-shrink: 0; }
.hgb-card__ids { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.hgb-card__seed { font: 500 9px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.14em; text-transform: uppercase; }
.hgb-card__abbr { font: 700 22px/0.9 var(--hgb-font-display); color: var(--hgb-text); letter-spacing: 0.02em; }
.hgb-card__pct { font: 700 32px/0.85 var(--hgb-font-display); color: var(--hgb-text); letter-spacing: -0.01em; font-variant-numeric: tabular-nums; display: inline-flex; align-items: baseline; gap: 1px; }
.hgb-card__pct small { font-size: 14px; color: var(--team-color); }
.hgb-card__vs { font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.2em; padding: 0 4px; align-self: center; }

/* Distribution bar */
.hgb-card__bar-wrap { margin-bottom: 14px; }
.hgb-card__bar-meta { display: flex; justify-content: space-between; font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 6px; }
.hgb-card__bar { display: flex; height: 24px; border-radius: 2px; overflow: hidden; background: rgba(255,255,255,0.03); border: 1px solid var(--hgb-border); }
.hgb-card__seg { position: relative; background: var(--c); flex: var(--w) 0 0; display: flex; align-items: center; justify-content: center; transition: filter 180ms ease; }
.hgb-card__seg + .hgb-card__seg { border-left: 1px solid rgba(13,13,20,0.9); }
.hgb-card__seg[data-boundary] + .hgb-card__seg { border-left: 2px solid rgba(255,255,255,0.15); }
.hgb-card__seg-val { font: 600 9px/1 var(--hgb-font-mono); color: rgba(255,255,255,0.9); font-variant-numeric: tabular-nums; text-shadow: 0 1px 2px rgba(0,0,0,0.5); }
.hgb-card__seg--small .hgb-card__seg-val { display: none; }
.hgb-card__seg--max::after { content: ''; position: absolute; top: -1px; left: -1px; right: -1px; height: 3px; background: #fff; opacity: 0.55; }
.hgb-card__bar-tics { display: flex; margin-top: 4px; font: 500 8px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.06em; }
.hgb-card__bar-tics span { flex: var(--w) 0 0; text-align: center; }

/* Card footer */
.hgb-card__foot { display: flex; justify-content: space-between; align-items: center; padding-top: 12px; border-top: 1px solid var(--hgb-border); }
.hgb-card__foot-left { display: flex; align-items: center; gap: 8px; }
.hgb-card__foot-label { font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.12em; text-transform: uppercase; }
.hgb-card__foot-val { font: 600 14px/1 var(--hgb-font-display); color: var(--hgb-text); letter-spacing: 0.02em; }
.hgb-card__foot-val strong { color: var(--hgb-team-a); }
.hgb-card__status { font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.10em; text-transform: uppercase; transition: color 0.15s; }
.hgb-card__status.live { color: #4ade80; }
.hgb-card__status.complete { color: var(--hgb-text-2); }

/* TBD */
.series-tbd { aspect-ratio: 2/1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; }
.series-tbd-teams { font: 700 20px/1 var(--hgb-font-display); color: rgba(255,255,255,0.12); letter-spacing: 0.06em; }
.series-tbd-label { font: 600 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.14em; text-transform: uppercase; }

/* Responsive */
@media (max-width: 700px) {
  .hero { padding: 28px 16px 20px; }
  .hero-title { font-size: 24px; }
  .content { padding: 24px 16px 48px; }
  .series-grid { grid-template-columns: 1fr; }
  .topbar { padding: 0 16px; }
  .hgb-card__pct { font-size: 28px; }
  .hgb-card__abbr { font-size: 20px; }
  .hgb-card__meta,
  .hgb-card__bar-meta,
  .hgb-card__foot-label,
  .hgb-card__status { font-size: 11px; }
  .hgb-card__foot-val { font-size: 15px; }
  .hgb-card__logo { width: 36px; height: 36px; }
}
</style>
</head>
<body>

<div class="topbar">
  <a href="/" class="brand">HGB</a>
  <div class="topbar-right">
    <a href="/playoffs" class="topbar-link topbar-link--active">PLAYOFFS</a>
    <a href="/teams" class="topbar-link">TEAMS</a>
    <a href="/support" class="topbar-link topbar-link--support" aria-label="Support HockeyGameBot">
      <svg class="support-heart" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      <span>SUPPORT</span>
    </a>
  </div>
</div>

<div class="hero">
  <div class="hero-eyebrow">2026 Stanley Cup Playoffs</div>
  <div class="hero-title">Round 1 Predictions</div>
  <div class="hero-meta">
    <span>Pre-series model predictions</span>
    <div class="hero-meta-dot"></div>
    <span>Games begin April 18</span>
  </div>
</div>

<div class="content">
  {(['east', 'west'] as const).map(conf => (
    <div class="conference">
      <div class="conference-header">
        {conf === 'east' ? 'Eastern Conference' : 'Western Conference'}
      </div>
      <div class="series-grid">
        {SERIES[conf].map(s => {
          const segs = buildSegments(s);
          const ml = mostLikely(s);
          return (
            <article
              class="hgb-card"
              style={`--hgb-team-a: ${s.higherColor}; --hgb-team-b: ${s.lowerColor};`}
              data-higher={s.higher}
              data-lower={s.lower}
              data-tbd={s.tbd ? 'true' : 'false'}
              role="button"
              tabindex="0"
              aria-label={`${s.higher} vs ${s.lower}`}
            >
              {s.tbd ? (
                <div class="series-tbd">
                  <div class="series-tbd-teams">{s.higher} · {s.lower}</div>
                  <div class="series-tbd-label">Matchup TBD</div>
                </div>
              ) : (
                <>
                  <header class="hgb-card__meta">
                    <span class="hgb-mini-badge">{s.conf} · Rd 1</span>
                    <span>#{s.higherSeed} vs #{s.lowerSeed}</span>
                  </header>

                  <div class="hgb-card__teams">
                    <div class="hgb-card__team" style={`--team-color: ${s.higherColor}`}>
                      <img src={`https://assets.nhle.com/logos/nhl/svg/${s.higher}_light.svg`} alt={s.higher} class="hgb-card__logo" />
                      <div class="hgb-card__ids">
                        <span class="hgb-card__seed">Seed #{s.higherSeed}</span>
                        <span class="hgb-card__abbr">{s.higher}</span>
                      </div>
                      <span class="hgb-card__pct" style="margin-left: auto">{s.higherPct}<small>%</small></span>
                    </div>

                    <span class="hgb-card__vs">vs</span>

                    <div class="hgb-card__team hgb-card__team--b" style={`--team-color: ${s.lowerColor}`}>
                      <img src={`https://assets.nhle.com/logos/nhl/svg/${s.lower}_light.svg`} alt={s.lower} class="hgb-card__logo" />
                      <div class="hgb-card__ids">
                        <span class="hgb-card__seed">Seed #{s.lowerSeed}</span>
                        <span class="hgb-card__abbr">{s.lower}</span>
                      </div>
                      <span class="hgb-card__pct" style="margin-right: auto">{s.lowerPct}<small>%</small></span>
                    </div>
                  </div>

                  <div class="hgb-card__bar-wrap">
                    <div class="hgb-card__bar-meta">
                      <span>Outcome distribution</span>
                    </div>
                    <div class="hgb-card__bar">
                      {segs.map(seg => (
                        <span
                          class={`hgb-card__seg${seg.isMax ? ' hgb-card__seg--max' : ''}${seg.isSmall ? ' hgb-card__seg--small' : ''}`}
                          style={`--c: ${seg.c}; --w: ${seg.w}`}
                          data-boundary={seg.boundary ? 'true' : undefined}
                          title={`${seg.label} · ${seg.w}%`}
                        >
                          <span class="hgb-card__seg-val">{seg.w}</span>
                        </span>
                      ))}
                    </div>
                    <div class="hgb-card__bar-tics">
                      {segs.map(seg => (
                        <span style={`--w: ${seg.w}`}>{seg.label.split(' in ')[1]}</span>
                      ))}
                    </div>
                  </div>

                  <footer class="hgb-card__foot">
                    <div class="hgb-card__foot-left">
                      <span class="hgb-card__foot-label">Most Likely</span>
                      <span class="hgb-card__foot-val">
                        <strong>{ml?.label.split(' in ')[0]}</strong> in {ml?.label.split(' in ')[1]} · {ml?.pct}%
                      </span>
                    </div>
                    <span class="hgb-card__status" data-status={`${s.higher}-${s.lower}`}>Begins Apr 18</span>
                  </footer>
                </>
              )}
            </article>
          );
        })}
      </div>
    </div>
  ))}
</div>

<script>
async function loadSeriesStatus() {
  try {
    const res = await fetch('https://api-web.nhle.com/v1/playoff-series/carousel/20252026');
    if (!res.ok) return;
    const data = await res.json();
    const round1 = data.rounds?.find((r: any) => r.roundNumber === 1);
    if (!round1) return;
    for (const series of round1.series) {
      const top = series.topSeedTeam?.abbrev;
      const bot = series.bottomSeedTeam?.abbrev;
      const topW = series.topSeedTeam?.wins ?? 0;
      const botW = series.bottomSeedTeam?.wins ?? 0;
      if (!top || !bot) continue;
      const el = document.querySelector(`[data-status="${top}-${bot}"]`) ||
                 document.querySelector(`[data-status="${bot}-${top}"]`);
      if (!el) continue;
      if (topW === 0 && botW === 0) {
        el.textContent = 'Begins Apr 18';
      } else if (topW === 4) {
        el.textContent = `${top} wins 4-${botW}`; el.classList.add('complete');
      } else if (botW === 4) {
        el.textContent = `${bot} wins 4-${topW}`; el.classList.add('complete');
      } else {
        const leader = topW > botW ? top : bot;
        el.textContent = `${leader} leads ${Math.max(topW,botW)}-${Math.min(topW,botW)}`;
        el.classList.add('live');
      }
    }
  } catch (_) {}
}
loadSeriesStatus();
</script>

</body>
</html>
