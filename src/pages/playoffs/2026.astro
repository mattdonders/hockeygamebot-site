---
// ── helpers ───────────────────────────────────────────────────────────────────
function mixHex(hex: string, target: string, amount: number): string {
  if (!hex.startsWith('#') || hex.length < 7) return hex;
  const p = (h: string, o: number) => parseInt(h.slice(o, o + 2), 16);
  const r1=p(hex,1), g1=p(hex,3), b1=p(hex,5);
  const r2=p(target,1), g2=p(target,3), b2=p(target,5);
  const t = amount / 100;
  const r=Math.round(r1+(r2-r1)*t), g=Math.round(g1+(g2-g1)*t), b=Math.round(b1+(b2-b1)*t);
  return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
}

// Static team metadata. Colors & seed labels are hardcoded because they don't
// live in the API payload (intentionally — the cron shouldn't care about UI).
// OTT & ANA use gold overrides instead of their primaries because CAR/OTT and
// EDM/ANA share near-identical reds/oranges and need visual separation on the
// distribution bars.
const TEAM_META: Record<string, { name: string; color: string; conf: string; seed: string; seedFull: string }> = {
  CAR: { name: 'Carolina Hurricanes',    color: '#CC0000', conf: 'East', seed: 'Metro · 1',  seedFull: 'Metropolitan · 1st' },
  OTT: { name: 'Ottawa Senators',        color: '#C2912C', conf: 'East', seed: 'Atl · WC2',  seedFull: 'Atlantic · Wild Card 2' },
  BUF: { name: 'Buffalo Sabres',         color: '#003087', conf: 'East', seed: 'Atl · 1',    seedFull: 'Atlantic · 1st' },
  BOS: { name: 'Boston Bruins',          color: '#FCB514', conf: 'East', seed: 'Atl · WC1',  seedFull: 'Atlantic · Wild Card 1' },
  TBL: { name: 'Tampa Bay Lightning',    color: '#0038A8', conf: 'East', seed: 'Atl · 2',    seedFull: 'Atlantic · 2nd' },
  MTL: { name: 'Montréal Canadiens',     color: '#AF1E2D', conf: 'East', seed: 'Atl · 3',    seedFull: 'Atlantic · 3rd' },
  PIT: { name: 'Pittsburgh Penguins',    color: '#FCB514', conf: 'East', seed: 'Met · 2',    seedFull: 'Metropolitan · 2nd' },
  PHI: { name: 'Philadelphia Flyers',    color: '#F74902', conf: 'East', seed: 'Met · 3',    seedFull: 'Metropolitan · 3rd' },
  DAL: { name: 'Dallas Stars',           color: '#006847', conf: 'West', seed: 'Cen · 2',    seedFull: 'Central · 2nd' },
  MIN: { name: 'Minnesota Wild',         color: '#A6192E', conf: 'West', seed: 'Cen · 3',    seedFull: 'Central · 3rd' },
  VGK: { name: 'Vegas Golden Knights',   color: '#B4975A', conf: 'West', seed: 'Pac · 1',    seedFull: 'Pacific · 1st' },
  UTA: { name: 'Utah Hockey Club',       color: '#69B3E7', conf: 'West', seed: 'Pac · WC1',  seedFull: 'Pacific · Wild Card 1' },
  COL: { name: 'Colorado Avalanche',     color: '#6F263D', conf: 'West', seed: 'Cen · 1',    seedFull: 'Central · 1st' },
  LAK: { name: 'Los Angeles Kings',      color: '#A2AAAD', conf: 'West', seed: 'Pac · WC2',  seedFull: 'Pacific · Wild Card 2' },
  EDM: { name: 'Edmonton Oilers',        color: '#FF4C00', conf: 'West', seed: 'Pac · 2',    seedFull: 'Pacific · 2nd' },
  ANA: { name: 'Anaheim Ducks',          color: '#FCD116', conf: 'West', seed: 'Pac · 3',    seedFull: 'Pacific · 3rd' },
};

// ── BUILD-TIME FETCH: hgb-api is the source of truth for everything dynamic ──
// distributions, win %, per-game winners, next-game times, staleness. No
// hardcoded placeholder numbers — the page renders with real data on first
// paint or a skeleton state if the API is unreachable at build time.
type ApiSeries = {
  series_id: string; round: number; season: string;
  team_a: string; team_b: string;
  win_pct_a: number; win_pct_b: number;
  dist_a: number[]; dist_b: number[];
  games: (string | null)[];
  is_complete: boolean; winner: string | null; winner_in: number | null;
  next_game_utc: string | null;
  updated_at: string;
};

let apiSeries: ApiSeries[] = [];
let apiSeriesR2: ApiSeries[] = [];
let latestUpdate: string | null = null;
try {
  const [res1, res2] = await Promise.all([
    fetch('https://api.hockeygamebot.com/v1/playoffs/round/1'),
    fetch('https://api.hockeygamebot.com/v1/playoffs/round/2'),
  ]);
  if (res1.ok) { const d = await res1.json(); apiSeries = d.series ?? []; latestUpdate = d.latest_update ?? null; }
  if (res2.ok) { const d = await res2.json(); apiSeriesR2 = d.series ?? []; latestUpdate = latestUpdate ?? d.latest_update ?? null; }
} catch (_) {}

function buildSeriesArray(raw: ApiSeries[]) {
  return raw.map(s => {
    const a = TEAM_META[s.team_a] ?? null;
    const b = TEAM_META[s.team_b] ?? null;
    if (!a || !b) return null;
    return {
      id: s.series_id,
      conf: a.conf,
      miniBadge: `${a.conf === 'East' ? 'East' : 'West'} · ${a.seed.split(' · ')[1] ?? a.seed} vs ${b.seed.split(' · ')[1] ?? b.seed}`,
      games: s.games,
      is_complete: s.is_complete,
      winner: s.winner,
      winner_in: s.winner_in,
      nextGameUTC: s.next_game_utc,
      a: { abbr: s.team_a, name: a.name, color: a.color, seed: a.seed, seedFull: a.seedFull,
           dist: s.dist_a, winPct: s.win_pct_a },
      b: { abbr: s.team_b, name: b.name, color: b.color, seed: b.seed, seedFull: b.seedFull,
           dist: s.dist_b, winPct: s.win_pct_b },
    };
  }).filter((x): x is NonNullable<typeof x> => x !== null);
}

const SERIES    = buildSeriesArray(apiSeries);
const SERIES_R2 = buildSeriesArray(apiSeriesR2);

// Quick lookup: series by team pair (for bracket rendering)
const seriesByTeams = new Map<string, typeof SERIES[0]>();
[...SERIES, ...SERIES_R2].forEach(s => {
  seriesByTeams.set(`${s.a.abbr}-${s.b.abbr}`, s);
  seriesByTeams.set(`${s.b.abbr}-${s.a.abbr}`, s);
});

// ── Bracket state for hero ────────────────────────────────────────────────────
// Hardcoded 2026 bracket topology. Each arm: r1a + r1b → r2.
// Winner of r1a plays winner of r1b in round 2.
type BracketArm = { r1: [string, string]; r2: [string, string] };
const EAST_BRACKET: BracketArm[] = [
  { r1: ['CAR','OTT'], r2: ['CAR','PHI'] },
  { r1: ['PHI','PIT'], r2: ['CAR','PHI'] },
  { r1: ['BUF','BOS'], r2: ['BUF','MTL'] },
  { r1: ['MTL','TBL'], r2: ['BUF','MTL'] },
];
const WEST_BRACKET: BracketArm[] = [
  { r1: ['COL','LAK'], r2: ['COL','MIN'] },
  { r1: ['MIN','DAL'], r2: ['COL','MIN'] },
  { r1: ['VGK','UTA'], r2: ['VGK','ANA'] },
  { r1: ['ANA','EDM'], r2: ['VGK','ANA'] },
];

// R1 winners/losers for bracket rendering
const r1Winners = new Map<string, boolean>(); // team → won round 1
SERIES.forEach(s => {
  if (s.is_complete && s.winner) {
    const loser = s.a.abbr === s.winner ? s.b.abbr : s.a.abbr;
    r1Winners.set(s.winner, true);
    r1Winners.set(loser, false);
  }
});

// R2 series lookup by team pair
function getR2Series(a: string, b: string) {
  return seriesByTeams.get(`${a}-${b}`) ?? seriesByTeams.get(`${b}-${a}`) ?? null;
}

// ── card helpers (server-side) ────────────────────────────────────────────────
function buildCardSegs(s: typeof SERIES[0]) {
  if (!s.a.dist.length) return [];
  const [a4,a5,a6,a7] = s.a.dist;
  const [b4,b5,b6,b7] = s.b.dist;
  const hc = s.a.color, lc = s.b.color;
  const raw = [
    { w:a4, c:mixHex(hc,'#000000',32), label:`${s.a.abbr} in 4`, boundary:false },
    { w:a5, c:mixHex(hc,'#000000',18), label:`${s.a.abbr} in 5`, boundary:false },
    { w:a6, c:hc,                       label:`${s.a.abbr} in 6`, boundary:false },
    { w:a7, c:mixHex(hc,'#ffffff',14), label:`${s.a.abbr} in 7`, boundary:false },
    { w:b7, c:mixHex(lc,'#ffffff',14), label:`${s.b.abbr} in 7`, boundary:true  },
    { w:b6, c:lc,                       label:`${s.b.abbr} in 6`, boundary:false },
    { w:b5, c:mixHex(lc,'#000000',18), label:`${s.b.abbr} in 5`, boundary:false },
    { w:b4, c:mixHex(lc,'#000000',32), label:`${s.b.abbr} in 4`, boundary:false },
  ];
  const maxW = Math.max(...raw.map(x => x.w));
  return raw.filter(sg => sg.w > 0).map(sg => ({ ...sg, isSmall: sg.w <= 6, isMax: sg.w === maxW }));
}

function mostLikely(s: typeof SERIES[0]) {
  if (!s.a.dist.length) return null;
  const all = [
    ...s.a.dist.map((v: number, i: number) => ({ label:`${s.a.abbr} in ${i+4}`, v })),
    ...s.b.dist.map((v: number, i: number) => ({ label:`${s.b.abbr} in ${i+4}`, v })),
  ];
  return all.reduce((best, x) => x.v > best.v ? x : best);
}

const eastSeries    = SERIES.filter(s => s.conf === 'East');
const westSeries    = SERIES.filter(s => s.conf === 'West');
const eastSeriesR2  = SERIES_R2.filter(s => s.conf === 'East');
const westSeriesR2  = SERIES_R2.filter(s => s.conf === 'West');

// Rough cup win probability: P(win R2) × ½ × ½ (assuming 50/50 in ECF+SCF)
// Win percentages from the API are 0-100. Eliminated teams get 0.
const cupPct: Record<string, number> = {};
SERIES_R2.forEach(s => {
  cupPct[s.a.abbr] = Math.round(s.a.winPct / 4);
  cupPct[s.b.abbr] = Math.round(s.b.winPct / 4);
});
const cupRanked = Object.entries(cupPct)
  .map(([abbr, pct]) => ({ abbr, pct, color: TEAM_META[abbr]?.color ?? '#888' }))
  .sort((a, b) => b.pct - a.pct);
