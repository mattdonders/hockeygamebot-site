<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>2026 Stanley Cup Playoffs — Round 1 Predictions · HockeyGameBot</title>
  <meta name="description" content="Model predictions for every 2026 Stanley Cup Playoffs first-round series.">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="apple-touch-icon" href="/favicon-180x180.png">
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style is:global>
:root {
  --hgb-bg: #0d0d14;
  --hgb-surface: #15151e;
  --hgb-surface-2: #1a1a26;
  --hgb-border: rgba(255,255,255,0.06);
  --hgb-border-strong: rgba(255,255,255,0.12);
  --hgb-border-bright: rgba(255,255,255,0.22);
  --hgb-text: #ebe9e6;
  --hgb-text-2: #a8a8b4;
  --hgb-text-3: #6a6a78;
  --hgb-text-4: #494957;
  --hgb-font-display: 'Oswald', sans-serif;
  --hgb-font-body: 'Space Grotesk', sans-serif;
  --hgb-font-mono: 'JetBrains Mono', ui-monospace, monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { -webkit-font-smoothing: antialiased; }
body { background: var(--hgb-bg); color: var(--hgb-text); font-family: var(--hgb-font-body); min-height: 100vh; font-size: 14px; line-height: 1.4; }

/* ── Topbar ── */
.topbar { height: 52px; background: var(--hgb-bg); border-bottom: 1px solid var(--hgb-border-strong); display: flex; align-items: center; padding: 0 24px; gap: 16px; position: sticky; top: 0; z-index: 50; }
.brand { font-family: var(--hgb-font-display); font-size: 22px; font-weight: 700; color: #fff; letter-spacing: 0.1em; text-decoration: none; }
.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 6px; }
.topbar-link { font: 600 10px/1 var(--hgb-font-mono); letter-spacing: 0.1em; color: var(--hgb-text-3); text-decoration: none; padding: 5px 10px; border: 1px solid var(--hgb-border-strong); border-radius: 3px; transition: color 0.15s, border-color 0.15s; white-space: nowrap; display: inline-flex; align-items: center; gap: 5px; text-transform: uppercase; }
.topbar-link:hover { color: var(--hgb-text); border-color: var(--hgb-border-bright); }
.topbar-link--active { color: #E8002D; border-color: rgba(232,0,45,0.35); }
.support-heart { opacity: 0.5; transition: opacity 0.15s; flex-shrink: 0; }
.topbar-link--support:hover .support-heart { opacity: 1; }

/* ── Page header ── */
.page-head { padding: 36px 24px 28px; display: flex; justify-content: space-between; align-items: flex-end; gap: 20px; flex-wrap: wrap; border-bottom: 1px solid var(--hgb-border); }
.page-head__title { display: flex; flex-direction: column; gap: 6px; }
.page-head__eyebrow { font: 500 10px/1 var(--hgb-font-mono); color: #E8002D; letter-spacing: 0.18em; text-transform: uppercase; }
.page-head__h1 { font: 500 34px/1 var(--hgb-font-display); letter-spacing: 0.06em; text-transform: uppercase; }
.page-head__meta { display: flex; flex-direction: column; gap: 4px; text-align: right; }
.page-head__meta small { font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.14em; text-transform: uppercase; }
.page-head__meta strong { font: 500 14px/1 var(--hgb-font-display); color: var(--hgb-text-2); letter-spacing: 0.04em; }

/* ── Content ── */
.content { max-width: 1120px; margin: 0 auto; padding: 32px 24px 100px; }
.section-label { font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-3); letter-spacing: 0.16em; text-transform: uppercase; margin: 0 0 16px; display: flex; align-items: center; gap: 12px; }
.section-label::after { content: ''; flex: 1; height: 1px; background: var(--hgb-border); }
.conf-block { margin-bottom: 48px; }
.series-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.pending-strip { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px; }

/* ── Series card ── */
.hgb-card {
  position: relative; display: block; padding: 20px 22px 18px;
  background: linear-gradient(180deg, #181821 0%, #13131c 100%);
  border: 1px solid var(--hgb-border-strong); border-radius: 10px;
  color: inherit; text-decoration: none; cursor: pointer; text-align: left;
  width: 100%; font-family: inherit;
  transition: transform 220ms cubic-bezier(.2,.8,.2,1), border-color 220ms ease, box-shadow 220ms ease;
  overflow: hidden;
}
.hgb-card:hover { transform: translateY(-2px); border-color: var(--hgb-border-bright); box-shadow: 0 12px 32px -12px rgba(0,0,0,0.5); }
.hgb-card:focus-visible { outline: 2px solid rgba(232,0,45,0.6); outline-offset: 2px; }

/* meta strip */
.hgb-card__meta { display: flex; align-items: center; gap: 10px; font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 14px; }
.hgb-mini-badge { padding: 3px 7px; border: 1px solid var(--hgb-border-strong); border-radius: 2px; color: var(--hgb-text-3); background: rgba(255,255,255,0.02); }
.hgb-card__state { font: 600 10px/1 var(--hgb-font-display); color: var(--team-color, var(--hgb-text-2)); letter-spacing: 0.04em; }
.hgb-card__state::before { content: '●'; margin-right: 5px; font-size: 7px; vertical-align: middle; color: inherit; }

/* teams row */
.hgb-card__teams { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 12px; margin-bottom: 14px; }
.hgb-card__team { display: flex; align-items: center; gap: 12px; min-width: 0; }
.hgb-card__team--b { flex-direction: row-reverse; text-align: right; }
.hgb-card__logo { width: 44px; height: 44px; object-fit: contain; filter: drop-shadow(0 2px 10px rgba(0,0,0,0.4)); flex-shrink: 0; }
.hgb-card__ids { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
.hgb-card__seed { font: 500 9px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.14em; text-transform: uppercase; }
.hgb-card__abbr { font: 500 22px/0.9 var(--hgb-font-display); color: var(--hgb-text); letter-spacing: 0.02em; }
.hgb-card__pct { font: 500 34px/0.85 var(--hgb-font-display); color: var(--hgb-text); letter-spacing: -0.01em; font-variant-numeric: tabular-nums; display: inline-flex; align-items: baseline; gap: 2px; }
.hgb-card__pct small { font-size: 18px; color: var(--team-color); }
.hgb-card__vs { font: 500 11px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.2em; padding: 0 4px; align-self: center; }

/* game dots (shown mid-series) */
.hgb-card__dots { display: flex; gap: 3px; margin-bottom: 10px; }
.hgb-card__dot { flex: 1; height: 3px; border-radius: 1px; background: rgba(255,255,255,0.05); }
.hgb-card__dot--a { background: var(--hgb-team-a); }
.hgb-card__dot--b { background: var(--hgb-team-b); }

/* distribution bar */
.hgb-card__bar { display: flex; height: 26px; border-radius: 2px; overflow: hidden; background: rgba(255,255,255,0.03); border: 1px solid var(--hgb-border); margin-bottom: 14px; }
.hgb-card__seg { position: relative; background: var(--c); flex: var(--w) 0 0; display: flex; align-items: center; justify-content: center; }
.hgb-card__seg + .hgb-card__seg { border-left: 1px solid rgba(13,13,20,0.85); }
.hgb-card__seg[data-boundary] { border-left: 2px solid rgba(255,255,255,0.28) !important; }
.hgb-card__seg-val { font: 600 9px/1 var(--hgb-font-mono); color: rgba(255,255,255,0.9); font-variant-numeric: tabular-nums; text-shadow: 0 1px 2px rgba(0,0,0,0.5); }
.hgb-card__seg--small .hgb-card__seg-val { display: none; }

/* footer */
.hgb-card__foot { display: flex; align-items: baseline; gap: 8px; padding-top: 12px; border-top: 1px solid var(--hgb-border); }
.hgb-card__foot-label { font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.12em; text-transform: uppercase; }
.hgb-card__foot-val { font: 500 14px/1 var(--hgb-font-display); color: var(--hgb-text); letter-spacing: 0.02em; }
.hgb-card__foot-val strong { color: var(--hgb-team-a); }

/* TBD */
.series-tbd { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 20px; min-height: 76px; background: rgba(255,255,255,0.015); border: 1px dashed var(--hgb-border-strong); border-radius: 10px; }
.series-tbd-teams { font: 700 16px/1 var(--hgb-font-display); color: rgba(255,255,255,0.18); letter-spacing: 0.06em; }
.series-tbd-sep { color: var(--hgb-text-4); font: 500 10px/1 var(--hgb-font-mono); }
.series-tbd-label { font: 600 9px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.14em; text-transform: uppercase; border: 1px solid var(--hgb-border-strong); padding: 3px 7px; border-radius: 2px; }

/* ── Modal ── */
.hgb-modal { position: fixed; inset: 0; z-index: 200; display: flex; align-items: flex-end; justify-content: center; pointer-events: none; }
.hgb-modal.is-open { pointer-events: auto; }
.hgb-modal__scrim { position: absolute; inset: 0; background: radial-gradient(ellipse at center bottom, rgba(10,10,15,0.75), rgba(0,0,0,0.92)); backdrop-filter: blur(6px); opacity: 0; transition: opacity 320ms ease; }
.hgb-modal.is-open .hgb-modal__scrim { opacity: 1; }
.hgb-modal__sheet {
  position: relative; width: 100%; max-width: 860px; max-height: 94vh;
  overflow-y: auto;
  background: linear-gradient(180deg, #181821 0%, #12121a 100%);
  border: 1px solid var(--hgb-border-strong); border-bottom: none;
  border-radius: 16px 16px 0 0;
  box-shadow: 0 -1px 0 rgba(255,255,255,0.07) inset, 0 -24px 60px -12px rgba(0,0,0,0.6);
  transform: translateY(60px); opacity: 0;
  transition: transform 420ms cubic-bezier(.2,.8,.2,1), opacity 260ms ease;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.08) transparent;
}
.hgb-modal__sheet::-webkit-scrollbar { width: 6px; }
.hgb-modal__sheet::-webkit-scrollbar-track { background: transparent; }
.hgb-modal__sheet::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 3px; }
.hgb-modal__sheet::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.18); }
.hgb-modal.is-animating .hgb-modal__sheet { overflow: hidden; }
.hgb-modal.is-open .hgb-modal__sheet { transform: translateY(0); opacity: 1; }

.hgb-modal__handle { position: absolute; top: 10px; left: 50%; transform: translateX(-50%); width: 42px; height: 4px; border-radius: 2px; background: rgba(255,255,255,0.14); border: none; cursor: grab; z-index: 3; transition: background 200ms, width 200ms; }
.hgb-modal__handle:hover { background: rgba(255,255,255,0.3); width: 56px; }

/* modal util bar */
.hgb-util { position: relative; z-index: 2; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 22px 28px 14px; }
.hgb-util__group { display: flex; align-items: center; gap: 10px; }
.hgb-mono { font: 500 10px/1.2 var(--hgb-font-mono); color: var(--hgb-text-3); letter-spacing: 0.1em; text-transform: uppercase; }
.hgb-badge { display: inline-flex; align-items: center; padding: 4px 8px; border: 1px solid var(--hgb-border-strong); border-radius: 2px; font: 600 9px/1 var(--hgb-font-mono); color: var(--hgb-text-2); letter-spacing: 0.18em; text-transform: uppercase; background: rgba(255,255,255,0.02); }
.hgb-modal__close { width: 28px; height: 28px; border-radius: 4px; border: 1px solid var(--hgb-border-strong); background: transparent; color: var(--hgb-text-2); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 150ms ease; }
.hgb-modal__close:hover { color: var(--hgb-text); border-color: var(--hgb-border-bright); background: var(--hgb-surface-2); }

/* matchup header */
.hgb-matchup { position: relative; z-index: 2; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 28px; padding: 18px 28px 28px; }
.hgb-matchup::after { content: ''; position: absolute; left: 28px; right: 28px; bottom: 0; height: 1px; background: var(--hgb-border); }
.hgb-team { display: flex; align-items: center; gap: 18px; }
.hgb-team--b { flex-direction: row-reverse; text-align: right; }
.hgb-team__logo { width: 60px; height: 60px; object-fit: contain; filter: drop-shadow(0 4px 20px rgba(0,0,0,0.5)); }
.hgb-team__meta { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
.hgb-team__seed { font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-3); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 4px; display: inline-flex; align-items: center; gap: 6px; }
.hgb-team__seed::before { content: ''; width: 10px; height: 2px; background: var(--team-color); display: inline-block; }
.hgb-team--b .hgb-team__seed { justify-content: flex-end; }
.hgb-team--b .hgb-team__seed::before { display: none; }
.hgb-team--b .hgb-team__seed::after { content: ''; width: 10px; height: 2px; background: var(--team-color); display: inline-block; }
.hgb-team__abbr { font: 500 32px/0.9 var(--hgb-font-display); letter-spacing: 0.02em; color: var(--hgb-text); }
.hgb-team__name { font: 400 12px/1.3 var(--hgb-font-body); color: var(--hgb-text-2); }
.hgb-matchup__center { display: flex; flex-direction: column; align-items: center; gap: 6px; min-width: 92px; }
.hgb-matchup__vs { font: 500 13px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.28em; padding: 0 8px; }
.hgb-matchup__score { display: flex; flex-direction: column; align-items: center; gap: 6px; }
.hgb-matchup__score-nums { display: flex; align-items: center; gap: 10px; font: 500 44px/0.9 var(--hgb-font-display); letter-spacing: 0.02em; font-variant-numeric: tabular-nums; }
.hgb-matchup__score-a, .hgb-matchup__score-b { color: var(--hgb-text-4); }
.hgb-matchup__score-a.is-lead { color: var(--hgb-team-a); }
.hgb-matchup__score-b.is-lead { color: var(--hgb-team-b); }
.hgb-matchup__score-sep { color: var(--hgb-text-4); font-size: 30px; }
.hgb-matchup__status { font: 600 9px/1 var(--hgb-font-mono); letter-spacing: 0.22em; text-transform: uppercase; color: var(--hgb-text-2); }
.hgb-matchup__status.is-lead-a { color: var(--hgb-team-a); }
.hgb-matchup__status.is-lead-b { color: var(--hgb-team-b); }

/* series tracker */
.hgb-tracker { position: relative; z-index: 2; padding: 22px 28px 24px; display: flex; flex-direction: column; gap: 14px; }
.hgb-tracker::after { content: ''; position: absolute; left: 28px; right: 28px; bottom: 0; height: 1px; background: var(--hgb-border); }
.hgb-tracker__grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; max-width: 560px; width: 100%; margin: 0 auto; }
.hgb-tracker__game { aspect-ratio: 1; border: 1px solid var(--hgb-border-strong); border-radius: 4px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; min-height: 52px; background: rgba(255,255,255,0.015); }
.hgb-tracker__game--played { background: var(--c); border-color: var(--c); }
.hgb-tracker__game--next { border-color: var(--hgb-border-bright); background: rgba(255,255,255,0.04); box-shadow: 0 0 0 1px rgba(255,255,255,0.08); }
.hgb-tracker__winner { font: 600 12px/1 var(--hgb-font-display); color: #fff; letter-spacing: 0.04em; }
.hgb-tracker__num { font: 500 9px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.14em; text-transform: uppercase; }
.hgb-tracker__game--played .hgb-tracker__num { color: rgba(255,255,255,0.8); }
.hgb-tracker__game--next .hgb-tracker__num { color: var(--hgb-text-2); }
.hgb-tracker__meta { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; padding: 0 2px; }
.hgb-tracker__next { display: flex; align-items: baseline; gap: 8px; }
.hgb-tracker__next-label { font: 500 9px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.18em; text-transform: uppercase; }
.hgb-tracker__next-val { font: 500 14px/1 var(--hgb-font-display); color: var(--hgb-text); letter-spacing: 0.04em; }
.hgb-tracker__advance { display: flex; align-items: baseline; gap: 18px; }
.hgb-tracker__adv-item { display: inline-flex; align-items: baseline; gap: 6px; font: 500 9px/1 var(--hgb-font-mono); color: var(--hgb-text-4); letter-spacing: 0.14em; text-transform: uppercase; }
.hgb-tracker__adv-num { font: 500 18px/1 var(--hgb-font-display); color: var(--team-color); letter-spacing: 0.02em; font-variant-numeric: tabular-nums; }

/* win probability */
.hgb-wp { position: relative; z-index: 2; padding: 28px 28px 32px; display: flex; flex-direction: column; align-items: center; gap: 16px; }
.hgb-wp__label { font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-3); letter-spacing: 0.22em; text-transform: uppercase; }
.hgb-wp__row { width: 100%; position: relative; display: grid; grid-template-columns: 1fr 1fr; align-items: center; }
.hgb-wp__row::before { content: ''; position: absolute; top: 8%; bottom: 8%; left: 50%; width: 1px; background: var(--hgb-border); }
.hgb-wp__side { display: flex; align-items: baseline; justify-content: center; gap: 4px; line-height: 1; }
.hgb-wp__num { font: 500 84px/0.85 var(--hgb-font-display); color: var(--hgb-text); letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
.hgb-wp__pct { font: 500 28px/1 var(--hgb-font-display); color: var(--team-color); }

/* distribution chart */
.hgb-dist { position: relative; z-index: 2; padding: 28px 28px 24px; border-top: 1px solid var(--hgb-border); }
.hgb-dist__head { margin-bottom: 20px; }
.hgb-dist__h { font: 600 10px/1 var(--hgb-font-mono); letter-spacing: 0.18em; text-transform: uppercase; color: var(--hgb-text-3); }
.hgb-dist__body { display: grid; grid-template-columns: 32px 1fr; gap: 18px; }
.hgb-dist__y { display: flex; flex-direction: column; justify-content: space-between; font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-4); text-align: right; height: 280px; font-variant-numeric: tabular-nums; }
.hgb-dist__y span::after { content: ''; display: inline-block; width: 4px; height: 1px; background: var(--hgb-text-4); margin-left: 4px; vertical-align: middle; }
.hgb-dist__y .hgb-dist__y-0 { color: var(--hgb-text-2); font-weight: 600; }
.hgb-dist__y .hgb-dist__y-0::after { background: var(--hgb-border-bright); width: 6px; }
.hgb-dist__plot { position: relative; height: 280px; display: grid; grid-template-columns: repeat(4, 1fr); }
.hgb-dist__plot::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(to bottom,
    transparent 12.5%, rgba(255,255,255,0.03) 12.5%, rgba(255,255,255,0.03) calc(12.5% + 1px), transparent calc(12.5% + 1px),
    transparent 25%,   rgba(255,255,255,0.03) 25%,   rgba(255,255,255,0.03) calc(25% + 1px),   transparent calc(25% + 1px),
    transparent 37.5%, rgba(255,255,255,0.03) 37.5%, rgba(255,255,255,0.03) calc(37.5% + 1px), transparent calc(37.5% + 1px),
    transparent 62.5%, rgba(255,255,255,0.03) 62.5%, rgba(255,255,255,0.03) calc(62.5% + 1px), transparent calc(62.5% + 1px),
    transparent 75%,   rgba(255,255,255,0.03) 75%,   rgba(255,255,255,0.03) calc(75% + 1px),   transparent calc(75% + 1px),
    transparent 87.5%, rgba(255,255,255,0.03) 87.5%, rgba(255,255,255,0.03) calc(87.5% + 1px), transparent calc(87.5% + 1px)
  );
  pointer-events: none;
}
.hgb-dist__plot::after { content: ''; position: absolute; left: 0; right: 0; top: 50%; height: 1px; background: var(--hgb-border-bright); z-index: 3; }
.hgb-dist__col { position: relative; display: grid; grid-template-rows: 1fr 28px 1fr; z-index: 1; }
.hgb-dist__half { position: relative; display: flex; justify-content: center; overflow: visible; }
.hgb-dist__half--top { align-items: flex-end; }
.hgb-dist__half--bot { align-items: flex-start; }
.hgb-dist__bar {
  position: relative; width: 54px; max-width: 60%;
  height: 0;
  transition: height 700ms cubic-bezier(.2,.8,.2,1) var(--delay, 0ms);
  background: linear-gradient(to top, color-mix(in srgb, var(--team-color), #000 10%), color-mix(in srgb, var(--team-color), #fff 12%));
  border-radius: 1px 1px 0 0;
}
.hgb-modal.is-open .hgb-dist__bar { height: var(--v); }
.hgb-dist__bar--a { --team-color: var(--hgb-team-a); }
.hgb-dist__bar--b { --team-color: var(--hgb-team-b); border-radius: 0 0 1px 1px; background: linear-gradient(to bottom, color-mix(in srgb, var(--team-color), #000 10%), color-mix(in srgb, var(--team-color), #fff 12%)); }
.hgb-dist__bar::after { content: ''; position: absolute; left: -5px; right: -5px; top: -1px; height: 2px; background: color-mix(in srgb, var(--team-color), #fff 25%); box-shadow: 0 0 12px color-mix(in srgb, var(--team-color), transparent 40%); }
.hgb-dist__bar--b::after { top: auto; bottom: -1px; }
.hgb-dist__bar--max { box-shadow: 0 -10px 40px -8px var(--team-color); }
.hgb-dist__bar--b.hgb-dist__bar--max { box-shadow: 0 10px 40px -8px var(--team-color); }
.hgb-dist__cap { position: absolute; left: 50%; transform: translateX(-50%); font: 600 12px/1 var(--hgb-font-mono); color: var(--team-color); font-variant-numeric: tabular-nums; white-space: nowrap; letter-spacing: 0.02em; opacity: 0; transition: opacity 300ms ease calc(var(--delay, 0ms) + 500ms); }
.hgb-modal.is-open .hgb-dist__cap { opacity: 1; }
.hgb-dist__bar--a .hgb-dist__cap { bottom: calc(100% + 8px); }
.hgb-dist__bar--b .hgb-dist__cap { top: calc(100% + 8px); }
.hgb-dist__bar--max .hgb-dist__cap::before { content: '★ '; font-family: var(--hgb-font-body); font-size: 10px; opacity: 0.85; }
.hgb-dist__axis { display: flex; align-items: center; justify-content: center; font: 500 11px/1 var(--hgb-font-mono); color: var(--hgb-text-2); letter-spacing: 0.12em; text-transform: uppercase; }

/* telemetry row */
.hgb-tel { position: relative; z-index: 2; display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid var(--hgb-border); background: linear-gradient(180deg, transparent, rgba(0,0,0,0.25)); }
.hgb-tel__cell { padding: 18px 22px 22px; display: flex; flex-direction: column; gap: 8px; border-right: 1px solid var(--hgb-border); position: relative; }
.hgb-tel__cell:last-child { border-right: none; }
.hgb-tel__cell::before { content: ''; position: absolute; top: 16px; left: 22px; width: 4px; height: 4px; background: var(--hgb-text-4); border-radius: 50%; }
.hgb-tel__label { font: 500 10px/1 var(--hgb-font-mono); color: var(--hgb-text-3); letter-spacing: 0.14em; text-transform: uppercase; padding-left: 12px; }
.hgb-tel__val { padding-left: 12px; }
.hgb-tel__big { font: 500 24px/1 var(--hgb-font-display); color: var(--hgb-text); font-variant-numeric: tabular-nums; }
.hgb-tel__unit { font: 400 11px/1 var(--hgb-font-body); color: var(--hgb-text-3); }

/* modal entry animations */
.hgb-modal.is-open .hgb-util,
.hgb-modal.is-open .hgb-matchup,
.hgb-modal.is-open .hgb-tracker,
.hgb-modal.is-open .hgb-wp,
.hgb-modal.is-open .hgb-dist,
.hgb-modal.is-open .hgb-tel { animation: hgb-rise 480ms cubic-bezier(.2,.8,.2,1) backwards; }
.hgb-modal.is-open .hgb-util    { animation-delay: 120ms; }
.hgb-modal.is-open .hgb-matchup { animation-delay: 180ms; }
.hgb-modal.is-open .hgb-tracker { animation-delay: 220ms; }
.hgb-modal.is-open .hgb-wp      { animation-delay: 260ms; }
.hgb-modal.is-open .hgb-dist    { animation-delay: 320ms; }
.hgb-modal.is-open .hgb-tel     { animation-delay: 400ms; }
@keyframes hgb-rise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

/* ── Responsive ── */
@media (max-width: 700px) {
  .page-head { padding: 24px 16px 20px; }
  .page-head__h1 { font-size: 26px; }
  .content { padding: 24px 16px 60px; }
  .series-grid, .pending-strip { grid-template-columns: 1fr; gap: 12px; }
  .topbar { padding: 0 16px; }
  .hgb-card__pct { font-size: 28px; }
  .hgb-card__pct small { font-size: 15px; }
  .hgb-matchup { gap: 14px; padding: 14px 18px 22px; }
  .hgb-team__logo { width: 44px; height: 44px; }
  .hgb-team__abbr { font-size: 24px; }
  .hgb-matchup__score-nums { font-size: 34px; }
  .hgb-wp__num { font-size: 64px; }
  .hgb-dist { padding: 24px 16px 16px; }
  .hgb-dist__bar { width: 40px; }
  .hgb-tracker { padding: 18px 16px 20px; }
  .hgb-tracker__grid { gap: 5px; }
  .hgb-tracker__meta { flex-direction: column; align-items: flex-start; gap: 10px; }
  .hgb-tel { grid-template-columns: 1fr 1fr; }
  .hgb-tel__cell:nth-child(2) { border-right: none; }
  .hgb-tel__cell:nth-child(-n+2) { border-bottom: 1px solid var(--hgb-border); }
  .hgb-util { padding: 18px 18px 12px; }
}
</style>
</head>
<body>

<div class="topbar">
  <a href="/" class="brand">HGB</a>
  <div class="topbar-right">
    <a href="/playoffs" class="topbar-link topbar-link--active">PLAYOFFS</a>
    <a href="/teams" class="topbar-link">TEAMS</a>
    <a href="/support" class="topbar-link topbar-link--support" aria-label="Support HockeyGameBot">
      <svg class="support-heart" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      <span>SUPPORT</span>
    </a>
  </div>
</div>

<div class="page-head">
  <div class="page-head__title">
    <span class="page-head__eyebrow">HockeyGameBot · Model Projections</span>
    <h1 class="page-head__h1">2026 Stanley Cup Playoffs</h1>
  </div>
  <div class="page-head__meta">
    <small>Round 1 · Monte Carlo, 10,000 sims each</small>
    <strong>Blended model</strong>
  </div>
</div>

<div class="content">
  {([['East', eastSeries], ['West', westSeries]] as const).map(([label, series]) => (
    <div class="conf-block">
      <div class="section-label">{label}ern Conference · Round 1</div>
      <div class="series-grid">
        {series.filter(s => !(s as any).tbd).map(s => {
          const segs = buildCardSegs(s);
          const ml = mostLikely(s);
          const pctA = winPct(s.a.dist);
          const pctB = winPct(s.b.dist);
          return (
            <button
              class="hgb-card"
              data-id={s.id}
              style={`--hgb-team-a: ${s.a.color}; --hgb-team-b: ${s.b.color};`}
              aria-label={`${s.a.abbr} vs ${s.b.abbr} — click to open series details`}
            >
              <header class="hgb-card__meta">
                <span class="hgb-mini-badge">{s.miniBadge}</span>
              </header>

              <div class="hgb-card__teams">
                <div class="hgb-card__team" style={`--team-color: ${s.a.color}`}>
                  <img src={`https://assets.nhle.com/logos/nhl/svg/${s.a.abbr}_light.svg`} alt={s.a.abbr} class="hgb-card__logo" loading="lazy" />
                  <div class="hgb-card__ids">
                    <span class="hgb-card__seed">{s.a.seed}</span>
                    <span class="hgb-card__abbr">{s.a.abbr}</span>
                  </div>
                  <span class="hgb-card__pct" style="margin-left: auto">{pctA}<small>%</small></span>
                </div>
                <span class="hgb-card__vs">vs</span>
                <div class="hgb-card__team hgb-card__team--b" style={`--team-color: ${s.b.color}`}>
                  <img src={`https://assets.nhle.com/logos/nhl/svg/${s.b.abbr}_light.svg`} alt={s.b.abbr} class="hgb-card__logo" loading="lazy" />
                  <div class="hgb-card__ids">
                    <span class="hgb-card__seed">{s.b.seed}</span>
                    <span class="hgb-card__abbr">{s.b.abbr}</span>
                  </div>
                  <span class="hgb-card__pct" style="margin-right: auto">{pctB}<small>%</small></span>
                </div>
              </div>

              <div class="hgb-card__bar">
                {segs.map(seg => (
                  <span
                    class={`hgb-card__seg${seg.isSmall ? ' hgb-card__seg--small' : ''}`}
                    style={`--c: ${seg.c}; --w: ${seg.w}`}
                    data-boundary={seg.boundary ? 'true' : undefined}
                    title={`${seg.label} · ${seg.w}%`}
                  >
                    <span class="hgb-card__seg-val">{seg.w}</span>
                  </span>
                ))}
              </div>

              <footer class="hgb-card__foot">
                <span class="hgb-card__foot-label">Most Likely</span>
                <span class="hgb-card__foot-val">
                  <strong>{ml?.label.split(' in ')[0]}</strong> in {ml?.label.split(' in ')[1]} · {ml?.v}%
                </span>
              </footer>
            </button>
          );
        })}
      </div>

      {series.some(s => (s as any).tbd) && (
        <div class="pending-strip">
          {series.filter(s => (s as any).tbd).map(s => (
            <div class="series-tbd">
              <span class="series-tbd-teams">{s.a.abbr}</span>
              <span class="series-tbd-sep">vs</span>
              <span class="series-tbd-teams">{s.b.abbr}</span>
              <span class="series-tbd-label">Prediction Pending</span>
            </div>
          ))}
        </div>
      )}
    </div>
  ))}
</div>

<!-- ── Shared modal (populated via JS on card click) ── -->
<div class="hgb-modal" id="hgb-modal" role="dialog" aria-modal="true" aria-label="Series details">
  <div class="hgb-modal__scrim" data-hgb-close></div>
  <section class="hgb-modal__sheet">
    <button class="hgb-modal__handle" data-hgb-close aria-label="Close"></button>

    <header class="hgb-util">
      <div class="hgb-util__group">
        <span class="hgb-badge">Projection</span>
        <span class="hgb-mono">10,000 sims · blended model</span>
      </div>
      <div class="hgb-util__group">
        <span class="hgb-mono" data-field="round-label"></span>
        <button class="hgb-modal__close" data-hgb-close aria-label="Close modal">
          <svg viewBox="0 0 14 14" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 3L11 11M11 3L3 11"/></svg>
        </button>
      </div>
    </header>

    <div class="hgb-matchup">
      <div class="hgb-team" style="--team-color: var(--hgb-team-a)">
        <img src="" alt="" class="hgb-team__logo" data-field="logo-a">
        <div class="hgb-team__meta">
          <span class="hgb-team__seed" data-field="seed-a"></span>
          <span class="hgb-team__abbr" data-field="abbr-a"></span>
          <span class="hgb-team__name" data-field="name-a"></span>
        </div>
      </div>

      <div class="hgb-matchup__center">
        <span class="hgb-matchup__vs" id="matchup-vs">VS</span>
        <div class="hgb-matchup__score" id="matchup-score" hidden>
          <div class="hgb-matchup__score-nums">
            <span class="hgb-matchup__score-a" data-field="score-a">0</span>
            <span class="hgb-matchup__score-sep">–</span>
            <span class="hgb-matchup__score-b" data-field="score-b">0</span>
          </div>
          <span class="hgb-matchup__status" data-field="series-status"></span>
        </div>
      </div>

      <div class="hgb-team hgb-team--b" style="--team-color: var(--hgb-team-b)">
        <img src="" alt="" class="hgb-team__logo" data-field="logo-b">
        <div class="hgb-team__meta">
          <span class="hgb-team__seed" data-field="seed-b"></span>
          <span class="hgb-team__abbr" data-field="abbr-b"></span>
          <span class="hgb-team__name" data-field="name-b"></span>
        </div>
      </div>
    </div>

    <!-- series tracker — shown only when series has started -->
    <div class="hgb-tracker" id="hgb-tracker" hidden>
      <div class="hgb-tracker__grid" id="hgb-tracker-grid"></div>
      <div class="hgb-tracker__meta">
        <div class="hgb-tracker__next" id="hgb-tracker-next">
          <span class="hgb-tracker__next-label">Next</span>
          <span class="hgb-tracker__next-val" data-field="next-game"></span>
        </div>
        <div class="hgb-tracker__advance">
          <span class="hgb-tracker__adv-item" style="--team-color: var(--hgb-team-a)">
            <span class="hgb-tracker__adv-num" data-field="advance-a"></span>
            <span data-field="advance-label-a"></span>
          </span>
          <span class="hgb-tracker__adv-item" style="--team-color: var(--hgb-team-b)">
            <span class="hgb-tracker__adv-num" data-field="advance-b"></span>
            <span data-field="advance-label-b"></span>
          </span>
        </div>
      </div>
    </div>

    <div class="hgb-wp">
      <span class="hgb-wp__label" data-field="wp-label">Series Win Probability</span>
      <div class="hgb-wp__row">
        <div class="hgb-wp__side" style="--team-color: var(--hgb-team-a)">
          <span class="hgb-wp__num" data-field="wp-a"></span>
          <span class="hgb-wp__pct">%</span>
        </div>
        <div class="hgb-wp__side" style="--team-color: var(--hgb-team-b)">
          <span class="hgb-wp__num" data-field="wp-b"></span>
          <span class="hgb-wp__pct">%</span>
        </div>
      </div>
    </div>

    <div class="hgb-dist">
      <div class="hgb-dist__head">
        <h3 class="hgb-dist__h">Series Length Distribution</h3>
      </div>
      <div class="hgb-dist__body">
        <div class="hgb-dist__y">
          <span id="y-top"></span><span></span><span></span><span></span>
          <span class="hgb-dist__y-0">0</span>
          <span></span><span></span><span></span><span id="y-bot"></span>
        </div>
        <div class="hgb-dist__plot" id="hgb-plot"></div>
      </div>
    </div>

    <div class="hgb-tel">
      <div class="hgb-tel__cell">
        <span class="hgb-tel__label">Most Likely</span>
        <div class="hgb-tel__val"><span class="hgb-tel__big" data-field="most-likely"></span></div>
      </div>
      <div class="hgb-tel__cell">
        <span class="hgb-tel__label" data-field="tel-2-label">Sweep Odds</span>
        <div class="hgb-tel__val"><span class="hgb-tel__big" data-field="tel-2-val"></span><span class="hgb-tel__unit">%</span></div>
      </div>
      <div class="hgb-tel__cell">
        <span class="hgb-tel__label">Goes Seven</span>
        <div class="hgb-tel__val"><span class="hgb-tel__big" data-field="goes-seven"></span><span class="hgb-tel__unit">%</span></div>
      </div>
      <div class="hgb-tel__cell">
        <span class="hgb-tel__label" data-field="tel-4-label">Expected Length</span>
        <div class="hgb-tel__val"><span class="hgb-tel__big" data-field="exp-length"></span><span class="hgb-tel__unit">games</span></div>
      </div>
    </div>
  </section>
</div>

<!-- Series data for client-side modal population -->
<script id="hgb-series-json" type="application/json" set:html={JSON.stringify(SERIES)}></script>

<script>
// ── Data ──────────────────────────────────────────────────────────────────────
const SERIES = JSON.parse(document.getElementById('hgb-series-json')!.textContent!);

// ── Helpers ───────────────────────────────────────────────────────────────────
const logoFor = (abbr: string) => `https://assets.nhle.com/logos/nhl/svg/${abbr}_light.svg`;
const winTotal = (dist: number[]) => dist.reduce((s: number, v: number) => s + v, 0);
const darker  = (hex: string, pct: number) => `color-mix(in srgb, ${hex}, #000 ${pct}%)`;
const lighter = (hex: string, pct: number) => `color-mix(in srgb, ${hex}, #fff ${pct}%)`;

function findMax(s: any) {
  const all = [
    ...s.a.dist.map((v: number, i: number) => ({ team: 'a', game: i + 4, v })),
    ...s.b.dist.map((v: number, i: number) => ({ team: 'b', game: i + 4, v })),
  ];
  return all.filter((x: any) => x.v > 0).reduce((m: any, x: any) => x.v > m.v ? x : m);
}

function seriesState(s: any) {
  const wA = s.games.filter((g: any) => g === s.a.abbr).length;
  const wB = s.games.filter((g: any) => g === s.b.abbr).length;
  const played = wA + wB;
  const hasStarted = played > 0;
  let leader = 'tied', status = 'Series tied';
  if (wA > wB) { leader = 'a'; status = `${s.a.abbr} leads`; }
  else if (wB > wA) { leader = 'b'; status = `${s.b.abbr} leads`; }
  if (wA === 4 || wB === 4) {
    status = `${wA === 4 ? s.a.abbr : s.b.abbr} wins series`;
  }
  return { wA, wB, played, hasStarted, leader, status };
}

// ── Modal population ──────────────────────────────────────────────────────────
const modal = document.getElementById('hgb-modal')!;
const plot = document.getElementById('hgb-plot')!;
const tracker = document.getElementById('hgb-tracker')!;
const trackerGrid = document.getElementById('hgb-tracker-grid')!;
const matchupVs = document.getElementById('matchup-vs')!;
const matchupScore = document.getElementById('matchup-score')!;

function setField(name: string, val: string) {
  document.querySelectorAll(`[data-field="${name}"]`).forEach(el => {
    if ((el as HTMLImageElement).tagName === 'IMG') (el as HTMLImageElement).src = val;
    else el.textContent = val;
  });
}

function renderTracker(s: any) {
  const state = seriesState(s);
  return [0,1,2,3,4,5,6].map(i => {
    const winner = s.games[i];
    const g = i + 1;
    if (winner) {
      const team = winner === s.a.abbr ? s.a : s.b;
      return `<div class="hgb-tracker__game hgb-tracker__game--played" style="--c: ${team.color}">
        <span class="hgb-tracker__winner">${winner}</span>
        <span class="hgb-tracker__num">G${g}</span>
      </div>`;
    } else if (i === state.played) {
      return `<div class="hgb-tracker__game hgb-tracker__game--next"><span class="hgb-tracker__num">G${g}</span></div>`;
    }
    return `<div class="hgb-tracker__game"><span class="hgb-tracker__num">G${g}</span></div>`;
  }).join('');
}

function openModal(id: string) {
  const s = SERIES.find((x: any) => x.id === id);
  if (!s || s.tbd) return;

  modal.style.setProperty('--hgb-team-a', s.a.color);
  modal.style.setProperty('--hgb-team-b', s.b.color);

  const winA = winTotal(s.a.dist), winB = winTotal(s.b.dist);
  const max = findMax(s);
  const mlTeam = max.team === 'a' ? s.a : s.b;
  const state = seriesState(s);

  // header
  setField('round-label', s.miniBadge.toUpperCase());
  setField('logo-a', logoFor(s.a.abbr));
  setField('logo-b', logoFor(s.b.abbr));
  setField('abbr-a', s.a.abbr); setField('abbr-b', s.b.abbr);
  setField('name-a', s.a.name); setField('name-b', s.b.name);
  setField('seed-a', s.a.seedFull); setField('seed-b', s.b.seedFull);

  // VS or score
  if (state.hasStarted) {
    matchupVs.hidden = true;
    matchupScore.hidden = false;
    const scoreA = document.querySelector('[data-field="score-a"]')!;
    const scoreB = document.querySelector('[data-field="score-b"]')!;
    const statusEl = document.querySelector('[data-field="series-status"]')!;
    scoreA.textContent = String(state.wA);
    scoreB.textContent = String(state.wB);
    scoreA.classList.toggle('is-lead', state.leader === 'a');
    scoreB.classList.toggle('is-lead', state.leader === 'b');
    statusEl.textContent = state.status;
    statusEl.classList.toggle('is-lead-a', state.leader === 'a');
    statusEl.classList.toggle('is-lead-b', state.leader === 'b');
  } else {
    matchupVs.hidden = false;
    matchupScore.hidden = true;
  }

  // tracker
  if (state.hasStarted) {
    tracker.hidden = false;
    trackerGrid.innerHTML = renderTracker(s);
    const nextDiv = document.getElementById('hgb-tracker-next')!;
    nextDiv.hidden = !s.nextGame;
    setField('next-game', s.nextGame || '');
    setField('advance-a', String(4 - state.wA));
    setField('advance-b', String(4 - state.wB));
    setField('advance-label-a', `${s.a.abbr} to advance`);
    setField('advance-label-b', `${s.b.abbr} to advance`);
  } else {
    tracker.hidden = true;
  }

  // WP
  setField('wp-label', state.hasStarted ? 'Series Win Probability · Current' : 'Series Win Probability');
  setField('wp-a', String(winA));
  setField('wp-b', String(winB));

  // distribution chart — auto-scale
  const scale = Math.max(20, ...s.a.dist, ...s.b.dist);
  // fill y-axis labels (top to bottom: scale, ¾, ½, ¼, 0, ¼, ½, ¾, scale)
  const yLabels = modal.querySelectorAll<HTMLElement>('.hgb-dist__y span');
  [scale, Math.round(scale*0.75), Math.round(scale*0.5), Math.round(scale*0.25),
   0,
   Math.round(scale*0.25), Math.round(scale*0.5), Math.round(scale*0.75), scale
  ].forEach((v, i) => {
    const el = yLabels[i];
    if (!el) return;
    // replace text node only, preserve ::after pseudo content
    el.childNodes.forEach(n => { if (n.nodeType === 3) n.textContent = v === 0 ? '' : String(v); });
    if (!el.childNodes.length) el.textContent = v === 0 ? '' : String(v);
  });

  const HALF_PX = 126; // (280px plot height − 28px axis) / 2
  let html = '';
  for (let g = 4; g <= 7; g++) {
    const i = g - 4;
    const va = s.a.dist[i], vb = s.b.dist[i];
    const pxA = va > 0 ? Math.max(4, Math.round((va / scale) * HALF_PX)) : 0;
    const pxB = vb > 0 ? Math.max(4, Math.round((vb / scale) * HALF_PX)) : 0;
    const dA = 60 + i * 80, dB = 80 + i * 80;
    const maxA = max.team === 'a' && max.game === g ? ' hgb-dist__bar--max' : '';
    const maxB = max.team === 'b' && max.game === g ? ' hgb-dist__bar--max' : '';
    const barA = va > 0
      ? `<div class="hgb-dist__bar hgb-dist__bar--a${maxA}" style="--v: ${pxA}px; --delay: ${dA}ms"><span class="hgb-dist__cap" style="--delay: ${dA}ms">${va}%</span></div>`
      : '';
    const barB = vb > 0
      ? `<div class="hgb-dist__bar hgb-dist__bar--b${maxB}" style="--v: ${pxB}px; --delay: ${dB}ms"><span class="hgb-dist__cap" style="--delay: ${dB}ms">${vb}%</span></div>`
      : '';
    html += `<div class="hgb-dist__col">
      <div class="hgb-dist__half hgb-dist__half--top">${barA}</div>
      <div class="hgb-dist__axis">G${g}</div>
      <div class="hgb-dist__half hgb-dist__half--bot">${barB}</div>
    </div>`;
  }

  // telemetry
  setField('most-likely', `${mlTeam.abbr} in ${max.game}`);
  if (!state.hasStarted) {
    setField('tel-2-label', 'Sweep Odds');
    setField('tel-2-val', String(s.a.dist[0] + s.b.dist[0]));
  } else {
    const leaderTeam = state.leader === 'a' ? s.a : s.b;
    setField('tel-2-label', `${leaderTeam.abbr} Sweep`);
    setField('tel-2-val', String(leaderTeam.dist[0]));
  }
  setField('goes-seven', String(s.a.dist[3] + s.b.dist[3]));
  const total = winA + winB;
  const expLen = total > 0
    ? ([4,5,6,7].reduce((sum: number, g: number, i: number) => sum + g * (s.a.dist[i] + s.b.dist[i]), 0) / total).toFixed(1)
    : '—';
  setField('exp-length', expLen);
  setField('tel-4-label', state.hasStarted ? 'Exp. Remaining' : 'Expected Length');

  // animate — re-trigger if already open
  // Insert bars AFTER removing is-open so transitions fire from height:0 on new elements
  const wasOpen = modal.classList.contains('is-open');
  if (wasOpen) { modal.classList.remove('is-open'); void modal.offsetWidth; }
  plot.innerHTML = html;
  // Force a reflow so the browser registers height:0 before adding is-open
  void plot.offsetWidth;
  modal.classList.add('is-open', 'is-animating');
  setTimeout(() => modal.classList.remove('is-animating'), 1400);

  // scroll to top of sheet
  modal.querySelector('.hgb-modal__sheet')!.scrollTop = 0;

  // deep-link
  history.pushState({ series: id }, '', `?series=${id}`);
}

function closeModal() {
  modal.classList.remove('is-open', 'is-animating');
  history.pushState({}, '', location.pathname);
}

// ── Focus trap ────────────────────────────────────────────────────────────────
function trapFocus(e: KeyboardEvent) {
  if (!modal.classList.contains('is-open') || e.key !== 'Tab') return;
  const focusable = Array.from(modal.querySelectorAll<HTMLElement>(
    'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
  )).filter(el => !el.hasAttribute('hidden') && el.offsetParent !== null);
  if (!focusable.length) return;
  const first = focusable[0], last = focusable[focusable.length - 1];
  if (e.shiftKey) {
    if (document.activeElement === first) { e.preventDefault(); last.focus(); }
  } else {
    if (document.activeElement === last) { e.preventDefault(); first.focus(); }
  }
}

// ── Wire up ───────────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLElement>('.hgb-card').forEach(card => {
  card.addEventListener('click', () => openModal(card.dataset.id!));
});
document.querySelectorAll('[data-hgb-close]').forEach(el => {
  el.addEventListener('click', closeModal);
});
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeModal();
  trapFocus(e);
});

// deep-link on load
const initId = new URLSearchParams(location.search).get('series');
if (initId) openModal(initId);

// back/forward
window.addEventListener('popstate', (e) => {
  if (e.state?.series) openModal(e.state.series);
  else closeModal();
});

// ── Live updates ──────────────────────────────────────────────────────────────
async function loadGameTimes() {
  const dates = ['2026-04-18', '2026-04-19', '2026-04-20', '2026-04-21'];
  for (const date of dates) {
    try {
      const res = await fetch(`https://api-web.nhle.com/v1/schedule/${date}`);
      if (!res.ok) continue;
      const data = await res.json();
      const games: any[] = data.gameWeek?.[0]?.games ?? [];
      for (const game of games) {
        if (game.gameType !== 3) continue;
        const away = game.awayTeam?.abbrev, home = game.homeTeam?.abbrev;
        if (!away || !home || !game.startTimeUTC) continue;
        const s = SERIES.find((x: any) =>
          (x.a.abbr === away || x.a.abbr === home) &&
          (x.b.abbr === away || x.b.abbr === home)
        );
        if (!s || s.nextGame) continue;
        const dt = new Date(game.startTimeUTC);
        const mon = dt.toLocaleDateString('en-US', { timeZone: 'America/New_York', month: 'short', day: 'numeric' });
        const time = dt.toLocaleTimeString('en-US', { timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit' });
        s.nextGame = `Game 1 · ${mon}, ${time} ET`;
      }
    } catch (_) {}
  }
}

async function loadSeriesStatus() {
  try {
    const res = await fetch('https://api-web.nhle.com/v1/playoff-series/carousel/20252026');
    if (!res.ok) return;
    const data = await res.json();
    const round1 = data.rounds?.find((r: any) => r.roundNumber === 1);
    if (!round1) return;
    for (const ser of round1.series) {
      const topAbbr = ser.topSeedTeam?.abbrev, botAbbr = ser.bottomSeedTeam?.abbrev;
      const topW = ser.topSeedTeam?.wins ?? 0, botW = ser.bottomSeedTeam?.wins ?? 0;
      if (!topAbbr || !botAbbr) continue;
      const s = SERIES.find((x: any) =>
        (x.a.abbr === topAbbr || x.a.abbr === botAbbr) &&
        (x.b.abbr === topAbbr || x.b.abbr === botAbbr)
      );
      if (!s) continue;
      // Update games array in place so modal gets fresh data
      const played = topW + botW;
      if (played > 0) {
        // Reconstruct games array (we only know win counts, not per-game winners)
        const topGames = Array(topW).fill(topAbbr);
        const botGames = Array(botW).fill(botAbbr);
        // Interleave — approximate; actual order comes from API if available
        for (let i = 0; i < played; i++) {
          s.games[i] = ser.games?.[i]?.gameOutcome?.winningTeamId
            ? (ser.games[i].homeTeam?.id === ser.games[i].gameOutcome?.winningTeamId
              ? ser.games[i].homeTeam?.abbrev
              : ser.games[i].awayTeam?.abbrev)
            : (i < topW ? topAbbr : botAbbr);
        }
      }
    }
  } catch (_) {}
}

loadGameTimes();
loadSeriesStatus();
</script>

