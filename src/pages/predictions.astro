---
/**
 * Game Predictions — daily model win-probability slate (hgb-spar-wins).
 *
 * DESIGN PREVIEW / MOCK DATA. This page renders a hardcoded slate so the
 * owner can preview the game-day surface before the API is wired. The real
 * product will fetch GET ${API_BASE}/v1/predictions?date=YYYY-MM-DD (the
 * predict_wins.py `slate` output — shape mirrored in MOCK below) client-side
 * on mount, exactly like /projections.
 *
 * Date navigation: the page is output:'static', so `?date=` cannot be read
 * per-request at build time. The prev/next arrows are plain links that adjust
 * the query param; a tiny inline enhancement script reads the param on load,
 * updates the visible date header, and recomputes the arrow hrefs so the
 * mechanism feels real. The mock games array is the same regardless of date.
 *
 * Conventions matched:
 *   - StatsLayout shell + <StatsMasthead slot="mast">, same as /projections.
 *   - "design preview · mock data" badge pinned top-right of the hero card.
 *   - Canonical light team logos via /logos/nhl/{abbr}_light.svg.
 *   - pickTeamColor() for per-team accent stripes.
 *   - Brand red (var(--red), #E8002D) for the featured favorite win %.
 */
import StatsLayout from '../layouts/StatsLayout.astro';
import StatsMasthead from '../components/StatsMasthead.astro';
import { pickTeamColor } from '../lib/team-colors';

// ── Mock slate (predict_wins.py `slate` output shape) ─────────────────────
const DEFAULT_DATE = '2026-10-15';

const MOCK = {
  product: 'slate',
  date: DEFAULT_DATE,
  model: { name: 'hgb-spar-wins', version: 'v1' },
  games: [
    { game_id: '2026020120', start_time_utc: '2026-10-15T23:00:00Z', away: 'CAR', home: 'BUF', away_win_prob: 0.61, home_win_prob: 0.39, b2b_away: false, b2b_home: true,  away_goalie: 'F. Andersen',  home_goalie: 'U. Luukkonen', state: 'pre' },
    { game_id: '2026020121', start_time_utc: '2026-10-15T23:00:00Z', away: 'TOR', home: 'MTL', away_win_prob: 0.66, home_win_prob: 0.34, b2b_away: false, b2b_home: false, away_goalie: 'J. Woll',       home_goalie: 'S. Montembeault', state: 'pre' },
    { game_id: '2026020122', start_time_utc: '2026-10-15T23:00:00Z', away: 'NYR', home: 'NJD', away_win_prob: 0.52, home_win_prob: 0.48, b2b_away: false, b2b_home: false, away_goalie: 'I. Shesterkin', home_goalie: 'J. Markstrom',   state: 'pre' },
    { game_id: '2026020123', start_time_utc: '2026-10-15T23:30:00Z', away: 'TBL', home: 'FLA', away_win_prob: 0.44, home_win_prob: 0.56, b2b_away: true,  b2b_home: false, away_goalie: 'A. Vasilevskiy',home_goalie: 'S. Bobrovsky',  state: 'pre' },
    { game_id: '2026020124', start_time_utc: '2026-10-15T23:30:00Z', away: 'BOS', home: 'PIT', away_win_prob: 0.63, home_win_prob: 0.37, b2b_away: false, b2b_home: false, away_goalie: 'J. Swayman',   home_goalie: 'T. Jarry',      state: 'pre' },
    { game_id: '2026020125', start_time_utc: '2026-10-16T00:00:00Z', away: 'WSH', home: 'CBJ', away_win_prob: 0.68, home_win_prob: 0.32, b2b_away: false, b2b_home: false, away_goalie: 'L. Thompson',  home_goalie: 'E. Merzlikins',  state: 'pre' },
    { game_id: '2026020126', start_time_utc: '2026-10-16T00:00:00Z', away: 'WPG', home: 'MIN', away_win_prob: 0.55, home_win_prob: 0.45, b2b_away: false, b2b_home: false, away_goalie: 'C. Hellebuyck', home_goalie: 'F. Gustavsson', state: 'pre' },
    { game_id: '2026020127', start_time_utc: '2026-10-16T00:30:00Z', away: 'COL', home: 'DAL', away_win_prob: 0.49, home_win_prob: 0.51, b2b_away: false, b2b_home: false, away_goalie: 'M. Blackwood',  home_goalie: 'J. Oettinger',  state: 'pre' },
    { game_id: '2026020128', start_time_utc: '2026-10-16T00:30:00Z', away: 'NSH', home: 'STL', away_win_prob: 0.47, home_win_prob: 0.53, b2b_away: false, b2b_home: false, away_goalie: 'J. Saros',     home_goalie: 'J. Binnington', state: 'pre' },
    { game_id: '2026020129', start_time_utc: '2026-10-16T01:00:00Z', away: 'EDM', home: 'CGY', away_win_prob: 0.58, home_win_prob: 0.42, b2b_away: false, b2b_home: false, away_goalie: 'S. Skinner',   home_goalie: 'D. Wolf',       state: 'pre' },
    { game_id: '2026020130', start_time_utc: '2026-10-16T02:00:00Z', away: 'VGK', home: 'SJS', away_win_prob: 0.72, home_win_prob: 0.28, b2b_away: false, b2b_home: true,  away_goalie: 'A. Hill',      home_goalie: 'M. Blackwood',  state: 'pre' },
    { game_id: '2026020131', start_time_utc: '2026-10-16T02:30:00Z', away: 'LAK', home: 'SEA', away_win_prob: 0.51, home_win_prob: 0.49, b2b_away: false, b2b_home: false, away_goalie: 'D. Kuemper',   home_goalie: 'J. Daccord',    state: 'pre' },
  ],
};

// ── Derived view model ────────────────────────────────────────────────────
const TOSS_UP_BAND = 0.04; // |p - 0.5| within this => toss-up

const fmtTime = (iso: string) =>
  new Date(iso).toLocaleTimeString('en-US', {
    timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit',
  });

const games = MOCK.games.map((g) => {
  const homeFav = g.home_win_prob >= g.away_win_prob;
  const favProb = Math.max(g.home_win_prob, g.away_win_prob);
  const tossUp = Math.abs(g.home_win_prob - 0.5) <= TOSS_UP_BAND;
  return {
    ...g,
    startEt: fmtTime(g.start_time_utc),
    homeFav,
    favAbbr: homeFav ? g.home : g.away,
    favProb,
    favPct: Math.round(favProb * 100),
    dogPct: Math.round((1 - favProb) * 100),
    awayPct: Math.round(g.away_win_prob * 100),
    homePct: Math.round(g.home_win_prob * 100),
    tossUp,
    awayColor: pickTeamColor(g.away),
    homeColor: pickTeamColor(g.home),
  };
});

const gameCount = games.length;

// Human date header for the default date, computed at build time. The inline
// script re-derives this from `?date=` on the client.
const dateLabel = new Date(`${DEFAULT_DATE}T12:00:00Z`).toLocaleDateString('en-US', {
  timeZone: 'UTC', weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
});
---
<StatsLayout
  title="Game Predictions — HGB Model — HockeyGameBot"
  description="Model win probability for every game on today's NHL slate — favorite, both teams' odds, projected starters, and back-to-back flags from the hgb-spar-wins model."
  ogImage="/og/default.png"
  currentPath={Astro.url.pathname}
>

<StatsMasthead slot="mast" eyebrow="HGB Model · Game Predictions" ghost="PICKS">
  <Fragment slot="headline">Game <em>predictions.</em></Fragment>
  <Fragment slot="lede">Model win probability for every game on the slate.</Fragment>
  <span id="pred-badge" class="pred-badge">design preview · mock data</span>
</StatsMasthead>

<main class="wrap">

  <!-- ── DATE NAVIGATION ── -->
  <nav class="date-nav" aria-label="Slate date">
    <a class="date-arrow" id="date-prev" href={`/predictions?date=${DEFAULT_DATE}`} aria-label="Previous day" rel="prev">‹</a>
    <div class="date-center">
      <div class="date-label" id="date-label">{dateLabel}</div>
      <div class="date-count"><span id="date-count">{gameCount}</span> games</div>
    </div>
    <a class="date-arrow" id="date-next" href={`/predictions?date=${DEFAULT_DATE}`} aria-label="Next day" rel="next">›</a>
  </nav>

  <!-- ── GAMES GRID ── -->
  {gameCount === 0 ? (
    <section class="empty-state">
      <div class="empty-mark">—</div>
      <h2 class="empty-title">No games scheduled</h2>
      <p class="empty-sub">There are no NHL games on this date. Use the arrows above to jump to another day.</p>
    </section>
  ) : (
    <section class="games-grid">
      {games.map((g) => (
        <article
          class:list={["game-card", { 'is-tossup': g.tossUp }]}
          style={`--away-color:${g.awayColor}; --home-color:${g.homeColor};`}
        >
          <div class="card-accent"><span class="acc-away"></span><span class="acc-home"></span></div>

          <div class="card-top">
            <span class="card-time">{g.startEt} ET</span>
            <span class="card-state">{g.tossUp ? 'Toss-up' : 'Pre'}</span>
          </div>

          <div class="matchup">
            {/* AWAY */}
            <div class:list={["team", "team-away", { fav: !g.homeFav && !g.tossUp }]}>
              <img class="team-logo-img" src={`/logos/nhl/${g.away}_light.svg`} width="40" height="40" alt={`${g.away} logo`} loading="lazy" />
              <div class="team-abbr">
                {g.away}
                {g.b2b_away && <span class="b2b-tag" title="Playing a back-to-back">B2B</span>}
              </div>
              <div class="team-pct">{g.awayPct}<span class="pct-sign">%</span></div>
            </div>

            <div class="at-sep">@</div>

            {/* HOME */}
            <div class:list={["team", "team-home", { fav: g.homeFav && !g.tossUp }]}>
              <img class="team-logo-img" src={`/logos/nhl/${g.home}_light.svg`} width="40" height="40" alt={`${g.home} logo`} loading="lazy" />
              <div class="team-abbr">
                {g.home}
                {g.b2b_home && <span class="b2b-tag" title="Playing a back-to-back">B2B</span>}
              </div>
              <div class="team-pct">{g.homePct}<span class="pct-sign">%</span></div>
            </div>
          </div>

          {/* SPLIT BAR */}
          <div class="split-bar" role="img" aria-label={`${g.away} ${g.awayPct}% to ${g.home} ${g.homePct}%`}>
            <span class="split-away" style={`width:${g.awayPct}%`}></span>
            <span class="split-home" style={`width:${g.homePct}%`}></span>
          </div>

          {/* PREDICTION — the big number */}
          <div class="prediction">
            {g.tossUp ? (
              <div class="pred-tossup">
                <span class="pred-tossup-num">50<span class="pred-sign">/</span>50</span>
                <span class="pred-label">Coin flip — no clear edge</span>
              </div>
            ) : (
              <div class="pred-fav">
                <span class="pred-big">{g.favPct}<span class="pred-sign">%</span></span>
                <span class="pred-label"><strong>{g.favAbbr}</strong> to win</span>
              </div>
            )}
          </div>

          {/* GOALIES */}
          <div class="goalies">
            <span class="goalie"><span class="gm">◇</span>{g.away_goalie}</span>
            <span class="goalie goalie-home"><span class="gm">◇</span>{g.home_goalie}</span>
          </div>
        </article>
      ))}
    </section>
  )}

  <p class="foot-note">
    <strong>Win %</strong> is the model's probability that each team wins the game — favorite highlighted.
    <strong>B2B</strong> flags a team playing the second half of a back-to-back. Projected starters are
    subject to change on game day.
  </p>

</main>

</StatsLayout>

{/* Progressive enhancement: reflect ?date= in the header + arrow links.
    Mock data is unchanged across dates; this only wires the navigation UX. */}
<script is:inline>
  (function () {
    var DEFAULT = '2026-10-15';
    function parseISO(s) {
      var m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(s || '');
      if (!m) return null;
      var d = new Date(Date.UTC(+m[1], +m[2] - 1, +m[3], 12, 0, 0));
      return isNaN(d.getTime()) ? null : d;
    }
    function toISO(d) {
      return d.getUTCFullYear() + '-' +
        String(d.getUTCMonth() + 1).padStart(2, '0') + '-' +
        String(d.getUTCDate()).padStart(2, '0');
    }
    var params = new URLSearchParams(window.location.search);
    var iso = params.get('date');
    var base = parseISO(iso) || parseISO(DEFAULT);

    var labelEl = document.getElementById('date-label');
    if (labelEl) {
      labelEl.textContent = base.toLocaleDateString('en-US', {
        timeZone: 'UTC', weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
      });
    }
    var prev = new Date(base); prev.setUTCDate(prev.getUTCDate() - 1);
    var next = new Date(base); next.setUTCDate(next.getUTCDate() + 1);
    var prevEl = document.getElementById('date-prev');
    var nextEl = document.getElementById('date-next');
    if (prevEl) prevEl.setAttribute('href', '/predictions?date=' + toISO(prev));
    if (nextEl) nextEl.setAttribute('href', '/predictions?date=' + toISO(next));
  })();
</script>

<style is:global>
  /* ── Status badge (mock preview) — pinned top-right of hero card ── */
  .pred-badge {
    display: inline-block;
    font-family: var(--body); font-weight: 700; font-size: 11px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--red);
    border: 1px solid var(--red); border-radius: 999px; padding: 3px 10px;
  }
  .mast-card:has(#pred-badge) { position: relative; }
  #pred-badge { position: absolute; top: 22px; right: 24px; }
  @media (max-width: 600px) {
    #pred-badge { position: static; margin-top: 12px; }
  }

  /* ── Date navigation ── */
  .date-nav {
    display: flex; align-items: center; justify-content: center; gap: 20px;
    margin: 0 0 24px;
    padding: 12px 16px;
    background: var(--surface); border: 1px solid var(--ink-10); border-radius: 14px;
  }
  .date-center { text-align: center; min-width: 240px; }
  .date-label {
    font-family: var(--display); font-weight: 800; font-size: clamp(19px, 3vw, 26px);
    text-transform: uppercase; letter-spacing: 0.01em; line-height: 1.05; color: var(--ink);
  }
  .date-count {
    font-family: var(--body); font-weight: 600; font-size: 11px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--ink-48); margin-top: 3px;
  }
  .date-count #date-count { font-family: var(--mono); font-weight: 500; color: var(--ink-72); }
  .date-arrow {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; flex-shrink: 0;
    font-family: var(--body); font-size: 26px; line-height: 1; font-weight: 400;
    color: var(--ink-56); text-decoration: none;
    background: var(--bg); border: 1px solid var(--ink-10); border-radius: 10px;
    transition: color .12s, border-color .12s, background .12s;
  }
  .date-arrow:hover { color: var(--ink); border-color: var(--ink-32); background: var(--surface); }

  /* ── Games grid ── */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  /* ── Game card ── */
  .game-card {
    position: relative; overflow: hidden;
    background: var(--surface); border: 1px solid var(--ink-10); border-radius: 14px;
    padding: 16px 18px 14px;
    display: flex; flex-direction: column;
    transition: border-color .12s, box-shadow .12s, transform .12s;
  }
  .game-card:hover { border-color: var(--ink-20); box-shadow: 0 6px 20px var(--ink-06); transform: translateY(-2px); }

  /* Two-tone team accent stripe across the top */
  .card-accent { position: absolute; top: 0; left: 0; right: 0; height: 4px; display: flex; }
  .card-accent .acc-away { flex: 1; background: var(--away-color); }
  .card-accent .acc-home { flex: 1; background: var(--home-color); }

  .card-top {
    display: flex; align-items: center; justify-content: space-between;
    margin: 2px 0 12px;
  }
  .card-time { font-family: var(--mono); font-size: 12px; font-weight: 500; color: var(--ink-72); }
  .card-state {
    font-family: var(--body); font-size: 9.5px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-32);
    border: 1px solid var(--ink-10); border-radius: 999px; padding: 2px 8px;
  }
  .is-tossup .card-state { color: var(--red); border-color: var(--red); }

  /* Matchup row: away | @ | home */
  .matchup {
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: start;
    gap: 8px; margin-bottom: 12px;
  }
  .team { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 4px; }
  .team-logo-img { width: 40px; height: 40px; object-fit: contain; }
  .team-abbr {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--display); font-weight: 700; font-size: 17px; letter-spacing: 0.01em;
    text-transform: uppercase; color: var(--ink);
  }
  .team-pct { font-family: var(--mono); font-weight: 500; font-size: 15px; color: var(--ink-48); }
  .team-pct .pct-sign { font-size: 11px; color: var(--ink-32); margin-left: 1px; }
  /* Favorite side gets a stronger read */
  .team.fav .team-abbr { color: var(--ink); }
  .team.fav .team-pct { color: var(--ink-86); font-weight: 500; }

  .b2b-tag {
    font-family: var(--body); font-size: 8.5px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: #fff; background: var(--ink-72);
    border-radius: 4px; padding: 1px 4px; line-height: 1.3;
  }
  .at-sep {
    align-self: center;
    font-family: var(--body); font-size: 12px; font-weight: 600; color: var(--ink-32);
    padding-top: 34px;
  }

  /* Split probability bar */
  .split-bar {
    display: flex; height: 6px; border-radius: 999px; overflow: hidden;
    background: var(--ink-06); margin-bottom: 14px;
  }
  .split-bar .split-away { background: var(--away-color); }
  .split-bar .split-home { background: var(--home-color); }

  /* Prediction — the big number */
  .prediction {
    display: flex; align-items: baseline; justify-content: center;
    padding: 4px 0 12px; border-top: 1px solid var(--ink-06); margin-top: auto;
  }
  .pred-fav { display: flex; align-items: baseline; gap: 10px; }
  .pred-big {
    font-family: var(--display); font-weight: 800; font-size: 52px; line-height: 0.9;
    letter-spacing: -0.01em; color: var(--red);
  }
  .pred-big .pred-sign { font-size: 24px; margin-left: 1px; }
  .pred-label {
    font-family: var(--body); font-size: 12.5px; font-weight: 500; color: var(--ink-56);
    align-self: center;
  }
  .pred-label strong { font-weight: 700; color: var(--ink); }

  .pred-tossup { display: flex; flex-direction: column; align-items: center; gap: 2px; padding-top: 6px; }
  .pred-tossup-num {
    font-family: var(--display); font-weight: 800; font-size: 40px; line-height: 0.9; color: var(--ink-86);
  }
  .pred-tossup-num .pred-sign { color: var(--ink-32); font-size: 26px; margin: 0 1px; }
  .is-tossup .pred-label { color: var(--ink-56); font-size: 11.5px; }

  /* Goalies */
  .goalies {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    border-top: 1px solid var(--ink-06); padding-top: 10px;
  }
  .goalie {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--body); font-size: 11px; font-weight: 500; color: var(--ink-56);
    min-width: 0;
  }
  .goalie .gm { color: var(--ink-32); font-size: 9px; }
  .goalie-home { text-align: right; }

  /* ── Empty state ── */
  .empty-state {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; min-height: 240px; padding: 48px 24px;
    background: var(--surface); border: 1px dashed var(--ink-20); border-radius: 16px;
  }
  .empty-mark {
    font-family: var(--display); font-weight: 800; font-size: 48px; color: var(--ink-20); line-height: 1;
  }
  .empty-title {
    font-family: var(--display); font-weight: 700; font-size: 24px; text-transform: uppercase;
    color: var(--ink); margin: 10px 0 6px;
  }
  .empty-sub { font-family: var(--body); font-size: 13px; color: var(--ink-48); max-width: 360px; line-height: 1.5; }

  .foot-note { margin: 22px 0 0; font-family: var(--body); font-size: 12px; line-height: 1.6; color: var(--ink-48); }
  .foot-note strong { color: var(--ink-72); font-weight: 700; }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .games-grid { grid-template-columns: 1fr; }
    .date-center { min-width: 0; }
    .pred-big { font-size: 46px; }
  }
</style>
