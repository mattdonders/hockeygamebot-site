---
/**
 * Game Predictions — daily model win-probability slate (hgb-spar-wins).
 *
 * DESIGN PREVIEW / MOCK DATA. This page renders a hardcoded slate so the
 * owner can preview the game-day surface before the API is wired. The real
 * product will fetch GET ${API_BASE}/v1/predictions?date=YYYY-MM-DD (the
 * predict_wins.py `slate` output — shape mirrored in MOCK below) client-side
 * on mount, exactly like /projections.
 *
 * Visual style mirrors /results: clean horizontal `.game-row` cards with a
 * single day-by-day header + prev/next-day nav. The model WIN % takes the
 * SCORE's slot (away% — home%, favorite = winner ink, underdog = muted ink),
 * and the bottom `.xg-bar` is driven by the win-prob split. There is NO
 * separate giant number — the score-slot % IS the prediction.
 *
 * Date navigation: the page is output:'static', so `?date=` cannot be read
 * per-request at build time. The prev/next arrows are plain `?date=` links; a
 * tiny inline enhancement script reads the param on load, updates the visible
 * date header, and recomputes the arrow hrefs so the mechanism feels real. The
 * mock games array is the same regardless of date.
 */
import StatsLayout from '../layouts/StatsLayout.astro';
import StatsMasthead from '../components/StatsMasthead.astro';

// ── Mock slate (predict_wins.py `slate` output shape) ─────────────────────
const DEFAULT_DATE = '2026-10-15';

const MOCK = {
  product: 'slate',
  date: DEFAULT_DATE,
  model: { name: 'hgb-spar-wins', version: 'v1' },
  games: [
    { game_id: '2026020120', start_time_utc: '2026-10-15T23:00:00Z', away: 'CAR', home: 'BUF', away_win_prob: 0.61, home_win_prob: 0.39, b2b_away: false, b2b_home: true,  away_goalie: 'F. Andersen',  home_goalie: 'U. Luukkonen', state: 'pre' },
    { game_id: '2026020121', start_time_utc: '2026-10-15T23:00:00Z', away: 'TOR', home: 'MTL', away_win_prob: 0.66, home_win_prob: 0.34, b2b_away: false, b2b_home: false, away_goalie: 'J. Woll',       home_goalie: 'S. Montembeault', state: 'pre' },
    { game_id: '2026020122', start_time_utc: '2026-10-15T23:00:00Z', away: 'NYR', home: 'NJD', away_win_prob: 0.52, home_win_prob: 0.48, b2b_away: false, b2b_home: false, away_goalie: 'I. Shesterkin', home_goalie: 'J. Markstrom',   state: 'pre' },
    { game_id: '2026020123', start_time_utc: '2026-10-15T23:30:00Z', away: 'TBL', home: 'FLA', away_win_prob: 0.44, home_win_prob: 0.56, b2b_away: true,  b2b_home: false, away_goalie: 'A. Vasilevskiy',home_goalie: 'S. Bobrovsky',  state: 'pre' },
    { game_id: '2026020124', start_time_utc: '2026-10-15T23:30:00Z', away: 'BOS', home: 'PIT', away_win_prob: 0.63, home_win_prob: 0.37, b2b_away: false, b2b_home: false, away_goalie: 'J. Swayman',   home_goalie: 'T. Jarry',      state: 'pre' },
    { game_id: '2026020125', start_time_utc: '2026-10-16T00:00:00Z', away: 'WSH', home: 'CBJ', away_win_prob: 0.68, home_win_prob: 0.32, b2b_away: false, b2b_home: false, away_goalie: 'L. Thompson',  home_goalie: 'E. Merzlikins',  state: 'pre' },
    { game_id: '2026020126', start_time_utc: '2026-10-16T00:00:00Z', away: 'WPG', home: 'MIN', away_win_prob: 0.55, home_win_prob: 0.45, b2b_away: false, b2b_home: false, away_goalie: 'C. Hellebuyck', home_goalie: 'F. Gustavsson', state: 'pre' },
    { game_id: '2026020127', start_time_utc: '2026-10-16T00:30:00Z', away: 'COL', home: 'DAL', away_win_prob: 0.49, home_win_prob: 0.51, b2b_away: false, b2b_home: false, away_goalie: 'M. Blackwood',  home_goalie: 'J. Oettinger',  state: 'pre' },
    { game_id: '2026020128', start_time_utc: '2026-10-16T00:30:00Z', away: 'NSH', home: 'STL', away_win_prob: 0.47, home_win_prob: 0.53, b2b_away: false, b2b_home: false, away_goalie: 'J. Saros',     home_goalie: 'J. Binnington', state: 'pre' },
    { game_id: '2026020129', start_time_utc: '2026-10-16T01:00:00Z', away: 'EDM', home: 'CGY', away_win_prob: 0.58, home_win_prob: 0.42, b2b_away: false, b2b_home: false, away_goalie: 'S. Skinner',   home_goalie: 'D. Wolf',       state: 'pre' },
    { game_id: '2026020130', start_time_utc: '2026-10-16T02:00:00Z', away: 'VGK', home: 'SJS', away_win_prob: 0.72, home_win_prob: 0.28, b2b_away: false, b2b_home: true,  away_goalie: 'A. Hill',      home_goalie: 'M. Blackwood',  state: 'pre' },
    { game_id: '2026020131', start_time_utc: '2026-10-16T02:30:00Z', away: 'LAK', home: 'SEA', away_win_prob: 0.51, home_win_prob: 0.49, b2b_away: false, b2b_home: false, away_goalie: 'D. Kuemper',   home_goalie: 'J. Daccord',    state: 'pre' },
  ],
};

// ── Derived view model ────────────────────────────────────────────────────
const TOSS_UP_BAND = 0.04; // |p - 0.5| within this => toss-up

const fmtTime = (iso: string) =>
  new Date(iso).toLocaleTimeString('en-US', {
    timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit',
  });

// City = full team name minus the nickname. Small lookup so cards can show a
// city eyebrow like /results without a data feed. Falls back to the abbr.
const CITY: Record<string, string> = {
  CAR: 'Carolina', BUF: 'Buffalo', TOR: 'Toronto', MTL: 'Montréal',
  NYR: 'New York', NJD: 'New Jersey', TBL: 'Tampa Bay', FLA: 'Florida',
  BOS: 'Boston', PIT: 'Pittsburgh', WSH: 'Washington', CBJ: 'Columbus',
  WPG: 'Winnipeg', MIN: 'Minnesota', COL: 'Colorado', DAL: 'Dallas',
  NSH: 'Nashville', STL: 'St. Louis', EDM: 'Edmonton', CGY: 'Calgary',
  VGK: 'Vegas', SJS: 'San Jose', LAK: 'Los Angeles', SEA: 'Seattle',
};
const NICK: Record<string, string> = {
  CAR: 'Hurricanes', BUF: 'Sabres', TOR: 'Maple Leafs', MTL: 'Canadiens',
  NYR: 'Rangers', NJD: 'Devils', TBL: 'Lightning', FLA: 'Panthers',
  BOS: 'Bruins', PIT: 'Penguins', WSH: 'Capitals', CBJ: 'Blue Jackets',
  WPG: 'Jets', MIN: 'Wild', COL: 'Avalanche', DAL: 'Stars',
  NSH: 'Predators', STL: 'Blues', EDM: 'Oilers', CGY: 'Flames',
  VGK: 'Golden Knights', SJS: 'Sharks', LAK: 'Kings', SEA: 'Kraken',
};

const games = MOCK.games.map((g) => {
  const homeFav = g.home_win_prob >= g.away_win_prob;
  const tossUp = Math.abs(g.home_win_prob - 0.5) <= TOSS_UP_BAND;
  return {
    ...g,
    startEt: fmtTime(g.start_time_utc),
    homeFav,
    tossUp,
    awayPct: Math.round(g.away_win_prob * 100),
    homePct: Math.round(g.home_win_prob * 100),
    awayCity: CITY[g.away] ?? g.away,
    homeCity: CITY[g.home] ?? g.home,
    awayNick: NICK[g.away] ?? g.away,
    homeNick: NICK[g.home] ?? g.home,
  };
});

const gameCount = games.length;

// Human date header for the default date, computed at build time. The inline
// script re-derives this from `?date=` on the client.
const dateLabel = new Date(`${DEFAULT_DATE}T12:00:00Z`).toLocaleDateString('en-US', {
  timeZone: 'UTC', weekday: 'short', month: 'short', day: 'numeric', year: 'numeric',
}).toUpperCase();
const rangeLabel = new Date(`${DEFAULT_DATE}T12:00:00Z`).toLocaleDateString('en-US', {
  timeZone: 'UTC', weekday: 'short', month: 'short', day: 'numeric',
}).toUpperCase();
---
<StatsLayout
  title="Game Predictions — HGB Model — HockeyGameBot"
  description="Model win probability for every game on today's NHL slate — favorite, both teams' odds, projected starters, and back-to-back flags from the hgb-spar-wins model."
  ogImage="/og/default.png"
  currentPath={Astro.url.pathname}
>

<StatsMasthead slot="mast" eyebrow="HGB Model · Game Predictions" ghost="PICKS">
  <Fragment slot="headline">Game <em>predictions.</em></Fragment>
  <Fragment slot="lede">Model win probability for every game on the slate.</Fragment>
  <span id="pred-badge" class="pred-badge">design preview · mock data</span>
</StatsMasthead>

<main class="wrap">

  <!-- ── DATE NAVIGATION (day-by-day) ── -->
  <div class="date-nav">
    <span class="date-nav-range" id="date-range">{rangeLabel}</span>
    <div class="date-nav-btns">
      <a class="date-btn" id="btn-prev" href={`/predictions?date=${DEFAULT_DATE}`} rel="prev">← Prev Day</a>
      <a class="date-btn" id="btn-next" href={`/predictions?date=${DEFAULT_DATE}`} rel="next">Next Day →</a>
    </div>
  </div>

  <div class="results-body">
    {gameCount === 0 ? (
      <div class="state-msg">No games scheduled on this date</div>
    ) : (
      <div class="day-group">
        <div class="day-header">
          <span class="day-label" id="day-label">{dateLabel}</span>
          <span class="day-count"><span id="day-count">{gameCount}</span> GAMES</span>
        </div>

        <div class="games-list">
          {games.map((g) => {
            const awayCls = g.awayPct >= g.homePct ? 'score-winner' : 'score-loser';
            const homeCls = g.homePct >= g.awayPct ? 'score-winner' : 'score-loser';
            return (
              <div class="game-row" style="display:grid">
                <div class="team-side away">
                  <img class="team-logo-sm" src={`/logos/nhl/${g.away}_light.svg`} alt={g.away} loading="lazy" />
                  <div>
                    <div class="team-city">{g.awayCity}</div>
                    <div class="team-nickname">
                      {g.awayNick}
                      {g.b2b_away && <span class="b2b-tag" title="Playing a back-to-back">B2B</span>}
                    </div>
                    <div class="team-goalie">◇ {g.away_goalie}</div>
                  </div>
                </div>

                <div class="score-block">
                  <div class="score-line">
                    <span class={awayCls}>{g.awayPct}<span class="pct-sign">%</span></span>
                    <span class="score-sep">—</span>
                    <span class={homeCls}>{g.homePct}<span class="pct-sign">%</span></span>
                  </div>
                  <div class="score-status">{g.startEt} ET{g.tossUp && ' · TOSS-UP'}</div>
                </div>

                <div class="team-side home">
                  <img class="team-logo-sm" src={`/logos/nhl/${g.home}_light.svg`} alt={g.home} loading="lazy" />
                  <div>
                    <div class="team-city">{g.homeCity}</div>
                    <div class="team-nickname">
                      {g.homeNick}
                      {g.b2b_home && <span class="b2b-tag" title="Playing a back-to-back">B2B</span>}
                    </div>
                    <div class="team-goalie">◇ {g.home_goalie}</div>
                  </div>
                </div>

                <div class="xg-bar" style="grid-column:1/-1">
                  <div class="xg-away" style={`width:${g.awayPct}%`}></div>
                  <div class="xg-home" style={`width:${g.homePct}%`}></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>

  <p class="foot-note">
    <strong>Win %</strong> is the model's probability that each team wins the game — the favorite
    is inked, the underdog muted, and the bar below shows the split. <strong>B2B</strong> flags a
    team playing the second half of a back-to-back. Projected starters are subject to change on game day.
  </p>

</main>

</StatsLayout>

{/* Progressive enhancement: reflect ?date= in the header + arrow links.
    Mock data is unchanged across dates; this only wires the navigation UX. */}
<script is:inline>
  (function () {
    var DEFAULT = '2026-10-15';
    function parseISO(s) {
      var m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(s || '');
      if (!m) return null;
      var d = new Date(Date.UTC(+m[1], +m[2] - 1, +m[3], 12, 0, 0));
      return isNaN(d.getTime()) ? null : d;
    }
    function toISO(d) {
      return d.getUTCFullYear() + '-' +
        String(d.getUTCMonth() + 1).padStart(2, '0') + '-' +
        String(d.getUTCDate()).padStart(2, '0');
    }
    function fmt(d, opts) {
      return d.toLocaleDateString('en-US', Object.assign({ timeZone: 'UTC' }, opts)).toUpperCase();
    }
    var params = new URLSearchParams(window.location.search);
    var base = parseISO(params.get('date')) || parseISO(DEFAULT);

    var rangeEl = document.getElementById('date-range');
    if (rangeEl) rangeEl.textContent = fmt(base, { weekday: 'short', month: 'short', day: 'numeric' });
    var dayEl = document.getElementById('day-label');
    if (dayEl) dayEl.textContent = fmt(base, { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });

    var prev = new Date(base); prev.setUTCDate(prev.getUTCDate() - 1);
    var next = new Date(base); next.setUTCDate(next.getUTCDate() + 1);
    var prevEl = document.getElementById('btn-prev');
    var nextEl = document.getElementById('btn-next');
    if (prevEl) prevEl.setAttribute('href', '/predictions?date=' + toISO(prev));
    if (nextEl) nextEl.setAttribute('href', '/predictions?date=' + toISO(next));
  })();
</script>

<style is:global>
  /* ── Status badge (mock preview) — pinned top-right of hero card ── */
  .pred-badge {
    display: inline-block;
    font-family: var(--body); font-weight: 700; font-size: 11px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--red);
    border: 1px solid var(--red); border-radius: 999px; padding: 3px 10px;
  }
  .mast-card:has(#pred-badge) { position: relative; }
  #pred-badge { position: absolute; top: 22px; right: 24px; }
  @media (max-width: 600px) {
    #pred-badge { position: static; margin-top: 12px; }
  }

  /* ── DATE NAV (mirrors /results) ── */
  .date-nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 0 4px;
    border-bottom: 1px solid var(--ink-14);
    margin-bottom: 0;
  }
  .date-nav-range {
    font-family: var(--mono); font-size: 11px; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-56);
  }
  .date-nav-btns { display: flex; gap: 8px; }
  .date-btn {
    font-family: var(--mono); font-size: 11px; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-48);
    background: none; border: 1px solid var(--ink-14); padding: 6px 14px;
    cursor: pointer; text-decoration: none;
    transition: color .15s, border-color .15s;
  }
  .date-btn:hover { color: var(--ink); border-color: var(--ink); }

  /* ── CONTENT ── */
  .results-body { padding: 0 0 64px; }
  .state-msg {
    display: flex; align-items: center; justify-content: center; padding: 80px 0;
    font-family: var(--mono); font-size: 12px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--ink-32);
  }

  /* Day group */
  .day-group { border-bottom: 1px solid var(--ink-10); }
  .day-header { display: flex; align-items: baseline; gap: 12px; padding: 22px 0 12px; }
  .day-label {
    font-family: var(--display); font-weight: 800; font-size: 19px;
    letter-spacing: 0.04em; text-transform: uppercase;
  }
  .day-count {
    font-family: var(--mono); font-size: 10px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32);
  }

  /* Game rows */
  .games-list { display: flex; flex-direction: column; gap: 6px; padding-bottom: 16px; }
  .game-row {
    display: grid; grid-template-columns: 1fr auto 1fr auto; align-items: center; gap: 0;
    background: var(--surface); border: 1px solid var(--ink-10);
    color: inherit; transition: border-color .15s, background .15s;
  }
  .game-row:hover { border-color: var(--ink-32); background: var(--bg-2); }

  /* Team side (away on left, home on right) */
  .team-side { display: flex; align-items: center; gap: 10px; padding: 12px 16px; }
  .team-side.home { flex-direction: row-reverse; text-align: right; }
  .team-logo-sm { width: 32px; height: 32px; object-fit: contain; flex-shrink: 0; }
  .team-nickname {
    display: flex; align-items: center; gap: 6px;
    font-family: var(--display); font-weight: 800; font-size: 20px;
    letter-spacing: 0.02em; line-height: 1.1; color: var(--ink);
    text-transform: uppercase; white-space: nowrap;
  }
  .team-side.home .team-nickname { flex-direction: row-reverse; }
  .team-city {
    font-family: var(--mono); font-size: 10px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-48); white-space: nowrap;
  }
  .team-goalie {
    font-family: var(--mono); font-size: 9.5px; font-weight: 500;
    letter-spacing: 0.04em; color: var(--ink-32); white-space: nowrap; margin-top: 3px;
  }
  .b2b-tag {
    font-family: var(--body); font-size: 8.5px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: #fff; background: var(--ink-72);
    border-radius: 4px; padding: 1px 4px; line-height: 1.3;
  }

  /* Score block — win% sits in the score slot */
  .score-block {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    padding: 10px 20px; min-width: 130px;
  }
  .score-line {
    display: flex; align-items: baseline; gap: 12px;
    font-family: var(--display); font-weight: 800; font-size: 30px; line-height: 1;
    letter-spacing: 0.01em; font-variant-numeric: tabular-nums;
  }
  .score-line .pct-sign {
    font-family: var(--display); font-weight: 800; font-size: 15px; margin-left: 1px;
  }
  .score-sep { font-family: var(--mono); font-size: 14px; font-weight: 600; color: var(--ink-32); align-self: center; }
  .score-winner { color: var(--ink); }
  .score-loser  { color: var(--ink-32); }
  .score-status {
    font-family: var(--mono); font-size: 9.5px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); white-space: nowrap;
  }

  /* Win-prob split bar (mirrors /results .xg-bar) */
  .xg-bar { grid-column: 1 / -1; display: flex; align-items: center; gap: 0; height: 3px; background: var(--ink-06); }
  .xg-away, .xg-home { height: 100%; transition: width .3s; }
  .xg-away { background: var(--ink-56); }
  .xg-home { background: var(--ink-32); }

  .foot-note { margin: 22px 0 0; font-family: var(--body); font-size: 12px; line-height: 1.6; color: var(--ink-48); }
  .foot-note strong { color: var(--ink-72); font-weight: 700; }

  @media (max-width: 600px) {
    .team-city { display: none; }
    .team-nickname { font-size: 16px; }
    .score-line { font-size: 24px; gap: 8px; }
    .score-line .pct-sign { font-size: 12px; }
    .score-block { padding: 8px 10px; min-width: 104px; }
    .team-side { padding: 10px 12px; gap: 8px; }
    .team-goalie { font-size: 9px; }
  }
</style>
