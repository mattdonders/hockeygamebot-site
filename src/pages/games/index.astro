---
// HockeyGameBot — /games/:id
// SPA shell. Client JS reads game_id from pathname, detects game state,
// and renders one of three distinct layouts: pregame / live / final.
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import { loadPlayers, loadPlayerGames } from '../../lib/stats-loader';

// Build impact map at build time:
//   player_id → { l10: last-10 gs_display[], gids: last-10 game_ids[] }
// Storing game_ids alongside values lets the game page look up "this game's Impact".
type ImpactEntry = { l10: number[]; gids: string[] };
const _sparklineMap: Record<number, ImpactEntry> = {};
for (const p of loadPlayers()) {
  const games = (loadPlayerGames(p.player_id) ?? [])
    .sort((a, b) => a.game_date.localeCompare(b.game_date))
    .slice(-10);
  _sparklineMap[p.player_id] = {
    l10:  games.map(g => +g.gs_display.toFixed(2)),
    gids: games.map(g => (g.game_id ?? '').replace(/\.0$/, '')),
  };
}
---
<!doctype html>
<html lang="en">
<head>
<ThemeScript />
<Fonts />
<meta charset="utf-8" />
<title>Game · HockeyGameBot</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
<link rel="apple-touch-icon" href="/favicon-180x180.png" />
<style is:global>
:root {
  --bg:      #EFEEE8;
  --bg-2:    #E8E7E0;
  --surface: #FFFFFF;
  --ink:     #0d0d14;
  --ink-72:  rgba(13,13,20,0.72);
  --ink-64:  rgba(13,13,20,0.64);
  --ink-56:  rgba(13,13,20,0.56);
  --ink-48:  rgba(13,13,20,0.48);
  --ink-32:  rgba(13,13,20,0.32);
  --ink-20:  rgba(13,13,20,0.20);
  --ink-14:  rgba(13,13,20,0.14);
  --ink-10:  rgba(13,13,20,0.10);
  --ink-06:  rgba(13,13,20,0.06);
  --ink-04:  rgba(13,13,20,0.04);
  --red:     #E8002D;
  --green:   #22c55e;
  --grid-line: rgba(13,13,20,0.04);
  --stats-pos: #166534;
  --stats-neg: #991b1b;
  --display: "Barlow Condensed", sans-serif;
  --body:    "Barlow", sans-serif;
  --mono:    "JetBrains Mono", monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; overflow-x: hidden; }
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }
.wrap { max-width: 1280px; margin: 0 auto; padding: 0 32px; }

/* ── LOADING ── */
#loading-state { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; gap: 16px; font-family: var(--mono); font-size: 13px; color: var(--ink-48); letter-spacing: 0.06em; }
.spinner { width: 24px; height: 24px; border: 2px solid var(--ink-14); border-top-color: var(--red); border-radius: 50%; animation: spin 0.7s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
#game-content { display: none; }

/* ── GAME MASTHEAD (matches site mast pattern) ── */
.game-mast { position: relative; border-bottom: 2px solid var(--ink);
  background-color: var(--bg);
  background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 96px 96px; }
.mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.mast-corners .corner { position: absolute; width: 16px; height: 16px; }
.mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-inner { position: relative; z-index: 2; padding: 28px 0 32px; }
.mast-top { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px; }
.mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; color: var(--ink-48); }
.mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; flex-shrink: 0; }
.mast-eyebrow a { color: var(--ink-48); text-decoration: none; }
.mast-eyebrow a:hover { color: var(--ink); }

/* White inset score card */
.mast-card { background: var(--surface); border: 1px solid var(--ink); overflow: hidden; }
.game-card-bar { height: 3px; display: flex; }
.game-card-bar-half { flex: 1; }
.score-grid { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 24px; padding: 28px 32px 16px; }
.team-side { display: flex; flex-direction: column; align-items: center; gap: 10px; }
.team-side.away { align-items: flex-end; }
.team-side.home { align-items: flex-start; }
.team-abbr-big { font-family: var(--display); font-weight: 800; font-size: clamp(32px, 5vw, 52px); letter-spacing: 0.02em; line-height: 1; color: var(--ink); }
.team-name-small { font-family: var(--display); font-weight: 600; font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); }
.score-center { text-align: center; }
.score-display { font-family: var(--display); font-weight: 800; font-size: clamp(56px, 8vw, 96px); letter-spacing: -0.02em; line-height: 1; display: flex; align-items: center; gap: 16px; color: var(--ink); }
.score-sep { font-weight: 400; color: var(--ink-32); }
.game-meta { margin-top: 10px; display: flex; flex-direction: column; align-items: center; gap: 6px; }
.status-badge { display: inline-flex; align-items: center; gap: 6px; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; padding: 3px 10px; }
.status-badge.final { background: var(--ink-06); color: var(--ink-56); }
.status-badge.live  { background: #22c55e; color: #fff; }
.status-badge.live::before { content: ""; width: 5px; height: 5px; background: #fff; border-radius: 50%; animation: pulse-dot 1.2s ease-in-out infinite; }
.status-badge.pre   { background: var(--ink-06); color: var(--ink-48); }
@keyframes pulse-dot { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
.game-live-clock { font-family: var(--display); font-weight: 800; font-size: clamp(18px, 2.5vw, 26px); letter-spacing: 0.04em; color: var(--ink); display: none; }
.game-live-clock.visible { display: block; }
.card-info-strip { padding: 10px 32px 16px; display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; border-top: 1px solid var(--ink-06); }
.header-info-left { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.06em; text-transform: uppercase; }
.header-info-right { font-family: var(--mono); font-size: 11px; color: var(--ink-56); letter-spacing: 0.06em; font-weight: 600; }

/* ── LINESCORE STRIP (full-width, outside .wrap) ── */
#section-linescore { background: var(--surface); border-bottom: 1px solid var(--ink-14); }
#section-linescore .period-table-wrap { border: none; border-radius: 0; max-width: 1280px; margin: 0 auto; padding: 0 32px; background: transparent; }

/* ── PRE-GAME BODY ── */
#section-pregame { padding: 40px 0 64px; }
.pregame-card { background: var(--surface); border: 1px solid var(--ink-14); padding: 32px; display: flex; flex-direction: column; gap: 20px; }
.pregame-time { font-family: var(--display); font-weight: 800; font-size: clamp(32px, 5vw, 56px); letter-spacing: -0.01em; line-height: 1; }
.pregame-venue { font-family: var(--mono); font-size: 12px; color: var(--ink-48); letter-spacing: 0.08em; text-transform: uppercase; }
.pregame-broadcasts { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.broadcast-chip { display: inline-flex; align-items: center; gap: 4px; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.12em; padding: 3px 10px; background: var(--bg-2); color: var(--ink-56); border: 1px solid var(--ink-14); }

/* ── PRE-GAME BODY: full sections ── */
.pg-body { display: grid; grid-template-columns: 1fr 320px; gap: 20px; padding: 32px 0 64px; align-items: start; }
@media (max-width: 860px) { .pg-body { grid-template-columns: 1fr; } }
.pg-section { background: var(--surface); border: 1px solid var(--ink-14); margin-bottom: 16px; }
.pg-section:last-child { margin-bottom: 0; }
.pg-section-hd { padding: 12px 20px 10px; border-bottom: 1px solid var(--ink-10); display: flex; align-items: center; gap: 8px; }
.pg-section-title { font-family: var(--display); font-weight: 800; font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-32); }
/* Matchup context */
.pg-matchup-inner { padding: 20px 24px 22px; }
.pg-series-label { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 6px; }
.pg-series-record { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.8vw, 30px); letter-spacing: -0.01em; line-height: 1; }
.pg-last5-wrap { margin-top: 20px; display: flex; flex-direction: column; gap: 10px; }
.pg-last5-row { display: flex; align-items: center; justify-content: space-between; }
.pg-last5-team { display: flex; align-items: center; gap: 8px; }
.pg-last5-abbr { font-family: var(--display); font-weight: 800; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; min-width: 34px; }
.pg-last5-dots { display: flex; gap: 4px; }
.pg-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.pg-dot-W { background: #22c55e; }
.pg-dot-L { background: var(--red); }
.pg-dot-OT { background: #f97316; }
.pg-last5-rec { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }
/* Playoff variant */
.pg-playoff-inner { padding: 20px 24px 22px; }
.pg-playoff-game-num { font-family: var(--display); font-weight: 800; font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
.pg-playoff-score { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.8vw, 34px); letter-spacing: -0.01em; line-height: 1; display: flex; align-items: center; gap: 12px; }
.pg-playoff-wins { display: flex; align-items: center; gap: 6px; }
.pg-playoff-num { font-size: 1em; }
.pg-playoff-label { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.08em; margin-top: 10px; }
/* Team stats mirror bars */
.pg-stat-row { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 10px; padding: 14px 20px 6px; border-top: 1px solid var(--ink-06); }
.pg-stat-row:first-child { border-top: none; }
.pg-stat-bar-row { display: grid; grid-template-columns: 1fr 1fr; height: 3px; padding: 0 20px; margin-bottom: 4px; }
.pg-stat-away-col { text-align: right; }
.pg-stat-home-col { text-align: left; }
.pg-stat-num { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px); line-height: 1; letter-spacing: -0.01em; }
.pg-stat-rank { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.08em; margin-top: 2px; }
.pg-stat-label-col { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.1em; text-transform: uppercase; text-align: center; white-space: nowrap; }
.pg-bar-seg { height: 3px; transition: width 0.4s ease; }
/* Goalies */
.pg-goalies-split { display: grid; grid-template-columns: 1fr 1px 1fr; }
.pg-goalie-div { background: var(--ink-14); }
.pg-goalie-col { padding: 18px 18px 20px; }
.pg-goalie-team-lbl { font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 4px; }
.pg-goalie-name { font-family: var(--display); font-weight: 800; font-size: clamp(15px, 2vw, 19px); letter-spacing: 0.01em; line-height: 1.15; margin-bottom: 6px; }
.pg-goalie-status { display: inline-flex; align-items: center; font-family: var(--mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; padding: 2px 7px; margin-bottom: 12px; }
.pg-goalie-status.confirmed { background: rgba(34,197,94,0.1); color: #16a34a; }
.pg-goalie-status.expected  { background: var(--ink-06); color: var(--ink-32); }
.pg-goalie-status.tbd       { background: var(--ink-06); color: var(--ink-32); }
.pg-goalie-stats { display: flex; gap: 18px; }
.pg-gs-val { font-family: var(--display); font-weight: 700; font-size: 19px; line-height: 1; }
.pg-gs-key { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 2px; }
.pg-goalie-rec { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.04em; margin-top: 8px; }
/* Milestones */
.pg-ms-row { display: flex; align-items: flex-start; gap: 12px; padding: 12px 20px; border-top: 1px solid var(--ink-06); }
.pg-ms-row:first-child { border-top: none; }
.pg-ms-badge { flex-shrink: 0; font-family: var(--display); font-weight: 700; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; padding: 3px 8px; white-space: nowrap; }
.pg-ms-badge.tonight  { background: rgba(232,0,45,0.1); color: var(--red); }
.pg-ms-badge.one-away { background: rgba(249,115,22,0.1); color: #c2410c; }
.pg-ms-badge.away     { background: var(--ink-06); color: var(--ink-32); }
.pg-ms-player { font-family: var(--display); font-weight: 700; font-size: 15px; letter-spacing: 0.01em; line-height: 1.1; }
.pg-ms-label { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.04em; margin-top: 2px; }
/* Officials */
.pg-off-inner { padding: 16px 20px; }
.pg-off-tba { display: flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; color: var(--ink-32); letter-spacing: 0.06em; }
.pg-off-group { margin-bottom: 14px; }
.pg-off-group:last-child { margin-bottom: 0; }
.pg-off-group-lbl { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 6px; }
.pg-off-name { font-family: var(--display); font-weight: 600; font-size: 14px; color: var(--ink-72); margin-bottom: 2px; }
/* Broadcast chips — pregame header */
.bc-chip { display: inline-flex; align-items: center; font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 3px 9px; }
.bc-chip.national { background: rgba(232,0,45,0.1); color: var(--red); border: 1px solid rgba(232,0,45,0.2); }
.bc-chip.local    { background: var(--ink-06); color: var(--ink-48); border: 1px solid var(--ink-14); }
/* Masthead record badge (pregame) */
.team-record-small { font-family: var(--mono); font-size: 11px; color: var(--ink-32); letter-spacing: 0.06em; }

/* ── PERIOD / LINESCORE TABLE ── */
.period-table-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow-x: auto; }
.period-table { width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 12px; }
.period-table th { padding: 8px 16px; background: var(--bg-2); font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-48); text-align: center; border-bottom: 1px solid var(--ink-14); }
.period-table th:first-child { text-align: left; min-width: 140px; }
.period-table td { padding: 10px 16px; text-align: center; border-bottom: 1px solid var(--ink-06); font-variant-numeric: tabular-nums; }
.period-table td:first-child { text-align: left; font-family: var(--display); font-weight: 700; font-size: 14px; letter-spacing: 0.06em; display: flex; align-items: center; gap: 10px; }
.period-table td:last-child { font-weight: 700; font-size: 14px; }
.period-table tr:last-child td { border-bottom: none; }

/* ── SECTIONS ── */
.section { padding: 40px 0 0; }
.section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 20px; padding-bottom: 11px; border-bottom: 1px solid var(--ink-20); }
.section-title { font-family: var(--display); font-weight: 800; font-size: clamp(18px, 2.5vw, 26px); text-transform: uppercase; letter-spacing: 0.01em; }
.section-title .accent { color: var(--red); }
.section-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.08em; text-transform: uppercase; }

/* ── KEY STATS — comparison table (AWAY | label | HOME) ── */
.stats-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
@media (max-width: 640px) { .stats-two-col { grid-template-columns: 1fr; } }
.stats-compare { background: var(--surface); border: 1px solid var(--ink-14); }
.stats-card-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--ink-32); }
.stats-compare-head { display: grid; grid-template-columns: 1fr auto 1fr; padding: 12px 28px 8px; }
.stats-abbr { font-family: var(--display); font-weight: 800; font-size: 14px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-56); }
.stats-abbr.right { text-align: right; }
.stats-compare-row { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 12px 28px; border-top: 1px solid var(--ink-06); gap: 16px; }
.stat-compare-num { font-family: var(--display); font-weight: 800; font-size: clamp(24px, 3vw, 34px); line-height: 1; letter-spacing: -0.01em; transition: color 0.3s; }
.stat-compare-num.right { text-align: right; }
.stat-compare-key { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.12em; text-transform: uppercase; text-align: center; white-space: nowrap; }

/* ── CHARTS — stacked, no tabs ── */
.chart-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; }
.chart-wrap + .chart-wrap { margin-top: 12px; }
.chart-svg { width: 100%; display: block; cursor: crosshair; }
.chart-no-data { padding: 40px 0; text-align: center; font-family: var(--mono); font-size: 12px; color: var(--ink-32); letter-spacing: 0.06em; }
.chart-sub-label { padding: 8px 14px 6px; font-family: var(--display); font-weight: 800; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-32); border-top: 1px solid var(--ink-06); }
/* Chart hover tooltip */
#ctip { position: fixed; pointer-events: none; z-index: 201; background: #0d0d14; color: #fff; border-radius: 3px; padding: 8px 12px; font-family: var(--mono); font-size: 11px; line-height: 1.5; letter-spacing: 0.02em; box-shadow: 0 4px 16px rgba(0,0,0,0.35); display: none; white-space: nowrap; }
#ctip .ct-team { font-family: var(--display); font-weight: 700; font-size: 13px; margin-bottom: 2px; }
#ctip .ct-sub { color: rgba(255,255,255,0.45); font-size: 10px; }
#ctip .ct-wp { font-size: 12px; }
#ctip .ct-meta { color: rgba(255,255,255,0.45); font-size: 10px; margin-top: 2px; }
/* Stats location badge */
.stats-location { font-family: var(--mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32); display: block; margin-top: 2px; }

/* ── LIVE REFRESH INDICATOR ── */
.refresh-bar { display: flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.08em; }
.refresh-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse-dot 1.5s ease-in-out infinite; }

/* ── GOAL LOG ── */
.goals-table-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow-x: auto; }
table.goals { width: 100%; border-collapse: collapse; font-size: 13px; }
table.goals thead tr { border-bottom: 1px solid var(--ink-20); }
table.goals th { padding: 10px 14px; text-align: left; font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-48); white-space: nowrap; }
table.goals td { padding: 11px 14px; border-bottom: 1px solid var(--ink-06); white-space: nowrap; vertical-align: middle; }
table.goals tr:last-child td { border-bottom: none; }
table.goals tbody tr:hover { background: var(--ink-04); }
.goal-team-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; flex-shrink: 0; }
.goal-scorer { font-weight: 600; }
.goal-assists { font-size: 12px; color: var(--ink-72); }
.player-link { color: inherit; text-decoration: none; border-bottom: 1px solid var(--ink-14); transition: border-color 0.15s; }
.player-link:hover { border-bottom-color: var(--ink); }
.strength-badge { display: inline-block; font-family: var(--display); font-weight: 700; font-size: 9.5px; letter-spacing: 0.14em; padding: 2px 6px; }
.str-pp { background: rgba(234,179,8,0.15); color: #92400e; }
.str-sh { background: rgba(59,130,246,0.15); color: #1e3a5f; }
.str-en { background: rgba(13,13,20,0.08); color: var(--ink-56); }
.goal-score { font-family: var(--mono); font-size: 11px; color: var(--ink-48); font-variant-numeric: tabular-nums; }
.video-link { font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; color: var(--red); opacity: 0.85; transition: opacity 0.15s; display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border: 1px solid rgba(232,0,45,0.25); background: rgba(232,0,45,0.04); }
.video-link:hover { opacity: 1; background: rgba(232,0,45,0.08); }
.wp-swing { font-family: var(--mono); font-size: 11px; font-weight: 600; font-variant-numeric: tabular-nums; }
.wp-swing.pos { color: var(--green); }
.wp-swing.neg { color: var(--red); }

/* ── PLAYER STATS ── */
.player-stats-grid { display: flex; flex-direction: column; gap: 1px; background: var(--ink-14); border: 1px solid var(--ink-14); }
.player-team-card { background: var(--surface); }
.player-team-head { display: flex; align-items: center; gap: 10px; padding: 10px 14px; background: var(--bg-2); border-bottom: 1px solid var(--ink-14); }
.player-team-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
.player-team-label { font-family: var(--display); font-weight: 800; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-56); }
table.ps { width: 100%; border-collapse: collapse; font-size: 13px; }
table.ps thead tr { border-bottom: 1px solid var(--ink-14); }
table.ps th { padding: 8px 10px; font-family: var(--display); font-weight: 700; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-32); white-space: nowrap; cursor: pointer; user-select: none; text-align: center; }
table.ps th:nth-child(2) { text-align: left; }
table.ps th:hover { color: var(--ink); }
table.ps th.sort-asc::after { content: " ↑"; }
table.ps th.sort-desc::after { content: " ↓"; }
table.ps td { padding: 8px 10px; border-bottom: 1px solid var(--ink-04); font-variant-numeric: tabular-nums; white-space: nowrap; text-align: center; }
table.ps td:nth-child(2) { text-align: left; }
table.ps tr:last-child td { border-bottom: none; }
table.ps tbody tr:hover { background: var(--ink-04); }
.ps-name { font-family: var(--body); font-weight: 600; font-size: 13px; }
/* Goalie sub-table */
.goalie-section-head { font-family: var(--display); font-weight: 700; font-size: 9px;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-32);
  padding: 8px 10px 6px; border-top: 2px solid var(--ink-14); margin-top: 2px; }
.ps-num { font-family: var(--mono); font-size: 10px; color: var(--ink-32); }
.ps-pos { font-family: var(--mono); font-size: 10px; color: var(--ink-48); }
.ps-toi { font-family: var(--mono); font-size: 11px; font-variant-numeric: tabular-nums; }
.ps-ixg { font-family: var(--mono); font-size: 11px; font-weight: 600; }
.ps-divider { padding: 5px 8px; background: var(--bg-2); font-family: var(--display); font-weight: 700; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-32); border-top: 1px solid var(--ink-14); }
/* Combined goalies table */
.ps-container { border: 1px solid var(--ink-14); }
.ps-container .player-stats-grid { border: none; }
#combined-goalies { border-top: 1px solid var(--ink-14); background: var(--surface); }
.cg-head { padding: 8px 12px 6px; font-family: var(--display); font-weight: 700; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-32); background: var(--bg-2); }
.cg-table { width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 12px; }
.cg-table th { padding: 7px 14px; font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); text-align: center; border-bottom: 1px solid var(--ink-14); white-space: nowrap; }
.cg-table th:nth-child(2) { text-align: left; width: 35%; }
.cg-table td { padding: 8px 14px; text-align: center; border-bottom: 1px solid var(--ink-06); color: var(--ink); white-space: nowrap; }
.cg-table td:first-child { color: var(--ink-32); font-size: 10px; width: 36px; }
.cg-table td:nth-child(2) { text-align: left; font-family: var(--body); font-weight: 600; font-size: 13px; }
.cg-table td:nth-child(3) { font-size: 10px; font-weight: 700; letter-spacing: 0.08em; }
.cg-table tr:last-child td { border-bottom: none; }
.gsax-pos { color: var(--stats-pos); font-weight: 700; }
.gsax-neg { color: var(--stats-neg); font-weight: 700; }

/* ── SHOT MAP ── */
.shot-map-outer { position: relative; background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; }
.shot-map-rink-wrap { padding: 16px 16px 0; }
.shot-map-svg { width: 100%; display: block; }
.shot-map-legend { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; justify-content: center; padding: 10px 14px; font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.06em; }
.shot-map-legend-team { display: flex; align-items: center; gap: 8px; }
.sml-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.sml-sep { width: 1px; height: 12px; background: var(--ink-14); }
.sml-key { display: flex; align-items: center; gap: 5px; }
/* Tooltip */
#shot-tooltip { position: fixed; pointer-events: none; z-index: 200; background: #0d0d14; color: #fff; border-radius: 4px; padding: 8px 11px; font-family: var(--mono); font-size: 11px; line-height: 1.5; letter-spacing: 0.02em; box-shadow: 0 4px 16px rgba(0,0,0,0.35); display: none; max-width: 200px; }
#shot-tooltip .stt-player { font-family: var(--display); font-weight: 700; font-size: 13px; letter-spacing: 0.04em; margin-bottom: 3px; }
#shot-tooltip .stt-xg { font-weight: 600; }
#shot-tooltip .stt-meta { color: rgba(255,255,255,0.5); font-size: 10px; margin-top: 2px; }

/* ── FROM THE BOT (cards + posts) ── */
.bot-row-label { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px; }
.hscroll { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 12px; scrollbar-width: thin; scrollbar-color: var(--ink-20) transparent; -webkit-overflow-scrolling: touch; }
.hscroll::-webkit-scrollbar { height: 4px; }
.hscroll::-webkit-scrollbar-track { background: transparent; }
.hscroll::-webkit-scrollbar-thumb { background: var(--ink-20); border-radius: 2px; }
/* Card tiles (image posts) */
.bot-card { flex-shrink: 0; width: 260px; background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; display: flex; flex-direction: column; }
.bot-card img { width: 100%; height: auto; display: block; object-fit: cover; }
.bot-card-meta { padding: 8px 10px; display: flex; justify-content: space-between; align-items: center; }
.bot-card-time { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); letter-spacing: 0.06em; }
.bot-card-counts { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); letter-spacing: 0.04em; }
/* Post tiles (text posts) */
.bot-post { flex-shrink: 0; width: 240px; background: var(--surface); border: 1px solid var(--ink-14); padding: 12px 14px; display: flex; flex-direction: column; gap: 8px; }
.bot-post-text { font-family: var(--body); font-size: 12px; line-height: 1.45; color: var(--ink); overflow: hidden; display: -webkit-box; -webkit-line-clamp: 6; -webkit-box-orient: vertical; flex: 1; }
.bot-post-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
.bot-post-time { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); letter-spacing: 0.04em; }
.bot-post-counts { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); letter-spacing: 0.04em; }
.bot-post-link { font-family: var(--mono); font-size: 9px; color: var(--red); opacity: 0.7; text-decoration: none; }
.bot-post-link:hover { opacity: 1; }

/* ── ON-ICE xGF ─────────────────────────────────────────────────────────── */
.onice-tabs { display: flex; gap: 4px; margin-bottom: 16px; align-items: center; }
.onice-view-toggle { margin-left: auto; font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; border: 1px solid var(--ink-20); border-radius: 3px; background: transparent; color: var(--ink-48); cursor: pointer; transition: background 0.12s, color 0.12s; }
.onice-view-toggle:hover { border-color: var(--ink-48); color: var(--ink); }
.onice-view-toggle.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }
.onice-view-toggle[data-view="table"] .onice-toggle-chart { display: inline; }
.onice-view-toggle[data-view="table"] .onice-toggle-table { display: none; }
.onice-view-toggle[data-view="chart"] .onice-toggle-chart { display: none; }
.onice-view-toggle[data-view="chart"] .onice-toggle-table { display: inline; }
.onice-tab { font-family: var(--display); font-weight: 700; font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; padding: 5px 14px; border: 1px solid var(--ink-20); border-radius: 3px; background: transparent; color: var(--ink-56); cursor: pointer; transition: background 0.12s, color 0.12s, border-color 0.12s; }
.onice-tab.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }
.onice-tab:hover:not(.active) { border-color: var(--ink-48); color: var(--ink); }
.onice-empty { font-family: var(--mono); font-size: 11px; color: var(--ink-32); padding: 20px 0; text-align: center; letter-spacing: 0.06em; }
.onice-card { background: var(--surface); border: 1px solid var(--ink-14); padding: 20px 24px 24px; }
/* split layout */
.onice-split { display: grid; grid-template-columns: 1fr 1px 1fr; }
.onice-col-div { background: var(--ink-20); margin: 0 6px; }
.onice-team-col { padding: 0 18px; }
.onice-team-col:first-child { padding-left: 0; }
.onice-team-col:last-child  { padding-right: 0; }
/* team header */
.onice-team-hdr { display: flex; align-items: flex-end; gap: 8px; border-bottom: 2px solid currentColor; padding-bottom: 6px; }
.onice-team-name { font-family: var(--display); font-weight: 800; font-size: 18px; letter-spacing: 0.08em; text-transform: uppercase; line-height: 1; }
.onice-team-avg { margin-left: auto; font-family: var(--mono); font-weight: 700; font-size: 13px; font-variant-numeric: tabular-nums; line-height: 1; }
/* subheader */
.onice-subhdr { display: grid; grid-template-columns: 1fr 72px 52px 32px 72px 52px; border-bottom: 1px solid var(--ink-10); padding: 7px 0 6px; }
.onice-sh { font-family: var(--mono); font-size: 10px; color: var(--ink-56); letter-spacing: 0.07em; text-transform: uppercase; text-align: center; font-weight: 600; white-space: nowrap; }
.onice-sh-r { text-align: right; padding-right: 4px; }
/* player rows */
.onice-name-text { font-family: var(--display); font-weight: 600; font-size: 15px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--ink); }
.onice-prow { display: grid; grid-template-columns: 1fr 72px 52px 32px 72px 52px; align-items: center; border-bottom: 1px solid var(--ink-14); }
.onice-prow:last-child { border-bottom: none; }
.onice-pcell { padding: 5px 8px 5px 0; overflow: hidden; }
.onice-heat { font-family: var(--mono); font-weight: 700; font-size: 13px; font-variant-numeric: tabular-nums; padding: 5px 4px; text-align: center; border-radius: 3px; margin: 3px 2px; display: block; }
.onice-toi { font-family: var(--mono); font-size: 13px; color: var(--ink-72); text-align: right; padding-right: 4px; white-space: nowrap; font-variant-numeric: tabular-nums; }
/* line rows */
.onice-lrow { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 10px; border-bottom: 1px solid var(--ink-14); padding: 7px 0; }
.onice-lrow:last-child { border-bottom: none; }
.onice-lnames { font-family: var(--display); font-weight: 600; font-size: 13px; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.onice-ltoi { font-family: var(--mono); font-size: 12px; color: var(--ink-56); white-space: nowrap; font-variant-numeric: tabular-nums; }
@media (max-width: 600px) {
  .onice-split { grid-template-columns: 1fr; }
  .onice-col-div { display: none; }
  .onice-team-col { padding: 0; margin-bottom: 24px; }
  .onice-team-col:last-child { margin-bottom: 0; }
}

/* ── THREE STARS ── */
.stars-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--ink-14); border: 1px solid var(--ink-14); }
.star-card { background: var(--surface); padding: 20px 22px 22px; display: flex; flex-direction: column; gap: 5px; border-top: 3px solid transparent; }
.star-rank { font-family: var(--mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-32); margin-bottom: 4px; }
.star-name { font-family: var(--display); font-weight: 800; font-size: clamp(18px, 2.5vw, 26px); letter-spacing: 0.01em; line-height: 1.05; }
.star-team { font-family: var(--display); font-weight: 700; font-size: 11px; color: var(--ink-48); letter-spacing: 0.14em; text-transform: uppercase; margin-top: 1px; }
.star-stat-line { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; margin-top: 6px; }

.no-data-msg { padding: 32px; text-align: center; font-family: var(--mono); font-size: 12px; color: var(--ink-32); letter-spacing: 0.04em; border: 1px solid var(--ink-14); background: var(--surface); }

/* ── GOAL VIDEO POPUP ── */
.gvp-overlay { position: fixed; inset: 0; z-index: 900; display: flex; align-items: center; justify-content: center; }
.gvp-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.75); }
.gvp-panel { position: relative; z-index: 1; background: #111; border-radius: 8px; width: 100%; max-width: 620px; overflow: hidden; box-shadow: 0 24px 64px rgba(0,0,0,0.6); }
.gvp-header { display: flex; align-items: stretch; background: rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.08); min-height: 38px; }
.gvp-tabs-bar { flex: 1; display: flex; }
.gvp-tab-btn { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; padding: 0 16px; height: 38px; border: none; border-bottom: 2px solid transparent; background: none; color: rgba(255,255,255,0.4); cursor: pointer; transition: color 0.15s; }
.gvp-tab-btn.active { color: #fff; border-bottom-color: #fff; }
.gvp-close { flex-shrink: 0; background: none; border: none; color: rgba(255,255,255,0.4); font-size: 18px; cursor: pointer; padding: 0 16px; line-height: 38px; transition: color 0.15s; }
.gvp-close:hover { color: #fff; }
.gvp-media { background: #000; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; }
.gvp-media video, .gvp-media iframe { width: 100%; height: 100%; display: block; border: none; }
.gvp-info { padding: 14px 18px 16px; }
.gvp-scorer-line { font-family: var(--display); font-weight: 700; font-size: 14px; color: #fff; letter-spacing: 0.04em; }
.gvp-wp-line { font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 4px; letter-spacing: 0.04em; }
.gvp-wp-delta { font-weight: 700; margin-left: 6px; }

/* ── CHART DOWNLOAD BUTTON ── */
.chart-dl-btn { font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; border: 1px solid var(--ink-20); border-radius: 3px; background: transparent; color: var(--ink-48); cursor: pointer; transition: background 0.12s, color 0.12s; }
.chart-dl-btn:hover { border-color: var(--ink-48); color: var(--ink); }

/* ── LINE COMBINATIONS ── */
.lc-table-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow-x: auto; }
table.lc { width: 100%; border-collapse: collapse; font-size: 13px; }
table.lc thead tr { border-bottom: 1px solid var(--ink-20); }
table.lc th { padding: 9px 12px; text-align: left; font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-48); white-space: nowrap; }
table.lc th:not(:first-child):not(:nth-child(2)) { text-align: center; }
table.lc td { padding: 10px 12px; border-bottom: 1px solid var(--ink-06); white-space: nowrap; vertical-align: middle; }
table.lc td:not(:first-child):not(:nth-child(2)) { text-align: center; font-family: var(--mono); font-size: 11px; font-variant-numeric: tabular-nums; }
table.lc tr:last-child td { border-bottom: none; }
table.lc tbody tr:hover { background: var(--ink-04); }
.lc-team-divider { padding: 7px 12px; background: var(--bg-2); font-family: var(--display); font-weight: 700; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-32); border-bottom: 1px solid var(--ink-14); display: flex; align-items: center; gap: 8px; }
.lc-team-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.lc-line-label { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.04em; }
.lc-players { font-family: var(--body); font-weight: 600; font-size: 13px; }
.lc-players-th { min-width: 200px; }
.lc-xgf-pos { color: var(--stats-pos); font-weight: 700; }
.lc-xgf-neg { color: var(--stats-neg); font-weight: 700; }
.lc-no-data { padding: 28px; text-align: center; font-family: var(--mono); font-size: 11px; color: var(--ink-32); letter-spacing: 0.06em; background: var(--surface); border: 1px solid var(--ink-14); }
.lc-section-dl-btn { font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; border: 1px solid var(--ink-20); border-radius: 3px; background: transparent; color: var(--ink-48); cursor: pointer; transition: background 0.12s, color 0.12s; }
.lc-section-dl-btn:hover { border-color: var(--ink-48); color: var(--ink); }

/* ── FOOTER ── */
.foot { margin-top: 48px; border-top: 1px solid var(--ink-14); padding: 24px 0; font-family: var(--mono); font-size: 11px; color: var(--ink-32); letter-spacing: 0.04em; }
.foot-inner { max-width: 1280px; margin: 0 auto; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }

/* ── RESPONSIVE ── */
@media (max-width: 720px) {
  .wrap { padding: 0 16px; }
  .mast-inner { padding: 20px 0 24px; }
  .score-grid { padding: 20px 16px 12px; gap: 12px; }
  .card-info-strip { padding: 8px 16px 14px; }
  #section-linescore .period-table-wrap { padding: 0 16px; }
  .team-abbr-big { font-size: clamp(22px, 6vw, 36px); }
  .score-display { font-size: clamp(40px, 10vw, 64px); gap: 10px; }
  #away-logo, #home-logo { width: 56px; height: 56px; }
  .stat-val { font-size: 22px; }
  .stats-4 { grid-template-columns: repeat(2, 1fr); }
  table.goals th, table.goals td { padding: 8px 10px; }
  .stars-grid { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .team-name-small { display: none; }
  .game-meta { font-size: 10px; }
}
</style>
</head>
<body>

<Nav currentPath="/games" />

<div id="loading-state">
  <div class="spinner"></div>
  <span>Loading game…</span>
</div>

<div id="game-content">

  <!-- SCORE MASTHEAD -->
  <section class="game-mast">
    <div class="mast-corners">
      <div class="corner tl"></div><div class="corner tr"></div>
      <div class="corner bl"></div><div class="corner br"></div>
    </div>
    <div class="mast-inner wrap">
      <div class="mast-top">
        <div class="mast-eyebrow"><span class="pip"></span> <span id="mast-breadcrumb">Game</span></div>
        <span id="mast-context" style="font-family:var(--mono);font-size:11px;color:var(--ink-48);letter-spacing:0.06em"></span>
      </div>
      <div class="mast-card">
        <div class="game-card-bar">
          <div class="game-card-bar-half" id="color-bar-away"></div>
          <div class="game-card-bar-half" id="color-bar-home"></div>
        </div>
        <div class="score-grid">
          <div class="team-side away">
            <img id="away-logo" src="" alt="" width="80" height="80" />
            <div class="team-abbr-big" id="away-abbr"></div>
            <div class="team-name-small" id="away-name"></div>
          </div>
          <div class="score-center">
            <div class="score-display">
              <span id="away-score">–</span>
              <span class="score-sep">–</span>
              <span id="home-score">–</span>
            </div>
            <div class="game-meta">
              <span id="status-badge" class="status-badge">Loading</span>
              <div id="game-live-clock" class="game-live-clock"></div>
            </div>
          </div>
          <div class="team-side home">
            <img id="home-logo" src="" alt="" width="80" height="80" />
            <div class="team-abbr-big" id="home-abbr"></div>
            <div class="team-name-small" id="home-name"></div>
          </div>
        </div>
        <div class="card-info-strip">
          <span id="header-info-left" class="header-info-left"></span>
          <span id="header-sog" class="header-info-right"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRE-GAME body -->
  <div id="section-pregame" style="display:none">
    <div class="wrap">
      <div class="pg-body">
        <!-- LEFT: Matchup context + Team stats -->
        <div class="pg-main">
          <div class="pg-section">
            <div class="pg-section-hd"><span class="pg-section-title">Matchup</span></div>
            <div id="pg-matchup-body"></div>
          </div>
          <div class="pg-section">
            <div class="pg-section-hd">
