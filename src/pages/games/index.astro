---
// HockeyGameBot — /games/:id
// SPA shell. Client JS reads game_id from pathname, detects game state,
// and renders one of three distinct layouts: pregame / live / final.
import Nav from '../../components/Nav.astro';
import { loadPlayers, loadPlayerGames } from '../../lib/stats-loader';

// Build impact map at build time:
//   player_id → { l10: last-10 gs_display[], gids: last-10 game_ids[] }
// Storing game_ids alongside values lets the game page look up "this game's Impact".
type ImpactEntry = { l10: number[]; gids: string[] };
const _sparklineMap: Record<number, ImpactEntry> = {};
for (const p of loadPlayers()) {
  const games = (loadPlayerGames(p.player_id) ?? [])
    .sort((a, b) => a.game_date.localeCompare(b.game_date))
    .slice(-10);
  _sparklineMap[p.player_id] = {
    l10:  games.map(g => +g.gs_display.toFixed(2)),
    gids: games.map(g => (g.game_id ?? '').replace(/\.0$/, '')),
  };
}
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Game · HockeyGameBot</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
<link rel="apple-touch-icon" href="/favicon-180x180.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style is:global>
:root {
  --bg:      #EFEEE8;
  --bg-2:    #E8E7E0;
  --surface: #FFFFFF;
  --ink:     #0d0d14;
  --ink-72:  rgba(13,13,20,0.72);
  --ink-56:  rgba(13,13,20,0.56);
  --ink-48:  rgba(13,13,20,0.48);
  --ink-32:  rgba(13,13,20,0.32);
  --ink-20:  rgba(13,13,20,0.20);
  --ink-14:  rgba(13,13,20,0.14);
  --ink-10:  rgba(13,13,20,0.10);
  --ink-06:  rgba(13,13,20,0.06);
  --ink-04:  rgba(13,13,20,0.04);
  --red:     #E8002D;
  --green:   #22c55e;
  --grid-line: rgba(13,13,20,0.04);
  --display: "Barlow Condensed", sans-serif;
  --body:    "Barlow", sans-serif;
  --mono:    "JetBrains Mono", monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; overflow-x: hidden; }
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }
.wrap { max-width: 1280px; margin: 0 auto; padding: 0 32px; }

/* ── LOADING ── */
#loading-state { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; gap: 16px; font-family: var(--mono); font-size: 13px; color: var(--ink-48); letter-spacing: 0.06em; }
.spinner { width: 24px; height: 24px; border: 2px solid var(--ink-14); border-top-color: var(--red); border-radius: 50%; animation: spin 0.7s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
#game-content { display: none; }

/* ── GAME MASTHEAD (matches site mast pattern) ── */
.game-mast { position: relative; border-bottom: 2px solid var(--ink);
  background-color: var(--bg);
  background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 96px 96px; }
.mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.mast-corners .corner { position: absolute; width: 16px; height: 16px; }
.mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-inner { position: relative; z-index: 2; padding: 28px 0 32px; }
.mast-top { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px; }
.mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; color: var(--ink-48); }
.mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; flex-shrink: 0; }
.mast-eyebrow a { color: var(--ink-48); text-decoration: none; }
.mast-eyebrow a:hover { color: var(--ink); }

/* White inset score card */
.mast-card { background: var(--surface); border: 1px solid var(--ink); overflow: hidden; }
.game-card-bar { height: 3px; display: flex; }
.game-card-bar-half { flex: 1; }
.score-grid { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 24px; padding: 28px 32px 16px; }
.team-side { display: flex; flex-direction: column; align-items: center; gap: 10px; }
.team-side.away { align-items: flex-end; }
.team-side.home { align-items: flex-start; }
.team-abbr-big { font-family: var(--display); font-weight: 800; font-size: clamp(32px, 5vw, 52px); letter-spacing: 0.02em; line-height: 1; color: var(--ink); }
.team-name-small { font-family: var(--display); font-weight: 600; font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); }
.score-center { text-align: center; }
.score-display { font-family: var(--display); font-weight: 800; font-size: clamp(56px, 8vw, 96px); letter-spacing: -0.02em; line-height: 1; display: flex; align-items: center; gap: 16px; color: var(--ink); }
.score-sep { font-weight: 400; color: var(--ink-32); }
.game-meta { margin-top: 10px; display: flex; flex-direction: column; align-items: center; gap: 6px; }
.status-badge { display: inline-flex; align-items: center; gap: 6px; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; padding: 3px 10px; }
.status-badge.final { background: var(--ink-06); color: var(--ink-56); }
.status-badge.live  { background: #22c55e; color: #fff; }
.status-badge.live::before { content: ""; width: 5px; height: 5px; background: #fff; border-radius: 50%; animation: pulse-dot 1.2s ease-in-out infinite; }
.status-badge.pre   { background: var(--ink-06); color: var(--ink-48); }
@keyframes pulse-dot { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
.game-live-clock { font-family: var(--display); font-weight: 800; font-size: clamp(18px, 2.5vw, 26px); letter-spacing: 0.04em; color: var(--ink); display: none; }
.game-live-clock.visible { display: block; }
.card-info-strip { padding: 10px 32px 16px; display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; border-top: 1px solid var(--ink-06); }
.header-info-left { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.06em; text-transform: uppercase; }
.header-info-right { font-family: var(--mono); font-size: 11px; color: var(--ink-56); letter-spacing: 0.06em; font-weight: 600; }

/* ── LINESCORE STRIP (full-width, outside .wrap) ── */
#section-linescore { background: var(--surface); border-bottom: 1px solid var(--ink-14); }
#section-linescore .period-table-wrap { border: none; border-radius: 0; max-width: 1280px; margin: 0 auto; padding: 0 32px; background: transparent; }

/* ── PRE-GAME BODY ── */
#section-pregame { padding: 40px 0 64px; }
.pregame-card { background: var(--surface); border: 1px solid var(--ink-14); padding: 32px; display: flex; flex-direction: column; gap: 20px; }
.pregame-time { font-family: var(--display); font-weight: 800; font-size: clamp(32px, 5vw, 56px); letter-spacing: -0.01em; line-height: 1; }
.pregame-venue { font-family: var(--mono); font-size: 12px; color: var(--ink-48); letter-spacing: 0.08em; text-transform: uppercase; }
.pregame-broadcasts { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.broadcast-chip { display: inline-flex; align-items: center; gap: 4px; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.12em; padding: 3px 10px; background: var(--bg-2); color: var(--ink-56); border: 1px solid var(--ink-14); }

/* ── PERIOD / LINESCORE TABLE ── */
.period-table-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow-x: auto; }
.period-table { width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 12px; }
.period-table th { padding: 8px 16px; background: var(--bg-2); font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-48); text-align: center; border-bottom: 1px solid var(--ink-14); }
.period-table th:first-child { text-align: left; min-width: 140px; }
.period-table td { padding: 10px 16px; text-align: center; border-bottom: 1px solid var(--ink-06); font-variant-numeric: tabular-nums; }
.period-table td:first-child { text-align: left; font-family: var(--display); font-weight: 700; font-size: 14px; letter-spacing: 0.06em; display: flex; align-items: center; gap: 10px; }
.period-table td:last-child { font-weight: 700; font-size: 14px; }
.period-table tr:last-child td { border-bottom: none; }

/* ── SECTIONS ── */
.section { padding: 40px 0 0; }
.section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 20px; padding-bottom: 11px; border-bottom: 1px solid var(--ink-20); }
.section-title { font-family: var(--display); font-weight: 800; font-size: clamp(18px, 2.5vw, 26px); text-transform: uppercase; letter-spacing: 0.01em; }
.section-title .accent { color: var(--red); }
.section-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.08em; text-transform: uppercase; }

/* ── KEY STATS — comparison table (AWAY | label | HOME) ── */
.stats-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
@media (max-width: 640px) { .stats-two-col { grid-template-columns: 1fr; } }
.stats-compare { background: var(--surface); border: 1px solid var(--ink-14); }
.stats-card-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--ink-32); }
.stats-compare-head { display: grid; grid-template-columns: 1fr auto 1fr; padding: 12px 28px 8px; }
.stats-abbr { font-family: var(--display); font-weight: 800; font-size: 14px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-56); }
.stats-abbr.right { text-align: right; }
.stats-compare-row { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 12px 28px; border-top: 1px solid var(--ink-06); gap: 16px; }
.stat-compare-num { font-family: var(--display); font-weight: 800; font-size: clamp(24px, 3vw, 34px); line-height: 1; letter-spacing: -0.01em; transition: color 0.3s; }
.stat-compare-num.right { text-align: right; }
.stat-compare-key { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.12em; text-transform: uppercase; text-align: center; white-space: nowrap; }

/* ── CHARTS — stacked, no tabs ── */
.chart-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; }
.chart-wrap + .chart-wrap { margin-top: 12px; }
.chart-svg { width: 100%; display: block; cursor: crosshair; }
.chart-no-data { padding: 40px 0; text-align: center; font-family: var(--mono); font-size: 12px; color: var(--ink-32); letter-spacing: 0.06em; }
.chart-sub-label { padding: 8px 14px 6px; font-family: var(--display); font-weight: 800; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-32); border-top: 1px solid var(--ink-06); }
/* Chart hover tooltip */
#ctip { position: fixed; pointer-events: none; z-index: 201; background: #0d0d14; color: #fff; border-radius: 3px; padding: 8px 12px; font-family: var(--mono); font-size: 11px; line-height: 1.5; letter-spacing: 0.02em; box-shadow: 0 4px 16px rgba(0,0,0,0.35); display: none; white-space: nowrap; }
#ctip .ct-team { font-family: var(--display); font-weight: 700; font-size: 13px; margin-bottom: 2px; }
#ctip .ct-sub { color: rgba(255,255,255,0.45); font-size: 10px; }
#ctip .ct-wp { font-size: 12px; }
#ctip .ct-meta { color: rgba(255,255,255,0.45); font-size: 10px; margin-top: 2px; }
/* Stats location badge */
.stats-location { font-family: var(--mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32); display: block; margin-top: 2px; }

/* ── LIVE REFRESH INDICATOR ── */
.refresh-bar { display: flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.08em; }
.refresh-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse-dot 1.5s ease-in-out infinite; }

/* ── GOAL LOG ── */
.goals-table-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow-x: auto; }
table.goals { width: 100%; border-collapse: collapse; font-size: 13px; }
table.goals thead tr { border-bottom: 1px solid var(--ink-20); }
table.goals th { padding: 10px 14px; text-align: left; font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-48); white-space: nowrap; }
table.goals td { padding: 11px 14px; border-bottom: 1px solid var(--ink-06); white-space: nowrap; vertical-align: middle; }
table.goals tr:last-child td { border-bottom: none; }
table.goals tbody tr:hover { background: var(--ink-04); }
.goal-team-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; flex-shrink: 0; }
.goal-scorer { font-weight: 600; }
.goal-assists { font-size: 12px; color: var(--ink-56); }
.player-link { color: inherit; text-decoration: none; border-bottom: 1px solid var(--ink-14); transition: border-color 0.15s; }
.player-link:hover { border-bottom-color: var(--ink); }
.strength-badge { display: inline-block; font-family: var(--display); font-weight: 700; font-size: 9.5px; letter-spacing: 0.14em; padding: 2px 6px; }
.str-pp { background: rgba(234,179,8,0.15); color: #92400e; }
.str-sh { background: rgba(59,130,246,0.15); color: #1e3a5f; }
.str-en { background: rgba(13,13,20,0.08); color: var(--ink-56); }
.goal-score { font-family: var(--mono); font-size: 11px; color: var(--ink-48); font-variant-numeric: tabular-nums; }
.video-link { font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; color: var(--red); opacity: 0.85; transition: opacity 0.15s; display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border: 1px solid rgba(232,0,45,0.25); background: rgba(232,0,45,0.04); }
.video-link:hover { opacity: 1; background: rgba(232,0,45,0.08); }
.wp-swing { font-family: var(--mono); font-size: 11px; font-weight: 600; font-variant-numeric: tabular-nums; }
.wp-swing.pos { color: var(--green); }
.wp-swing.neg { color: var(--red); }

/* ── PLAYER STATS ── */
.player-stats-grid { display: flex; flex-direction: column; gap: 1px; background: var(--ink-14); border: 1px solid var(--ink-14); }
.player-team-card { background: var(--surface); }
.player-team-head { display: flex; align-items: center; gap: 10px; padding: 10px 14px; background: var(--bg-2); border-bottom: 1px solid var(--ink-14); }
.player-team-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
.player-team-label { font-family: var(--display); font-weight: 800; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-56); }
table.ps { width: 100%; border-collapse: collapse; font-size: 13px; }
table.ps thead tr { border-bottom: 1px solid var(--ink-14); }
table.ps th { padding: 8px 10px; font-family: var(--display); font-weight: 700; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-32); white-space: nowrap; cursor: pointer; user-select: none; text-align: center; }
table.ps th:nth-child(2) { text-align: left; }
table.ps th:hover { color: var(--ink); }
table.ps th.sort-asc::after { content: " ↑"; }
table.ps th.sort-desc::after { content: " ↓"; }
table.ps td { padding: 8px 10px; border-bottom: 1px solid var(--ink-04); font-variant-numeric: tabular-nums; white-space: nowrap; text-align: center; }
table.ps td:nth-child(2) { text-align: left; }
table.ps tr:last-child td { border-bottom: none; }
table.ps tbody tr:hover { background: var(--ink-04); }
.ps-name { font-family: var(--body); font-weight: 600; font-size: 13px; }
/* Goalie sub-table */
.goalie-section-head { font-family: var(--display); font-weight: 700; font-size: 9px;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-32);
  padding: 8px 10px 6px; border-top: 2px solid var(--ink-14); margin-top: 2px; }
.ps-num { font-family: var(--mono); font-size: 10px; color: var(--ink-32); }
.ps-pos { font-family: var(--mono); font-size: 10px; color: var(--ink-48); }
.ps-toi { font-family: var(--mono); font-size: 11px; font-variant-numeric: tabular-nums; }
.ps-ixg { font-family: var(--mono); font-size: 11px; font-weight: 600; }
.ps-divider { padding: 5px 8px; background: var(--bg-2); font-family: var(--display); font-weight: 700; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-32); border-top: 1px solid var(--ink-14); }

/* ── SHOT MAP ── */
.shot-map-outer { position: relative; background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; }
.shot-map-rink-wrap { padding: 16px 16px 0; }
.shot-map-svg { width: 100%; display: block; }
.shot-map-legend { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; justify-content: center; padding: 10px 14px; font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.06em; }
.shot-map-legend-team { display: flex; align-items: center; gap: 8px; }
.sml-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.sml-sep { width: 1px; height: 12px; background: var(--ink-14); }
.sml-key { display: flex; align-items: center; gap: 5px; }
/* Tooltip */
#shot-tooltip { position: fixed; pointer-events: none; z-index: 200; background: #0d0d14; color: #fff; border-radius: 4px; padding: 8px 11px; font-family: var(--mono); font-size: 11px; line-height: 1.5; letter-spacing: 0.02em; box-shadow: 0 4px 16px rgba(0,0,0,0.35); display: none; max-width: 200px; }
#shot-tooltip .stt-player { font-family: var(--display); font-weight: 700; font-size: 13px; letter-spacing: 0.04em; margin-bottom: 3px; }
#shot-tooltip .stt-xg { font-weight: 600; }
#shot-tooltip .stt-meta { color: rgba(255,255,255,0.5); font-size: 10px; margin-top: 2px; }

/* ── FROM THE BOT (cards + posts) ── */
.bot-row-label { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px; }
.hscroll { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 12px; scrollbar-width: thin; scrollbar-color: var(--ink-20) transparent; -webkit-overflow-scrolling: touch; }
.hscroll::-webkit-scrollbar { height: 4px; }
.hscroll::-webkit-scrollbar-track { background: transparent; }
.hscroll::-webkit-scrollbar-thumb { background: var(--ink-20); border-radius: 2px; }
/* Card tiles (image posts) */
.bot-card { flex-shrink: 0; width: 260px; background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; display: flex; flex-direction: column; }
.bot-card img { width: 100%; height: auto; display: block; object-fit: cover; }
.bot-card-meta { padding: 8px 10px; display: flex; justify-content: space-between; align-items: center; }
.bot-card-time { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); letter-spacing: 0.06em; }
.bot-card-counts { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); letter-spacing: 0.04em; }
/* Post tiles (text posts) */
.bot-post { flex-shrink: 0; width: 240px; background: var(--surface); border: 1px solid var(--ink-14); padding: 12px 14px; display: flex; flex-direction: column; gap: 8px; }
.bot-post-text { font-family: var(--body); font-size: 12px; line-height: 1.45; color: var(--ink); overflow-hidden; display: -webkit-box; -webkit-line-clamp: 6; -webkit-box-orient: vertical; flex: 1; }
.bot-post-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
.bot-post-time { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); letter-spacing: 0.04em; }
.bot-post-counts { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); letter-spacing: 0.04em; }
.bot-post-link { font-family: var(--mono); font-size: 9px; color: var(--red); opacity: 0.7; text-decoration: none; }
.bot-post-link:hover { opacity: 1; }

/* ── THREE STARS ── */
.stars-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--ink-14); border: 1px solid var(--ink-14); }
.star-card { background: var(--surface); padding: 20px 22px 22px; display: flex; flex-direction: column; gap: 5px; border-top: 3px solid transparent; }
.star-rank { font-family: var(--mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-32); margin-bottom: 4px; }
.star-name { font-family: var(--display); font-weight: 800; font-size: clamp(18px, 2.5vw, 26px); letter-spacing: 0.01em; line-height: 1.05; }
.star-team { font-family: var(--display); font-weight: 700; font-size: 11px; color: var(--ink-48); letter-spacing: 0.14em; text-transform: uppercase; margin-top: 1px; }
.star-stat-line { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; margin-top: 6px; }

.no-data-msg { padding: 32px; text-align: center; font-family: var(--mono); font-size: 12px; color: var(--ink-32); letter-spacing: 0.04em; border: 1px solid var(--ink-14); background: var(--surface); }

/* ── GOAL VIDEO POPUP ── */
.gvp-overlay { position: fixed; inset: 0; z-index: 900; display: flex; align-items: center; justify-content: center; }
.gvp-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.75); }
.gvp-panel { position: relative; z-index: 1; background: #111; border-radius: 8px; width: 100%; max-width: 620px; overflow: hidden; box-shadow: 0 24px 64px rgba(0,0,0,0.6); }
.gvp-header { display: flex; align-items: stretch; background: rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.08); min-height: 38px; }
.gvp-tabs-bar { flex: 1; display: flex; }
.gvp-tab-btn { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; padding: 0 16px; height: 38px; border: none; border-bottom: 2px solid transparent; background: none; color: rgba(255,255,255,0.4); cursor: pointer; transition: color 0.15s; }
.gvp-tab-btn.active { color: #fff; border-bottom-color: #fff; }
.gvp-close { flex-shrink: 0; background: none; border: none; color: rgba(255,255,255,0.4); font-size: 18px; cursor: pointer; padding: 0 16px; line-height: 38px; transition: color 0.15s; }
.gvp-close:hover { color: #fff; }
.gvp-media { background: #000; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; }
.gvp-media video, .gvp-media iframe { width: 100%; height: 100%; display: block; border: none; }
.gvp-info { padding: 14px 18px 16px; }
.gvp-scorer-line { font-family: var(--display); font-weight: 700; font-size: 14px; color: #fff; letter-spacing: 0.04em; }
.gvp-wp-line { font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 4px; letter-spacing: 0.04em; }
.gvp-wp-delta { font-weight: 700; margin-left: 6px; }

/* ── FOOTER ── */
.foot { margin-top: 48px; border-top: 1px solid var(--ink-14); padding: 24px 0; font-family: var(--mono); font-size: 11px; color: var(--ink-32); letter-spacing: 0.04em; }
.foot-inner { max-width: 1280px; margin: 0 auto; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }

/* ── RESPONSIVE ── */
@media (max-width: 720px) {
  .wrap { padding: 0 16px; }
  .mast-inner { padding: 20px 0 24px; }
  .score-grid { padding: 20px 16px 12px; gap: 12px; }
  .card-info-strip { padding: 8px 16px 14px; }
  #section-linescore .period-table-wrap { padding: 0 16px; }
  .team-abbr-big { font-size: clamp(22px, 6vw, 36px); }
  .score-display { font-size: clamp(40px, 10vw, 64px); gap: 10px; }
  #away-logo, #home-logo { width: 56px; height: 56px; }
  .stat-val { font-size: 22px; }
  .stats-4 { grid-template-columns: repeat(2, 1fr); }
  table.goals th, table.goals td { padding: 8px 10px; }
  .stars-grid { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .team-name-small { display: none; }
  .game-meta { font-size: 10px; }
}
</style>
</head>
<body>

<Nav currentPath="/games" />

<div id="loading-state">
  <div class="spinner"></div>
  <span>Loading game…</span>
</div>

<div id="game-content">

  <!-- SCORE MASTHEAD -->
  <section class="game-mast">
    <div class="mast-corners">
      <div class="corner tl"></div><div class="corner tr"></div>
      <div class="corner bl"></div><div class="corner br"></div>
    </div>
    <div class="mast-inner wrap">
      <div class="mast-top">
        <div class="mast-eyebrow"><span class="pip"></span> <span id="mast-breadcrumb">Game</span></div>
        <span id="mast-context" style="font-family:var(--mono);font-size:11px;color:var(--ink-48);letter-spacing:0.06em"></span>
      </div>
      <div class="mast-card">
        <div class="game-card-bar">
          <div class="game-card-bar-half" id="color-bar-away"></div>
          <div class="game-card-bar-half" id="color-bar-home"></div>
        </div>
        <div class="score-grid">
          <div class="team-side away">
            <img id="away-logo" src="" alt="" width="80" height="80" />
            <div class="team-abbr-big" id="away-abbr"></div>
            <div class="team-name-small" id="away-name"></div>
          </div>
          <div class="score-center">
            <div class="score-display">
              <span id="away-score">–</span>
              <span class="score-sep">–</span>
              <span id="home-score">–</span>
            </div>
            <div class="game-meta">
              <span id="status-badge" class="status-badge">Loading</span>
              <div id="game-live-clock" class="game-live-clock"></div>
            </div>
          </div>
          <div class="team-side home">
            <img id="home-logo" src="" alt="" width="80" height="80" />
            <div class="team-abbr-big" id="home-abbr"></div>
            <div class="team-name-small" id="home-name"></div>
          </div>
        </div>
        <div class="card-info-strip">
          <span id="header-info-left" class="header-info-left"></span>
          <span id="header-sog" class="header-info-right"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRE-GAME body -->
  <div id="section-pregame" style="display:none">
    <div class="wrap">
      <div class="pregame-card" style="margin-top:32px">
        <div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--ink-32);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:8px">Puck Drop</div>
          <div class="pregame-time" id="pregame-time">–</div>
          <div class="pregame-venue" id="pregame-venue" style="margin-top:6px"></div>
        </div>
        <div id="pregame-broadcasts" class="pregame-broadcasts" style="display:none"></div>
      </div>
    </div>
  </div>

  <!-- LIVE / FINAL body -->
  <div id="section-game-body" style="display:none">
    <div class="wrap">

      <!-- THREE STARS — final state only, shown first -->
      <div class="section" id="section-stars" style="display:none">
        <div class="section-head">
          <h2 class="section-title">Three <span class="accent">Stars</span></h2>
        </div>
        <div class="stars-grid" id="stars-grid"></div>
      </div>

      <!-- KEY STATS — comparison table -->
      <div class="section" id="section-stats">
        <div class="section-head">
          <h2 class="section-title">Key <span class="accent">Stats</span></h2>
          <span class="section-meta" id="stats-source-label"></span>
        </div>
        <div class="stats-two-col">
          <!-- All situations card -->
          <div class="stats-compare" id="stats-strip">
            <div class="stats-compare-head">
              <div>
                <span class="stats-abbr" id="stats-away-abbr"></span>
                <span class="stats-location">Away</span>
              </div>
              <span class="stats-card-label">All Sit</span>
              <div style="text-align:right">
                <span class="stats-abbr right" id="stats-home-abbr"></span>
                <span class="stats-location" style="text-align:right">Home</span>
              </div>
            </div>
            <div class="stats-compare-row">
              <span class="stat-compare-num" id="away-goals">–</span>
              <span class="stat-compare-key">Goals</span>
              <span class="stat-compare-num right" id="home-goals">–</span>
            </div>
            <div class="stats-compare-row">
              <span class="stat-compare-num" id="away-sog">–</span>
              <span class="stat-compare-key">Shots</span>
              <span class="stat-compare-num right" id="home-sog">–</span>
            </div>
            <div class="stats-compare-row">
              <span class="stat-compare-num" id="away-xgf">–</span>
              <span class="stat-compare-key">xG</span>
              <span class="stat-compare-num right" id="home-xgf">–</span>
            </div>
            <div class="stats-compare-row">
              <span class="stat-compare-num" id="away-xgfpct">–</span>
              <span class="stat-compare-key">xG Share</span>
              <span class="stat-compare-num right" id="home-xgfpct">–</span>
            </div>
          </div>
          <!-- 5v5 card -->
          <div class="stats-compare" id="stats-strip-5v5">
            <div class="stats-compare-head">
              <div>
                <span class="stats-abbr" id="stats-away-abbr-5v5"></span>
                <span class="stats-location">Away</span>
              </div>
              <span class="stats-card-label">5v5</span>
              <div style="text-align:right">
                <span class="stats-abbr right" id="stats-home-abbr-5v5"></span>
                <span class="stats-location" style="text-align:right">Home</span>
              </div>
            </div>
            <div class="stats-compare-row">
              <span class="stat-compare-num" id="away-xg5v5">–</span>
              <span class="stat-compare-key">xG</span>
              <span class="stat-compare-num right" id="home-xg5v5">–</span>
            </div>
            <div class="stats-compare-row">
              <span class="stat-compare-num" id="away-xg5v5pct">–</span>
              <span class="stat-compare-key">xG Share</span>
              <span class="stat-compare-num right" id="home-xg5v5pct">–</span>
            </div>
          </div>
        </div>
      </div>

      <!-- GAME CHARTS — stacked, no tabs -->
      <div class="section" id="section-chart">
        <div class="section-head">
          <h2 class="section-title">Game <span class="accent">Charts</span></h2>
          <div id="chart-section-meta" class="section-meta">HGB xG model · 5v5</div>
        </div>
        <div class="chart-wrap">
          <div class="chart-no-data" id="chart-no-data" style="display:none">Win probability not available.</div>
          <svg id="wp-chart" class="chart-svg" viewBox="0 0 800 220" preserveAspectRatio="none"></svg>
        </div>
        <div class="chart-wrap">
          <div class="chart-sub-label">5v5 xG</div>
          <div class="chart-no-data" id="xg-no-data" style="display:none">xG data not available.</div>
          <svg id="xg-chart" class="chart-svg" viewBox="0 0 840 220" preserveAspectRatio="none"></svg>
        </div>
      </div>

      <!-- GOAL LOG -->
      <div class="section" id="section-goals">
        <div class="section-head">
          <h2 class="section-title">Goal <span class="accent">Log</span></h2>
          <div style="display:flex;align-items:center;gap:12px">
            <div class="refresh-bar" id="refresh-indicator" style="display:none">
              <span class="refresh-dot"></span>
              <span id="refresh-label">Live · updating</span>
            </div>
            <span class="section-meta" id="goal-count-label"></span>
          </div>
        </div>
        <div id="goals-container"></div>
      </div>

      <!-- SHOT MAP -->
      <div class="section" id="section-shotmap" style="display:none">
        <div class="section-head">
          <h2 class="section-title">Shot <span class="accent">Map</span></h2>
          <span class="section-meta" id="shotmap-meta">All situations · HGB xG model</span>
        </div>
        <div class="shot-map-outer">
          <div class="shot-map-rink-wrap">
            <svg id="shot-map-svg" class="shot-map-svg" viewBox="0 0 800 340" preserveAspectRatio="xMidYMid meet"></svg>
          </div>
          <div class="shot-map-legend" id="shot-map-legend"></div>
        </div>
      </div>

      <!-- PLAYER STATS -->
      <div class="section" id="section-player-stats" style="display:none">
        <div class="section-head">
          <h2 class="section-title">Player <span class="accent">Stats</span></h2>
          <span class="section-meta">ixG · HGB xG model · all-sit</span>
        </div>
        <div class="player-stats-grid" id="player-stats-grid"></div>
      </div>

      <!-- FROM THE BOT — cards + posts -->
      <div class="section" id="section-bot" style="display:none;padding-bottom:56px">
        <div class="section-head">
          <h2 class="section-title">From <span class="accent">the Bot</span></h2>
          <span class="section-meta" id="bot-handle-label"></span>
        </div>
        <div id="bot-cards-row" style="display:none">
          <div class="bot-row-label">Cards</div>
          <div class="hscroll" id="bot-cards-scroll"></div>
        </div>
        <div id="bot-posts-row" style="margin-top:20px;display:none">
          <div class="bot-row-label">Posts</div>
          <div class="hscroll" id="bot-posts-scroll"></div>
        </div>
      </div>

      <!-- PHASE 2 PLACEHOLDER -->
      <div class="section" id="section-coming-soon" style="padding-bottom:56px">
        <div class="no-data-msg" style="color:var(--ink-32);font-family:var(--mono);font-size:11px;letter-spacing:0.06em">
          On-ice xGF/xGA · Phase 2
        </div>
      </div>

    </div>
  </div>

</div><!-- /game-content -->

<!-- GOAL VIDEO POPUP -->
<div id="gvp" class="gvp-overlay" style="display:none" aria-modal="true" role="dialog">
  <div class="gvp-backdrop" id="gvp-backdrop"></div>
  <div class="gvp-panel">
    <div class="gvp-header">
      <div class="gvp-tabs-bar" id="gvp-tabs" style="display:none">
        <button class="gvp-tab-btn active" data-gvp-tab="gif">HGB GIF</button>
        <button class="gvp-tab-btn" data-gvp-tab="highlight">NHL Highlight</button>
      </div>
      <button class="gvp-close" id="gvp-close" aria-label="Close">✕</button>
    </div>
    <div class="gvp-media">
      <video id="gvp-video" controls autoplay playsinline style="display:none"></video>
      <iframe id="gvp-iframe" allowfullscreen allow="autoplay; encrypted-media" style="display:none"></iframe>
    </div>
    <div class="gvp-info">
      <div class="gvp-scorer-line" id="gvp-scorer"></div>
      <div class="gvp-wp-line" id="gvp-wp"></div>
    </div>
  </div>
</div>

<!-- CHART TOOLTIP -->
<div id="ctip">
  <div class="ct-team" id="ctip-team"></div>
  <div class="ct-sub" id="ctip-sub"></div>
  <div class="ct-wp" id="ctip-wp"></div>
  <div class="ct-meta" id="ctip-meta"></div>
</div>

<!-- SHOT TOOLTIP -->
<div id="shot-tooltip" role="tooltip">
  <div class="stt-player" id="stt-player"></div>
  <div class="stt-xg" id="stt-xg"></div>
  <div class="stt-meta" id="stt-meta"></div>
</div>

<footer class="foot">
  <div class="foot-inner">
    <a href="/" style="font-family:var(--display);font-weight:800;font-size:16px;letter-spacing:0.04em;text-transform:uppercase;display:inline-flex;align-items:center;gap:5px">
      Hockey<span style="width:4px;height:4px;background:var(--red);border-radius:50%;display:inline-block;margin:0 3px"></span>Gamebot
    </a>
    <span>Analytics by HGB · xG model XGBoost AUC 0.77</span>
  </div>
</footer>

<script define:vars={{ _sparklineMap }}>
  window._HGB_SPARKLINES = _sparklineMap;
</script>

<script is:inline>
(function () {
  'use strict';

  // Restore URL if we arrived via the 404.html fallback (no _redirects support)
  const _r = sessionStorage.getItem('hgb_game_redirect');
  if (_r) { sessionStorage.removeItem('hgb_game_redirect'); history.replaceState(null, '', _r); }

  const HGB_API = 'https://api.hockeygamebot.com';
  const LIVE_REFRESH_MS = 30_000;

  const TC = {
    ANA:['#F47A38','#B09862'], BOS:['#FFB81C','#000000'], BUF:['#002654','#FDBB30'],
    CAR:['#CC0000','#000000'], CBJ:['#002654','#CE1126'], CGY:['#C8102E','#F1BE48'],
    CHI:['#CF0A2C','#000000'], COL:['#6F263D','#236192'], DAL:['#006847','#8F8F8C'],
    DET:['#CE1126','#FFFFFF'], EDM:['#FF4C00','#041E42'], FLA:['#041E42','#C8102E'],
    LAK:['#111111','#A2AAAD'], MIN:['#154734','#A6192E'], MTL:['#AF1E2D','#00205B'],
    NSH:['#FFB81C','#041E42'], NJD:['#CE1126','#000000'], NYI:['#00539B','#F47D30'],
    NYR:['#0038A8','#CE1126'], OTT:['#DA1A32','#000000'], PHI:['#FA4616','#000000'],
    PIT:['#000000','#FCB514'], SEA:['#001628','#99D9D9'], SJS:['#006D75','#EA7200'],
    STL:['#002F87','#FDB827'], TBL:['#00205B','#FFFFFF'], TOR:['#00205B','#FFFFFF'],
    UTA:['#71AFE5','#090909'], VAN:['#00205B','#00843D'], VGK:['#B4975A','#333F48'],
    WSH:['#041E42','#C8102E'], WPG:['#041E42','#004C97'],
  };

  function teamColor(abbr) { return (TC[abbr] || ['#E8002D','#0d0d14'])[0]; }
  function logoUrl(abbr) { return `https://assets.nhle.com/logos/nhl/svg/${abbr}_dark.svg`; }
  function esc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function fmt2(v) { return v != null ? Number(v).toFixed(2) : '–'; }
  function playerSlug(name, id) {
    if (!name || !id) return null;
    const base = String(name).toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g, '')
      .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    return `${base}-${id}`;
  }

  // ── Global chart tooltip ─────────────────────────────────────────────────────
  function showCtip(e, team, sub, wp, meta) {
    const t = document.getElementById('ctip');
    document.getElementById('ctip-team').innerHTML = team || '';
    document.getElementById('ctip-sub').innerHTML  = sub  || '';
    document.getElementById('ctip-wp').innerHTML   = wp   || '';
    document.getElementById('ctip-meta').textContent = meta || '';
    document.getElementById('ctip-sub').style.display  = sub  ? '' : 'none';
    document.getElementById('ctip-wp').style.display   = wp   ? '' : 'none';
    document.getElementById('ctip-meta').style.display = meta ? '' : 'none';
    t.style.display = 'block';
    moveCtip(e);
  }
  function moveCtip(e) {
    const t = document.getElementById('ctip');
    if (!t || t.style.display === 'none') return;
    const pad = 14, tw = t.offsetWidth, th = t.offsetHeight;
    let lx = e.clientX + pad, ly = e.clientY - th / 2;
    if (lx + tw > window.innerWidth - 4) lx = e.clientX - tw - pad;
    if (ly < 4) ly = 4;
    if (ly + th > window.innerHeight - 4) ly = window.innerHeight - th - 4;
    t.style.left = lx + 'px'; t.style.top = ly + 'px';
  }
  function hideCtip() { const t = document.getElementById('ctip'); if (t) t.style.display = 'none'; }

  function tLabel(t) {
    const p = Math.floor(t / 1200) + 1, sec = t % 1200;
    const m = Math.floor(sec / 60).toString().padStart(2,'0');
    const s = Math.floor(sec % 60).toString().padStart(2,'0');
    return (p > 3 ? 'OT' : `P${p}`) + ` ${m}:${s}`;
  }

  function gameState(status) {
    const s = (status || '').toUpperCase();
    if (s === 'OFF' || s === 'FINAL') return 'final';
    if (s === 'LIVE' || s === 'CRIT') return 'live';
    return 'pre';
  }

  function strengthBadge(str) {
    if (!str || str === 'even') return '';
    const cls = str === 'pp' ? 'str-pp' : str === 'sh' ? 'str-sh' : 'str-en';
    return `<span class="strength-badge ${cls}">${esc(str.toUpperCase())}</span>`;
  }

  // ── Header ──────────────────────────────────────────────────────────────────

  function renderHeader(boxscore, state) {
    const away = boxscore.awayTeam || {};
    const home = boxscore.homeTeam || {};

    const awayAbbr = away.abbrev || '???';
    const homeAbbr = home.abbrev || '???';
    const awayColor = teamColor(awayAbbr);
    const homeColor = teamColor(homeAbbr);

    const date = boxscore.gameDate
      ? new Date(boxscore.gameDate + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' })
      : '';
    const venue = boxscore.venue?.default || '';

    document.title = `${awayAbbr} @ ${homeAbbr} · ${date} · HockeyGameBot`;

    // Breadcrumb
    const breadcrumb = document.getElementById('mast-breadcrumb');
    if (breadcrumb) breadcrumb.textContent = `${awayAbbr} @ ${homeAbbr}`;
    const ctx = document.getElementById('mast-context');
    if (ctx) {
      const gt = boxscore.gameType;
      ctx.textContent = gt === 3 ? '2026 Stanley Cup Playoffs' : gt === 1 ? '2025-26 Preseason' : '2025-26 Regular Season';
    }

    document.getElementById('away-logo').src = logoUrl(awayAbbr);
    document.getElementById('away-logo').alt = awayAbbr;
    document.getElementById('away-abbr').textContent = awayAbbr;
    document.getElementById('away-name').textContent = away.placeName?.default || '';
    document.getElementById('home-logo').src = logoUrl(homeAbbr);
    document.getElementById('home-logo').alt = homeAbbr;
    document.getElementById('home-abbr').textContent = homeAbbr;
    document.getElementById('home-name').textContent = home.placeName?.default || '';

    document.getElementById('color-bar-away').style.background = awayColor;
    document.getElementById('color-bar-home').style.background = homeColor;

    // Info strip left: venue · date
    const infoLeft = [date, venue].filter(Boolean).join(' · ');
    document.getElementById('header-info-left').textContent = infoLeft;

    // Broadcasts in info strip right (pregame only — SOG now in stats table)
    if (state === 'pre') {
      const broadcasts = (boxscore.tvBroadcasts || []).map(b => b.network || b.name || '').filter(Boolean);
      document.getElementById('header-sog').textContent = broadcasts.join(' · ');
    } else {
      document.getElementById('header-sog').textContent = '';
    }

    const badge = document.getElementById('status-badge');
    const clockEl = document.getElementById('game-live-clock');

    if (state === 'final') {
      document.getElementById('away-score').textContent = away.score ?? '–';
      document.getElementById('home-score').textContent = home.score ?? '–';
      const lastPeriodType = boxscore.gameOutcome?.lastPeriodType || '';
      const finalPeriod = boxscore.periodDescriptor?.number || 3;
      const isOT = lastPeriodType === 'OT' || finalPeriod === 4;
      const isSO = lastPeriodType === 'SO' || finalPeriod >= 5;
      badge.textContent = isSO ? 'Final · SO' : isOT ? 'Final · OT' : 'Final';
      badge.className = 'status-badge final';
      clockEl.classList.remove('visible');
    } else if (state === 'live') {
      document.getElementById('away-score').textContent = away.score ?? '0';
      document.getElementById('home-score').textContent = home.score ?? '0';
      const clock = boxscore.clock || {};
      const period = boxscore.period || boxscore.periodDescriptor?.number || 1;
      const periodLabel = period > 3 ? 'OT' : `P${period}`;
      const timeStr = clock.inIntermission ? 'INT' : (clock.timeRemaining || '');
      badge.textContent = 'Live';
      badge.className = 'status-badge live';
      clockEl.textContent = timeStr ? `${periodLabel} · ${timeStr}` : periodLabel;
      clockEl.classList.add('visible');
    } else {
      document.getElementById('away-score').textContent = '–';
      document.getElementById('home-score').textContent = '–';
      document.querySelector('.score-sep').style.display = 'none';
      const t = boxscore.startTimeUTC
        ? new Date(boxscore.startTimeUTC).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZoneName: 'short' })
        : 'Upcoming';
      badge.textContent = t;
      badge.className = 'status-badge pre';
      clockEl.classList.remove('visible');
    }

    return { awayAbbr, homeAbbr, awayColor, homeColor, awayScore: away.score ?? 0, homeScore: home.score ?? 0 };
  }

  // ── Pre-game section ─────────────────────────────────────────────────────────

  function renderPregame(boxscore) {
    const venue = boxscore.venue?.default || '';
    const broadcasts = boxscore.tvBroadcasts || [];

    const timeEl = document.getElementById('pregame-time');
    if (boxscore.startTimeUTC) {
      const d = new Date(boxscore.startTimeUTC);
      timeEl.textContent = d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZoneName: 'short' });
    } else {
      timeEl.textContent = 'Time TBD';
    }

    document.getElementById('pregame-venue').textContent = venue;

    if (broadcasts.length) {
      const chips = broadcasts.map(b => `<span class="broadcast-chip">${esc(b.network || b.name || '')}</span>`).join('');
      const wrap = document.getElementById('pregame-broadcasts');
      wrap.innerHTML = `<div style="font-family:var(--mono);font-size:10px;color:var(--ink-32);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:8px">Broadcasts</div>${chips}`;
      wrap.style.display = 'flex';
      wrap.style.flexDirection = 'column';
      wrap.style.gap = '8px';
    }

    document.getElementById('section-pregame').style.display = '';
  }

  // ── Key Stats ────────────────────────────────────────────────────────────────

  function renderStats(flow, boxscore, eventsData, awayAbbr, homeAbbr, awayColor, homeColor) {
    const awayAbbrEl = document.getElementById('stats-away-abbr');
    const homeAbbrEl = document.getElementById('stats-home-abbr');
    awayAbbrEl.textContent = awayAbbr;
    homeAbbrEl.textContent = homeAbbr;
    awayAbbrEl.style.color = awayColor;
    homeAbbrEl.style.color = homeColor;

    const away = boxscore.awayTeam || {};
    const home = boxscore.homeTeam || {};

    // Goals
    const awGoals = away.score ?? null, hmGoals = home.score ?? null;
    const awGoalsEl = document.getElementById('away-goals');
    const hmGoalsEl = document.getElementById('home-goals');
    if (awGoals != null && hmGoals != null) {
      awGoalsEl.textContent = awGoals;
      hmGoalsEl.textContent = hmGoals;
      awGoalsEl.style.color = awGoals > hmGoals ? awayColor : awGoals < hmGoals ? 'var(--ink-32)' : 'var(--ink)';
      hmGoalsEl.style.color = hmGoals > awGoals ? homeColor : hmGoals < awGoals ? 'var(--ink-32)' : 'var(--ink)';
    }

    // Populate 5v5 card abbrevs
    const a5Abbr = document.getElementById('stats-away-abbr-5v5');
    const h5Abbr = document.getElementById('stats-home-abbr-5v5');
    if (a5Abbr) { a5Abbr.textContent = awayAbbr; a5Abbr.style.color = awayColor; }
    if (h5Abbr) { h5Abbr.textContent = homeAbbr; h5Abbr.style.color = homeColor; }

    // 5v5 xG from events
    const xg5v5 = { home: 0, away: 0 };
    for (const ev of (eventsData?.events || [])) {
      if (!['SHOT_ON_GOAL','MISSED_SHOT','GOAL'].includes(ev.event_type)) continue;
      if (ev.payload?.situationCode !== '1551') continue;
      const xg = parseFloat(ev.payload?.xg);
      if (isNaN(xg) || xg <= 0) continue;
      const isHome = ev.event_team_id != null && String(ev.event_team_id) === String(ev.home_team_id);
      if (isHome) xg5v5.home += xg; else xg5v5.away += xg;
    }
    const aw5El = document.getElementById('away-xg5v5');
    const hm5El = document.getElementById('home-xg5v5');
    if (xg5v5.home > 0 || xg5v5.away > 0) {
      aw5El.textContent = xg5v5.away.toFixed(2);
      hm5El.textContent = xg5v5.home.toFixed(2);
      aw5El.style.color = xg5v5.away > xg5v5.home ? awayColor : xg5v5.away < xg5v5.home ? 'var(--ink-32)' : 'var(--ink)';
      hm5El.style.color = xg5v5.home > xg5v5.away ? homeColor : xg5v5.home < xg5v5.away ? 'var(--ink-32)' : 'var(--ink)';
      // 5v5 xG Share
      const tot5 = xg5v5.home + xg5v5.away;
      const aw5PctEl = document.getElementById('away-xg5v5pct');
      const hm5PctEl = document.getElementById('home-xg5v5pct');
      if (aw5PctEl && hm5PctEl && tot5 > 0) {
        const aw5Pct = xg5v5.away / tot5 * 100, hm5Pct = 100 - aw5Pct;
        aw5PctEl.textContent = `${aw5Pct.toFixed(1)}%`;
        hm5PctEl.textContent = `${hm5Pct.toFixed(1)}%`;
        aw5PctEl.style.color = aw5Pct > hm5Pct ? awayColor : 'var(--ink-32)';
        hm5PctEl.style.color = hm5Pct > aw5Pct ? homeColor : 'var(--ink-32)';
      }
    }

    // SOG
    const awaySog = away.sog ?? away.shots ?? null;
    const homeSog = home.sog ?? home.shots ?? null;
    const awSogEl = document.getElementById('away-sog');
    const hmSogEl = document.getElementById('home-sog');
    if (awaySog != null && homeSog != null) {
      awSogEl.textContent = awaySog;
      hmSogEl.textContent = homeSog;
      awSogEl.style.color = awaySog > homeSog ? awayColor : awaySog < homeSog ? 'var(--ink-32)' : 'var(--ink)';
      hmSogEl.style.color = homeSog > awaySog ? homeColor : homeSog < awaySog ? 'var(--ink-32)' : 'var(--ink)';
    }

    // xGF from flow
    const pts = flow.points || [];
    const last = [...pts].reverse().find(p => p.xg_home != null);
    if (!last) { document.getElementById('stats-strip').style.visibility = 'hidden'; return; }

    const homeXg = last.xg_home;
    const awayXg = last.xg_away;
    const total  = homeXg + awayXg;
    const homePct = total > 0 ? (homeXg / total * 100) : 50;
    const awayPct = 100 - homePct;

    const awXgEl  = document.getElementById('away-xgf');
    const hmXgEl  = document.getElementById('home-xgf');
    const awPctEl = document.getElementById('away-xgfpct');
    const hmPctEl = document.getElementById('home-xgfpct');

    awXgEl.textContent  = fmt2(awayXg);
    hmXgEl.textContent  = fmt2(homeXg);
    awPctEl.textContent = `${awayPct.toFixed(1)}%`;
    hmPctEl.textContent = `${homePct.toFixed(1)}%`;

    awXgEl.style.color  = awayXg > homeXg ? awayColor : awayXg < homeXg ? 'var(--ink-32)' : 'var(--ink)';
    hmXgEl.style.color  = homeXg > awayXg ? homeColor : homeXg < awayXg ? 'var(--ink-32)' : 'var(--ink)';
    awPctEl.style.color = awayPct > homePct ? awayColor : 'var(--ink-32)';
    hmPctEl.style.color = homePct > awayPct ? homeColor : 'var(--ink-32)';

    document.getElementById('stats-source-label').textContent = 'All sit · HGB xG model';
  }

  // ── WP Chart ────────────────────────────────────────────────────────────────

  function renderChart(flow, homeColor, awayColor, homeAbbr, awayAbbr, state, awayScore, homeScore) {
    const svg    = document.getElementById('wp-chart');
    const noData = document.getElementById('chart-no-data');
    const pts = (flow.points || []).filter(p => p.wp != null && p.t != null).sort((a, b) => a.t - b.t);

    // For final games, append a synthetic 100% point for the winner
    if (state === 'final' && pts.length) {
      const maxT = pts[pts.length - 1].t;
      pts.push({ t: maxT + 60, wp: (awayScore > homeScore) ? 0.0 : 1.0 });
    }

    if (pts.length < 2) {
      svg.style.display = 'none';
      noData.style.display = '';
      return;
    }

    const W = 800, H = 220, PAD = 18;
    const midY = H / 2;
    const maxT = Math.max(...pts.map(p => p.t));
    const px = t  => (t / maxT) * W;
    const py = wp => PAD + (1 - wp) * (H - 2 * PAD);
    const uid = Math.random().toString(36).slice(2, 8);

    const coords   = pts.map(p => ({ x: px(p.t), y: py(p.wp) }));
    const linePts  = coords.map(c => `${c.x.toFixed(1)},${c.y.toFixed(1)}`).join(' ');
    const areaPath = [
      `0,${py(pts[0].wp).toFixed(1)}`,
      ...coords.map(c => `${c.x.toFixed(1)},${c.y.toFixed(1)}`),
      `${coords[coords.length-1].x.toFixed(1)},${midY}`,
      `0,${midY}`,
    ].join(' ');

    const periodLines = [1200, 2400, 3600].filter(t => t < maxT);
    const periodZones = [];
    if (maxT > 1200) periodZones.push({ x: px(1200) + 4, label: 'P2' });
    if (maxT > 2400) periodZones.push({ x: px(2400) + 4, label: 'P3' });
    if (maxT > 3600) periodZones.push({ x: px(3600) + 4, label: 'OT' });

    function interpWp(t) {
      const before = [...pts].reverse().find(p => p.t <= t);
      const after  = pts.find(p => p.t >= t);
      if (!before) return after?.wp ?? 0.5;
      if (!after || before === after) return before.wp;
      const frac = (t - before.t) / (after.t - before.t);
      return before.wp + frac * (after.wp - before.wp);
    }

    // Goal dots — circles only, no text labels; tooltip via data-wpdot
    const goalDots = (flow.goals || []).map(g => {
      const gx = px(g.t).toFixed(1), gy = py(interpWp(g.t)).toFixed(1);
      const color = g.is_home ? homeColor : awayColor;
      const tip = JSON.stringify({ s: g.scorer||'', a: g.assists||[], h: !!g.is_home, t: g.t }).replace(/'/g,'&#39;');
      return `<circle cx="${gx}" cy="${gy}" r="5" fill="${color}" stroke="#fff" stroke-width="1.5" fill-opacity="0.95" data-wpdot='${tip}' style="cursor:pointer"/>`;
    }).join('');

    // End-of-line label
    const lastWp   = pts[pts.length - 1].wp;
    const winAbbr  = lastWp >= 0.5 ? homeAbbr : awayAbbr;
    const winColor = lastWp >= 0.5 ? homeColor : awayColor;
    const winPct   = (Math.max(lastWp, 1 - lastWp) * 100).toFixed(0);
    const endLabel = `<text x="${(W-6)}" y="${(py(lastWp)+4).toFixed(1)}" text-anchor="end" font-family="'Barlow Condensed',sans-serif" font-size="11" font-weight="700" fill="${winColor}">${esc(winAbbr)} ${winPct}%</text>`;

    svg.innerHTML = `
      <defs>
        <clipPath id="cu-${uid}"><rect x="0" y="0" width="${W}" height="${midY}"/></clipPath>
        <clipPath id="cl-${uid}"><rect x="0" y="${midY}" width="${W}" height="${H - midY}"/></clipPath>
      </defs>
      ${periodLines.map(t => `<line x1="${px(t).toFixed(1)}" y1="0" x2="${px(t).toFixed(1)}" y2="${H}" stroke="rgba(13,13,20,0.08)" stroke-width="1" stroke-dasharray="4,3"/>`).join('')}
      <line x1="0" y1="${midY}" x2="${W}" y2="${midY}" stroke="rgba(13,13,20,0.14)" stroke-width="0.8" stroke-dasharray="4,4"/>
      <text x="${W-6}" y="${(midY-3).toFixed(1)}" text-anchor="end" font-family="'JetBrains Mono',monospace" font-size="7" fill="rgba(13,13,20,0.35)">EVEN</text>
      ${[{wp:0.75,lbl:'75%'},{wp:0.25,lbl:'25%'}].map(r => {
        const ry = py(r.wp).toFixed(1);
        return `<line x1="0" y1="${ry}" x2="${W}" y2="${ry}" stroke="rgba(13,13,20,0.05)" stroke-width="0.6"/>
                <text x="5" y="${(parseFloat(ry)-3).toFixed(1)}" text-anchor="start" font-family="'JetBrains Mono',monospace" font-size="7" fill="rgba(13,13,20,0.3)">${r.lbl}</text>`;
      }).join('')}
      <polygon points="${areaPath}" fill="${homeColor}" fill-opacity="0.07" clip-path="url(#cu-${uid})"/>
      <polygon points="${areaPath}" fill="${awayColor}" fill-opacity="0.07" clip-path="url(#cl-${uid})"/>
      <polyline points="${linePts}" fill="none" stroke="${homeColor}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" clip-path="url(#cu-${uid})"/>
      <polyline points="${linePts}" fill="none" stroke="${awayColor}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" clip-path="url(#cl-${uid})"/>
      ${goalDots}
      ${periodZones.map(z => `<text x="${z.x.toFixed(1)}" y="${(PAD+9).toFixed(1)}" font-family="'Barlow Condensed',sans-serif" font-size="9" fill="rgba(13,13,20,0.3)" letter-spacing="0.08em">${z.label}</text>`).join('')}
      ${endLabel}`;

    // WP chart hover tooltip
    svg.addEventListener('mousemove', e => {
      const dot = e.target.closest('[data-wpdot]');
      if (dot) {
        try {
          const g = JSON.parse(dot.dataset.wpdot);
          const color = g.h ? homeColor : awayColor;
          const wp = interpWp(g.t);
          showCtip(e,
            `<span style="color:${color}">${esc(g.h ? homeAbbr : awayAbbr)}</span> — ${esc(g.s || 'Goal')}`,
            g.a?.length ? esc(g.a.join(', ')) : null,
            `${esc(homeAbbr)} <strong>${(wp*100).toFixed(1)}%</strong>  ·  ${esc(awayAbbr)} <strong>${((1-wp)*100).toFixed(1)}%</strong>`,
            tLabel(g.t)
          );
        } catch { hideCtip(); }
        return;
      }
      const rect = svg.getBoundingClientRect();
      const relX = (e.clientX - rect.left) / rect.width * W;
      if (relX < 2 || relX > W - 2) return hideCtip();
      const t = Math.min(Math.max((relX / W) * maxT, 0), maxT);
      const wp = interpWp(t);
      showCtip(e, null, null,
        `${esc(homeAbbr)} <strong style="color:${homeColor}">${(wp*100).toFixed(1)}%</strong>  ·  ${esc(awayAbbr)} <strong style="color:${awayColor}">${((1-wp)*100).toFixed(1)}%</strong>`,
        tLabel(t)
      );
    });
    svg.addEventListener('mouseleave', hideCtip);
  }

  // ── xG Step Chart (5v5, built from events endpoint) ─────────────────────────

  function renderXgChart(eventsData, flow, homeColor, awayColor, homeAbbr, awayAbbr) {
    const svg    = document.getElementById('xg-chart');
    const noData = document.getElementById('xg-no-data');

    function toGameSecs(period, tip) {
      if (!tip || !period) return null;
      const ci = tip.indexOf(':');
      if (ci === -1) return null;
      const m = parseInt(tip.slice(0, ci), 10), s = parseInt(tip.slice(ci + 1), 10);
      if (isNaN(m) || isNaN(s)) return null;
      const e = m * 60 + s;
      return period <= 3 ? (period - 1) * 1200 + e : 3600 + (period - 4) * 300 + e;
    }

    const homeShots = [], awayShots = [];
    for (const ev of (eventsData?.events || [])) {
      if (ev.event_type !== 'SHOT_ON_GOAL' && ev.event_type !== 'MISSED_SHOT' && ev.event_type !== 'GOAL') continue;
      if (ev.payload?.situationCode !== '1551') continue;
      const xg = parseFloat(ev.payload?.xg);
      if (isNaN(xg) || xg <= 0) continue;
      const t = toGameSecs(ev.period, ev.payload?.timeInPeriod);
      if (t === null) continue;
      const isHome = ev.event_team_id != null && String(ev.event_team_id) === String(ev.home_team_id);
      (isHome ? homeShots : awayShots).push({ t, xg });
    }
    homeShots.sort((a, b) => a.t - b.t);
    awayShots.sort((a, b) => a.t - b.t);

    if (!homeShots.length && !awayShots.length) { svg.style.display = 'none'; noData.style.display = ''; return; }

    function buildCum(shots) {
      let c = 0; const r = [{ t: 0, c: 0 }];
      for (const s of shots) { c += s.xg; r.push({ t: s.t, c }); }
      return r;
    }
    const homeCum = buildCum(homeShots);
    const awayCum = buildCum(awayShots);

    const homeTotal = homeCum[homeCum.length - 1]?.c ?? 0;
    const awayTotal = awayCum[awayCum.length - 1]?.c ?? 0;
    const rawMax = Math.max(homeTotal, awayTotal, 0.5);
    const yMax = Math.ceil(rawMax * 2) / 2 + 0.3;

    // Derive tMax from flow points so period dividers cover the full game
    const flowPts = (flow.points || []).filter(p => p.t != null);
    const tMax = flowPts.length
      ? Math.max(...flowPts.map(p => p.t))
      : Math.max(...homeShots.map(s => s.t), ...awayShots.map(s => s.t), 3600);

    const W = 840, H = 220;
    const PAD = { l: 34, r: 64, t: 14, b: 24 }; // r=64 to fit end-of-line labels
    const cW = W - PAD.l - PAD.r;
    const cH = H - PAD.t - PAD.b;
    const cx = t  => PAD.l + (t / tMax) * cW;
    const cy = xg => PAD.t + (1 - xg / yMax) * cH;

    function stepPath(pts) {
      if (!pts.length) return '';
      let d = `M${cx(0).toFixed(1)},${cy(0).toFixed(1)}`;
      for (let i = 1; i < pts.length; i++) {
        d += ` H${cx(pts[i].t).toFixed(1)} V${cy(pts[i].c).toFixed(1)}`;
      }
      d += ` H${cx(tMax).toFixed(1)}`;
      return d;
    }

    const yTicks = [];
    for (let v = 0; v <= Math.ceil(rawMax); v++) yTicks.push(v);

    const periodLines = [1200, 2400, 3600].filter(t => t < tMax);
    const periodZones = [];
    if (tMax > 1200) periodZones.push({ x: cx(1200) + 3, label: 'P2' });
    if (tMax > 2400) periodZones.push({ x: cx(2400) + 3, label: 'P3' });
    if (tMax > 3600) periodZones.push({ x: cx(3600) + 3, label: 'OT' });

    function cumAt(pts, t) { let v = 0; for (const p of pts) { if (p.t > t) break; v = p.c; } return v; }
    const xgGoalDots = (flow.goals || []).filter(g => g.t >= 0 && g.t <= tMax).map(g => {
      const cum   = cumAt(g.is_home ? homeCum : awayCum, g.t);
      const color = g.is_home ? homeColor : awayColor;
      const tip   = JSON.stringify({ h: !!g.is_home, t: g.t, s: g.scorer||'' }).replace(/'/g,'&#39;');
      return `<circle cx="${cx(g.t).toFixed(1)}" cy="${cy(cum).toFixed(1)}" r="3.5" fill="${color}" stroke="#fff" stroke-width="1.2" data-xgdot='${tip}' style="cursor:pointer"/>`;
    }).join('');

    // End-of-line labels — prevent overlap if within 14px
    let hLY = cy(homeTotal), aLY = cy(awayTotal);
    if (Math.abs(hLY - aLY) < 14) { hLY < aLY ? (hLY -= 7, aLY += 7) : (hLY += 7, aLY -= 7); }
    const xEnd = (PAD.l + cW + 6).toFixed(1);
    const endLabels = `
      <text x="${xEnd}" y="${(hLY + 4).toFixed(1)}" font-family="'Barlow Condensed',sans-serif" font-size="10" font-weight="700" fill="${homeColor}">${esc(homeAbbr)} ${homeTotal.toFixed(2)}</text>
      <text x="${xEnd}" y="${(aLY + 4).toFixed(1)}" font-family="'Barlow Condensed',sans-serif" font-size="10" font-weight="700" fill="${awayColor}">${esc(awayAbbr)} ${awayTotal.toFixed(2)}</text>
    `;

    svg.innerHTML = `
      ${yTicks.map(v => {
        const y = cy(v).toFixed(1);
        return `<line x1="${PAD.l}" y1="${y}" x2="${PAD.l + cW}" y2="${y}" stroke="rgba(13,13,20,0.08)" stroke-width="${v === 0 ? 1.2 : 0.6}"/>
                <text x="${(PAD.l - 5).toFixed(1)}" y="${(parseFloat(y) + 4).toFixed(1)}" text-anchor="end" font-family="'JetBrains Mono',monospace" font-size="9" fill="rgba(13,13,20,0.45)">${v}</text>`;
      }).join('')}
      ${periodLines.map(t => `<line x1="${cx(t).toFixed(1)}" y1="${PAD.t}" x2="${cx(t).toFixed(1)}" y2="${PAD.t + cH}" stroke="rgba(13,13,20,0.07)" stroke-width="1" stroke-dasharray="4,3"/>`).join('')}
      <path d="${stepPath(awayCum)}" fill="none" stroke="#fff" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="${stepPath(homeCum)}" fill="none" stroke="#fff" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="${stepPath(awayCum)}" fill="none" stroke="${awayColor}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="${stepPath(homeCum)}" fill="none" stroke="${homeColor}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      ${xgGoalDots}
      ${periodZones.map(z => `<text x="${z.x}" y="${(PAD.t + 10).toFixed(1)}" font-family="'Barlow Condensed',sans-serif" font-size="9" fill="rgba(13,13,20,0.28)" letter-spacing="0.08em">${z.label}</text>`).join('')}
      ${endLabels}
    `;

    // xG chart hover tooltip
    svg.addEventListener('mousemove', e => {
      const dot = e.target.closest('[data-xgdot]');
      if (dot) {
        try {
          const g = JSON.parse(dot.dataset.xgdot);
          const color = g.h ? homeColor : awayColor;
          const hXg = cumAt(homeCum, g.t), aXg = cumAt(awayCum, g.t);
          showCtip(e,
            `<span style="color:${color}">${esc(g.h ? homeAbbr : awayAbbr)}</span> — ${esc(g.s || 'Goal')}`,
            null,
            `${esc(homeAbbr)} <strong>${hXg.toFixed(2)}</strong>  ·  ${esc(awayAbbr)} <strong>${aXg.toFixed(2)}</strong>`,
            tLabel(g.t)
          );
        } catch { hideCtip(); }
        return;
      }
      const rect = svg.getBoundingClientRect();
      const relX = (e.clientX - rect.left) / rect.width * W;
      const tX = relX - PAD.l; if (tX < 0 || tX > cW) return hideCtip();
      const t = Math.min(Math.max((tX / cW) * tMax, 0), tMax);
      const hXg = cumAt(homeCum, t), aXg = cumAt(awayCum, t);
      showCtip(e, null, null,
        `${esc(homeAbbr)} <strong style="color:${homeColor}">${hXg.toFixed(2)}</strong>  ·  ${esc(awayAbbr)} <strong style="color:${awayColor}">${aXg.toFixed(2)}</strong>`,
        tLabel(t)
      );
    });
    svg.addEventListener('mouseleave', hideCtip);
  }

  // ── Goal log with WP SWING ───────────────────────────────────────────────────

  function computeWpSwing(goalT, isHome, pts) {
    const wpPts = pts.filter(p => p.wp != null && p.t != null);
    if (!wpPts.length) return null;
    const before = [...wpPts].reverse().find(p => p.t < goalT);
    const after  = wpPts.find(p => p.t > goalT);
    const wpBefore = before?.wp ?? 0.5;
    const wpAfter  = after?.wp  ?? wpBefore;
    // delta from home perspective; flip for away scorer so swing is always "for scoring team"
    const delta = wpAfter - wpBefore;
    return isHome ? delta : -delta;
  }

  function renderGoals(flow, homeAbbr, awayAbbr) {
    const goals = flow.goals || [];
    const pts   = flow.points || [];
    const container = document.getElementById('goals-container');
    document.getElementById('goal-count-label').textContent =
      goals.length ? `${goals.length} goal${goals.length !== 1 ? 's' : ''}` : '';

    if (!goals.length) {
      container.innerHTML = '<div class="no-data-msg">No goals yet.</div>';
      _gvpGoals = [];
      return;
    }

    // Pre-compute WP swing and store for the video popup to reference
    _gvpGoals = goals.map(g => {
      const swing = computeWpSwing(g.t, g.is_home, pts);
      const wpBefore = swing != null
        ? ([...pts].filter(p => p.wp != null && p.t < g.t).reverse()[0]?.wp ?? null)
        : null;
      // _wpBefore/_wpAfter are from home team's perspective (matches the WP chart)
      const wpAfter = wpBefore != null && swing != null ? wpBefore + (g.is_home ? swing : -swing) : null;
      // _swing is from SCORING team's perspective (always positive when scoring team gains)
      return { ...g, _swing: swing, _wpBefore: wpBefore, _wpAfter: wpAfter };
    });

    const hasWp = pts.some(p => p.wp != null);

    const rows = goals.map((g, i) => {
      const abbr   = g.is_home ? homeAbbr : awayAbbr;
      const color  = teamColor(abbr);
      const period = Math.floor(g.t / 1200) + 1;
      const sec    = g.t % 1200;
      const m = Math.floor(sec / 60).toString().padStart(2, '0');
      const s = (sec % 60).toString().padStart(2, '0');
      const periodLabel = period > 3 ? 'OT' : `P${period}`;
      const timeLabel = `${periodLabel} ${m}:${s}`;
      const hasVideo = g.goal_video_url || g.highlight_clip_id;
      const videoHtml = hasVideo
        ? `<button class="video-link" onclick="openGoalVideo(${i})" type="button">▶ Watch</button>`
        : '';

      let swingHtml = '<span style="color:var(--ink-32)">–</span>';
      if (hasWp) {
        const swing = computeWpSwing(g.t, g.is_home, pts);
        if (swing != null) {
          const pct  = (swing * 100).toFixed(1);
          const cls  = swing >= 0 ? 'pos' : 'neg';
          const sign = swing >= 0 ? '+' : '';
          swingHtml  = `<span class="wp-swing ${cls}">${sign}${pct}%</span>`;
        }
      }

      return `<tr>
        <td><span style="font-family:var(--mono);font-size:11px;color:var(--ink-48)">${i + 1}</span></td>
        <td><span style="font-family:var(--mono);font-size:11px">${esc(timeLabel)}</span></td>
        <td><span class="goal-team-dot" style="background:${color}"></span><span style="font-family:var(--display);font-weight:700;font-size:12px;letter-spacing:0.08em">${esc(abbr)}</span></td>
        <td><span class="goal-scorer">${g.scorer ? `<a href="/stats/player/${playerSlug(g.scorer, g.scorer_id)}" class="player-link">${esc(g.scorer)}</a>` : '–'}</span></td>
        <td><span class="goal-assists">${(g.assists || []).length ? (g.assists.map((a, ai) => {
            const aid = (g.assist_ids || [])[ai];
            return aid ? `<a href="/stats/player/${playerSlug(a, aid)}" class="player-link">${esc(a)}</a>` : esc(a);
          }).join(', ')) : '–'}</span></td>
        <td>${strengthBadge(g.strength)}</td>
        <td><span class="goal-score">${esc(g.score || '')}</span></td>
        <td>${swingHtml}</td>
        <td>${videoHtml}</td>
      </tr>`;
    }).join('');

    container.innerHTML = `<div class="goals-table-wrap">
      <table class="goals">
        <thead><tr>
          <th>#</th><th>Time</th><th>Team</th><th>Scorer</th>
          <th>Assists</th><th>Str</th><th>Score</th><th>WP Swing</th><th></th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
  }

  // ── Goal Video Popup ─────────────────────────────────────────────────────────

  const BRIGHTCOVE = 'https://players.brightcove.net/6415718365001/EXtG1xJ7H_default/index.html';
  let _gvpGoals = [];  // set by renderGoals so onclick buttons can reference by index

  function openGoalVideo(idx) {
    const g = _gvpGoals[idx];
    if (!g) return;

    const hasGif       = !!g.goal_video_url;
    const hasHighlight = !!g.highlight_clip_id;
    const hasBoth      = hasGif && hasHighlight;

    const gvp     = document.getElementById('gvp');
    const tabs    = document.getElementById('gvp-tabs');
    const video   = document.getElementById('gvp-video');
    const iframe  = document.getElementById('gvp-iframe');
    const scorer  = document.getElementById('gvp-scorer');
    const wpEl    = document.getElementById('gvp-wp');

    // Scorer info
    const assists = (g.assists || []).join(', ');
    scorer.textContent = g.scorer ? (assists ? `${g.scorer} · ${assists}` : g.scorer) : 'Goal';

    // WP swing — show from scoring team's perspective (matches goal log)
    if (g._swing != null && g._wpBefore != null && g._wpAfter != null) {
      const swingPct = (g._swing * 100).toFixed(1);
      const sign     = g._swing >= 0 ? '+' : '';
      const color    = g._swing >= 0 ? 'var(--green)' : 'var(--red)';
      wpEl.innerHTML = `Win probability (home): <strong>${(g._wpBefore * 100).toFixed(1)}%</strong> → <strong>${(g._wpAfter * 100).toFixed(1)}%</strong><span class="gvp-wp-delta" style="color:${color}">${sign}${swingPct}%</span>`;
    } else {
      wpEl.textContent = '';
    }

    // Tabs — only when both sources available
    tabs.style.display = hasBoth ? 'flex' : 'none';

    function showGif() {
      tabs.querySelectorAll('.gvp-tab-btn').forEach(b => b.classList.remove('active'));
      tabs.querySelector('[data-gvp-tab="gif"]')?.classList.add('active');
      video.src = g.goal_video_url;
      video.style.display = 'block';
      iframe.style.display = 'none';
      iframe.src = '';
    }
    function showHighlight() {
      tabs.querySelectorAll('.gvp-tab-btn').forEach(b => b.classList.remove('active'));
      tabs.querySelector('[data-gvp-tab="highlight"]')?.classList.add('active');
      iframe.src = `${BRIGHTCOVE}?videoId=${g.highlight_clip_id}&autoplay=true`;
      iframe.style.display = 'block';
      video.style.display = 'none';
      video.src = '';
    }

    // Default: prefer GIF (our content), fall back to Brightcove
    if (hasGif) showGif(); else showHighlight();

    // Wire tab clicks (replace to avoid duplicate listeners)
    tabs.querySelectorAll('.gvp-tab-btn').forEach(btn => {
      const clone = btn.cloneNode(true);
      btn.parentNode.replaceChild(clone, btn);
      clone.addEventListener('click', () => {
        clone.dataset.gvpTab === 'gif' ? showGif() : showHighlight();
      });
    });

    gvp.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeGvp() {
    const gvp   = document.getElementById('gvp');
    const video = document.getElementById('gvp-video');
    const iframe = document.getElementById('gvp-iframe');
    gvp.style.display = 'none';
    video.src = '';
    iframe.src = '';
    document.body.style.overflow = '';
  }

  // ── Shot Map ────────────────────────────────────────────────────────────────

  function renderShotMap(eventsData, flow, awayAbbr, homeAbbr, awayColor, homeColor) {
    const SHOT_EVENTS = new Set(['SHOT_ON_GOAL', 'MISSED_SHOT', 'BLOCKED_SHOT', 'GOAL']);
    const shots = (eventsData?.events || []).filter(ev =>
      SHOT_EVENTS.has(ev.event_type) &&
      ev.payload?.details?.xCoord != null &&
      ev.payload?.details?.yCoord != null
    );
    if (!shots.length) return;

    // NHL rink: x ∈ [-100, 100] ft, y ∈ [-42.5, 42.5] ft
    // SVG: 800 × 340 px @ 4px/ft. Center = (400, 170).
    const toX = x => 400 + x * 4;
    const toY = y => 170 - y * 4;

    // ── Rink background ──────────────────────────────────────────────────────
    // toY(3)=158 (top, +3ft), toY(-3)=182 (bottom, -3ft), crease r=24px (6ft)
    // Crease D: arc from top to bottom of goal line, clockwise for left (into ice),
    //           counter-clockwise for right, then Z closes along goal line — no bezier!
    // Goal nets: 4ft deep behind goal line = 16px. Left at x=28–44, right at x=756–772.
    const rink = `
      <defs>
        <clipPath id="rink-clip"><rect x="0" y="0" width="800" height="340" rx="28"/></clipPath>
      </defs>
      <rect x="0" y="0" width="800" height="340" rx="28" fill="#F7F9FB"/>
      <g clip-path="url(#rink-clip)">
        <!-- Center red line -->
        <line x1="400" y1="0" x2="400" y2="340" stroke="#C8102E" stroke-width="3.5"/>
        <!-- Blue lines -->
        <line x1="300" y1="0" x2="300" y2="340" stroke="#003DA5" stroke-width="2.5"/>
        <line x1="500" y1="0" x2="500" y2="340" stroke="#003DA5" stroke-width="2.5"/>
        <!-- Goal lines -->
        <line x1="44" y1="0" x2="44" y2="340" stroke="#C8102E" stroke-width="1.2"/>
        <line x1="756" y1="0" x2="756" y2="340" stroke="#C8102E" stroke-width="1.2"/>
        <!-- Goal creases: D = arc from (gl, ±3ft) clockwise into ice, close with Z -->
        <path d="M44,158 A24,24 0 0 1 44,182 Z" fill="rgba(0,61,165,0.12)" stroke="#003DA5" stroke-width="1"/>
        <path d="M756,158 A24,24 0 0 0 756,182 Z" fill="rgba(0,61,165,0.12)" stroke="#003DA5" stroke-width="1"/>
        <!-- Goal nets: 4ft (16px) deep behind goal line, 6ft (24px) wide -->
        <rect x="28" y="158" width="16" height="24" fill="rgba(13,13,20,0.06)" stroke="rgba(13,13,20,0.3)" stroke-width="1.5"/>
        <rect x="756" y="158" width="16" height="24" fill="rgba(13,13,20,0.06)" stroke="rgba(13,13,20,0.3)" stroke-width="1.5"/>
        <!-- Center circle + dot -->
        <circle cx="400" cy="170" r="60" fill="none" stroke="#C8102E" stroke-width="1.2"/>
        <circle cx="400" cy="170" r="3" fill="#C8102E"/>
        <!-- Offensive zone face-off circles + center dots: x=±69ft, y=±22ft -->
        <circle cx="${toX(-69)}" cy="${toY(22)}" r="48" fill="none" stroke="#C8102E" stroke-width="1"/>
        <circle cx="${toX(-69)}" cy="${toY(22)}" r="3" fill="#C8102E"/>
        <circle cx="${toX(-69)}" cy="${toY(-22)}" r="48" fill="none" stroke="#C8102E" stroke-width="1"/>
        <circle cx="${toX(-69)}" cy="${toY(-22)}" r="3" fill="#C8102E"/>
        <circle cx="${toX(69)}" cy="${toY(22)}" r="48" fill="none" stroke="#C8102E" stroke-width="1"/>
        <circle cx="${toX(69)}" cy="${toY(22)}" r="3" fill="#C8102E"/>
        <circle cx="${toX(69)}" cy="${toY(-22)}" r="48" fill="none" stroke="#C8102E" stroke-width="1"/>
        <circle cx="${toX(69)}" cy="${toY(-22)}" r="3" fill="#C8102E"/>
        <!-- Neutral zone face-off dots: x=±20ft, y=±22ft -->
        <circle cx="${toX(-20)}" cy="${toY(22)}" r="3" fill="#C8102E"/>
        <circle cx="${toX(-20)}" cy="${toY(-22)}" r="3" fill="#C8102E"/>
        <circle cx="${toX(20)}" cy="${toY(22)}" r="3" fill="#C8102E"/>
        <circle cx="${toX(20)}" cy="${toY(-22)}" r="3" fill="#C8102E"/>
      </g>
      <!-- Boards outline on top (outside clip so it sits above all elements) -->
      <rect x="0" y="0" width="800" height="340" rx="28" fill="none" stroke="rgba(13,13,20,0.2)" stroke-width="2"/>
    `;

    // ── Shot markers ─────────────────────────────────────────────────────────
    function periodToSecs(period, tip) {
      if (!tip || !period) return null;
      const ci = tip.indexOf(':');
      if (ci === -1) return null;
      const m = parseInt(tip.slice(0, ci), 10), s = parseInt(tip.slice(ci + 1), 10);
      if (isNaN(m) || isNaN(s)) return null;
      const e = m * 60 + s;
      return period <= 3 ? (period - 1) * 1200 + e : 3600 + (period - 4) * 300 + e;
    }

    const markers = shots.map((ev, i) => {
      const d = ev.payload?.details || {};
      const isHome = ev.event_team_id != null && String(ev.event_team_id) === String(ev.home_team_id);
      const period = ev.period || 1;
      // Even periods (2, 4…): teams have switched ends — negate both axes to restore P1 orientation
      const flip = (period % 2 === 0);
      const x = toX(flip ? -d.xCoord : d.xCoord).toFixed(1);
      const y = toY(flip ? -d.yCoord : d.yCoord).toFixed(1);
      const color = isHome ? homeColor : awayColor;
      const abbr  = isHome ? homeAbbr : awayAbbr;
      const type  = ev.event_type;
      const xgVal = parseFloat(ev.payload?.xg);
      const xgStr = !isNaN(xgVal) && xgVal > 0 ? xgVal.toFixed(3) : null;

      // Determine player name
      const player = d.shootingPlayerName || d.scoringPlayerName || d.blockingPlayerName || '';
      // Time label
      const p = ev.period || 1;
      const tip = ev.payload?.timeInPeriod || '';
      const pLabel = p > 3 ? 'OT' : `P${p}`;
      const timeLabel = tip ? `${pLabel} ${tip}` : pLabel;
      const shotLabel = type === 'GOAL' ? 'Goal' : type === 'SHOT_ON_GOAL' ? 'Shot on goal' : type === 'MISSED_SHOT' ? 'Missed shot' : 'Blocked shot';

      // Encode tooltip data as JSON in data attribute
      const tipData = JSON.stringify({
        player: player || abbr,
        team: abbr,
        shot: shotLabel,
        xg: xgStr,
        time: timeLabel,
        type,
      });

      if (type === 'GOAL') {
        // Larger circle with white ring
        return `<circle cx="${x}" cy="${y}" r="6.5" fill="${color}" stroke="#fff" stroke-width="2" data-tip='${tipData.replace(/'/g,"&#39;")}' style="cursor:pointer"/>`;
      } else if (type === 'SHOT_ON_GOAL') {
        return `<circle cx="${x}" cy="${y}" r="4" fill="${color}" fill-opacity="0.75" stroke="${color}" stroke-width="0.5" data-tip='${tipData.replace(/'/g,"&#39;")}' style="cursor:pointer"/>`;
      } else if (type === 'MISSED_SHOT') {
        return `<circle cx="${x}" cy="${y}" r="3.5" fill="none" stroke="${color}" stroke-opacity="0.5" stroke-width="1.2" data-tip='${tipData.replace(/'/g,"&#39;")}' style="cursor:pointer"/>`;
      } else {
        // Blocked: small X
        const s = 3;
        return `<g transform="translate(${x},${y})" data-tip='${tipData.replace(/'/g,"&#39;")}' style="cursor:pointer">
          <line x1="${-s}" y1="${-s}" x2="${s}" y2="${s}" stroke="${color}" stroke-opacity="0.4" stroke-width="1.5"/>
          <line x1="${s}" y1="${-s}" x2="${-s}" y2="${s}" stroke="${color}" stroke-opacity="0.4" stroke-width="1.5"/>
        </g>`;
      }
    }).join('');

    const svg = document.getElementById('shot-map-svg');
    svg.innerHTML = rink + markers;

    // ── Legend ───────────────────────────────────────────────────────────────
    const isAway = ev => String(ev.event_team_id) !== String(ev.home_team_id);
    const awayAttempts = shots.filter(ev => isAway(ev)).length;
    const homeAttempts = shots.length - awayAttempts;
    const awaySog   = shots.filter(ev => isAway(ev)  && (ev.event_type === 'SHOT_ON_GOAL' || ev.event_type === 'GOAL')).length;
    const homeSog   = shots.filter(ev => !isAway(ev) && (ev.event_type === 'SHOT_ON_GOAL' || ev.event_type === 'GOAL')).length;
    const awayGoals = shots.filter(ev => isAway(ev)  && ev.event_type === 'GOAL').length;
    const homeGoals = shots.filter(ev => !isAway(ev) && ev.event_type === 'GOAL').length;

    document.getElementById('shot-map-legend').innerHTML = `
      <div class="shot-map-legend-team">
        <div class="sml-dot" style="background:${awayColor}"></div>
        <span style="color:${awayColor};font-weight:600">${esc(awayAbbr)}</span>
        <span>${awayAttempts} att · ${awaySog} SOG · ${awayGoals}G</span>
      </div>
      <div class="sml-sep"></div>
      <div class="shot-map-legend-team">
        <div class="sml-dot" style="background:${homeColor}"></div>
        <span style="color:${homeColor};font-weight:600">${esc(homeAbbr)}</span>
        <span>${homeAttempts} att · ${homeSog} SOG · ${homeGoals}G</span>
      </div>
      <div class="sml-sep"></div>
      <div class="sml-key"><svg width="10" height="10"><circle cx="5" cy="5" r="4.5" fill="#888" stroke="#fff" stroke-width="1.5"/></svg> Goal</div>
      <div class="sml-key"><svg width="10" height="10"><circle cx="5" cy="5" r="3.5" fill="#888" fill-opacity="0.75"/></svg> SOG</div>
      <div class="sml-key"><svg width="10" height="10"><circle cx="5" cy="5" r="3.5" fill="none" stroke="#888" stroke-width="1.2"/></svg> Missed</div>
      <div class="sml-key"><svg width="10" height="10"><line x1="2" y1="2" x2="8" y2="8" stroke="#888" stroke-width="1.5"/><line x1="8" y1="2" x2="2" y2="8" stroke="#888" stroke-width="1.5"/></svg> Blocked</div>
    `;

    // ── Tooltip ──────────────────────────────────────────────────────────────
    const tooltip  = document.getElementById('shot-tooltip');
    const sttPlayer = document.getElementById('stt-player');
    const sttXg    = document.getElementById('stt-xg');
    const sttMeta  = document.getElementById('stt-meta');

    function showTip(e, data) {
      sttPlayer.textContent = data.player;
      sttXg.innerHTML = `${esc(data.shot)}${data.xg ? ` · <span style="color:#4ade80">${data.xg} xG</span>` : ''}`;
      sttMeta.textContent = `${data.team} · ${data.time}`;
      tooltip.style.display = 'block';
      moveTip(e);
    }
    function moveTip(e) {
      const pad = 14;
      const tw  = tooltip.offsetWidth;
      const th  = tooltip.offsetHeight;
      let lx = e.clientX + pad;
      let ly = e.clientY - th / 2;
      if (lx + tw > window.innerWidth - 8) lx = e.clientX - tw - pad;
      if (ly < 4) ly = 4;
      if (ly + th > window.innerHeight - 4) ly = window.innerHeight - th - 4;
      tooltip.style.left = lx + 'px';
      tooltip.style.top  = ly + 'px';
    }
    function hideTip() { tooltip.style.display = 'none'; }

    svg.addEventListener('mouseover', e => {
      const t = e.target.closest('[data-tip]');
      if (!t) return hideTip();
      try { showTip(e, JSON.parse(t.dataset.tip)); } catch { hideTip(); }
    });
    svg.addEventListener('mousemove', e => {
      if (tooltip.style.display === 'block') moveTip(e);
    });
    svg.addEventListener('mouseout', e => {
      if (!e.target.closest('[data-tip]')) hideTip();
    });
    // Mobile tap
    svg.addEventListener('click', e => {
      const t = e.target.closest('[data-tip]');
      if (!t) return hideTip();
      try {
        showTip(e, JSON.parse(t.dataset.tip));
        setTimeout(hideTip, 3000);
      } catch { hideTip(); }
    });

    document.getElementById('section-shotmap').style.display = '';
  }

  // ── Player Stats ─────────────────────────────────────────────────────────────

  let _currentGameId = '';

  function renderPlayerStats(boxscore, eventsData, awayAbbr, homeAbbr, awayColor, homeColor) {
    const pbs = boxscore.playerByGameStats;
    if (!pbs) return;

    // Build ixG map from events (all-situations)
    const ixgByPlayer = {};
    for (const ev of (eventsData?.events || [])) {
      if (ev.event_type !== 'SHOT_ON_GOAL' && ev.event_type !== 'MISSED_SHOT' && ev.event_type !== 'GOAL') continue;
      const xg = parseFloat(ev.payload?.xg);
      if (isNaN(xg) || xg <= 0) continue;
      const pid = ev.payload?.details?.shootingPlayerId || ev.payload?.details?.scoringPlayerId;
      if (!pid) continue;
      ixgByPlayer[pid] = (ixgByPlayer[pid] || 0) + xg;
    }

    // Sort state per team card: { col, dir }
    const sortState = { away: { col: 'ixg', dir: -1 }, home: { col: 'ixg', dir: -1 } };

    function toiToSecs(toi) {
      if (!toi) return 0;
      const [m, s] = toi.split(':').map(Number);
      return (m || 0) * 60 + (s || 0);
    }

    function buildSkaterTable(players, teamKey, color) {
      const colDefs = [
        { key: 'sweaterNumber', label: '#',    val: p => p.sweaterNumber },
        { key: 'name',          label: 'Player',val: p => p.name?.default || '' },
        { key: 'pos',           label: 'Pos',  val: p => p.position },
        { key: 'toi',           label: 'TOI',  val: p => p.toi,           num: p => toiToSecs(p.toi) },
        { key: 'goals',         label: 'G',    val: p => p.goals ?? 0,    num: p => p.goals ?? 0 },
        { key: 'assists',       label: 'A',    val: p => p.assists ?? 0,  num: p => p.assists ?? 0 },
        { key: 'points',        label: 'PTS',  val: p => p.points ?? 0,   num: p => p.points ?? 0 },
        { key: 'plusMinus',     label: '±',    val: p => p.plusMinus != null ? (p.plusMinus > 0 ? `+${p.plusMinus}` : p.plusMinus) : 0, num: p => p.plusMinus ?? 0 },
        { key: 'sog',           label: 'SOG',  val: p => p.sog ?? 0,      num: p => p.sog ?? 0 },
        { key: 'hits',          label: 'HIT',  val: p => p.hits ?? 0,     num: p => p.hits ?? 0 },
        { key: 'blockedShots',  label: 'BLK',  val: p => p.blockedShots ?? 0, num: p => p.blockedShots ?? 0 },
        { key: 'ixg',           label: 'ixG',  val: p => {
            const v = ixgByPlayer[p.playerId];
            return v != null ? v.toFixed(2) : '–';
          }, num: p => ixgByPlayer[p.playerId] ?? 0, hgb: true },
        { key: 'impact',        label: 'Impact',     val: p => '', num: p => 0, impactVal: true },
        { key: 'l10',           label: 'L10 Trend',  val: p => '', num: p => 0, spark: true },
      ];

      const ss = sortState[teamKey];
      const sorted = [...players].sort((a, b) => {
        const col = colDefs.find(c => c.key === ss.col) || colDefs[3];
        const fn  = col.num || (c => 0);
        const av  = fn(a), bv = fn(b);
        return typeof av === 'string' ? av.localeCompare(bv) * ss.dir : (av - bv) * ss.dir;
      });

      const cleanGameId = (_currentGameId || '').replace(/\.0$/, '');
      const ths = colDefs.map(c => {
        if (c.spark || c.impactVal) return `<th data-col="${c.key}" data-team="${teamKey}" style="color:${color};opacity:0.85;text-align:center">${esc(c.label)}</th>`;
        const cls = ss.col === c.key ? (ss.dir === 1 ? 'sort-asc' : 'sort-desc') : '';
        return `<th class="${cls}" data-col="${c.key}" data-team="${teamKey}" style="${c.hgb ? `color:${color};opacity:0.85` : ''}">${esc(c.label)}</th>`;
      }).join('');

      const GS_MIN = -5, GS_MAX = 12;
      function sparkSvg(vals) {
        const smap = window._HGB_SPARKLINES || {};
        const v = vals;
        if (!v || !v.length) return '<span style="color:var(--ink-20);font-size:10px">—</span>';
        const W = 64, H = 18, P = 2;
        const n = v.length;
        const xs = i => (n > 1 ? P + (i / (n-1)) * (W - 2*P) : W/2).toFixed(1);
        const ys = val => (P + (H - 2*P) - ((val - GS_MIN) / (GS_MAX - GS_MIN)) * (H - 2*P)).toFixed(1);
        const zero = ys(0);
        const path = v.map((val, i) => `${i===0?'M':'L'}${xs(i)},${ys(val)}`).join(' ');
        const avg = v.reduce((s, x) => s + x, 0) / v.length;
        const c = avg >= 0 ? '#1a7a3e' : '#E8002D';
        return `<svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}" style="display:block">
          <line x1="${P}" y1="${zero}" x2="${W-P}" y2="${zero}" stroke="rgba(13,13,20,0.10)" stroke-width="1"/>
          <path d="${path}" fill="none" stroke="${c}" stroke-width="1.5" stroke-linejoin="round"/>
          <circle cx="${xs(n-1)}" cy="${ys(v[n-1])}" r="2" fill="${c}"/>
        </svg>`;
      }

      const rows = sorted.map(p => {
        const ixgVal = ixgByPlayer[p.playerId];
        const ixgStyle = ixgVal != null && ixgVal > 0 ? `color:${color};` : 'color:var(--ink-32)';
        return `<tr>${colDefs.map((c, ci) => {
          if (c.impactVal) {
            const entry = (window._HGB_SPARKLINES || {})[p.playerId];
            if (!entry) return `<td style="text-align:center;font-family:var(--mono);font-size:11px;color:var(--ink-32)">—</td>`;
            const idx = entry.gids.indexOf(cleanGameId);
            const v = idx >= 0 ? entry.l10[idx] : null;
            if (v == null) return `<td style="text-align:center;font-family:var(--mono);font-size:11px;color:var(--ink-32)">—</td>`;
            const c2 = v >= 0 ? '#1a7a3e' : '#E8002D';
            return `<td style="text-align:center;font-family:var(--mono);font-size:11px;font-weight:700;color:${c2}">${v >= 0 ? '+' : ''}${v.toFixed(2)}</td>`;
          }
          if (c.spark) {
            const entry = (window._HGB_SPARKLINES || {})[p.playerId];
            return `<td style="padding:2px 8px;vertical-align:middle">${sparkSvg(entry ? entry.l10 : null)}</td>`;
          }
          let td = esc(String(c.val(p)));
          if (ci === 0) td = `<span class="ps-num">${td}</span>`;
          else if (ci === 1) td = `<span class="ps-name">${td}</span>`;
          else if (ci === 2) td = `<span class="ps-pos">${td}</span>`;
          else if (ci === 3) td = `<span class="ps-toi">${td}</span>`;
          else if (c.hgb) td = `<span class="ps-ixg" style="${ixgStyle}">${td}</span>`;
          return `<td>${td}</td>`;
        }).join('')}</tr>`;
      }).join('');

      return `<table class="ps" data-team="${teamKey}">
        <thead><tr>${ths}</tr></thead>
        <tbody>${rows}</tbody>
      </table>`;
    }

    function buildGoalieTable(goalies) {
      const active = goalies.filter(g => g.toi && g.toi !== '00:00');
      if (!active.length) return '';
      const rows = active.map(g => {
        const svPct = g.shotsAgainst > 0 ? (g.saves / g.shotsAgainst * 100).toFixed(1) : '–';
        return `<tr>
          <td><span class="ps-num">${esc(String(g.sweaterNumber))}</span></td>
          <td><span class="ps-name">${esc(g.name?.default || '')}</span></td>
          <td><span class="ps-toi">${esc(g.toi)}</span></td>
          <td>${g.saves ?? 0}</td><td>${g.shotsAgainst ?? 0}</td>
          <td>${g.goalsAgainst ?? 0}</td>
          <td><span style="font-family:var(--mono);font-size:11px">${svPct}%</span></td>
        </tr>`;
      }).join('');
      return `<tr class="ps-divider"><td colspan="7">Goaltenders</td></tr>
        <table class="ps"><thead><tr>
          <th>#</th><th>Goalie</th><th>TOI</th><th>SV</th><th>SA</th><th>GA</th><th>SV%</th>
        </tr></thead><tbody>${rows}</tbody></table>`;
    }

    function buildTeamCard(teamData, teamKey, abbr, color) {
      const fwd  = teamData.forwards  || [];
      const def  = teamData.defense   || [];
      const gols = teamData.goalies   || [];
      const all  = [...fwd, ...def];
      if (!all.length) return '';

      const skaterTbl = buildSkaterTable(all, teamKey, color);

      // Separate goalie table
      const activeGolies = gols.filter(g => g.toi && g.toi !== '00:00');
      let goalieSection = '';
      if (activeGolies.length) {
        const goalieRows = activeGolies.map(g => {
          const sa = g.shotsAgainst ?? 0;
          const sv = g.saves ?? 0;
          const ga = g.goalsAgainst ?? 0;
          const svPct = sa > 0 ? (sv / sa).toFixed(3) : '—';
          return `<tr>
            <td><span class="ps-num">${esc(String(g.sweaterNumber ?? ''))}</span></td>
            <td><span class="ps-name">${esc(g.name?.default || '')}</span></td>
            <td><span class="ps-toi">${esc(g.toi)}</span></td>
            <td>${sa}</td>
            <td>${sv}</td>
            <td>${ga}</td>
            <td style="font-weight:700">${svPct}</td>
          </tr>`;
        }).join('');
        goalieSection = `<div class="goalie-section-head">Goaltenders</div>
          <div style="overflow-x:auto">
            <table class="ps">
              <thead><tr>
                <th>#</th><th>Goalie</th><th>TOI</th>
                <th>SA</th><th>SV</th><th>GA</th><th>SV%</th>
              </tr></thead>
              <tbody>${goalieRows}</tbody>
            </table>
          </div>`;
      }

      return `<div class="player-team-card">
        <div class="player-team-head">
          <div class="player-team-dot" style="background:${color}"></div>
          <span class="player-team-label">${esc(abbr)}</span>
        </div>
        <div style="overflow-x:auto">${skaterTbl}</div>
        ${goalieSection}
      </div>`;
    }

    const away = pbs.awayTeam || {};
    const home = pbs.homeTeam || {};
    const grid = document.getElementById('player-stats-grid');

    function render() {
      grid.innerHTML = [
        buildTeamCard(away, 'away', awayAbbr, awayColor),
        buildTeamCard(home, 'home', homeAbbr, homeColor),
      ].join('');

      // Wire sort clicks
      grid.querySelectorAll('table.ps th[data-col]').forEach(th => {
        th.addEventListener('click', () => {
          const teamKey = th.dataset.team;
          const col     = th.dataset.col;
          const ss      = sortState[teamKey];
          ss.dir = ss.col === col ? -ss.dir : -1;
          ss.col = col;
          render();
        });
      });
    }

    render();
    document.getElementById('section-player-stats').style.display = '';
  }

  // ── Three stars — OFF state only ─────────────────────────────────────────────

  function renderThreeStars(threeStars) {
    if (!threeStars || !threeStars.length) return;

    const starColors = ['#F59E0B', '#94A3B8', '#92400e'];

    const cards = threeStars.slice(0, 3).map((s, i) => {
      // D1: player_name may have full name; player_last_name is fallback
      const name = s.player_name || s.player_last_name || s.name?.default || '';
      const team = s.team_abbrev || s.teamAbbrev || '';

      const statLine = [
        s.goals    != null ? `${s.goals}G`    : null,
        s.assists  != null ? `${s.assists}A`   : null,
        s.saves    != null ? `${s.saves} SV`   : null,
        s.savePctg != null ? `${(s.savePctg * 100).toFixed(1)}%` : null,
      ].filter(Boolean).join(' · ');

      const tColor = teamColor(team);
      return `<div class="star-card" style="border-top-color:${tColor}">
        <div class="star-rank" style="color:${tColor}">${i + 1}${['st','nd','rd'][i]} Star · ${esc(team)}</div>
        <div class="star-name">${esc(name)}</div>
        ${statLine ? `<div class="star-stat-line">${esc(statLine)}</div>` : ''}
      </div>`;
    }).join('');

    document.getElementById('stars-grid').innerHTML = cards;
    document.getElementById('section-stars').style.display = '';
  }

  // ── From the Bot (Bluesky posts + cards) ────────────────────────────────────

  async function renderBotPosts(awayAbbr, homeAbbr, gameDate) {
    const BSKY = 'https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed';
    const dateStr = gameDate; // "2026-05-12"

    async function fetchFeed(handle) {
      try {
        const r = await fetch(`${BSKY}?actor=${handle}.hockeygamebot.com&limit=100`);
        if (!r.ok) return [];
        const d = await r.json();
        return (d.feed || [])
          .map(f => f.post)
          .filter(p => (p.record?.createdAt || '').startsWith(dateStr));
      } catch { return []; }
    }

    const [awayPosts, homePosts] = await Promise.all([
      fetchFeed(awayAbbr.toLowerCase()),
      fetchFeed(homeAbbr.toLowerCase()),
    ]);

    // Deduplicate by uri (away and home bots may both post game-starts etc.)
    const seen = new Set();
    const all = [...awayPosts, ...homePosts].filter(p => {
      if (seen.has(p.uri)) return false;
      seen.add(p.uri); return true;
    }).sort((a, b) => new Date(a.record.createdAt) - new Date(b.record.createdAt));

    if (!all.length) return;

    const cards  = all.filter(p => p.embed?.images?.length);
    const posts  = all.filter(p => !p.embed?.images?.length);

    function fmtTime(iso) {
      return new Date(iso).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZoneName: 'short' });
    }
    function fmtCounts(p) {
      const parts = [];
      if (p.likeCount)   parts.push(`♥ ${p.likeCount}`);
      if (p.repostCount) parts.push(`↻ ${p.repostCount}`);
      return parts.join('  ');
    }
    function bskyUrl(p) {
      const did = p.author?.did || '';
      const rkey = p.uri?.split('/').pop() || '';
      return `https://bsky.app/profile/${p.author?.handle || did}/post/${rkey}`;
    }

    if (cards.length) {
      document.getElementById('bot-cards-scroll').innerHTML = cards.map(p => {
        const img = p.embed.images[0];
        return `<a class="bot-card" href="${bskyUrl(p)}" target="_blank" rel="noopener">
          <img src="${esc(img.fullsize)}" alt="${esc(img.alt || '')}" loading="lazy" />
          <div class="bot-card-meta">
            <span class="bot-card-time">${fmtTime(p.record.createdAt)}</span>
            <span class="bot-card-counts">${fmtCounts(p)}</span>
          </div>
        </a>`;
      }).join('');
      document.getElementById('bot-cards-row').style.display = '';
    }

    if (posts.length) {
      document.getElementById('bot-posts-scroll').innerHTML = posts.map(p => {
        const text = (p.record.text || '').replace(/https?:\/\/\S+/g, '').trim();
        if (!text) return '';
        return `<div class="bot-post">
          <div class="bot-post-text">${esc(text)}</div>
          <div class="bot-post-footer">
            <span class="bot-post-time">${fmtTime(p.record.createdAt)}</span>
            <span class="bot-post-counts">${fmtCounts(p)}</span>
            <a class="bot-post-link" href="${bskyUrl(p)}" target="_blank" rel="noopener">↗</a>
          </div>
        </div>`;
      }).filter(Boolean).join('');
      document.getElementById('bot-posts-row').style.display = '';
    }

    if (cards.length || posts.length) {
      document.getElementById('bot-handle-label').textContent =
        `${awayAbbr.toLowerCase()}.hockeygamebot.com · ${homeAbbr.toLowerCase()}.hockeygamebot.com`;
      document.getElementById('section-bot').style.display = '';
    }
  }

  // ── Main render ─────────────────────────────────────────────────────────────

  function renderGame(boxscore, flow, eventsData, state) {
    const { awayAbbr, homeAbbr, awayColor, homeColor, awayScore, homeScore } =
      renderHeader(boxscore, state);

    if (state === 'pre') {
      renderPregame(boxscore);
    } else {
      document.getElementById('section-game-body').style.display = '';
      renderStats(flow, boxscore, eventsData, awayAbbr, homeAbbr, awayColor, homeColor);
      renderChart(flow, homeColor, awayColor, homeAbbr, awayAbbr, state, awayScore, homeScore);
      renderXgChart(eventsData, flow, homeColor, awayColor, homeAbbr, awayAbbr);
      renderGoals(flow, homeAbbr, awayAbbr);
      renderShotMap(eventsData, flow, awayAbbr, homeAbbr, awayColor, homeColor);
      renderPlayerStats(boxscore, eventsData, awayAbbr, homeAbbr, awayColor, homeColor);
      if (!renderGame._botLoaded) {
        renderGame._botLoaded = true;
        renderBotPosts(awayAbbr, homeAbbr, boxscore.gameDate || '');
      }

      if (state === 'live') {
        document.getElementById('refresh-indicator').style.display = 'flex';
        document.getElementById('chart-section-meta').textContent = '5v5 · HGB xG model · live';
      } else {
        document.getElementById('chart-section-meta').textContent = '5v5 · HGB xG model';
        renderThreeStars(flow.three_stars);
      }
    }
  }

  // ── Init + live-refresh ──────────────────────────────────────────────────────

  async function fetchAll(gameId) {
    const EMPTY_FLOW = { points: [], goals: [], three_stars: null };
    let boxscoreRes;
    try {
      boxscoreRes = await fetch(`${HGB_API}/v1/games/${gameId}/boxscore`);
    } catch (e) {
      throw new Error(`Boxscore unreachable: ${e.message}`);
    }
    if (!boxscoreRes.ok) throw new Error(`Game ${gameId} not found (HTTP ${boxscoreRes.status})`);
    const boxscore = await boxscoreRes.json();
    const [flowRes, eventsRes] = await Promise.all([
      fetch(`${HGB_API}/v1/games/${gameId}/flow`).catch(() => null),
      fetch(`${HGB_API}/v1/games/${gameId}/events?sort=asc`).catch(() => null),
    ]);
    const flow = flowRes?.ok ? await flowRes.json().catch(() => EMPTY_FLOW) : EMPTY_FLOW;
    const eventsData = eventsRes?.ok ? await eventsRes.json().catch(() => null) : null;
    return { boxscore, flow, eventsData };
  }

  async function init() {
    const parts  = window.location.pathname.split('/').filter(Boolean);
    const gameId = parts[parts.length - 1];
    _currentGameId = gameId;  // set early so buildTeamCard can use it

    if (!gameId || gameId === 'games') {
      document.getElementById('loading-state').innerHTML =
        '<p style="font-family:var(--mono);font-size:13px;color:var(--ink-48)">No game selected — visit from the <a href="/playoffs/2026" style="color:var(--red)">scoreboard</a>.</p>';
      return;
    }

    try {
      const { boxscore, flow, eventsData } = await fetchAll(gameId);
      const state = gameState(boxscore.gameState);

      renderGame(boxscore, flow, eventsData, state);

      document.getElementById('loading-state').style.display = 'none';
      document.getElementById('game-content').style.display = 'block';

      if (state === 'live') {
        const interval = setInterval(async () => {
          try {
            const { boxscore: bs, flow: fl, eventsData: ev } = await fetchAll(gameId);
            const newState = gameState(bs.gameState);
            renderGame(bs, fl, ev, newState);
            if (newState !== 'live') {
              clearInterval(interval);
              document.getElementById('refresh-indicator').style.display = 'none';
            }
          } catch (_) { /* silent — stale data OK */ }
        }, LIVE_REFRESH_MS);
      }

    } catch (err) {
      document.getElementById('loading-state').innerHTML =
        `<p style="font-family:var(--mono);font-size:13px;color:var(--red)">${esc(err.message)}</p>
         <a href="/" style="font-family:var(--mono);font-size:12px;color:var(--ink-48)">← Home</a>`;
    }
  }

  // GVP close handlers
  document.getElementById('gvp-close').addEventListener('click', closeGvp);
  document.getElementById('gvp-backdrop').addEventListener('click', closeGvp);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeGvp(); });

  // Expose to inline onclick (IIFE scope workaround)
  window.openGoalVideo = openGoalVideo;

  init();
})();
</script>
</body>
</html>
