---
// HockeyGameBot — /puck-passport — "Puck Passport" attended-games tracker (Phase 0, stateless)
// The interactive dashboard is a React island; everything the user owns lives in
// localStorage (no auth in Phase 0). Everything else is derived from public data.
import Base from '../layouts/Base.astro';
import AttendedTracker from '../components/react/AttendedTracker.tsx';
---

<Base
  title="Puck Passport · HockeyGameBot"
  description="Your Puck Passport — stamp every NHL game you've been to in person and watch it add up: counters, team records, arenas visited, and every player you've seen."
  currentPath={Astro.url.pathname}
>
  <!-- Shared canvas-export surface (window.HGB_Export) — powers the Share card modal. -->
  <script is:inline src="/js/table-export.js" slot="head"></script>

  <style is:global slot="head">
    :root { --semi: 'Barlow Semi-Condensed', sans-serif; }

    .att-wrap { max-width: 1120px; margin: 0 auto; padding: 0 32px; }

    /* ── MASTHEAD ── */
    .att-mast {
      position: relative;
      padding: 52px 0 40px;
      border-bottom: 2px solid var(--ink);
      background-color: var(--bg);
      background-image:
        linear-gradient(var(--ink-04) 1px, transparent 1px),
        linear-gradient(90deg, var(--ink-04) 1px, transparent 1px);
      background-size: 48px 48px;
    }
    .att-mast-ghost {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      font-family: var(--display); font-weight: 800; font-size: clamp(70px, 16vw, 170px);
      letter-spacing: -0.01em; text-transform: uppercase;
      color: var(--ink); opacity: 0.05; pointer-events: none; white-space: nowrap; user-select: none;
    }
    .att-mast-corners { position: absolute; inset: 0; pointer-events: none; }
    .att-corner { position: absolute; width: 16px; height: 16px; opacity: 0.2; }
    .att-corner::before, .att-corner::after { content: ''; position: absolute; background: var(--ink); }
    .att-corner::before { width: 2px; height: 100%; }
    .att-corner::after  { width: 100%; height: 2px; }
    .att-corner.tl { top: 12px; left: 12px; }
    .att-corner.tr { top: 12px; right: 12px; }
    .att-corner.tr::before { right: 0; }
    .att-corner.tr::after  { right: 0; }
    .att-mast-inner { position: relative; z-index: 2; }
    .att-mast-top { display: flex; align-items: center; margin-bottom: 20px;
      font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .att-mast-top-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .att-mast-top-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .att-mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .att-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--red); }
    .att-headline { font-family: var(--display); font-weight: 800; font-size: clamp(40px, 5vw, 64px); letter-spacing: -0.01em; text-transform: uppercase; line-height: 0.95; color: var(--ink); margin-top: 8px; }
    .att-sub { font-family: var(--body); font-size: 15px; color: var(--ink-56); margin-top: 10px; max-width: 560px; line-height: 1.5; }
    .att-note { font-family: var(--mono); font-size: 11px; color: var(--ink-48); margin-top: 12px; }

    /* ── BODY ── */
    .att-body { padding: 40px 0 96px; }
    .att-root { display: flex; flex-direction: column; gap: 44px; }
    .att-loading { font-family: var(--mono); font-size: 13px; color: var(--ink-48); padding: 40px 0; }

    /* Banners (FAIL LOUD) */
    .att-banner { font-family: var(--mono); font-size: 12px; line-height: 1.5; padding: 12px 16px; background: var(--surface); border-left: 3px solid var(--red); color: var(--ink-72); }
    .att-banner-warn { border-left-color: var(--red); }

    /* Counters */
    .att-counters { display: grid; grid-template-columns: repeat(5, 1fr); gap: 2px; background: var(--ink-14); border: 1.5px solid var(--ink); }
    .att-counter { background: var(--surface); padding: 22px 16px 18px; text-align: center; }
    .att-counter-num { font-family: var(--display); font-weight: 800; font-size: clamp(34px, 5vw, 52px); line-height: 1; color: var(--ink); position: relative; }
    .att-counter-pending { color: var(--ink-32); }
    .att-counter-warn { color: var(--red); font-size: 16px; vertical-align: super; margin-left: 3px; cursor: help; }
    .att-counter-label { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-48); margin-top: 10px; }

    /* Share bar */
    .att-share-bar { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-top: -20px; }
    .att-share-btn {
      font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase;
      background: var(--ink); color: var(--surface); border: none; padding: 11px 22px; cursor: pointer; transition: opacity .15s;
    }
    .att-share-btn:hover { opacity: 0.85; }
    .att-share-btn:disabled { opacity: 0.4; cursor: default; }
    .att-share-note { font-family: var(--mono); font-size: 11px; color: var(--ink-48); }
    @media (max-width: 640px) { .att-share-note { display: none; } }

    /* Sections */
    .att-section { }
    .att-section-head { display: flex; align-items: baseline; gap: 12px; border-bottom: 1.5px solid var(--ink); padding-bottom: 10px; margin-bottom: 18px; }
    .att-section-label { font-family: var(--display); font-weight: 800; font-size: 20px; letter-spacing: 0.03em; text-transform: uppercase; }
    .att-section-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-48); margin-left: auto; }

    /* Add-games controls */
    .att-add-controls { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 16px; }
    .att-date, .att-matchup {
      font-family: var(--mono); font-size: 13px; padding: 10px 14px;
      background: var(--surface); border: 1.5px solid var(--ink-20); color: var(--ink); outline: none;
    }
    .att-date:focus, .att-matchup:focus { border-color: var(--ink-56); }
    .att-matchup { flex: 1; min-width: 180px; }
    .att-btn {
      font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase;
      background: var(--ink); color: var(--surface); border: none; padding: 11px 22px; cursor: pointer; transition: opacity .15s;
    }
    .att-btn:hover { opacity: 0.85; }
    .att-btn:disabled { opacity: 0.4; cursor: default; }

    .att-add-results { display: flex; flex-direction: column; background: var(--surface); border: 1.5px solid var(--ink-14); }
    .att-add-empty { font-family: var(--mono); font-size: 12px; color: var(--ink-48); padding: 10px 0; }
    .att-add-row {
      display: grid; grid-template-columns: 120px 70px 1fr auto; align-items: center; gap: 14px;
      padding: 11px 16px; border-bottom: 1px solid var(--ink-10);
      font-family: var(--mono); font-size: 13px;
    }
    .att-add-row:last-child { border-bottom: none; }
    .att-add-row:hover { background: var(--bg-2); }
    .att-add-teams { display: inline-flex; align-items: center; gap: 8px; }
    .att-add-at { color: var(--ink-32); }
    .att-add-score { color: var(--ink-72); font-weight: 600; }
    .att-add-venue { color: var(--ink-48); font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .att-add-btn {
      font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.04em;
      background: var(--surface); border: 1.5px solid var(--ink-20); color: var(--ink); padding: 7px 14px; cursor: pointer; transition: border-color .12s, color .12s; white-space: nowrap;
    }
    .att-add-btn:hover:not(:disabled) { border-color: var(--ink); }
    .att-add-btn.added { color: var(--green); border-color: var(--green); cursor: default; }

    /* Mode toggle (By Team / By Date) */
    .att-mode-toggle { display: inline-flex; gap: 0; border: 1.5px solid var(--ink); margin-bottom: 16px; }
    .att-mode-btn {
      font-family: var(--display); font-weight: 800; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase;
      background: var(--surface); color: var(--ink-56); border: none; padding: 9px 20px; cursor: pointer; transition: background .12s, color .12s;
    }
    .att-mode-btn + .att-mode-btn { border-left: 1.5px solid var(--ink); }
    .att-mode-btn.active { background: var(--ink); color: var(--surface); }
    .att-mode-btn:not(.active):hover { color: var(--ink); }

    /* Selects (team + season + opponent) — mirror the .att-date input styling */
    .att-select {
      font-family: var(--mono); font-size: 13px; padding: 10px 14px;
      background: var(--surface); border: 1.5px solid var(--ink-20); color: var(--ink); outline: none; cursor: pointer;
    }
    .att-select:focus { border-color: var(--ink-56); }

    /* Recall filters row (opponent + home/away chips + score) */
    .att-filters { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 12px; }
    .att-filter-opp { min-width: 160px; }
    .att-chips { display: inline-flex; border: 1.5px solid var(--ink-20); }
    .att-chip-btn {
      font-family: var(--mono); font-size: 12px; font-weight: 600;
      background: var(--surface); color: var(--ink-56); border: none; padding: 9px 14px; cursor: pointer; transition: background .12s, color .12s;
    }
    .att-chip-btn + .att-chip-btn { border-left: 1.5px solid var(--ink-14); }
    .att-chip-btn.active { background: var(--ink); color: var(--surface); }
    .att-chip-btn:not(.active):hover { color: var(--ink); }

    /* Multi-select action bar */
    .att-select-bar { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 12px; }
    .att-select-count { font-family: var(--mono); font-size: 12px; color: var(--ink-56); }
    .att-btn-sm { font-size: 12px; padding: 9px 18px; }

    /* By-team result rows carry a checkbox + date column, plus a dedicated
       column for the PRE/PLAYOFF game-type chip so it never overlaps the score. */
    .att-add-row-team { grid-template-columns: 22px 96px 120px 62px 74px 1fr auto; }
    .att-check { width: 16px; height: 16px; accent-color: var(--ink); cursor: pointer; }
    .att-check:disabled { cursor: default; opacity: 0.4; }
    .att-add-date { color: var(--ink-56); font-size: 12px; }
    .att-add-type { display: inline-flex; align-items: center; }
    .att-add-type .att-chip { margin-left: 0; }
    .att-ot { margin-left: 5px; color: var(--red); font-size: 10px; font-weight: 700; }

    /* Game-type chip */
    .att-chip { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.08em; color: var(--red); border: 1px solid var(--red); padding: 1px 5px; margin-left: 6px; }
    /* Unverified (manual) chip — neutral grey, NOT red, so it reads as "limited" not "special". */
    .att-chip-unverified { color: var(--ink-48); border-color: var(--ink-20); text-transform: uppercase; }

    /* Unverified footnote (near counters) */
    .att-unverified-note { font-family: var(--mono); font-size: 11px; line-height: 1.5; color: var(--ink-56); padding: 8px 12px; background: var(--surface); border-left: 3px solid var(--ink-20); margin-top: -28px; }

    /* Manual fallback (add a game the NHL API can't find) */
    .att-manual { margin-top: 18px; padding-top: 16px; border-top: 1px dashed var(--ink-14); }
    .att-manual-toggle {
      font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--ink-56);
      background: none; border: none; padding: 4px 0; cursor: pointer; text-decoration: underline; text-underline-offset: 3px;
    }
    .att-manual-toggle:hover { color: var(--ink); }
    .att-manual-form { margin-top: 14px; display: flex; flex-direction: column; gap: 12px; max-width: 640px; }
    .att-manual-note { font-family: var(--mono); font-size: 11px; line-height: 1.5; color: var(--ink-48); }
    .att-manual-grid { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
    .att-manual-grid .att-select { flex: 1; min-width: 150px; }
    .att-manual-at, .att-manual-dash { font-family: var(--mono); font-size: 13px; color: var(--ink-32); }
    .att-manual-score {
      font-family: var(--mono); font-size: 13px; padding: 10px 12px; width: 84px;
      background: var(--surface); border: 1.5px solid var(--ink-20); color: var(--ink); outline: none;
    }
    .att-manual-score:focus { border-color: var(--ink-56); }
    .att-manual-hint { font-family: var(--mono); font-size: 10px; color: var(--ink-32); }

    /* Remove button in games table */
    .att-remove { background: none; border: none; color: var(--ink-32); font-size: 13px; cursor: pointer; padding: 4px 6px; line-height: 1; transition: color .12s; }
    .att-remove:hover { color: var(--red); }

    /* Two-column (team records + arenas) */
    .att-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 44px; }

    /* Team records */
    .att-teams { display: flex; flex-direction: column; gap: 4px; }
    .att-team-row { display: flex; align-items: center; gap: 10px; padding: 8px 12px; background: var(--surface); border: 1px solid var(--ink-10); font-family: var(--mono); font-size: 13px; }
    .att-team-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .att-team-abbr { font-weight: 700; min-width: 40px; }
    .att-team-name { color: var(--ink-56); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .att-team-rec { font-weight: 700; }

    /* Home Rinks — one team-coloured pip per current NHL team (collectible). The
       grid auto-fits and wraps cleanly; abbrevs sit under each pip so you can read
       off exactly which teams' home rinks are still missing. */
    .att-rinks {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(38px, 1fr));
      gap: 10px 6px; padding: 12px; background: var(--surface); border: 1px solid var(--ink-10);
    }
    .att-rink { display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .att-rink-pip {
      width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0;
      border: 1px solid var(--ink-10); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);
    }
    .att-rink-abbr { font-family: var(--mono); font-size: 9px; font-weight: 700; color: var(--ink-32); letter-spacing: 0.02em; }
    .att-rink-on .att-rink-abbr { color: var(--ink-72); }
    .att-rinks-substat { margin-top: 8px; font-family: var(--mono); font-size: 11px; color: var(--ink-48); }

    /* Badges (Screwball-style chips) */
    /* Uniform grid: every card is the SAME width so a long blurb wraps inside its
       cell instead of blowing the card wider than its neighbours. Responsive —
       auto-fill reflows columns and never overflows the page. */
    .att-badges { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 12px; }
    .att-badge {
      display: flex; flex-direction: column; gap: 5px;
      background: var(--surface); border: 1.5px solid var(--ink);
      padding: 14px 16px 13px; position: relative;
    }
    /* Colour accent by CATEGORY (mirrors iOS): a short top bar, not a full
       coloured border — every card keeps the same solid ink border (3B). */
    .att-badge::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: var(--badge-accent, var(--ink));
    }
    .att-badge[data-family="game-type"] { --badge-accent: var(--red); }
    .att-badge[data-family="moment"] { --badge-accent: var(--ink); }
    .att-badge[data-family="collection"] { --badge-accent: #B8860B; }
    .att-badge-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .att-badge-label { font-family: var(--body); font-weight: 800; font-size: 14px; letter-spacing: 0.02em; text-transform: uppercase; color: var(--ink); line-height: 1.1; }
    .att-badge-count { font-family: var(--mono); font-weight: 700; font-size: 13px; color: var(--red); flex-shrink: 0; }
    .att-badge-rarity { font-family: var(--mono); font-size: 10px; letter-spacing: 0.03em; color: var(--ink-48); }
    .att-badge-family { color: var(--ink-32); text-transform: uppercase; }
    .att-badge-blurb { font-family: var(--mono); font-size: 10px; line-height: 1.4; color: var(--ink-48); margin-top: 2px; }
    .att-badge-note { font-family: var(--mono); font-size: 10px; line-height: 1.4; color: var(--ink-32); font-style: italic; margin-top: 1px; }

    /* Ghost (unearned) badges — dimmed + dashed "locked" chips; the chase hook.
       Legible on purpose: the label + "1 in N" tease stay readable. */
    .att-badge-ghost {
      border-style: dashed; border-color: var(--ink-14); background: transparent; opacity: 0.66;
    }
    /* Locked cards stay muted regardless of family — grey out the colour accent. */
    .att-badge-ghost::before { background: var(--ink-14); }
    .att-badge-ghost .att-badge-label { color: var(--ink-56); }
    .att-badge-ghost .att-badge-rarity { color: var(--ink-32); }
    .att-badge-ghost-tag {
      font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--ink-32); border: 1px solid var(--ink-14); padding: 1px 5px; flex-shrink: 0;
    }

    /* Milestones Witnessed (mirrors the team-record row aesthetic) */
    .att-milestones { display: flex; flex-direction: column; gap: 4px; }
    .att-milestone { display: flex; align-items: center; gap: 12px; padding: 10px 14px; background: var(--surface); border: 1px solid var(--ink-10); }
    .att-milestone-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .att-milestone-main { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .att-milestone-label { font-family: var(--display); font-weight: 800; font-size: 14px; letter-spacing: 0.02em; text-transform: uppercase; color: var(--ink); line-height: 1.1; }
    .att-milestone-sub { font-family: var(--mono); font-size: 11px; color: var(--ink-56); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* Single-game records (grid, matches counter aesthetic) */
    .att-records { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; background: var(--ink-14); border: 1.5px solid var(--ink); }
    .att-record { background: var(--surface); padding: 18px 16px 16px; }
    .att-record-label { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-48); }
    .att-record-value { font-family: var(--display); font-weight: 800; font-size: clamp(24px, 3.4vw, 30px); line-height: 1; color: var(--ink); margin-top: 8px; }
    .att-record-sub { font-family: var(--mono); font-size: 11px; line-height: 1.4; color: var(--ink-56); margin-top: 7px; }

    /* Empty state — honest "structure you'll fill" hero + ghost badge wall + grey pips */
    .att-empty { text-align: center; padding: 56px 24px; background: var(--surface); border: 1.5px dashed var(--ink-20); }
    .att-empty-hero { text-align: center; padding: 44px 24px; background: var(--surface); border: 1.5px dashed var(--ink-20); }
    .att-empty-title { font-family: var(--display); font-weight: 800; font-size: clamp(26px, 4vw, 34px); text-transform: uppercase; color: var(--ink); }
    .att-empty-sub { font-family: var(--body); font-size: 14px; color: var(--ink-56); margin-top: 8px; max-width: 440px; margin-left: auto; margin-right: auto; line-height: 1.5; }
    .att-empty-cta { margin-top: 20px; }

    @media (max-width: 820px) {
      .att-two-col { grid-template-columns: 1fr; gap: 44px; }
    }
    @media (max-width: 640px) {
      .att-wrap { padding: 0 16px; }
      .att-mast-card { padding: 22px 18px 18px; }
      .att-counters { grid-template-columns: repeat(3, 1fr); }
      .att-records { grid-template-columns: repeat(2, 1fr); }
      .att-badges { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
      .att-add-row { grid-template-columns: 1fr auto; row-gap: 6px; }
      .att-add-row-team { grid-template-columns: 22px 1fr auto; column-gap: 10px; }
      .att-add-date { display: none; }
      .att-add-type { display: none; }
      .att-add-venue { display: none; }
    }
  </style>

  <!-- MASTHEAD -->
  <section class="att-mast">
    <div class="att-mast-ghost">PASSPORT</div>
    <div class="att-mast-corners"><div class="att-corner tl"></div><div class="att-corner tr"></div></div>
    <div class="att-wrap att-mast-inner">
      <div class="att-mast-top">
        <span class="att-mast-top-eyebrow"><span class="pip"></span> HockeyGameBot · Personal Tracker</span>
      </div>
      <div class="att-mast-card">
        <span class="att-eyebrow">Personal Tracker</span>
        <h1 class="att-headline">Puck Passport</h1>
        <p class="att-sub">
          Log the NHL games you've been to in person and see it all add up — periods, goals and shots witnessed,
          team records, arenas visited, and every player you've watched.
        </p>
        <p class="att-note" id="att-mast-note">// Saved in this browser only. Sign in to sync across devices.</p>
      </div>
    </div>
  </section>

  <!-- BODY -->
  <section class="att-body">
    <div class="att-wrap">
      <AttendedTracker client:only="react" />
    </div>
  </section>
</Base>
