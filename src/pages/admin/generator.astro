---
// /admin/generator — HGB Admin: Leaderboard Card Generator
// Auth-gated client-side (same pattern as /admin/insights).
// Fetches player/goalie data from existing API endpoints, renders
// leaderboard cards as HTML, and downloads via html2canvas.
// Content calendar log persisted to D1 via /v1/admin/generator/calendar.
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
---
<!doctype html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Card Generator · HGB Admin</title>
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #EFEEE8; --surface: #FFFFFF; --ink: #0d0d14; --red: #E8002D;
      --ink-06: rgba(13,13,20,0.06); --ink-10: rgba(13,13,20,0.10);
      --ink-14: rgba(13,13,20,0.14); --ink-20: rgba(13,13,20,0.20);
      --ink-32: rgba(13,13,20,0.32); --ink-48: rgba(13,13,20,0.48);
      --ink-72: rgba(13,13,20,0.72);
      --display: "Barlow Condensed", sans-serif;
      --body: "Barlow", sans-serif;
      --mono: "JetBrains Mono", monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }

    /* ── Mast ── */
    .admin-mast { border-bottom: 2px solid var(--ink); background: var(--bg); }
    .admin-mast-inner { max-width: 1400px; margin: 0 auto; padding: 20px 32px; display: flex; align-items: baseline; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .admin-eyebrow { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--red); margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
    .admin-pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .admin-title { font-family: var(--display); font-weight: 800; font-size: clamp(24px, 3vw, 36px); text-transform: uppercase; letter-spacing: -0.005em; }
    .admin-user { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* ── Body ── */
    .page-body { max-width: 1400px; margin: 0 auto; padding: 28px 32px 80px; }

    /* ── Auth states ── */
    .auth-state { text-align: center; padding: 80px 32px; }
    .auth-state-label { font-family: var(--display); font-weight: 700; font-size: 20px; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; }
    .auth-state-sub { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.06em; margin-bottom: 20px; }
    .auth-btn { font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; padding: 10px 24px; background: var(--ink); color: var(--bg); border: none; cursor: pointer; text-decoration: none; display: inline-block; }

    /* ── Controls ── */
    .controls { display: flex; align-items: flex-end; gap: 14px; flex-wrap: wrap; margin-bottom: 24px; padding: 18px 20px; background: var(--surface); border: 1px solid var(--ink-14); }
    .ctrl-group { display: flex; flex-direction: column; gap: 5px; }
    .ctrl-label { font-family: var(--mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-48); }
    .ctrl-select { font-family: var(--body); font-size: 13px; color: var(--ink); background: var(--bg); border: 1px solid var(--ink-20); padding: 7px 10px; min-width: 200px; cursor: pointer; appearance: auto; }
    .ctrl-select:disabled { opacity: 0.4; cursor: not-allowed; }
    .ctrl-select-sm { min-width: 110px; }
    .ctrl-stepper { display: flex; align-items: center; gap: 0; border: 1px solid var(--ink-20); }
    .ctrl-stepper-val { font-family: var(--mono); font-size: 13px; font-weight: 700; width: 52px; text-align: center; background: var(--bg); color: var(--ink); border: none; padding: 7px 4px; }
    .ctrl-stepper-btn { font-family: var(--mono); font-size: 14px; width: 30px; height: 33px; background: transparent; border: none; border-left: 1px solid var(--ink-14); color: var(--ink-48); cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .ctrl-stepper-btn:first-child { border-left: none; border-right: 1px solid var(--ink-14); }
    .ctrl-stepper-btn:hover { background: var(--ink-06); color: var(--ink); }
    .generate-btn { font-family: var(--display); font-weight: 800; font-size: 14px; letter-spacing: 0.06em; text-transform: uppercase; padding: 9px 22px; background: var(--ink); color: var(--bg); border: none; cursor: pointer; align-self: flex-end; height: 33px; white-space: nowrap; }
    .generate-btn:hover { background: var(--red); }
    .generate-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── Card preview area ── */
    .preview-section { margin-bottom: 32px; }
    .preview-toolbar { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .preview-label { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.10em; text-transform: uppercase; }
    .download-btn { font-family: var(--mono); font-size: 10px; letter-spacing: 0.10em; text-transform: uppercase; padding: 6px 14px; border: 1px solid var(--ink-20); background: transparent; color: var(--ink-48); cursor: pointer; }
    .download-btn:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }
    .preview-scroll { overflow-x: auto; border: 1px solid var(--ink-14); }
    .preview-scale-wrap { transform-origin: top left; }

    /* ── Calendar ── */
    .calendar-section { border-top: 2px solid var(--ink); padding-top: 24px; }
    .calendar-title { font-family: var(--display); font-weight: 800; font-size: 20px; text-transform: uppercase; letter-spacing: 0.02em; margin-bottom: 4px; }
    .calendar-sub { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.06em; margin-bottom: 20px; }
    .calendar-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
    .cal-item { background: var(--surface); border: 1px solid var(--ink-14); padding: 12px 14px; }
    .cal-group { font-family: var(--mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-32); margin-bottom: 3px; }
    .cal-name { font-family: var(--display); font-weight: 700; font-size: 15px; color: var(--ink); margin-bottom: 6px; }
    .cal-when { font-family: var(--mono); font-size: 9px; color: var(--ink-48); letter-spacing: 0.04em; margin-bottom: 8px; }
    .cal-when.fresh { color: #166534; }
    .cal-btn { font-family: var(--mono); font-size: 9px; letter-spacing: 0.10em; text-transform: uppercase; padding: 4px 10px; border: 1px solid var(--ink-20); background: transparent; color: var(--ink-48); cursor: pointer; }
    .cal-btn:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }
    .cal-btn.posted { background: #166534; color: #fff; border-color: transparent; }
    .cal-load-btn { font-family: var(--mono); font-size: 9px; letter-spacing: 0.10em; text-transform: uppercase; padding: 4px 10px; border: 1px solid var(--ink-20); background: transparent; color: var(--ink-48); cursor: pointer; margin-right: 4px; }
    .cal-load-btn:hover { background: var(--ink-10); color: var(--ink); }
    .cal-actions { display: flex; gap: 4px; flex-wrap: wrap; }
    .tier-header { font-family: var(--display); font-weight: 800; font-size: 16px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--ink); padding: 12px 0 8px; border-bottom: 1px solid var(--ink-14); margin-bottom: 10px; grid-column: 1 / -1; }
    .tier-label { font-family: var(--mono); font-size: 9px; letter-spacing: 0.14em; color: var(--red); margin-left: 8px; font-weight: 700; }
    .cal-desc { font-family: var(--body); font-size: 11px; color: var(--ink-48); margin-bottom: 6px; line-height: 1.4; }

    @media (max-width: 640px) {
      .admin-mast-inner, .page-body { padding-left: 16px; padding-right: 16px; }
      .controls { gap: 10px; }
    }
  </style>
</head>
<body>
<Nav currentPath="/admin/generator" />

<div class="admin-mast">
  <div class="admin-mast-inner">
    <div>
      <div class="admin-eyebrow"><span class="admin-pip"></span>HGB Admin · Card Generator</div>
      <h1 class="admin-title">Leaderboard Generator</h1>
    </div>
    <div class="admin-user" id="admin-user-display"></div>
  </div>
</div>

<div class="page-body">

  <!-- Auth states -->
  <div id="state-loading" class="auth-state">
    <div class="auth-state-label">Checking authorization…</div>
    <div class="auth-state-sub">Verifying admin session</div>
  </div>
  <div id="state-unauthed" class="auth-state" style="display:none">
    <div class="auth-state-label">Sign in required</div>
    <div class="auth-state-sub">You need an active session to access admin tools.</div>
    <a href="/account" class="auth-btn">Sign in →</a>
  </div>
  <div id="state-forbidden" class="auth-state" style="display:none">
    <div class="auth-state-label">Admin access required</div>
    <div class="auth-state-sub">Your account does not have admin privileges.</div>
  </div>
  <div id="state-error" class="auth-state" style="display:none">
    <div class="auth-state-label">Something went wrong</div>
    <div class="auth-state-sub" id="error-msg"></div>
  </div>

  <!-- Main UI -->
  <div id="generator-ui" style="display:none">

    <!-- Controls -->
    <div class="controls">
      <div class="ctrl-group">
        <span class="ctrl-label">Category</span>
        <select class="ctrl-select" id="ctrl-category"></select>
      </div>
      <div class="ctrl-group">
        <span class="ctrl-label">View</span>
        <select class="ctrl-select ctrl-select-sm" id="ctrl-view">
          <option value="both">Both</option>
          <option value="top">Top only</option>
          <option value="bottom">Bottom only</option>
        </select>
      </div>
      <div class="ctrl-group">
        <span class="ctrl-label">Top/Bottom N</span>
        <div class="ctrl-stepper">
          <button class="ctrl-stepper-btn" id="n-minus">−</button>
          <input class="ctrl-stepper-val" id="ctrl-n" type="text" value="10" readonly />
          <button class="ctrl-stepper-btn" id="n-plus">+</button>
        </div>
      </div>
      <div class="ctrl-group">
        <span class="ctrl-label">Game Type</span>
        <select class="ctrl-select ctrl-select-sm" id="ctrl-gametype">
          <option value="regular">Regular Season</option>
          <option value="playoff">Playoffs</option>
        </select>
      </div>
      <div class="ctrl-group">
        <span class="ctrl-label">Position</span>
        <select class="ctrl-select ctrl-select-sm" id="ctrl-pos">
          <option value="all">All</option>
          <option value="F">Forwards</option>
          <option value="D">Defense</option>
        </select>
      </div>
      <div class="ctrl-group" id="ctrl-display-group">
        <span class="ctrl-label">Display</span>
        <select class="ctrl-select ctrl-select-sm" id="ctrl-display">
          <option value="raw">Raw values</option>
          <option value="pct">% rank</option>
        </select>
      </div>
      <div class="ctrl-group">
        <span class="ctrl-label" id="toi-label">Min TOI (min)</span>
        <div class="ctrl-stepper">
          <button class="ctrl-stepper-btn" id="toi-minus">−</button>
          <input class="ctrl-stepper-val" id="ctrl-toi" type="text" value="200" readonly style="width:60px" />
          <button class="ctrl-stepper-btn" id="toi-plus">+</button>
        </div>
      </div>
      <button class="generate-btn" id="generate-btn" onclick="generateCard()">Generate Card</button>
    </div>

    <!-- Preview -->
    <div class="preview-section" id="preview-section" style="display:none">
      <div class="preview-toolbar">
        <span class="preview-label">Preview</span>
        <button class="download-btn" id="download-btn" onclick="downloadCard()">↓ Download PNG</button>
      </div>
      <div class="preview-scroll" id="preview-scroll">
        <div class="preview-scale-wrap" id="preview-scale-wrap">
          <div id="card-inner"></div>
        </div>
      </div>
    </div>

    <!-- Calendar -->
    <div class="calendar-section">
      <div class="calendar-title">Content Calendar</div>
      <div class="calendar-sub">Track when each category was last posted · click "Mark Posted" after publishing</div>
      <div class="calendar-grid" id="calendar-grid"></div>
    </div>

  </div><!-- /generator-ui -->

</div>

<script src="/js/table-export.js" defer></script>
<script is:inline>
(function() {
  const API         = 'https://api.hockeygamebot.com';
  const SESSION_KEY = 'hgb_session';
  const SEASON      = '2025-26';
  const N_VALUES    = [5, 10, 15, 20];

  // ── Category definitions ──────────────────────────────────────────────────
  // field: function(row) → number | null
  // filterField: which TOI/GP field to apply minToi against
  // toiStep: increment for the TOI stepper
  const CATEGORIES = [
    {
      slug: 'goalie_gsax', label: 'Goalie GSAx', group: 'Goalies',
      desc: 'Goals Saved Above Expected · all-sit excl EN+SO',
      dataType: 'goalies',
      field:   r => r.gsax,
      fmtVal:  v => (v >= 0 ? '+' : '') + Number(v).toFixed(2),
      auxCol:  'TOI', auxFmt: r => Math.round((r.toi_sec || 0) / 60) + 'm',
      filterField: 'toi_min', toiDefault: 60, toiStep: 30, toiLabel: 'Min TOI (min)',
      badgeFn: gsaxBadge,
    },
    {
      slug: 'goals_60', label: 'Goals/60 (5v5)', group: 'Skaters — Offense',
      desc: 'Individual goals per 60 min at even strength',
      dataType: 'skaters',
      field:   r => r.rates_per_60 && r.rates_per_60.goals,
      fmtVal:  v => Number(v).toFixed(2),
      auxCol:  'GP', auxFmt: r => r.gp,
      filterField: 'ev_toi', toiDefault: 200, toiStep: 50, toiLabel: 'Min EV TOI (min)',
      badgeFn: rankBadge,
    },
    {
      slug: 'a1_60', label: 'A1/60 (5v5)', group: 'Skaters — Offense',
      desc: 'Primary assists per 60 min at even strength',
      dataType: 'skaters',
      field:   r => r.rates_per_60 && r.rates_per_60.a1,
      fmtVal:  v => Number(v).toFixed(2),
      auxCol:  'GP', auxFmt: r => r.gp,
      filterField: 'ev_toi', toiDefault: 200, toiStep: 50, toiLabel: 'Min EV TOI (min)',
      badgeFn: rankBadge,
    },
    {
      slug: 'ixg_60', label: 'xG/60 (5v5)', group: 'Skaters — Offense',
      desc: 'Individual expected goals per 60 at even strength',
      dataType: 'skaters',
      field:   r => r.rates_per_60 && r.rates_per_60.ixg,
      fmtVal:  v => Number(v).toFixed(2),
      auxCol:  'GP', auxFmt: r => r.gp,
      filterField: 'ev_toi', toiDefault: 200, toiStep: 50, toiLabel: 'Min EV TOI (min)',
      badgeFn: rankBadge,
    },
    {
      slug: 'finishing', label: 'Finishing', group: 'Skaters — Offense',
      desc: 'Goal rate above xG expectation · shooting talent',
      dataType: 'skaters',
      field:   r => r.rates_per_60 && r.rates_per_60.finishing,
      fmtVal:  v => (v >= 0 ? '+' : '') + Number(v).toFixed(2),
      auxCol:  'GP', auxFmt: r => r.gp,
      filterField: 'ev_toi', toiDefault: 200, toiStep: 50, toiLabel: 'Min EV TOI (min)',
      badgeFn: rankBadge,
    },
    {
      slug: 'game_score', label: 'Game Score avg', group: 'Skaters — Offense',
      desc: 'Composite per-game value averaged across all games',
      dataType: 'skaters',
      field:   r => r.avg_gs_display,
      fmtVal:  v => Number(v).toFixed(2),
      auxCol:  'GP', auxFmt: r => r.gp,
      filterField: 'gp', toiDefault: 20, toiStep: 5, toiLabel: 'Min GP',
      badgeFn: rankBadge,
    },
    {
      slug: 'pp_xg60', label: 'PP xG/60', group: 'Skaters — Offense',
      desc: 'Individual expected goals per 60 on power play',
      dataType: 'skaters',
      field:   r => r.rates_per_60 && r.rates_per_60.xg_pp_per60,
      fmtVal:  v => Number(v).toFixed(2),
      auxCol:  'GP', auxFmt: r => r.gp,
      filterField: 'pp_toi', toiDefault: 60, toiStep: 30, toiLabel: 'Min PP TOI (min)',
      badgeFn: rankBadge,
    },
    {
      slug: 'war', label: 'WAR', group: 'Skaters — Value',
      desc: 'Wins Above Replacement · full season',
      dataType: 'skaters',
      field:   r => r.war,
      fmtVal:  v => (v >= 0 ? '+' : '') + Number(v).toFixed(2),
      auxCol:  'GP', auxFmt: r => r.gp,
      filterField: 'gp', toiDefault: 20, toiStep: 5, toiLabel: 'Min GP',
      badgeFn: rankBadge,
      pctSupported: true,
    },
    {
      slug: 'rapm_off', label: 'RAPM Offense', group: 'Skaters — Value',
      desc: 'On-ice offensive impact · isolated from teammates',
      dataType: 'skaters',
      field:   r => r.rapm_off,
      fmtVal:  v => (v >= 0 ? '+' : '') + Number(v).toFixed(2),
      auxCol:  'GP', auxFmt: r => r.gp,
      filterField: 'ev_toi', toiDefault: 200, toiStep: 50, toiLabel: 'Min EV TOI (min)',
      badgeFn: rankBadge,
      pctSupported: true,
    },
    {
      slug: 'rapm_def', label: 'RAPM Defense', group: 'Skaters — Value',
      desc: 'On-ice defensive impact · isolated from teammates',
      dataType: 'skaters',
      field:   r => r.rapm_def,
      fmtVal:  v => (v >= 0 ? '+' : '') + Number(v).toFixed(2),
      auxCol:  'GP', auxFmt: r => r.gp,
      filterField: 'ev_toi', toiDefault: 200, toiStep: 50, toiLabel: 'Min EV TOI (min)',
      badgeFn: rankBadge,
      pctSupported: true,
    },
  ];

  // ── Team colors (synced with team-colors.ts) ──────────────────────────────
  const TC = {
    ANA:['#F47A38','#B09862'], BOS:['#FFB81C','#000000'], BUF:['#002654','#FDBB30'],
    CAR:['#CC0000','#000000'], CBJ:['#002654','#CE1126'], CGY:['#C8102E','#F1BE48'],
    CHI:['#CF0A2C','#000000'], COL:['#6F263D','#236192'], DAL:['#006847','#8F8F8C'],
    DET:['#CE1126','#FFFFFF'], EDM:['#FF4C00','#041E42'], FLA:['#041E42','#C8102E'],
    LAK:['#111111','#A2AAAD'], MIN:['#154734','#A6192E'], MTL:['#AF1E2D','#00205B'],
    NSH:['#FFB81C','#041E42'], NJD:['#CE1126','#000000'], NYI:['#00539B','#F47D30'],
    NYR:['#0038A8','#CE1126'], OTT:['#DA1A32','#000000'], PHI:['#FA4616','#000000'],
    PIT:['#000000','#FCB514'], SEA:['#001628','#99D9D9'], SJS:['#006D75','#EA7200'],
    STL:['#002F87','#FDB827'], TBL:['#00205B','#FFFFFF'], TOR:['#00205B','#FFFFFF'],
    UTA:['#71AFE5','#090909'], VAN:['#00205B','#00843D'], VGK:['#B4975A','#333F48'],
    WSH:['#041E42','#C8102E'], WPG:['#041E42','#004C97'],
  };
  function teamColor(abbrev) {
    const c = TC[abbrev] || ['#E8002D', '#555555'];
    const hex = c[0]; const r = parseInt(hex.slice(1,3),16)/255, g = parseInt(hex.slice(3,5),16)/255, b = parseInt(hex.slice(5,7),16)/255;
    const l = (Math.max(r,g,b) + Math.min(r,g,b)) / 2;
    return l < 0.15 ? c[1] : c[0];
  }

  // ── Badge color functions ─────────────────────────────────────────────────
  function gsaxBadge(value) {
    if (value >= 5)  return { bg: '#4ade80', text: '#14532d' };
    if (value >= 2)  return { bg: '#a3e635', text: '#365314' };
    if (value >= -2) return { bg: '#d1d5db', text: '#374151' };
    if (value >= -5) return { bg: '#fb923c', text: '#7c2d12' };
    return               { bg: '#f87171', text: '#7f1d1d' };
  }
  // rank is 0-indexed within the list; isTop = true for top list
  function rankBadge(value, rank, isTop) {
    if (isTop) {
      if (rank < 3)  return { bg: '#4ade80', text: '#14532d' };
      if (rank < 6)  return { bg: '#a3e635', text: '#365314' };
      return               { bg: '#d1d5db', text: '#374151' };
    } else {
      if (rank < 3)  return { bg: '#f87171', text: '#7f1d1d' };
      if (rank < 6)  return { bg: '#fb923c', text: '#7c2d12' };
      return               { bg: '#d1d5db', text: '#374151' };
    }
  }

  // ── State ─────────────────────────────────────────────────────────────────
  let _token = null;
  let _players = null;
  let _goalies = null;
  let _calLog = {};       // { slug: ISO string }
  let _nIdx = 1;          // index into N_VALUES (default 10)
  let _lastCardData = null; // saved for native canvas download

  // ── DOM helpers ───────────────────────────────────────────────────────────
  const $ = id => document.getElementById(id);

  function showState(id) {
    ['state-loading','state-unauthed','state-forbidden','state-error','generator-ui']
      .forEach(s => $(s).style.display = s === id ? '' : 'none');
  }

  // ── Auth ──────────────────────────────────────────────────────────────────
  async function init() {
    try { _token = localStorage.getItem(SESSION_KEY); } catch(e) {}
    if (!_token) { showState('state-unauthed'); return; }

    let whoami;
    try {
      const r = await fetch(`${API}/v1/admin/whoami`, { headers: { Authorization: `Bearer ${_token}` } });
      if (r.status === 401) { showState('state-unauthed'); return; }
      if (!r.ok) throw new Error(`whoami ${r.status}`);
      whoami = await r.json();
    } catch(e) {
      $('error-msg').textContent = `Auth check failed: ${e.message}`;
      showState('state-error'); return;
    }

    if (!whoami.is_admin) { showState('state-forbidden'); return; }
    const u = $('admin-user-display');
    if (u && whoami.email) u.textContent = `// ${whoami.email}`;

    buildCategorySelect();
    syncControls();
    wireSteppers();

    showState('generator-ui');

    // Load calendar + prefetch both data sets in parallel (background)
    loadCalendar();
    prefetchData();
  }

  // ── Category select ───────────────────────────────────────────────────────
  function buildCategorySelect() {
    const sel = $('ctrl-category');
    const groups = {};
    CATEGORIES.forEach(c => { (groups[c.group] = groups[c.group] || []).push(c); });
    Object.entries(groups).forEach(([grp, cats]) => {
      const og = document.createElement('optgroup');
      og.label = grp;
      cats.forEach(c => {
        const o = document.createElement('option');
        o.value = c.slug; o.textContent = c.label;
        og.appendChild(o);
      });
      sel.appendChild(og);
    });
    sel.addEventListener('change', syncControls);
  }

  function currentCat() {
    return CATEGORIES.find(c => c.slug === $('ctrl-category').value) || CATEGORIES[0];
  }

  function syncControls() {
    const cat = currentCat();
    // Position filter: disable for goalies
    const posSel = $('ctrl-pos');
    posSel.disabled = cat.dataType === 'goalies';
    if (cat.dataType === 'goalies') posSel.value = 'all';
    // Game type: only goalies have full playoff data; disable for skater rate/value categories
    const gtSel = $('ctrl-gametype');
    gtSel.disabled = cat.dataType === 'skaters';
    if (cat.dataType === 'skaters') gtSel.value = 'regular';
    // TOI label + default
    $('toi-label').textContent = cat.toiLabel;
    $('ctrl-toi').value = cat.toiDefault;
    // Display select: only enabled for categories that support PCT mode
    const displaySel = $('ctrl-display');
    if (displaySel) {
      displaySel.disabled = !cat.pctSupported;
      if (!cat.pctSupported) displaySel.value = 'raw';
    }
  }

  // ── Steppers ──────────────────────────────────────────────────────────────
  function wireSteppers() {
    $('n-minus').addEventListener('click', () => {
      if (_nIdx > 0) { _nIdx--; $('ctrl-n').value = N_VALUES[_nIdx]; }
    });
    $('n-plus').addEventListener('click', () => {
      if (_nIdx < N_VALUES.length - 1) { _nIdx++; $('ctrl-n').value = N_VALUES[_nIdx]; }
    });
    $('toi-minus').addEventListener('click', () => {
      const cat = currentCat();
      const cur = parseInt($('ctrl-toi').value) || 0;
      $('ctrl-toi').value = Math.max(0, cur - cat.toiStep);
    });
    $('toi-plus').addEventListener('click', () => {
      const cat = currentCat();
      const cur = parseInt($('ctrl-toi').value) || 0;
      $('ctrl-toi').value = cur + cat.toiStep;
    });
  }

  // ── Prefetch data ─────────────────────────────────────────────────────────
  // Stats endpoints are public — no Authorization header needed or wanted.
  // Sending auth headers triggers a CORS preflight that these endpoints don't handle.
  async function prefetchData() {
    const [pr, gr] = await Promise.all([
      fetch(`${API}/v1/stats/players`),
      fetch(`${API}/v1/stats/goalies`),
    ]);
    if (pr.ok) { const d = await pr.json(); _players = d.players || d; }
    if (gr.ok) { const d = await gr.json(); _goalies = d.goalies || d; }
  }

  // ── Generate ──────────────────────────────────────────────────────────────
  window.generateCard = async function() {
    const btn = $('generate-btn');
    btn.disabled = true; btn.textContent = 'Loading…';

    const cat      = currentCat();
    const view     = $('ctrl-view').value;
    const n        = parseInt($('ctrl-n').value) || 10;
    const pos      = $('ctrl-pos').value;
    const minToi   = parseInt($('ctrl-toi').value) || 0;
    const gameType = $('ctrl-gametype').value; // 'regular' | 'playoff'

    // Ensure data loaded (public endpoints — no auth header)
    if (cat.dataType === 'goalies' && !_goalies) {
      const r = await fetch(`${API}/v1/stats/goalies`);
      if (r.ok) { const d = await r.json(); _goalies = d.goalies || d; }
    }
    if (cat.dataType === 'skaters' && !_players) {
      const r = await fetch(`${API}/v1/stats/players`);
      if (r.ok) { const d = await r.json(); _players = d.players || d; }
    }

    const pool = cat.dataType === 'goalies' ? _goalies : _players;
    if (!pool) {
      btn.disabled = false; btn.textContent = 'Generate Card';
      alert('Failed to load data. Check your session.'); return;
    }

    // For goalies in playoff mode, read from playoff_* fields instead
    const isPlayoff   = gameType === 'playoff' && cat.dataType === 'goalies';
    const valueField  = isPlayoff ? (r => r.playoff_gsax) : cat.field;
    const auxFmtFn    = isPlayoff ? (r => (r.playoff_games ?? 0) + ' GP') : cat.auxFmt;
    const auxColLabel = isPlayoff ? 'GP' : cat.auxCol;

    // Filter
    let rows = pool.filter(r => {
      const v = valueField(r);
      if (v == null || isNaN(v)) return false;
      if (cat.dataType === 'skaters' && pos !== 'all' && r.pos_group !== pos) return false;

      if (isPlayoff) return (r.playoff_games || 0) >= Math.max(1, Math.round(minToi / 60));
      if (cat.filterField === 'gp')      return (r.gp || 0) >= minToi;
      if (cat.filterField === 'toi_min') return ((r.toi_sec || 0) / 60) >= minToi;
      if (cat.filterField === 'ev_toi')  return ((r.toi_ev_sec_total || 0) / 60) >= minToi;
      if (cat.filterField === 'pp_toi')  return ((r.toi_pp_sec_total || 0) / 60) >= minToi;
      return true;
    });

    // Sort descending by value
    rows.sort((a, b) => valueField(b) - valueField(a));

    const topN    = rows.slice(0, n);
    const bottomN = rows.slice(-n).reverse();

    // Compute percentile ranks within filtered pool when PCT mode is on
    const pctMode = !!(cat.pctSupported && $('ctrl-display') && $('ctrl-display').value === 'pct');
    if (pctMode) {
      const total = rows.length;
      rows.forEach((r, i) => {
        r._pct = total <= 1 ? 100 : Math.round((1 - i / (total - 1)) * 100);
      });
    }

    _lastCardData = { cat, topN, bottomN, view, n, pos, minToi, gameType, valueField, auxFmtFn, auxColLabel, pctMode };

    // Render canvas preview async after fonts load
    btn.disabled = false; btn.textContent = 'Generate Card';
    document.fonts.ready.then(() => {
      Promise.all([
        document.fonts.load('800 52px "Barlow Condensed"'),
        document.fonts.load('700 16px "Barlow Condensed"'),
        document.fonts.load('700 9px "Barlow Condensed"'),
        document.fonts.load('400 11px "Barlow"'),
      ]).then(() => {
        try {
          const canvas = drawLeaderboardCard(_lastCardData);
          const img = document.createElement('img');
          img.src = canvas.toDataURL('image/png');
          img.style.cssText = 'width:100%;height:auto;display:block;';
          const inner = $('card-inner');
          inner.innerHTML = '';
          inner.appendChild(img);
          const wrap = $('preview-scale-wrap');
          wrap.style.transform = '';
          wrap.style.width = '';
          wrap.style.height = '';
          $('preview-scroll').style.height = '';
          $('preview-section').style.display = '';
        } catch(e) { console.error('[preview]', e); }
      });
    });
  };

  // ── Download (native Canvas 2D API — no html2canvas) ─────────────────────
  window.downloadCard = function() {
    if (!_lastCardData) { alert('Generate a card first.'); return; }
    const btn = $('download-btn');
    btn.textContent = 'Generating…'; btn.disabled = true;
    document.fonts.ready.then(() => {
      Promise.all([
        document.fonts.load('800 52px "Barlow Condensed"'),
        document.fonts.load('700 16px "Barlow Condensed"'),
        document.fonts.load('700 9px "Barlow Condensed"'),
        document.fonts.load('400 11px "Barlow"'),
      ]).then(() => {
        try {
          const canvas = drawLeaderboardCard(_lastCardData);
          const filename = 'hgb-' + (_lastCardData.cat.slug || 'card').replace(/_/g, '-') + '.png';
          window.HGB_Export.showCardModal(canvas, filename);
        } catch(e) { console.error('[card] draw failed:', e); }
        btn.textContent = '↓ Download PNG'; btn.disabled = false;
      });
    });
  };

  function drawLeaderboardCard(d) {
    const { cat, topN, bottomN, view, n, pos, minToi, gameType, valueField, auxFmtFn, auxColLabel, pctMode } = d;

    // ── Dimensions & constants ─────────────────────────────────────────────
    const W       = 1200, SCALE = 2, PAD_X = 48;
    const HDR_H   = 76;    // white header: title
    const CHIP_SH = 44;    // white header: chip row
    const SEP_H   = 2;     // red separator
    const PAD_Y   = 24;    // body top/bottom padding
    const COL_TH  = 22;    // column title text height
    const COL_HH  = 20;    // column header row height
    const ROW_H   = 44;    // data row height
    const BADGE_H = 26;    // badge rectangle height
    const BADGE_W = 76;    // badge rectangle width
    const FOOT_H  = 36;    // footer height
    const COL_GAP = 48;    // gap between two columns (both mode)

    const BG      = '#EFEEE8';
    const SURFACE = '#FFFFFF';
    const INK     = '#0D0D14';
    const RED     = '#E8002D';
    const INK45   = 'rgba(13,13,20,0.45)';
    const INK32   = 'rgba(13,13,20,0.32)';
    const INK14   = 'rgba(13,13,20,0.14)';
    const INK10   = 'rgba(13,13,20,0.10)';

    const isPlayoff = gameType === 'playoff';
    const isBoth    = view === 'both';
    const showTop   = view === 'top' || isBoth;

    const splitSingle = !isBoth && n > 10;

    const colW  = (isBoth || splitSingle) ? Math.floor((W - 2 * PAD_X - COL_GAP) / 2) : W - 2 * PAD_X;
    const rowsForHeight = splitSingle ? Math.ceil(n / 2) : n;
    const bodyH = PAD_Y + COL_TH + 2 + COL_HH + 3 + 1 + 4 + rowsForHeight * ROW_H + PAD_Y;
    const H     = HDR_H + CHIP_SH + SEP_H + bodyH + FOOT_H;

    const canvas = document.createElement('canvas');
    canvas.width  = W * SCALE;
    canvas.height = H * SCALE;
    const ctx = canvas.getContext('2d');
    ctx.scale(SCALE, SCALE);

    // Fill entire canvas with BG so footer area is visible (canvas default is transparent)
    ctx.fillStyle = BG;
    ctx.fillRect(0, 0, W, H);

    // ── Helpers ────────────────────────────────────────────────────────────
    function rrect(x, y, w, h, r) {
      ctx.beginPath();
      if (typeof ctx.roundRect === 'function') {
        ctx.roundRect(x, y, w, h, r);
      } else {
        ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
        ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
        ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
        ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath();
      }
    }
    function clamp(text, maxW) {
      if (ctx.measureText(text).width <= maxW) return text;
      let t = text;
      while (t.length > 1 && ctx.measureText(t + '…').width > maxW) t = t.slice(0, -1);
      return t + '…';
    }
    function ordinal(n) {
      n = Math.round(n);
      const s = ['th','st','nd','rd'];
      const v = n % 100;
      return n + (s[(v - 20) % 10] || s[v] || s[0]);
    }
    function pctBadge(pct) {
      if (pct >= 75) return { bg: '#4ade80', text: '#14532d' };
      if (pct >= 50) return { bg: '#a3e635', text: '#365314' };
      if (pct >= 25) return { bg: '#d1d5db', text: '#374151' };
      return               { bg: '#fb923c', text: '#7c2d12' };
    }
    function chip(x, y, label, bg, fg) {
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      const chipH = 20;
      const tw = ctx.measureText(label).width + 18;
      rrect(x, y, tw, chipH, 2); ctx.fillStyle = bg; ctx.fill();
      ctx.fillStyle = fg; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText(label, x + 9, y + chipH / 2);
      return tw;
    }

    // ── White header ────────────────────────────────────────────────────────
    ctx.fillStyle = SURFACE;
    ctx.fillRect(0, 0, W, HDR_H + CHIP_SH);

    // Title
    ctx.font = '800 52px "Barlow Condensed", sans-serif';
    ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
    ctx.fillText(cat.label.toUpperCase(), PAD_X, HDR_H / 2);

    // Chip row
    const chipY0 = HDR_H + (CHIP_SH - 20) / 2;
    let cx = PAD_X;
    cx += chip(cx, chipY0, isPlayoff ? 'PLAYOFFS' : 'REGULAR SEASON', isPlayoff ? RED : INK, isPlayoff ? '#fff' : BG) + 6;
    if (cat.dataType !== 'goalies') {
      const pl = pos === 'F' ? 'FORWARDS' : pos === 'D' ? 'DEFENSE' : 'ALL SKATERS';
      cx += chip(cx, chipY0, pl, INK, BG) + 6;
    }
    if (minToi > 0) {
      const minLabel = isPlayoff
        ? 'MIN ' + Math.max(1, Math.round(minToi / 60)) + ' GP'
        : 'MIN ' + minToi + ' ' + (cat.toiLabel.includes('GP') ? 'GP' : 'MIN');
      chip(cx, chipY0, minLabel, INK, BG);
    }
    // HGB chip — right-aligned
    ctx.font = '700 9px "Barlow Condensed", sans-serif';
    const hgbW = ctx.measureText('HOCKEYGAMEBOT').width + 18;
    chip(W - PAD_X - hgbW, chipY0, 'HOCKEYGAMEBOT', RED, '#fff');

    // Hairline at bottom of white header
    ctx.fillStyle = INK14; ctx.fillRect(0, HDR_H + CHIP_SH - 1, W, 1);

    // ── Red separator ────────────────────────────────────────────────────────
    ctx.fillStyle = RED;
    ctx.fillRect(0, HDR_H + CHIP_SH, W, SEP_H);

    // ── Cream body ───────────────────────────────────────────────────────────
    const bodyY = HDR_H + CHIP_SH + SEP_H;
    ctx.fillStyle = BG; ctx.fillRect(0, bodyY, W, bodyH);

    // Column grid x offsets (relative to column left edge)
    const RANK_R    = 22;   // rank number, right-aligned
    const TEAM_L    = 30;   // team abbrev, left-aligned
    const NAME_L    = 90;   // player name, left-aligned  (= 22+8+52+8)
    const ROW_PAD_R = 8;    // right padding inside each row
    const BDGE_L    = colW - BADGE_W - ROW_PAD_R;  // badge rect (8px from right edge)
    const AUX_R     = BDGE_L - 16;                  // aux text, right-aligned (16px gap to badge)

    const posLabel = cat.dataType === 'goalies' ? 'GOALIES'
                   : pos === 'F' ? 'FORWARDS'
                   : pos === 'D' ? 'DEFENSE' : 'SKATERS';

    function drawColumn(rows, title, isTop, colX, rankOffset = 0) {
      const y0 = bodyY + PAD_Y;

      // Column title
      ctx.font = '800 11px "Barlow Condensed", sans-serif';
      ctx.fillStyle = RED; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText(title, colX, y0 + COL_TH / 2);

      // Column header row
      const hdrY = y0 + COL_TH + 2;
      ctx.font = '600 9px "Barlow", sans-serif';
      ctx.fillStyle = INK32;
      ctx.textAlign = 'right';  ctx.fillText('#',           colX + RANK_R,               hdrY + COL_HH / 2);
      ctx.textAlign = 'left';   ctx.fillText('TEAM',        colX + TEAM_L,               hdrY + COL_HH / 2);
      ctx.fillText('PLAYER',    colX + NAME_L,               hdrY + COL_HH / 2);
      ctx.textAlign = 'right';  ctx.fillText(auxColLabel,   colX + AUX_R,                hdrY + COL_HH / 2);
      ctx.fillStyle = RED;
      ctx.textAlign = 'center'; ctx.fillText(cat.label + ' ↓', colX + BDGE_L + BADGE_W / 2, hdrY + COL_HH / 2);

      // Divider line
      const divY = hdrY + COL_HH + 3;
      ctx.fillStyle = INK14; ctx.fillRect(colX, divY, colW, 1);

      // Data rows
      let ry = divY + 4;
      rows.forEach((r, i) => {
        const val    = valueField(r);
        const badge  = pctMode ? pctBadge(r._pct || 0) : (cat.badgeFn === gsaxBadge ? gsaxBadge(val) : rankBadge(val, i + rankOffset, isTop));
        const name   = ((r.first_name && r.last_name) ? r.first_name + ' ' + r.last_name : (r.display_name || '')).toUpperCase();
        const abbrev = r.team_abbrev || '???';
        const aux    = String(auxFmtFn(r));
        const tc     = teamColor(abbrev);
        const nameMaxW = AUX_R - NAME_L - 8;
        const midY   = ry + ROW_H / 2;

        // Row background (zebra)
        ctx.fillStyle = i % 2 === 0 ? BG : 'rgba(13,13,20,0.04)';
        ctx.fillRect(colX, ry, colW, ROW_H);

        // Rank
        ctx.font = '700 11px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        ctx.fillText(String(i + 1 + rankOffset), colX + RANK_R, midY);

        // Team abbrev (colored)
        ctx.font = '800 12px "Barlow Condensed", sans-serif';
        ctx.fillStyle = tc; ctx.textAlign = 'left';
        ctx.fillText(abbrev, colX + TEAM_L, midY);

        // Player name (truncate if needed)
        ctx.font = '700 16px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK;
        ctx.fillText(clamp(name, nameMaxW), colX + NAME_L, midY);

        // Aux (GP / TOI)
        ctx.font = '400 11px "Barlow", sans-serif';
        ctx.fillStyle = INK45; ctx.textAlign = 'right';
        ctx.fillText(aux, colX + AUX_R, midY);

        // Badge
        const badgeY = ry + (ROW_H - BADGE_H) / 2;
        rrect(colX + BDGE_L, badgeY, BADGE_W, BADGE_H, 2);
        ctx.fillStyle = badge.bg; ctx.fill();
        ctx.font = '700 13px "Barlow Condensed", sans-serif';
        ctx.fillStyle = badge.text; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(pctMode ? ordinal(r._pct || 0) : cat.fmtVal(val), colX + BDGE_L + BADGE_W / 2, badgeY + BADGE_H / 2);

        ry += ROW_H;
      });
    }

    if (isBoth) {
      drawColumn(topN,    'TOP '    + n + ' ' + posLabel + ' BY ' + cat.label.toUpperCase(), true,  PAD_X);
      drawColumn(bottomN, 'BOTTOM ' + n + ' ' + posLabel + ' BY ' + cat.label.toUpperCase(), false, PAD_X + colW + COL_GAP);
    } else if (splitSingle) {
      const half       = Math.ceil(n / 2);
      const sourceRows = showTop ? topN : bottomN;
      const prefix     = showTop ? 'TOP ' : 'BOTTOM ';
      const colTitle   = prefix + n + ' ' + posLabel + ' BY ' + cat.label.toUpperCase();
      drawColumn(sourceRows.slice(0, half), colTitle, showTop, PAD_X, 0);
      drawColumn(sourceRows.slice(half),    colTitle, showTop, PAD_X + colW + COL_GAP, half);
    } else if (showTop) {
      drawColumn(topN,    'TOP '    + n + ' ' + posLabel + ' BY ' + cat.label.toUpperCase(), true,  PAD_X);
    } else {
      drawColumn(bottomN, 'BOTTOM ' + n + ' ' + posLabel + ' BY ' + cat.label.toUpperCase(), false, PAD_X);
    }

    // ── Footer ───────────────────────────────────────────────────────────────
    const footY = H - FOOT_H;
    ctx.fillStyle = INK10; ctx.fillRect(0, footY, W, FOOT_H);
    ctx.font = '700 9px "Barlow Condensed", sans-serif';
    ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText('HOCKEYGAMEBOT.COM  ·  HGB STATS  ·  2025-26', W / 2, footY + FOOT_H / 2);

    return canvas;
  }

  // ── Calendar / Schedule ───────────────────────────────────────────────────
  let _schedule = []; // rows from content_calendar, ordered by tier + sort_order

  async function loadCalendar() {
    try {
      // Schedule endpoint is public — no Authorization header needed.
      const r = await fetch(`${API}/v1/admin/generator/schedule`);
      if (!r.ok) return;
      const d = await r.json();
      _schedule = d.schedule || [];
    } catch(e) {}
    renderCalendar();
  }

  function ageText(isoStr) {
    if (!isoStr) return null;
    const days = Math.floor((Date.now() - new Date(isoStr).getTime()) / 86400000);
    if (days === 0) return 'Posted today';
    if (days === 1) return 'Posted yesterday';
    return `Posted ${days}d ago`;
  }

  function renderCalendar() {
    const grid = $('calendar-grid');
    if (!grid) return;
    if (!_schedule.length) {
      grid.innerHTML = '<div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:24px 0;">No schedule loaded.</div>';
      return;
    }

    const TIER_LABELS = { 1: 'Tier 1 — Post First', 2: 'Tier 2 — Rotate In', 3: 'Tier 3 — August / Camp' };
    let html = '';
    let lastTier = null;

    _schedule.forEach(item => {
      if (item.tier !== lastTier) {
        lastTier = item.tier;
        html += `<div class="tier-header">${esc(TIER_LABELS[item.tier] || 'Tier ' + item.tier)}<span class="tier-label">T${item.tier}</span></div>`;
      }
      const age       = ageText(item.last_posted_at);
      const freshClass = age && item.last_posted_at && (Date.now() - new Date(item.last_posted_at).getTime()) < 7 * 86400000 ? 'fresh' : '';
      const gameLabel = item.game_type === 'playoff' ? ' · Playoffs' : '';
      const posLabel  = item.pos_filter === 'F' ? ' · Fwd' : item.pos_filter === 'D' ? ' · D' : '';
      const viewLabel = item.view === 'top' ? ' · Top only' : item.view === 'bottom' ? ' · Bottom only' : '';
      const settingsStr = JSON.stringify({ category: item.category, game_type: item.game_type, pos_filter: item.pos_filter, view: item.view, min_toi: item.min_toi }).replace(/"/g, '&quot;');

      html += `
<div class="cal-item" id="calitem-${esc(item.slug)}">
  <div class="cal-group">${esc(item.series || '')}${esc(gameLabel)}${esc(posLabel)}${esc(viewLabel)}</div>
  <div class="cal-name">${esc(item.category.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()))}</div>
  <div class="cal-desc">${esc(item.description || '')}</div>
  <div class="cal-when ${freshClass}" id="calwhen-${esc(item.slug)}">${esc(age || 'Never posted')}</div>
  <div class="cal-actions">
    <button class="cal-load-btn" onclick="loadSettings(${settingsStr})">Load Settings</button>
    <button class="cal-btn" onclick="markPosted('${esc(item.slug)}', this)">Mark Posted</button>
  </div>
</div>`;
    });

    grid.innerHTML = html;
  }

  window.loadSettings = function(settings) {
    // Pre-fill controls from a schedule row
    const catSel = $('ctrl-category');
    if (settings.category) catSel.value = settings.category;
    const gtSel = $('ctrl-gametype');
    if (settings.game_type) gtSel.value = settings.game_type;
    const posSel = $('ctrl-pos');
    if (settings.pos_filter) posSel.value = settings.pos_filter;
    const viewSel = $('ctrl-view');
    if (settings.view) viewSel.value = settings.view;
    const toiEl = $('ctrl-toi');
    if (settings.min_toi != null) toiEl.value = settings.min_toi;
    syncControls();
    // Scroll to controls
    document.querySelector('.controls').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  window.markPosted = async function(slug, btn) {
    btn.textContent = 'Saving…'; btn.disabled = true;
    try {
      const r = await fetch(`${API}/v1/admin/generator/calendar`, {
        method: 'POST',
        headers: { Authorization: `Bearer ${_token}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ category: slug }),
      });
      if (r.ok) {
        const el = $(`calwhen-${slug}`);
        if (el) { el.textContent = 'Posted today'; el.className = 'cal-when fresh'; }
        btn.textContent = 'Posted ✓'; btn.classList.add('posted');
        setTimeout(() => { btn.textContent = 'Mark Posted'; btn.classList.remove('posted'); btn.disabled = false; }, 2000);
      } else {
        btn.textContent = 'Mark Posted'; btn.disabled = false;
      }
    } catch(e) { btn.textContent = 'Mark Posted'; btn.disabled = false; }
  };

  // ── Helpers ───────────────────────────────────────────────────────────────
  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Boot ──────────────────────────────────────────────────────────────────
  init();
})();
</script>

</body>
</html>
