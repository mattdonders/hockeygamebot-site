---
// HockeyGameBot — /support page
import Base from '../layouts/Base.astro';
const currentPath = '/support';
---
<Base title="Support · HockeyGameBot" description="32 team bots. Live scores. Win probability charts. All automated, all season. Help keep HockeyGameBot running." currentPath={currentPath}>

<style is:global>
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }
.wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

/* ── MASTHEAD ── */
.mast {
  position: relative;
  border-bottom: 2px solid var(--ink);
  background-color: var(--bg);
  background-image:
    linear-gradient(var(--ink-04) 1px, transparent 1px),
    linear-gradient(90deg, var(--ink-04) 1px, transparent 1px);
  background-size: 48px 48px;
}
.mast-ghost {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  font-family: var(--display); font-weight: 800; font-size: clamp(80px, 18vw, 180px);
  letter-spacing: -0.01em; text-transform: uppercase;
  color: var(--ink); opacity: 0.05; pointer-events: none; white-space: nowrap; user-select: none;
}
.mast-corners { position: absolute; inset: 0; pointer-events: none; }
.corner { position: absolute; width: 16px; height: 16px; opacity: 0.2; }
.corner::before, .corner::after { content: ''; position: absolute; background: var(--ink); }
.corner::before { width: 2px; height: 100%; }
.corner::after  { width: 100%; height: 2px; }
.corner.tl { top: 12px; left: 12px; }
.corner.tr { top: 12px; right: 12px; }
.corner.tr::before { right: 0; }
.corner.tr::after  { right: 0; }
.mast-inner { position: relative; z-index: 2; padding: 36px 0; }
.mast-top { display: flex; align-items: center; margin-bottom: 20px;
  font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
.mast-top-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
  text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
.mast-top-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
.mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px;
  display: flex; align-items: flex-start; gap: 64px; }
.mast-left { flex: 1; display: flex; flex-direction: column; gap: 12px; }
.mast-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--red); }
.mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(40px, 5vw, 64px); letter-spacing: -0.01em; text-transform: uppercase; line-height: 0.95; }
.mast-sub { font-family: var(--body); font-size: 15px; color: var(--ink-56); line-height: 1.6; max-width: 420px; margin-top: 4px; }
.mast-right { flex: 0 0 auto; display: flex; flex-direction: column; gap: 16px; padding-top: 4px; }
.btn-kofi {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--ink); color: var(--surface);
  font-family: var(--display); font-weight: 800; font-size: 14px; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 14px 28px; border: none; cursor: pointer;
  transition: opacity .15s; text-decoration: none; white-space: nowrap;
}
.btn-kofi:hover { opacity: 0.82; }
.mast-cost-pill {
  font-family: var(--mono); font-size: 11px; color: var(--ink-48); text-align: center; letter-spacing: 0.06em;
}
.mast-cost-pill strong { color: var(--ink); }

/* ── SECTIONS ── */
.content { padding: 0 0 80px; }
.section { padding: 56px 0; border-bottom: 1px solid var(--ink-14); }
.section:last-child { border-bottom: none; }
.section-inner { max-width: 680px; }
.section-eyebrow { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 10px; }
.section-title { font-family: var(--display); font-weight: 800; font-size: 28px; letter-spacing: 0.02em; text-transform: uppercase; margin-bottom: 20px; }
.prose { display: flex; flex-direction: column; gap: 16px; }
.prose p { font-size: 15px; color: var(--ink-72); line-height: 1.7; }

/* ── COST TABLE ── */
.cost-table-wrap { border: 1.5px solid var(--ink-14); margin: 24px 0 20px; overflow-x: auto; }
.cost-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.cost-table th {
  padding: 10px 16px;
  text-align: left;
  font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ink-48); background: var(--bg-2);
  border-bottom: 1.5px solid var(--ink-14);
}
.cost-table td { padding: 12px 16px; border-bottom: 1px solid var(--ink-06); color: var(--ink-72); }
.cost-table tr:last-child td { border-bottom: none; }
.cost-table td:first-child { font-weight: 600; color: var(--ink); }
.cost-table td:nth-child(2) { font-family: var(--mono); font-weight: 600; color: var(--ink); white-space: nowrap; }
.cost-total td { background: var(--surface); border-top: 1.5px solid var(--ink-14); }
.cost-total td:nth-child(2) { color: var(--red); font-size: 15px; }
.cost-note { font-size: 13px; color: var(--ink-56); line-height: 1.65; margin-bottom: 8px; }
.cost-note--accent {
  color: var(--ink); font-weight: 500;
  border-left: 3px solid var(--red); padding-left: 14px; margin-top: 16px;
  font-family: var(--mono); font-size: 12px;
}

/* ── CTA ── */
.section--cta { background: var(--ink); border-bottom: none; }
.section--cta .section-eyebrow { color: rgba(239,238,232,0.4); }
.section--cta .section-title { color: var(--surface); }
.section--cta .prose p { color: rgba(239,238,232,0.6); }
.btn-kofi-light {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--surface); color: var(--ink);
  font-family: var(--display); font-weight: 800; font-size: 14px; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 14px 28px; border: none; cursor: pointer;
  transition: opacity .15s; text-decoration: none; margin-top: 24px;
}
.btn-kofi-light:hover { opacity: 0.88; }
.cta-note { font-family: var(--mono); font-size: 12px; color: rgba(239,238,232,0.4); margin-top: 16px; line-height: 1.6; }
.cta-note a { color: rgba(239,238,232,0.65); }
.cta-note a:hover { color: var(--surface); }

/* ── FOOTER ── */
.footer { border-top: 1.5px solid var(--ink-14); padding: 24px 0; }
.footer-bar { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
.footer-copy { font-family: var(--mono); font-size: 11px; color: var(--ink-32); }
.footer-links { display: flex; gap: 16px; margin-left: auto; }
.footer-links a { font-family: var(--mono); font-size: 11px; color: var(--ink-48); transition: color .15s; }
.footer-links a:hover { color: var(--ink); }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .mast-card { flex-direction: column; gap: 32px; padding: 24px 20px 20px; }
  .mast-right { align-self: flex-start; }
  .mast-inner { padding: 28px 0; }
}
@media (max-width: 480px) {
  .wrap { padding: 0 16px; }
  .mast-headline { font-size: clamp(36px, 12vw, 52px); }
  .cost-table th:nth-child(3), .cost-table td:nth-child(3) { display: none; }
}
</style>

<!-- ── MASTHEAD ── -->
<section class="mast">
  <div class="mast-ghost">SUPPORT</div>
  <div class="mast-corners"><div class="corner tl"></div><div class="corner tr"></div></div>
  <div class="wrap">
    <div class="mast-inner">
      <div class="mast-top">
        <span class="mast-top-eyebrow"><span class="pip"></span> HockeyGameBot · Support</span>
      </div>
      <div class="mast-card">
        <div class="mast-left">
          <span class="mast-eyebrow">Support the Project</span>
          <h1 class="mast-headline">One person.<br/>32 bots.</h1>
          <p class="mast-sub">HockeyGameBot is a solo side project — a network of 32 NHL team bots that track every game, every night, all season. Help keep it running.</p>
        </div>
        <div class="mast-right">
          <a href="https://ko-fi.com/hockeygamebot" class="btn-kofi" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            Support on Ko-fi
          </a>
          <p class="mast-cost-pill">Running costs: <strong>~$77/mo</strong></p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── CONTENT ── -->
<div class="content">
  <div class="wrap">

    <!-- What is this -->
    <div class="section">
      <div class="section-inner">
        <p class="section-eyebrow">Background</p>
        <h2 class="section-title">What is HockeyGameBot?</h2>
        <div class="prose">
          <p>HockeyGameBot is a side project I've been building since 2019 — a network of 32 team-specific bots, one for every NHL franchise, that automatically track live games and post updates to X and Bluesky. Goals, penalties, pre-game charts, period recaps, milestones, three stars, final scores. All of it, automatically, every night.</p>
          <p>There's also a live Twitch scoreboard showing every game at once, a website with detailed game cards and advanced analytics, and playoff cards that generate automatically after every series result.</p>
          <p>One person, one server, a little Claude Code, and a lot of Python. Everything you see was built from the ground up.</p>
        </div>
      </div>
    </div>

    <!-- Cost table -->
    <div class="section">
      <div class="section-inner">
        <p class="section-eyebrow">Transparency</p>
        <h2 class="section-title">What it costs to run</h2>
        <p class="cost-note">These are the real monthly numbers during the regular season and playoffs.</p>
        <div class="cost-table-wrap">
          <table class="cost-table">
            <thead>
              <tr>
                <th>Service</th>
                <th>Cost</th>
                <th>What it does</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Cloud Server</td>
                <td>~$12/mo</td>
                <td>Runs all 32 bots simultaneously without interruption</td>
              </tr>
              <tr>
                <td>X (Twitter) API</td>
                <td>~$65/mo</td>
                <td>32 accounts × ~$2/mo avg, required to post anything</td>
              </tr>
              <tr>
                <td>Cloudflare Workers</td>
                <td>~$0</td>
                <td>API layer and live scoreboard backend (free tier)</td>
              </tr>
              <tr class="cost-total">
                <td>Total (peak)</td>
                <td>~$77/mo</td>
                <td></td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="cost-note">Offseason costs drop significantly. X API fees are by far the biggest line item — posting from 32 accounts adds up fast.</p>
        <p class="cost-note cost-note--accent">Every dollar goes directly to keeping the lights on.</p>
      </div>
    </div>

    <!-- Want to help -->
    <div class="section">
      <div class="section-inner">
        <p class="section-eyebrow">Get involved</p>
        <h2 class="section-title">Want to help?</h2>
        <div class="prose">
          <p>Right now, supporting just means helping keep this running. There's no paywall, no member dashboard, no tier system — just a support link and an honest ask.</p>
          <p>If you follow one of the bots and get value from it, any contribution helps cover the server, the API costs, and the time that goes into building new features.</p>
          <p>Perks and supporter features are coming. But for now, thank you.</p>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- ── CTA ── -->
<section class="section--cta">
  <div class="wrap">
    <div class="section-inner">
      <p class="section-eyebrow">Ready?</p>
      <h2 class="section-title">Support HockeyGameBot</h2>
      <a href="https://ko-fi.com/hockeygamebot" class="btn-kofi-light" target="_blank" rel="noopener">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        Support on Ko-fi
      </a>
      <p class="cta-note">Not ready to support? Follow your team bot — it's free and it helps more than you'd think.<br/><a href="/teams">Find your team bot →</a></p>
    </div>
  </div>
</section>

<!-- ── FOOTER ── -->
<footer class="footer">
  <div class="wrap footer-bar">
    <span class="footer-copy">© 2026 HockeyGameBot</span>
    <nav class="footer-links">
      <a href="/">Home</a>
      <a href="/stats">Stats</a>
      <a href="/teams">Teams</a>
      <a href="https://ko-fi.com/hockeygamebot" target="_blank" rel="noopener">Ko-fi</a>
    </nav>
  </div>
</footer>

</Base>
