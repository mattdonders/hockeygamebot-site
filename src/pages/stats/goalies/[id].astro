---
import Nav from '../../../components/Nav.astro';
import ThemeScript from '../../../components/ThemeScript.astro';
import Fonts from '../../../components/Fonts.astro';
import Table from '../../../components/Table.astro';
import { loadGoalies } from '../../../lib/stats-loader';
import { pickTeamColor } from '../../../lib/team-colors';
import type { GoalieRecord } from '../../../lib/stats-schemas';

export async function getStaticPaths() {
  const SA_QUAL = 500; // minimum shots against to be "qualified" for ranking
  const goalies = loadGoalies();
  // Rank qualified goalies (min 500 SA) by GSAx, descending.
  const qualified = goalies
    .filter(g => g.sa >= SA_QUAL)
    .sort((a, b) => b.gsax - a.gsax);
  const rankById = new Map<number, number>();
  qualified.forEach((g, i) => rankById.set(g.goalie_id, i + 1));

  return goalies.map(g => ({
    params: { id: String(g.goalie_id) },
    props:  {
      goalie:    g,
      gsaxRank:  rankById.get(g.goalie_id) ?? null,
      qualCount: qualified.length,
    },
  }));
}

interface Props { goalie: GoalieRecord; gsaxRank: number | null; qualCount: number }
const { goalie, gsaxRank, qualCount } = Astro.props;

const SA_QUAL    = 500; // keep in sync with getStaticPaths qualifier
const hasTeam    = goalie.team_abbrev != null && goalie.team_abbrev !== '???' && goalie.team_abbrev !== '';
const teamColor  = hasTeam ? pickTeamColor(goalie.team_abbrev) : '#8a8a8a';
const initial    = goalie.name.split('.')[0]?.trim() ?? '';
const lastName   = goalie.name.split('.').pop()?.trim() ?? goalie.name;
const gsaxSign   = goalie.gsax >= 0 ? '+' : '';
const headshotUrl = `https://assets.nhle.com/mugs/nhl/20252026/${goalie.team_abbrev}/${goalie.goalie_id}.png`;
const vsExp      = goalie.sv_pct != null && goalie.sa > 0
  ? +((goalie.sv_pct - (1 - goalie.xga / goalie.sa)) * 100).toFixed(2)
  : null;

// ── Cumulative chart ───────────────────────────────────────────────────────
const games = [...goalie.games].sort((a, b) => a.game_date.localeCompare(b.game_date));
const cumPoints: { game: number; gsax: number }[] = [];
let cum = 0;
for (const [i, g] of games.entries()) {
  cum += g.gsax;
  cumPoints.push({ game: i + 1, gsax: +cum.toFixed(2) });
}

const SVG_W = 720, SVG_H = 180;
const PAD = { t: 16, r: 16, b: 28, l: 44 };
const cW = SVG_W - PAD.l - PAD.r;
const cH = SVG_H - PAD.t - PAD.b;
const xMax = cumPoints.length || 1;
const yVals = cumPoints.map(p => p.gsax);
let yMin = Math.min(0, ...yVals), yMax = Math.max(0, ...yVals);
const yPad = (yMax - yMin) * 0.12;
yMin -= yPad; yMax += yPad;

const cpx  = (g: number) => PAD.l + (g / xMax) * cW;
const cpy  = (v: number) => PAD.t + cH - ((v - yMin) / (yMax - yMin)) * cH;
const cpy0 = cpy(0);
const path = cumPoints.map((p, i) =>
  `${i === 0 ? 'M' : 'L'}${cpx(p.game).toFixed(1)},${cpy(p.gsax).toFixed(1)}`
).join(' ');
const areaPath = cumPoints.length >= 2
  ? `${path} L${cpx(xMax).toFixed(1)},${cpy0.toFixed(1)} L${cpx(1).toFixed(1)},${cpy0.toFixed(1)} Z`
  : '';

// ── xG-tier bar chart data ─────────────────────────────────────────────────
const binAbsMax = Math.max(...goalie.bins.map(b => Math.abs(b.gsax)), 1);
// bar width = percentage of max, full bar = 120px
const BAR_MAX_W = 120;

// Short bin labels for display
const BIN_SHORT: Record<string, string> = {
  'Easiest (0-20%)': 'Easiest',
  'Low (20-40%)':    'Low',
  'Medium (40-60%)': 'Medium',
  'Hard (60-80%)':   'Hard',
  'Hardest (80-100%)': 'Hardest',
};

// Shot-type breakdown table (Table.astro consumer) —————————————————————————
const shotTypeRows = goalie.types.map(t => ({
  shot_type_group: t.shot_type_group,
  sa:              t.sa,
  sv_pct:          t.sv_pct,
  league_sv_pct:   t.league_sv_pct,
  gsax:            t.gsax,
}));
const signedColor = (v: any, _r: any, tok?: { pos: string; neg: string }) => {
  if (v == null) return undefined;
  return v >= 0 ? tok?.pos : tok?.neg;
};
const shotTypeColumns = [
  { key: 'shot_type_group', label: 'Type',   type: 'label' as const, bold: true },
  { key: 'sa',              label: 'SA',     type: 'number' as const },
  { key: 'sv_pct',          label: 'SV%',    type: 'number' as const,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(3) },
  { key: 'league_sv_pct',   label: 'Lg SV%', type: 'number' as const,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(3) },
  { key: 'gsax',            label: 'GSAx',   type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : (v >= 0 ? '+' : '') + Number(v).toFixed(1),
    color: signedColor },
];

// ── Tweet-card data (passed to client script via define:vars) ───────────────
// dSv% = actual SV% minus expected SV% (xsv_pct). Both stored as fractions.
const dSvPct = goalie.dsv_pct != null
  ? goalie.dsv_pct
  : (goalie.sv_pct != null && goalie.xsv_pct != null ? goalie.sv_pct - goalie.xsv_pct : null);

const cardData = {
  name:       goalie.name,
  goalieId:   goalie.goalie_id,
  team:       goalie.team_abbrev,
  hasTeam,
  teamColor,
  headshotUrl,
  gsax:       goalie.gsax,
  svPct:      goalie.sv_pct ?? null,
  gaa:        goalie.gaa ?? null,
  dSvPct,
  sa:         goalie.sa,
  rank:       gsaxRank,
  qualCount,
  saQual:     SA_QUAL,
  // Tier bars — re-map raw bin_label to the canonical 5-tier display label
  bins: goalie.bins.map(b => ({
    label:        BIN_SHORT[b.bin_label] ?? b.bin_label,
    gsax:         b.gsax,
    svPct:        b.sv_pct ?? null,
    leagueSvPct:  b.league_sv_pct,
    sa:           b.sa,
  })),
  edge: goalie.edge ?? null,
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{goalie.name} · Goalie GSAx · HGB Stats</title>
  <meta name="description" content={`${goalie.name} (${goalie.team_abbrev}) — GSAx ${gsaxSign}${goalie.gsax.toFixed(2)}, SV% ${goalie.sv_pct != null ? (goalie.sv_pct * 100).toFixed(2) : '—'}%. HGB xG-model goalie analysis, 2025–26.`} />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #EFEEE8;
      --ink:      #0d0d14;
      --red:      #E8002D;
      --green:    #1a7a3e;
      --surface:  #FFFFFF;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04:   rgba(13,13,20,0.04);
      --ink-06:   rgba(13,13,20,0.06);
      --ink-10:   rgba(13,13,20,0.10);
      --ink-14:   rgba(13,13,20,0.14);
      --ink-20:   rgba(13,13,20,0.20);
      --ink-32:   rgba(13,13,20,0.32);
      --ink-48:   rgba(13,13,20,0.48);
      --ink-72:   rgba(13,13,20,0.72);
      --display:  'Barlow Condensed', sans-serif;
      --body:     'Barlow', sans-serif;
      --mono:     'JetBrains Mono', monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    /* ── Masthead ── */
    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
      margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .back-link { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; color: var(--ink-48);
      text-decoration: none; }
    .back-link:hover { color: var(--ink); }

    /* ── Hero card (matches player page) ── */
    .mast-top a { color: var(--ink-48); text-decoration: none; }
    .mast-top a:hover { color: var(--ink); }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); border-left-width: 4px; padding: 24px 28px; }
    .hero { display: grid; grid-template-columns: auto 1fr; gap: 28px; align-items: start; }
    .headshot-wrap { position: relative; width: 168px; flex-shrink: 0; }
    .headshot { width: 168px; height: 168px; object-fit: cover; border: 2px solid var(--ink-14);
      background: var(--surface); display: block; }
    .headshot-team-bar { position: absolute; bottom: 0; left: 0; right: 0; height: 4px; }
    .hero-identity { display: flex; flex-direction: column; gap: 8px; }
    .hero-badges { display: flex; gap: 6px; flex-wrap: wrap; }
    .badge { display: inline-block; font-family: var(--mono); font-size: 9px; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase; padding: 2px 7px;
      border: 1px solid var(--ink-20); color: var(--ink-48); }
    .hero-name { font-family: var(--display); font-weight: 800; text-transform: uppercase;
      line-height: 0.92; letter-spacing: -0.01em; }
    .hero-name .first { font-size: 22px; color: var(--ink-48); font-weight: 700; }
    .hero-name .last  { font-size: clamp(40px, 5vw, 64px); color: var(--ink); display: block; }
    .hero-stats { display: flex; flex-wrap: wrap; gap: 0; margin-top: 8px; }
    .stat-cell { padding: 10px 20px 10px 0; min-width: 80px; }
    .stat-cell + .stat-cell { border-left: 1px solid var(--ink-10); padding-left: 20px; }
    .stat-label { font-family: var(--mono); font-size: 9px; font-weight: 700;
      letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-32); margin-bottom: 4px; }
    .stat-value { font-family: var(--display); font-weight: 800; font-size: 28px;
      line-height: 1.0; letter-spacing: -0.01em; }
    .stat-value.pos { color: var(--green); }
    .stat-value.neg { color: var(--red); }
    @media (max-width: 640px) {
      .hero { grid-template-columns: 1fr; gap: 16px; }
      .headshot-wrap { width: 100px; }
      .headshot { width: 100px; height: 100px; }
    }

    /* ── Layout ── */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; padding-top: 32px; }
    @media (max-width: 768px) { .two-col { grid-template-columns: 1fr; } }

    /* ── Section cards ── */
    .sec-card { background: var(--surface); border: 1px solid var(--ink-14); }
    .sec-head { padding: 14px 20px 10px; border-bottom: 1px solid var(--ink-10); }
    .sec-title { font-family: var(--display); font-weight: 800; font-size: 14px;
      text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink); }
    .sec-sub { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32);
      letter-spacing: 0.06em; margin-top: 2px; }
    .sec-body { padding: 16px 20px; }

    /* ── Cumulative chart ── */
    .chart-full { padding-top: 32px; }
    .chart-full .sec-card { }
    .chart-svg { width: 100%; height: auto; display: block; }

    /* ── xG Tier chart ── */
    .bin-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .bin-row:last-child { margin-bottom: 0; }
    .bin-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.04em;
      color: var(--ink-48); width: 62px; flex-shrink: 0; text-align: right; }
    .bin-bars { flex: 1; position: relative; height: 20px; display: flex; align-items: center; }
    .bin-zero { position: absolute; left: 50%; top: 0; bottom: 0; width: 1px;
      background: var(--ink-20); }
    .bin-bar { height: 14px; border-radius: 1px; position: absolute; }
    .bin-bar.pos { background: var(--green); left: 50%; }
    .bin-bar.neg { background: var(--red); right: 50%; }
    .bin-gsax { font-family: var(--mono); font-size: 10px; font-weight: 700;
      width: 52px; flex-shrink: 0; }
    .bin-gsax.pos { color: var(--green); }
    .bin-gsax.neg { color: var(--red); }
    .bin-svpct { font-family: var(--mono); font-size: 9px; white-space: nowrap;
      min-width: 48px; text-align: right; }

    /* Shot-type table chrome lives in Table.astro now. */
    .sec-body .tbl-wrap { border: none; }

    @media (max-width: 768px) {
      .mast-inner, .wrap { padding-left: 16px; padding-right: 16px; }
      .hero-card { grid-template-columns: 4px 1fr; }
      .hero-name { font-size: 36px; }
    }
  </style>
</head>
<body>

<Nav currentPath="/stats/goalies" />

<!-- ── Masthead ── -->
<header class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div><a href="/stats/goalies">← Goalies</a></div>
      <div>{goalie.team_abbrev} · G · {goalie.sa.toLocaleString()} SA · 2025–26</div>
    </div>

    <div class="mast-card" style={`border-left-color:${teamColor}`}>
      <div class="hero">
        <div class="headshot-wrap">
          <img class="headshot" src={headshotUrl} alt={goalie.name} width="168" height="168"
            onerror="this.src='https://assets.nhle.com/logos/nhl/svg/${goalie.team_abbrev}_light.svg';this.style.objectFit='contain';this.style.padding='24px'" />
          <div class="headshot-team-bar" style={`background:${teamColor}`}></div>
        </div>
        <div class="hero-identity">
          <div class="hero-badges">
            <span class="badge">{goalie.team_abbrev}</span>
            <span class="badge">G</span>
            <span class="badge">{gsaxSign}{goalie.gsax.toFixed(1)} GSAx</span>
            <button id="dl-goalie-card" type="button"
              style={`margin-left:auto;cursor:pointer;font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:4px 10px;border:none;background:${teamColor};color:#fff;`}>
              Download Card →
            </button>
          </div>
          <div id="goalie-card-status" style="display:none;font-family:var(--mono);font-size:9px;letter-spacing:0.08em;color:var(--ink-48)"></div>
          <div class="hero-name">
            <span class="first">{initial}.</span>
            <span class="last">{lastName}</span>
          </div>
          <div class="hero-stats">
            <div class="stat-cell">
              <div class="stat-label">GSAx</div>
              <div class={`stat-value ${goalie.gsax >= 0 ? 'pos' : 'neg'}`}>{gsaxSign}{goalie.gsax.toFixed(1)}</div>
            </div>
            <div class="stat-cell">
              <div class="stat-label">SV%</div>
              <div class="stat-value">{goalie.sv_pct != null ? goalie.sv_pct.toFixed(3) : '—'}</div>
            </div>
            <div class="stat-cell">
              <div class="stat-label">xGA</div>
              <div class="stat-value">{goalie.xga.toFixed(1)}</div>
            </div>
            <div class="stat-cell">
              <div class="stat-label">GA</div>
              <div class="stat-value">{goalie.ga}</div>
            </div>
            {vsExp != null && (
              <div class="stat-cell">
                <div class="stat-label">vs Exp</div>
                <div class={`stat-value ${vsExp >= 0 ? 'pos' : 'neg'}`}>
                  {vsExp >= 0 ? '+' : ''}{vsExp.toFixed(2)}%
                </div>
              </div>
            )}
            <div class="stat-cell">
              <div class="stat-label">5v5 SA</div>
              <div class="stat-value">{goalie.sa_5v5.toLocaleString()}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<main class="wrap">

  <!-- ── Cumulative GSAx chart (first) ── -->
  {cumPoints.length > 1 && (
    <div class="chart-full">
      <div class="sec-card">
        <div class="sec-head">
          <div class="sec-title">Cumulative GSAx — Season</div>
          <div class="sec-sub">{cumPoints.length} games · final: {gsaxSign}{goalie.gsax.toFixed(2)}</div>
        </div>
        <div style="padding:16px 16px 8px">
          <svg class="chart-svg" viewBox={`0 0 ${SVG_W} ${SVG_H}`} preserveAspectRatio="xMidYMid meet">
            {[...Array(5)].map((_, i) => {
              const gv = yMin + (i / 4) * (yMax - yMin);
              const gy = cpy(gv).toFixed(1);
              return (
                <g>
                  <line x1={PAD.l} y1={gy} x2={PAD.l + cW} y2={gy} stroke="rgba(13,13,20,0.06)" stroke-width="1" />
                  <text x={(PAD.l - 6).toFixed(1)} y={gy} text-anchor="end" dominant-baseline="middle"
                    font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(13,13,20,0.32)">
                    {gv >= 0 ? '+' : ''}{gv.toFixed(0)}
                  </text>
                </g>
              );
            })}
            <line x1={PAD.l} y1={cpy0.toFixed(1)} x2={(PAD.l + cW).toFixed(1)} y2={cpy0.toFixed(1)}
              stroke="rgba(13,13,20,0.28)" stroke-width="1.5" stroke-dasharray="4 3" />
            {areaPath && <path d={areaPath} fill={teamColor} fill-opacity="0.07" />}
            <path d={path} fill="none" stroke={teamColor} stroke-width="2"
              stroke-linejoin="round" stroke-linecap="round" />
            {cumPoints.length > 0 && (
              <circle cx={cpx(cumPoints[cumPoints.length-1].game).toFixed(1)}
                cy={cpy(cumPoints[cumPoints.length-1].gsax).toFixed(1)}
                r="3.5" fill={teamColor} />
            )}
            <text x={(PAD.l + cW / 2).toFixed(1)} y={(SVG_H - 4).toFixed(1)}
              text-anchor="middle" font-family="JetBrains Mono, monospace"
              font-size="9" fill="rgba(13,13,20,0.28)" letter-spacing="0.08em">GAME #</text>
          </svg>
        </div>
      </div>
    </div>
  )}

  <!-- ── Two-column: xG bins + shot types ── -->
  <div class="two-col">

    <!-- xG Tier breakdown -->
    <div class="sec-card">
      <div class="sec-head">
        <div class="sec-title">GSAx by xG Tier</div>
        <div class="sec-sub">How many goals saved above expected within each shot difficulty band</div>
      </div>
      <div class="sec-body">
        {goalie.bins.length > 0 ? (
          <>
            {goalie.bins.map(b => {
              const pct = Math.min(Math.abs(b.gsax) / binAbsMax, 1);
              const barW = Math.round(pct * BAR_MAX_W / 2);  // half-bar from center
              const isPos = b.gsax >= 0;
              const svDiff = b.sv_pct != null
                ? +((b.sv_pct - b.league_sv_pct) * 100).toFixed(1)
                : null;
              return (
                <div class="bin-row">
                  <div class="bin-label">{BIN_SHORT[b.bin_label] ?? b.bin_label}</div>
                  <div class="bin-bars">
                    <div class="bin-zero"></div>
                    <div class={`bin-bar ${isPos ? 'pos' : 'neg'}`} style={`width:${barW}px`}></div>
                  </div>
                  <div class={`bin-gsax ${isPos ? 'pos' : 'neg'}`}>{isPos ? '+' : ''}{b.gsax.toFixed(1)}</div>
                  {svDiff != null && svDiff !== 0 && (
                    <div class="bin-svpct" style={`color:${svDiff > 0 ? 'var(--green)' : 'var(--red)'}`}>
                      {svDiff > 0 ? '+' : ''}{svDiff.toFixed(1)}%
                    </div>
                  )}
                  {svDiff != null && svDiff === 0 && (
                    <div class="bin-svpct" style="color:var(--ink-32)">±0%</div>
                  )}
                </div>
              );
            })}
            <div style="margin-top:14px;font-family:var(--mono);font-size:9px;color:var(--ink-32);letter-spacing:0.06em">
              BAR WIDTH = |GSAX| · % COLUMN = SV% VS LEAGUE AVG
            </div>
          </>
        ) : (
          <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:12px 0">
            Tier breakdown available after next pipeline run.
          </div>
        )}
      </div>
    </div>

    <!-- Shot-type breakdown -->
    <div class="sec-card">
      <div class="sec-head">
        <div class="sec-title">GSAx by Shot Type</div>
        <div class="sec-sub">Performance vs league-average save rate per shot category</div>
      </div>
      <div class="sec-body" style="padding:0">
        {goalie.types.length > 0 ? (
          <Table
            columns={shotTypeColumns}
            rows={shotTypeRows}
            sticky={false}
            ariaLabel="GSAx by shot type"
          />
        ) : (
          <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:16px 20px">
            Shot-type breakdown available after next pipeline run.
          </div>
        )}
      </div>
    </div>
  </div>


</main>

<footer style="max-width:1100px;margin:0 auto;padding:20px 32px;font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(13,13,20,0.20)">
  HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026 · GSAx XGBoost AUC 0.77
</footer>

<canvas id="goalie-card-canvas" style="display:none"></canvas>

<script define:vars={{ G: cardData }}>
  (function () {
    const status = document.getElementById('goalie-card-status');
    const btn    = document.getElementById('dl-goalie-card');
    if (!btn) return;

    // ── palette (matches skater card) ──────────────────────────────────────
    const BG      = '#EFEEE8';
    const SURFACE = '#FFFFFF';
    const INK     = '#0D0D14';
    const RED     = '#E8002D';
    const GREEN   = '#1a7a3e';
    const INK72   = 'rgba(13,13,20,0.72)';
    const INK48   = 'rgba(13,13,20,0.48)';
    const INK32   = 'rgba(13,13,20,0.32)';
    const INK20   = 'rgba(13,13,20,0.20)';
    const INK14   = 'rgba(13,13,20,0.14)';
    const INK10   = 'rgba(13,13,20,0.10)';
    const INK06   = 'rgba(13,13,20,0.06)';
    const TEAM_C  = G.hasTeam ? (G.teamColor || INK) : '#8a8a8a';

    const TEAM_NAMES = {
      ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',
      BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',
      CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',
      DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',
      FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',
      MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',
      NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',
      PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',
      SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',
      TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',
      VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS',
    };

    // ── helpers (same patterns as skater card) ─────────────────────────────
    function rrect(ctx, x, y, w, h, r) {
      ctx.beginPath();
      if (typeof ctx.roundRect === 'function') { ctx.roundRect(x, y, w, h, r); }
      else {
        ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
        ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
        ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
        ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath();
      }
    }
    function loadImg(src) {
      return new Promise(res => {
        const img = new Image(); img.crossOrigin = 'anonymous';
        img.onload = () => res(img); img.onerror = () => res(null);
        img.src = src;
      });
    }
    function ordinal(n) {
      const a = Math.round(n), m10 = a % 10, m100 = a % 100;
      if (m100 >= 11 && m100 <= 13) return a + 'th';
      if (m10 === 1) return a + 'st';
      if (m10 === 2) return a + 'nd';
      if (m10 === 3) return a + 'rd';
      return a + 'th';
    }
    const sgn = (v) => (v >= 0 ? '+' : '');
    // Save % as ".923" (no leading zero); null → "—"
    const svStr = (v) => v == null ? '—' : v.toFixed(3).replace(/^0/, '');

    // ── EDGE drawing helpers (goalie) ─────────────────────────────────────
    function edgeTierColor(pct) {
      if (pct == null) return INK32;
      if (pct >= 75) return GREEN;
      if (pct >= 50) return '#34a853';
      if (pct >= 25) return INK32;
      return RED;
    }

    function drawEdgeStatBox(ctx, x, y, w, h, lbl, valStr, pct100, avgStr) {
      ctx.fillStyle = '#FFFFFF'; ctx.beginPath(); ctx.roundRect(x, y, w, h, 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(x, y, w, h, 4); ctx.stroke();
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText(lbl, x + 10, y + 9);
      ctx.font = '800 28px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'top';
      ctx.fillText(valStr, x + 10, y + 22);
      const bx = x + 10, bw = w - 20, bh = 5, by = h - 28 + y;
      ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(bx, by, bw, bh, 2); ctx.fill();
      const fc = edgeTierColor(pct100);
      if (pct100 != null) {
        ctx.fillStyle = fc; ctx.beginPath(); ctx.roundRect(bx, by, Math.max(5, (pct100 / 100) * bw), bh, 2); ctx.fill();
      }
      ctx.font = '600 9px "Barlow", sans-serif';
      ctx.fillStyle = fc; ctx.textBaseline = 'top';
      ctx.fillText(pct100 != null ? ordinal(Math.round(pct100)) + ' pct' : '', x + 10, by + 7);
      if (avgStr) {
        ctx.font = '400 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textAlign = 'right';
        ctx.fillText(avgStr, x + w - 10, by + 7);
        ctx.textAlign = 'left';
      }
    }

    function drawGoalieEdgeSection(ctx, baseY, W, PAD, e) {
      let y = baseY + 12;
      // Divider
      const divW = (W - PAD * 2 - 210) / 2;
      ctx.fillStyle = INK10; ctx.fillRect(PAD, y + 8, divW, 1);
      ctx.font = '700 8px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('NHL EDGE GOALIE TRACKING', W / 2, y + 8);
      ctx.fillStyle = INK10; ctx.fillRect(W / 2 + 105, y + 8, divW, 1);
      y += 24;

      // 3 stat boxes
      const bw = (W - PAD * 2 - 20) / 3, bh = 88;
      const ga900  = e.games_above_900;
      const gd60   = e.goal_diff_per60;
      const wpct   = e.point_pctg;
      const boxes = [
        { lbl: 'ELITE GAMES (>.900)',
          val: ga900?.value != null ? (ga900.value * 100).toFixed(1) + '%' : '—',
          pct: ga900?.pct != null ? ga900.pct * 100 : null,
          avg: ga900?.league_avg != null ? 'avg ' + (ga900.league_avg * 100).toFixed(1) + '%' : '' },
        { lbl: 'GOAL DIFF / 60',
          val: gd60?.value != null ? (gd60.value >= 0 ? '+' : '') + gd60.value.toFixed(2) : '—',
          pct: gd60?.pct != null ? gd60.pct * 100 : null,
          avg: gd60?.league_avg != null ? 'avg +' + gd60.league_avg.toFixed(2) : '' },
        { lbl: 'WIN %',
          val: wpct?.value != null ? (wpct.value * 100).toFixed(1) + '%' : '—',
          pct: wpct?.pct != null ? wpct.pct * 100 : null,
          avg: wpct?.league_avg != null ? 'avg ' + (wpct.league_avg * 100).toFixed(1) + '%' : '' },
      ];
      for (let i = 0; i < 3; i++) {
        drawEdgeStatBox(ctx, PAD + i * (bw + 10), y, bw, bh, boxes[i].lbl, boxes[i].val, boxes[i].pct, boxes[i].avg);
      }
      y += bh + 16;

      // Zone Sv% card
      const zones = e.zones || [];
      const ZONE_LABELS = ['HIGH DANGER', 'MID RANGE', 'LONG RANGE'];
      const colW = (W - PAD * 2 - 16) / 3;
      const CARD_H = 148;
      ctx.fillStyle = '#FFFFFF'; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 8, W - PAD * 2 + 4, CARD_H, 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 8, W - PAD * 2 + 4, CARD_H, 4); ctx.stroke();
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('SAVE % BY SHOT LOCATION', PAD + 8, y + 1);
      y += 18;

      const CHIP_H = 20;
      for (let i = 0; i < 3; i++) {
        const z = zones[i] || {};
        const cx = PAD + i * (colW + 8);
        let cy = y;
        const pct100 = z.svpct_pct != null ? z.svpct_pct * 100 : null;
        const fc = edgeTierColor(pct100);
        // zone chip
        const teamRgb = TEAM_C.startsWith('#') ? `rgba(${parseInt(TEAM_C.slice(1,3),16)},${parseInt(TEAM_C.slice(3,5),16)},${parseInt(TEAM_C.slice(5,7),16)},0.14)` : 'rgba(13,13,20,0.06)';
        ctx.fillStyle = i === 0 ? teamRgb : 'rgba(13,13,20,0.06)';
        ctx.beginPath(); ctx.roundRect(cx, cy, colW, CHIP_H, 2); ctx.fill();
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = i === 0 ? TEAM_C : INK32;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(ZONE_LABELS[i], cx + colW / 2, cy + CHIP_H / 2);
        cy += CHIP_H + 8;
        // Sv% value
        ctx.font = '800 30px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
        const svVal = z.svpct != null ? z.svpct.toFixed(3).replace(/^0/, '') : '—';
        ctx.fillText(svVal, cx, cy); cy += 33;
        // Percentile bar
        ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(cx, cy, colW, 5, 2); ctx.fill();
        if (pct100 != null) {
          ctx.fillStyle = fc; ctx.beginPath(); ctx.roundRect(cx, cy, Math.max(4, (pct100/100)*colW), 5, 2); ctx.fill();
        }
        cy += 7;
        ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = fc; ctx.textBaseline = 'top';
        ctx.fillText(pct100 != null ? ordinal(Math.round(pct100)) + ' percentile' : '', cx, cy); cy += 13;
        // League avg
        ctx.font = '400 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        const avgVal = z.svpct_league_avg != null ? 'avg ' + z.svpct_league_avg.toFixed(3).replace(/^0/, '') : '';
        ctx.fillText(avgVal, cx, cy);
      }
    }

    // ── card draw ──────────────────────────────────────────────────────────
    async function drawGoalieCard() {
      const SCALE = 2;
      const W = 750;
      const BASE_H = 900;
      const PAD = 28;
      const e = G.edge;
      const EDGE_H = e ? 300 : 0;
      const H = BASE_H + EDGE_H;

      const canvas = document.getElementById('goalie-card-canvas');
      canvas.width  = W * SCALE;
      canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.scale(SCALE, SCALE);

      // background
      ctx.fillStyle = BG;
      ctx.fillRect(0, 0, W, H);

      let y = 0;

      // ── HEADER BAND (white, ~110px) ───────────────────────────────────────
      const HDR_H = 110;
      ctx.fillStyle = SURFACE;
      ctx.fillRect(0, y, W, HDR_H);
      // team-color accent bar (6px). Neutral gray if no team.
      ctx.fillStyle = TEAM_C;
      ctx.fillRect(0, y, 6, HDR_H);

      // name
      ctx.font = '800 32px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK;
      ctx.textBaseline = 'alphabetic';
      ctx.textAlign = 'left';
      ctx.fillText(G.name.toUpperCase(), PAD, y + 44);

      // chips row: TEAM · G · +X.X GSAx
      const chipH = 18, chipY0 = y + 62;
      const gsaxChip = sgn(G.gsax) + G.gsax.toFixed(1) + ' GSAx';
      const chips = [
        { t: G.hasTeam ? G.team : 'FA', bg: TEAM_C,  fg: BG  },
        { t: 'G',                       bg: INK,     fg: BG  },
        { t: gsaxChip,                  bg: INK,     fg: BG, accent: G.gsax >= 0 ? GREEN : RED },
      ];
      let cx = PAD;
      ctx.font = '500 9px "JetBrains Mono", monospace';
      ctx.textBaseline = 'middle';
      for (const c of chips) {
        const tw = ctx.measureText(c.t).width;
        const cw = tw + 18;
        rrect(ctx, cx, chipY0, cw, chipH, 3);
        ctx.fillStyle = c.accent || c.bg; ctx.fill();
        ctx.fillStyle = c.fg; ctx.textAlign = 'left';
        ctx.fillText(c.t, cx + 9, chipY0 + chipH / 2 + 0.5);
        cx += cw + 8;
      }
      // HGB wordmark chip (red pill, right)
      const brand = 'HGB STATS';
      const btw = ctx.measureText(brand).width, bcw = btw + 18;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2 + 0.5);

      // header bottom border
      ctx.fillStyle = INK10;
      ctx.fillRect(0, y + HDR_H - 1, W, 1);
      y += HDR_H;

      // ── HERO ROW (~200px, cream) ─────────────────────────────────────────
      const HERO_H = 200;
      const R = 70, HS_CX = PAD + R, HS_CY = y + HERO_H / 2;
      const hsImg = await loadImg(G.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
      } else {
        ctx.fillStyle = INK10; ctx.fillRect(HS_CX - R, HS_CY - R, R * 2, R * 2);
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 3; ctx.stroke();

      // KPI grid (2×2) to the right
      const gridX = HS_CX + R + 28;
      const gridW = W - gridX - PAD;
      const dSvDisplay = G.dSvPct != null;
      const kpis = [
        { label: 'GSAx', val: sgn(G.gsax) + G.gsax.toFixed(1),
          color: G.gsax >= 0 ? GREEN : RED },
        { label: 'Sv%',  val: svStr(G.svPct), color: INK },
        { label: 'GAA',  val: G.gaa != null ? G.gaa.toFixed(2) : '—', color: INK },
      ];
      if (dSvDisplay) {
        // dSv% shown in percentage points
        const d = G.dSvPct * 100;
        kpis.push({ label: 'dSv%', val: (d >= 0 ? '+' : '') + d.toFixed(2),
          color: d >= 0 ? GREEN : RED });
      }
      const cols = 2;
      const cellW = gridW / cols;
      const cellH = HERO_H / 2 - 6;
      for (let i = 0; i < kpis.length; i++) {
        const k = kpis[i];
        const col = i % cols, row = Math.floor(i / cols);
        const kx = gridX + col * cellW;
        const ky = y + 18 + row * (cellH + 8);
        ctx.font = '500 10px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
        ctx.fillText(k.label.toUpperCase(), kx, ky + 12);
        ctx.font = '800 42px "Barlow Condensed", sans-serif';
        ctx.fillStyle = k.color;
        ctx.fillText(k.val, kx, ky + 56);
      }
      y += HERO_H;

      // ── RANK CONTEXT LINE (~40px) ────────────────────────────────────────
      const RANK_H = 40;
      ctx.font = '500 12px "JetBrains Mono", monospace';
      ctx.fillStyle = INK48; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      let rankTxt;
      if (G.rank != null) {
        rankTxt = ordinal(G.rank) + ' of ' + G.qualCount + ' qualified goalies (min. ' + G.saQual + ' SA)';
      } else {
        rankTxt = G.sa.toLocaleString() + ' shots against · below ' + G.saQual + ' SA qualifier';
      }
      ctx.fillText(rankTxt, W / 2, y + RANK_H / 2);
      y += RANK_H;

      // ── GSAx BY xG TIER BARS (~440px) ────────────────────────────────────
      const TIER_TOP = y + 8;
      // title
      ctx.font = '800 18px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
      ctx.fillText('GSAx BY xG DIFFICULTY TIER', PAD, TIER_TOP + 18);
      // subtitle
      ctx.font = '400 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32;
      ctx.fillText('GOALS SAVED ABOVE EXPECTED WITHIN EACH SHOT-DIFFICULTY BAND', PAD, TIER_TOP + 36);

      const barsTop = TIER_TOP + 56;
      const footerTop = BASE_H - 60;
      const barsBottom = footerTop - 16;

      if (G.bins && G.bins.length > 0) {
        const absMax = Math.max(...G.bins.map(b => Math.abs(b.gsax)), 1);
        const LABEL_W = 92;
        const VAL_W   = 130; // right column for GSAx + sv label
        const chartL  = PAD + LABEL_W;
        const chartR  = W - PAD - VAL_W;
        const zeroX   = chartL + (chartR - chartL) / 2;
        const halfW   = (chartR - chartL) / 2;
        const rowGap  = (barsBottom - barsTop) / G.bins.length;
        const barH    = Math.min(24, rowGap - 18);

        for (let i = 0; i < G.bins.length; i++) {
          const b = G.bins[i];
          const rowCY = barsTop + i * rowGap + rowGap / 2;
          const isPos = b.gsax >= 0;
          const barLen = (Math.abs(b.gsax) / absMax) * halfW;

          // tier label (left)
          ctx.font = '500 12px "JetBrains Mono", monospace';
          ctx.fillStyle = INK72; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
          ctx.fillText(b.label, PAD + LABEL_W - 12, rowCY);

          // zero line
          ctx.fillStyle = INK20;
          ctx.fillRect(zeroX, rowCY - barH / 2 - 4, 1, barH + 8);

          // bar
          ctx.fillStyle = isPos ? GREEN : RED;
          if (isPos) {
            rrect(ctx, zeroX, rowCY - barH / 2, Math.max(2, barLen), barH, 2);
          } else {
            rrect(ctx, zeroX - Math.max(2, barLen), rowCY - barH / 2, Math.max(2, barLen), barH, 2);
          }
          ctx.fill();

          // GSAx value at end of bar
          ctx.font = '500 13px "JetBrains Mono", monospace';
          ctx.fillStyle = isPos ? GREEN : RED;
          ctx.textBaseline = 'middle';
          if (isPos) {
            ctx.textAlign = 'left';
            ctx.fillText(sgn(b.gsax) + b.gsax.toFixed(1), zeroX + Math.max(2, barLen) + 8, rowCY);
          } else {
            ctx.textAlign = 'right';
            ctx.fillText(b.gsax.toFixed(1), zeroX - Math.max(2, barLen) - 8, rowCY);
          }

          // Sv% vs league label (far right)
          ctx.font = '400 9px "JetBrains Mono", monospace';
          ctx.fillStyle = INK32; ctx.textAlign = 'right';
          const svLbl = b.svPct != null
            ? svStr(b.svPct) + ' vs ' + svStr(b.leagueSvPct) + ' lg'
            : '— vs ' + svStr(b.leagueSvPct) + ' lg';
          ctx.fillText(svLbl, W - PAD, rowCY);
        }
      } else {
        ctx.font = '500 13px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('Tier breakdown refreshing — available after next pipeline run.',
          W / 2, (barsTop + barsBottom) / 2);
      }

      // ── FOOTER STRIP (~60px) ─────────────────────────────────────────────
      ctx.fillStyle = INK06;
      ctx.fillRect(0, footerTop, W, 1);
      ctx.font = '400 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      const footerLabel = e
        ? 'HOCKEYGAMEBOT.COM · 2025–26 · GSAx XGBoost · EDGE DATA: NHL'
        : 'HOCKEYGAMEBOT.COM · 2025–26 REGULAR SEASON · GSAx XGBoost';
      ctx.fillText(footerLabel, PAD, footerTop + 30);

      // ── NHL EDGE SECTION (appended below base card) ───────────────────────
      if (e) {
        drawGoalieEdgeSection(ctx, BASE_H, W, PAD, e);
      }

      return canvas;
    }

    // ── download modal (same pattern as skater card) ───────────────────────
    function showCardModal(canvas, filename) {
      document.getElementById('hgb-card-modal')?.remove();
      const dataUrl = canvas.toDataURL('image/png');
      const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
      const overlay = document.createElement('div');
      overlay.id = 'hgb-card-modal';
      overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.92);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:16px;';
      overlay.innerHTML = `
        <div style="position:relative;max-width:min(90vw,820px);width:100%;">
          <button id="hgb-modal-close" style="position:absolute;top:-40px;right:0;background:none;border:none;color:#fff;font-size:28px;cursor:pointer;line-height:1;opacity:0.7;">×</button>
          <img src="${dataUrl}" alt="${filename}" style="width:100%;height:auto;display:block;border:1px solid rgba(255,255,255,0.12);" />
          <div style="display:flex;align-items:center;justify-content:space-between;margin-top:10px;gap:12px;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(255,255,255,0.4);letter-spacing:0.06em;">
              ${isIOS ? 'Long-press image to save · ' : ''}${filename}
            </span>
            ${!isIOS ? `<a href="${dataUrl}" download="${filename}" style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.10em;text-transform:uppercase;padding:6px 14px;background:#fff;color:#0d0d14;text-decoration:none;white-space:nowrap;">↓ Download</a>` : ''}
          </div>
        </div>`;
      document.body.appendChild(overlay);
      document.getElementById('hgb-modal-close').addEventListener('click', () => overlay.remove());
      overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
      document.addEventListener('keydown', function esc(e) {
        if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', esc); }
      });
    }

    // ── wire button ────────────────────────────────────────────────────────
    btn.addEventListener('click', async () => {
      const label = btn.textContent;
      btn.textContent = 'Generating…'; btn.disabled = true;
      if (status) { status.style.display = 'block'; status.textContent = 'Drawing…'; }
      try {
        if (document.fonts && document.fonts.ready) await document.fonts.ready;
        const canvas = await drawGoalieCard();
        const slug = G.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        showCardModal(canvas, `hgb_goalie_${slug}_25-26.png`);
        if (status) { status.textContent = 'Done ✓'; setTimeout(() => { if (status) status.style.display = 'none'; }, 3000); }
      } catch (e) {
        console.error(e);
        if (status) status.textContent = 'Error — try again';
      } finally {
        btn.textContent = label; btn.disabled = false;
      }
    });
  })();
</script>

</body>
</html>
