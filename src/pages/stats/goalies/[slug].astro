---
import Nav from '../../../components/Nav.astro';
import ThemeScript from '../../../components/ThemeScript.astro';
import Fonts from '../../../components/Fonts.astro';
import Table from '../../../components/Table.astro';
import { loadGoalies } from '../../../lib/stats-loader';
import { pickTeamColor } from '../../../lib/team-colors';
import type { GoalieRecord } from '../../../lib/stats-schemas';
import { buildGoalieHeatmapSVG } from '../../../lib/rink-svg';

export async function getStaticPaths() {
  const SA_QUAL = 500; // minimum shots against to be "qualified" for ranking
  const goalies = loadGoalies();
  // Rank qualified goalies (min 500 SA) by GSAx, descending.
  const qualified = goalies
    .filter(g => g.sa >= SA_QUAL)
    .sort((a, b) => b.gsax - a.gsax);
  const rankById = new Map<number, number>();
  qualified.forEach((g, i) => rankById.set(g.goalie_id, i + 1));

  function findSimilarGoalies(all: GoalieRecord[], current: GoalieRecord) {
    const curVal = current.gsax;
    const candidates = all
      .filter(g => g.goalie_id !== current.goalie_id && g.sa >= SA_QUAL)
      .sort((a, b) => Math.abs(a.gsax - curVal) - Math.abs(b.gsax - curVal));
    for (const band of [1.0, 2.5, 5.0]) {
      const inBand = candidates.filter(g => Math.abs(g.gsax - curVal) <= band);
      if (inBand.length >= 3) return inBand.slice(0, 4).sort((a, b) => b.gsax - a.gsax);
    }
    return candidates.slice(0, 4).sort((a, b) => b.gsax - a.gsax);
  }

  return goalies.map(g => {
    const slugParam = g.slug && g.slug.length > 0
      ? g.slug
      : `goalie-${g.goalie_id}`;
    return {
      params: { slug: slugParam },
      props:  {
        goalie:         g,
        gsaxRank:       rankById.get(g.goalie_id) ?? null,
        qualCount:      qualified.length,
        similarGoalies: findSimilarGoalies(goalies, g),
      },
    };
  });
}

interface Props { goalie: GoalieRecord; gsaxRank: number | null; qualCount: number; similarGoalies: GoalieRecord[] }
const { goalie, gsaxRank, qualCount, similarGoalies } = Astro.props;

const SA_QUAL    = 500; // keep in sync with getStaticPaths qualifier
const hasTeam    = goalie.team_abbrev != null && goalie.team_abbrev !== '???' && goalie.team_abbrev !== '';
const teamColor  = hasTeam ? pickTeamColor(goalie.team_abbrev) : '#8a8a8a';
const initial    = goalie.name.split('.')[0]?.trim() ?? '';
const lastName   = goalie.name.split('.').pop()?.trim() ?? goalie.name;
const firstName  = (goalie.first_name && goalie.first_name.length > 0) ? goalie.first_name : initial;
const displayLast = (goalie.last_name && goalie.last_name.length > 0) ? goalie.last_name : lastName;
const gsaxSign   = goalie.gsax >= 0 ? '+' : '';
// Hero tile percentiles
const gsaxPct    = gsaxRank != null && qualCount > 1
  ? Math.round((qualCount - gsaxRank) / (qualCount - 1) * 100)
  : null;
const svPctEdgePct = goalie.edge?.svpct_all?.pct != null
  ? Math.round(goalie.edge.svpct_all.pct * 100)
  : null;

function ordinal(n: number): string {
  const m10 = n % 10, m100 = n % 100;
  if (m100 >= 11 && m100 <= 13) return `${n}th`;
  if (m10 === 1) return `${n}st`;
  if (m10 === 2) return `${n}nd`;
  if (m10 === 3) return `${n}rd`;
  return `${n}th`;
}
const headshotUrl = `https://assets.nhle.com/mugs/nhl/20252026/${goalie.team_abbrev}/${goalie.goalie_id}.png`;
const hasPlayoffs  = (goalie.playoff_games ?? 0) > 0 && goalie.playoff_gsax != null;
const poSvPct      = hasPlayoffs && goalie.playoff_sa != null && goalie.playoff_sa > 0 && goalie.playoff_ga != null
  ? +(1 - goalie.playoff_ga / goalie.playoff_sa).toFixed(3)
  : null;
const poSign       = hasPlayoffs && goalie.playoff_gsax != null && goalie.playoff_gsax >= 0 ? '+' : '';

const vsExp      = goalie.sv_pct != null && goalie.sa > 0
  ? +((goalie.sv_pct - (1 - goalie.xga / goalie.sa)) * 100).toFixed(2)
  : null;

// ── Cumulative chart ───────────────────────────────────────────────────────
const games = [...goalie.games].sort((a, b) => a.game_date.localeCompare(b.game_date));
const cumPoints: { game: number; gsax: number }[] = [];
let cum = 0;
for (const [i, g] of games.entries()) {
  cum += g.gsax;
  cumPoints.push({ game: i + 1, gsax: +cum.toFixed(2) });
}

const SVG_W = 720, SVG_H = 180;
const PAD = { t: 16, r: 16, b: 28, l: 44 };
const cW = SVG_W - PAD.l - PAD.r;
const cH = SVG_H - PAD.t - PAD.b;
const xMax = cumPoints.length || 1;
const yVals = cumPoints.map(p => p.gsax);
let yMin = Math.min(0, ...yVals), yMax = Math.max(0, ...yVals);
const yPad = (yMax - yMin) * 0.12;
yMin -= yPad; yMax += yPad;

const cpx  = (g: number) => PAD.l + (g / xMax) * cW;
const cpy  = (v: number) => PAD.t + cH - ((v - yMin) / (yMax - yMin)) * cH;
const cpy0 = cpy(0);
const path = cumPoints.map((p, i) =>
  `${i === 0 ? 'M' : 'L'}${cpx(p.game).toFixed(1)},${cpy(p.gsax).toFixed(1)}`
).join(' ');
const areaPath = cumPoints.length >= 2
  ? `${path} L${cpx(xMax).toFixed(1)},${cpy0.toFixed(1)} L${cpx(1).toFixed(1)},${cpy0.toFixed(1)} Z`
  : '';

// ── xG-tier bar chart data ─────────────────────────────────────────────────
const binAbsMax = Math.max(...goalie.bins.map(b => Math.abs(b.gsax)), 1);
// bar width = percentage of max, full bar = 120px
const BAR_MAX_W = 120;

// Short bin labels for display
const BIN_SHORT: Record<string, string> = {
  'Easiest (0-20%)': 'Easiest',
  'Low (20-40%)':    'Low',
  'Medium (40-60%)': 'Medium',
  'Hard (60-80%)':   'Hard',
  'Hardest (80-100%)': 'Hardest',
};

// Shot-type breakdown table (Table.astro consumer) —————————————————————————
const shotTypeRows = goalie.types.map(t => ({
  shot_type_group: t.shot_type_group,
  sa:              t.sa,
  sv_pct:          t.sv_pct,
  league_sv_pct:   t.league_sv_pct,
  gsax:            t.gsax,
}));
const signedColor = (v: any, _r: any, tok?: { pos: string; neg: string }) => {
  if (v == null) return undefined;
  return v >= 0 ? tok?.pos : tok?.neg;
};
const shotTypeColumns = [
  { key: 'shot_type_group', label: 'Type',   type: 'label' as const, bold: true },
  { key: 'sa',              label: 'SA',     type: 'number' as const },
  { key: 'sv_pct',          label: 'SV%',    type: 'number' as const,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(3) },
  { key: 'league_sv_pct',   label: 'Lg SV%', type: 'number' as const,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(3) },
  { key: 'gsax',            label: 'GSAx',   type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : (v >= 0 ? '+' : '') + Number(v).toFixed(1),
    color: signedColor },
];

// ── Game log table ─────────────────────────────────────────────────────────
function secToTOI(sec: number | null | undefined): string {
  if (sec == null) return '—';
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return `${m}:${String(s).padStart(2, '0')}`;
}

const gameLogRows = [...goalie.games]
  .sort((a, b) => b.game_date.localeCompare(a.game_date))
  .map(g => ({
    date_fmt: g.game_date.slice(5).replace('-', '/'),
    opp:      g.opp_abbrev ?? '—',
    decision: g.decision ?? '—',
    type_lbl: g.game_type === 3 ? 'PO' : 'RS',
    toi_fmt:  secToTOI(g.toi_sec),
    sa:       g.sa,
    ga:       g.ga,
    sv_pct:   g.sv_pct,
    xga:      g.xga,
    gsax:     g.gsax,
  }));

const gameLogColumns = [
  { key: 'date_fmt', label: 'Date',  type: 'label' as const },
  { key: 'opp',     label: 'Opp',   type: 'label' as const, bold: true },
  { key: 'decision',label: 'Dec',   type: 'label' as const },
  { key: 'type_lbl',label: 'Type',  type: 'label' as const },
  { key: 'toi_fmt', label: 'TOI',   type: 'number' as const },
  { key: 'sa',      label: 'SA',    type: 'number' as const },
  { key: 'ga',      label: 'GA',    type: 'number' as const },
  { key: 'sv_pct',  label: 'SV%',   type: 'number' as const,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(3) },
  { key: 'xga',     label: 'xGA',   type: 'number' as const,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(2) },
  { key: 'gsax',    label: 'GSAx',  type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : (v >= 0 ? '+' : '') + Number(v).toFixed(2),
    color: signedColor },
];

// ── EDGE zone stats (3-zone summary) ────────────────────────────────────────
const edgeZones = goalie.edge?.zones ?? [];
const hdZone  = edgeZones[0] ?? null;
const midZone = edgeZones[1] ?? null;
const lngZone = edgeZones[2] ?? null;
const hasEdgeZones = hdZone != null && midZone != null && lngZone != null;

function zoneColor(pct: number | null): string {
  if (pct == null) return 'rgba(13,13,20,0.12)';
  const p = pct * 100;
  if (p >= 75) return '#1a7a3e';
  if (p >= 50) return '#34a853';
  if (p >= 25) return '#c07020';
  return '#E8002D';
}

// ── Coordinate shot-bin heatmap ─────────────────────────────────────────────
const heatBins = goalie.shot_bins ?? [];
const hasHeatmap = heatBins.length > 0;
const heatmapSvg = hasHeatmap ? buildGoalieHeatmapSVG(heatBins) : '';

// ── Career stats ─────────────────────────────────────────────────────────────
const careerRS = (goalie.career_seasons ?? []).filter(s => s.game_type === 2);
const careerPO = (goalie.career_seasons ?? []).filter(s => s.game_type === 3);
const hasCareer = careerRS.length > 0 || careerPO.length > 0;

// ── Tweet-card data (passed to client script via define:vars) ───────────────
// dSv% = actual SV% minus expected SV% (xsv_pct). Both stored as fractions.
const dSvPct = goalie.dsv_pct != null
  ? goalie.dsv_pct
  : (goalie.sv_pct != null && goalie.xsv_pct != null ? goalie.sv_pct - goalie.xsv_pct : null);

const cardData = {
  name:       goalie.name,
  goalieId:   goalie.goalie_id,
  team:       goalie.team_abbrev,
  hasTeam,
  teamColor,
  headshotUrl,
  gsax:       goalie.gsax,
  gsaxPer100: goalie.gsax_per_100 ?? null,
  svPct:      goalie.sv_pct ?? null,
  xsvPct:     goalie.xsv_pct ?? null,
  gaa:        goalie.gaa ?? null,
  dSvPct,
  sa:         goalie.sa,
  rank:       gsaxRank,
  qualCount,
  saQual:     SA_QUAL,
  playoffGsax:  goalie.playoff_gsax ?? null,
  playoffSa:    goalie.playoff_sa ?? null,
  playoffGa:    goalie.playoff_ga ?? null,
  playoffGames: goalie.playoff_games ?? null,
  // Tier bars — re-map raw bin_label to the canonical 5-tier display label
  bins: goalie.bins.map(b => ({
    label:        BIN_SHORT[b.bin_label] ?? b.bin_label,
    gsax:         b.gsax,
    svPct:        b.sv_pct ?? null,
    leagueSvPct:  b.league_sv_pct,
    sa:           b.sa,
    ga:           b.ga,
  })),
  // Shot-type breakdown (top 4 by SA, excluding "Other")
  types: goalie.types
    .filter(t => t.shot_type_group !== 'Other')
    .sort((a, b) => b.sa - a.sa)
    .slice(0, 4)
    .map(t => ({
      label:       t.shot_type_group,
      gsax:        t.gsax,
      svPct:       t.sv_pct ?? null,
      leagueSvPct: t.league_sv_pct,
      sa:          t.sa,
    })),
  edge: goalie.edge ?? null,
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{goalie.name} · Goalie GSAx · HGB Stats</title>
  <meta name="description" content={`${goalie.name} (${goalie.team_abbrev}) — GSAx ${gsaxSign}${goalie.gsax.toFixed(2)}, SV% ${goalie.sv_pct != null ? (goalie.sv_pct * 100).toFixed(2) : '—'}%. HGB xG-model goalie analysis, 2025–26.`} />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #EFEEE8;
      --ink:      #0d0d14;
      --red:      #E8002D;
      --green:    #1a7a3e;
      --surface:  #FFFFFF;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04:   rgba(13,13,20,0.04);
      --ink-06:   rgba(13,13,20,0.06);
      --ink-10:   rgba(13,13,20,0.10);
      --ink-14:   rgba(13,13,20,0.14);
      --ink-20:   rgba(13,13,20,0.20);
      --ink-32:   rgba(13,13,20,0.32);
      --ink-48:   rgba(13,13,20,0.48);
      --ink-72:   rgba(13,13,20,0.72);
      --display:  'Barlow Condensed', sans-serif;
      --body:     'Barlow', sans-serif;
      --mono:     'JetBrains Mono', monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    /* ── Masthead ── */
    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
      margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .back-link { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; color: var(--ink-48);
      text-decoration: none; }
    .back-link:hover { color: var(--ink); }

    /* ── Hero card (matches player page) ── */
    .mast-top a { color: var(--ink-48); text-decoration: none; }
    .mast-top a:hover { color: var(--ink); }
    .mast-card {
      background: var(--surface); border: 1px solid var(--ink-14);
      border-left: 6px solid currentColor; padding: 28px 32px;
      display: flex; align-items: center; gap: 0; position: relative;
    }
    .mast-left { display: flex; align-items: center; gap: 28px; flex: 1; min-width: 0; }
    .headshot-circle-wrap { flex-shrink: 0; }
    .headshot-circle {
      width: 110px; height: 110px; border-radius: 50%; object-fit: cover;
      border: 3px solid var(--team-c, var(--ink)); display: block;
      background: var(--surface);
    }
    .identity-text { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
    .player-name {
      font-family: var(--display); font-weight: 800; font-size: clamp(36px, 4.5vw, 56px);
      text-transform: uppercase; line-height: 0.95; letter-spacing: -0.01em; color: var(--ink);
    }
    .player-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; }
    .dl-card-btn {
      margin-top: 4px; cursor: pointer; font-family: var(--mono); font-size: 9px; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; border: none;
      background: var(--team-c, var(--ink)); color: #fff; align-self: flex-start;
    }
    .mast-right { display: flex; flex-direction: column; gap: 8px; flex-shrink: 0; margin-left: 28px; }
    .hero-tile {
      background: var(--bg); border: 1px solid var(--ink-14);
      padding: 16px 10px; text-align: center; min-width: 150px; flex: 1;
    }
    .tile-label { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 6px; }
    .tile-big { font-family: var(--display); font-weight: 800; font-size: 44px; line-height: 1; letter-spacing: -0.02em; }
    .tile-sub { font-family: var(--mono); font-size: 10px; color: var(--ink-48); margin-top: 4px; }
    .tile-row { display: flex; gap: 12px; }
    .po-tile-combined {
      background: var(--bg); border: 1px solid var(--ink-14);
      padding: 8px 14px; display: flex; align-items: center; gap: 16px;
      align-self: stretch; box-sizing: border-box;
    }
    .po-tile-combined .po-label {
      font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--team-c, var(--ink)); white-space: nowrap; flex-shrink: 0;
    }
    .po-tile-combined .po-val {
      font-family: var(--display); font-weight: 800; font-size: 24px;
      line-height: 1; letter-spacing: -0.01em;
    }
    .po-tile-combined .po-sep {
      font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.06em;
    }

    @media (max-width: 768px) {
      .mast-card { flex-wrap: wrap; gap: 16px; padding: 16px; }
      .mast-right { margin-left: 0; width: 100%; }
      .tile-row { width: 100%; }
      .hero-tile { flex: 1 1 0; min-width: 0; }
    }
    @media (max-width: 480px) {
      .headshot-circle { width: 80px; height: 80px; }
    }

    /* ── Layout ── */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }
    .content { display: grid; grid-template-columns: 1fr 280px; gap: 24px; padding: 28px 0 80px; align-items: start; }
    .content-main { display: flex; flex-direction: column; gap: 24px; grid-column: 1; align-self: start; min-width: 0; }
    .page-sidebar { grid-column: 2; display: flex; flex-direction: column; gap: 16px; position: sticky; top: 20px; align-self: start; }
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .cta-card { background: var(--ink); padding: 22px 18px; }
    .cta-btn { display: block; width: 100%; background: var(--red); color: #fff; font-family: var(--body); font-weight: 700; font-size: 15px; letter-spacing: 0.06em; text-transform: uppercase; padding: 12px 16px; border: none; cursor: pointer; text-align: center; margin-bottom: 8px; }
    .cta-note { font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; color: rgba(255,255,255,0.24); margin-top: 8px; text-align: center; }
    @media (max-width: 768px) {
      .content { grid-template-columns: 1fr; padding: 20px 0 60px; }
      .page-sidebar { grid-column: 1; position: static; }
      .two-col { grid-template-columns: 1fr; }
    }

    /* ── Section cards ── */
    .sec-card { background: var(--surface); border: 1px solid var(--ink-14); }
    .sec-head { padding: 14px 20px 10px; border-bottom: 1px solid var(--ink-10); }
    .sec-title { font-family: var(--display); font-weight: 800; font-size: 14px;
      text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink); }
    .sec-sub { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32);
      letter-spacing: 0.06em; margin-top: 2px; }
    .sec-body { padding: 16px 20px; }

    /* ── Cumulative chart ── */
    .chart-full { }
    .chart-svg { width: 100%; height: auto; display: block; }

    /* ── xG Tier chart ── */
    .bin-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .bin-row:last-child { margin-bottom: 0; }
    .bin-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.04em;
      color: var(--ink-48); width: 62px; flex-shrink: 0; text-align: right; }
    .bin-bars { flex: 1; position: relative; height: 20px; display: flex; align-items: center; }
    .bin-zero { position: absolute; left: 50%; top: 0; bottom: 0; width: 1px;
      background: var(--ink-20); }
    .bin-bar { height: 14px; border-radius: 1px; position: absolute; }
    .bin-bar.pos { background: var(--green); left: 50%; }
    .bin-bar.neg { background: var(--red); right: 50%; }
    .bin-gsax { font-family: var(--mono); font-size: 10px; font-weight: 700;
      width: 52px; flex-shrink: 0; }
    .bin-gsax.pos { color: var(--green); }
    .bin-gsax.neg { color: var(--red); }
    .bin-svpct { font-family: var(--mono); font-size: 9px; white-space: nowrap;
      min-width: 48px; text-align: right; }

    /* Shot-type table chrome lives in Table.astro now. */
    .sec-body .tbl-wrap { border: none; }

    /* ── Similar Goalies ── */
    .peer-strip { display: flex; flex-direction: column; }
    .peer-row { display: flex; align-items: center; gap: 10px; padding: 10px 18px; border-bottom: 1px solid var(--ink-06); text-decoration: none; color: inherit; }
    .peer-row:last-child { border-bottom: 0; }
    .peer-row:hover { background: var(--bg); }
    .peer-name { font-family: var(--body); font-weight: 600; font-size: 13px; color: rgba(13,13,20,0.72); }
    .peer-meta { font-family: var(--body); font-weight: 400; font-size: 11px; color: rgba(13,13,20,0.48); }
    .peer-gsax { font-family: var(--mono); font-size: 13px; font-weight: 700; }
    .peer-gsax.pos { color: #00A86B; }
    .peer-gsax.neg { color: var(--red); }

    /* ── EDGE Zone stats (compact) ── */
    .zone-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: var(--ink-10); border: 1px solid var(--ink-10); }
    .zone-col { background: var(--surface); padding: 12px 14px; }
    .zone-col-lbl { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 4px; }
    .zone-col-sv { font-family: var(--display); font-weight: 800; font-size: 28px; line-height: 1; margin-bottom: 4px; }
    .zone-col-pct { font-family: var(--mono); font-size: 10px; font-weight: 600; margin-bottom: 2px; }
    .zone-col-meta { font-family: var(--mono); font-size: 9px; color: var(--ink-48); line-height: 1.4; }

    /* ── Shot bin heatmap ── */
    .heatmap-legend { display: flex; gap: 20px; margin-top: 10px; font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.06em; flex-wrap: wrap; }
    .heat-swatch { display: inline-block; width: 10px; height: 10px; vertical-align: middle; margin-right: 4px; }
    .heat-mode-btn { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.10em; text-transform: uppercase; padding: 5px 10px; border: 1px solid var(--ink-20); background: transparent; color: var(--ink-48); cursor: pointer; }
    .heat-mode-btn.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }
    .heat-mode-btn:hover:not(.active) { border-color: var(--ink-48); color: var(--ink); }
    .shot-map-svg { width: 100%; height: auto; display: block; }

    /* ── Career stats table ── */
    .career-tabs { display: flex; gap: 8px; padding: 12px 20px 0; }
    .career-tab { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 6px 14px; border: 1px solid var(--ink-20); background: transparent; color: var(--ink-48); cursor: pointer; }
    .career-tab.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }
    .career-tab:hover:not(.active) { border-color: var(--ink-48); color: var(--ink); }
    .career-tbl { width: 100%; border-collapse: collapse; font-size: 12px; }
    .career-tbl th { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-32); padding: 8px 12px; text-align: right; border-bottom: 1px solid var(--ink-10); white-space: nowrap; }
    .career-tbl th:first-child { text-align: left; }
    .career-tbl td { font-family: var(--mono); font-size: 12px; padding: 7px 12px; text-align: right; border-bottom: 1px solid var(--ink-06); }
    .career-tbl td:first-child { text-align: left; font-weight: 700; }
    .career-tbl tr:hover td { background: var(--bg); }
    .career-tbl tr:last-child td { border-bottom: none; }
    .career-team-cell { display: flex; align-items: center; gap: 8px; }
    .career-team-logo { width: 20px; height: 20px; object-fit: contain; }
    .career-season-row.rs-row { }
    .career-season-row.po-row { display: none; }
    .career-gsax-pos { color: var(--green); font-weight: 700; }
    .career-gsax-neg { color: var(--red);   font-weight: 700; }

    /* ── Game log table ── */
    .sec-body .tbl-wrap { border: none; }

    @media (max-width: 768px) {
      .mast-inner, .wrap { padding-left: 16px; padding-right: 16px; }
      .zone-stats { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<Nav currentPath="/stats/goalies" />

<!-- ── Masthead ── -->
<header class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div><a href="/stats/goalies">← Goalies</a></div>
      <div>{goalie.team_abbrev} · G · {goalie.sa.toLocaleString()} SA · 2025–26</div>
    </div>

    <div class="mast-card" style={`border-left-color:${teamColor}; color:${teamColor}; --team-c:${teamColor}`}>
      <!-- Left: circle headshot + identity -->
      <div class="mast-left">
        <div class="headshot-circle-wrap">
          <img class="headshot-circle" src={headshotUrl} alt={goalie.name} width="110" height="110"
            style={`border-color:${teamColor}`}
            onerror="this.src='https://assets.nhle.com/logos/nhl/svg/'+this.dataset.team+'_light.svg';this.style.objectFit='contain';this.style.padding='18px'"
            data-team={goalie.team_abbrev} />
        </div>
        <div class="identity-text">
          <div class="player-name">{firstName}<br/>{displayLast}</div>
          <div class="player-meta">
            {goalie.team_abbrev} · G · {goalie.gp ?? goalie.games.length} GP · {goalie.sa.toLocaleString()} SA · 2025–26
          </div>
          {hasPlayoffs && (
            <div class="player-meta" style={`color:${teamColor}; margin-top:3px`}>
              2026 Playoffs · {goalie.playoff_games} GP
              {goalie.playoff_sa != null && <Fragment> · {goalie.playoff_sa.toLocaleString()} SA</Fragment>}
              {goalie.playoff_ga != null && <Fragment> · {goalie.playoff_ga} GA</Fragment>}
            </div>
          )}
        </div>
      </div>

      <!-- Right: hero tiles (reg szn row + optional playoffs row) -->
      <div class="mast-right">
        <div class="tile-row">
          <div class="hero-tile">
            <div class="tile-label">GSAx</div>
            <div class="tile-big" style={`color:${teamColor}`}>{gsaxSign}{goalie.gsax.toFixed(2)}</div>
            <div class="tile-sub">{gsaxPct != null ? `reg szn · ${ordinal(gsaxPct)} pct` : 'reg szn'}</div>
          </div>
          <div class="hero-tile">
            <div class="tile-label">SV%</div>
            <div class="tile-big" style={`color:${teamColor}`}>{goalie.sv_pct != null ? goalie.sv_pct.toFixed(3) : '—'}</div>
            <div class="tile-sub">{svPctEdgePct != null ? `reg szn · ${ordinal(svPctEdgePct)} pct` : 'reg szn'}</div>
          </div>
        </div>
        {hasPlayoffs && (
          <div class="po-tile-combined" style={`--team-c:${teamColor}`}>
            <span class="po-label">Playoffs</span>
            <span class="po-val" style={`color:${goalie.playoff_gsax! >= 0 ? '#00A86B' : 'var(--red)'}`}>
              {poSign}{goalie.playoff_gsax!.toFixed(2)}
            </span>
            <span class="po-sep">GSAx</span>
            {poSvPct != null && <Fragment>
              <span class="po-sep">·</span>
              <span class="po-val" style={`color:${teamColor}`}>{poSvPct.toFixed(3)}</span>
              <span class="po-sep">SV%</span>
            </Fragment>}
          </div>
        )}
      </div>
    </div>

  </div>
</header>

<main class="wrap">
<div class="content">
<div class="content-main">

  <!-- ── Cumulative GSAx chart (first) ── -->
  {cumPoints.length > 1 && (
    <div class="chart-full">
      <div class="sec-card">
        <div class="sec-head">
          <div class="sec-title">Cumulative GSAx — Season</div>
          <div class="sec-sub">{cumPoints.length} games · final: {gsaxSign}{goalie.gsax.toFixed(2)}</div>
        </div>
        <div style="padding:16px 16px 8px">
          <svg class="chart-svg" viewBox={`0 0 ${SVG_W} ${SVG_H}`} preserveAspectRatio="xMidYMid meet">
            {[...Array(5)].map((_, i) => {
              const gv = yMin + (i / 4) * (yMax - yMin);
              const gy = cpy(gv).toFixed(1);
              return (
                <g>
                  <line x1={PAD.l} y1={gy} x2={PAD.l + cW} y2={gy} stroke="rgba(13,13,20,0.06)" stroke-width="1" />
                  <text x={(PAD.l - 6).toFixed(1)} y={gy} text-anchor="end" dominant-baseline="middle"
                    font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(13,13,20,0.32)">
                    {gv >= 0 ? '+' : ''}{gv.toFixed(0)}
                  </text>
                </g>
              );
            })}
            <line x1={PAD.l} y1={cpy0.toFixed(1)} x2={(PAD.l + cW).toFixed(1)} y2={cpy0.toFixed(1)}
              stroke="rgba(13,13,20,0.28)" stroke-width="1.5" stroke-dasharray="4 3" />
            {areaPath && <path d={areaPath} fill={teamColor} fill-opacity="0.07" />}
            <path d={path} fill="none" stroke={teamColor} stroke-width="2"
              stroke-linejoin="round" stroke-linecap="round" />
            {cumPoints.length > 0 && (
              <circle cx={cpx(cumPoints[cumPoints.length-1].game).toFixed(1)}
                cy={cpy(cumPoints[cumPoints.length-1].gsax).toFixed(1)}
                r="3.5" fill={teamColor} />
            )}
            <text x={(PAD.l + cW / 2).toFixed(1)} y={(SVG_H - 4).toFixed(1)}
              text-anchor="middle" font-family="JetBrains Mono, monospace"
              font-size="9" fill="rgba(13,13,20,0.28)" letter-spacing="0.08em">GAME #</text>
          </svg>
        </div>
      </div>
    </div>
  )}

  <!-- ── Two-column: xG bins + shot types ── -->
  <div class="two-col">

    <!-- xG Tier breakdown -->
    <div class="sec-card">
      <div class="sec-head">
        <div class="sec-title">GSAx by xG Tier</div>
        <div class="sec-sub">How many goals saved above expected within each shot difficulty band</div>
      </div>
      <div class="sec-body">
        {goalie.bins.length > 0 ? (
          <>
            {goalie.bins.map(b => {
              const pct = Math.min(Math.abs(b.gsax) / binAbsMax, 1);
              const barW = Math.round(pct * BAR_MAX_W / 2);  // half-bar from center
              const isPos = b.gsax >= 0;
              const svDiff = b.sv_pct != null
                ? +((b.sv_pct - b.league_sv_pct) * 100).toFixed(1)
                : null;
              return (
                <div class="bin-row">
                  <div class="bin-label">{BIN_SHORT[b.bin_label] ?? b.bin_label}</div>
                  <div class="bin-bars">
                    <div class="bin-zero"></div>
                    <div class={`bin-bar ${isPos ? 'pos' : 'neg'}`} style={`width:${barW}px`}></div>
                  </div>
                  <div class={`bin-gsax ${isPos ? 'pos' : 'neg'}`}>{isPos ? '+' : ''}{b.gsax.toFixed(1)}</div>
                  {svDiff != null && svDiff !== 0 && (
                    <div class="bin-svpct" style={`color:${svDiff > 0 ? 'var(--green)' : 'var(--red)'}`}>
                      {svDiff > 0 ? '+' : ''}{svDiff.toFixed(1)}%
                    </div>
                  )}
                  {svDiff != null && svDiff === 0 && (
                    <div class="bin-svpct" style="color:var(--ink-32)">±0%</div>
                  )}
                </div>
              );
            })}
            <div style="margin-top:14px;font-family:var(--mono);font-size:9px;color:var(--ink-32);letter-spacing:0.06em">
              BAR WIDTH = |GSAX| · % COLUMN = SV% VS LEAGUE AVG
            </div>
          </>
        ) : (
          <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:12px 0">
            Tier breakdown available after next pipeline run.
          </div>
        )}
      </div>
    </div>

    <!-- Shot-type breakdown -->
    <div class="sec-card">
      <div class="sec-head">
        <div class="sec-title">GSAx by Shot Type</div>
        <div class="sec-sub">Performance vs league-average save rate per shot category</div>
      </div>
      <div class="sec-body" style="padding:0">
        {goalie.types.length > 0 ? (
          <Table
            columns={shotTypeColumns}
            rows={shotTypeRows}
            sticky={false}
            ariaLabel="GSAx by shot type"
          />
        ) : (
          <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:16px 20px">
            Shot-type breakdown available after next pipeline run.
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- ── Coordinate Shot-Bin Heatmap ── -->
  {hasHeatmap && (
    <div class="sec-card">
      <div class="sec-head" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
        <div>
          <div class="sec-title">Save % by Shot Location</div>
          <div class="sec-sub" id="heat-sub">smoothed · blue = above your avg · red = below</div>
        </div>
        <div style="display:flex;gap:6px;flex-shrink:0">
          <button class="heat-mode-btn active" data-mode="raw">Own SV%</button>
          <button class="heat-mode-btn" data-mode="league">vs League</button>
        </div>
      </div>
      <div class="sec-body" style="padding:14px 20px 16px">
        <Fragment set:html={heatmapSvg} />
        <div class="heatmap-legend">
          <div><span class="heat-swatch" style="background:rgba(20,100,200,0.75)"></span>BETTER</div>
          <div><span class="heat-swatch" style="background:rgba(220,40,40,0.75)"></span>WORSE</div>
          <div id="heat-legend-ctx">vs own avg</div>
          <div>MIN 5 SHOTS PER BIN</div>
          <div>{heatBins.reduce((s, b) => s + b.shots, 0).toLocaleString()} SA · {heatBins.reduce((s, b) => s + b.goals, 0)} GA total</div>
        </div>
      </div>
      {hasEdgeZones && (
        <div style="border-top:1px solid var(--ink-10)">
          <div style="padding:10px 20px 8px;font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-32)">NHL EDGE Zones</div>
          <div class="zone-stats" style="margin:0 20px 14px;border-radius:0">
            {[
              { lbl: 'High Danger', z: hdZone! },
              { lbl: 'Mid Range',   z: midZone! },
              { lbl: 'Long Range',  z: lngZone! },
            ].map(({ lbl, z }) => {
              const pct100 = z.svpct_pct != null ? z.svpct_pct * 100 : null;
              const color  = zoneColor(z.svpct_pct);
              return (
                <div class="zone-col">
                  <div class="zone-col-lbl" style={`color:${color}`}>{lbl}</div>
                  <div class="zone-col-sv" style={`color:${color}`}>{z.svpct != null ? z.svpct.toFixed(3) : '—'}</div>
                  <div class="zone-col-pct" style={`color:${color}`}>{pct100 != null ? ordinal(Math.round(pct100)) + ' pct' : '—'}</div>
                  <div class="zone-col-meta">{z.svpct_league_avg != null ? `avg ${z.svpct_league_avg.toFixed(3)}` : ''}</div>
                  <div class="zone-col-meta">{z.saves != null ? `${z.saves} sv · ${z.ga} ga` : ''}</div>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </div>
  )}
  {!hasHeatmap && hasEdgeZones && (
    <div class="sec-card">
      <div class="sec-head">
        <div class="sec-title">Save % by Zone</div>
        <div class="sec-sub">NHL EDGE tracking · shot location profile vs league average</div>
      </div>
      <div class="sec-body" style="padding:0">
        <div class="zone-stats" style="border:none">
          {[{ lbl: 'High Danger', z: hdZone! }, { lbl: 'Mid Range', z: midZone! }, { lbl: 'Long Range', z: lngZone! }].map(({ lbl, z }) => {
            const pct100 = z.svpct_pct != null ? z.svpct_pct * 100 : null;
            const color  = zoneColor(z.svpct_pct);
            return (
              <div class="zone-col">
                <div class="zone-col-lbl" style={`color:${color}`}>{lbl}</div>
                <div class="zone-col-sv" style={`color:${color}`}>{z.svpct != null ? z.svpct.toFixed(3) : '—'}</div>
                <div class="zone-col-pct" style={`color:${color}`}>{pct100 != null ? ordinal(Math.round(pct100)) + ' pct' : '—'}</div>
                <div class="zone-col-meta">{z.svpct_league_avg != null ? `avg ${z.svpct_league_avg.toFixed(3)}` : ''}</div>
                <div class="zone-col-meta">{z.saves != null ? `${z.saves} sv · ${z.ga} ga` : ''}</div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  <!-- ── Career Stats ── -->
  {hasCareer && (
    <div class="sec-card">
      <div class="sec-head" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
        <div>
          <div class="sec-title">Career Stats — <span style={`color:${teamColor}`}>Season by Season</span></div>
          <div class="sec-sub">xG-model stats · all seasons with 100+ SA faced</div>
        </div>
      </div>
      <div class="career-tabs">
        <button class="career-tab active" data-type="2">Regular Season</button>
        {careerPO.length > 0 && <button class="career-tab" data-type="3">Playoffs</button>}
      </div>
      <div style="overflow-x:auto;padding-bottom:4px">
        <table class="career-tbl">
          <thead>
            <tr>
              <th>Season</th>
              <th>Team</th>
              <th>GP</th>
              <th>SA</th>
              <th>GA</th>
              <th>SV%</th>
              <th>xGA</th>
              <th>GSAx</th>
            </tr>
          </thead>
          <tbody>
            {[...careerRS, ...careerPO].map(s => {
              const gsaxSign = s.gsax >= 0 ? '+' : '';
              const cls = s.game_type === 2 ? 'career-season-row rs-row' : 'career-season-row po-row';
              return (
                <tr class={cls}>
                  <td>{s.season}</td>
                  <td>
                    <div class="career-team-cell">
                      {s.team_abbrev && (
                        <img class="career-team-logo"
                          src={`https://assets.nhle.com/logos/nhl/svg/${s.team_abbrev}_light.svg`}
                          alt={s.team_abbrev} width="20" height="20" />
                      )}
                      <span>{s.team_abbrev ?? '—'}</span>
                    </div>
                  </td>
                  <td>{s.gp}</td>
                  <td>{s.sa.toLocaleString()}</td>
                  <td>{s.ga}</td>
                  <td>{s.sv_pct != null ? s.sv_pct.toFixed(3) : '—'}</td>
                  <td>{s.xga.toFixed(1)}</td>
                  <td class={s.gsax >= 0 ? 'career-gsax-pos' : 'career-gsax-neg'}>{gsaxSign}{s.gsax.toFixed(1)}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <div style="padding:8px 20px;font-family:var(--mono);font-size:9px;color:var(--ink-20);letter-spacing:0.06em">
        HOCKEYGAMEBOT.COM · GSAx = xGA − GA via XGBoost model · min 100 SA
      </div>
    </div>
  )}

  <!-- ── Game Log Table ── -->
  {gameLogRows.length > 0 && (
    <div class="sec-card">
      <div class="sec-head">
        <div class="sec-title">Game Log</div>
        <div class="sec-sub">{gameLogRows.length} games · most recent first · RS = regular season · PO = playoffs</div>
      </div>
      <div class="sec-body" style="padding:0">
        <Table
          columns={gameLogColumns}
          rows={gameLogRows}
          sticky={true}
          ariaLabel="Game log"
        />
      </div>
    </div>
  )}

</div><!-- /content-main -->

<!-- ── Sidebar ── -->
<div class="page-sidebar">
  <div class="cta-card">
    <button id="dl-goalie-card" type="button" class="cta-btn" style={`background:${teamColor}`}>
      2025–26 Goalie Card →
    </button>
    <div class="cta-note" id="goalie-card-status" style="display:none"></div>
  </div>

  {similarGoalies.length > 0 && (
    <div class="sec-card">
      <div class="sec-head">
        <div class="sec-title">Similar <span style={`color:${teamColor}`}>Goalies</span></div>
        <div class="sec-sub">By GSAx · qualified starters</div>
      </div>
      <div class="peer-strip">
        {similarGoalies.map(g => {
          const sign = g.gsax >= 0 ? '+' : '';
          const peerSlug = g.slug && g.slug.length > 0 ? g.slug : `goalie-${g.goalie_id}`;
          return (
            <a href={`/stats/goalies/${peerSlug}`} class="peer-row">
              <div style="flex:1">
                <div class="peer-name">{g.first_name && g.last_name ? `${g.first_name} ${g.last_name}` : g.name}</div>
                <div class="peer-meta">{g.team_abbrev} · {g.sa.toLocaleString()} SA</div>
              </div>
              <span class={`peer-gsax ${g.gsax >= 0 ? 'pos' : 'neg'}`}>{sign}{g.gsax.toFixed(2)}</span>
            </a>
          );
        })}
      </div>
    </div>
  )}
</div><!-- /page-sidebar -->

</div><!-- /content -->
</main>

<footer style="max-width:1100px;margin:0 auto;padding:20px 32px;font-family:var(--mono);font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(13,13,20,0.20)">
  HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026 · GSAx XGBoost AUC 0.77
</footer>

<canvas id="goalie-card-canvas" style="display:none"></canvas>
<script is:inline src="/js/table-export.js"></script>

<script is:inline>
(function () {
  // Career stats RS/PO tab toggle
  var careerTabs = document.querySelectorAll('.career-tab');
  careerTabs.forEach(function (btn) {
    btn.addEventListener('click', function () {
      careerTabs.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var type = btn.getAttribute('data-type');
      document.querySelectorAll('.career-season-row').forEach(function (row) {
        row.style.display = type === '2'
          ? (row.classList.contains('rs-row') ? '' : 'none')
          : (row.classList.contains('po-row') ? '' : 'none');
      });
    });
  });

  // Heatmap mode toggle (Own SV% vs League)
  var heatBtns = document.querySelectorAll('.heat-mode-btn');
  if (heatBtns.length) {
    var heatRects = null;
    heatBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var mode = btn.getAttribute('data-mode');
        heatBtns.forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
        if (!heatRects) heatRects = document.querySelectorAll('#goalie-heat-svg rect[data-fill-raw]');
        heatRects.forEach(function (rect) {
          rect.setAttribute('fill', rect.getAttribute('data-fill-' + mode) || '');
        });
        var sub = document.getElementById('heat-sub');
        var ctx = document.getElementById('heat-legend-ctx');
        if (mode === 'league') {
          if (sub) sub.textContent = 'smoothed · blue = above league avg · red = below';
          if (ctx) ctx.textContent = 'vs league avg per zone';
        } else {
          if (sub) sub.textContent = 'smoothed · blue = above your avg · red = below';
          if (ctx) ctx.textContent = 'vs own avg';
        }
      });
    });
  }
})();
</script>

<script define:vars={{ G: cardData }}>
  (function () {
    const status = document.getElementById('goalie-card-status');
    const btn    = document.getElementById('dl-goalie-card');
    if (!btn) return;

    // ── palette (matches skater card) ──────────────────────────────────────
    const BG      = '#EFEEE8';
    const SURFACE = '#FFFFFF';
    const INK     = '#0D0D14';
    const RED     = '#E8002D';
    const GREEN   = '#1a7a3e';
    const INK72   = 'rgba(13,13,20,0.72)';
    const INK48   = 'rgba(13,13,20,0.48)';
    const INK32   = 'rgba(13,13,20,0.32)';
    const INK20   = 'rgba(13,13,20,0.20)';
    const INK14   = 'rgba(13,13,20,0.14)';
    const INK10   = 'rgba(13,13,20,0.10)';
    const INK06   = 'rgba(13,13,20,0.06)';
    const TEAM_C  = G.hasTeam ? (G.teamColor || INK) : '#8a8a8a';

    const TEAM_NAMES = {
      ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',
      BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',
      CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',
      DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',
      FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',
      MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',
      NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',
      PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',
      SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',
      TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',
      VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS',
    };

    // ── helpers ────────────────────────────────────────────────────────────
    function rrect(ctx, x, y, w, h, r) {
      ctx.beginPath();
      if (typeof ctx.roundRect === 'function') { ctx.roundRect(x, y, w, h, r); }
      else {
        ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
        ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
        ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
        ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath();
      }
    }
    function loadImg(src) {
      return new Promise(res => {
        const img = new Image(); img.crossOrigin = 'anonymous';
        img.onload = () => res(img); img.onerror = () => res(null);
        img.src = src;
      });
    }
    function ordinal(n) {
      const a = Math.round(n), m10 = a % 10, m100 = a % 100;
      if (m100 >= 11 && m100 <= 13) return a + 'th';
      if (m10 === 1) return a + 'st';
      if (m10 === 2) return a + 'nd';
      if (m10 === 3) return a + 'rd';
      return a + 'th';
    }
    const sgn = (v) => (v >= 0 ? '+' : '');
    // Save % as ".923" (no leading zero); null → "—"
    const svStr = (v) => v == null ? '—' : v.toFixed(3).replace(/^0/, '');

    // ── drawing helpers ────────────────────────────────────────────────────
    function edgeTierColor(pct) {
      if (pct == null) return INK32;
      if (pct >= 75) return GREEN;
      if (pct >= 50) return '#34a853';
      if (pct >= 25) return INK32;
      return RED;
    }

    function panel(ctx, x, y, w, h, r) {
      ctx.fillStyle = SURFACE; ctx.beginPath(); ctx.roundRect(x, y, w, h, r ?? 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(x, y, w, h, r ?? 4); ctx.stroke();
    }

    function sectionTitle(ctx, x, y, title, subtitle) {
      ctx.font = '800 16px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText(title, x, y);
      if (subtitle) {
        ctx.font = '500 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32;
        ctx.fillText(subtitle, x, y + 19);
      }
    }

    function pctBar(ctx, x, y, w, h, pct100, color) {
      ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(x, y, w, h, 2); ctx.fill();
      if (pct100 != null && pct100 > 0) {
        ctx.fillStyle = color || edgeTierColor(pct100);
        ctx.beginPath(); ctx.roundRect(x, y, Math.max(4, (pct100/100)*w), h, 2); ctx.fill();
      }
    }

    function teamRgba(alpha) {
      if (!TEAM_C.startsWith('#') || TEAM_C.length < 7) return `rgba(13,13,20,${alpha})`;
      const r = parseInt(TEAM_C.slice(1,3),16), g = parseInt(TEAM_C.slice(3,5),16), b = parseInt(TEAM_C.slice(5,7),16);
      return `rgba(${r},${g},${b},${alpha})`;
    }

    // ── card draw ──────────────────────────────────────────────────────────
    async function drawGoalieCard() {
      const SCALE = 2;
      const W = 750, PAD = 28;
      const e = G.edge;
      const hasPlayoff = G.playoffGames > 0;

      const HDR_H   = 110;
      const HERO_H  = 210;
      const TIER_H  = 290;
      const TYPE_H  = G.types && G.types.length > 0 ? 190 : 0;
      const EDGE_BOX_H = e ? 120 : 0;
      const EDGE_ZON_H = e ? 155 : 0;
      const PO_H    = hasPlayoff ? 52 : 0;
      const FOOT_H  = 44;
      const GAP     = 10;

      const H = HDR_H + HERO_H + GAP + TIER_H + (TYPE_H ? GAP + TYPE_H : 0)
              + (EDGE_BOX_H ? GAP + EDGE_BOX_H : 0) + (EDGE_ZON_H ? GAP + EDGE_ZON_H : 0)
              + (PO_H ? GAP + PO_H : 0) + FOOT_H;

      const canvas = document.getElementById('goalie-card-canvas');
      canvas.width  = W * SCALE;
      canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.scale(SCALE, SCALE);

      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, H);

      let y = 0;

      // ── 1. HEADER ────────────────────────────────────────────────────────
      ctx.fillStyle = SURFACE; ctx.fillRect(0, 0, W, HDR_H);
      ctx.fillStyle = TEAM_C;  ctx.fillRect(0, 0, 6, HDR_H);

      ctx.font = '800 32px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText((G.name || '').toUpperCase(), PAD, 44);

      const chipH = 18, chipY0 = 62;
      const chips = [
        { t: G.hasTeam ? G.team : 'FA', bg: TEAM_C, fg: BG },
        { t: 'G',                        bg: INK,    fg: BG },
        { t: sgn(G.gsax) + G.gsax.toFixed(1) + ' GSAx', bg: INK, fg: BG, accent: G.gsax >= 0 ? GREEN : RED },
      ];
      let cx2 = PAD;
      ctx.font = '500 9px "JetBrains Mono", monospace'; ctx.textBaseline = 'middle';
      for (const c of chips) {
        const tw = ctx.measureText(c.t).width, cw = tw + 18;
        rrect(ctx, cx2, chipY0, cw, chipH, 3); ctx.fillStyle = c.accent || c.bg; ctx.fill();
        ctx.fillStyle = c.fg; ctx.textAlign = 'left';
        ctx.fillText(c.t, cx2 + 9, chipY0 + chipH / 2 + 0.5);
        cx2 += cw + 8;
      }
      const brand = 'HGB STATS', btw = ctx.measureText(brand).width, bcw = btw + 18;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3); ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2 + 0.5);

      ctx.fillStyle = INK10; ctx.fillRect(0, HDR_H - 1, W, 1);
      y = HDR_H;

      // ── 2. HERO ROW ───────────────────────────────────────────────────────
      panel(ctx, 0, y, W, HERO_H, 0);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, y, 6, HERO_H);

      const R = 68, HS_CX = PAD + R + 6, HS_CY = y + HERO_H / 2;
      const hsImg = await loadImg(G.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI*2); ctx.clip();
      if (hsImg) ctx.drawImage(hsImg, HS_CX-R, HS_CY-R, R*2, R*2);
      else { ctx.fillStyle = INK10; ctx.fillRect(HS_CX-R, HS_CY-R, R*2, R*2); }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI*2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 3; ctx.stroke();

      const tileX = HS_CX + R + 24;
      const tileW = (W - tileX - PAD) / 4;
      const svPctPct = e?.svpct_all?.pct  != null ? e.svpct_all.pct * 100  : null;
      const gaaPct   = e?.gaa?.pct         != null ? e.gaa.pct * 100        : null;
      const rankPct  = G.rank != null && G.qualCount > 0 ? (1 - (G.rank-1)/G.qualCount)*100 : null;
      const dVal     = G.dSvPct != null ? G.dSvPct * 100 : null;

      const tiles = [
        { lbl: 'GSAx',  big: sgn(G.gsax) + G.gsax.toFixed(1),
          sub: G.gsaxPer100 != null ? G.gsaxPer100.toFixed(2) + ' /100 SA' : '',
          bigColor: G.gsax >= 0 ? GREEN : RED, pct: rankPct },
        { lbl: 'SV %',  big: svStr(G.svPct),
          sub: G.xsvPct != null ? 'xSv ' + svStr(G.xsvPct) : '',
          bigColor: INK, pct: svPctPct },
        { lbl: 'GAA',   big: G.gaa != null ? G.gaa.toFixed(2) : '—',
          sub: e?.gaa?.league_avg != null ? 'lg ' + e.gaa.league_avg.toFixed(2) : '',
          bigColor: INK, pct: gaaPct },
        { lbl: 'dSV %', big: dVal != null ? (dVal>=0?'+':'') + dVal.toFixed(2) : '—',
          sub: 'vs expected', bigColor: dVal != null ? (dVal >= 0 ? GREEN : RED) : INK, pct: null },
      ];

      for (let i = 0; i < tiles.length; i++) {
        const tx = tileX + i * tileW, t = tiles[i];
        if (i > 0) { ctx.fillStyle = INK06; ctx.fillRect(tx, y + 16, 1, HERO_H - 32); }
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
        ctx.fillText(t.lbl, tx + 10, y + 18);
        ctx.font = '800 36px "Barlow Condensed", sans-serif'; ctx.fillStyle = t.bigColor;
        ctx.fillText(t.big, tx + 10, y + 30);
        if (t.sub) {
          ctx.font = '500 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
          ctx.fillText(t.sub, tx + 10, y + 72);
        }
        if (t.pct != null) {
          const fc = edgeTierColor(t.pct);
          pctBar(ctx, tx + 10, y + 87, tileW - 20, 4, t.pct, fc);
          ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = fc; ctx.textBaseline = 'top';
          ctx.fillText(ordinal(Math.round(t.pct)) + ' pct', tx + 10, y + 94);
        }
      }

      ctx.font = '500 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      const rankTxt = G.rank != null
        ? ordinal(G.rank) + ' of ' + G.qualCount + ' qualified goalies (min. ' + G.saQual + ' SA)'
        : G.sa.toLocaleString() + ' SA · below ' + G.saQual + ' SA qualifier';
      ctx.fillText(rankTxt, W / 2, y + HERO_H - 14);
      ctx.fillStyle = INK10; ctx.fillRect(0, y + HERO_H - 1, W, 1);
      y += HERO_H + GAP;

      // ── 3. GSAx BY xG TIER ───────────────────────────────────────────────
      panel(ctx, PAD - 4, y, W - PAD*2 + 8, TIER_H, 4);
      sectionTitle(ctx, PAD + 8, y + 12, 'GSAx BY xG DIFFICULTY TIER',
        'GOALS SAVED ABOVE EXPECTED · EACH SHOT-DIFFICULTY BAND');

      if (G.bins && G.bins.length > 0) {
        const barsTop = y + 44, barsBot = y + TIER_H - 12;
        const absMax  = Math.max(...G.bins.map(b => Math.abs(b.gsax)), 1);
        const LABEL_W = 88, VAL_W = 118;
        const chartL  = PAD + LABEL_W, chartR = W - PAD - VAL_W;
        const zeroX   = chartL + (chartR - chartL) / 2;
        const halfW   = (chartR - chartL) / 2;
        const rowGap  = (barsBot - barsTop) / G.bins.length;
        const barH    = Math.min(22, rowGap - 22);

        for (let i = 0; i < G.bins.length; i++) {
          const b = G.bins[i];
          const rowCY = barsTop + i * rowGap + rowGap / 2;
          const isPos = b.gsax >= 0;
          const barLen = (Math.abs(b.gsax) / absMax) * halfW;

          ctx.font = '500 11px "JetBrains Mono", monospace';
          ctx.fillStyle = INK72; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
          ctx.fillText(b.label, PAD + LABEL_W - 8, rowCY - 5);
          ctx.font = '400 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
          ctx.fillText(b.sa + ' SA · ' + b.ga + ' GA', PAD + LABEL_W - 8, rowCY + 8);

          ctx.fillStyle = INK14; ctx.fillRect(zeroX, rowCY - barH/2 - 4, 1, barH + 8);

          ctx.fillStyle = isPos ? GREEN : RED;
          if (isPos) { rrect(ctx, zeroX, rowCY - barH/2, Math.max(2, barLen), barH, 2); }
          else       { rrect(ctx, zeroX - Math.max(2, barLen), rowCY - barH/2, Math.max(2, barLen), barH, 2); }
          ctx.fill();

          ctx.font = '600 12px "JetBrains Mono", monospace';
          ctx.fillStyle = isPos ? GREEN : RED; ctx.textBaseline = 'middle';
          if (isPos) { ctx.textAlign = 'left';  ctx.fillText(sgn(b.gsax)+b.gsax.toFixed(1), zeroX+Math.max(2,barLen)+6, rowCY); }
          else       { ctx.textAlign = 'right'; ctx.fillText(b.gsax.toFixed(1),             zeroX-Math.max(2,barLen)-6, rowCY); }

          ctx.font = '400 9px "JetBrains Mono", monospace';
          ctx.fillStyle = INK32; ctx.textAlign = 'right';
          const svLbl = (b.svPct != null ? svStr(b.svPct) : '—') + ' vs ' + svStr(b.leagueSvPct) + ' lg';
          ctx.fillText(svLbl, W - PAD, rowCY);
        }
      }
      y += TIER_H + GAP;

      // ── 4. GSAx BY SHOT TYPE ──────────────────────────────────────────────
      if (G.types && G.types.length > 0) {
        panel(ctx, PAD - 4, y, W - PAD*2 + 8, TYPE_H, 4);
        sectionTitle(ctx, PAD + 8, y + 12, 'GSAx BY SHOT TYPE', 'GOALS SAVED ABOVE EXPECTED · BY SHOT CATEGORY');

        const typeAbsMax = Math.max(...G.types.map(t => Math.abs(t.gsax)), 1);
        const colW = (W - PAD*2 - 8 - 24) / G.types.length;
        const colTopY = y + 44;
        const CHIP2 = 20, NUM2 = 30, BAR2 = 5;

        for (let i = 0; i < G.types.length; i++) {
          const t = G.types[i];
          const colX = PAD + 4 + i * (colW + 8);
          let cy = colTopY;
          const isPos = t.gsax >= 0;

          ctx.fillStyle = i === 0 ? teamRgba(0.12) : INK06;
          ctx.beginPath(); ctx.roundRect(colX, cy, colW, CHIP2, 2); ctx.fill();
          ctx.font = '700 9px "JetBrains Mono", monospace';
          ctx.fillStyle = i === 0 ? TEAM_C : INK48;
          ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText(t.label.toUpperCase(), colX + colW/2, cy + CHIP2/2);
          cy += CHIP2 + 8;

          ctx.font = '800 ' + NUM2 + 'px "Barlow Condensed", sans-serif';
          ctx.fillStyle = isPos ? GREEN : RED; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(sgn(t.gsax) + t.gsax.toFixed(1), colX, cy); cy += NUM2 + 4;

          const bLen = (Math.abs(t.gsax) / typeAbsMax) * colW;
          ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(colX, cy, colW, BAR2, 2); ctx.fill();
          ctx.fillStyle = isPos ? GREEN : RED;
          ctx.beginPath(); ctx.roundRect(colX, cy, Math.max(3, bLen), BAR2, 2); ctx.fill();
          cy += BAR2 + 6;

          ctx.font = '500 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
          ctx.textBaseline = 'top'; ctx.textAlign = 'left';
          ctx.fillText('SV%', colX, cy); cy += 11;
          ctx.font = '800 18px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
          ctx.fillText(svStr(t.svPct), colX, cy); cy += 20;
          ctx.font = '400 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
          ctx.fillText('vs ' + svStr(t.leagueSvPct) + ' lg', colX, cy); cy += 12;
          ctx.fillText(t.sa + ' SA', colX, cy);
        }
        y += TYPE_H + GAP;
      }

      // ── 5. EDGE STAT BOXES ────────────────────────────────────────────────
      if (e) {
        const divW = (W - PAD*2 - 200) / 2;
        ctx.fillStyle = INK14; ctx.fillRect(PAD, y + 8, divW, 1);
        ctx.font = '700 8px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('NHL EDGE GOALIE TRACKING', W/2, y + 8);
        ctx.fillStyle = INK14; ctx.fillRect(W/2 + 100, y + 8, divW, 1);
        y += 20;

        const bw = (W - PAD*2 - 20) / 3, bh = EDGE_BOX_H - 20;
        const edgeBoxes = [
          { lbl: 'ELITE GAMES (>.900)',
            val: e.games_above_900?.value != null ? (e.games_above_900.value*100).toFixed(1)+'%' : '—',
            pct: e.games_above_900?.pct   != null ? e.games_above_900.pct*100 : null,
            avg: e.games_above_900?.league_avg != null ? 'avg '+(e.games_above_900.league_avg*100).toFixed(1)+'%' : '' },
          { lbl: 'GOAL DIFF / 60',
            val: e.goal_diff_per60?.value != null ? (e.goal_diff_per60.value>=0?'+':'')+e.goal_diff_per60.value.toFixed(2) : '—',
            pct: e.goal_diff_per60?.pct   != null ? e.goal_diff_per60.pct*100 : null,
            avg: e.goal_diff_per60?.league_avg != null ? 'avg +'+e.goal_diff_per60.league_avg.toFixed(2) : '' },
          { lbl: 'WIN %',
            val: e.point_pctg?.value != null ? (e.point_pctg.value*100).toFixed(1)+'%' : '—',
            pct: e.point_pctg?.pct   != null ? e.point_pctg.pct*100 : null,
            avg: e.point_pctg?.league_avg != null ? 'avg '+(e.point_pctg.league_avg*100).toFixed(1)+'%' : '' },
        ];
        for (let i = 0; i < 3; i++) {
          const bx = PAD + i*(bw+10), b = edgeBoxes[i];
          panel(ctx, bx, y, bw, bh, 4);
          ctx.font = '700 9px "JetBrains Mono", monospace';
          ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(b.lbl, bx+10, y+9);
          ctx.font = '800 30px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
          ctx.fillText(b.val, bx+10, y+21);
          const barY = y + bh - 24;
          pctBar(ctx, bx+10, barY, bw-20, 5, b.pct);
          const fc = edgeTierColor(b.pct);
          ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = fc; ctx.textBaseline = 'top';
          ctx.fillText(b.pct != null ? ordinal(Math.round(b.pct))+' pct' : '', bx+10, barY+7);
          if (b.avg) {
            ctx.font = '400 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32; ctx.textAlign = 'right';
            ctx.fillText(b.avg, bx+bw-10, barY+7); ctx.textAlign = 'left';
          }
        }
        y += EDGE_BOX_H + GAP;

        // ── 6. SAVE % BY ZONE ──────────────────────────────────────────────
        panel(ctx, PAD - 4, y, W - PAD*2 + 8, EDGE_ZON_H, 4);
        sectionTitle(ctx, PAD + 8, y + 12, 'SAVE % BY SHOT LOCATION ZONE',
          'HIGH DANGER (HD) · MID RANGE · LONG RANGE');

        const zones2 = e.zones || [];
        const ZONE_LBLS = ['HIGH DANGER', 'MID RANGE', 'LONG RANGE'];
        const zColW = (W - PAD*2 - 8 - 16) / 3;
        const zTop = y + 44;

        for (let i = 0; i < 3; i++) {
          const z = zones2[i] || {};
          const zx = PAD + 4 + i*(zColW+8);
          let zy = zTop;
          const zPct = z.svpct_pct != null ? z.svpct_pct*100 : null;
          const zfc  = edgeTierColor(zPct);

          ctx.fillStyle = i === 0 ? teamRgba(0.12) : INK06;
          ctx.beginPath(); ctx.roundRect(zx, zy, zColW, 20, 2); ctx.fill();
          ctx.font = '700 9px "JetBrains Mono", monospace';
          ctx.fillStyle = i === 0 ? TEAM_C : INK48;
          ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText(ZONE_LBLS[i], zx + zColW/2, zy + 10);
          zy += 28;

          ctx.font = '800 32px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
          ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(z.svpct != null ? svStr(z.svpct) : '—', zx, zy); zy += 36;

          pctBar(ctx, zx, zy, zColW, 5, zPct, zfc); zy += 7;
          ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = zfc; ctx.textBaseline = 'top';
          ctx.fillText(zPct != null ? ordinal(Math.round(zPct))+' percentile' : '', zx, zy); zy += 14;

          ctx.font = '400 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
          ctx.fillText(z.league_svpct != null ? 'avg '+svStr(z.league_svpct) : '', zx, zy); zy += 13;

          ctx.font = '500 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
          ctx.fillText(z.saves != null ? z.saves+' SV · '+z.ga+' GA' : '', zx, zy);
        }
        y += EDGE_ZON_H + GAP;
      }

      // ── 7. PLAYOFF STRIP ──────────────────────────────────────────────────
      if (hasPlayoff) {
        const svPO = G.playoffSa > 0 ? 1 - G.playoffGa/G.playoffSa : null;
        ctx.fillStyle = teamRgba(0.06); ctx.fillRect(0, y, W, PO_H);
        ctx.fillStyle = TEAM_C; ctx.fillRect(0, y, 4, PO_H);
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = TEAM_C; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText('2026 PLAYOFFS', PAD, y + PO_H/2 - 8);
        ctx.font = '500 11px "JetBrains Mono", monospace'; ctx.fillStyle = INK48;
        const poLine = G.playoffGames + ' GP  ·  ' + sgn(G.playoffGsax) + G.playoffGsax.toFixed(1) + ' GSAx'
          + '  ·  ' + G.playoffGa + ' GA on ' + G.playoffSa + ' SA'
          + (svPO != null ? '  ·  ' + svStr(svPO) + ' Sv%' : '');
        ctx.fillText(poLine, PAD, y + PO_H/2 + 8);
        ctx.fillStyle = INK10; ctx.fillRect(0, y + PO_H - 1, W, 1);
        y += PO_H + GAP;
      }

      // ── 8. FOOTER ─────────────────────────────────────────────────────────
      ctx.fillStyle = INK06; ctx.fillRect(0, y, W, 1);
      ctx.font = '400 9px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText(
        e ? 'HOCKEYGAMEBOT.COM · 2025–26 · GSAx XGBoost · EDGE DATA: NHL'
          : 'HOCKEYGAMEBOT.COM · 2025–26 REGULAR SEASON · GSAx XGBoost',
        PAD, y + FOOT_H/2
      );

      return canvas;
    }

    // ── wire button ────────────────────────────────────────────────────────
    btn.addEventListener('click', async () => {
      const label = btn.textContent;
      btn.textContent = 'Generating…'; btn.disabled = true;
      if (status) { status.style.display = 'block'; status.textContent = 'Drawing…'; }
      try {
        if (document.fonts && document.fonts.ready) await document.fonts.ready;
        const canvas = await drawGoalieCard();
        const slug = G.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        window.HGB_Export.showCardModal(canvas, `hgb_goalie_${slug}_25-26.png`);
        if (status) { status.textContent = 'Done ✓'; setTimeout(() => { if (status) status.style.display = 'none'; }, 3000); }
      } catch (e) {
        console.error(e);
        if (status) status.textContent = 'Error — try again';
      } finally {
        btn.textContent = label; btn.disabled = false;
      }
    });
  })();
</script>

</body>
</html>
