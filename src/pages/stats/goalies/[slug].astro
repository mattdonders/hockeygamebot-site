})();
</script>

<script define:vars={{ G: cardData, careerSeasons: (goalie.career_seasons ?? []).filter(s => s.game_type === 2), teamColors: allTeamColors }}>
  (function () {
    const status = document.getElementById('goalie-card-status');
    const btn    = document.getElementById('dl-goalie-card');
    if (!btn) return;

    // ── palette (matches skater card) ──────────────────────────────────────
    const BG      = '#EFEEE8';
    const SURFACE = '#FFFFFF';
    const INK     = '#0D0D14';
    const RED     = '#E8002D';
    const GREEN   = '#1a7a3e';
    const INK72   = 'rgba(13,13,20,0.72)';
    const INK48   = 'rgba(13,13,20,0.48)';
    const INK45   = 'rgba(13,13,20,0.45)';
    const INK32   = 'rgba(13,13,20,0.32)';
    const INK20   = 'rgba(13,13,20,0.20)';
    const INK14   = 'rgba(13,13,20,0.14)';
    const INK10   = 'rgba(13,13,20,0.10)';
    const INK06   = 'rgba(13,13,20,0.06)';
    const TEAM_C  = G.hasTeam ? (G.teamColor || INK) : '#8a8a8a';
    let _selectedSeason = G.season;

    const TEAM_NAMES = {
      ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',
      BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',
      CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',
      DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',
      FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',
      MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',
      NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',
      PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',
      SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',
      TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',
      VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS',
    };

    // ── helpers ────────────────────────────────────────────────────────────
    function rrect(ctx, x, y, w, h, r) {
      ctx.beginPath();
      if (typeof ctx.roundRect === 'function') { ctx.roundRect(x, y, w, h, r); }
      else {
        ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
        ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
        ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
        ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath();
      }
    }
    function loadImg(src) {
      return new Promise(res => {
        const img = new Image(); img.crossOrigin = 'anonymous';
        img.onload = () => res(img); img.onerror = () => res(null);
        img.src = src;
      });
    }
    function ordinal(n) {
      const a = Math.round(n), m10 = a % 10, m100 = a % 100;
      if (m100 >= 11 && m100 <= 13) return a + 'th';
      if (m10 === 1) return a + 'st';
      if (m10 === 2) return a + 'nd';
      if (m10 === 3) return a + 'rd';
      return a + 'th';
    }
    const sgn = (v) => (v >= 0 ? '+' : '');
    // Save % as ".923" (no leading zero); null → "—"
    const svStr = (v) => v == null ? '—' : v.toFixed(3).replace(/^0/, '');

    // ── drawing helpers ────────────────────────────────────────────────────
    function edgeTierColor(pct) {
      if (pct == null) return INK32;
      if (pct >= 75) return GREEN;
      if (pct >= 50) return '#34a853';
      if (pct >= 25) return INK32;
      return RED;
    }

    function panel(ctx, x, y, w, h, r) {
      ctx.fillStyle = SURFACE; ctx.beginPath(); ctx.roundRect(x, y, w, h, r ?? 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(x, y, w, h, r ?? 4); ctx.stroke();
    }

    function sectionTitle(ctx, x, y, title, subtitle) {
      ctx.font = '800 16px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText(title, x, y);
      if (subtitle) {
        ctx.font = '500 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32;
        ctx.fillText(subtitle, x, y + 19);
      }
    }

    function pctBar(ctx, x, y, w, h, pct100, color) {
      ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(x, y, w, h, 2); ctx.fill();
      if (pct100 != null && pct100 > 0) {
        ctx.fillStyle = color || edgeTierColor(pct100);
        ctx.beginPath(); ctx.roundRect(x, y, Math.max(4, (pct100/100)*w), h, 2); ctx.fill();
      }
    }

    function teamRgba(alpha) {
      if (!TEAM_C.startsWith('#') || TEAM_C.length < 7) return `rgba(13,13,20,${alpha})`;
      const r = parseInt(TEAM_C.slice(1,3),16), g = parseInt(TEAM_C.slice(3,5),16), b = parseInt(TEAM_C.slice(5,7),16);
      return `rgba(${r},${g},${b},${alpha})`;
    }

    // ── EDGE stat box (white panel + label + big value + pct bar) ─────────
    function drawEdgeStatBox(ctx, x, y, w, h, lbl, valStr, pct, avgStr) {
      const PAD = 10;
      ctx.fillStyle = SURFACE; ctx.beginPath(); ctx.roundRect(x, y, w, h, 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(x, y, w, h, 4); ctx.stroke();
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK45; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText(lbl.toUpperCase(), x + PAD, y + 9);
      ctx.font = '800 28px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK; ctx.textBaseline = 'top';
      ctx.fillText(valStr, x + PAD, y + 20);
      const bx = x + PAD, bw = w - PAD * 2, bh = 6, barY = y + h - 30;
      const pct100 = pct != null ? pct * 100 : null;
      pctBar(ctx, bx, barY, bw, bh, pct100);
      const fc = edgeTierColor(pct100);
      ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = fc; ctx.textBaseline = 'top';
      ctx.fillText(pct100 != null ? ordinal(Math.round(pct100)) + ' percentile' : '', x + PAD, y + h - 22);
      if (avgStr) {
        ctx.font = '400 10px "JetBrains Mono", monospace'; ctx.fillStyle = INK32; ctx.textAlign = 'right';
        ctx.fillText(avgStr, x + w - PAD, y + h - 22); ctx.textAlign = 'left';
      }
    }

    // ── card draw ──────────────────────────────────────────────────────────
    async function drawGoalieCard(selectedSeason) {
      // ── season lookup (mirrors drawSeasonCard pattern from player page) ───
      var allSeasons = typeof careerSeasons !== 'undefined' ? careerSeasons : [];
      var hist = null;
      if (selectedSeason && selectedSeason !== G.season) {
        hist = allSeasons.find(function(s) { return s.season === selectedSeason; }) || null;
      }
      var isHistorical = !!hist;
      // Season-aware local variables (shadow G for historical seasons)
      var heroSeason   = isHistorical ? selectedSeason : G.season;
      var seasonTeam   = isHistorical ? (hist.team_abbrev || G.team) : G.team;
      var TEAM_C       = (teamColors && teamColors[seasonTeam]) ? teamColors[seasonTeam] : (G.teamColor || INK);
      var gSa          = isHistorical ? (hist.sa          ?? G.sa)       : G.sa;
      var gGa          = isHistorical ? (hist.ga          ?? G.ga)       : G.ga;
      var gSvPct       = isHistorical ? (hist.sv_pct      ?? null)       : G.svPct;
      var gGp          = isHistorical ? (hist.gp          ?? G.gp)       : G.gp;
      var gGsax        = isHistorical ? (hist.gsax        ?? null)       : G.gsax;
      var gGsax5v5     = isHistorical ? (hist.gsax_5v5    ?? null)       : G.gsax5v5;
      var gGsaxPct     = isHistorical ? (hist.gsax_pct    ?? null)       : G.gsaxPct;
      var gGsax5v5Pct  = isHistorical ? (hist.gsax_5v5_pct ?? null)      : G.gsax5v5Pct;
      var gGsaxPer60   = isHistorical ? null                             : G.gsaxPer60;
      var gGsax60Pct   = isHistorical ? null                             : G.gsax60Pct;
      var gDSvPct      = isHistorical
        ? (hist.gsax != null && hist.sa > 0 ? hist.gsax / hist.sa : null)
        : G.dSvPct;
      var gDsvPctPct   = isHistorical ? null : G.dsvPctPct;
      var gGaa         = isHistorical ? null : G.gaa;
      var e            = isHistorical ? null : G.edge;

      const BG2 = '#EFEEE8', SURFACE2 = '#FFFFFF';
      const SCALE = 2;
      const L_W = 520, R_W = 520, PAD2 = 24, R_PAD = 20;
      const hasEdge = !!e;
      const W = hasEdge ? L_W + R_W : L_W;

      // Heights (matching player drawSeasonCard conventions)
      const HDR_H = 52, CHIP_H = 34;
      const ID_H = 122, BAR_ROW_H = 28, BAR_ROWS = 6;
      const COUNTS_H_S = 68;
      const L_CONTENT_H = 6 + ID_H + COUNTS_H_S + 1 + 20 + 12 + BAR_ROWS * BAR_ROW_H + 12;
      // Right: 36+10 hdr + 2×(90+10)-10+20 tiles + 137 zone panel = 393; card height = L_CONTENT_H = 409
      const EDGE_CONTENT_H = hasEdge ? 393 : 80;
      const CONTENT_H = Math.max(L_CONTENT_H, EDGE_CONTENT_H);
      const FOOT_H = 36;
      const H = HDR_H + CHIP_H + CONTENT_H + FOOT_H;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // Background + left team-color accent bar
      ctx.fillStyle = BG2; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 4, H);

      // ── HEADER (white band) ────────────────────────────────────────────────
      ctx.fillStyle = SURFACE2; ctx.fillRect(0, 0, W, HDR_H + CHIP_H);
      ctx.fillStyle = INK14; ctx.fillRect(0, HDR_H + CHIP_H - 1, W, 1);

      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((G.firstName + ' ' + G.lastName).toUpperCase(), PAD2, HDR_H / 2);
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
      ctx.fillText('SEASON CARD · ' + heroSeason, W - PAD2, HDR_H / 2);

      // Chips
      const chipH2 = 18, chipY0 = HDR_H + (CHIP_H - chipH2) / 2;
      const teamFull = TEAM_NAMES[seasonTeam] || seasonTeam || 'FREE AGENT';
      const chipLabels = [
        ...(G.sweaterNumber != null ? [`#${G.sweaterNumber}`] : []),
        teamFull, 'GOALIE', heroSeason,
        ...(G.age != null ? [`AGE: ${G.age}`] : []),
        ...(G.shoots ? [`CATCHES: ${G.shoots}`] : []),
      ];
      // jersey number + team name both get team color (matches player card pattern)
      const teamColorChips = 1 + (G.sweaterNumber != null ? 1 : 0);
      let cx2 = PAD2;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chipLabels.length; ci++) {
        const cw = ctx.measureText(chipLabels[ci]).width + 18;
        rrect(ctx, cx2, chipY0, cw, chipH2, 3);
        ctx.fillStyle = ci < teamColorChips ? TEAM_C : INK; ctx.fill();
        ctx.fillStyle = BG2; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chipLabels[ci], cx2 + 9, chipY0 + chipH2 / 2);
        cx2 += cw + 8;
      }
      const brand2 = 'HOCKEYGAMEBOT';
      const bcw2 = ctx.measureText(brand2).width + 18;
      rrect(ctx, W - PAD2 - bcw2, chipY0, bcw2, chipH2, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG2; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand2, W - PAD2 - bcw2 + 9, chipY0 + chipH2 / 2);

      // Panel divider
      if (hasEdge) { ctx.fillStyle = INK14; ctx.fillRect(L_W, HDR_H + CHIP_H, 1, CONTENT_H); }

      // ── LEFT PANEL ─────────────────────────────────────────────────────────
      let y = HDR_H + CHIP_H + 6;

      // Headshot circle
      const R = 36, HS_CX = PAD2 + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(G.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      ctx.fillStyle = INK10; ctx.fillRect(HS_CX - R, HS_CY - R, R * 2, R * 2);
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
      } else {
        const initials = ((G.firstName || '')[0] || '') + ((G.lastName || '')[0] || '');
        ctx.font = '700 28px "Barlow Condensed", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.25)'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(initials.toUpperCase(), HS_CX, HS_CY);
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      // 2 hero tiles: GSAx % and GSAx/60 %
      const heroX = HS_CX + R + 18;
      const heroW = (L_W - heroX - PAD2) / 2;
      const heroTiles = [
        { label: 'HGB GSAx · ' + heroSeason,  pct: gGsaxPct,    sub: gGsax    != null ? (gGsax    >= 0 ? '+' : '') + gGsax.toFixed(1)    + ' GSAx' : '' },
        { label: 'GSAx 5v5 · ' + heroSeason,  pct: gGsax5v5Pct, sub: gGsax5v5 != null ? (gGsax5v5 >= 0 ? '+' : '') + gGsax5v5.toFixed(1) + ' GSAx' : '' },
      ];
      for (let i = 0; i < heroTiles.length; i++) {
        const t = heroTiles[i];
        const tcx = heroX + i * heroW + heroW / 2;
        if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(heroX + i * heroW, y + 18, 1, ID_H - 36); }
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.52)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText(t.label, tcx, y + 18);
        ctx.font = '900 58px "Barlow Condensed", sans-serif';
        ctx.fillStyle = t.pct != null ? TEAM_C : INK32;
        ctx.fillText(t.pct != null ? t.pct + '%' : '—', tcx, y + 34);
        if (t.sub) {
          ctx.font = '600 12px "JetBrains Mono", monospace';
          ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top';
          ctx.fillText(t.sub, tcx, y + 96);
        }
      }
      y += ID_H;

      // Counting strip: SA | GA | SV% | GP
      ctx.fillStyle = SURFACE2; ctx.fillRect(4, y, L_W - 4, COUNTS_H_S);
      const fmtSvPct = (v) => v != null ? v.toFixed(3).replace(/^0/, '') : '—';
      const countCols = [
        { label: 'SA',  val: gSa   != null ? String(gSa)   : '—', color: INK },
        { label: 'GA',  val: gGa   != null ? String(gGa)   : '—', color: INK },
        { label: 'SV%', val: fmtSvPct(gSvPct),                     color: TEAM_C },
        { label: 'GP',  val: gGp   != null ? String(gGp)   : '—', color: INK },
      ];
      const cColW = (L_W - PAD2 * 2) / countCols.length;
      for (let ci = 0; ci < countCols.length; ci++) {
        const cc = countCols[ci];
        const ccx = PAD2 + ci * cColW + cColW / 2;
        if (ci > 0) { ctx.fillStyle = INK06; ctx.fillRect(PAD2 + ci * cColW, y + 10, 1, COUNTS_H_S - 20); }
        ctx.font = '800 32px "Barlow Condensed", sans-serif';
        ctx.fillStyle = cc.color; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText(cc.val, ccx, y + COUNTS_H_S / 2 - 8);
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle';
        ctx.fillText(cc.label, ccx, y + COUNTS_H_S / 2 + 16);
      }
      y += COUNTS_H_S;

      ctx.fillStyle = INK14; ctx.fillRect(0, y, L_W, 1); y += 1 + 20;

      // Section header
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('GOALIE PERCENTILES', PAD2, y);
      const sHdrW = ctx.measureText('GOALIE PERCENTILES').width;
      ctx.fillStyle = RED;
      ctx.fillText('  VS. NHL GOALIES', PAD2 + sHdrW, y);
      y += 12;

      // 6 percentile bars — label top line, actual value bottom line, bar, % right
      const dVal = gDSvPct != null ? gDSvPct * 100 : null;
      const svPctPct2 = e?.svpct_all?.pct != null ? e.svpct_all.pct * 100 : null;
      const gaaPct2   = e?.gaa?.pct        != null ? e.gaa.pct * 100        : null;
      const hdPct     = e?.zones?.[0]?.svpct_pct != null ? e.zones[0].svpct_pct * 100 : null;
      const bars = [
        { label: 'GSAx',      val: gGsaxPct,    raw: gGsax     != null ? (gGsax     >= 0 ? '+' : '') + gGsax.toFixed(1)           : null, rawColor: gGsax     != null ? (gGsax     >= 0 ? GREEN : RED) : INK32 },
        { label: 'GSAx / 60', val: gGsax60Pct,  raw: gGsaxPer60 != null ? (gGsaxPer60 >= 0 ? '+' : '') + gGsaxPer60.toFixed(2)   : null, rawColor: gGsaxPer60 != null ? (gGsaxPer60 >= 0 ? GREEN : RED) : INK32 },
        { label: 'SV %',      val: svPctPct2,   raw: gSvPct    != null ? fmtSvPct(gSvPct)                                          : null, rawColor: INK },
        { label: 'dSV %',     val: gDsvPctPct,  raw: dVal      != null ? (dVal      >= 0 ? '+' : '') + dVal.toFixed(2) + '%'       : null, rawColor: dVal       != null ? (dVal       >= 0 ? GREEN : RED) : INK32 },
        { label: 'HD SV %',   val: hdPct,       raw: e?.zones?.[0]?.svpct != null ? fmtSvPct(e.zones[0].svpct)                     : null, rawColor: INK },
        { label: 'GAA',       val: gaaPct2,     raw: gGaa      != null ? gGaa.toFixed(2)                                            : null, rawColor: INK },
      ];
      function barFillG(v) {
        if (v == null) return 'rgba(13,13,20,0.20)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.35)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      function pctColorG(v) {
        if (v == null) return 'rgba(13,13,20,0.35)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.50)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      const BAR_H_PX = 11, BAR_LABEL_W = 124, BAR_RANK_W = 44;
      const BAR_AVAIL = L_W - PAD2 * 2 - BAR_LABEL_W - BAR_RANK_W - 8;
      for (let bi = 0; bi < bars.length; bi++) {
        const b = bars[bi], rowY = y + bi * BAR_ROW_H;
        const bmy = rowY + BAR_ROW_H / 2;
        const bby = bmy - BAR_H_PX / 2;
        const bx = PAD2 + BAR_LABEL_W;
        // Label left-aligned, value right-aligned to bar's left edge
        ctx.textBaseline = 'middle';
        ctx.font = '600 10px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textAlign = 'left';
        ctx.fillText(b.label, PAD2, bmy);
        if (b.raw) {
          ctx.font = '700 9px "JetBrains Mono", monospace';
          ctx.fillStyle = b.rawColor || INK32; ctx.textAlign = 'right';
          ctx.fillText(b.raw, bx - 8, bmy);
        }
        rrect(ctx, bx, bby, BAR_AVAIL, BAR_H_PX, 3); ctx.fillStyle = INK10; ctx.fill();
        if (b.val != null) {
          rrect(ctx, bx, bby, Math.max(6, (b.val / 100) * BAR_AVAIL), BAR_H_PX, 3);
          ctx.fillStyle = barFillG(b.val); ctx.fill();
        }
        ctx.font = '800 14px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        ctx.fillStyle = b.val == null ? 'rgba(13,13,20,0.32)' : pctColorG(b.val);
        ctx.fillText(b.val == null ? '—' : Math.round(b.val) + '%', L_W - PAD2, bmy);
      }

      // ── RIGHT PANEL — NHL EDGE GOALIE TRACKING ─────────────────────────────
      const RX = L_W + 1;
      let ry = HDR_H + CHIP_H;
      if (hasEdge) {
        // EDGE header
        const EDGE_HDR_H = 36;
        ctx.fillStyle = INK14; ctx.fillRect(RX, ry + EDGE_HDR_H - 1, R_W, 1);
        ctx.font = '800 13px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillStyle = INK; ctx.fillText('NHL EDGE ', RX + R_PAD, ry + EDGE_HDR_H / 2);
        const edgeLblW = ctx.measureText('NHL EDGE ').width;
        ctx.fillStyle = '#006D75'; ctx.fillText('GOALIE TRACKING', RX + R_PAD + edgeLblW, ry + EDGE_HDR_H / 2);
        ry += EDGE_HDR_H + 10;

        // 2×2 EDGE tiles
        const tileW = (R_W - R_PAD * 2 - 10) / 2, tileH = 90;
        const edgePairs = [
          ['ELITE GAMES (>.900)',
            e.games_above_900?.value != null ? (e.games_above_900.value * 100).toFixed(1) + '%' : '—',
            e.games_above_900?.pct ?? null,
            e.games_above_900?.league_avg != null ? 'avg ' + (e.games_above_900.league_avg * 100).toFixed(1) + '%' : ''],
          ['GOAL DIFF / 60',
            e.goal_diff_per60?.value != null ? (e.goal_diff_per60.value >= 0 ? '+' : '') + e.goal_diff_per60.value.toFixed(2) : '—',
            e.goal_diff_per60?.pct ?? null,
            e.goal_diff_per60?.league_avg != null ? 'avg +' + e.goal_diff_per60.league_avg.toFixed(2) : ''],
          ['WIN %',
            e.point_pctg?.value != null ? (e.point_pctg.value * 100).toFixed(1) + '%' : '—',
            e.point_pctg?.pct ?? null,
            e.point_pctg?.league_avg != null ? 'avg ' + (e.point_pctg.league_avg * 100).toFixed(1) + '%' : ''],
          ['SV % (ALL SITUATIONS)',
            e.svpct_all?.value != null ? svStr(e.svpct_all.value) : '—',
            e.svpct_all?.pct ?? null,
            e.svpct_all?.league_avg != null ? 'avg ' + svStr(e.svpct_all.league_avg) : ''],
        ];
        for (let i = 0; i < 4; i++) {
          const col = i % 2, row = Math.floor(i / 2);
          drawEdgeStatBox(ctx,
            RX + R_PAD + col * (tileW + 10), ry + row * (tileH + 10),
            tileW, tileH,
            edgePairs[i][0], edgePairs[i][1], edgePairs[i][2], edgePairs[i][3]);
        }
        ry += 2 * (tileH + 10) - 10 + 20;

        // Zone save% section — white panel matching tile style
        const zones = e.zones || [];
        const ZONE_LBLS2 = ['HIGH DANGER', 'MID RANGE', 'LONG RANGE'];
        const zbw = R_W - R_PAD * 2, zbx = RX + R_PAD;
        const ZONE_PANEL_H = 137;

        // White panel
        ctx.fillStyle = SURFACE2; ctx.beginPath(); ctx.roundRect(zbx, ry, zbw, ZONE_PANEL_H, 4); ctx.fill();
        ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(zbx, ry, zbw, ZONE_PANEL_H, 4); ctx.stroke();

        // Panel header — matches player card "SHOT LOCATION BY DANGER ZONE" style
        ctx.font = '700 10px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
        ctx.textAlign = 'left'; ctx.textBaseline = 'top';
        ctx.fillText('SAVE % BY SHOT LOCATION ZONE', zbx + 10, ry + 9);

        const zColW2 = (zbw - 16 - R_PAD) / 3;

        for (let i = 0; i < 3; i++) {
          const z = zones[i] || {};
          const zx = zbx + 8 + i * (zColW2 + 8);
          let zy2 = ry + 24;
          const zPct2 = z.svpct_pct != null ? z.svpct_pct * 100 : null;
          const zfc2  = edgeTierColor(zPct2);


          // Column label chip
          ctx.fillStyle = i === 0 ? teamRgba(0.12) : INK06;
          ctx.beginPath(); ctx.roundRect(zx, zy2, zColW2, 20, 2); ctx.fill();
          ctx.font = '700 10px "JetBrains Mono", monospace';
          ctx.fillStyle = i === 0 ? TEAM_C : INK45;
          ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText(ZONE_LBLS2[i], zx + zColW2 / 2, zy2 + 10);
          zy2 += 26; // chip + 6 gap

          // SV · GA counts — centered under the chip
          ctx.font = '700 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK48;
          ctx.textAlign = 'center'; ctx.textBaseline = 'top';
          ctx.fillText(z.saves != null ? z.saves + ' SV · ' + z.ga + ' GA' : '', zx + zColW2 / 2, zy2);
          zy2 += 13; // 9px text + 4 gap

          // Gap before sv% — distributes remaining space so panel bottom lines up with left panel
          zy2 += 20;

          // Big SV%
          ctx.font = '800 28px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
          ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(z.svpct != null ? svStr(z.svpct) : '—', zx, zy2);
          zy2 += 30; // 28px + 2 gap

          // Bar
          pctBar(ctx, zx, zy2, zColW2, 5, zPct2, zfc2);
          zy2 += 7; // 5px + 2 gap

          // Pct label
          ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = zfc2; ctx.textBaseline = 'top';
          ctx.fillText(zPct2 != null ? ordinal(Math.round(zPct2)) + ' percentile' : '', zx, zy2);
        }
      }

      // ── FOOTER ──────────────────────────────────────────────────────────────
      const FOOT_INK = 'rgba(13,13,20,0.55)';
      ctx.fillStyle = INK10; ctx.fillRect(0, H - FOOT_H, W, FOOT_H);
      ctx.font = '700 11px "Barlow Condensed", sans-serif';
      ctx.fillStyle = FOOT_INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText(e ? G.footers.withEdge : G.footers.noEdge, W / 2, H - FOOT_H / 2);

      return canvas;
    }

    // ── Shot Zone Map Card (KDE right panel) ──────────────────────────────
    async function drawGoalieKDE() {
      const BG2 = '#EFEEE8', SURFACE2 = '#FFFFFF';
      const SCALE = 2;
      const L_W = 520, R_W = 520, PAD2 = 24, R_PAD = 20;
      const W = L_W + R_W;

      const HDR_H = 52, CHIP_H = 34;
      const ID_H = 122, BAR_ROW_H = 28, BAR_ROWS = 6;
      const COUNTS_H_S = 68;
      const L_CONTENT_H = 6 + ID_H + COUNTS_H_S + 1 + 20 + 12 + BAR_ROWS * BAR_ROW_H + 12;
      const CONTENT_H = L_CONTENT_H;
      const FOOT_H = 36;
      const H = HDR_H + CHIP_H + CONTENT_H + FOOT_H;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // Background + left accent bar
      ctx.fillStyle = BG2; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 4, H);

      // Header (white band)
      ctx.fillStyle = SURFACE2; ctx.fillRect(0, 0, W, HDR_H + CHIP_H);
      ctx.fillStyle = INK14; ctx.fillRect(0, HDR_H + CHIP_H - 1, W, 1);

      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((G.firstName + ' ' + G.lastName).toUpperCase(), PAD2, HDR_H / 2);
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
      ctx.fillText('SEASON CARD · ' + G.season, W - PAD2, HDR_H / 2);

      // Chips
      const chipH2 = 18, chipY0 = HDR_H + (CHIP_H - chipH2) / 2;
      const teamFull = TEAM_NAMES[G.team] || G.team || 'FREE AGENT';
      const chipLabels = [
        ...(G.sweaterNumber != null ? [`#${G.sweaterNumber}`] : []),
        teamFull, 'GOALIE', G.season,
        ...(G.age != null ? [`AGE: ${G.age}`] : []),
        ...(G.shoots ? [`CATCHES: ${G.shoots}`] : []),
      ];
      const teamColorChips = 1 + (G.sweaterNumber != null ? 1 : 0);
      let cx2 = PAD2;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chipLabels.length; ci++) {
        const cw = ctx.measureText(chipLabels[ci]).width + 18;
        rrect(ctx, cx2, chipY0, cw, chipH2, 3);
        ctx.fillStyle = ci < teamColorChips ? TEAM_C : INK; ctx.fill();
        ctx.fillStyle = BG2; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chipLabels[ci], cx2 + 9, chipY0 + chipH2 / 2);
        cx2 += cw + 8;
      }
      const brand2 = 'HOCKEYGAMEBOT';
      const bcw2 = ctx.measureText(brand2).width + 18;
      rrect(ctx, W - PAD2 - bcw2, chipY0, bcw2, chipH2, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG2; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand2, W - PAD2 - bcw2 + 9, chipY0 + chipH2 / 2);

      // Panel divider
      ctx.fillStyle = INK14; ctx.fillRect(L_W, HDR_H + CHIP_H, 1, CONTENT_H);

      // ── LEFT PANEL (identical to drawGoalieCard) ──────────────────────────
      let y = HDR_H + CHIP_H + 6;

      const R = 36, HS_CX = PAD2 + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(G.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      ctx.fillStyle = INK10; ctx.fillRect(HS_CX - R, HS_CY - R, R * 2, R * 2);
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
      } else {
        const initials = ((G.firstName || '')[0] || '') + ((G.lastName || '')[0] || '');
        ctx.font = '700 28px "Barlow Condensed", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.25)'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(initials.toUpperCase(), HS_CX, HS_CY);
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      const heroX = HS_CX + R + 18;
      const heroW = (L_W - heroX - PAD2) / 2;
      const heroTiles = [
        { label: 'HGB GSAx · ' + G.season,  pct: G.gsaxPct,    sub: G.gsax    != null ? (G.gsax    >= 0 ? '+' : '') + G.gsax.toFixed(1)    + ' GSAx' : '' },
        { label: 'GSAx 5v5 · ' + G.season,  pct: G.gsax5v5Pct, sub: G.gsax5v5 != null ? (G.gsax5v5 >= 0 ? '+' : '') + G.gsax5v5.toFixed(1) + ' GSAx' : '' },
      ];
      for (let i = 0; i < heroTiles.length; i++) {
        const t = heroTiles[i];
        const tcx = heroX + i * heroW + heroW / 2;
        if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(heroX + i * heroW, y + 18, 1, ID_H - 36); }
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.52)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText(t.label, tcx, y + 18);
        ctx.font = '900 58px "Barlow Condensed", sans-serif';
        ctx.fillStyle = t.pct != null ? TEAM_C : INK32;
        ctx.fillText(t.pct != null ? t.pct + '%' : '—', tcx, y + 34);
        if (t.sub) {
          ctx.font = '600 12px "JetBrains Mono", monospace';
          ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top';
          ctx.fillText(t.sub, tcx, y + 96);
        }
      }
      y += ID_H;

      ctx.fillStyle = SURFACE2; ctx.fillRect(4, y, L_W - 4, COUNTS_H_S);
      const fmtSvPct = (v) => v != null ? v.toFixed(3).replace(/^0/, '') : '—';
      const countCols = [
        { label: 'SA',  val: G.sa  != null ? String(G.sa)  : '—', color: INK },
        { label: 'GA',  val: G.ga  != null ? String(G.ga)  : '—', color: INK },
        { label: 'SV%', val: fmtSvPct(G.svPct),                    color: TEAM_C },
        { label: 'GP',  val: G.gp  != null ? String(G.gp)  : '—', color: INK },
      ];
      const cColW = (L_W - PAD2 * 2) / countCols.length;
      for (let ci = 0; ci < countCols.length; ci++) {
        const cc = countCols[ci];
        const ccx = PAD2 + ci * cColW + cColW / 2;
        if (ci > 0) { ctx.fillStyle = INK06; ctx.fillRect(PAD2 + ci * cColW, y + 10, 1, COUNTS_H_S - 20); }
        ctx.font = '800 32px "Barlow Condensed", sans-serif';
        ctx.fillStyle = cc.color; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText(cc.val, ccx, y + COUNTS_H_S / 2 - 8);
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle';
        ctx.fillText(cc.label, ccx, y + COUNTS_H_S / 2 + 16);
      }
      y += COUNTS_H_S;
      ctx.fillStyle = INK14; ctx.fillRect(0, y, L_W, 1); y += 1 + 20;

      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('GOALIE PERCENTILES', PAD2, y);
      const sHdrW = ctx.measureText('GOALIE PERCENTILES').width;
      ctx.fillStyle = RED;
      ctx.fillText('  VS. NHL GOALIES', PAD2 + sHdrW, y);
      y += 12;

      const dVal = G.dSvPct != null ? G.dSvPct * 100 : null;
      const bars = [
        { label: 'GSAx',      val: G.gsaxPct,   raw: G.gsax      != null ? (G.gsax      >= 0 ? '+' : '') + G.gsax.toFixed(1)         : null, rawColor: G.gsax      != null ? (G.gsax      >= 0 ? GREEN : RED) : INK32 },
        { label: 'GSAx / 60', val: G.gsax60Pct, raw: G.gsaxPer60 != null ? (G.gsaxPer60 >= 0 ? '+' : '') + G.gsaxPer60.toFixed(2)    : null, rawColor: G.gsaxPer60 != null ? (G.gsaxPer60 >= 0 ? GREEN : RED) : INK32 },
        { label: 'SV %',      val: G.edge?.svpct_all?.pct != null ? G.edge.svpct_all.pct * 100 : null, raw: G.svPct != null ? fmtSvPct(G.svPct) : null, rawColor: INK },
        { label: 'dSV %',     val: G.dsvPctPct, raw: dVal        != null ? (dVal        >= 0 ? '+' : '') + dVal.toFixed(2) + '%'      : null, rawColor: dVal        != null ? (dVal        >= 0 ? GREEN : RED) : INK32 },
        { label: 'HD SV %',   val: G.edge?.zones?.[0]?.svpct_pct != null ? G.edge.zones[0].svpct_pct * 100 : null, raw: G.edge?.zones?.[0]?.svpct != null ? fmtSvPct(G.edge.zones[0].svpct) : null, rawColor: INK },
        { label: 'GAA',       val: G.edge?.gaa?.pct != null ? G.edge.gaa.pct * 100 : null, raw: G.gaa != null ? G.gaa.toFixed(2) : null, rawColor: INK },
      ];
      function barFillG2(v) {
        if (v == null) return 'rgba(13,13,20,0.20)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.35)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      function pctColorG2(v) {
        if (v == null) return 'rgba(13,13,20,0.35)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.50)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      const BAR_H_PX = 11, BAR_LABEL_W = 124, BAR_RANK_W = 44;
      const BAR_AVAIL = L_W - PAD2 * 2 - BAR_LABEL_W - BAR_RANK_W - 8;
      for (let bi = 0; bi < bars.length; bi++) {
        const b = bars[bi], rowY = y + bi * BAR_ROW_H;
        const bmy = rowY + BAR_ROW_H / 2;
        const bby = bmy - BAR_H_PX / 2;
        const bx = PAD2 + BAR_LABEL_W;
        ctx.textBaseline = 'middle';
        ctx.font = '600 10px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textAlign = 'left';
        ctx.fillText(b.label, PAD2, bmy);
        if (b.raw) {
          ctx.font = '700 9px "JetBrains Mono", monospace';
          ctx.fillStyle = b.rawColor || INK32; ctx.textAlign = 'right';
          ctx.fillText(b.raw, bx - 8, bmy);
        }
        rrect(ctx, bx, bby, BAR_AVAIL, BAR_H_PX, 3); ctx.fillStyle = INK10; ctx.fill();
        if (b.val != null) {
          rrect(ctx, bx, bby, Math.max(6, (b.val / 100) * BAR_AVAIL), BAR_H_PX, 3);
          ctx.fillStyle = barFillG2(b.val); ctx.fill();
        }
        ctx.font = '800 14px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        ctx.fillStyle = b.val == null ? 'rgba(13,13,20,0.32)' : pctColorG2(b.val);
        ctx.fillText(b.val == null ? '—' : Math.round(b.val) + '%', L_W - PAD2, bmy);
      }

      // ── RIGHT PANEL — KDE Zone Map ────────────────────────────────────────
      const RX = L_W + 1;
      const kdeUrl = `https://media.hockeygamebot.com/stats/goalie-cards/${G.goalieId}.png`;
      const kdeImg = await loadImg(kdeUrl);

      if (kdeImg) {
        const KDE_HDR_H = 36;
        // Section header
        ctx.fillStyle = INK14; ctx.fillRect(RX, HDR_H + CHIP_H + KDE_HDR_H - 1, R_W, 1);
        ctx.font = '800 13px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillStyle = INK;
        ctx.fillText('SHOT LOCATION MAP', RX + R_PAD, HDR_H + CHIP_H + KDE_HDR_H / 2);

        // Draw map — fit into remaining right panel space, centered
        const MAP_TOP = HDR_H + CHIP_H + KDE_HDR_H + 12;
        const MAP_BOT = H - FOOT_H - 12;
        const availH = MAP_BOT - MAP_TOP;
        const availW = R_W - R_PAD * 2;
        const imgAspect = kdeImg.naturalWidth / kdeImg.naturalHeight;
        let drawW = availW, drawH = availW / imgAspect;
        if (drawH > availH) { drawH = availH; drawW = availH * imgAspect; }
        const drawX = RX + R_PAD + (availW - drawW) / 2;
        const drawY = MAP_TOP + (availH - drawH) / 2;
        ctx.drawImage(kdeImg, drawX, drawY, drawW, drawH);

        // Legend
        const LX = RX + R_PAD, LY = H - FOOT_H - 20;
        const gradW = 80, gradH = 5;
        const grad = ctx.createLinearGradient(LX, 0, LX + gradW, 0);
        grad.addColorStop(0, '#b91c1c'); grad.addColorStop(0.5, '#ffffff'); grad.addColorStop(1, '#1d4ed8');
        ctx.fillStyle = grad; ctx.fillRect(LX, LY, gradW, gradH);
        ctx.font = '700 8px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText('WORSE', LX, LY - 6);
        ctx.textAlign = 'right';
        ctx.fillText('BETTER', LX + gradW, LY - 6);
      } else {
        // Fallback: no map available yet
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('ZONE MAP UNAVAILABLE', RX + R_W / 2, HDR_H + CHIP_H + CONTENT_H / 2);
      }

      // Footer
      ctx.fillStyle = INK10; ctx.fillRect(0, H - FOOT_H, W, FOOT_H);
      ctx.font = '700 11px "Barlow Condensed", sans-serif';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText('HOCKEYGAMEBOT.COM · ' + G.season + ' · KDE ZONE MAP · KERNEL DENSITY ESTIMATION · 6FT BW', W / 2, H - FOOT_H / 2);

      return canvas;
    }

    // ── Goalie Talent Card ────────────────────────────────────────────────
    // First-pass sibling to the Season card (spec §5). Same 1040-wide two-panel
    // shell (header/chips/footer). Hero = HGB TALENT % (3yr blended rate) +
    // Y-2/Y-1/Y-0 past single-season WAR% boxes + 3yr Games-Played %. Left =
    // 3yr boxscore strip (SA/GA/SV%/GP) + 6 season-card-style percentile bars
    // (gray track, colored fill/label by percentile) from G.card3yr — calibrated
    // GSAx scale, consistent with the Talent hero. Right = 3yr shotmap PNG
    // ({id}_3yr.png). Canvas-drawn — refined on a local dev server by the maintainer.
    async function drawGoalieTalentCard() {
      const BG2 = '#EFEEE8', SURFACE2 = '#FFFFFF';
      const SCALE = 2;
      const L_W = 520, R_W = 520, PAD2 = 24, R_PAD = 20;
      const W = L_W + R_W;

      const HDR_H = 52, CHIP_H = 34;
      const ID_H = 122, BAR_ROW_H = 28, BAR_ROWS = 6;
      const COUNTS_H_S = 68;
      // Match the Season/KDE card height so this reads as a sibling card.
      const L_CONTENT_H = 6 + ID_H + COUNTS_H_S + 1 + 20 + 12 + BAR_ROWS * BAR_ROW_H + 12;
      const CONTENT_H = L_CONTENT_H;
      const FOOT_H = 36;
      const H = HDR_H + CHIP_H + CONTENT_H + FOOT_H;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // Background + left accent bar
      ctx.fillStyle = BG2; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 4, H);

      // Header (white band)
      ctx.fillStyle = SURFACE2; ctx.fillRect(0, 0, W, HDR_H + CHIP_H);
      ctx.fillStyle = INK14; ctx.fillRect(0, HDR_H + CHIP_H - 1, W, 1);

      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((G.firstName + ' ' + G.lastName).toUpperCase(), PAD2, HDR_H / 2);
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
      ctx.fillText('TALENT CARD · 3-YEAR BLEND', W - PAD2, HDR_H / 2);

      // Chips
      const chipH2 = 18, chipY0 = HDR_H + (CHIP_H - chipH2) / 2;
      const teamFull = TEAM_NAMES[G.team] || G.team || 'FREE AGENT';
      const chipLabels = [
        ...(G.sweaterNumber != null ? [`#${G.sweaterNumber}`] : []),
        teamFull, 'GOALIE', G.season,
        ...(G.age != null ? [`AGE: ${G.age}`] : []),
        ...(G.shoots ? [`CATCHES: ${G.shoots}`] : []),
      ];
      const teamColorChips = 1 + (G.sweaterNumber != null ? 1 : 0);
      let cx2 = PAD2;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chipLabels.length; ci++) {
        const cw = ctx.measureText(chipLabels[ci]).width + 18;
        rrect(ctx, cx2, chipY0, cw, chipH2, 3);
        ctx.fillStyle = ci < teamColorChips ? TEAM_C : INK; ctx.fill();
        ctx.fillStyle = BG2; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chipLabels[ci], cx2 + 9, chipY0 + chipH2 / 2);
        cx2 += cw + 8;
      }
      const brand2 = 'HOCKEYGAMEBOT';
      const bcw2 = ctx.measureText(brand2).width + 18;
      rrect(ctx, W - PAD2 - bcw2, chipY0, bcw2, chipH2, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG2; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand2, W - PAD2 - bcw2 + 9, chipY0 + chipH2 / 2);

      // Panel divider
      ctx.fillStyle = INK14; ctx.fillRect(L_W, HDR_H + CHIP_H, 1, CONTENT_H);

      // ── LEFT PANEL — hero (Talent) + 3yr boxscore + percentile bars ───────
      let y = HDR_H + CHIP_H + 6;

      // Headshot circle
      const R = 36, HS_CX = PAD2 + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(G.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      ctx.fillStyle = INK10; ctx.fillRect(HS_CX - R, HS_CY - R, R * 2, R * 2);
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
      } else {
        const initials = ((G.firstName || '')[0] || '') + ((G.lastName || '')[0] || '');
        ctx.font = '700 28px "Barlow Condensed", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.25)'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(initials.toUpperCase(), HS_CX, HS_CY);
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      // Short season labels for the WAR boxes, derived from G.season ("2025-26").
      const _startYr = parseInt(String(G.season).slice(0, 4), 10);
      const fmtSzn = (yr) => Number.isNaN(yr) ? '' : String(yr).slice(2) + '-' + String(yr + 1).slice(2);

      // Hero region to the right of the headshot: TALENT | PAST WAR (Y-2/Y-1/Y-0) | GP%.
      const heroX = HS_CX + R + 18;
      const heroW = L_W - heroX - PAD2;
      const talentW = heroW * 0.28;
      const warW    = heroW * 0.50;
      const gpW     = heroW * 0.22;

      // TALENT (big %)
      {
        const tcx = heroX + talentW / 2;
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.72)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText('HGB TALENT', tcx, y + 14);
        ctx.font = '900 56px "Barlow Condensed", sans-serif';
        ctx.fillStyle = G.talentPct != null ? TEAM_C : INK32;
        ctx.fillText(G.talentPct != null ? Math.round(G.talentPct) + '%' : '—', tcx, y + 28);
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top';
        ctx.fillText('3YR BLENDED RATE', tcx, y + 92);
      }

      // PAST SINGLE-SEASON WAR — Y-2 / Y-1 / Y-0 (oldest → newest)
      {
        const L_WAR = heroX + talentW;
        ctx.fillStyle = INK10; ctx.fillRect(L_WAR, y + 18, 1, ID_H - 36);
        const rcx = L_WAR + warW / 2;
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.72)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText('PAST SINGLE-SEASON WAR', rcx, y + 14);

        const warCols = [
          { szn: fmtSzn(_startYr - 2), pct: G.warPctY2 },
          { szn: fmtSzn(_startYr - 1), pct: G.warPctY1 },
          { szn: fmtSzn(_startYr),     pct: G.warPct   },
        ];
        const PAD_INNER = 12;
        const usable = warW - PAD_INNER * 2;
        const SZN_Y = y + 38, NUM_Y = y + 50;
        warCols.forEach((c, i) => {
          const ccx = L_WAR + PAD_INNER + usable * (i + 0.5) / warCols.length;
          ctx.font = '700 9px "Barlow", sans-serif';
          ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
          ctx.fillText(c.szn, ccx, SZN_Y);
          ctx.font = '800 26px "Barlow Condensed", sans-serif';
          ctx.fillStyle = c.pct != null ? INK : INK32;
          ctx.fillText(c.pct != null ? Math.round(c.pct) + '%' : '—', ccx, NUM_Y);
        });
      }

      // GAMES PLAYED (3YR) workload
      {
        const L_GP = heroX + talentW + warW;
        ctx.fillStyle = INK10; ctx.fillRect(L_GP, y + 18, 1, ID_H - 36);
        const gcx = L_GP + gpW / 2;
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.72)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText('GAMES', gcx, y + 20);
        ctx.fillText('PLAYED · 3YR', gcx, y + 32);
        ctx.font = '900 34px "Barlow Condensed", sans-serif';
        ctx.fillStyle = G.gpPct3yr != null ? TEAM_C : INK32; ctx.textBaseline = 'top';
        ctx.fillText(G.gpPct3yr != null ? Math.round(G.gpPct3yr) + '%' : '—', gcx, y + 50);
      }
      y += ID_H;

      // 3-year data source. `card3yr` carries the calibrated boxscore totals + the
      // 6 season-card-style percentile bars (see stats-schemas.ts card_3yr). Bars use
      // the CALIBRATED GSAx percentile — consistent with the Talent hero — so we no
      // longer render the retired raw shot-type GSAx panel (which was on an
      // inconsistent xG scale and could contradict the hero, e.g. Andersen).
      const c3 = G.card3yr || {};
      const c3bars = Array.isArray(c3.bars) ? c3.bars : [];
      const fmtSvPct = (v) => v != null ? v.toFixed(3).replace(/^0/, '') : '—';

      // ── Boxscore strip: SA | GA | SV% | GP (3-year totals) ─────────────────
      ctx.fillStyle = SURFACE2; ctx.fillRect(4, y, L_W - 4, COUNTS_H_S);
      const countCols = [
        { label: 'SA',  val: c3.sa != null ? String(c3.sa) : '—',    color: INK },
        { label: 'GA',  val: c3.ga != null ? String(c3.ga) : '—',    color: INK },
        { label: 'SV%', val: fmtSvPct(c3.sv_pct),                     color: TEAM_C },
        { label: 'GP',  val: c3.gp != null ? String(c3.gp) : '—',    color: INK },
      ];
      const cColW = (L_W - PAD2 * 2) / countCols.length;
      for (let ci = 0; ci < countCols.length; ci++) {
        const cc = countCols[ci];
        const ccx = PAD2 + ci * cColW + cColW / 2;
        if (ci > 0) { ctx.fillStyle = INK06; ctx.fillRect(PAD2 + ci * cColW, y + 10, 1, COUNTS_H_S - 20); }
        ctx.font = '800 32px "Barlow Condensed", sans-serif';
        ctx.fillStyle = cc.color; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText(cc.val, ccx, y + COUNTS_H_S / 2 - 8);
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle';
        ctx.fillText(cc.label, ccx, y + COUNTS_H_S / 2 + 16);
      }
      y += COUNTS_H_S;

      ctx.fillStyle = INK14; ctx.fillRect(0, y, L_W, 1); y += 1 + 20;

      // Section header
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('3-YEAR PERCENTILES', PAD2, y);
      const sHdrW = ctx.measureText('3-YEAR PERCENTILES').width;
      ctx.fillStyle = RED;
      ctx.fillText('  VS. NHL GOALIES', PAD2 + sHdrW, y);
      y += 12;

      // ── 6 percentile bars — season-card gray-track style ──────────────────
      // pct (1–100) drives BOTH the fill width AND the fill color; value is
      // formatted per the bar's `fmt` (see spec). Same tier colors as drawGoalieCard.
      function barFillG(v) {
        if (v == null) return 'rgba(13,13,20,0.20)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.35)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      function pctColorG(v) {
        if (v == null) return 'rgba(13,13,20,0.35)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.50)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      function fmtBarValue(fmt, v) {
        if (v == null) return null;
        switch (fmt) {
          case 'gsax':   return (v >= 0 ? '+' : '') + v.toFixed(1);
          case 'rate2':  return (v >= 0 ? '+' : '') + v.toFixed(2);
          case 'svpct':  return v.toFixed(3).replace(/^0/, '');
          case 'dsvpct': return (v >= 0 ? '+' : '') + (v * 100).toFixed(1) + '%';
          case 'gaa':    return v.toFixed(2);
          default:       return String(v);
        }
      }
      // Green/red on signed formats (gsax, rate2, dsvpct); neutral ink otherwise.
      const signedFmts = { gsax: 1, rate2: 1, dsvpct: 1 };
      const BAR_H_PX = 11, BAR_LABEL_W = 124, BAR_RANK_W = 44;
      const BAR_AVAIL = L_W - PAD2 * 2 - BAR_LABEL_W - BAR_RANK_W - 8;
      for (let bi = 0; bi < 6; bi++) {
        const b = c3bars[bi] || {};
        const pct = b.pct != null ? b.pct : null;
        const raw = fmtBarValue(b.fmt, b.value);
        const rowY = y + bi * BAR_ROW_H;
        const bmy = rowY + BAR_ROW_H / 2;
        const bby = bmy - BAR_H_PX / 2;
        const bx = PAD2 + BAR_LABEL_W;
        // Label left, raw value right-aligned to bar's left edge
        ctx.textBaseline = 'middle';
        ctx.font = '600 10px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textAlign = 'left';
        ctx.fillText(b.label || '—', PAD2, bmy);
        if (raw != null) {
          const rawColor = signedFmts[b.fmt] ? (b.value >= 0 ? GREEN : RED) : INK;
          ctx.font = '700 9px "JetBrains Mono", monospace';
          ctx.fillStyle = rawColor; ctx.textAlign = 'right';
          ctx.fillText(raw, bx - 8, bmy);
        }
        // Gray track + colored fill
        rrect(ctx, bx, bby, BAR_AVAIL, BAR_H_PX, 3); ctx.fillStyle = INK10; ctx.fill();
        if (pct != null) {
          rrect(ctx, bx, bby, Math.max(6, (pct / 100) * BAR_AVAIL), BAR_H_PX, 3);
          ctx.fillStyle = barFillG(pct); ctx.fill();
        }
        // Percentile label
        ctx.font = '800 14px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        ctx.fillStyle = pct == null ? 'rgba(13,13,20,0.32)' : pctColorG(pct);
        ctx.fillText(pct == null ? '—' : Math.round(pct) + '%', L_W - PAD2, bmy);
      }

      // ── RIGHT PANEL — 3-year shotmap PNG ──────────────────────────────────
      const RX = L_W + 1;
      const mapUrl = `https://media.hockeygamebot.com/stats/goalie-cards/${G.goalieId}_3yr.png`;
      const mapImg = await loadImg(mapUrl);

      const MAP_HDR_H = 36;
      ctx.fillStyle = INK14; ctx.fillRect(RX, HDR_H + CHIP_H + MAP_HDR_H - 1, R_W, 1);
      ctx.font = '800 13px "Barlow Condensed", sans-serif';
      ctx.textAlign = 'left'; ctx.textBaseline = 'middle'; ctx.fillStyle = INK;
      ctx.fillText('SHOT LOCATION MAP · 3-YEAR', RX + R_PAD, HDR_H + CHIP_H + MAP_HDR_H / 2);

      if (mapImg) {
        const MAP_TOP = HDR_H + CHIP_H + MAP_HDR_H + 12;
        const MAP_BOT = H - FOOT_H - 20;
        const availH = MAP_BOT - MAP_TOP;
        const availW = R_W - R_PAD * 2;
        const imgAspect = mapImg.naturalWidth / mapImg.naturalHeight;
        let drawW = availW, drawH = availW / imgAspect;
        if (drawH > availH) { drawH = availH; drawW = availH * imgAspect; }
        const drawX = RX + R_PAD + (availW - drawW) / 2;
        const drawY = MAP_TOP + (availH - drawH) / 2;
        ctx.drawImage(mapImg, drawX, drawY, drawW, drawH);

        // Legend
        const LX = RX + R_PAD, LY = H - FOOT_H - 16;
        const gradW = 80, gradH = 5;
        const grad = ctx.createLinearGradient(LX, 0, LX + gradW, 0);
        grad.addColorStop(0, '#b91c1c'); grad.addColorStop(0.5, '#ffffff'); grad.addColorStop(1, '#1d4ed8');
        ctx.fillStyle = grad; ctx.fillRect(LX, LY, gradW, gradH);
        ctx.font = '700 8px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText('WORSE', LX, LY - 6);
        ctx.textAlign = 'right';
        ctx.fillText('BETTER', LX + gradW, LY - 6);
      } else {
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('3-YEAR SHOT MAP UNAVAILABLE', RX + R_W / 2, HDR_H + CHIP_H + CONTENT_H / 2);
      }

      // Footer
      ctx.fillStyle = INK10; ctx.fillRect(0, H - FOOT_H, W, FOOT_H);
      ctx.font = '700 11px "Barlow Condensed", sans-serif';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText(G.footers.talent, W / 2, H - FOOT_H / 2);

      return canvas;
    }

    // ── wire KDE button ────────────────────────────────────────────────────
    const kdeBtn = document.getElementById('dl-goalie-kde');
    const kdeStatus = document.getElementById('goalie-kde-status');
    if (kdeBtn) {
      kdeBtn.addEventListener('click', async () => {
        const label = kdeBtn.textContent;
        kdeBtn.textContent = 'Generating…'; kdeBtn.disabled = true;
        if (kdeStatus) { kdeStatus.style.display = 'block'; kdeStatus.textContent = 'Loading map…'; }
        try {
          if (document.fonts) {
            await document.fonts.ready;
            await Promise.all([
              document.fonts.load('900 1px "Barlow Condensed"'),
              document.fonts.load('700 1px "JetBrains Mono"'),
              document.fonts.load('600 1px "Barlow"'),
            ]);
          }
          const canvas = await drawGoalieKDE();
          const slug = G.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
          window.HGB_Export.showCardModal(canvas, `hgb_goalie_kde_${slug}_25-26.png`);
          if (kdeStatus) { kdeStatus.textContent = 'Done ✓'; setTimeout(() => { if (kdeStatus) kdeStatus.style.display = 'none'; }, 3000); }
        } catch (e) {
          console.error(e);
          if (kdeStatus) kdeStatus.textContent = 'Error — try again';
        } finally {
          kdeBtn.textContent = label; kdeBtn.disabled = false;
        }
      });
    }

    // ── wire Talent button ─────────────────────────────────────────────────
    // Only present for qualified goalies (talent_pct != null → button rendered).
    const talentBtn = document.getElementById('dl-goalie-talent');
    const talentStatus = document.getElementById('goalie-talent-status');
    if (talentBtn) {
      talentBtn.addEventListener('click', async () => {
        const label = talentBtn.textContent;
        talentBtn.textContent = 'Generating…'; talentBtn.disabled = true;
        if (talentStatus) { talentStatus.style.display = 'block'; talentStatus.textContent = 'Drawing…'; }
        try {
          if (document.fonts) {
            await document.fonts.ready;
            await Promise.all([
              document.fonts.load('900 1px "Barlow Condensed"'),
              document.fonts.load('700 1px "JetBrains Mono"'),
              document.fonts.load('600 1px "Barlow"'),
            ]);
          }
          const canvas = await drawGoalieTalentCard();
          const slug = G.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
          window.HGB_Export.showCardModal(canvas, `hgb_goalie_talent_${slug}_25-26.png`);
          if (talentStatus) { talentStatus.textContent = 'Done ✓'; setTimeout(() => { if (talentStatus) talentStatus.style.display = 'none'; }, 3000); }
        } catch (e) {
          console.error(e);
          if (talentStatus) talentStatus.textContent = 'Error — try again';
        } finally {
          talentBtn.textContent = label; talentBtn.disabled = false;
        }
      });
    }

    // ── update button label + selected season when a career table row is clicked
    document.addEventListener('hgb:season-select', (ev) => {
      const season = ev.detail?.season;
      if (!season || !btn) return;
      _selectedSeason = season;
      btn.textContent = `${season} Goalie Card →`;
    });

    // ── wire button ────────────────────────────────────────────────────────
    btn.addEventListener('click', async () => {
      const label = btn.textContent;
      btn.textContent = 'Generating…'; btn.disabled = true;
      if (status) { status.style.display = 'block'; status.textContent = 'Drawing…'; }
      try {
        if (document.fonts) {
          await document.fonts.ready;
          await Promise.all([
            document.fonts.load('900 1px "Barlow Condensed"'),
            document.fonts.load('700 1px "JetBrains Mono"'),
            document.fonts.load('600 1px "Barlow"'),
          ]);
        }
        const canvas = await drawGoalieCard(_selectedSeason);
        const slug = G.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        const seasonSlug = (_selectedSeason || G.season).replace(/[-–]/g, '-');
        window.HGB_Export.showCardModal(canvas, `hgb_goalie_${slug}_${seasonSlug}.png`);
        if (status) { status.textContent = 'Done ✓'; setTimeout(() => { if (status) status.style.display = 'none'; }, 3000); }
      } catch (e) {
        console.error(e);
        if (status) status.textContent = 'Error — try again';
      } finally {
        btn.textContent = label; btn.disabled = false;
      }
    });
  })();
</script>

</StatsLayout>
