<!-- Floating tooltip for cumulative chart -->
<div id="cum-tip" style="position:fixed;display:none;pointer-events:none;background:#0d0d14;color:#EFEEE8;padding:6px 10px;font-family:'JetBrains Mono',monospace;font-size:11px;border-radius:2px;z-index:200;white-space:nowrap">
  <div id="cum-tip-head" style="font-weight:700;font-size:12px;margin-bottom:2px"></div>
  <div id="cum-tip-val" style="color:rgba(239,238,232,0.65);font-size:10px;letter-spacing:0.04em"></div>
</div>

<script is:inline>
(function () {
  const tip     = document.getElementById('cum-tip');
  const tipHead = document.getElementById('cum-tip-head');
  const tipVal  = document.getElementById('cum-tip-val');
  const marker  = document.getElementById('cum-marker');
  if (!tip || !tipHead || !tipVal) return;

  function sign(v) { return v >= 0 ? '+' : ''; }
  function moveTip(e) {
    const x = e.clientX + 14, y = e.clientY - 36;
    tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? e.clientX - tip.offsetWidth - 8 : x) + 'px';
    tip.style.top  = Math.max(4, y) + 'px';
  }

  document.querySelectorAll('.cum-hit').forEach(function (c) {
    c.addEventListener('mouseenter', function (e) {
      const d   = c.dataset;
      const dt  = d.date ? d.date.slice(5).replace('-', '/') : '—';
      const cum = parseFloat(d.gsaxCum);
      const gm  = parseFloat(d.gsaxGame);
      tipHead.textContent = 'Game ' + d.game + ' · vs ' + d.opp + ' · ' + dt;
      tipVal.textContent  = 'game: ' + sign(gm) + gm.toFixed(2) + ' GSAx  ·  cum: ' + sign(cum) + cum.toFixed(2);
      tip.style.display = 'block';
      if (marker) { marker.setAttribute('x1', c.getAttribute('cx')); marker.setAttribute('x2', c.getAttribute('cx')); marker.removeAttribute('display'); }
      moveTip(e);
    });
    c.addEventListener('mousemove', moveTip);
    c.addEventListener('mouseleave', function () {
      tip.style.display = 'none';
      if (marker) marker.setAttribute('display', 'none');
    });
  });
})();
</script>

<script is:inline>
(function () {
  // Chart mode toggle: LINE vs BARS
  var btnLine  = document.getElementById('chart-mode-line');
  var btnBar   = document.getElementById('chart-mode-bar');
  var lineEls  = document.getElementById('line-els');
  var barEls   = document.getElementById('bar-els');
  var hitCircs = document.querySelectorAll('.cum-hit');
  if (!btnLine || !btnBar || !lineEls || !barEls) return;

  var activeStyle   = { background: '#0d0d14', color: '#EFEEE8' };
  var inactiveStyle = { background: 'transparent', color: 'rgba(13,13,20,0.45)' };

  function setMode(mode) {
    if (mode === 'line') {
      lineEls.removeAttribute('display');
      barEls.setAttribute('display', 'none');
      Object.assign(btnLine.style, activeStyle);
      Object.assign(btnBar.style, inactiveStyle);
      // hit circles use cumulative y → already positioned correctly
      hitCircs.forEach(function(c) { c.style.display = ''; });
    } else {
      lineEls.setAttribute('display', 'none');
      barEls.removeAttribute('display');
      Object.assign(btnLine.style, inactiveStyle);
      Object.assign(btnBar.style, activeStyle);
      // hide line hit circles in bar mode (bars are directly hoverable)
      hitCircs.forEach(function(c) { c.style.display = 'none'; });
    }
  }

  btnLine.addEventListener('click', function() { setMode('line'); });
  btnBar.addEventListener('click', function() { setMode('bar'); });

  // Bar hover tooltip (reuse #cum-tip)
  var tip     = document.getElementById('cum-tip');
  var tipHead = document.getElementById('cum-tip-head');
  var tipVal  = document.getElementById('cum-tip-val');
  var marker  = document.getElementById('cum-marker');
  function sign(v) { return v >= 0 ? '+' : ''; }
  function moveTip(e) {
    var x = e.clientX + 14, y = e.clientY - 36;
    tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? e.clientX - tip.offsetWidth - 8 : x) + 'px';
    tip.style.top  = Math.max(4, y) + 'px';
  }
  document.querySelectorAll('.bar-hit').forEach(function(b) {
    b.addEventListener('mouseenter', function(e) {
      var d = b.dataset;
      var dt  = d.date ? d.date.slice(5).replace('-', '/') : '—';
      var gm  = parseFloat(d.gsaxGame);
      var cum = parseFloat(d.gsaxCum);
      tipHead.textContent = 'Game ' + d.game + ' · vs ' + d.opp + ' · ' + dt;
      tipVal.textContent  = 'game: ' + sign(gm) + gm.toFixed(2) + ' GSAx  ·  cum: ' + sign(cum) + cum.toFixed(2);
      tip.style.display = 'block';
      moveTip(e);
    });
    b.addEventListener('mousemove', moveTip);
    b.addEventListener('mouseleave', function() { tip.style.display = 'none'; });
  });
})();
</script>

<script is:inline>
(function () {
  // Career stats RS/PO tab toggle
  var careerTabs = document.querySelectorAll('.career-tab');
  careerTabs.forEach(function (btn) {
