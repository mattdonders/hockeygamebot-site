function getExportChips() {
  const chips = [{ all: 'All Situations', '5v5': '5v5', pp: 'Power Play' }[situation]];
  if (posFilter !== 'all') chips.push(posFilter === 'F' ? 'Forwards' : 'Defense');
  return chips;
}

document.getElementById('dl-btn').addEventListener('click', function () {
  let filtered = DATA.slice();
  if (posFilter !== 'all') filtered = filtered.filter(r => r.group === posFilter);
  filtered.sort((a, b) => {
    const av = a[sortKey] ?? (sortAsc ? Infinity : -Infinity);
    const bv = b[sortKey] ?? (sortAsc ? Infinity : -Infinity);
    return sortAsc ? av - bv : bv - av;
  });
  const rows = filtered.map((r, i) => Object.assign({ _rank: i + 1 }, r));
  const sitLabel = { all: 'All Situations', '5v5': '5v5', pp: 'Power Play' }[situation];
  window.HGB_Export.downloadTablePng({
    title: 'Season Leaderboards',
    filterChips: getExportChips(),
    rows,
    columns: SIT_EXPORT_COLS[situation],
    filename: 'hgb-leaderboards.png',
  });
});
</script>
