---
import {
  loadPlayers,
  loadTopForwardsShots60,
  loadTopGoals60,
} from '../../lib/stats-loader';
import { pickTeamColor } from '../../lib/team-colors';

// ── Ranked list — HGB Rating (RAPM ×60, goals above replacement / 60 min) ───
const allPlayers = loadPlayers();
const withRapm = allPlayers.filter(p => p.rapm != null && p.gp >= 20);
const fwdRapmSorted = withRapm.filter(p => p.pos_group === 'F').sort((a, b) => (b.rapm ?? 0) - (a.rapm ?? 0));
const defRapmSorted = withRapm.filter(p => p.pos_group === 'D').sort((a, b) => (b.rapm ?? 0) - (a.rapm ?? 0));
function toRatingRow(p: typeof allPlayers[0], rank: number, total: number) {
  return { player_id: p.player_id, slug: p.slug, display_name: p.display_name,
           team_abbrev: p.team_abbrev, pos: p.pos, gp: p.gp,
           value: (p.rapm ?? 0) * 60,
           pct: Math.round((1 - rank / total) * 100) };
}
const fwdHGB = fwdRapmSorted.slice(0, 25).map((p, i) => toRatingRow(p, i, fwdRapmSorted.length));
const defHGB = defRapmSorted.slice(0, 25).map((p, i) => toRatingRow(p, i, defRapmSorted.length));
const top12Ids = new Set(fwdHGB.slice(0, 12).map(p => p.player_id));

// ── Bar chart (shots/60) ─────────────────────────────────────────────────────
const fwdShots = loadTopForwardsShots60(20);
const allFwds = allPlayers.filter(p => p.pos_group === 'F' && p.gp >= 20);

// Empty-array math guards (P2 LOW fix — SITE-FIX-03).
// `Math.min/max(...[])` returns ±Infinity, which breaks downstream math
// (division, SVG coords, toFixed). Also `sum/length` on an empty array is NaN.
// Helpers fall back to caller-supplied defaults when arr is empty.
const hasFwds = allFwds.length > 0;
function safeMin(vals: number[], fallback = 0): number {
  return vals.length ? Math.min(...vals) : fallback;
}
function safeMax(vals: number[], fallback = 0): number {
  return vals.length ? Math.max(...vals) : fallback;
}
function safeAvg(vals: number[], fallback = 0): number {
  return vals.length ? vals.reduce((s, v) => s + v, 0) / vals.length : fallback;
}

const shotsMax = fwdShots[0]?.value ?? 16;
const shotsAvg = safeAvg(allFwds.map(p => p.rates_per_60.shots));
const avgBarPct = ((shotsAvg / shotsMax) * 100).toFixed(1);

// ── Scatter (xG/60 × finishing) ──────────────────────────────────────────────
// All four extrema now safe: empty allFwds → 0-1 range, zero dots rendered,
// empty-state markup below replaces the chart.
const ixgVals      = allFwds.map(p => p.rates_per_60.ixg);
const finishVals   = allFwds.map(p => p.rates_per_60.finishing);
const xMin = Math.max(0, safeMin(ixgVals) * 0.85);
const xMax = Math.max(safeMax(ixgVals) * 1.04, xMin + 0.01); // guard zero-width range
const yAbsMax = Math.max(
  Math.abs(safeMin(finishVals)),
  Math.abs(safeMax(finishVals))
) * 1.04 || 1; // guard zero-range → default ±1
const yMin = -yAbsMax, yMax = yAbsMax;
const xAvg = safeAvg(ixgVals);

const PL = 40, PR = 572, PT = 12, PB = 356;
const PW = PR - PL, PH = PB - PT;
function toX(v: number): number { return PL + (v - xMin) / (xMax - xMin) * PW; }
function toY(v: number): number { return PB - (v - yMin) / (yMax - yMin) * PH; }
const xAvgSvg = toX(xAvg).toFixed(1);
const yMidSvg = toY(0).toFixed(1);

// Scatter: tier classification (top12 by HGBScore = elite, 13-50 = mid, rest = dim)
const hgbRankMap = new Map(fwdHGB.map((p, i) => [p.player_id, i]));
const scatterDots = allFwds.map(p => ({
  x: toX(p.rates_per_60.ixg).toFixed(1),
  y: toY(p.rates_per_60.finishing).toFixed(1),
  tc: pickTeamColor(p.team_abbrev),
  tier: top12Ids.has(p.player_id) ? 'elite' : (hgbRankMap.has(p.player_id) ? 'mid' : 'dim'),
  name: p.display_name,
  slug: p.slug,
  rank: hgbRankMap.get(p.player_id) ?? 999,
}));

// Scatter quadrant narratives (real data)
const eliteQ = allFwds
  .filter(p => p.rates_per_60.ixg >= xAvg && p.rates_per_60.finishing >= 0)
  .sort((a, b) => b.rates_per_60.finishing - a.rates_per_60.finishing)
  .slice(0, 4);
const coldQ = allFwds
  .filter(p => p.rates_per_60.ixg >= xAvg && p.rates_per_60.finishing < 0)
  .sort((a, b) => a.rates_per_60.finishing - b.rates_per_60.finishing)
  .slice(0, 3);
const finisherQ = allFwds
  .filter(p => p.rates_per_60.ixg < xAvg && p.rates_per_60.finishing >= 0)
  .sort((a, b) => b.rates_per_60.finishing - a.rates_per_60.finishing)
  .slice(0, 3);

// ── Goals/60 ─────────────────────────────────────────────────────────────────
const goals60 = loadTopGoals60(10);

// ── Helpers ──────────────────────────────────────────────────────────────────
function hexToRgba(hex: string, alpha: number): string {
  const r = parseInt(hex.slice(1,3), 16);
  const g = parseInt(hex.slice(3,5), 16);
  const b = parseInt(hex.slice(5,7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}
function dotColor(pct: number): string {
  return pct >= 90 ? '#00c078' : pct >= 70 ? '#60a5fa' : pct >= 40 ? '#8a8a82' : '#e8002d';
}
function rankStr(n: number): string { return String(n).padStart(2, '0'); }
function fmtToi(sec: number): string {
  const m = Math.floor(sec / 60), s = Math.round(sec % 60);
  return `${m}:${s.toString().padStart(2,'0')}`;
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Leaderboards — HGB Stats — HockeyGameBot</title>
  <meta name="description" content="Top NHL skaters by HGB Rating (RAPM ×60), shots per 60, expected goals, and pure goals per 60. Four angles on the season, all rate-adjusted, minimum 20 games played." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:      #EFEEE8;
      --ink:     #0d0d14;
      --red:     #E8002D;
      --surface: #FFFFFF;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04:  rgba(13,13,20,0.04);
      --ink-06:  rgba(13,13,20,0.06);
      --ink-10:  rgba(13,13,20,0.10);
      --ink-14:  rgba(13,13,20,0.14);
      --ink-20:  rgba(13,13,20,0.20);
      --ink-32:  rgba(13,13,20,0.32);
      --ink-48:  rgba(13,13,20,0.48);
      --ink-72:  rgba(13,13,20,0.72);
      --display: 'Barlow Condensed', sans-serif;
      --body:    'Barlow', sans-serif;
      --mono:    'JetBrains Mono', monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    /* ── Nav ──────────────────────────────────────────────────────────── */
    .nav { background: var(--bg); border-bottom: 1px solid var(--ink-14); position: sticky; top: 0; z-index: 50; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 32px; height: 52px; display: flex; align-items: center; gap: 20px; }
    .wordmark { font-family: var(--display); font-weight: 800; font-size: 20px; letter-spacing: 0.04em; text-transform: uppercase; text-decoration: none; color: var(--ink); display: inline-flex; align-items: center; }
    .wordmark .dot { width: 6px; height: 6px; background: var(--red); border-radius: 50%; margin: 0 6px; display: inline-block; }
    .nav-links { margin-left: auto; display: flex; align-items: center; gap: 0; font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; }
    .nav-links a { padding: 5px 12px; color: var(--ink-48); text-decoration: none; }
    .nav-links a:hover, .nav-links a.active { color: var(--ink); }
    .nav-links .sep { color: var(--ink-20); }

    /* ── Masthead ─────────────────────────────────────────────────────── */
    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px); text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px; }
    .mast-headline em { color: var(--red); font-style: normal; }
    .mast-lede { font-size: 13.5px; line-height: 1.6; color: var(--ink-48); max-width: 640px; }
    .mast-lede .mono { font-family: var(--mono); font-size: 12px; color: var(--ink-72); }

    /* ── Content layout ───────────────────────────────────────────────── */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

    /* ── White surface cards ──────────────────────────────────────────── */
    .card { background: var(--surface); border: 1px solid var(--ink-14); }
    .card-head { padding: 14px 18px 12px; border-bottom: 1px solid var(--ink-06); display: flex; align-items: baseline; justify-content: space-between; }
    .card-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-32); }
    .card-eyebrow .accent { color: var(--red); }
    .card-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* ── Section structure ────────────────────────────────────────────── */
    .lb-sec { padding: 40px 0 0; }
    .lb-sec-h { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 8px; }
    .lb-sec-h h2 { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 26px); color: var(--ink); margin: 0; letter-spacing: 0.01em; text-transform: uppercase; }
    .lb-sec-mode { font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-32); white-space: nowrap; }
    .lb-sec-mode b { color: var(--red); font-weight: 700; }
    .lb-sec-lede { font-size: 13px; color: var(--ink-48); max-width: 780px; line-height: 1.6; margin: 0 0 18px; }
    .lb-sec-lede .mono { font-family: var(--mono); font-size: 11.5px; color: var(--ink-72); }

    /* ── SECTION 1: Ranked list (2-col: fwds + D) ────────────────────── */
    .ranked { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 18px; }
    @media (max-width: 720px) { .ranked { grid-template-columns: 1fr; } }
    .ranked-col { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; }
    .ranked-col-h {
      padding: 12px 14px; display: flex; justify-content: space-between; align-items: center;
      border-bottom: 1px solid var(--ink-06);
      font-family: var(--display); font-weight: 700;
      font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--ink-72);
    }
    .ranked-col-h .tag { color: var(--red); font-size: 10px; letter-spacing: 0.2em; }
    .ranked-col-h .sub { font-family: var(--mono); font-size: 12px; color: var(--ink-32); letter-spacing: 0; text-transform: none; }

    /* Rows — flex: rank | logo | info | value | dot */
    .rc-row {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 14px; position: relative;
      border-bottom: 1px solid var(--ink-06);
      border-left: 3px solid transparent;
      text-decoration: none; color: inherit;
      background: transparent; transition: background 0.1s;
    }
    .rc-row:last-child { border-bottom: none; }
    .rc-row:hover { background: var(--ink-04); }

    /* Top 1-3 highlights */
    .rc-row.top1 { background: var(--ink-04); }
    .rc-row.top1:hover { background: var(--ink-06); }
    .rc-row.top2, .rc-row.top3 { background: var(--ink-04); }
    .rc-row.top2:hover, .rc-row.top3:hover { background: var(--ink-06); }

    .rc-rank {
      font-family: var(--mono); font-size: 11px;
      color: var(--ink-32); min-width: 22px; text-align: right;
      flex-shrink: 0; font-variant-numeric: tabular-nums;
    }
    .rc-row.top1 .rc-rank, .rc-row.top2 .rc-rank, .rc-row.top3 .rc-rank { color: var(--red); font-weight: 700; }
    .rc-logo { width: 20px; height: 20px; object-fit: contain; flex-shrink: 0; opacity: 0.85; }
    .rc-row.top1 .rc-logo, .rc-row.top2 .rc-logo { width: 24px; height: 24px; opacity: 1; }
    .rc-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
    .rc-name {
      font-family: var(--body); font-size: 13px; font-weight: 600;
      color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .rc-row.top1 .rc-name, .rc-row.top2 .rc-name, .rc-row.top3 .rc-name { font-size: 13.5px; }
    .rc-meta {
      font-family: var(--mono); font-size: 10px; font-weight: 400;
      letter-spacing: 0.06em; color: var(--ink-32);
    }
    .rc-val {
      font-family: var(--mono); font-size: 15px; font-weight: 700;
      font-variant-numeric: tabular-nums; color: var(--ink);
      min-width: 38px; text-align: right; flex-shrink: 0;
    }
    .rc-row.top1 .rc-val { font-size: 16px; }
    .rc-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    .ranked-foot {
      padding: 9px 14px; display: flex; justify-content: space-between;
      border-top: 1px solid var(--ink-06);
      font-family: var(--display); font-weight: 700;
      font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--ink-32);
    }
    .ranked-foot a { color: var(--red); text-decoration: none; transition: opacity 0.12s; }
    .ranked-foot a:hover { opacity: 0.7; }

    /* ── SECTION 2: Horizontal bar chart ─────────────────────────────── */
    .barboard { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; margin-top: 18px; }
    .barboard-h {
      padding: 11px 18px; display: flex; justify-content: space-between;
      border-bottom: 1px solid var(--ink-06);
      font-family: var(--display); font-weight: 700;
      font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-72);
    }
    .barboard-h .sub { font-family: var(--mono); font-size: 11px; color: var(--ink-32); letter-spacing: 0; text-transform: none; font-weight: 400; }

    .bar-row {
      display: grid; grid-template-columns: 30px 160px 1fr 76px 52px;
      gap: 14px; align-items: center; padding: 9px 18px;
      border-bottom: 1px solid var(--ink-06); font-size: 13px; position: relative;
    }
    .bar-row:last-child { border-bottom: none; }
    .bar-row:hover { background: var(--ink-04); }
    .bar-row.avg-row {
      border-top: 1px dashed var(--ink-14);
      background: var(--ink-04);
    }

    .bar-rk { font-family: var(--mono); color: var(--ink-32); font-size: 11px; font-variant-numeric: tabular-nums; }
    .bar-row.bar-top .bar-rk { color: var(--red); font-weight: 700; }

    .bar-nm {
      font-family: var(--body); font-weight: 600; font-size: 13.5px;
      color: var(--ink); letter-spacing: 0.015em;
      display: flex; align-items: center; gap: 8px; white-space: nowrap; overflow: hidden;
    }
    .bar-nm .tm {
      font-family: var(--mono); font-weight: 400; color: var(--ink-32);
      font-size: 10px; padding: 1px 5px; border: 1px solid var(--ink-14);
      text-transform: uppercase; letter-spacing: 0.04em; flex-shrink: 0;
    }

    .bar-cell { position: relative; height: 12px; background: var(--ink-06); overflow: visible; }
    .bar-fill { position: absolute; left: 0; top: 0; bottom: 0; border-radius: 0; }

    .bar-avg-tick {
      position: absolute; top: -5px; bottom: -5px; width: 1px;
      background: var(--red); z-index: 2;
    }
    .bar-avg-tick::before {
      content: 'LEAGUE AVG'; position: absolute; top: -14px; left: 4px;
      font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em;
      color: var(--red); white-space: nowrap;
    }
    .bar-v {
      font-family: var(--mono); font-variant-numeric: tabular-nums;
      color: var(--ink); font-weight: 700; font-size: 14px; text-align: right;
    }
    .bar-gp { font-family: var(--mono); color: var(--ink-32); font-size: 10.5px; text-align: right; }

    /* ── SECTION 3: Scatter ──────────────────────────────────────────── */
    .scatter-card { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; margin-top: 18px; }
    .scatter-ch {
      padding: 12px 18px; border-bottom: 1px solid var(--ink-06);
      display: flex; justify-content: space-between; align-items: center;
      font-family: var(--display); font-weight: 700;
      font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-72);
    }
    .scatter-legend { display: flex; gap: 14px; font-family: var(--mono); font-size: 10px; color: var(--ink-32); align-items: center; }
    .scatter-legend .sw { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 5px; vertical-align: -1px; }
    .scatter-grid { display: grid; grid-template-columns: 1fr 280px; }
    @media (max-width: 760px) { .scatter-grid { grid-template-columns: 1fr; } }
    .scatter-plot { position: relative; padding: 8px 10px; }
    .scatter-plot svg { width: 100%; height: auto; display: block; }
    .scatter-side {
      border-left: 1px solid var(--ink-14); padding: 18px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .scatter-side h4 {
      font-family: var(--display); font-weight: 700;
      font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--red); margin: 0 0 8px;
    }
    .scatter-side .note { font-size: 12px; color: var(--ink-48); line-height: 1.55; margin: 0 0 12px; }
    .scatter-side .qhead {
      font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--ink-32);
      padding-bottom: 5px; border-bottom: 1px solid var(--ink-06); margin: 8px 0 4px;
    }
    .scatter-side .qrow {
      display: flex; align-items: baseline; justify-content: space-between;
      padding: 6px 0; border-bottom: 1px solid var(--ink-06); font-size: 12px;
    }
    .scatter-side .qrow:last-child { border-bottom: none; }
    .scatter-side .qk {
      font-family: var(--body); font-weight: 600;
      color: var(--ink); letter-spacing: 0.015em;
    }
    .scatter-side .qk .tm { color: var(--ink-32); font-family: var(--mono); font-size: 10px; margin-left: 6px; font-weight: 400; }
    .scatter-side .qv {
      font-family: var(--mono); font-variant-numeric: tabular-nums;
      color: var(--ink); font-weight: 700; letter-spacing: 0.02em; font-size: 13px;
    }

    /* ── SECTION 4: Goals/60 ranked list ─────────────────────────────── */
    .goals-list { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; margin-top: 18px; }
    /* Reuse rc-row styles for goals list rows */

    /* ── Goalie placeholder ──────────────────────────────────────────── */
    .lb-coming { padding: 32px 0; border-top: 1px solid var(--ink-14); margin-top: 40px; }
    .lb-coming-eyebrow {
      font-family: var(--display); font-size: 11px; font-weight: 700;
      letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-32);
      display: block; margin-bottom: 8px;
    }
    .lb-coming-text { font-size: 13px; color: var(--ink-48); line-height: 1.55; }

    /* ── Methodology (3-col grid) ─────────────────────────────────────── */
    .lb-method { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; margin-top: 40px; }
    .lb-method-h {
      padding: 12px 18px; border-bottom: 1px solid var(--ink-06);
      display: flex; justify-content: space-between; align-items: center;
    }
    .lb-method-h .title {
      font-family: var(--display); font-weight: 700;
      font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-72);
    }
    .lb-method-h .tag { font-family: var(--mono); font-size: 10px; color: var(--ink-32); }
    .lb-method-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
    @media (max-width: 640px) { .lb-method-grid { grid-template-columns: 1fr; } }
    .lb-method-card { padding: 20px; border-right: 1px solid var(--ink-06); }
    .lb-method-card:last-child { border-right: none; }
    .lb-method-card .k {
      font-family: var(--display); font-weight: 700; font-size: 13px;
      color: var(--ink); letter-spacing: 0.02em; text-transform: uppercase;
      margin-bottom: 6px; display: flex; align-items: baseline; justify-content: space-between;
    }
    .badge { font-family: var(--mono); font-size: 10px; padding: 1px 5px; letter-spacing: 0.1em; font-weight: 700; }
    .badge-core { color: var(--red); border: 1px solid rgba(232,0,45,0.4); }
    .badge-coming { color: var(--ink-32); border: 1px solid var(--ink-14); }
    .lb-method-card .v { font-size: 12.5px; color: var(--ink-48); line-height: 1.55; }
    .lb-method-card .v .mono { font-family: var(--mono); font-size: 11px; color: var(--ink-72); }

    /* ── Empty state ──────────────────────────────────────────────────── */
    .lb-empty {
      padding: 40px 18px; text-align: center;
      font-family: var(--body);
      color: var(--ink-48); font-size: 13px; line-height: 1.6;
    }
    .lb-empty strong {
      display: block; margin-bottom: 4px;
      font-family: var(--display); font-weight: 700;
      font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--ink-72);
    }

    /* ── Footer ─────────────────────────────────────────────────────── */
    .lb-footer {
      text-align: center; margin-top: 48px; color: var(--ink-32);
      font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-inner { padding: 0 20px; }
      .mast-inner { padding: 28px 20px; }
      .mast-card { padding: 24px 20px 20px; }
      .mast-headline { font-size: clamp(28px, 6vw, 52px); }
      .wrap { padding: 0 20px 60px; }
      .lb-sec { padding: 28px 0 0; }
      /* Bar chart: give player name column room, overflow the value cols */
      .bar-row { grid-template-columns: 24px 1fr 1fr 56px; gap: 8px; padding: 8px 14px; }
      .bar-gp { display: none; }
      .mast-top { flex-direction: column; align-items: flex-start; gap: 6px; }
    }
    @media (max-width: 640px) {
      /* Bar chart on phone: player name truncates, bar and value stay */
      .bar-row { grid-template-columns: 20px 140px 1fr 48px; gap: 6px; padding: 7px 12px; }
      .bar-nm { font-size: 12px; }
      .bar-nm .tm { display: none; }
      .bar-v { font-size: 13px; }
      /* Scatter: already collapses to 1fr but side panel needs spacing */
      .scatter-side { border-left: none; border-top: 1px solid var(--ink-14); padding: 14px; }
    }
    @media (max-width: 480px) {
      .nav-inner { padding: 0 16px; }
      .mast-inner { padding: 20px 16px; }
      .mast-card { padding: 18px 14px 16px; }
      .mast-headline { font-size: clamp(24px, 7vw, 40px); }
      .wrap { padding: 0 16px 48px; }
      /* Bar chart: very narrow — just rank + name + value */
      .bar-row { grid-template-columns: 18px 1fr 44px; gap: 4px; }
      .bar-cell { display: none; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="wordmark">Hockey<span class="dot"></span>Gamebot</a>
      <nav class="nav-links">
        <a href="/">Home</a><span class="sep"> · </span>
        <a href="/scoreboard">Scoreboard</a><span class="sep"> · </span>
        <a href="/playoffs/2026">Playoffs</a><span class="sep"> · </span>
        <a href="/stats" class="active">Stats</a><span class="sep"> · </span>
        <a href="/teams">Teams</a><span class="sep"> · </span>
        <a href="/support">Support</a><span class="sep"> · </span>
      <a href="/account">Account</a>
      </nav>
    </div>
  </nav>

  <!-- MASTHEAD -->
  <section class="mast">
    <div class="mast-corners">
      <div class="corner tl"></div><div class="corner tr"></div>
      <div class="corner bl"></div><div class="corner br"></div>
    </div>
    <div class="mast-inner">
      <div class="mast-top">
        <div class="mast-eyebrow"><span class="pip"></span> HGB Stats · Leaderboards</div>
        <div>min 20 GP · rate-adjusted · 2025–2026</div>
      </div>
      <div class="mast-card">
        <h1 class="mast-headline">Who's driving<br>play this season.</h1>
        <p class="mast-lede">Four leaderboards, four ways to read the season. <span class="mono">HGB Rating</span> (RAPM ×60) for overall per-position, <span class="mono">shots/60</span> for volume, an <span class="mono">xG&nbsp;&times;&nbsp;finishing</span> scatter for shot quality, and <span class="mono">goals/60</span> for pure scoring rate. All rate-adjusted, minimum 20 GP.</p>
      </div>
    </div>
  </section>

  <main class="wrap">

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 1 — Ranked list · HGB Rating
         ════════════════════════════════════════════════════════════ -->
    <div class="lb-sec">
      <div class="lb-sec-h">
        <h2>Top overall · HGB Rating</h2>
        <span class="lb-sec-mode">Mode · <b>Ranked list</b></span>
      </div>
      <p class="lb-sec-lede">Per-game blend of goals, assists, shots, <span class="mono">xG</span>, and two-way play — scaled so <span class="mono">1.0</span> is a solid full game. Split by position so we're not comparing scorers to 40-minute defensemen.</p>

      <div class="ranked">
        <!-- Forwards -->
        <div class="ranked-col">
          <div class="ranked-col-h">
            <span><span class="card-eyebrow"><span class="accent">HGB Rating</span> · Forwards</span> <span class="tag">TOP 25</span></span>
            <span class="sub">min 20 GP · per 60</span>
          </div>
          {fwdHGB.map((p, i) => {
            const tc = pickTeamColor(p.team_abbrev);
            const cls = i === 0 ? 'top1' : i === 1 ? 'top2' : i === 2 ? 'top3' : '';
            return (
              <a class={`rc-row${cls ? ' ' + cls : ''}`} href={`/stats/player/${p.slug}`}
                 style={`border-left-color:${tc};`}>
                <span class="rc-rank">{rankStr(i + 1)}</span>
                <img class="rc-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="24" height="24" loading="lazy" />
                <div class="rc-info">
                  <span class="rc-name">{p.display_name}</span>
                  <span class="rc-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP</span>
                </div>
                <span class="rc-val" style={`color:${p.value >= 0 ? '#14803c' : 'var(--red)'}`}>{p.value >= 0 ? '+' : ''}{p.value.toFixed(2)}</span>
                <span class="rc-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
              </a>
            );
          })}
          <div class="ranked-foot">
            <span>HGB Rating · {fwdHGB.length} shown</span>
            <a href="/stats/leaderboards/all">View all {allFwds.length} →</a>
          </div>
        </div>

        <!-- Defensemen -->
        <div class="ranked-col">
          <div class="ranked-col-h">
            <span><span class="card-eyebrow"><span class="accent">HGB Rating</span> · Defensemen</span> <span class="tag">TOP 25</span></span>
            <span class="sub">min 20 GP · per 60</span>
          </div>
          {defHGB.map((p, i) => {
            const tc = pickTeamColor(p.team_abbrev);
            const cls = i === 0 ? 'top1' : i === 1 ? 'top2' : i === 2 ? 'top3' : '';
            return (
              <a class={`rc-row${cls ? ' ' + cls : ''}`} href={`/stats/player/${p.slug}`}
                 style={`border-left-color:${tc};`}>
                <span class="rc-rank">{rankStr(i + 1)}</span>
                <img class="rc-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="24" height="24" loading="lazy" />
                <div class="rc-info">
                  <span class="rc-name">{p.display_name}</span>
                  <span class="rc-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP</span>
                </div>
                <span class="rc-val" style={`color:${p.value >= 0 ? '#14803c' : 'var(--red)'}`}>{p.value >= 0 ? '+' : ''}{p.value.toFixed(2)}</span>
                <span class="rc-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
              </a>
            );
          })}
          <div class="ranked-foot">
            <span>Defensemen score lower — that's by design</span>
            <a href="/stats/leaderboards/all">View all →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 2 — Horizontal bars · Shots/60
         ════════════════════════════════════════════════════════════ -->
    <div class="lb-sec">
      <div class="lb-sec-h">
        <h2>Shot generation · shots / 60</h2>
        <span class="lb-sec-mode">Mode · <b>Horizontal bars</b></span>
      </div>
      <p class="lb-sec-lede">Same players, different read. Bars scaled to the top shooter in the league. The <span class="mono">league avg</span> tick shows how far ahead the elite tier sits — ranking hides this gap, bars reveal it.</p>
      <div class="barboard">
        <div class="barboard-h">
          <span><span class="card-eyebrow"><span class="accent">Shots / 60</span> · Forwards</span></span>
          <span class="sub">league avg {shotsAvg.toFixed(1)} · max {shotsMax.toFixed(1)} · n={allFwds.length} fwds</span>
        </div>
        {fwdShots.length === 0 && (
          <div class="lb-empty">
            <strong>No data available</strong>
            No forwards match the current filter (min 20 GP).
          </div>
        )}
        {fwdShots.map((p, i) => {
          const tc = pickTeamColor(p.team_abbrev);
          const barW = ((p.value / shotsMax) * 100).toFixed(1);
          const isTop = i < 3;
          return (
            <a class={`bar-row${i === 0 ? ' bar-top bar-top1' : isTop ? ' bar-top' : ''}`}
               href={`/stats/player/${p.slug}`} style="text-decoration:none; color:inherit; display:grid; grid-template-columns: 30px 160px 1fr 76px 52px; gap:14px; align-items:center; padding:9px 18px; border-bottom:1px solid var(--ink-06);">
              <span class="bar-rk">{rankStr(i + 1)}</span>
              <span class="bar-nm">{p.display_name} <span class="tm">{p.team_abbrev}</span></span>
              <span class="bar-cell">
                <span class="bar-fill" style={`width:${barW}%; background:${tc};`}></span>
                {i === 0 && <span class="bar-avg-tick" style={`left:${avgBarPct}%`}></span>}
              </span>
              <span class="bar-v">{p.value.toFixed(1)}</span>
              <span class="bar-gp">{p.gp} GP</span>
            </a>
          );
        })}
        <!-- League average reference row (only when data present) -->
        {hasFwds && (
          <div class="bar-row avg-row" style="display:grid; grid-template-columns: 30px 160px 1fr 76px 52px; gap:14px; align-items:center; padding:9px 18px;">
            <span class="bar-rk" style="color:var(--ink-32)">AVG</span>
            <span class="bar-nm" style="color:var(--ink-48); font-size:12px;">League avg forward</span>
            <span class="bar-cell"><span class="bar-fill" style={`width:${avgBarPct}%; background:var(--ink-14);`}></span></span>
            <span class="bar-v" style="color:var(--ink-48); font-size:13px;">{shotsAvg.toFixed(1)}</span>
            <span class="bar-gp">—</span>
          </div>
        )}
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 3 — Scatter · xG × Finishing
         ════════════════════════════════════════════════════════════ -->
    <div class="lb-sec">
      <div class="lb-sec-h">
        <h2>Shot quality · xG × finishing</h2>
        <span class="lb-sec-mode">Mode · <b>Scatter plot</b></span>
      </div>
      <p class="lb-sec-lede">Up and right = creates <em>and</em> converts high-quality looks. Upper-left = finishes above expected on low volume. Lower-right = high volume, cold puck. The gap between McDavid and everyone else is not a rounding error.</p>
      <div class="scatter-card">
        <div class="scatter-ch">
          <span><span class="card-eyebrow"><span class="accent">xG × Finishing</span> · Forwards · 20+ GP · n={allFwds.length}</span></span>
          <span class="scatter-legend">
            <span><span class="sw" style="background:var(--red)"></span>Top 12</span>
            <span><span class="sw" style="background:var(--ink-32)"></span>Mid field</span>
            <span><span class="sw" style="background:var(--ink-14)"></span>Rest</span>
          </span>
        </div>
        {!hasFwds && (
          <div class="lb-empty">
            <strong>No data available</strong>
            Scatter plot requires at least one forward meeting the filter (min 20 GP).
          </div>
        )}
        {hasFwds && (
        <div class="scatter-grid">
          <div class="scatter-plot">
            <svg viewBox={`0 0 610 ${PB + 30}`} preserveAspectRatio="none">
              <!-- grid -->
              <defs>
                <pattern id="sg" width="60" height="40" patternUnits="userSpaceOnUse">
                  <path d="M60 0 L0 0 0 40" fill="none" stroke="rgba(13,13,20,0.06)" stroke-width="1"/>
                </pattern>
              </defs>
              <rect x={PL} y={PT} width={PW} height={PH} fill="url(#sg)"/>
              <!-- quadrant dividers at league avg xG and zero finishing -->
              <line x1={xAvgSvg} y1={PT} x2={xAvgSvg} y2={PB} stroke="rgba(13,13,20,0.20)" stroke-dasharray="3 4"/>
              <line x1={PL} y1={yMidSvg} x2={PR} y2={yMidSvg} stroke="rgba(13,13,20,0.20)" stroke-dasharray="3 4"/>
              <!-- axes -->
              <line x1={PL} y1={PB} x2={PR} y2={PB} stroke="rgba(13,13,20,0.20)"/>
              <line x1={PL} y1={PT} x2={PL} y2={PB} stroke="rgba(13,13,20,0.20)"/>
              <!-- quadrant labels -->
              <g font-family="JetBrains Mono, monospace" font-size="8.5" fill="rgba(13,13,20,0.32)" letter-spacing="1.2">
                <text x={Number(xAvgSvg) + 8} y={PT + 16}>ELITE · CREATES &amp; FINISHES</text>
                <text x={PL + 8} y={PT + 16}>CAN'T BUY A GOAL</text>
                <text x={PL + 8} y={PB - 8}>LOW VOLUME · LOW SKILL</text>
                <text x={PR - 8} y={PB - 8} text-anchor="end">HIGH VOLUME · LOW FINISH</text>
              </g>
              <!-- axis labels -->
              <g font-family="JetBrains Mono, monospace" font-size="10" fill="rgba(13,13,20,0.48)" font-weight="600" letter-spacing="1.2">
                <text x={(PL + PR) / 2} y={PB + 22} text-anchor="middle">xG / 60 →</text>
                <text x="16" y={(PT + PB) / 2} text-anchor="middle" transform={`rotate(-90,16,${(PT + PB) / 2})`}>Finishing ΔxG</text>
              </g>
              <!-- dim background field -->
              <g fill="rgba(13,13,20,0.12)">
                {scatterDots.filter(d => d.tier === 'dim').map(d => (
                  <circle cx={d.x} cy={d.y} r="2"/>
                ))}
              </g>
              <!-- mid tier -->
              <g fill="rgba(13,13,20,0.32)">
                {scatterDots.filter(d => d.tier === 'mid').map(d => (
                  <circle cx={d.x} cy={d.y} r="3"/>
                ))}
              </g>
              <!-- elite — team colors -->
              {scatterDots.filter(d => d.tier === 'elite').map(d => (
                <circle cx={d.x} cy={d.y} r={d.rank < 3 ? '6' : d.rank < 6 ? '5' : '4'} fill={d.tc} opacity="0.9"/>
              ))}
              <!-- elite labels (top 6) -->
              <g font-family="Barlow, sans-serif" font-size="10.5" font-weight="600" fill="rgba(13,13,20,0.72)">
                {scatterDots.filter(d => d.tier === 'elite' && d.rank < 6).map(d => (
                  <text x={Number(d.x) + 8} y={Number(d.y) + 4}>{d.name.split(' ')[0][0] + '. ' + d.name.split(' ').slice(1).join(' ')}</text>
                ))}
              </g>
            </svg>
          </div>
          <div class="scatter-side">
            <h4>Story of the quadrants</h4>
            <p class="note">The top-right elite corner is thin for a reason — you need both volume and quality. Volume shooters in the bottom-right are regression candidates: expect their goal numbers to drop.</p>
            <span class="qhead">Top-right · Elite</span>
            {eliteQ.map(p => (
              <div class="qrow">
                <span class="qk">{p.display_name} <span class="tm">{p.team_abbrev}</span></span>
                <span class="qv">{p.rates_per_60.finishing >= 0 ? '+' : ''}{p.rates_per_60.finishing.toFixed(2)}</span>
              </div>
            ))}
            <span class="qhead">Bottom-right · Volume, cold</span>
            {coldQ.map(p => (
              <div class="qrow">
                <span class="qk">{p.display_name} <span class="tm">{p.team_abbrev}</span></span>
                <span class="qv" style="color:var(--red)">{p.rates_per_60.finishing.toFixed(2)}</span>
              </div>
            ))}
            <span class="qhead">Top-left · Finishing on low volume</span>
            {finisherQ.map(p => (
              <div class="qrow">
                <span class="qk">{p.display_name} <span class="tm">{p.team_abbrev}</span></span>
                <span class="qv" style="color:#2563eb">{p.rates_per_60.finishing >= 0 ? '+' : ''}{p.rates_per_60.finishing.toFixed(2)}</span>
              </div>
            ))}
          </div>
        </div>
        )}
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 4 — Goals/60 · Top 10
         ════════════════════════════════════════════════════════════ -->
    <div class="lb-sec">
      <div class="lb-sec-h">
        <h2>Pure scoring · goals / 60</h2>
        <span class="lb-sec-mode">Mode · <b>Ranked list</b></span>
      </div>
      <p class="lb-sec-lede">Goals per 60 minutes, regardless of position or ice time. The rawest scoring-rate leaderboard — partial seasons welcome (min 10 GP). Caufield at the top is not a fluke.</p>
      <div class="goals-list">
        {goals60.length === 0 && (
          <div class="lb-empty">
            <strong>No data available</strong>
            No players match the current filter (min 10 GP).
          </div>
        )}
        <div class="ranked-col-h">
          <span><span class="card-eyebrow"><span class="accent">Goals / 60</span> · All Skaters</span> <span class="tag">TOP 10</span></span>
          <span class="sub">min 10 GP · per 60</span>
        </div>
        {goals60.map((p, i) => {
          const tc = pickTeamColor(p.team_abbrev);
          const cls = i === 0 ? 'top1' : i === 1 ? 'top2' : i === 2 ? 'top3' : '';
          return (
            <a class={`rc-row${cls ? ' ' + cls : ''}`} href={`/stats/player/${p.slug}`}
               style={`border-left-color:${tc};`}>
              <span class="rc-rank">{rankStr(i + 1)}</span>
              <img class="rc-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="24" height="24" loading="lazy" />
              <div class="rc-info">
                <span class="rc-name">{p.display_name}</span>
                <span class="rc-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP · {fmtToi(p.toi_avg_sec)} TOI</span>
              </div>
              <span class="rc-val">{p.value.toFixed(2)}</span>
              <span class="rc-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
            </a>
          );
        })}
        <div class="ranked-foot">
          <span>Goals / 60 min · min 10 GP</span>
          <a href="/stats/leaderboards/all">View full →</a>
        </div>
      </div>
    </div>

    <!-- GOALIE PLACEHOLDER -->
    <div class="lb-coming">
      <span class="lb-coming-eyebrow">Goalie metrics · Coming soon</span>
      <p class="lb-coming-text">GSAx and save-percentile leaderboards pending — goalie pipeline is in development.</p>
    </div>

    <!-- METHODOLOGY (3-col) -->
    <div class="lb-method">
      <div class="lb-method-h">
        <span class="title">How we measure</span>
        <span class="tag">methodology · 2025–2026</span>
      </div>
      <div class="lb-method-grid">
        <div class="lb-method-card">
          <div class="k">HGB Rating <span class="badge badge-core">CORE</span></div>
          <div class="v">Per-game blend of goals, assists, shots, <span class="mono">xG</span>, and two-way play — scaled so <span class="mono">1.0</span> is a solid game. Percentiles vs same position group with 20+ GP.</div>
        </div>
        <div class="lb-method-card">
          <div class="k">Expected goals (xG)</div>
          <div class="v">Probability a shot scores, based on location, angle, shot type, and context. Better signal than raw shot count — Tkachuk getting 16 shots/60 and only 1.44 xG/60 tells the real story.</div>
        </div>
        <div class="lb-method-card">
          <div class="k">RAPM <span class="badge badge-coming">COMING</span></div>
          <div class="v">Isolates a player's true on-ice impact by controlling for linemates and opponents. Ships after the regular season data is complete.</div>
        </div>
      </div>
    </div>

  </main>

  <footer class="lb-footer">HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026 · LEADERBOARD V2</footer>

</body>
</html>
