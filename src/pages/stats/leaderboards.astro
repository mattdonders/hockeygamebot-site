---
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import Table from '../../components/Table.astro';
import { loadPlayers, loadPlayoffLeaderboard } from '../../lib/stats-loader';

const allPlayers = loadPlayers();
const eligible   = allPlayers.filter(p => p.gp >= 20);

const fwdRapm = eligible.filter(p => p.pos_group === 'F').map(p => p.rapm ?? 0).sort((a,b) => a - b);
const defRapm = eligible.filter(p => p.pos_group === 'D').map(p => p.rapm ?? 0).sort((a,b) => a - b);

function warPct(rapm: number | null, group: 'F' | 'D'): number | null {
  if (rapm == null) return null;
  const arr = group === 'F' ? fwdRapm : defRapm;
  let lo = 0, hi = arr.length;
  while (lo < hi) { const mid = (lo + hi) >>> 1; if (arr[mid] <= rapm) lo = mid + 1; else hi = mid; }
  return Math.round((lo / arr.length) * 100);
}

const tableRows = eligible.map(p => {
  const evOff = p.rates_per_60.ev_offence;
  const evDef = p.rates_per_60.ev_defence;
  const xgfTotal = evOff + evDef;
  return {
    slug:     p.slug,
    name:     p.display_name,
    team:     p.team_abbrev,
    pos:      p.pos,
    group:    p.pos_group,
    gp:       p.gp,
    war:      p.rapm != null ? +(p.rapm * (p.toi_avg_sec * p.gp) / 3600 * 0.1).toFixed(2) : null,
    war_p:    warPct(p.rapm, p.pos_group),
    g60:      +p.rates_per_60.goals.toFixed(2),
    g60_p:    Math.round(p.percentiles_vs_pos.goals),
    a60:      +p.rates_per_60.a1.toFixed(2),
    a60_p:    Math.round(p.percentiles_vs_pos.a1),
    x60:      +p.rates_per_60.ixg.toFixed(2),
    x60_p:    Math.round(p.percentiles_vs_pos.ixg),
    fin:      +p.rates_per_60.finishing.toFixed(2),
    fin_p:    Math.round(p.percentiles_vs_pos.finishing),
    imp:      +p.avg_gs_display.toFixed(2),
    imp_p:    Math.round(p.gs_pct),
    xgf_pct:  xgfTotal > 0 ? +(evOff / xgfTotal * 100).toFixed(1) : 50.0,
    xgf60:    +evOff.toFixed(2),
    xga60:    +evDef.toFixed(2),
    sc60:     +(p.rates_per_60.sc_per60 ?? 0).toFixed(2),
    hdc60:    +(p.rates_per_60.hdc_per60 ?? 0).toFixed(2),
    hdc_pct:  +(p.hdc_pct ?? 50).toFixed(1),
    pp_toi:   p.toi_pp_sec_total != null ? +(p.toi_pp_sec_total / p.gp / 60).toFixed(1) : 0,
    pp_g:     p.goals_pp ?? 0,
    pp_xg60:  +(p.rates_per_60.xg_pp_per60 ?? 0).toFixed(2),
  };
});

const playoffGoals   = loadPlayoffLeaderboard('goals');
const playoffAssists = loadPlayoffLeaderboard('assists');
const playoffXg      = loadPlayoffLeaderboard('xg');
const hasPlayoffData = playoffGoals.length > 0;

// SSR initial: situation=all (WAR), pre-sorted by WAR desc, top 50.
const ssrRows = tableRows
  .slice()
  .sort((a, b) => (b.war ?? -Infinity) - (a.war ?? -Infinity))
  .slice(0, 50)
  .map((r, i) => ({ ...r, _rank: i + 1 }));

// Initial column set (situation=all). JS swaps via replaceColumns when sit/gametype changes.
const initialColumns = [
  { key: '_rank', label: '#',      type: 'rank' as const, sortable: false },
  { key: 'name',  label: 'Player', type: 'player' as const, sub: (r: any) => `${r.team} · ${r.pos} · ${r.gp} GP` },
  { key: 'pos',   label: 'Pos',    type: 'position' as const, sortable: true },
  { key: 'gp',    label: 'GP',     type: 'number' as const },
  { key: 'war',   label: 'WAR',    type: 'number' as const, bold: true },
  { key: 'g60',   label: 'G/60',   type: 'number' as const },
  { key: 'a60',   label: 'A1/60',  type: 'number' as const },
  { key: 'x60',   label: 'xG/60',  type: 'number' as const },
  { key: 'fin',   label: 'Fin',    type: 'number' as const },
  { key: 'imp',   label: 'Impact', type: 'number' as const },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Leaderboards — HGB Stats — HockeyGameBot</title>
  <meta name="description" content="All NHL skaters ranked by WAR, Goals/60, xG/60, finishing, and HGB Impact. Sortable table, min 20 GP, 2025–26 season." />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #EFEEE8;
      --ink:      #0d0d14;
      --red:      #E8002D;
      --surface:  #FFFFFF;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04:   rgba(13,13,20,0.04);
      --ink-06:   rgba(13,13,20,0.06);
      --ink-10:   rgba(13,13,20,0.10);
      --ink-14:   rgba(13,13,20,0.14);
      --ink-20:   rgba(13,13,20,0.20);
      --ink-32:   rgba(13,13,20,0.32);
      --ink-48:   rgba(13,13,20,0.48);
      --ink-72:   rgba(13,13,20,0.72);
      --display:  'Barlow Condensed', sans-serif;
      --body:     'Barlow', sans-serif;
      --mono:     'JetBrains Mono', monospace;
      --stats-pos: #166534;
      --stats-neg: #991b1b;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
      margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px);
      text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px; }
    .mast-headline em { color: var(--red); font-style: normal; }
    .mast-lede { font-size: 13.5px; line-height: 1.6; color: var(--ink-48); max-width: 640px; }
    .mast-lede .mono { font-family: var(--mono); font-size: 12px; color: var(--ink-72); }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

    .lb-section { padding: 40px 0 0; }
    .lb-head { display: flex; align-items: center; justify-content: space-between; gap: 16px;
      margin-bottom: 16px; flex-wrap: wrap; }
    .lb-title { font-family: var(--display); font-weight: 800; font-size: 22px;
      text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
    .lb-meta { font-family: var(--mono); font-size: 10.5px; color: var(--ink-32); letter-spacing: 0.06em; }

    .lb-filters { display: flex; align-items: center; gap: 6px; }
    .lb-tab {
      font-family: var(--display); font-weight: 700; font-size: 10.5px;
      letter-spacing: 0.18em; text-transform: uppercase;
      padding: 5px 12px; border: 1px solid var(--ink-14);
      background: transparent; color: var(--ink-48); cursor: pointer; transition: all 0.1s;
    }
    .lb-tab:hover { background: var(--ink-06); color: var(--ink); }
    .lb-tab.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }

    /* Percentile sub-line stack (Advanced) */
    .stat-stack { display: flex; flex-direction: column; align-items: center; gap: 1px; line-height: 1.2; }
    .stat-stack .sp {
      display: block; font-family: var(--mono); font-size: 9px;
      font-variant-numeric: tabular-nums;
    }
    .stat-stack .pe { color: #00c078; }
    .stat-stack .pg { color: #60a5fa; }
    .stat-stack .pa { color: var(--ink-32); }
    .stat-stack .pl { color: var(--red); opacity: 0.65; }
    .stat-stack .nil { color: var(--ink-32); }

    /* Show-all row */
    .lb-more { padding: 14px 18px; border-top: 1px solid var(--ink-06); text-align: center; }
    .lb-more-btn {
      font-family: var(--display); font-weight: 700; font-size: 10.5px;
      letter-spacing: 0.18em; text-transform: uppercase; padding: 7px 20px;
      border: 1px solid var(--ink-14); background: transparent; color: var(--ink-48);
      cursor: pointer; transition: all 0.1s;
    }
    .lb-more-btn:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }

    .lb-method { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; margin-top: 40px; }
    .lb-method-h { padding: 12px 18px; border-bottom: 1px solid var(--ink-06);
      display: flex; justify-content: space-between; align-items: center; }
    .lb-method-h .title { font-family: var(--display); font-weight: 700; font-size: 11px;
      letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-72); }
    .lb-method-h .tag  { font-family: var(--mono); font-size: 10px; color: var(--ink-32); }
    .lb-method-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
    @media (max-width: 640px) { .lb-method-grid { grid-template-columns: 1fr; } }
    .lb-method-card { padding: 20px; border-right: 1px solid var(--ink-06); }
    .lb-method-card:last-child { border-right: none; }
    .lb-method-card .k { font-family: var(--display); font-weight: 700; font-size: 13px;
      color: var(--ink); letter-spacing: 0.02em; text-transform: uppercase;
      margin-bottom: 6px; display: flex; align-items: baseline; justify-content: space-between; }
    .badge { font-family: var(--mono); font-size: 10px; padding: 1px 5px; letter-spacing: 0.1em; font-weight: 700; }
    .badge-core { color: var(--red); border: 1px solid rgba(232,0,45,0.4); }
    .lb-method-card .v { font-size: 12.5px; color: var(--ink-48); line-height: 1.55; }

    .lb-footer { text-align: center; margin-top: 48px; color: var(--ink-32);
      font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }

    @media (max-width: 768px) {
      .mast-inner { padding: 28px 20px; }
      .mast-card  { padding: 24px 20px 20px; }
      .wrap { padding: 0 20px 60px; }
    }
    @media (max-width: 480px) {
      .mast-inner { padding: 20px 16px; }
      .mast-card  { padding: 18px 14px 16px; }
      .wrap { padding: 0 16px 48px; }
    }
  </style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<section class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div class="mast-eyebrow"><span class="pip"></span> HGB Stats · Leaderboards</div>
      <div>min 20 GP · rate-adjusted · 2025–2026</div>
    </div>
    <div class="mast-card">
      <h1 class="mast-headline">Who's driving<br><em>play this season.</em></h1>
      <p class="mast-lede">All {eligible.length} skaters in one table. Sort any column — <span class="mono">WAR</span> for overall impact, <span class="mono">G/60</span> and <span class="mono">xG/60</span> for scoring, <span class="mono">Fin</span> for luck. Percentiles within position group.</p>
    </div>
  </div>
</section>

<main class="wrap">

  <section class="lb-section">
    <div class="lb-head">
      <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
        <span class="lb-title" id="lb-title">Season Leaderboards</span>
        <span class="lb-meta" id="lb-count">{eligible.length} players · 2025–26</span>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px">
        <div class="lb-filters" id="gametype-filter">
          <button class="lb-tab active" data-gametype="2">Regular Season</button>
          <button class="lb-tab" data-gametype="3">Playoffs</button>
        </div>
        <div class="lb-filters" id="sit-filter">
          <button class="lb-tab active" data-sit="all">All Sit</button>
          <button class="lb-tab" data-sit="5v5">5v5</button>
          <button class="lb-tab" data-sit="pp">PP</button>
        </div>
        <div class="lb-filters" id="pos-filter">
          <button class="lb-tab active" data-pos="all">All</button>
          <button class="lb-tab" data-pos="F">Fwds</button>
          <button class="lb-tab" data-pos="D">Def</button>
        </div>
      </div>
    </div>

    <Table
      columns={initialColumns}
      rows={ssrRows}
      rowHref={(r) => `/stats/player/${r.slug}`}
      defaultSort={{ column: 'war', direction: 'desc' }}
      scrollable
      maxHeight={700}
      exportFilename="hgb-leaderboards.png"
      exportTitle="Season Leaderboards"
      ariaLabel="NHL skater leaderboards"
    />
    <div class="lb-more" id="lb-more" style="display:none">
      <button class="lb-more-btn" id="lb-more-btn">Show all players →</button>
    </div>
  </section>

  <div class="lb-method">
    <div class="lb-method-h">
      <span class="title">How we measure</span>
      <span class="tag">methodology · 2025–2026</span>
    </div>
    <div class="lb-method-grid">
      <div class="lb-method-card">
        <div class="k">WAR <span class="badge badge-core">CORE</span></div>
        <div class="v">Wins Above Replacement — RAPM × total 5v5 TOI × 0.1, where RAPM (Regularized Adjusted Plus-Minus) controls for linemates and opponents via ridge regression. Cumulative season value; use for overall impact comparisons.</div>
      </div>
      <div class="lb-method-card">
        <div class="k">Expected goals (xG)</div>
        <div class="v">Probability a shot scores, based on location, angle, shot type, and context. Better signal than raw shot count — Tkachuk getting 16 shots/60 and only 1.44 xG/60 tells the real story.</div>
      </div>
      <div class="lb-method-card">
        <div class="k">Finishing</div>
        <div class="v">Goals/60 minus xG/60 — how much a player over- or under-performs their shot quality. Positive means they're converting at a rate above expected; negative suggests regression risk.</div>
      </div>
    </div>
  </div>

</main>

<footer class="lb-footer">HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026 · LEADERBOARD V3</footer>

<script type="application/json" id="lb-data" set:html={JSON.stringify({
  rows: tableRows,
  poGoals: playoffGoals,
  poAssists: playoffAssists,
  poXg: playoffXg,
  hasPlayoffData,
})}></script>

<script is:inline src="/js/table-export.js"></script>

<script>
(function() {
  'use strict';
  const PAGE = 50;
  const sgn2 = (n) => n >= 0 ? '+' : '';

  const dataEl = document.getElementById('lb-data');
  if (!dataEl) return;
  const payload = JSON.parse(dataEl.textContent || '{}');
  const DATA = payload.rows || [];
  const PO_DATA = {
    goals:   payload.poGoals || [],
    assists: payload.poAssists || [],
    xg:      payload.poXg || [],
  };

  let gameType  = 2;
  let situation = 'all';
  let posFilter = 'all';
  let sortKey   = 'war';
  let showAll   = false;
  let poSortKey = 'goals';

  // ── Situation column definitions ───────────────────────────────────────
  // Each situation tab has its own column set. Each col can be:
  //   - `pctKey`: percentile sub-line key (Advanced view stat-stack)
  //   - `signed`: ±value with threshold color
  //   - `fmt`: value formatter
  const SIT_COLS = {
    all: {
      defaultSort: 'war',
      cols: [
        { label: 'WAR', key: 'war', pctKey: 'war_p', signed: true, bold: true,
          fmt: v => v != null ? sgn2(v) + Number(v).toFixed(2) : '—' },
        { label: 'G/60', key: 'g60', pctKey: 'g60_p', fmt: v => Number(v).toFixed(2) },
        { label: 'A1/60', key: 'a60', pctKey: 'a60_p', fmt: v => Number(v).toFixed(2) },
        { label: 'xG/60', key: 'x60', pctKey: 'x60_p', fmt: v => Number(v).toFixed(2) },
        { label: 'Fin', key: 'fin', pctKey: 'fin_p', signed: true,
          fmt: v => v != null ? sgn2(v) + Number(v).toFixed(2) : '—' },
        { label: 'Impact', key: 'imp', pctKey: 'imp_p', fmt: v => Number(v).toFixed(2) },
      ],
    },
    '5v5': {
      defaultSort: 'xgf_pct',
      cols: [
        { label: 'xGF%', key: 'xgf_pct', bold: true,
          fmt: v => Number(v).toFixed(1) + '%',
          color: v => v >= 55 ? 'var(--stats-pos)' : v <= 45 ? 'var(--stats-neg)' : null },
        { label: 'xGF/60', key: 'xgf60', fmt: v => Number(v).toFixed(2) },
        { label: 'xGA/60', key: 'xga60', fmt: v => Number(v).toFixed(2) },
        { label: 'SC/60', key: 'sc60', fmt: v => Number(v).toFixed(2) },
        { label: 'HDC/60', key: 'hdc60', fmt: v => Number(v).toFixed(2) },
        { label: 'HDC%', key: 'hdc_pct', fmt: v => Number(v).toFixed(1) + '%' },
      ],
    },
    pp: {
      defaultSort: 'pp_xg60',
      cols: [
        { label: 'PP min/gm', key: 'pp_toi', fmt: v => Number(v).toFixed(1) },
        { label: 'PP G', key: 'pp_g' },
        { label: 'PP xG/60', key: 'pp_xg60', bold: true, fmt: v => Number(v).toFixed(2) },
        { label: 'SC/60', key: 'sc60', fmt: v => Number(v).toFixed(2) },
        { label: 'HDC/60', key: 'hdc60', fmt: v => Number(v).toFixed(2) },
      ],
    },
  };

  function readUrl() {
    const p = new URLSearchParams(window.location.search);
    if (p.get('game_type') === '3' || p.get('season') === 'playoff') gameType = 3;
  }
  function updateUrl() {
    const p = new URLSearchParams();
    if (gameType === 3) p.set('game_type', '3');
    const qs = p.toString();
    history.replaceState(null, '', qs ? `?${qs}` : window.location.pathname);
  }

  function pctCls(p) {
    if (p == null) return 'pa';
    return p >= 90 ? 'pe' : p >= 70 ? 'pg' : p >= 40 ? 'pa' : 'pl';
  }
  function ordinal(p) {
    if (p == null) return '—';
    const s = (p % 100 >= 11 && p % 100 <= 13) ? 'th' :
      p % 10 === 1 ? 'st' : p % 10 === 2 ? 'nd' : p % 10 === 3 ? 'rd' : 'th';
    return `${p}${s}`;
  }
  function esc(s) {
    return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  function buildPoUnified() {
    const byId = {};
    for (const r of (PO_DATA.goals || [])) { byId[r.player_id] = { ...r, goals: r.value, assists: null, xg60: null }; }
    for (const r of (PO_DATA.assists || [])) {
      if (byId[r.player_id]) byId[r.player_id].assists = r.value;
      else byId[r.player_id] = { ...r, goals: null, assists: r.value, xg60: null };
    }
    for (const r of (PO_DATA.xg || [])) {
      if (byId[r.player_id]) byId[r.player_id].xg60 = r.value;
      else byId[r.player_id] = { ...r, goals: null, assists: null, xg60: r.value };
    }
    return Object.values(byId);
  }

  function regRowHtml(r, rank, activeCols) {
    const href = `/stats/player/${r.slug}`;
    const teamAbbr = esc(r.team || '');
    const nameEsc = esc(r.name);
    const subText = `${r.team} · ${r.pos} · ${r.gp} GP`;
    const cells = [];
    cells.push(`<td class="tbl-td td-rk align-right">${String(rank).padStart(2, '0')}</td>`);
    cells.push(
      `<td class="tbl-td td-player align-left">` +
      `<div class="td-player-inner">` +
      (teamAbbr ? `<img class="td-logo" src="https://assets.nhle.com/logos/nhl/svg/${teamAbbr}_light.svg" width="22" height="22" alt="${teamAbbr}" loading="lazy" onerror="this.style.display='none'" />` : '') +
      `<div class="td-player-meta">` +
      `<span class="td-name">${nameEsc}</span>` +
      `<span class="td-sub">${esc(subText)}</span>` +
      `</div></div></td>`
    );
    cells.push(`<td class="tbl-td align-center"><span class="pos-badge">${esc(r.pos)}</span></td>`);
    cells.push(`<td class="tbl-td align-center type-number">${r.gp == null ? '—' : String(r.gp)}</td>`);

    for (const c of activeCols) {
      const val = r[c.key];
      const cls = ['tbl-td', 'align-center', 'type-number', c.bold ? 'bold' : ''].filter(Boolean).join(' ');
      let color;
      if (c.signed && val != null) color = val >= 0 ? 'var(--stats-pos)' : 'var(--stats-neg)';
      else if (c.color && val != null) color = c.color(val);
      const style = color ? ` style="color:${color}"` : '';

      let content;
      if (val == null) content = '—';
      else if (c.fmt) content = c.fmt(val);
      else content = String(val);

      if (c.pctKey) {
        const pct = r[c.pctKey];
        const pctLabel = ordinal(pct);
        const pctCol = pctCls(pct);
        content = `<div class="stat-stack"><span>${content}</span><span class="sp ${pctCol}">${pctLabel}</span></div>`;
      }
      cells.push(`<td class="${cls}"${style}>${content}</td>`);
    }

    return `<tr class="tbl-tr clickable" tabindex="0" data-href="${href}" role="link">${cells.join('')}</tr>`;
  }

  function poRowHtml(r, rank) {
    const href = `/stats/player/${r.slug}`;
    const teamAbbr = esc(r.team_abbrev || '');
    const nameEsc = esc(r.display_name);
    const subText = `${r.team_abbrev} · ${r.pos} · ${r.gp} GP`;
    const cells = [];
    cells.push(`<td class="tbl-td td-rk align-right">${String(rank).padStart(2, '0')}</td>`);
    cells.push(
      `<td class="tbl-td td-player align-left">` +
      `<div class="td-player-inner">` +
      (teamAbbr ? `<img class="td-logo" src="https://assets.nhle.com/logos/nhl/svg/${teamAbbr}_light.svg" width="22" height="22" alt="${teamAbbr}" loading="lazy" onerror="this.style.display='none'" />` : '') +
      `<div class="td-player-meta">` +
      `<span class="td-name">${nameEsc}</span>` +
      `<span class="td-sub">${esc(subText)}</span>` +
      `</div></div></td>`
    );
    cells.push(`<td class="tbl-td align-center"><span class="pos-badge">${esc(r.pos)}</span></td>`);
    cells.push(`<td class="tbl-td align-center type-number">${r.gp ?? '—'}</td>`);
    cells.push(`<td class="tbl-td align-center type-number">${r.goals == null ? '—' : String(r.goals)}</td>`);
    cells.push(`<td class="tbl-td align-center type-number">${r.assists == null ? '—' : String(r.assists)}</td>`);
    cells.push(`<td class="tbl-td align-center type-number">${r.xg60 == null ? '—' : Number(r.xg60).toFixed(2)}</td>`);
    return `<tr class="tbl-tr clickable" tabindex="0" data-href="${href}" role="link">${cells.join('')}</tr>`;
  }

  function buildRegSchema(activeCols) {
    const schema = [
      { key: '_rank', label: '#', type: 'rank', sortable: false },
      { key: 'name', label: 'Player', type: 'player', sortable: true },
      { key: 'pos', label: 'Pos', type: 'position', sortable: true },
      { key: 'gp', label: 'GP', type: 'number', sortable: true },
    ];
    for (const c of activeCols) {
      schema.push({ key: c.key, label: c.label, type: 'number', sortable: true, bold: !!c.bold });
    }
    return schema;
  }

  function buildPoSchema() {
    return [
      { key: '_rank', label: '#', type: 'rank', sortable: false },
      { key: 'display_name', label: 'Player', type: 'player', sortable: true },
      { key: 'pos', label: 'Pos', type: 'position', sortable: true },
      { key: 'gp', label: 'GP', type: 'number', sortable: true },
      { key: 'goals', label: 'Goals', type: 'number', sortable: true, bold: true },
      { key: 'assists', label: 'Assists', type: 'number', sortable: true },
      { key: 'xg60', label: 'xG/60', type: 'number', sortable: true },
    ];
  }

  const wrap = document.querySelector('.tbl-wrap[data-tbl-id]');
  if (!wrap) return;
  const tblId = wrap.dataset.tblId;
  const tbody = wrap.querySelector('tbody');

  function render() {
    if (gameType === 3) {
      renderPlayoff();
      return;
    }
    const cfg = SIT_COLS[situation];
    const activeCols = cfg.cols;
    let filtered = DATA.slice();
    if (posFilter !== 'all') filtered = filtered.filter(r => r.group === posFilter);

    filtered.sort((a, b) => {
      const av = a[sortKey] ?? -Infinity;
      const bv = b[sortKey] ?? -Infinity;
      return bv - av;
    });

    const total = filtered.length;
    const visible = showAll ? filtered : filtered.slice(0, PAGE);

    const newSchema = buildRegSchema(activeCols);
    const replacer = window.HGB_Table && window.HGB_Table.replaceColumns;
    if (typeof replacer === 'function') replacer(tblId, newSchema);

    if (visible.length === 0) {
      tbody.innerHTML = `<tr class="tbl-empty"><td colspan="${newSchema.length}">No data</td></tr>`;
    } else {
      tbody.innerHTML = visible.map((r, i) => regRowHtml(r, i + 1, activeCols)).join('');
    }
    wrap.dispatchEvent(new CustomEvent('tbl:rows-changed'));

    document.getElementById('lb-count').textContent = `${total} players · 2025–26`;
    document.getElementById('lb-title').textContent = 'Season Leaderboards';

    const moreDiv = document.getElementById('lb-more');
    const moreBtn = document.getElementById('lb-more-btn');
    if (!showAll && total > PAGE) {
      moreDiv.style.display = '';
      moreBtn.textContent = `Show all ${total} players →`;
    } else {
      moreDiv.style.display = 'none';
    }
  }

  function renderPlayoff() {
    const unified = buildPoUnified();
    const sortField = poSortKey === 'goals' ? 'goals' : poSortKey === 'assists' ? 'assists' : 'xg60';
    unified.sort((a, b) => (b[sortField] ?? -Infinity) - (a[sortField] ?? -Infinity));

    const newSchema = buildPoSchema();
    const replacer = window.HGB_Table && window.HGB_Table.replaceColumns;
    if (typeof replacer === 'function') replacer(tblId, newSchema);

    if (unified.length === 0) {
      tbody.innerHTML = `<tr class="tbl-empty"><td colspan="${newSchema.length}">Playoff data available once postseason begins</td></tr>`;
    } else {
      tbody.innerHTML = unified.map((r, i) => poRowHtml(r, i + 1)).join('');
    }
    wrap.dispatchEvent(new CustomEvent('tbl:rows-changed'));

    document.getElementById('lb-title').textContent = 'Playoff Leaderboards';
    document.getElementById('lb-count').textContent = unified.length > 0
      ? `${unified.length} players · 2025–26 playoffs`
      : 'No playoff data yet';
    document.getElementById('lb-more').style.display = 'none';
  }

  function syncGameType() {
    const isPlayoff = gameType === 3;
    document.getElementById('sit-filter').style.display = isPlayoff ? 'none' : '';
    document.getElementById('pos-filter').style.display = isPlayoff ? 'none' : '';
    document.querySelectorAll('#gametype-filter .lb-tab').forEach(btn => {
      btn.classList.toggle('active', parseInt(btn.dataset.gametype) === gameType);
    });
  }

  document.querySelectorAll('[data-sit]').forEach(btn => {
    btn.addEventListener('click', () => {
      situation = btn.dataset.sit;
      sortKey = SIT_COLS[situation].defaultSort;
      showAll = false;
      document.querySelectorAll('[data-sit]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      render();
    });
  });
  document.querySelectorAll('[data-pos]').forEach(btn => {
    btn.addEventListener('click', () => {
      posFilter = btn.dataset.pos;
      showAll = false;
      document.querySelectorAll('[data-pos]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      render();
    });
  });
  document.getElementById('lb-more-btn')?.addEventListener('click', () => {
    showAll = true;
    render();
  });
  document.querySelectorAll('#gametype-filter .lb-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const gt = parseInt(btn.dataset.gametype);
      if (gt === gameType) return;
      gameType = gt;
      updateUrl();
      syncGameType();
      render();
    });
  });

  readUrl();
  syncGameType();
  render();
})();
</script>

</body>
</html>
