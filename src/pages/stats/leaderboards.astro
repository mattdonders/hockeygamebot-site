---
import '../../styles/stats-tokens.css';
import PageHeader from '../../components/stats/PageHeader.astro';
import {
  loadPlayers,
  loadTopForwardsHGBScore,
  loadTopDefensemenHGBScore,
  loadTopForwardsShots60,
  loadTopGoals60,
} from '../../lib/stats-loader';
import { pickTeamColor } from '../../lib/team-colors';

// ── Ranked list ──────────────────────────────────────────────────────────────
const fwdHGB = loadTopForwardsHGBScore(25);
const defHGB = loadTopDefensemenHGBScore(25);
const top12Ids = new Set(fwdHGB.slice(0, 12).map(p => p.player_id));

// ── Bar chart (shots/60) ─────────────────────────────────────────────────────
const fwdShots = loadTopForwardsShots60(20);
const allPlayers = loadPlayers();
const allFwds = allPlayers.filter(p => p.pos_group === 'F' && p.gp >= 20);
const shotsMax = fwdShots[0]?.value ?? 16;
const shotsAvg = allFwds.reduce((s, p) => s + p.rates_per_60.shots, 0) / allFwds.length;
const avgBarPct = ((shotsAvg / shotsMax) * 100).toFixed(1);

// ── Scatter (xG/60 × finishing) ──────────────────────────────────────────────
const xMin = Math.max(0, Math.min(...allFwds.map(p => p.rates_per_60.ixg)) * 0.85);
const xMax = Math.max(...allFwds.map(p => p.rates_per_60.ixg)) * 1.04;
const yAbsMax = Math.max(
  Math.abs(Math.min(...allFwds.map(p => p.rates_per_60.finishing))),
  Math.abs(Math.max(...allFwds.map(p => p.rates_per_60.finishing)))
) * 1.04;
const yMin = -yAbsMax, yMax = yAbsMax;
const xAvg = allFwds.reduce((s, p) => s + p.rates_per_60.ixg, 0) / allFwds.length;

const PL = 40, PR = 572, PT = 12, PB = 356;
const PW = PR - PL, PH = PB - PT;
function toX(v: number): number { return PL + (v - xMin) / (xMax - xMin) * PW; }
function toY(v: number): number { return PB - (v - yMin) / (yMax - yMin) * PH; }
const xAvgSvg = toX(xAvg).toFixed(1);
const yMidSvg = toY(0).toFixed(1);

// Scatter: tier classification (top12 by HGBScore = elite, 13-50 = mid, rest = dim)
const hgbRankMap = new Map(fwdHGB.map((p, i) => [p.player_id, i]));
const scatterDots = allFwds.map(p => ({
  x: toX(p.rates_per_60.ixg).toFixed(1),
  y: toY(p.rates_per_60.finishing).toFixed(1),
  tc: pickTeamColor(p.team_abbrev),
  tier: top12Ids.has(p.player_id) ? 'elite' : (hgbRankMap.has(p.player_id) ? 'mid' : 'dim'),
  name: p.display_name,
  slug: p.slug,
  rank: hgbRankMap.get(p.player_id) ?? 999,
}));

// Scatter quadrant narratives (real data)
const eliteQ = allFwds
  .filter(p => p.rates_per_60.ixg >= xAvg && p.rates_per_60.finishing >= 0)
  .sort((a, b) => b.rates_per_60.finishing - a.rates_per_60.finishing)
  .slice(0, 4);
const coldQ = allFwds
  .filter(p => p.rates_per_60.ixg >= xAvg && p.rates_per_60.finishing < 0)
  .sort((a, b) => a.rates_per_60.finishing - b.rates_per_60.finishing)
  .slice(0, 3);
const finisherQ = allFwds
  .filter(p => p.rates_per_60.ixg < xAvg && p.rates_per_60.finishing >= 0)
  .sort((a, b) => b.rates_per_60.finishing - a.rates_per_60.finishing)
  .slice(0, 3);

// ── Goals/60 ─────────────────────────────────────────────────────────────────
const goals60 = loadTopGoals60(10);

// ── Helpers ──────────────────────────────────────────────────────────────────
function hexToRgba(hex: string, alpha: number): string {
  const r = parseInt(hex.slice(1,3), 16);
  const g = parseInt(hex.slice(3,5), 16);
  const b = parseInt(hex.slice(5,7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}
function dotColor(pct: number): string {
  return pct >= 90 ? '#00c078' : pct >= 70 ? '#60a5fa' : pct >= 40 ? '#8a8a82' : '#e8002d';
}
function rankStr(n: number): string { return String(n).padStart(2, '0'); }
function fmtToi(sec: number): string {
  const m = Math.floor(sec / 60), s = Math.round(sec % 60);
  return `${m}:${s.toString().padStart(2,'0')}`;
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Anti-FOUC -->
  <script is:inline>
    (function(){
      try {
        var s = localStorage.getItem('hgb-mode');
        var sys = window.matchMedia('(prefers-color-scheme:light)').matches ? 'light' : 'dark';
        document.documentElement.dataset.mode = s || sys;
      } catch(_) { document.documentElement.dataset.mode = 'dark'; }
    })();
  </script>
  <meta name="color-scheme" content="light dark">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Leaderboards — HGB Stats</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { min-height: 100vh; -webkit-font-smoothing: antialiased; }
    body { background: var(--site-bg); color: var(--site-white); font-family: var(--font-site-body); }

    /* ── Shell ──────────────────────────────────────────────────────── */
    .lb-main { max-width: 1120px; margin: 0 auto; padding: 0 24px 80px; }

    /* ── Breadcrumb ─────────────────────────────────────────────────── */
    .lb-crumb { padding: 18px 0 0; }
    .lb-crumb a {
      font-family: var(--font-card-display); font-size: 11px; font-weight: 700;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--site-muted); text-decoration: none; transition: color 0.12s;
    }
    .lb-crumb a:hover { color: var(--site-white); }
    .lb-crumb .sep { color: var(--site-border2); padding: 0 8px; }
    .lb-crumb .cur { color: var(--hgb-red); }

    /* ── Hero ───────────────────────────────────────────────────────── */
    .lb-hero {
      padding: 20px 0 28px; border-bottom: 1px solid var(--site-border);
      margin-bottom: 0;
    }
    .lb-hero h1 {
      font-family: var(--font-card-display); font-weight: 800;
      font-size: clamp(36px, 5.5vw, 64px); line-height: 1.0;
      letter-spacing: -0.005em; color: var(--site-white);
      text-transform: uppercase; margin: 0 0 14px;
    }
    .lb-hero h1 .em { color: var(--hgb-red); }
    .lb-hero .lede { font-size: 13.5px; line-height: 1.6; color: var(--site-muted); max-width: 640px; }
    .lb-hero .lede .mono { font-family: var(--font-mono); font-size: 12px; color: var(--site-text); }

    /* ── Section header system (from Claude Design) ──────────────────── */
    .lb-sec { padding: 40px 0 0; }
    .lb-sec-h {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 24px; margin-bottom: 8px;
    }
    .lb-sec-h h2 {
      font-family: var(--font-card-display); font-weight: 800;
      font-size: clamp(20px, 2.5vw, 26px); color: var(--site-white);
      margin: 0; letter-spacing: 0.01em; text-transform: uppercase;
    }
    .lb-sec-mode {
      font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--site-muted); white-space: nowrap;
    }
    .lb-sec-mode b { color: var(--hgb-red); font-weight: 700; }
    .lb-sec-lede {
      font-size: 13px; color: var(--site-muted); max-width: 780px;
      line-height: 1.6; margin: 0 0 18px;
    }
    .lb-sec-lede .mono { font-family: var(--font-mono); font-size: 11.5px; color: var(--site-text); }

    /* ── SECTION 1: Ranked list (2-col: fwds + D) ────────────────────── */
    .ranked { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 18px; }
    @media (max-width: 720px) { .ranked { grid-template-columns: 1fr; } }
    .ranked-col {
      background: var(--site-card); border: 1px solid var(--site-border);
      border-radius: var(--radius-md); overflow: hidden;
    }
    .ranked-col-h {
      padding: 12px 14px; display: flex; justify-content: space-between; align-items: center;
      border-bottom: 1px solid var(--site-border);
      font-family: var(--font-card-display); font-weight: 700;
      font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--site-text);
    }
    .ranked-col-h .tag { color: var(--hgb-red); font-size: 10px; letter-spacing: 0.2em; }
    .ranked-col-h .sub { font-family: var(--font-mono); font-size: 9.5px; color: var(--site-muted); letter-spacing: 0; text-transform: none; }

    /* Rows — flex: rank | logo | info | value | dot */
    .rc-row {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 14px; position: relative;
      border-bottom: 1px solid var(--site-border);
      border-left: 3px solid transparent;
      text-decoration: none; color: inherit;
      background: transparent; transition: background 0.1s;
    }
    .rc-row:last-child { border-bottom: none; }
    .rc-row:hover { background: rgba(255,255,255,0.04); }
    [data-mode="light"] .rc-row:hover { background: rgba(13,13,20,0.04); }

    /* Top-1 red gradient treatment (Claude Design) */
    .rc-row.top1 {
      background: linear-gradient(90deg, rgba(232,0,45,0.07), transparent 65%);
    }
    .rc-row.top1:hover { background: linear-gradient(90deg, rgba(232,0,45,0.11), transparent 65%); }
    [data-mode="light"] .rc-row.top1 { background: linear-gradient(90deg, rgba(232,0,45,0.05), transparent 65%); }

    /* Top 2-3 tinted */
    .rc-row.top2, .rc-row.top3 { background: var(--row-tint, transparent); }
    .rc-row.top2:hover, .rc-row.top3:hover { background: rgba(255,255,255,0.04); }

    .rc-rank {
      font-family: var(--font-mono); font-size: 11px;
      color: var(--site-muted); min-width: 22px; text-align: right;
      flex-shrink: 0; font-variant-numeric: tabular-nums;
    }
    .rc-row.top1 .rc-rank, .rc-row.top2 .rc-rank, .rc-row.top3 .rc-rank {
      color: var(--hgb-red); font-weight: 700;
    }
    .rc-logo { width: 20px; height: 20px; object-fit: contain; flex-shrink: 0; opacity: 0.85; }
    .rc-row.top1 .rc-logo, .rc-row.top2 .rc-logo { width: 24px; height: 24px; opacity: 1; }
    .rc-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
    .rc-name {
      font-family: var(--font-site-body); font-size: 13px; font-weight: 600;
      color: var(--site-white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .rc-row.top1 .rc-name, .rc-row.top2 .rc-name, .rc-row.top3 .rc-name { color: #fff; font-size: 13.5px; }
    .rc-meta {
      font-family: var(--font-card-display); font-size: 10px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--site-muted);
    }
    .rc-val {
      font-family: var(--font-site-display); font-size: 15px; font-weight: 700;
      font-variant-numeric: tabular-nums; color: var(--site-white);
      min-width: 38px; text-align: right; flex-shrink: 0;
    }
    .rc-row.top1 .rc-val { color: #00e676; font-size: 16px; }
    [data-mode="light"] .rc-row.top1 .rc-val { color: var(--hgb-red); }
    .rc-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    .ranked-foot {
      padding: 9px 14px; display: flex; justify-content: space-between;
      border-top: 1px solid var(--site-border);
      font-family: var(--font-card-display); font-weight: 700;
      font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--site-muted);
    }
    .ranked-foot a { color: var(--hgb-red); text-decoration: none; transition: opacity 0.12s; }
    .ranked-foot a:hover { opacity: 0.7; }

    /* ── SECTION 2: Horizontal bar chart ─────────────────────────────── */
    .barboard {
      background: var(--site-card); border: 1px solid var(--site-border);
      border-radius: var(--radius-md); overflow: hidden; margin-top: 18px;
    }
    .barboard-h {
      padding: 11px 18px; display: flex; justify-content: space-between;
      border-bottom: 1px solid var(--site-border);
      font-family: var(--font-card-display); font-weight: 700;
      font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--site-text);
    }
    .barboard-h .sub { font-family: var(--font-mono); font-size: 9.5px; color: var(--site-muted); letter-spacing: 0; text-transform: none; }

    .bar-row {
      display: grid; grid-template-columns: 30px 160px 1fr 76px 52px;
      gap: 14px; align-items: center; padding: 9px 18px;
      border-bottom: 1px solid var(--site-border); font-size: 13px; position: relative;
    }
    .bar-row:last-child { border-bottom: none; }
    .bar-row:hover { background: rgba(255,255,255,0.03); }
    [data-mode="light"] .bar-row:hover { background: rgba(13,13,20,0.03); }
    .bar-row.avg-row {
      border-top: 1px dashed var(--site-border2); background: rgba(255,255,255,0.01);
    }
    [data-mode="light"] .bar-row.avg-row { background: rgba(13,13,20,0.02); }

    .bar-rk { font-family: var(--font-mono); color: var(--site-muted); font-size: 11px; font-variant-numeric: tabular-nums; }
    .bar-row.bar-top .bar-rk { color: var(--hgb-red); font-weight: 700; }

    .bar-nm {
      font-family: var(--font-card-display); font-weight: 700; font-size: 13.5px;
      color: var(--site-white); letter-spacing: 0.015em;
      display: flex; align-items: center; gap: 8px; white-space: nowrap; overflow: hidden;
    }
    .bar-nm .tm {
      font-family: var(--font-mono); font-weight: 400; color: var(--site-muted);
      font-size: 10px; padding: 1px 5px; border: 1px solid var(--site-border);
      border-radius: var(--radius-sm); text-transform: uppercase; letter-spacing: 0.04em;
      flex-shrink: 0;
    }

    .bar-cell { position: relative; height: 12px; background: var(--site-border); border-radius: 1px; overflow: visible; }
    .bar-fill { position: absolute; left: 0; top: 0; bottom: 0; background: #16a34a; border-radius: 1px; }
    .bar-row.bar-top1 .bar-fill { background: linear-gradient(90deg, #00e676, #16a34a); }
    .bar-row.bar-top1 .bar-fill::after {
      content: ''; position: absolute; right: -1px; top: -6px; bottom: -6px;
      width: 2px; background: #00e676; box-shadow: 0 0 8px rgba(0,230,118,0.7);
    }
    [data-mode="light"] .bar-fill { background: #00874e; }
    [data-mode="light"] .bar-row.bar-top1 .bar-fill { background: linear-gradient(90deg, #00a860, #00874e); }
    [data-mode="light"] .bar-row.bar-top1 .bar-fill::after { display: none; }

    .bar-avg-tick {
      position: absolute; top: -5px; bottom: -5px; width: 1px;
      background: rgba(255,255,255,0.25); z-index: 2;
    }
    [data-mode="light"] .bar-avg-tick { background: rgba(13,13,20,0.25); }
    .bar-avg-tick::before {
      content: 'LEAGUE AVG'; position: absolute; top: -14px; left: 4px;
      font-family: var(--font-mono); font-size: 7.5px; letter-spacing: 0.1em;
      color: var(--site-muted); white-space: nowrap;
    }
    .bar-v {
      font-family: var(--font-site-display); font-variant-numeric: tabular-nums;
      color: var(--site-white); font-weight: 700; font-size: 14px; text-align: right;
    }
    .bar-gp { font-family: var(--font-mono); color: var(--site-muted); font-size: 10.5px; text-align: right; }

    /* ── SECTION 3: Scatter ──────────────────────────────────────────── */
    .scatter-card {
      background: var(--site-card); border: 1px solid var(--site-border);
      border-radius: var(--radius-md); overflow: hidden; margin-top: 18px;
    }
    .scatter-ch {
      padding: 12px 18px; border-bottom: 1px solid var(--site-border);
      display: flex; justify-content: space-between; align-items: center;
      font-family: var(--font-card-display); font-weight: 700;
      font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--site-text);
    }
    .scatter-legend { display: flex; gap: 14px; font-family: var(--font-mono); font-size: 10px; color: var(--site-muted); align-items: center; }
    .scatter-legend .sw { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 5px; vertical-align: -1px; }
    .scatter-grid { display: grid; grid-template-columns: 1fr 280px; }
    @media (max-width: 760px) { .scatter-grid { grid-template-columns: 1fr; } }
    .scatter-plot { position: relative; padding: 8px 10px; }
    .scatter-plot svg { width: 100%; height: auto; display: block; }
    .scatter-side {
      border-left: 1px solid var(--site-border); padding: 18px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .scatter-side h4 {
      font-family: var(--font-card-display); font-weight: 700;
      font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--hgb-red); margin: 0 0 8px;
    }
    .scatter-side .note { font-size: 12px; color: var(--site-muted); line-height: 1.55; margin: 0 0 12px; }
    .scatter-side .qhead {
      font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--site-muted);
      padding-bottom: 5px; border-bottom: 1px solid var(--site-border); margin: 8px 0 4px;
    }
    .scatter-side .qrow {
      display: flex; align-items: baseline; justify-content: space-between;
      padding: 6px 0; border-bottom: 1px solid var(--site-border); font-size: 12px;
    }
    .scatter-side .qrow:last-child { border-bottom: none; }
    .scatter-side .qk {
      font-family: var(--font-card-display); font-weight: 600;
      color: var(--site-white); letter-spacing: 0.015em;
    }
    .scatter-side .qk .tm { color: var(--site-muted); font-family: var(--font-mono); font-size: 10px; margin-left: 6px; font-weight: 400; }
    .scatter-side .qv {
      font-family: var(--font-site-display); font-variant-numeric: tabular-nums;
      color: var(--site-white); font-weight: 700; letter-spacing: 0.02em; font-size: 13px;
    }

    /* ── SECTION 4: Goals/60 ranked list ─────────────────────────────── */
    .goals-list {
      background: var(--site-card); border: 1px solid var(--site-border);
      border-radius: var(--radius-md); overflow: hidden; margin-top: 18px;
    }
    /* Reuse rc-row styles for goals list rows */

    /* ── Goalie placeholder ──────────────────────────────────────────── */
    .lb-coming { padding: 32px 0; border-top: 1px solid var(--site-border); margin-top: 40px; }
    .lb-coming-eyebrow {
      font-family: var(--font-site-body); font-size: 11px; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase; color: var(--site-muted);
      display: block; margin-bottom: 8px;
    }
    .lb-coming-text { font-size: 13px; color: var(--site-muted); line-height: 1.55; }

    /* ── Methodology (3-col grid from Claude Design) ─────────────────── */
    .lb-method {
      background: var(--site-card); border: 1px solid var(--site-border);
      border-radius: var(--radius-md); overflow: hidden; margin-top: 40px;
    }
    .lb-method-h {
      padding: 12px 18px; border-bottom: 1px solid var(--site-border);
      display: flex; justify-content: space-between; align-items: center;
    }
    .lb-method-h .title {
      font-family: var(--font-card-display); font-weight: 700;
      font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--site-text);
    }
    .lb-method-h .tag { font-family: var(--font-mono); font-size: 10px; color: var(--site-muted); }
    .lb-method-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
    @media (max-width: 640px) { .lb-method-grid { grid-template-columns: 1fr; } }
    .lb-method-card {
      padding: 20px 20px; border-right: 1px solid var(--site-border);
    }
    .lb-method-card:last-child { border-right: none; }
    .lb-method-card .k {
      font-family: var(--font-card-display); font-weight: 700; font-size: 13px;
      color: var(--site-white); letter-spacing: 0.02em; text-transform: uppercase;
      margin-bottom: 6px; display: flex; align-items: baseline; justify-content: space-between;
    }
    .lb-method-card .badge {
      font-family: var(--font-mono); font-size: 9px; padding: 1px 5px;
      border-radius: var(--radius-sm); letter-spacing: 0.1em; font-weight: 700;
    }
    .badge-core { color: var(--hgb-red); border: 1px solid rgba(232,0,45,0.4); }
    .badge-coming { color: var(--site-muted); border: 1px solid var(--site-border2); }
    .lb-method-card .v { font-size: 12.5px; color: var(--site-muted); line-height: 1.55; }
    .lb-method-card .v .mono { font-family: var(--font-mono); font-size: 11px; color: var(--site-text); }

    /* ── Footer ─────────────────────────────────────────────────────── */
    .lb-footer {
      text-align: center; margin-top: 48px; color: var(--site-border2);
      font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    }
  </style>
</head>
<body>
  <PageHeader activePage="stats" />

  <main class="lb-main">

    <!-- BREADCRUMB -->
    <nav class="lb-crumb">
      <a href="/stats">Stats</a>
      <span class="sep">/</span>
      <span class="cur">Leaderboards</span>
    </nav>

    <!-- HERO -->
    <section class="lb-hero">
      <h1>Who's driving<br>play this season.</h1>
      <p class="lede">Four leaderboards, four ways to read the season. <span class="mono">HGBScore v2</span> for overall per-position, <span class="mono">shots/60</span> for volume, an <span class="mono">xG × finishing</span> scatter for shot quality, and <span class="mono">goals/60</span> for pure scoring rate. All rate-adjusted, minimum 20 GP.</p>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 1 — Ranked list · HGBScore V2
         ════════════════════════════════════════════════════════════ -->
    <div class="lb-sec">
      <div class="lb-sec-h">
        <h2>Top overall · HGBScore V2</h2>
        <span class="lb-sec-mode">Mode · <b>Ranked list</b></span>
      </div>
      <p class="lb-sec-lede">Per-game blend of goals, assists, shots, <span class="mono">xG</span>, and two-way play — scaled so <span class="mono">1.0</span> is a solid full game. Split by position so we're not comparing scorers to 40-minute defensemen.</p>

      <div class="ranked">
        <!-- Forwards -->
        <div class="ranked-col">
          <div class="ranked-col-h">
            <span>Forwards <span class="tag">· TOP 25</span></span>
            <span class="sub">min 20 GP · per 60</span>
          </div>
          {fwdHGB.map((p, i) => {
            const tc = pickTeamColor(p.team_abbrev);
            const cls = i === 0 ? 'top1' : i === 1 ? 'top2' : i === 2 ? 'top3' : '';
            const tintStyle = (i === 1 || i === 2) ? `--row-tint:${hexToRgba(tc, 0.06)};` : '';
            return (
              <a class={`rc-row${cls ? ' ' + cls : ''}`} href={`/stats/player/${p.slug}`}
                 style={`border-left-color:${tc};${tintStyle}`}>
                <span class="rc-rank">{rankStr(i + 1)}</span>
                <img class="rc-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="24" height="24" loading="lazy" />
                <div class="rc-info">
                  <span class="rc-name">{p.display_name}</span>
                  <span class="rc-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP</span>
                </div>
                <span class="rc-val">{p.value.toFixed(2)}</span>
                <span class="rc-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
              </a>
            );
          })}
          <div class="ranked-foot">
            <span>HGBScore V2 · {fwdHGB.length} shown</span>
            <a href="/stats/leaderboards/all">View all {allFwds.length} →</a>
          </div>
        </div>

        <!-- Defensemen -->
        <div class="ranked-col">
          <div class="ranked-col-h">
            <span>Defensemen <span class="tag">· TOP 25</span></span>
            <span class="sub">min 20 GP · per 60</span>
          </div>
          {defHGB.map((p, i) => {
            const tc = pickTeamColor(p.team_abbrev);
            const cls = i === 0 ? 'top1' : i === 1 ? 'top2' : i === 2 ? 'top3' : '';
            const tintStyle = (i === 1 || i === 2) ? `--row-tint:${hexToRgba(tc, 0.06)};` : '';
            return (
              <a class={`rc-row${cls ? ' ' + cls : ''}`} href={`/stats/player/${p.slug}`}
                 style={`border-left-color:${tc};${tintStyle}`}>
                <span class="rc-rank">{rankStr(i + 1)}</span>
                <img class="rc-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="24" height="24" loading="lazy" />
                <div class="rc-info">
                  <span class="rc-name">{p.display_name}</span>
                  <span class="rc-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP</span>
                </div>
                <span class="rc-val">{p.value.toFixed(2)}</span>
                <span class="rc-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
              </a>
            );
          })}
          <div class="ranked-foot">
            <span>Defensemen score lower — that's by design</span>
            <a href="/stats/leaderboards/all">View all →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 2 — Horizontal bars · Shots/60
         ════════════════════════════════════════════════════════════ -->
    <div class="lb-sec">
      <div class="lb-sec-h">
        <h2>Shot generation · shots / 60</h2>
        <span class="lb-sec-mode">Mode · <b>Horizontal bars</b></span>
      </div>
      <p class="lb-sec-lede">Same players, different read. Bars scaled to the top shooter in the league. The <span class="mono">league avg</span> tick shows how far ahead the elite tier sits — ranking hides this gap, bars reveal it.</p>
      <div class="barboard">
        <div class="barboard-h">
          <span>Forwards · Shots / 60</span>
          <span class="sub">league avg {shotsAvg.toFixed(1)} · max {shotsMax.toFixed(1)} · n={allFwds.length} fwds</span>
        </div>
        {fwdShots.map((p, i) => {
          const barW = ((p.value / shotsMax) * 100).toFixed(1);
          const isTop = i < 3;
          return (
            <a class={`bar-row${i === 0 ? ' bar-top bar-top1' : isTop ? ' bar-top' : ''}`}
               href={`/stats/player/${p.slug}`} style="text-decoration:none; color:inherit; display:grid; grid-template-columns: 30px 160px 1fr 76px 52px; gap:14px; align-items:center; padding:9px 18px; border-bottom:1px solid var(--site-border);">
              <span class="bar-rk">{rankStr(i + 1)}</span>
              <span class="bar-nm">{p.display_name} <span class="tm">{p.team_abbrev}</span></span>
              <span class="bar-cell">
                <span class="bar-fill" style={`width:${barW}%`}></span>
                {i === 0 && <span class="bar-avg-tick" style={`left:${avgBarPct}%`}></span>}
              </span>
              <span class="bar-v">{p.value.toFixed(1)}</span>
              <span class="bar-gp">{p.gp} GP</span>
            </a>
          );
        })}
        <!-- League average reference row -->
        <div class="bar-row avg-row" style="display:grid; grid-template-columns: 30px 160px 1fr 76px 52px; gap:14px; align-items:center; padding:9px 18px;">
          <span class="bar-rk" style="color:var(--site-muted)">AVG</span>
          <span class="bar-nm" style="color:var(--site-muted); font-size:12px;">League avg forward</span>
          <span class="bar-cell"><span class="bar-fill" style={`width:${avgBarPct}%; background:var(--site-border2);`}></span></span>
          <span class="bar-v" style="color:var(--site-muted); font-size:13px;">{shotsAvg.toFixed(1)}</span>
          <span class="bar-gp">—</span>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 3 — Scatter · xG × Finishing
         ════════════════════════════════════════════════════════════ -->
    <div class="lb-sec">
      <div class="lb-sec-h">
        <h2>Shot quality · xG × finishing</h2>
        <span class="lb-sec-mode">Mode · <b>Scatter plot</b></span>
      </div>
      <p class="lb-sec-lede">Up and right = creates <em>and</em> converts high-quality looks. Upper-left = finishes above expected on low volume. Lower-right = high volume, cold puck. The gap between McDavid and everyone else is not a rounding error.</p>
      <div class="scatter-card">
        <div class="scatter-ch">
          <span>xG / 60 × Finishing · Forwards · 20+ GP · n={allFwds.length}</span>
          <span class="scatter-legend">
            <span><span class="sw" style="background:var(--hgb-red)"></span>Top 12</span>
            <span><span class="sw" style="background:#9a9a9a"></span>Mid field</span>
            <span><span class="sw" style="background:#2a2a2a"></span>Rest</span>
          </span>
        </div>
        <div class="scatter-grid">
          <div class="scatter-plot">
            <svg viewBox={`0 0 610 ${PB + 30}`} preserveAspectRatio="none">
              <!-- grid -->
              <defs>
                <pattern id="sg" width="60" height="40" patternUnits="userSpaceOnUse">
                  <path d="M60 0 L0 0 0 40" fill="none" stroke="#141414" stroke-width="1"/>
                </pattern>
              </defs>
              <rect x={PL} y={PT} width={PW} height={PH} fill="url(#sg)"/>
              <!-- quadrant dividers at league avg xG and zero finishing -->
              <line x1={xAvgSvg} y1={PT} x2={xAvgSvg} y2={PB} stroke="#2a2a2a" stroke-dasharray="3 4"/>
              <line x1={PL} y1={yMidSvg} x2={PR} y2={yMidSvg} stroke="#2a2a2a" stroke-dasharray="3 4"/>
              <!-- axes -->
              <line x1={PL} y1={PB} x2={PR} y2={PB} stroke="#2a2a2a"/>
              <line x1={PL} y1={PT} x2={PL} y2={PB} stroke="#2a2a2a"/>
              <!-- quadrant labels -->
              <g font-family="JetBrains Mono, monospace" font-size="8.5" fill="#2e2e2e" letter-spacing="1.2">
                <text x={Number(xAvgSvg) + 8} y={PT + 16}>ELITE · CREATES &amp; FINISHES</text>
                <text x={PL + 8} y={PT + 16}>CAN'T BUY A GOAL</text>
                <text x={PL + 8} y={PB - 8}>LOW VOLUME · LOW SKILL</text>
                <text x={PR - 8} y={PB - 8} text-anchor="end">HIGH VOLUME · LOW FINISH</text>
              </g>
              <!-- axis labels -->
              <g font-family="Space Grotesk, sans-serif" font-size="10" fill="#666" font-weight="600" letter-spacing="1.2">
                <text x={(PL + PR) / 2} y={PB + 22} text-anchor="middle">xG / 60 →</text>
                <text x="16" y={(PT + PB) / 2} text-anchor="middle" transform={`rotate(-90,16,${(PT + PB) / 2})`}>Finishing ΔxG</text>
              </g>
              <!-- dim background field -->
              <g fill="#252525">
                {scatterDots.filter(d => d.tier === 'dim').map(d => (
                  <circle cx={d.x} cy={d.y} r="2"/>
                ))}
              </g>
              <!-- mid tier -->
              <g fill="#5a5a5a">
                {scatterDots.filter(d => d.tier === 'mid').map(d => (
                  <circle cx={d.x} cy={d.y} r="3"/>
                ))}
              </g>
              <!-- elite — team colors -->
              {scatterDots.filter(d => d.tier === 'elite').map(d => (
                <circle cx={d.x} cy={d.y} r={d.rank < 3 ? '6' : d.rank < 6 ? '5' : '4'} fill={d.tc} opacity="0.9"/>
              ))}
              <!-- elite labels (top 6) -->
              <g font-family="Space Grotesk, sans-serif" font-size="10.5" font-weight="600" fill="#fff">
                {scatterDots.filter(d => d.tier === 'elite' && d.rank < 6).map(d => (
                  <text x={Number(d.x) + 8} y={Number(d.y) + 4}>{d.name.split(' ')[0][0] + '. ' + d.name.split(' ').slice(1).join(' ')}</text>
                ))}
              </g>
            </svg>
          </div>
          <div class="scatter-side">
            <h4>Story of the quadrants</h4>
            <p class="note">The top-right elite corner is thin for a reason — you need both volume and quality. Volume shooters in the bottom-right are regression candidates: expect their goal numbers to drop.</p>
            <span class="qhead">Top-right · Elite</span>
            {eliteQ.map(p => (
              <div class="qrow">
                <span class="qk">{p.display_name} <span class="tm">{p.team_abbrev}</span></span>
                <span class="qv">{p.rates_per_60.finishing >= 0 ? '+' : ''}{p.rates_per_60.finishing.toFixed(2)}</span>
              </div>
            ))}
            <span class="qhead">Bottom-right · Volume, cold</span>
            {coldQ.map(p => (
              <div class="qrow">
                <span class="qk">{p.display_name} <span class="tm">{p.team_abbrev}</span></span>
                <span class="qv" style="color:var(--hgb-red)">{p.rates_per_60.finishing.toFixed(2)}</span>
              </div>
            ))}
            <span class="qhead">Top-left · Finishing on low volume</span>
            {finisherQ.map(p => (
              <div class="qrow">
                <span class="qk">{p.display_name} <span class="tm">{p.team_abbrev}</span></span>
                <span class="qv" style="color:#60a5fa">{p.rates_per_60.finishing >= 0 ? '+' : ''}{p.rates_per_60.finishing.toFixed(2)}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 4 — Goals/60 · Top 10
         ════════════════════════════════════════════════════════════ -->
    <div class="lb-sec">
      <div class="lb-sec-h">
        <h2>Pure scoring · goals / 60</h2>
        <span class="lb-sec-mode">Mode · <b>Ranked list</b></span>
      </div>
      <p class="lb-sec-lede">Goals per 60 minutes, regardless of position or ice time. The rawest scoring-rate leaderboard — partial seasons welcome (min 10 GP). Caufield at the top is not a fluke.</p>
      <div class="goals-list">
        {goals60.map((p, i) => {
          const tc = pickTeamColor(p.team_abbrev);
          const cls = i === 0 ? 'top1' : i === 1 ? 'top2' : i === 2 ? 'top3' : '';
          const tintStyle = (i === 1 || i === 2) ? `--row-tint:${hexToRgba(tc, 0.06)};` : '';
          return (
            <a class={`rc-row${cls ? ' ' + cls : ''}`} href={`/stats/player/${p.slug}`}
               style={`border-left-color:${tc};${tintStyle}`}>
              <span class="rc-rank">{rankStr(i + 1)}</span>
              <img class="rc-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="24" height="24" loading="lazy" />
              <div class="rc-info">
                <span class="rc-name">{p.display_name}</span>
                <span class="rc-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP · {fmtToi(p.toi_avg_sec)} TOI</span>
              </div>
              <span class="rc-val">{p.value.toFixed(2)}</span>
              <span class="rc-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
            </a>
          );
        })}
        <div class="ranked-foot">
          <span>Goals / 60 min · min 10 GP</span>
          <a href="/stats/leaderboards/all">View full →</a>
        </div>
      </div>
    </div>

    <!-- GOALIE PLACEHOLDER -->
    <div class="lb-coming">
      <span class="lb-coming-eyebrow">Goalie metrics · Coming soon</span>
      <p class="lb-coming-text">GSAx and save-percentile leaderboards pending — goalie pipeline is in development.</p>
    </div>

    <!-- METHODOLOGY (3-col from Claude Design) -->
    <div class="lb-method">
      <div class="lb-method-h">
        <span class="title">How we measure</span>
        <span class="tag">methodology · 2025–2026</span>
      </div>
      <div class="lb-method-grid">
        <div class="lb-method-card">
          <div class="k">HGBScore V2 <span class="badge badge-core">CORE</span></div>
          <div class="v">Per-game blend of goals, assists, shots, <span class="mono">xG</span>, and two-way play — scaled so <span class="mono">1.0</span> is a solid game. Percentiles vs same position group with 20+ GP.</div>
        </div>
        <div class="lb-method-card">
          <div class="k">Expected goals (xG)</div>
          <div class="v">Probability a shot scores, based on location, angle, shot type, and context. Better signal than raw shot count — Tkachuk getting 16 shots/60 and only 1.44 xG/60 tells the real story.</div>
        </div>
        <div class="lb-method-card">
          <div class="k">RAPM <span class="badge badge-coming">COMING</span></div>
          <div class="v">Isolates a player's true on-ice impact by controlling for linemates and opponents. Ships after the regular season data is complete.</div>
        </div>
      </div>
    </div>

  </main>

  <footer class="lb-footer">HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026 · LEADERBOARD V2</footer>

</body>
</html>
