---
import '../../styles/stats-tokens.css';
import PageHeader from '../../components/stats/PageHeader.astro';
import SectionEyebrow from '../../components/stats/SectionEyebrow.astro';
import {
  loadTopForwardsHGBScore,
  loadTopDefensemenHGBScore,
  loadTopForwardsXG60,
  loadTopGoals60,
} from '../../lib/stats-loader';
import { pickTeamColor } from '../../lib/team-colors';

const fwdHGB  = loadTopForwardsHGBScore(25);
const defHGB  = loadTopDefensemenHGBScore(25);
const fwdXG   = loadTopForwardsXG60(25);
const goals60 = loadTopGoals60(10);

function fmtToi(sec: number): string {
  const m = Math.floor(sec / 60);
  const s = Math.round(sec % 60);
  return `${m}:${s.toString().padStart(2, '0')}`;
}

function dotColor(pct: number): string {
  return pct >= 90 ? '#00c078' : pct >= 70 ? '#60a5fa' : pct >= 40 ? '#8a8a82' : '#e8002d';
}

function hexToRgba(hex: string, alpha: number): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}

function rankStr(n: number): string {
  return String(n).padStart(2, '0');
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Anti-FOUC: sets html[data-mode] before CSS renders — zero flash. -->
  <script is:inline>
    (function() {
      try {
        var saved = localStorage.getItem('hgb-mode');
        var system = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.dataset.mode = saved || system;
      } catch (_) { document.documentElement.dataset.mode = 'dark'; }
    })();
  </script>
  <meta name="color-scheme" content="light dark">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Leaderboards — HGB Stats</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { min-height: 100vh; -webkit-font-smoothing: antialiased; }
    body {
      background: var(--site-bg);
      color: var(--site-white);
      font-family: var(--font-site-body, 'Space Grotesk', sans-serif);
    }

    /* ── Shell ──────────────────────────────────────────────────────── */
    .lb-main { max-width: 1120px; margin: 0 auto; padding: 0 24px 64px; }

    /* ── Breadcrumb ─────────────────────────────────────────────────── */
    .lb-crumb { padding: 20px 0 14px; }
    .lb-crumb a {
      font-family: var(--font-card-display);
      font-size: 13px; font-weight: 700;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--site-muted); text-decoration: none;
      transition: color 0.12s;
    }
    .lb-crumb a:hover { color: var(--site-white); }

    /* ── Hero ───────────────────────────────────────────────────────── */
    .lb-hero { padding: 20px 0 16px; border-bottom: 1px solid var(--site-border); }
    .lb-headline {
      font-family: var(--font-card-display);
      font-size: clamp(28px, 3.5vw, 38px);
      font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.01em; line-height: 1.05;
      margin-top: 10px; color: var(--site-white);
    }
    .lb-sub {
      margin-top: 10px; font-size: 13px;
      color: var(--site-muted); line-height: 1.55; max-width: 520px;
    }

    /* ── HGBScore pair (4a + 4b): same metric, same 25 rows ─────────── */
    .lb-pair {
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: 40px;
      align-items: start;
      padding: 28px 0;
      border-bottom: 1px solid var(--site-border);
    }
    @media (max-width: 768px) { .lb-pair { grid-template-columns: 1fr; row-gap: 32px; } }

    /* ── Full-width sections ────────────────────────────────────────── */
    .lb-section { padding: 28px 0; border-bottom: 1px solid var(--site-border); }

    /* ── Section blurb ──────────────────────────────────────────────── */
    .lb-blurb {
      margin-top: 6px; margin-bottom: 16px;
      font-size: 13px; color: var(--site-muted); line-height: 1.55; max-width: 620px;
    }

    /* ── List container ─────────────────────────────────────────────── */
    .lb-list {
      background: var(--site-card);
      border: 1px solid var(--site-border);
      border-radius: var(--radius-md);
      overflow: hidden;
    }

    /* ── Row — flex link, not a table row ───────────────────────────── */
    .lb-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      border-left: 3px solid transparent;
      border-bottom: 1px solid var(--site-border);
      text-decoration: none;
      color: inherit;
      background: transparent;
      transition: background 0.12s;
    }
    .lb-row:last-child { border-bottom: none; }
    .lb-row:hover { background: rgba(255,255,255,0.05); }
    [data-mode="light"] .lb-row:hover { background: rgba(13,13,20,0.04); }

    /* Top-3 featured: taller, team-color tinted background */
    .lb-row--top {
      padding: 13px 16px;
      background: var(--row-tint, transparent);
    }
    .lb-row--top:hover { background: rgba(255,255,255,0.07); }
    [data-mode="light"] .lb-row--top:hover { background: rgba(13,13,20,0.06); }

    /* ── Rank number ────────────────────────────────────────────────── */
    .lb-rank {
      font-family: var(--font-card-display);
      font-size: 20px;
      font-weight: 900;
      line-height: 1;
      color: rgba(255,255,255,0.16);
      min-width: 30px;
      text-align: right;
      letter-spacing: -0.01em;
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
    }
    [data-mode="light"] .lb-rank { color: rgba(13,13,20,0.18); }
    .lb-row--top .lb-rank {
      color: rgba(255,255,255,0.5);
      font-size: 24px;
    }
    [data-mode="light"] .lb-row--top .lb-rank { color: rgba(13,13,20,0.5); }

    /* ── Team logo ──────────────────────────────────────────────────── */
    .lb-logo {
      width: 22px;
      height: 22px;
      object-fit: contain;
      flex-shrink: 0;
      opacity: 0.88;
    }
    .lb-row--top .lb-logo { width: 28px; height: 28px; opacity: 1; }

    /* ── Two-line info block ────────────────────────────────────────── */
    .lb-info {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .lb-name {
      font-family: var(--font-site-body);
      font-size: 13px;
      font-weight: 600;
      color: var(--site-white);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      line-height: 1.2;
    }
    .lb-row--top .lb-name { font-size: 15px; }
    .lb-meta {
      font-family: var(--font-card-display);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--site-muted);
      white-space: nowrap;
    }

    /* ── Metric value ───────────────────────────────────────────────── */
    .lb-val {
      font-family: var(--font-site-display);
      font-size: 16px;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      color: var(--site-white);
      min-width: 44px;
      text-align: right;
      flex-shrink: 0;
    }
    .lb-row--top .lb-val { font-size: 20px; min-width: 52px; }

    /* ── Percentile dot ─────────────────────────────────────────────── */
    .lb-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ── View-all link ──────────────────────────────────────────────── */
    .lb-view-all {
      display: block; margin-top: 8px;
      font-size: 11px; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--site-muted); text-decoration: none;
      text-align: right; transition: color 0.12s;
    }
    .lb-view-all:hover { color: var(--site-white); }

    /* ── Goalie / coming-soon ───────────────────────────────────────── */
    .lb-coming-text {
      margin-top: 10px; font-size: 13px;
      color: var(--site-muted); line-height: 1.55;
    }

    /* ── Methodology ────────────────────────────────────────────────── */
    .lb-method {
      padding: 28px 0;
      display: flex; align-items: center;
      justify-content: space-between;
      flex-wrap: wrap; gap: 10px;
    }
    .lb-method-text { font-size: 13px; color: var(--site-muted); line-height: 1.55; flex: 1; }
    .lb-method-link {
      font-family: var(--font-card-display);
      font-size: 12px; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--site-muted); text-decoration: none;
      transition: color 0.12s; white-space: nowrap;
    }
    .lb-method-link:hover { color: var(--site-white); }

    /* ── Footer ─────────────────────────────────────────────────────── */
    .lb-footer {
      text-align: center; padding: 20px 0;
      font-size: 0.7rem; letter-spacing: 0.1em;
      color: var(--site-muted); font-family: var(--font-mono);
    }
  </style>
</head>
<body>
  <PageHeader activePage="stats" />

  <main class="lb-main">

    <nav class="lb-crumb"><a href="/stats">← STATS</a></nav>

    <section class="lb-hero">
      <SectionEyebrow label="LEADERBOARDS" />
      <h1 class="lb-headline">Who's driving play this season.</h1>
      <p class="lb-sub">Four angles on the best skaters in the NHL — by HGBScore, finishing, and pure scoring rate.</p>
    </section>

    <!-- HGBScore pair: 2-col, same metric, identical 25-row height -->
    <div class="lb-pair">

      <section>
        <SectionEyebrow label="TOP 25 FORWARDS · HGBSCORE V2" />
        <p class="lb-blurb">Per-game blend of goals, assists, xG, and two-way play — rate-adjusted per 60 minutes.</p>
        <div class="lb-list">
          {fwdHGB.map((p, i) => {
            const tc = pickTeamColor(p.team_abbrev);
            const isTop = i < 3;
            return (
              <a
                class={`lb-row${isTop ? ' lb-row--top' : ''}`}
                href={`/stats/player/${p.slug}`}
                style={`border-left-color:${tc};${isTop ? `--row-tint:${hexToRgba(tc, 0.08)};` : ''}`}
              >
                <span class="lb-rank">{rankStr(i + 1)}</span>
                <img class="lb-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="28" height="28" loading="lazy" />
                <div class="lb-info">
                  <span class="lb-name">{p.display_name}</span>
                  <span class="lb-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP</span>
                </div>
                <span class="lb-val">{p.value.toFixed(2)}</span>
                <span class="lb-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
              </a>
            );
          })}
        </div>
        <a href="/stats/leaderboards/all" class="lb-view-all">VIEW FULL LEADERBOARD →</a>
      </section>

      <section>
        <SectionEyebrow label="TOP 25 DEFENSEMEN · HGBSCORE V2" />
        <p class="lb-blurb">Defensemen typically score lower than forwards on HGBScore because volume matters — an elite defenseman drives play without racking up goals.</p>
        <div class="lb-list">
          {defHGB.map((p, i) => {
            const tc = pickTeamColor(p.team_abbrev);
            const isTop = i < 3;
            return (
              <a
                class={`lb-row${isTop ? ' lb-row--top' : ''}`}
                href={`/stats/player/${p.slug}`}
                style={`border-left-color:${tc};${isTop ? `--row-tint:${hexToRgba(tc, 0.08)};` : ''}`}
              >
                <span class="lb-rank">{rankStr(i + 1)}</span>
                <img class="lb-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="28" height="28" loading="lazy" />
                <div class="lb-info">
                  <span class="lb-name">{p.display_name}</span>
                  <span class="lb-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP</span>
                </div>
                <span class="lb-val">{p.value.toFixed(2)}</span>
                <span class="lb-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
              </a>
            );
          })}
        </div>
        <a href="/stats/leaderboards/all" class="lb-view-all">VIEW FULL LEADERBOARD →</a>
      </section>

    </div>

    <!-- xG/60: full-width -->
    <section class="lb-section">
      <SectionEyebrow label="TOP 25 FORWARDS · XG / 60" />
      <p class="lb-blurb">Expected goals per 60 minutes. Surfaces finishers who generate high-quality chances — not just volume shooters.</p>
      <div class="lb-list">
        {fwdXG.map((p, i) => {
          const tc = pickTeamColor(p.team_abbrev);
          const isTop = i < 3;
          return (
            <a
              class={`lb-row${isTop ? ' lb-row--top' : ''}`}
              href={`/stats/player/${p.slug}`}
              style={`border-left-color:${tc};${isTop ? `--row-tint:${hexToRgba(tc, 0.08)};` : ''}`}
            >
              <span class="lb-rank">{rankStr(i + 1)}</span>
              <img class="lb-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="28" height="28" loading="lazy" />
              <div class="lb-info">
                <span class="lb-name">{p.display_name}</span>
                <span class="lb-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP · {fmtToi(p.toi_avg_sec)} TOI</span>
              </div>
              <span class="lb-val">{p.value.toFixed(2)}</span>
              <span class="lb-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
            </a>
          );
        })}
      </div>
      <a href="/stats/leaderboards/all" class="lb-view-all">VIEW FULL LEADERBOARD →</a>
    </section>

    <!-- Goals/60: full-width, Top 10 spotlight -->
    <section class="lb-section">
      <SectionEyebrow label="TOP 10 · GOALS / 60" />
      <p class="lb-blurb">Goals per 60 minutes, regardless of position or ice time. The rawest scoring-rate leaderboard — partial seasons welcome.</p>
      <div class="lb-list">
        {goals60.map((p, i) => {
          const tc = pickTeamColor(p.team_abbrev);
          const isTop = i < 3;
          return (
            <a
              class={`lb-row${isTop ? ' lb-row--top' : ''}`}
              href={`/stats/player/${p.slug}`}
              style={`border-left-color:${tc};${isTop ? `--row-tint:${hexToRgba(tc, 0.08)};` : ''}`}
            >
              <span class="lb-rank">{rankStr(i + 1)}</span>
              <img class="lb-logo" src={`https://assets.nhle.com/logos/nhl/svg/${p.team_abbrev}_light.svg`} alt={p.team_abbrev} width="28" height="28" loading="lazy" />
              <div class="lb-info">
                <span class="lb-name">{p.display_name}</span>
                <span class="lb-meta">{p.pos} · {p.team_abbrev} · {p.gp} GP · {fmtToi(p.toi_avg_sec)} TOI</span>
              </div>
              <span class="lb-val">{p.value.toFixed(2)}</span>
              <span class="lb-dot" style={`background:${dotColor(p.pct)}`} title={`${Math.round(p.pct)}th pct`}></span>
            </a>
          );
        })}
      </div>
      <a href="/stats/leaderboards/all" class="lb-view-all">VIEW FULL LEADERBOARD →</a>
    </section>

    <!-- Goalie placeholder -->
    <section class="lb-section">
      <SectionEyebrow label="GOALIE METRICS · COMING SOON" color="muted" />
      <p class="lb-coming-text">GSAx and save-percentile leaderboards pending — goalie pipeline is in development.</p>
    </section>

    <!-- Methodology -->
    <div class="lb-method">
      <SectionEyebrow label="HOW WE MEASURE" color="muted" />
      <span class="lb-method-text">
        HGBScore V2 combines individual shot quality, on-ice xG, finishing skill, and penalties drawn/taken — all rate-adjusted per 60 minutes. Percentiles vs position peers with 20+ GP.
      </span>
      <a href="/stats/methodology" class="lb-method-link">READ THE FULL METHODOLOGY →</a>
    </div>

  </main>

  <footer class="lb-footer">HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026</footer>

</body>
</html>
