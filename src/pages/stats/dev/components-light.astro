---
import '../../../styles/stats-tokens.css';
import PageHeader      from '../../../components/stats/PageHeader.astro';
import SectionEyebrow  from '../../../components/stats/SectionEyebrow.astro';
import DualStatBar      from '../../../components/stats/DualStatBar.astro';
import PercentileTile   from '../../../components/stats/PercentileTile.astro';
import PlayerHero       from '../../../components/stats/PlayerHero.astro';
import LeaderboardRow   from '../../../components/stats/LeaderboardRow.astro';
import GameRow          from '../../../components/stats/GameRow.astro';

const sampleTiles = [
  { label: 'EV OFFENCE',   rawVal: '3.18',  pct: 99.2 },
  { label: 'EV DEFENCE',   rawVal: '2.04',  pct: 58.4 },
  { label: 'FINISHING',    rawVal: '+0.64', pct: 88.6 },
  { label: 'GOALS',        rawVal: '1.84',  pct: 98.1 },
  { label: '1ST ASSISTS',  rawVal: '3.12',  pct: 96.8 },
  { label: 'SHOTS',        rawVal: '9.40',  pct: 99.5 },
  { label: 'PENALTY DIFF', rawVal: '+0.45', pct: 92.3 },
  { label: 'ixG',          rawVal: '1.20',  pct: 97.7 },
  { label: 'GAME SCORE',   rawVal: '+2.85', pct: 99.8 },
];

const sampleLeaderboard = [
  { rank: 1, displayName: 'C. McDavid',  teamAbbrev: 'EDM', pos: 'C', value: '+2.85', pct: 99.8 },
  { rank: 2, displayName: 'C. Makar',    teamAbbrev: 'COL', pos: 'D', value: '+2.41', pct: 99.6 },
  { rank: 3, displayName: 'J. Hughes',   teamAbbrev: 'NJD', pos: 'C', value: '+2.18', pct: 97.5 },
  { rank: 4, displayName: 'N. Kucherov', teamAbbrev: 'TBL', pos: 'R', value: '+2.06', pct: 96.9 },
  { rank: 5, displayName: 'D. Pastrnak', teamAbbrev: 'BOS', pos: 'R', value: '+1.94', pct: 95.3 },
];

const sampleGames = [
  { homeTeam: 'BOS', awayTeam: 'BUF', homeScore: 3, awayScore: 2,
    state: 'live' as const, stateLabel: 'P2 · 08:41',
    homeSOG: 24, awaySOG: 19, homeXG: 3.42, awayXG: 2.18 },
  { homeTeam: 'COL', awayTeam: 'DAL', homeScore: 4, awayScore: 1,
    state: 'final' as const, stateLabel: 'FINAL',
    homeSOG: 31, awaySOG: 22, homeXG: 4.11, awayXG: 1.87 },
  { homeTeam: 'EDM', awayTeam: 'LAK', homeScore: 0, awayScore: 0,
    state: 'fut' as const, stateLabel: '7:00 PM MT' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Component Gallery — Light Mode — HGB Stats</title>
</head>
<body data-mode="light">

<PageHeader activePage="stats" />

<main class="gallery">

  <div class="g-variant-link">
    <a href="/stats/dev/components">← View dark variant</a>
  </div>

  <!-- ═══ RED VARIANT CHECK ═════════════════════════════════════════ -->
  <section class="g-section">
    <div class="g-label">Red Variant Check — pick one, commit the hex</div>
    <div class="g-red-strip">
      {[
        { hex: '#E8002D', note: 'current' },
        { hex: '#D40022', note: 'darker / more saturated' },
        { hex: '#C7002A', note: 'classic sports red' },
        { hex: '#FF1A3A', note: 'brighter (likely hot)' },
      ].map(({ hex, note }) => (
        <div class="g-red-swatch">
          <div class="g-red-chips">
            <div class="g-red-chip g-red-chip--dark"  style={`--swatch:${hex}`}></div>
            <div class="g-red-chip g-red-chip--light" style={`--swatch:${hex}`}></div>
          </div>
          <code class="g-red-hex">{hex}</code>
          <span class="g-red-note">{note}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ SectionEyebrow ════════════════════════════════════════════ -->
  <section class="g-section">
    <div class="g-label">SectionEyebrow</div>
    <div class="g-row g-row--gap">
      <SectionEyebrow label="★ First Round · 2026 Playoffs" color="red" />
      <SectionEyebrow label="● Live Now · 3 games" color="cyan" />
      <SectionEyebrow label="Top Performers" color="muted" />
    </div>
  </section>

  <!-- ═══ PercentileTile ════════════════════════════════════════════ -->
  <section class="g-section">
    <div class="g-label">PercentileTile — light mode (cream neutral, mode="light")</div>
    <div class="g-tile-grid">
      {sampleTiles.map(t => (
        <PercentileTile label={t.label} rawVal={t.rawVal} pct={t.pct} mode="light" />
      ))}
    </div>
    <div class="g-tile-grid g-tile-grid--scale">
      {[0, 10, 25, 50, 75, 90, 99].map(p => (
        <PercentileTile label="SCALE" rawVal={`${p}th`} pct={p} mode="light" />
      ))}
    </div>
  </section>

  <!-- ═══ PlayerHero ════════════════════════════════════════════════ -->
  <section class="g-section">
    <div class="g-label">PlayerHero</div>
    <div class="g-col">
      <PlayerHero firstName="Connor" lastName="McDavid" displayName="C. McDavid"
                  teamAbbrev="EDM" pos="C" teamColor="#FF4C00" />
      <PlayerHero firstName="Cale"   lastName="Makar"   displayName="C. Makar"
                  teamAbbrev="COL" pos="D" teamColor="#6F263D" />
    </div>
  </section>

  <!-- ═══ DualStatBar ═══════════════════════════════════════════════ -->
  <section class="g-section">
    <div class="g-label">DualStatBar</div>
    <div class="g-stat-group">
      <DualStatBar label="Shots on Goal"       leftVal="24"   rightVal="19"   leftPct={56} leftColor="#FCB514" rightColor="#002855" />
      <DualStatBar label="Expected Goals (xG)" leftVal="3.42" rightVal="2.18" leftPct={61} leftColor="#00e5ff" rightColor="#1a4050" />
      <DualStatBar label="Goals Against"       leftVal="1.8"  rightVal="2.4"  leftPct={43} invertWinner />
    </div>
  </section>

  <!-- ═══ LeaderboardRow ════════════════════════════════════════════ -->
  <section class="g-section">
    <div class="g-label">LeaderboardRow</div>
    <div class="g-leaderboard">
      <div class="g-lb-head">
        <span class="g-lb-rk">#</span>
        <span>PLAYER</span>
        <span>TEAM</span>
        <span style="text-align:right">AVG GS</span>
        <span></span>
      </div>
      {sampleLeaderboard.map(r => (
        <LeaderboardRow rank={r.rank} displayName={r.displayName}
                        teamAbbrev={r.teamAbbrev} pos={r.pos}
                        value={r.value} pct={r.pct} />
      ))}
    </div>
  </section>

  <!-- ═══ GameRow ═══════════════════════════════════════════════════ -->
  <section class="g-section">
    <div class="g-label">GameRow</div>
    <div class="g-game-grid">
      {sampleGames.map(g => (
        <GameRow {...g} />
      ))}
    </div>
  </section>

</main>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: var(--site-bg);
    color: var(--site-text);
    font-family: var(--font-site-body);
    -webkit-font-smoothing: antialiased;
  }

  .g-variant-link {
    margin-bottom: 32px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
  }
  .g-variant-link a { color: var(--site-muted); text-decoration: none; }
  .g-variant-link a:hover { color: var(--site-white); }

  /* ── Red strip ─────────────────────────────────────────────────── */
  .g-red-strip { display: flex; gap: 28px; flex-wrap: wrap; }
  .g-red-swatch { display: flex; flex-direction: column; gap: 6px; }
  .g-red-chips { display: flex; gap: 4px; }
  .g-red-chip {
    width: 64px; height: 36px; border-radius: var(--radius-sm, 2px);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .g-red-chip::after {
    content: '';
    display: block;
    width: 100%; height: 100%;
    background: var(--swatch);
    position: absolute; inset: 0;
  }
  .g-red-chip--dark  { background: #090909; }
  .g-red-chip--light { background: #efeee8; border: 1px solid rgba(13,13,20,0.10); }
  .g-red-hex  { font-family: var(--font-mono); font-size: 11px; color: var(--site-text); }
  .g-red-note { font-size: 10px; color: var(--site-muted); letter-spacing: 0.06em; }

  /* ── Gallery layout ─────────────────────────────────────────────── */
  .gallery {
    max-width: 1100px;
    margin: 0 auto;
    padding: 36px 20px 120px;
  }

  .g-section  { margin-bottom: 52px; }
  .g-label    { font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--hgb-red); margin-bottom: 14px; }
  .g-row      { display: flex; align-items: center; }
  .g-row--gap { gap: 28px; }
  .g-col      { display: flex; flex-direction: column; gap: 10px; }

  .g-tile-grid {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: 6px;
    margin-bottom: 6px;
  }
  .g-tile-grid--scale { grid-template-columns: repeat(7, 1fr); margin-top: 8px; }

  .g-stat-group {
    background: var(--site-card);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md, 3px);
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 480px;
  }

  .g-leaderboard {
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md, 3px);
    overflow: hidden;
  }
  .g-lb-head {
    display: grid;
    grid-template-columns: 32px 1fr auto auto 14px;
    gap: 0 12px;
    padding: 7px 14px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--site-muted);
    border-bottom: 1px solid var(--site-border);
    background: var(--site-card);
  }
  .g-lb-rk { text-align: right; }

  .g-game-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }

  @media (max-width: 768px) {
    .g-tile-grid { grid-template-columns: repeat(3, 1fr); }
    .g-tile-grid--scale { grid-template-columns: repeat(4, 1fr); }
    .g-game-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 1024px) {
    .g-game-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
