      // center divider
      ctx.fillStyle = INK10; ctx.fillRect(PAD + COL_W + COL_GAP / 2, y, 1, N_ROWS * BAR_ROW_H);
      drawBarCol(rightBarRows, PAD + COL_W + COL_GAP);

      y += N_ROWS * BAR_ROW_H;

      // ── sparkline (last 10 games) ────────────────────────────────────────
      y += SEC_SEP;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK48; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText('LAST 10 GAMES — HGB IMPACT', PAD, y + SP_LBL / 2);
      y += SP_LBL;

      const gs = D.recentGS;
      if (gs.length >= 2) {
        const spMin = -5, spMax = 12;
        const spW = W - PAD * 2, spH = SP_H;
        const spX = i => PAD + (i / (gs.length - 1)) * spW;
        const spY = v => y + spH - ((Math.min(spMax, Math.max(spMin, v)) - spMin) / (spMax - spMin)) * spH;
        const sp0 = spY(0);

        // area fill
        ctx.beginPath();
        ctx.moveTo(spX(0), spY(gs[0]));
        for (let i = 1; i < gs.length; i++) ctx.lineTo(spX(i), spY(gs[i]));
        ctx.lineTo(spX(gs.length - 1), sp0);
        ctx.lineTo(spX(0), sp0);
        ctx.closePath();
        ctx.fillStyle = 'rgba(20,128,60,0.12)';
        ctx.fill();

        // zero line
        ctx.strokeStyle = INK14; ctx.lineWidth = 1; ctx.setLineDash([3, 3]);
        ctx.beginPath(); ctx.moveTo(PAD, sp0); ctx.lineTo(W - PAD, sp0); ctx.stroke();
        ctx.setLineDash([]);

        // line
        ctx.beginPath();
        ctx.moveTo(spX(0), spY(gs[0]));
        for (let i = 1; i < gs.length; i++) ctx.lineTo(spX(i), spY(gs[i]));
        ctx.strokeStyle = '#14803c'; ctx.lineWidth = 2; ctx.stroke();

        // dots
        for (let i = 0; i < gs.length; i++) {
          ctx.beginPath(); ctx.arc(spX(i), spY(gs[i]), 3, 0, Math.PI * 2);
          ctx.fillStyle = gs[i] >= 0 ? '#14803c' : RED; ctx.fill();
        }
      }
      y += SP_H;

      // ── footer ───────────────────────────────────────────────────────────
      ctx.fillStyle = INK06; ctx.fillRect(0, y, W, FOOT_H);
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · 2025-26', W / 2, y + FOOT_H / 2);

      return canvas;
    }

    // ── Landscape card (900×500) ─────────────────────────────────────────
    async function drawCardWide() {
      const BG      = '#EFEEE8';
      const SURFACE = '#FFFFFF';
      const SCALE = 2;
      const W = 900, H = 500;
      const DIVX = 280;  // left column width
      const PAD  = 28;
      const FOOT = 20;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // background
      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, H);

      // white right panel inset
      ctx.fillStyle = SURFACE; ctx.fillRect(DIVX + 12, 16, W - DIVX - 28, H - FOOT - 32);

      // 6px team-color left border strip
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 6, H - FOOT);

      // ── LEFT COLUMN ─────────────────────────────────────────────────────
      const hsImg = await loadImg(D.headshotUrl);
      const R = 58, HS_CX = DIVX / 2, HS_CY = 88;
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
      } else {
        ctx.fillStyle = INK10; ctx.fill();
        ctx.font = '800 36px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText((D.firstName[0] + D.lastName[0]).toUpperCase(), HS_CX, HS_CY);
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 3; ctx.stroke();

      // first name small above last name
      const LX = 34;
      ctx.font = '600 13px "Barlow", sans-serif';
      ctx.fillStyle = INK48; ctx.textBaseline = 'top'; ctx.textAlign = 'left';
      ctx.fillText(D.firstName.toUpperCase(), LX, 162);
      ctx.font = '800 52px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK;
      ctx.fillText(D.lastName.toUpperCase(), LX, 174);

      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.letterSpacing = '0.06em';
      ctx.fillText(D.team + ' · ' + D.pos + ' · 2025-26', LX, 234);

      // hairline separator
      ctx.fillStyle = INK14; ctx.fillRect(LX, 252, DIVX - LX - 12, 1);

      // WAR hero number
      const warNum = D.war != null ? D.war.toFixed(1) : '—';
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'top';
      ctx.fillText('WAR', LX, 263);
      ctx.font = '800 58px "Barlow Condensed", sans-serif';
      ctx.fillStyle = D.war != null && D.war > 0 ? TEAM_C : INK;
      ctx.fillText(warNum, LX, 272);
      ctx.font = '700 11px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32;
      ctx.fillText(ordinal(D.impactPct) + ' vs ' + D.posLabel.toLowerCase() + 's', LX, 338);

      // ── RIGHT COLUMN ────────────────────────────────────────────────────
      const RX = DIVX + 24;  // right content start x
      const RW = W - RX - 16;  // right content width

      // 4 headline KPIs
      const hKpis = [
        { label: 'G / 60',  val: D.ratesG.toFixed(2),  pct: ordinal(D.percentiles.goals) },
        { label: 'A1 / 60', val: D.ratesA1.toFixed(2), pct: ordinal(D.percentiles.a1) },
        { label: 'xG / 60', val: D.ratesXg.toFixed(2), pct: ordinal(D.percentiles.ixg) },
        { label: 'TOI / GP',val: fmtToi(D.toiAvgSec),  pct: String(D.gp) + ' GP' },
      ];
      const kW = RW / 4;
      for (let i = 0; i < hKpis.length; i++) {
        const kx = RX + i * kW + kW / 2;
        if (i > 0) { ctx.fillStyle = INK14; ctx.fillRect(RX + i * kW, 28, 1, 118); }
        ctx.font = '800 38px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText(hKpis[i].val, kx, 82);
        ctx.font = '700 9px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK48;
        ctx.fillText(hKpis[i].label, kx, 112);
        ctx.font = '700 12px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32;
        ctx.fillText(hKpis[i].pct, kx, 128);
      }

      // divider below KPIs
      ctx.fillStyle = INK14; ctx.fillRect(RX, 148, RW, 1);

      // 10 percentile bars in 2 columns of 5
      const pct = D.percentiles;
      const leftBars = [
        { label: 'EV Offense', val: pct.ev_offence, rate: D.ratesG.toFixed(2),  blue: false },
        { label: 'EV Defense', val: pct.ev_defence, rate: '',                    blue: true  },
        { label: 'Goals / 60', val: pct.goals,      rate: D.ratesG.toFixed(2),  blue: false },
        { label: 'A1 / 60',   val: pct.a1,         rate: D.ratesA1.toFixed(2), blue: false },
        { label: 'xG / 60',   val: pct.ixg,        rate: D.ratesXg.toFixed(2), blue: false },
      ];
      const ppPct  = pct.pp_off ?? null;
      const pkPct  = pct.pk_def ?? null;
      const finStr = (D.finishing >= 0 ? '+' : '') + D.finishing.toFixed(2);
      const rightBars = [
        { label: 'Finishing',  val: pct.finishing,  rate: finStr, blue: false },
        { label: 'Shots / 60', val: pct.shots,      rate: '',     blue: false },
        { label: 'Pen. Diff',  val: pct.pen_diff,   rate: '',     blue: false },
        ...(ppPct !== null ? [{ label: 'PP RAPM', val: ppPct, rate: '', blue: false }] : []),
        ...(pkPct !== null ? [{ label: 'PK RAPM', val: pkPct, rate: '', blue: false }] : []),
      ];

      const BAR_COL_W  = RW / 2 - 8;
      const BAR_H_PX   = 10;
      const BAR_ROW_H  = 54;
      const BAR_LABEL_W = 76;
      const BAR_TRACK_W = BAR_COL_W - BAR_LABEL_W - 34;
      const BAR_Y0     = 160;

      function drawBarColumn(bars, colX) {
        for (let bi = 0; bi < bars.length; bi++) {
          const row = bars[bi];
          const ry = BAR_Y0 + bi * BAR_ROW_H;
          const barY = ry + 30;

          // label
          ctx.font = '600 9px "Barlow", sans-serif';
          ctx.fillStyle = INK48; ctx.textBaseline = 'top'; ctx.textAlign = 'left';
          ctx.fillText(row.label, colX, ry + 8);

          // rate value right of label
          if (row.rate) {
            ctx.font = '700 9px "JetBrains Mono", monospace';
            ctx.fillStyle = INK32; ctx.textAlign = 'left';
            ctx.fillText(row.rate, colX + BAR_LABEL_W - 4, ry + 8);
          }

          // bar track
          const bx = colX + BAR_LABEL_W;
          rrect(ctx, bx, barY, BAR_TRACK_W, BAR_H_PX, 3);
          ctx.fillStyle = INK10; ctx.fill();

          // bar fill
          const fillW = Math.max(6, (row.val / 100) * BAR_TRACK_W);
          rrect(ctx, bx, barY, fillW, BAR_H_PX, 3);
          const isNeg = row.val < 25;
          ctx.fillStyle = row.val >= 75 ? (row.blue ? '#4285f4' : '#14803c')
                        : row.val >= 50 ? (row.blue ? '#7baaf7' : '#34a853')
                        : row.val >= 25 ? INK32 : RED;
          ctx.fill();

          // ordinal — big and right-aligned
          ctx.font = '800 14px "Barlow Condensed", sans-serif';
          ctx.fillStyle = row.val >= 50 ? INK : (row.val >= 25 ? INK32 : RED);
          ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
          ctx.fillText(ordinal(row.val), colX + BAR_COL_W, barY + BAR_H_PX / 2);
        }
      }

      drawBarColumn(leftBars,  RX);
      // center divider between bar columns
      ctx.fillStyle = INK10; ctx.fillRect(RX + BAR_COL_W + 8, 148, 1, H - 148 - FOOT - 20);
      drawBarColumn(rightBars, RX + BAR_COL_W + 16);

      // ── footer ──────────────────────────────────────────────────────────
      ctx.fillStyle = INK06; ctx.fillRect(0, H - FOOT, W, FOOT);
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · 2025-26', W / 2, H - FOOT / 2);

      return canvas;
    }

    // ── EDGE drawing helpers ─────────────────────────────────────────────
    function edgeTierColor(pct, blue) {
      if (pct == null) return INK32;
      if (pct >= 75) return blue ? '#4285f4' : '#137333';
      if (pct >= 50) return blue ? '#7baaf7' : '#34a853';
      if (pct >= 25) return INK32;
      return RED;
    }

    function drawEdgeStatBox(ctx, x, y, w, h, lbl, valStr, pct, avgStr, blue) {
      const PAD = 10;
      // box background
      ctx.fillStyle = '#FFFFFF'; ctx.beginPath();
      ctx.roundRect(x, y, w, h, 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.roundRect(x, y, w, h, 4); ctx.stroke();
      // label
      ctx.font = '700 7.5px "JetBrains Mono", monospace';
      ctx.fillStyle = INK45; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText(lbl.toUpperCase(), x + PAD, y + 9);
      // value
      ctx.font = '800 28px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'top';
      ctx.fillText(valStr, x + PAD, y + 20);
      // bar
      const bx = x + PAD, bw = w - PAD * 2, bh = 6, by = y + h - 30;
      ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(bx, by, bw, bh, 2); ctx.fill();
      if (pct != null) {
        const fc = edgeTierColor(pct, blue);
        ctx.fillStyle = fc;
        ctx.beginPath(); ctx.roundRect(bx, by, Math.max(6, (pct / 100) * bw), bh, 2); ctx.fill();
        // pct label
        ctx.font = '600 10px "Barlow", sans-serif';
        ctx.fillStyle = fc; ctx.textBaseline = 'top';
        ctx.fillText(`${Math.round(pct)}th percentile`, x + PAD, y + h - 22);
      }
      // avg
      if (avgStr) {
        ctx.font = '400 7.5px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textBaseline = 'bottom';
        ctx.fillText(avgStr, x + PAD, y + h - 4);
      }
    }

    function drawEdgePairs(ctx, y, W, PAD, e) {
      const bw = (W - PAD * 2 - 10) / 2;
      const bh = 86;
      const pairs = [
        ['TOP SPEED', e.speed_max_mph != null ? `${e.speed_max_mph} mph` : '—', e.speed_max_pct, e.speed_max_league_avg_mph != null ? `avg ${e.speed_max_league_avg_mph} mph` : '', false],
        ['MILES SKATED', e.distance_mi != null ? `${e.distance_mi} mi` : '—', e.distance_pct, e.distance_league_avg_mi != null ? `avg ${e.distance_league_avg_mi} mi` : '', false],
        ['BURSTS > 20 MPH', e.bursts_over_20 != null ? `${e.bursts_over_20}` : '—', e.bursts_over_20_pct, e.bursts_over_20_league_avg != null ? `avg ${e.bursts_over_20_league_avg}` : '', false],
        ['HARDEST SHOT', e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : '', false],
      ];
      for (let i = 0; i < pairs.length; i++) {
        const col = i % 2;
        const row = Math.floor(i / 2);
        const x = PAD + col * (bw + 10);
        const by = y + row * (bh + 10);
        drawEdgeStatBox(ctx, x, by, bw, bh, pairs[i][0], pairs[i][1], pairs[i][2], pairs[i][3], pairs[i][4]);
      }
      return y + 2 * (bh + 10) - 10;
    }

    function drawZoneBar(ctx, y, W, PAD, e, TEAM_C) {
      const oz = e.oz_pct ?? 45, nz = e.nz_pct ?? 32, dz = e.dz_pct ?? 23;
      const bw = W - PAD * 2, bh = 20, bx = PAD;
      // background rounded rect
      ctx.fillStyle = '#FFFFFF'; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 10, W - PAD * 2 + 4, 90, 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 10, W - PAD * 2 + 4, 90, 4); ctx.stroke();
      // title
      ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
      ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('ZONE TIME — EVEN STRENGTH', PAD + 6, y - 4);
      y += 14;
      // segmented bar
      ctx.save(); ctx.beginPath(); ctx.roundRect(bx, y, bw, bh, 3); ctx.clip();
      ctx.fillStyle = TEAM_C; ctx.fillRect(bx, y, bw * oz / 100, bh);
      ctx.fillStyle = 'rgba(13,13,20,0.18)'; ctx.fillRect(bx + bw * oz / 100, y, bw * nz / 100, bh);
      ctx.fillStyle = 'rgba(232,0,45,0.30)'; ctx.fillRect(bx + bw * (oz + nz) / 100, y, bw * dz / 100, bh);
      ctx.restore();
      y += bh + 8;
      // labels
      const segs = [['OFFENSIVE ZONE', `${oz.toFixed(0)}%`, oz], ['NEUTRAL ZONE', `${nz.toFixed(0)}%`, nz], ['DEFENSIVE ZONE', `${dz.toFixed(0)}%`, dz]];
      let lx = PAD + 6;
      for (const [name, pct, w] of segs) {
        ctx.font = '800 16px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK; ctx.textBaseline = 'top'; ctx.textAlign = 'left';
        ctx.fillText(pct, lx, y);
        ctx.font = '600 8px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
        ctx.fillText(name, lx, y + 18);
        lx += bw * w / 100;
      }
      // OZ percentile note
      if (e.oz_ev_pct_pct != null) {
        ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = TEAM_C; ctx.textBaseline = 'bottom';
        ctx.fillText(`OZ time: ${Math.round(e.oz_ev_pct_pct)}th percentile`, PAD + 6, y + 40);
      }
      return y + 44;
    }

    function drawShotDanger(ctx, y, W, PAD, e) {
      const colW = (W - PAD * 2 - 16) / 3;
      const zones = [
        { lbl: 'HIGH DANGER', color: TEAM_C,    n: e.shots_high,  np: e.shots_high_pct,  sh: e.shooting_pct_high,  shp: e.shooting_pct_high_pct },
        { lbl: 'MID RANGE',   color: INK32,     n: e.shots_mid,   np: e.shots_mid_pct,   sh: e.shooting_pct_mid,   shp: e.shooting_pct_mid_pct },
        { lbl: 'LONG RANGE',  color: INK32,     n: e.shots_long,  np: e.shots_long_pct,  sh: e.shooting_pct_long,  shp: e.shooting_pct_long_pct },
      ];
      // background card
      ctx.fillStyle = '#FFFFFF'; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 10, W - PAD * 2 + 4, 185, 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 10, W - PAD * 2 + 4, 185, 4); ctx.stroke();
      ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('SHOT LOCATION BY DANGER ZONE', PAD + 6, y - 4);
      y += 12;
      for (let i = 0; i < 3; i++) {
        const z = zones[i];
        const cx = PAD + i * (colW + 8);
        const ry = y;
        // zone chip
        const chipColor = i === 0 ? `rgba(${parseInt(TEAM_C.slice(1,3),16)},${parseInt(TEAM_C.slice(3,5),16)},${parseInt(TEAM_C.slice(5,7),16)},0.14)` : 'rgba(13,13,20,0.06)';
        ctx.fillStyle = chipColor; ctx.beginPath(); ctx.roundRect(cx, ry, colW, 16, 2); ctx.fill();
        ctx.font = '700 7px "JetBrains Mono", monospace'; ctx.fillStyle = i === 0 ? TEAM_C : INK45;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(z.lbl, cx + colW / 2, ry + 8);
        // Attempts
        ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
        ctx.fillText('ATTEMPTS', cx, ry + 22);
        ctx.font = '800 24px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
        ctx.fillText(z.n != null ? `${z.n}` : '—', cx, ry + 30);
        const npColor = edgeTierColor(z.np, false);
        ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = npColor;
        ctx.fillText(z.np != null ? `${Math.round(z.np)}th` : '', cx, ry + 56);
        const abw = colW, abh = 5;
        ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(cx, ry + 66, abw, abh, 2); ctx.fill();
        if (z.np != null) { ctx.fillStyle = npColor; ctx.beginPath(); ctx.roundRect(cx, ry + 66, Math.max(4, (z.np/100)*abw), abh, 2); ctx.fill(); }
        // Shooting %
        ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK32; ctx.textBaseline = 'top';
        ctx.fillText('SHOOTING %', cx, ry + 78);
        ctx.font = '800 20px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
        ctx.fillText(z.sh != null ? `${z.sh}%` : '—', cx, ry + 88);
        const shpColor = edgeTierColor(z.shp, false);
        ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = shpColor;
        ctx.fillText(z.shp != null ? `${Math.round(z.shp)}th` : '', cx, ry + 110);
        ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(cx, ry + 121, abw, abh, 2); ctx.fill();
        if (z.shp != null) { ctx.fillStyle = shpColor; ctx.beginPath(); ctx.roundRect(cx, ry + 121, Math.max(4, (z.shp/100)*abw), abh, 2); ctx.fill(); }
      }
      return y + 133;
    }

    function drawEdgeDivider(ctx, y, W) {
      ctx.fillStyle = INK10; ctx.fillRect(20, y + 10, (W - 40) / 2 - 80, 1);
      ctx.font = '700 8px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('NHL EDGE ATHLETE TRACKING', W / 2, y + 10);
      ctx.fillStyle = INK10; ctx.fillRect(W / 2 + 80, y + 10, (W - 40) / 2 - 80, 1);
      return y + 24;
    }

    // ── Expanded card: existing card + EDGE section appended ─────────────
    async function drawEdgeCombinedCard() {
      const e = D.edge;
      const W = 560, SCALE = 2, PAD = 20;
      // draw the base portrait card first
      const base = await drawCard();
      const baseH = base.height / SCALE;
      // compute EDGE section height
      // Traced: divider(24)+gap(8)+pairs(194)+gap(12)+zone(86)+gap(12)+shot(145)+gap(10)+footer(36)+init(6) = 533 + 8 buffer
      const EDGE_H = e ? 541 : 60;
      const TOTAL_H = baseH + EDGE_H;
      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = TOTAL_H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);
      // copy base card
      ctx.drawImage(base, 0, 0, W * SCALE, baseH * SCALE, 0, 0, W, baseH);
      if (!e) {
        ctx.fillStyle = INK10; ctx.fillRect(0, baseH, W, EDGE_H);
        ctx.font = '700 10px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('EDGE DATA NOT YET AVAILABLE', W / 2, baseH + EDGE_H / 2);
        return canvas;
      }
      // EDGE section background
      ctx.fillStyle = '#EFEEE8'; ctx.fillRect(0, baseH, W, EDGE_H);
      let y = baseH + 6;
      y = drawEdgeDivider(ctx, y, W);
      y += 8;
      // draw pairs
      const bw = (W - PAD * 2 - 10) / 2, bh = 86;
      const pairs = [
        ['TOP SPEED', e.speed_max_mph != null ? `${e.speed_max_mph} mph` : '—', e.speed_max_pct, e.speed_max_league_avg_mph != null ? `avg ${e.speed_max_league_avg_mph} mph` : ''],
        ['MILES SKATED', e.distance_mi != null ? `${e.distance_mi} mi` : '—', e.distance_pct, e.distance_league_avg_mi != null ? `avg ${e.distance_league_avg_mi} mi` : ''],
        ['BURSTS > 20 MPH', e.bursts_over_20 != null ? `${e.bursts_over_20}` : '—', e.bursts_over_20_pct, e.bursts_over_20_league_avg != null ? `avg ${e.bursts_over_20_league_avg}` : ''],
        ['HARDEST SHOT', e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : ''],
      ];
      for (let i = 0; i < 4; i++) {
        const col = i % 2, row = Math.floor(i / 2);
        drawEdgeStatBox(ctx, PAD + col * (bw + 10), y + row * (bh + 10), bw, bh, pairs[i][0], pairs[i][1], pairs[i][2], pairs[i][3], false);
      }
      y += 2 * (bh + 10) - 10 + 12;
      y = drawZoneBar(ctx, y, W, PAD, e, TEAM_C);
      y += 12;
      y = drawShotDanger(ctx, y, W, PAD, e);
      y += 10;
      // footer
      ctx.fillStyle = INK10; ctx.fillRect(0, y, W, 36);
      ctx.font = '700 8px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · 2025-26 · EDGE DATA: NHL, INC.', W / 2, y + 18);
      return canvas;
    }

    // ── EDGE card: hero + EDGE data (no percentile bars) ─────────────────
    async function drawEdgeCard() {
      const e = D.edge;
      const W = 560, SCALE = 2, PAD = 20;
      // heights
      const HDR_H = 48, CHIP_H = 32, HERO_H = 88, SEP_H = 1, KPI_H = 60;
      // Traced: divider(24)+gap(8)+pairs(194)+gap(12)+zone(86)+gap(12)+shot(145) = 481 + 8 buffer
      const EDGE_SEC_H = e ? 489 : 80;
      const FOOT_H = 36;
      const TOTAL_H = HDR_H + CHIP_H + HERO_H + SEP_H + KPI_H + 16 + EDGE_SEC_H + 12 + FOOT_H;
      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = TOTAL_H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);
      ctx.fillStyle = '#EFEEE8'; ctx.fillRect(0, 0, W, TOTAL_H);
      let y = 0;
      // uses INK, RED, INK06..INK48, TEAM_C from outer IIFE scope
      const rrect = (ctx, x, y, w, h, r) => { ctx.beginPath(); ctx.roundRect(x, y, w, h, r); };
      // ── Header ───────────────────────────────────────────────────────────
      ctx.fillStyle = '#FFFFFF'; ctx.fillRect(0, y, W, HDR_H);
      ctx.font = '800 22px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText(`${D.firstName.toUpperCase()} ${D.lastName.toUpperCase()}`, PAD, y + HDR_H / 2);
      ctx.fillStyle = INK14; ctx.fillRect(0, y + HDR_H - 1, W, 1);
      y += HDR_H;
      // ── Chips ────────────────────────────────────────────────────────────
      const chips = [D.team, D.posLabel.toUpperCase(), '2025-26', 'HOCKEYGAMEBOT'];
      let cx2 = PAD;
      chips.forEach((txt, i) => {
        ctx.font = '700 8px "JetBrains Mono", monospace';
        const tw = ctx.measureText(txt).width + 16;
        ctx.fillStyle = i === 0 ? TEAM_C : i < 3 ? INK : INK10;
        rrect(ctx, cx2, y + 7, tw, 18, 2); ctx.fill();
        ctx.fillStyle = i < 3 ? '#FFFFFF' : INK;
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText(txt, cx2 + 8, y + 16);
        cx2 += tw + 6;
      });
      y += CHIP_H;
      // ── Hero row ────────────────────────────────────────────────────────
      ctx.fillStyle = '#FFFFFF'; ctx.fillRect(0, y, W, HERO_H);
      ctx.fillStyle = INK06; ctx.fillRect(0, y, W, 1);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, y, 6, HERO_H);
      // headshot circle
      ctx.save();
      ctx.beginPath(); ctx.arc(6 + 14 + 34, y + HERO_H / 2, 34, 0, Math.PI * 2); ctx.clip();
      ctx.fillStyle = INK10; ctx.fillRect(6, y, 82, HERO_H);
      ctx.restore();
      ctx.strokeStyle = INK14; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.arc(6 + 14 + 34, y + HERO_H / 2, 34, 0, Math.PI * 2); ctx.stroke();
      // hero tiles
      const tileX = 100;
      const tiles = [
        [D.warPct != null ? `${D.warPct}%` : '—', D.war != null ? `${D.war >= 0 ? '+' : ''}${D.war.toFixed(2)} WAR` : '—', TEAM_C],
        [D.impactPct != null ? `${Math.round(D.impactPct)}%` : '—', `${D.avgGsDisplay?.toFixed(2) ?? '—'} GS avg`, INK],
        [`${D.gp} GP`, `${D.totalG}G · ${D.totalA}A`, INK],
      ];
      const tileW = (W - tileX) / 3;
      tiles.forEach(([big, small, color], i) => {
        const tx = tileX + i * tileW;
        if (i > 0) { ctx.fillStyle = INK06; ctx.fillRect(tx, y + 16, 1, HERO_H - 32); }
        ctx.font = '800 32px "Barlow Condensed", sans-serif';
        ctx.fillStyle = color; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(big, tx + tileW / 2, y + HERO_H / 2 - 8);
        ctx.font = '400 8.5px "JetBrains Mono", monospace';
        ctx.fillStyle = INK48; ctx.fillText(small, tx + tileW / 2, y + HERO_H / 2 + 14);
      });
      ctx.fillStyle = INK14; ctx.fillRect(0, y + HERO_H - 1, W, 1);
      y += HERO_H + SEP_H;
      // ── KPI strip ────────────────────────────────────────────────────────
      ctx.fillStyle = '#FFFFFF'; ctx.fillRect(0, y, W, KPI_H);
      const kpis = [
        ['G / 60', D.ratesG?.toFixed(2) ?? '—'],['A1 / 60', D.ratesA1?.toFixed(2) ?? '—'],
        ['xG / 60', D.ratesXg?.toFixed(2) ?? '—'],['Finishing', (D.finishing >= 0 ? '+' : '') + D.finishing?.toFixed(2)],
        ['Shots / 60', ((D.totalS ?? 0) / Math.max(D.gp * D.toiAvgSec / 3600, 0.01)).toFixed(1)],
      ];
      kpis.forEach(([lbl, val], i) => {
        const kx = PAD + i * ((W - PAD * 2) / 5);
        if (i > 0) { ctx.fillStyle = INK06; ctx.fillRect(kx, y + 10, 1, KPI_H - 20); }
        ctx.font = '800 20px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(val, kx + (W - PAD * 2) / 10, y + KPI_H / 2 - 6);
        ctx.font = '700 8px "JetBrains Mono", monospace';
        ctx.fillStyle = INK48;
        ctx.fillText(lbl.toUpperCase(), kx + (W - PAD * 2) / 10, y + KPI_H / 2 + 10);
      });
      ctx.fillStyle = INK14; ctx.fillRect(0, y + KPI_H - 1, W, 1);
      y += KPI_H + 16;
      // ── EDGE section ─────────────────────────────────────────────────────
      if (!e) {
        ctx.fillStyle = INK10; ctx.fillRect(PAD, y, W - PAD * 2, 60);
        ctx.font = '700 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('EDGE DATA NOT YET AVAILABLE', W / 2, y + 30);
        y += 72;
      } else {
        y = drawEdgeDivider(ctx, y, W);
        y += 8;
        const bw2 = (W - PAD * 2 - 10) / 2, bh2 = 86;
        const pairs2 = [
          ['TOP SPEED', e.speed_max_mph != null ? `${e.speed_max_mph} mph` : '—', e.speed_max_pct, e.speed_max_league_avg_mph != null ? `avg ${e.speed_max_league_avg_mph} mph` : ''],
          ['MILES SKATED', e.distance_mi != null ? `${e.distance_mi} mi` : '—', e.distance_pct, e.distance_league_avg_mi != null ? `avg ${e.distance_league_avg_mi} mi` : ''],
          ['BURSTS > 20 MPH', e.bursts_over_20 != null ? `${e.bursts_over_20}` : '—', e.bursts_over_20_pct, e.bursts_over_20_league_avg != null ? `avg ${e.bursts_over_20_league_avg}` : ''],
          ['HARDEST SHOT', e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : ''],
        ];
        for (let i = 0; i < 4; i++) {
          const col = i % 2, row = Math.floor(i / 2);
          drawEdgeStatBox(ctx, PAD + col * (bw2 + 10), y + row * (bh2 + 10), bw2, bh2, pairs2[i][0], pairs2[i][1], pairs2[i][2], pairs2[i][3], false);
        }
        y += 2 * (bh2 + 10) - 10 + 12;
        y = drawZoneBar(ctx, y, W, PAD, e, TEAM_C);
        y += 12;
        y = drawShotDanger(ctx, y, W, PAD, e);
        y += 10;
      }
      // ── Footer ───────────────────────────────────────────────────────────
      ctx.fillStyle = INK10; ctx.fillRect(0, y, W, FOOT_H);
      ctx.font = '700 8px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · 2025-26 · EDGE DATA: NHL, INC.', W / 2, y + FOOT_H / 2);
      return canvas;
    }

    // ── Season Card: single-season stats left + EDGE right ───────────────────
    async function drawSeasonCard(selectedSeason) {
      const BG = '#EFEEE8', SURFACE = '#FFFFFF';
      const SCALE = 2;
      const L_W = 520, R_W = 520, W = L_W + R_W;
      const PAD = 24, R_PAD = 20;
      const e = D.edge;

      // Look up season data — current season uses D.percentiles, historical uses _seasonStats
      var seasonData = null;
      if (selectedSeason && selectedSeason !== D.currentSeason) {
        var allSeasons = typeof _seasonStats !== 'undefined' ? _seasonStats : (window._seasonStats || []);
        seasonData = allSeasons.find(function(s) { return s.season === selectedSeason; }) || null;
      }
      var isHistorical = !!seasonData;
      var isLimited = isHistorical && seasonData.limited;

      // Helper to pick current vs historical percentile
      function sp(currentVal, histKey) {
        if (!isHistorical) return currentVal;
        var v = seasonData[histKey];
        return v != null ? v : null;
      }

      // Heights
      const HDR_H = 52, CHIP_H = 34;
      const ID_H = 122, BAR_ROW_H = 29, BAR_ROWS = 11;
      const L_CONTENT_H = 6 + ID_H + 1 + 20 + 12 + BAR_ROWS * BAR_ROW_H + 12;
      const EDGE_CONTENT_H = e ? 473 : 80; // measured: 44(hdr)+194(tiles)+92(zone)+143(shot)
      const CONTENT_H = Math.max(L_CONTENT_H, EDGE_CONTENT_H);
      const FOOT_H = 36;
      const H = HDR_H + CHIP_H + CONTENT_H + FOOT_H;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // Background + left accent bar
      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 4, H);

      // ── SHARED HEADER (white band) ─────────────────────────────────────────
      ctx.fillStyle = SURFACE; ctx.fillRect(0, 0, W, HDR_H + CHIP_H);
      ctx.fillStyle = INK14; ctx.fillRect(0, HDR_H + CHIP_H - 1, W, 1);

      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, HDR_H / 2);
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
      ctx.fillText('SEASON CARD · 2025-26', W - PAD, HDR_H / 2);

      // Chips
      const TEAM_NAMES_S = { ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS' };
      const chipH = 18, chipY0 = HDR_H + (CHIP_H - chipH) / 2;
      const chips = [(TEAM_NAMES_S[D.team] || D.team), D.posLabel.toUpperCase(), '2025-26'];
      let cx = PAD;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chips.length; ci++) {
        const cw = ctx.measureText(chips[ci]).width + 18;
        rrect(ctx, cx, chipY0, cw, chipH, 3);
        ctx.fillStyle = ci === 0 ? TEAM_C : INK; ctx.fill();
        ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
        cx += cw + 8;
      }
      const brand = 'HOCKEYGAMEBOT';
      const bcw = ctx.measureText(brand).width + 18;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);

      // Panel divider
      ctx.fillStyle = INK14; ctx.fillRect(L_W, HDR_H + CHIP_H, 1, CONTENT_H);

      // ── LEFT PANEL — identity + single-season bars ─────────────────────────
      let y = HDR_H + CHIP_H + 6;

      const R = 36, HS_CX = PAD + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(D.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) { ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2); }
      else { ctx.fillStyle = INK10; ctx.fill(); }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      const heroX = HS_CX + R + 18;
      const heroW = (L_W - heroX - PAD) / 3;
      var heroRatingPct = isHistorical ? seasonData.hgb_rating_pct : D.hgb_rating_percentile;
      var heroWarPct    = isHistorical ? seasonData.war_pct        : D.warPct;
      var heroImpPct    = isHistorical ? seasonData.impact_pct     : (D.impactPct != null ? Math.round(D.impactPct) : null);
      var heroSeason    = isHistorical ? selectedSeason : (D.currentSeason || '2025-26');
      var heroGp        = isHistorical ? (seasonData.gp || '—') : D.gp;
      const heroTiles = [
        { label: 'HGB RATING', pct: heroRatingPct, sub: heroSeason + ' · ' + heroGp + ' GP' + (isLimited ? ' · limited sample' : '') },
        { label: 'HGB WAR',    pct: heroWarPct,    sub: heroSeason },
        { label: 'HGB IMPACT', pct: heroImpPct,    sub: heroSeason },
      ];
      for (let i = 0; i < heroTiles.length; i++) {
        const t = heroTiles[i];
        const tcx = heroX + i * heroW + heroW / 2;
        if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(heroX + i * heroW, y + 18, 1, ID_H - 36); }
        ctx.font = '700 9px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText(t.label, tcx, y + 20);
        ctx.font = '900 36px "Barlow Condensed", sans-serif';
        ctx.fillStyle = t.pct != null ? TEAM_C : INK32;
        ctx.fillText(t.pct != null ? t.pct + '%' : '—', tcx, y + 33);
        ctx.font = '800 12px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK48; ctx.textBaseline = 'top';
        ctx.fillText(t.sub, tcx, y + 78);
      }
      y += ID_H;
      ctx.fillStyle = INK14; ctx.fillRect(0, y, L_W, 1); y += 1 + 20;

      // Section header
      const isF = D.posGroup === 'F';
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK48; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('SINGLE SEASON', PAD, y);
      var ssW = ctx.measureText('SINGLE SEASON').width;
      ctx.fillStyle = RED;
      ctx.fillText('  ' + (isF ? 'VS. FORWARDS' : 'VS. DEFENSEMEN'), PAD + ssW, y);
      y += 12;

      // Single-season bars
      const pct = D.percentiles;
      const bars_ev_off  = sp(pct.ev_offence,  'rapm_off_pct');
      const bars_ev_def  = sp(pct.ev_defence,  'rapm_def_pct');
      const bars_goals   = sp(pct.goals,        'goals_pct');
      const bars_a1      = sp(pct.a1,           'a1_pct');
      const bars_ixg     = sp(pct.ixg,          'ixg_pct');
      const bars_fin     = sp(pct.finishing,     'rapm_finishing_pct');
      const bars_pen     = sp(pct.pen_diff,      'pen_diff_pct');
      const bars_pp      = sp(pct.pp_off ?? null,'rapm_pp_pct');
      const bars_pk      = sp(pct.pk_def ?? null,'rapm_pk_pct');
      const bars_qoc     = sp(D.qoc,             'qoc_pct');
      const bars_qot     = sp(D.qot,             'qot_pct');
      function barFillS(v, kind) {
        if (kind === 'context') return '#4285f4';
        if (v == null) return 'rgba(13,13,20,0.20)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.35)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      function pctColorS(v, kind) {
        if (kind === 'context') return '#4285f4';
        if (v == null) return 'rgba(13,13,20,0.35)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.50)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      const bars = [
        { label: 'EV Offense',   val: bars_ev_off, kind: 'performance' },
        { label: 'EV Defense',   val: bars_ev_def, kind: 'context'     },
        { label: 'Goals / 60',   val: bars_goals,  kind: 'performance' },
        { label: 'A1 / 60',      val: bars_a1,     kind: 'performance' },
        { label: 'xG / 60',      val: bars_ixg,    kind: 'performance' },
        { label: 'Finishing',    val: bars_fin,    kind: 'performance' },
        { label: 'Pen. Diff',    val: bars_pen,    kind: 'performance' },
        { label: 'Power Play',   val: bars_pp,     kind: 'performance' },
        { label: 'Penalty Kill', val: bars_pk,     kind: 'performance' },
        { label: 'Opp. Quality', val: bars_qoc,    kind: 'context'     },
        { label: 'Mate Quality', val: bars_qot,    kind: 'context'     },
      ];
      const BAR_H_PX = 13, BAR_LABEL_W = 96, BAR_RANK_W = 40;
      const BAR_AVAIL = L_W - PAD * 2 - BAR_LABEL_W - BAR_RANK_W - 8;
      for (let bi = 0; bi < bars.length; bi++) {
        const b = bars[bi], rowY = y + bi * BAR_ROW_H, bby = rowY + (BAR_ROW_H - BAR_H_PX) / 2;
        ctx.font = '600 11px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(b.label, PAD, rowY + BAR_ROW_H / 2);
        const bx = PAD + BAR_LABEL_W;
        rrect(ctx, bx, bby, BAR_AVAIL, BAR_H_PX, 3); ctx.fillStyle = INK10; ctx.fill();
        if (b.val != null) {
          rrect(ctx, bx, bby, Math.max(6, (b.val / 100) * BAR_AVAIL), BAR_H_PX, 3);
          ctx.fillStyle = barFillS(b.val, b.kind); ctx.fill();
        }
        ctx.font = '800 15px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        ctx.fillStyle = b.val == null ? 'rgba(13,13,20,0.32)' : pctColorS(b.val, b.kind);
        ctx.fillText(b.val == null ? '—' : Math.round(b.val) + '%', L_W - PAD, rowY + BAR_ROW_H / 2);
      }

      // ── RIGHT PANEL — NHL EDGE ─────────────────────────────────────────────
      const RX = L_W + 1;
      let ry = HDR_H + CHIP_H;
      if (!e) {
        ctx.fillStyle = INK10; ctx.fillRect(RX, ry, R_W, CONTENT_H);
        ctx.font = '700 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('EDGE DATA NOT YET AVAILABLE', RX + R_W / 2, ry + CONTENT_H / 2);
      } else {
        // EDGE header
        const EDGE_HDR_H = 36;
        ctx.fillStyle = INK14; ctx.fillRect(RX, ry + EDGE_HDR_H - 1, R_W, 1);
        ctx.font = '800 13px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillStyle = INK; ctx.fillText('NHL EDGE ', RX + R_PAD, ry + EDGE_HDR_H / 2);
        const edgeLabelW = ctx.measureText('NHL EDGE ').width;
        ctx.fillStyle = '#006D75'; ctx.fillText('TRACKING', RX + R_PAD + edgeLabelW, ry + EDGE_HDR_H / 2);
        ry += EDGE_HDR_H + 8;

        // 2×2 stat tiles
        const tileW = (R_W - R_PAD * 2 - 10) / 2, tileH = 86;
        const pairs = [
          ['TOP SPEED',      e.speed_max_mph != null ? e.speed_max_mph + ' mph' : '—',       e.speed_max_pct,      e.speed_max_league_avg_mph != null ? 'avg ' + e.speed_max_league_avg_mph + ' mph' : '', false],
          ['MILES SKATED',   e.distance_mi   != null ? e.distance_mi + ' mi' : '—',          e.distance_pct,       e.distance_league_avg_mi != null ? 'avg ' + e.distance_league_avg_mi + ' mi' : '',  false],
          ['BURSTS > 20 MPH',e.bursts_over_20 != null ? String(e.bursts_over_20) : '—',      e.bursts_over_20_pct, e.bursts_over_20_league_avg != null ? 'avg ' + e.bursts_over_20_league_avg : '',     false],
          ['HARDEST SHOT',   e.shot_speed_max_mph != null ? e.shot_speed_max_mph + ' mph' : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? 'avg ' + e.shot_speed_max_league_avg_mph + ' mph' : '', false],
        ];
        for (let i = 0; i < 4; i++) {
          const col = i % 2, row = Math.floor(i / 2);
          drawEdgeStatBox(ctx, RX + R_PAD + col * (tileW + 10), ry + row * (tileH + 10), tileW, tileH, pairs[i][0], pairs[i][1], pairs[i][2], pairs[i][3], pairs[i][4]);
        }
        ry += 2 * (tileH + 10) - 10 + 12;
        // Zone bar (abbreviated labels to avoid overflow in narrow segments)
        const oz2 = e.oz_pct ?? 45, nz2 = e.nz_pct ?? 32, dz2 = e.dz_pct ?? 23;
        const zbw = R_W - R_PAD * 2, zbx = RX + R_PAD;
        ctx.fillStyle = '#FFFFFF'; ctx.beginPath(); ctx.roundRect(zbx, ry - 10, zbw, 90, 4); ctx.fill();
        ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(zbx, ry - 10, zbw, 90, 4); ctx.stroke();
        ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
        ctx.fillText('ZONE TIME — EVEN STRENGTH', zbx + 6, ry - 4);
        if (e.oz_ev_pct_pct != null) {
          ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
          ctx.fillText('OZ: ' + Math.round(e.oz_ev_pct_pct) + 'th', RX + R_W - R_PAD, ry - 4);
        }
        ry += 14;
        ctx.save(); ctx.beginPath(); ctx.roundRect(zbx, ry, zbw, 20, 3); ctx.clip();
        ctx.fillStyle = TEAM_C;                    ctx.fillRect(zbx,                      ry, zbw * oz2 / 100, 20);
        ctx.fillStyle = 'rgba(13,13,20,0.18)';     ctx.fillRect(zbx + zbw * oz2 / 100,    ry, zbw * nz2 / 100, 20);
        ctx.fillStyle = 'rgba(232,0,45,0.30)';     ctx.fillRect(zbx + zbw*(oz2+nz2)/100,  ry, zbw * dz2 / 100, 20);
        ctx.restore();
        ry += 26;
        const zSegs2 = [['OZ', oz2.toFixed(0) + '%', oz2], ['NZ', nz2.toFixed(0) + '%', nz2], ['DZ', dz2.toFixed(0) + '%', dz2]];
        let zlx = zbx + 6;
        for (let zi = 0; zi < zSegs2.length; zi++) {
          const [abbr, pctStr, w] = zSegs2[zi];
          ctx.font = '800 14px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK; ctx.textBaseline = 'top'; ctx.textAlign = 'left';
          ctx.fillText(pctStr, zlx, ry);
          ctx.font = '600 7px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
          ctx.fillText(abbr, zlx, ry + 17);
          zlx += zbw * w / 100;
        }
        ry += 40 + 12;

        // Shot danger — clip to tile area width so helper's -2/+4 background doesn't overflow
        ctx.save();
        ctx.translate(RX, 0);
        ctx.beginPath(); ctx.rect(R_PAD, 0, R_W - R_PAD * 2, H); ctx.clip();
        ry = drawShotDanger(ctx, ry, R_W, R_PAD, e) + 10;
        ctx.restore();
      }

      // Footer
      ctx.fillStyle = INK10; ctx.fillRect(0, H - FOOT_H, W, FOOT_H);
      ctx.font = '700 8px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · 2025-26 · EDGE DATA: NHL, INC.', W / 2, H - FOOT_H / 2);

      return canvas;
    }

    // ── Season WAR card ────────────────────────────────────────────────────── (removed)
    async function drawSeasonWARCard(selectedSeason) {
      const BG = '#EFEEE8', SURFACE = '#FFFFFF';
      const W = 560, SCALE = 2, PAD = 24;
      const wc = D.war_components;
      const e  = D.edge;

      // ── WAR section layout ──
      const WAR_ROWS = 6, WAR_ROW_H = 34, WAR_LABEL_W = 148, BAR_TOTAL_W = W - PAD * 2 - WAR_LABEL_W - 44;
      const WAR_SCALE = 3.0; // ±3.0 = full bar
      const WAR_SECTION_H = 16 + WAR_ROWS * WAR_ROW_H + 8 + 34 + 16; // label + rows + sep + total + pad
      // ── EDGE section (reuse helpers) ──
      const EDGE_H = e ? 541 : 48;
      // ── Header + identity (same as drawCard) ──
      const HDR_H = 48, CHIP_H = 30, ID_H = 100, SEP_H = 1;
      const FOOT_H = 36;
      const TOTAL_H = HDR_H + CHIP_H + 6 + ID_H + SEP_H + 16 + WAR_SECTION_H + EDGE_H + FOOT_H;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = TOTAL_H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // ── background ──
      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, TOTAL_H);

      // ── team color bar ──
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, W, 5);

      let y = 5;

      // ── header strip ──
      ctx.fillStyle = BG;
      ctx.font = '700 9px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText('HOCKEYGAMEBOT', PAD, y + HDR_H / 2);
      ctx.textAlign = 'right';
      ctx.fillText('HGB STATS', W - PAD, y + HDR_H / 2);
      y += HDR_H;

      // ── season chip ──
      ctx.fillStyle = TEAM_C;
      const chipTxt = selectedSeason + ' · PLAYER SEASON CARD';
      const chipW = ctx.measureText(chipTxt).width + 24;
      rrect(ctx, PAD, y + 5, chipW, 20, 3);
      ctx.fill();
      ctx.font = '700 9px "JetBrains Mono", monospace';
      ctx.fillStyle = '#fff'; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText(chipTxt, PAD + 12, y + 15);
      y += CHIP_H + 6;

      // ── identity block ──
      const hs = await loadImg(D.headshotUrl);
      const HS = 72;
      ctx.save();
      ctx.beginPath(); ctx.arc(PAD + HS / 2, y + HS / 2, HS / 2, 0, Math.PI * 2); ctx.clip();
      if (hs) ctx.drawImage(hs, PAD, y, HS, HS);
      ctx.restore();
      ctx.font = '800 26px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText(D.firstName.toUpperCase(), PAD + HS + 14, y + 4);
      ctx.font = '800 26px "Barlow Condensed", sans-serif'; ctx.fillStyle = TEAM_C;
      ctx.fillText(D.lastName.toUpperCase(), PAD + HS + 14, y + 32);
      ctx.font = '500 10px "JetBrains Mono", monospace'; ctx.fillStyle = INK48;
      ctx.textBaseline = 'middle';
      ctx.fillText(`${D.team} · ${D.pos} · ${D.gp} GP · ${selectedSeason}`, PAD + HS + 14, y + 68);
      const warSign = D.war != null && D.war >= 0 ? '+' : '';
      ctx.font = '700 10px "JetBrains Mono", monospace'; ctx.fillStyle = TEAM_C;
      ctx.fillText(`${warSign}${D.war?.toFixed(2) ?? '—'} WAR  ·  ${D.warPct ?? '—'}%ile`, PAD + HS + 14, y + 86);
      y += ID_H;

      // ── separator ──
      ctx.fillStyle = INK14; ctx.fillRect(0, y, W, 1); y += 1 + 16;

      // ── WAR section label ──
      ctx.font = '700 9px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText('WAR BREAKDOWN', PAD, y + 7);
      ctx.fillStyle = INK14; ctx.fillRect(PAD + ctx.measureText('WAR BREAKDOWN').width + 8, y + 7, W - PAD * 2 - ctx.measureText('WAR BREAKDOWN').width - 8, 1);
      y += 16;

      // ── WAR component rows ──
      const warRows = [
        { label: 'EV OFFENCE',  val: wc?.ev_off_war    ?? null },
        { label: 'EV DEFENCE',  val: wc?.ev_def_war    ?? null },
        { label: 'FINISHING',   val: wc?.finishing_war ?? null },
        { label: 'POWERPLAY',   val: wc?.pp            ?? null },
        { label: 'PENALTY KILL', val: wc?.pk           ?? null },
        { label: 'PENALTIES',   val: wc?.pen           ?? null },
      ];

      const ZERO_X = PAD + WAR_LABEL_W + (BAR_TOTAL_W / 2); // zero line x

      for (const row of warRows) {
        const v = row.val ?? 0;
        const barPx = Math.min(Math.abs(v) / WAR_SCALE, 1.0) * (BAR_TOTAL_W / 2);
        const isPos = v >= 0;
        const barColor = isPos ? '#137333' : '#991b1b';
        const dimColor = 'rgba(13,13,20,0.08)';

        // row bg on hover area
        const ry = y + (WAR_ROW_H - 20) / 2;

        // label
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK48; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText(row.label, PAD, y + WAR_ROW_H / 2);

        // bar track
        ctx.fillStyle = dimColor; ctx.fillRect(PAD + WAR_LABEL_W, ry, BAR_TOTAL_W, 20);

        // zero line
        ctx.fillStyle = INK32; ctx.fillRect(ZERO_X, ry, 1, 20);

        // filled bar
        ctx.fillStyle = row.val == null ? INK14 : barColor;
        if (isPos) ctx.fillRect(ZERO_X, ry, barPx, 20);
        else       ctx.fillRect(ZERO_X - barPx, ry, barPx, 20);

        // value label
        const valStr = row.val == null ? '—' : (v >= 0 ? '+' : '') + v.toFixed(2);
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = row.val == null ? INK32 : barColor;
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        ctx.fillText(valStr, W - PAD, y + WAR_ROW_H / 2);

        y += WAR_ROW_H;
      }

      // ── total row ──
      y += 8;
      ctx.fillStyle = INK14; ctx.fillRect(PAD, y, W - PAD * 2, 1); y += 10;
      ctx.font = '800 12px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText('TOTAL WAR', PAD, y + 12);
      const totStr = D.war != null ? (D.war >= 0 ? '+' : '') + D.war.toFixed(2) : '—';
      ctx.font = '800 14px "Barlow Condensed", sans-serif'; ctx.fillStyle = TEAM_C;
      ctx.textAlign = 'right';
      ctx.fillText(totStr, W - PAD, y + 12);
      y += 34 + 16;

      // ── EDGE section ──
      if (e) {
        y = drawEdgeDivider(ctx, y, W) + 8;
        const bw = (W - PAD * 2 - 10) / 2, bh = 86;
        const pairs = [
          ['TOP SPEED',      e.speed_max_mph != null ? `${e.speed_max_mph} mph` : '—',    e.speed_max_pct,     e.speed_max_league_avg_mph    != null ? `avg ${e.speed_max_league_avg_mph} mph` : ''],
          ['MILES SKATED',   e.distance_mi   != null ? `${e.distance_mi} mi` : '—',       e.distance_pct,      e.distance_league_avg_mi      != null ? `avg ${e.distance_league_avg_mi} mi` : ''],
          ['BURSTS > 20 MPH',e.bursts_over_20 != null ? `${e.bursts_over_20}` : '—',      e.bursts_over_20_pct,e.bursts_over_20_league_avg   != null ? `avg ${e.bursts_over_20_league_avg}` : ''],
          ['HARDEST SHOT',   e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : ''],
        ];
        for (let i = 0; i < 4; i++) {
          const col = i % 2, row_i = Math.floor(i / 2);
          drawEdgeStatBox(ctx, PAD + col * (bw + 10), y + row_i * (bh + 10), bw, bh, pairs[i][0], pairs[i][1], pairs[i][2], pairs[i][3], false);
        }
        y += 2 * (bh + 10) - 10 + 12;
        y = drawZoneBar(ctx, y, W, PAD, e, TEAM_C) + 12;
        y = drawShotDanger(ctx, y, W, PAD, e) + 10;
      }

      // ── footer ──
      ctx.fillStyle = INK10; ctx.fillRect(0, TOTAL_H - FOOT_H, W, FOOT_H);
      ctx.font = '700 8px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · ' + selectedSeason + ' · EDGE DATA: NHL, INC.', W / 2, TOTAL_H - FOOT_H / 2);

      return canvas;
    }

    // ── Landscape card: portrait left (560px) + teal divider + EDGE right (339px) ──
    async function drawLandscapeCard() {
      const SCALE   = 2;
      const PORT_W  = 560;
      const DIV_W   = 1;
      const RIGHT_W = 339;
      const TOTAL_W = PORT_W + DIV_W + RIGHT_W;   // 900
      const FOOT_H  = 36;
      const PAD     = 16;
      const TEAL    = '#006D75';

      // Build portrait first — its height determines the landscape height
      const portrait = await drawCard();
      const TOTAL_H  = portrait.height / SCALE;

      const canvas  = document.createElement('canvas');
      canvas.width  = TOTAL_W * SCALE;
      canvas.height = TOTAL_H * SCALE;
      const ctx     = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      ctx.fillStyle = '#EFEEE8'; ctx.fillRect(0, 0, TOTAL_W, TOTAL_H);
      // Copy portrait to the left
      ctx.drawImage(portrait, 0, 0, PORT_W * SCALE, TOTAL_H * SCALE, 0, 0, PORT_W, TOTAL_H);
      // Teal 1px divider
      ctx.fillStyle = TEAL; ctx.fillRect(PORT_W, 0, DIV_W, TOTAL_H);

      const RX = PORT_W + DIV_W;
      const e  = D.edge;

      if (!e) {
        ctx.fillStyle = INK10; ctx.fillRect(RX, 0, RIGHT_W, TOTAL_H);
        ctx.font = '700 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('EDGE DATA NOT AVAILABLE', RX + RIGHT_W / 2, TOTAL_H / 2);
        return canvas;
      }

      let ry = 0;

      // ── Edge header (40px) ───────────────────────────────────────────────
      const EDGE_HDR_H = 40;
      ctx.fillStyle = INK14; ctx.fillRect(RX, ry + EDGE_HDR_H - 1, RIGHT_W, 1);
      ctx.font = '800 13px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText('NHL EDGE', RX + PAD, ry + EDGE_HDR_H / 2);
      ctx.fillStyle = TEAL; ctx.textAlign = 'right';
      ctx.fillText('TRACKING', RX + RIGHT_W - PAD, ry + EDGE_HDR_H / 2);
      ry += EDGE_HDR_H;

      // ── 2×2 stat tiles ───────────────────────────────────────────────────
      const TILE_PAD_V = 10;
      const TILE_GAP   = 8;
      const tileW      = (RIGHT_W - PAD * 2 - TILE_GAP) / 2;
      const TILE_H     = 80;
      const tilePairs  = [
        ['TOP SPEED',      e.speed_max_mph    != null ? `${e.speed_max_mph} mph`     : '—', e.speed_max_pct,       e.speed_max_league_avg_mph   != null ? `avg ${e.speed_max_league_avg_mph} mph`   : ''],
        ['MILES SKATED',   e.distance_mi      != null ? `${e.distance_mi} mi`        : '—', e.distance_pct,        e.distance_league_avg_mi     != null ? `avg ${e.distance_league_avg_mi} mi`     : ''],
        ['BURSTS >20 MPH', e.bursts_over_20   != null ? `${e.bursts_over_20}`        : '—', e.bursts_over_20_pct,  e.bursts_over_20_league_avg  != null ? `avg ${e.bursts_over_20_league_avg}`     : ''],
        ['HARDEST SHOT',   e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : ''],
      ];
      const tilesStartY = ry + TILE_PAD_V;
      for (let i = 0; i < 4; i++) {
        const col = i % 2, row = Math.floor(i / 2);
        drawEdgeStatBox(ctx, RX + PAD + col * (tileW + TILE_GAP), tilesStartY + row * (TILE_H + TILE_GAP), tileW, TILE_H, ...tilePairs[i]);
      }
      ry = tilesStartY + 2 * (TILE_H + TILE_GAP) - TILE_GAP + TILE_PAD_V;

      // ── Zone time ─────────────────────────────────────────────────────────
      ctx.fillStyle = INK14; ctx.fillRect(RX + PAD, ry, RIGHT_W - PAD * 2, 1); ry += 9;
      ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
      ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('ZONE TIME — EVEN STRENGTH', RX + PAD, ry);
      if (e.oz_ev_pct_pct != null) {
        ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = TEAL; ctx.textAlign = 'right';
        ctx.fillText(`OZ: ${Math.round(e.oz_ev_pct_pct)}th`, RX + RIGHT_W - PAD, ry);
      }
      ry += 14;
      const oz = e.oz_pct ?? 45, nz = e.nz_pct ?? 32, dz = e.dz_pct ?? 23;
      const zbw = RIGHT_W - PAD * 2, zbx = RX + PAD;
      ctx.save(); ctx.beginPath(); ctx.roundRect(zbx, ry, zbw, 20, 3); ctx.clip();
      ctx.fillStyle = TEAL;                       ctx.fillRect(zbx,                     ry, zbw * oz / 100,   20);
      ctx.fillStyle = 'rgba(13,13,20,0.18)';      ctx.fillRect(zbx + zbw * oz / 100,    ry, zbw * nz / 100,   20);
      ctx.fillStyle = 'rgba(232,0,45,0.30)';      ctx.fillRect(zbx + zbw*(oz+nz)/100,   ry, zbw * dz / 100,   20);
      ctx.restore();
      ry += 26;
      const zSegs = [['OZ', `${oz.toFixed(0)}%`, oz], ['NZ', `${nz.toFixed(0)}%`, nz], ['DZ', `${dz.toFixed(0)}%`, dz]];
      let lx2 = zbx;
      for (const [name, pctStr, w] of zSegs) {
        ctx.font = '800 14px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
        ctx.textAlign = 'left'; ctx.textBaseline = 'top'; ctx.fillText(pctStr, lx2, ry);
        ctx.font = '600 7px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
        ctx.fillText(name, lx2, ry + 16); lx2 += zbw * w / 100;
      }
      ry += 30;

      // ── Shot location — 3 horizontal rows (fills remaining height) ────────
      ctx.fillStyle = INK14; ctx.fillRect(RX + PAD, ry, RIGHT_W - PAD * 2, 1); ry += 9;
      ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
      ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('SHOT LOCATION BY DANGER ZONE', RX + PAD, ry); ry += 14;

      const shotZones = [
        { chip: 'HIGH DGR',  n: e.shots_high, np: e.shots_high_pct, sh: e.shooting_pct_high, shp: e.shooting_pct_high_pct, hi: true  },
        { chip: 'MID RANGE', n: e.shots_mid,  np: e.shots_mid_pct,  sh: e.shooting_pct_mid,  shp: e.shooting_pct_mid_pct,  hi: false },
        { chip: 'LNG RANGE', n: e.shots_long, np: e.shots_long_pct, sh: e.shooting_pct_long, shp: e.shooting_pct_long_pct, hi: false },
      ];
      const shotRowH = (TOTAL_H - FOOT_H - ry) / 3;
      const CHIP_W   = 72;
      const STAT_GAP = 8;
      const statW    = (RIGHT_W - PAD * 2 - CHIP_W - 10 - STAT_GAP) / 2;

      for (let zi = 0; zi < 3; zi++) {
        const z    = shotZones[zi];
        const rowY = ry + zi * shotRowH;
        if (zi > 0) { ctx.fillStyle = INK06; ctx.fillRect(RX + PAD, rowY, RIGHT_W - PAD * 2, 1); }

        // zone chip
        const chipX = RX + PAD;
        const chipY = rowY + (shotRowH - 22) / 2;
        ctx.beginPath(); ctx.roundRect(chipX, chipY, CHIP_W, 22, 3);
        if (z.hi) {
          const r2 = parseInt(TEAM_C.slice(1,3),16), g3 = parseInt(TEAM_C.slice(3,5),16), b3 = parseInt(TEAM_C.slice(5,7),16);
          ctx.fillStyle = `rgba(${r2},${g3},${b3},0.14)`;
        } else {
          ctx.fillStyle = INK06;
        }
        ctx.fill();
        ctx.font = '800 7px "Barlow Condensed", sans-serif';
        ctx.fillStyle = z.hi ? TEAM_C : INK45;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(z.chip, chipX + CHIP_W / 2, chipY + 11);

        // two mini-stat blocks (ATTEMPTS | SHOOT%)
        const contentH   = 56;
        const contentTop = rowY + (shotRowH - contentH) / 2;
        const stat1X = RX + PAD + CHIP_W + 10;
        const stat2X = stat1X + statW + STAT_GAP;

        function drawMiniStat(sx, displayVal, pctVal, label) {
          const pctC = edgeTierColor(pctVal, false);
          ctx.font = '600 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
          ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(label, sx, contentTop);
          ctx.font = '800 24px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
          ctx.fillText(displayVal != null ? `${displayVal}` : '—', sx, contentTop + 11);
          ctx.font = '600 11px "Barlow", sans-serif'; ctx.fillStyle = pctC;
          ctx.fillText(pctVal != null ? `${Math.round(pctVal)}th` : '', sx, contentTop + 36);
          ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(sx, contentTop + 50, statW - 2, 4, 2); ctx.fill();
          if (pctVal != null) {
            ctx.fillStyle = pctC; ctx.beginPath();
            ctx.roundRect(sx, contentTop + 50, Math.max(3, (pctVal / 100) * (statW - 2)), 4, 2); ctx.fill();
          }
        }

        drawMiniStat(stat1X, z.n,                              z.np,  'ATTEMPTS');
        drawMiniStat(stat2X, z.sh != null ? `${z.sh}%` : null, z.shp, 'SHOOTING%');
      }

      // ── Footer ───────────────────────────────────────────────────────────
      ctx.fillStyle = INK06; ctx.fillRect(RX, TOTAL_H - FOOT_H, RIGHT_W, FOOT_H);
      ctx.font = '700 8px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('EDGE DATA: NHL, INC.', RX + RIGHT_W / 2, TOTAL_H - FOOT_H / 2);

      return canvas;
    }

    // ── HGB Rating Card (JFresh-style blended component card) ────────────
    // ── Rating Card — portrait 520×720, 3-year talent profile ──────────────
    // Clean shareable card focused on the 3-year weighted talent profile.
    // Header is copied exactly from drawCard's header/chips block.
    async function drawRatingCard() {
      const BG      = '#EFEEE8';
      const SURFACE = '#FFFFFF';
      const SCALE   = 2;
      const W       = 520;
      const PAD     = 28;

      // Compute content height: header+chips(86) + gap(6) + identity(122) + sep(1)
      // + section gap(20) + section label(12) + 11 bars(363) + bottom pad(12) + footer(36)
      const _HDR = 52, _CHIP = 34, _ID = 122, _BAR_ROWS = 11, _BAR_ROW = 33, _FOOT = 36;
      const H = _HDR + _CHIP + 6 + _ID + 1 + 20 + 12 + _BAR_ROWS * _BAR_ROW + 12 + _FOOT;

      const canvas = document.createElement('canvas');
      canvas.width  = W * SCALE;
      canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // background
      ctx.fillStyle = BG;
      ctx.fillRect(0, 0, W, H);

      // team full name lookup (same table as drawCard)
      const TEAM_NAMES = {
        ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',
        BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',
        CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',
        DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',
        FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',
        MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',
        NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',
        PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',
        SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',
        TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',
        VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS',
      };
      const teamFullName = TEAM_NAMES[D.team] || D.team;

      let y = 0;

      // ════════ SECTION 1 — WHITE BAND: orange accent bar + name + chips ════════
      const HDR_H  = 52;
      const CHIP_H = 34;

      // White fills the full name+chips area; orange accent bar spans the full white band
      ctx.fillStyle = SURFACE;
      ctx.fillRect(0, y, W, HDR_H + CHIP_H);
      // Orange left accent bar — 4px, full height of white band
      ctx.fillStyle = TEAM_C;
      ctx.fillRect(0, y, 4, HDR_H + CHIP_H);
      // Player name
      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK;
      ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, y + HDR_H / 2);
      y += HDR_H;

      // Chips row — team | position | season  +  HOCKEYGAMEBOT (right)
      // Still inside the white band (white fill covers HDR_H + CHIP_H)
      const chipH = 18, chipY0 = y + (CHIP_H - chipH) / 2;
      const chips = [teamFullName, D.posLabel.toUpperCase(), '2025-26'];
      let cx = PAD;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chips.length; ci++) {
        const tw = ctx.measureText(chips[ci]).width;
        const cw = tw + 18;
        rrect(ctx, cx, chipY0, cw, chipH, 3);
        ctx.fillStyle = ci === 0 ? TEAM_C : INK;
        ctx.fill();
        ctx.fillStyle = BG;
        ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
        cx += cw + 8;
      }
      const brand = 'HOCKEYGAMEBOT';
      const btw = ctx.measureText(brand).width;
      const bcw = btw + 18;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);
      // Bottom border of white band
      ctx.fillStyle = 'rgba(13,13,20,0.08)';
      ctx.fillRect(0, y + CHIP_H - 1, W, 1);
      y += CHIP_H;

      // ════════ SECTION 2 — IDENTITY ROW (headshot + 3 hero tiles) ════════
      const ID_H = 122;
      y += 6;

      // headshot circle (same style as drawCard — team-color border)
      const R = 36, HS_CX = PAD + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(D.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
      } else {
        ctx.fillStyle = INK10; ctx.fill();
        ctx.font = '800 24px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText((D.firstName[0] + D.lastName[0]).toUpperCase(), HS_CX, HS_CY);
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      // 3 hero tiles to the right of headshot
      const heroX  = HS_CX + R + 18;
      const heroW  = (W - heroX - PAD) / 3;

      const ratingPctVal = D.hgb_rating_percentile;
      const ratingRawStr = D.hgb_rating != null
        ? (D.hgb_rating >= 0 ? '+' : '') + D.hgb_rating.toFixed(2) + ' Rating'
        : '—';
      const warPctVal  = D.warPct  ?? (D.impactPct != null ? Math.round(D.impactPct) : null);
      const impPctVal  = D.impactPct != null ? Math.round(D.impactPct) : null;
      const warRawStr  = D.war != null ? D.war.toFixed(2) + ' WAR' : '—';
      const impRawStr  = D.avgGsDisplay != null ? D.avgGsDisplay.toFixed(2) + ' Avg' : '—';

      const heroTiles = [
        { label: 'HGB RATING', pct: ratingPctVal, sub: ratingRawStr, tag: '' },
        { label: 'HGB WAR',    pct: warPctVal,    sub: warRawStr,    tag: '2025-26' },
        { label: 'HGB IMPACT', pct: impPctVal,    sub: impRawStr,    tag: '2025-26' },
      ];
      for (let i = 0; i < heroTiles.length; i++) {
        const t  = heroTiles[i];
        const tcx = heroX + i * heroW + heroW / 2;
        if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(heroX + i * heroW, y + 18, 1, ID_H - 36); }
        // label
        ctx.font = '700 9px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText(t.label, tcx, y + 20);
        // big percentile
        ctx.font = '900 36px "Barlow Condensed", sans-serif';
        ctx.fillStyle = t.pct != null ? TEAM_C : INK32;
        ctx.fillText(t.pct != null ? t.pct + '%' : '—', tcx, y + 33);
        // sub raw value
        ctx.font = '800 12px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK48; ctx.textBaseline = 'top';
        ctx.fillText(t.sub, tcx, y + 78);
        // small season tag (current-season signal)
        if (t.tag) {
          ctx.font = '700 8px "JetBrains Mono", monospace';
          ctx.fillStyle = INK32; ctx.textBaseline = 'top';
          ctx.fillText(t.tag, tcx, y + 96);
        }
      }
      y += ID_H;

      // separator
      ctx.fillStyle = INK14; ctx.fillRect(0, y, W, 1); y += 1;

      // ════════ SECTION 3 — 3-YEAR PROFILE BARS ════════
      y += 20;

      // section header: eyebrow + red "VS. X" + right-aligned meta
      const isF = D.posGroup === 'F';
      const vsLabel = isF ? 'VS. FORWARDS' : 'VS. DEFENSEMEN';
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK48; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('3-YEAR PROFILE', PAD, y);
      const eyeW = ctx.measureText('3-YEAR PROFILE').width;
      ctx.fillStyle = RED;
      ctx.fillText('  ' + vsLabel, PAD + eyeW, y);
      // right-aligned meta: clarifies the Rating blend window per strength state
      ctx.font = '400 8px "JetBrains Mono", monospace';
      ctx.fillStyle = INK32; ctx.textAlign = 'right';
      ctx.fillText('Rating: EV 3yr blended · PP/PK current season', W - PAD, y);
      ctx.textAlign = 'left';
      y += 12;

      // 11 bars, single column. Fall back to season percentiles when 3yr null.
      const pct3 = D.percentiles;
      const v3 = (a, b) => (a != null ? a : (b != null ? b : null));
      // kind: 'context' → blue (deployment context / QoC / QoT / EV-defense isn't
      // raw player skill, so it shouldn't use the green→red "good/bad" scale).
      // All other bars default to the 5-tier green/gray/red performance scale.
      const profileBars = [
        { label: 'EV Offense',   val: D.hgb_rating_off_pct,                            kind: 'performance' },
        { label: 'EV Defense',   val: D.hgb_rating_def_pct,                            kind: 'perf'        },
        { label: 'Goals / 60',   val: v3(D.g_60_pct_3yr,      pct3.goals),             kind: 'performance' },
        { label: 'A1 / 60',      val: v3(D.a1_60_pct_3yr,     pct3.a1),                kind: 'performance' },
        { label: 'xG / 60',      val: v3(D.xg_60_pct_3yr,     pct3.ixg),               kind: 'performance' },
        { label: 'Finishing',    val: v3(D.finishing_pct_3yr, pct3.finishing),         kind: 'performance' },
        { label: 'Pen. Diff',    val: v3(D.pen_diff_pct_3yr,  pct3.pen_diff),          kind: 'performance' },
        { label: 'Power Play',   val: pct3.pp_off ?? null,                             kind: 'performance' },
        { label: 'Penalty Kill', val: pct3.pk_def ?? null,                             kind: 'performance' },
        { label: 'Opp. Quality', val: v3(D.qoc_pct_3yr,       D.qoc),                  kind: 'context'     },
        { label: 'Mate Quality', val: v3(D.qot_pct_3yr,       D.qot),                  kind: 'context'     },
      ];

      const BAR_ROW_H   = 33;
      const BAR_H_PX    = 13;
      const BAR_LABEL_W = 96;
      const BAR_RANK_W  = 44;
      const BAR_AVAIL   = W - PAD * 2 - BAR_LABEL_W - BAR_RANK_W - 8;

      function barFill(pct, kind) {
        // contextual metrics (EV Defense, QoC, QoT) — always blue.
        // High here is "tough deployment / context", not "good player skill".
        if (kind === 'context') return '#4285f4';
        if (pct == null) return 'rgba(13,13,20,0.20)';
        if (pct >= 75) return '#137333';           // elite — dark green
        if (pct >= 55) return '#4CAF50';           // above avg — light green
        if (pct >= 40) return 'rgba(13,13,20,0.35)'; // average — neutral gray
        if (pct >= 25) return '#E57373';           // below avg — light red
        return '#E8002D';                          // poor — dark red
      }
      function pctColor(pct, kind) {
        if (kind === 'context') return '#4285f4';
        if (pct == null) return 'rgba(13,13,20,0.35)';
        if (pct >= 75) return '#137333';
        if (pct >= 55) return '#4CAF50';
        if (pct >= 40) return 'rgba(13,13,20,0.50)';
        if (pct >= 25) return '#E57373';
        return '#E8002D';
      }

      function makeHatchPattern(ctx) {
        const sz = 6;
        const pc = document.createElement('canvas');
        pc.width = sz; pc.height = sz;
        const px = pc.getContext('2d');
        px.strokeStyle = 'rgba(13,13,20,0.18)';
        px.lineWidth = 1;
        px.beginPath();
        px.moveTo(0, sz); px.lineTo(sz, 0);
        px.stroke();
        return ctx.createPattern(pc, 'repeat');
      }

      for (let bi = 0; bi < profileBars.length; bi++) {
        const b = profileBars[bi];
        const rowY = y + bi * BAR_ROW_H;
        const by   = rowY + (BAR_ROW_H - BAR_H_PX) / 2;
        const val  = b.val;

        // label
        ctx.font = '600 11px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(b.label, PAD, rowY + BAR_ROW_H / 2);

        // track
        const bx = PAD + BAR_LABEL_W;
        rrect(ctx, bx, by, BAR_AVAIL, BAR_H_PX, 3);
        ctx.fillStyle = INK10; ctx.fill();

        if (val == null) {
          // hatch pattern fill for no-data bars
          const hatch = makeHatchPattern(ctx);
          rrect(ctx, bx, by, BAR_AVAIL, BAR_H_PX, 3);
          ctx.fillStyle = hatch; ctx.fill();
        } else {
          const tierC = barFill(val, b.kind);
          // fill
          const fillW = Math.max(6, (val / 100) * BAR_AVAIL);
          rrect(ctx, bx, by, fillW, BAR_H_PX, 3);
          ctx.fillStyle = tierC; ctx.fill();
        }

        // percentage (right-aligned) — skip for null bars, show muted dash instead
        ctx.font = '800 15px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        if (val == null) {
          ctx.fillStyle = 'rgba(13,13,20,0.32)';
          ctx.fillText('—', W - PAD, rowY + BAR_ROW_H / 2);
        } else {
          ctx.fillStyle = pctColor(val, b.kind);
          ctx.fillText(Math.round(val) + '%', W - PAD, rowY + BAR_ROW_H / 2);
        }
      }
      y += profileBars.length * BAR_ROW_H + 12;

      // ════════ SECTION 4 — FOOTER ════════
      const FOOT_H = 36;
      const footY = y;
      ctx.fillStyle = INK06; ctx.fillRect(0, footY, W, FOOT_H);
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText('HOCKEYGAMEBOT · HGB STATS · 2025-26', W / 2, footY + FOOT_H / 2);

      return canvas;
    }

    // ── shared card modal — shows PNG in overlay, easier to save on iOS ──
    function showCardModal(canvas, filename) {
      // Remove any existing modal
      document.getElementById('hgb-card-modal')?.remove();

      const dataUrl = canvas.toDataURL('image/png');
      const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);

      const overlay = document.createElement('div');
      overlay.id = 'hgb-card-modal';
      overlay.style.cssText = `position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.92);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:16px;`;

      overlay.innerHTML = `
        <div style="position:relative;max-width:min(90vw,820px);width:100%;">
          <button id="hgb-modal-close" style="position:absolute;top:-40px;right:0;background:none;border:none;color:#fff;font-size:28px;cursor:pointer;line-height:1;opacity:0.7;">×</button>
          <img src="${dataUrl}" alt="${filename}" style="width:100%;height:auto;display:block;border:1px solid rgba(255,255,255,0.12);" />
          <div style="display:flex;align-items:center;justify-content:space-between;margin-top:10px;gap:12px;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(255,255,255,0.4);letter-spacing:0.06em;">
              ${isIOS ? 'Long-press image to save · ' : ''}${filename}
            </span>
            ${!isIOS ? `<a href="${dataUrl}" download="${filename}" style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.10em;text-transform:uppercase;padding:6px 14px;background:#fff;color:#0d0d14;text-decoration:none;white-space:nowrap;">↓ Download</a>` : ''}
          </div>
        </div>`;

      document.body.appendChild(overlay);
      document.getElementById('hgb-modal-close').addEventListener('click', () => overlay.remove());
      overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
      document.addEventListener('keydown', function esc(e) {
        if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', esc); }
      });
    }

    // ── shared canvas download helper (kept for non-card uses) ───────────
    function downloadCanvas(canvas, filename) {
      showCardModal(canvas, filename);
    }

    // ── RAPM z-score horizontal bar card ─────────────────────────────────────
    async function drawRapmCard() {
      const R = D.rapm;
      if (!R || R.ev_xgf60_z == null) throw new Error('No RAPM data for this player');

      const BG = '#EFEEE8', SURFACE = '#FFFFFF';
      const RED = '#CC0000', BAR_NEG = 'rgba(13,13,20,0.18)';
      const MUTED = 'rgba(13,13,20,0.45)', GRID = 'rgba(13,13,20,0.09)';
      const SCALE = 2, W = 780;
      const PAD = 36, LABEL_W = 76, VAL_W = 58;
      const CHART_L = PAD + LABEL_W, CHART_R = W - PAD - VAL_W;
      const CHART_W = CHART_R - CHART_L;
      const Z_MAX = 3, ZERO_X = CHART_L + CHART_W / 2;
      const PX_PER_Z = CHART_W / (Z_MAX * 2);
      const ROW_H = 52, AXIS_H = 32, SEC_H = 36;

      const evRows = [
        { label: 'GF/60',  z: R.ev_gf60_z  },
        { label: 'xGF/60', z: R.ev_xgf60_z },
        { label: 'xGA/60', z: R.ev_xga60_z },
        { label: 'CF/60',  z: R.ev_cf60_z  },
        { label: 'CA/60',  z: R.ev_ca60_z  },
      ].filter(r => r.z != null);
      const ppRows = [
        { label: 'GF/60',  z: R.pp_gf60_z  },
        { label: 'xGF/60', z: R.pp_xgf60_z },
        { label: 'CF/60',  z: R.pp_cf60_z  },
      ].filter(r => r.z != null);

      const HERO_H = 86; // 52 name row + 34 chip row, matches Rating Card
      const EV_H = SEC_H + evRows.length * ROW_H + AXIS_H;
      const PP_H = ppRows.length > 0 ? SEC_H + ppRows.length * ROW_H + AXIS_H + 20 : 0;
      const H = HERO_H + EV_H + PP_H + 28;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      const TEAM_C = D.teamColor || '#CC0000';
      const TEAM_NAMES_R = { ANA:'ANAHEIM DUCKS',BOS:'BOSTON BRUINS',BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SJS:'SAN JOSE SHARKS',SEA:'SEATTLE KRAKEN',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS' };
      const teamFull = TEAM_NAMES_R[D.team] || D.team;

      // ── Background ──
      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, H);

      // ── Hero: white band + 4px team accent (matches Rating Card) ──
      ctx.fillStyle = SURFACE; ctx.fillRect(0, 0, W, HERO_H);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 4, HERO_H);

      // Name row
      const fn = D.firstName && D.lastName ? `${D.firstName} ${D.lastName}` : (D.firstName || '');
      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = '#0D0D14'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(fn.toUpperCase(), PAD, HERO_H / 2 - 12);

      // Chips row
      const chipH = 18, chipY0 = HERO_H / 2 + 4;
      const chips = [teamFull, D.posLabel ? D.posLabel.toUpperCase() : D.pos, '2025-26', 'REG SEASON'];
      let cx2 = PAD;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      chips.forEach((chip, ci) => {
        const tw = ctx.measureText(chip).width, cw = tw + 18;
        rrect(ctx, cx2, chipY0, cw, chipH, 3);
        ctx.fillStyle = ci === 0 ? TEAM_C : '#0D0D14'; ctx.fill();
        ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chip, cx2 + 9, chipY0 + chipH / 2);
        cx2 += cw + 8;
      });
      // RAPM label pill right-aligned
      const rapmLabel = ppRows.length > 0 ? 'EV & PP RAPM' : 'EV RAPM';
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      const rtw = ctx.measureText(rapmLabel).width, rcw = rtw + 18;
      rrect(ctx, W - PAD - rcw, chipY0, rcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(rapmLabel, W - PAD - rcw + 9, chipY0 + chipH / 2);

      // Bottom border
      ctx.fillStyle = 'rgba(13,13,20,0.08)'; ctx.fillRect(0, HERO_H - 1, W, 1);

      function drawSection(label, rows, toi, yStart) {
        // Section header
        ctx.textAlign = 'left';
        ctx.font = '800 13px "Barlow Condensed", sans-serif'; ctx.fillStyle = RED;
        ctx.fillText(label.toUpperCase(), PAD, yStart + 24);
        if (toi != null) {
          ctx.textAlign = 'right';
          ctx.font = '400 10px "JetBrains Mono", monospace'; ctx.fillStyle = MUTED;
          ctx.fillText(`${label === 'Even Strength' ? 'EV' : 'PP'} TOI: ${toi.toFixed(1)} min`, W - PAD, yStart + 24);
        }

        const chartTop = yStart + SEC_H;

        // Chart bg + gridlines
        ctx.fillStyle = SURFACE; ctx.fillRect(CHART_L, chartTop, CHART_W, rows.length * ROW_H);
        [-3,-2,-1,0,1,2,3].forEach(v => {
          const x = Math.round(ZERO_X + v * PX_PER_Z) + 0.5;
          ctx.beginPath(); ctx.strokeStyle = v === 0 ? 'rgba(13,13,20,0.22)' : GRID;
          ctx.lineWidth = v === 0 ? 1.5 : 1;
          ctx.setLineDash(v === 0 ? [5, 4] : []);
          ctx.moveTo(x, chartTop); ctx.lineTo(x, chartTop + rows.length * ROW_H);
          ctx.stroke(); ctx.setLineDash([]);
        });

        // Row separators
        rows.forEach((_, i) => {
          if (i > 0) { ctx.fillStyle = GRID; ctx.fillRect(CHART_L, chartTop + i * ROW_H, CHART_W, 1); }
        });

        // Bars + labels + values
        rows.forEach((r, i) => {
          const cy = chartTop + i * ROW_H + ROW_H / 2;
          const z = Math.max(-3, Math.min(3, r.z));
          const barW = Math.abs(z) * PX_PER_Z;
          const barX = z >= 0 ? ZERO_X : ZERO_X - barW;
          const barH = ROW_H * 0.42;

          ctx.fillStyle = z >= 0 ? TEAM_C : BAR_NEG;
          ctx.fillRect(barX, cy - barH / 2, barW, barH);

          // Metric label — Barlow Condensed at ≥12px, JetBrains Mono only for tiny text
          ctx.textAlign = 'right'; ctx.fillStyle = MUTED;
          ctx.font = '600 12px "Barlow Condensed", sans-serif';
          ctx.fillText(r.label, CHART_L - 10, cy + 5);

          // Value — bold, larger
          const sign = r.z >= 0 ? '+' : '';
          ctx.textAlign = 'left';
          ctx.fillStyle = r.z >= 0 ? TEAM_C : MUTED;
          ctx.font = '700 13px "Barlow Condensed", sans-serif';
          ctx.fillText(`${sign}${r.z.toFixed(2)}`, CHART_R + 10, cy + 5);
        });

        // Axis numbers — JetBrains Mono (numeric data, small)
        const axisY = chartTop + rows.length * ROW_H + 20;
        ctx.font = '400 10px "JetBrains Mono", monospace'; ctx.fillStyle = MUTED; ctx.textAlign = 'center';
        [-3,-2,-1,0,1,2,3].forEach(v => {
          ctx.fillText(String(v), ZERO_X + v * PX_PER_Z, axisY);
        });
      }

      let y = HERO_H + 6;
      drawSection('Even Strength', evRows, R.ev_toi, y);
      y += SEC_H + evRows.length * ROW_H + AXIS_H + 16;
      if (ppRows.length > 0) drawSection('Power Play', ppRows, R.pp_toi, y);

      return canvas;
    }

    function bindCardBtn(id, label, drawFn, filename, sizeLabel = '560px · 2× retina PNG') {
      const b = document.getElementById(id);
      if (!b) return;
      b.addEventListener('click', async () => {
        b.textContent = 'Generating…'; b.disabled = true;
        status.textContent = 'Drawing…';
        try {
          if (document.fonts && document.fonts.ready) await document.fonts.ready;
          const canvas = await drawFn();
          downloadCanvas(canvas, filename);
          status.textContent = 'Downloaded ✓';
          setTimeout(() => { status.textContent = sizeLabel; }, 3000);
        } catch (e) {
          console.error(e);
          status.textContent = 'Error — try again';
        } finally {
          b.textContent = label; b.disabled = false;
        }
      });
    }

    // Season WAR card — season-aware binding (season can change via row click)
    (() => {
      let _selectedSeason = D.currentSeason ?? '2025-26';
      document.addEventListener('hgb:season-select', function(e) { _selectedSeason = e.detail?.season ?? _selectedSeason; });
      const btn = document.getElementById('download-season-card-btn');
      const status = document.getElementById('card-status');
      if (btn) btn.addEventListener('click', async function() {
        const label = btn.textContent ?? '';
        btn.textContent = 'Generating…'; btn.disabled = true;
        if (status) status.style.display = 'block';
        try {
          if (document.fonts?.ready) await document.fonts.ready;
          const canvas = await drawSeasonCard(_selectedSeason);
          downloadCanvas(canvas, `hgb_season_${D.slug}_${_selectedSeason}.png`);
          if (status) { status.textContent = 'Downloaded ✓'; setTimeout(function() { if (status) status.style.display = 'none'; }, 3000); }
        } catch(err) { console.error(err); if (status) status.textContent = 'Error — try again'; }
        finally { btn.textContent = label; btn.disabled = false; }
      });
    })();

    bindCardBtn('download-card-btn',     'Player Card →',      drawCard,              `hgb_${D.slug}_25-26.png`);
    bindCardBtn('download-expanded-btn', 'Expanded Card →',    drawLandscapeCard,     `hgb_${D.slug}_expanded_25-26.png`, '900px · 2× retina PNG');
    bindCardBtn('download-edge-btn',     'NHL EDGE Card →',    drawEdgeCard,          `hgb_${D.slug}_edge_25-26.png`);
    bindCardBtn('download-rating-card-btn', 'Rating Card →',   drawRatingCard,        `hgb_rating_${D.slug}_25-26.png`, '520×720px · 2× retina PNG');
    bindCardBtn('download-rapm-card-btn',   'RAPM Card →',     drawRapmCard,          `hgb_rapm_${D.slug}_25-26.png`,   '760px · 2× retina PNG');
    bindCardBtn('download-history-card-btn','History Card →',  drawHistoryCard,       `hgb_history_${D.slug}.png`,      '560×auto · 2× retina PNG');
    bindCardBtn('download-expanded-card-btn','Expanded Card →', drawExpandedCard,     `hgb_expanded_${D.slug}.png`,     '1040×auto · 2× retina PNG');
  })();

  // ── HISTORY CARD draw function ─────────────────────────────────────────────
  // Defined outside the main IIFE so it can reference _seasonStats + _card.
  async function drawHistoryCard() {
    const D = _card;
    const seasons = _seasonStats; // sorted descending by season

    const INK    = '#0D0D14';
    const RED    = '#E8002D';
    const INK06  = 'rgba(13,13,20,0.06)';
    const INK10  = 'rgba(13,13,20,0.10)';
    const INK14  = 'rgba(13,13,20,0.14)';
    const INK32  = 'rgba(13,13,20,0.32)';
    const INK48  = 'rgba(13,13,20,0.48)';
    const TEAM_C = D.teamColor || INK;

    function tierColor(val) {
      if (val == null) return INK32;
      if (val >= 70) return '#137333';
      if (val <= 30) return '#E8002D';
      return INK48;
    }

    const SCALE = 2;
    const W = 560;
    const PAD = 28;

    // Header: 52px name + 34px chips = 86px
    const HDR_H  = 52;
    const CHIP_H = 34;
    const HERO_H = 88;  // 3-tile hero: HGB RATING | HGB WAR | HGB IMPACT
    const SEP_H  = 1;
    const COL_H  = 36;  // column headers
    const ROW_H  = 36;  // each season row
    const FOOT_H = 36;

    const displaySeasons = seasons.slice(0, 10);
    const N = displaySeasons.length;

    const TOTAL_H = HDR_H + CHIP_H + HERO_H + SEP_H + COL_H + N * ROW_H + FOOT_H;

    const canvas = document.createElement('canvas');
    canvas.width  = W * SCALE;
    canvas.height = TOTAL_H * SCALE;
    const ctx = canvas.getContext('2d');
    ctx.scale(SCALE, SCALE);

    // ── Background (light card — cream editorial style) ─────────────────
    ctx.fillStyle = '#EFEEE8';
    ctx.fillRect(0, 0, W, TOTAL_H);

    // 4px left accent bar (team color, full height)
    ctx.fillStyle = TEAM_C;
    ctx.fillRect(0, 0, 4, TOTAL_H);

    let y = 0;

    // ── HEADER (white band) ─────────────────────────────────────────────
    ctx.fillStyle = '#FFFFFF';
    ctx.fillRect(0, y, W, HDR_H + CHIP_H);
    // Bottom border of header
    ctx.fillStyle = INK14;
    ctx.fillRect(0, y + HDR_H + CHIP_H - 1, W, 1);

    // Player name
    ctx.font = '800 24px "Barlow Condensed", sans-serif';
    ctx.fillStyle = INK;
    ctx.textBaseline = 'middle';
    ctx.textAlign = 'left';
    ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, y + HDR_H / 2);
    // "SEASON HISTORY" label right-aligned
    ctx.font = '700 10px "JetBrains Mono", monospace';
    ctx.fillStyle = TEAM_C;
    ctx.textAlign = 'right';
    ctx.fillText('SEASON HISTORY', W - PAD, y + HDR_H / 2);
    y += HDR_H;

    // Chips row
    const chipH = 18;
    const chipY0 = y + (CHIP_H - chipH) / 2;
    const TEAM_NAMES_H = { ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS' };
    const teamFull = TEAM_NAMES_H[D.team] || D.team;
    const chips = [teamFull, (D.posLabel || D.pos).toUpperCase()];
    let cx = PAD;
    ctx.font = '700 9px "Barlow Condensed", sans-serif';
    for (let ci = 0; ci < chips.length; ci++) {
      const tw = ctx.measureText(chips[ci]).width;
      const cw = tw + 18;
      ctx.beginPath(); ctx.roundRect(cx, chipY0, cw, chipH, 3);
      ctx.fillStyle = ci === 0 ? TEAM_C : INK;
      ctx.fill();
      ctx.fillStyle = '#FFFFFF';
      ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
      cx += cw + 8;
    }
    const brand = 'HOCKEYGAMEBOT';
    const btw = ctx.measureText(brand).width;
    const bcw = btw + 18;
    ctx.beginPath(); ctx.roundRect(W - PAD - bcw, chipY0, bcw, chipH, 3);
    ctx.fillStyle = RED; ctx.fill();
    ctx.fillStyle = '#FFFFFF'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
    ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);
    y += CHIP_H;

    // ── HERO ROW — exact same pattern as Rating Card: headshot + 3 stat tiles ──
    const heroR = 38, hsCX = PAD + heroR, hsCY = y + HERO_H / 2;
    const hsImgH = await (function li(src) {
      return new Promise(res => { const i = new Image(); i.crossOrigin='anonymous'; i.onload=()=>res(i); i.onerror=()=>res(null); i.src=src; });
    })(D.headshotUrl);
    ctx.save(); ctx.beginPath(); ctx.arc(hsCX, hsCY, heroR, 0, Math.PI*2); ctx.clip();
    if (hsImgH) {
      ctx.drawImage(hsImgH, hsCX-heroR, hsCY-heroR, heroR*2, heroR*2);
    } else {
      ctx.fillStyle = INK10; ctx.fill();
      ctx.font = '800 24px "Barlow Condensed",sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline='middle'; ctx.textAlign='center';
      ctx.fillText((D.firstName[0]+D.lastName[0]).toUpperCase(), hsCX, hsCY);
    }
    ctx.restore();
    ctx.beginPath(); ctx.arc(hsCX, hsCY, heroR, 0, Math.PI*2);
    ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

    // 3 stat tiles to the right of headshot
    const statX = hsCX + heroR + 18;
    const statW = (W - statX - PAD) / 3;
    const ratingPctVal = D.hgb_rating_percentile ?? null;
    const ratingRawStr = D.hgb_rating != null ? (D.hgb_rating>0?'+':'') + D.hgb_rating.toFixed(2) + ' Rating' : '—';
    const warPctVal  = D.warPct ?? Math.round(D.impactPct);
    const impPctVal  = Math.round(D.impactPct);
    const warRawStr  = D.war != null ? (D.war>=0?'+':'') + D.war.toFixed(2) + ' WAR' : '—';
    const gsAvgStr   = D.avgGsDisplay != null ? (D.avgGsDisplay>=0?'+':'') + D.avgGsDisplay.toFixed(2) + ' Avg' : '—';
    const heroStats  = [
      { label: 'HGB RATING',      big: ratingPctVal != null ? ratingPctVal+'%' : '—', small: ratingRawStr },
      { label: 'HGB WAR',         big: warPctVal+'%',                                  small: warRawStr   },
      { label: 'HGB GAME IMPACT', big: impPctVal+'%',                                  small: gsAvgStr    },
    ];
    for (let i = 0; i < heroStats.length; i++) {
      const hs = heroStats[i];
      const sx = statX + i * statW + statW / 2;
      if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(statX + i*statW, y+14, 1, HERO_H-28); }
      ctx.font = '700 9px "Barlow Condensed",sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline='top'; ctx.textAlign='center';
      ctx.fillText(hs.label, sx, y+14);
      ctx.font = '800 30px "Barlow Condensed",sans-serif';
      ctx.fillStyle = TEAM_C; ctx.textBaseline='top';
      ctx.fillText(hs.big, sx, y+27);
      ctx.font = '800 12px "Barlow Condensed",sans-serif';
      ctx.fillStyle = INK48; ctx.textBaseline='top';
      ctx.fillText(hs.small, sx, y+66);
    }
    ctx.fillStyle = INK14; ctx.fillRect(0, y+HERO_H-1, W, 1);
    y += HERO_H;

    // separator
    ctx.fillStyle = INK10;
    ctx.fillRect(0, y, W, SEP_H);
    y += SEP_H;

    // ── COLUMN HEADERS ───────────────────────────────────────────────────
    const COL1_X = PAD;              // SEASON label
    const COL2_X = PAD + 80;         // HGB RATING
    const COL3_X = PAD + 80 + 130;   // HGB WAR
    const COL4_X = PAD + 80 + 260;   // HGB IMPACT
    const COL_VAL_W = 120;

    ctx.font = '700 10px "JetBrains Mono", monospace';
    ctx.fillStyle = INK32;
    ctx.textBaseline = 'middle';
    ['SEASON', 'RATING', 'WAR', 'IMPACT'].forEach((label, i) => {
      const x = [COL1_X, COL2_X, COL3_X, COL4_X][i];
      ctx.textAlign = i === 0 ? 'left' : 'right';
      ctx.fillText(label, i === 0 ? x : x + COL_VAL_W, y + COL_H / 2);
    });
    // header bottom border
    ctx.fillStyle = INK10;
    ctx.fillRect(0, y + COL_H - 1, W, 1);
    y += COL_H;

    // ── SEASON ROWS ──────────────────────────────────────────────────────
    for (let ri = 0; ri < displaySeasons.length; ri++) {
      const s = displaySeasons[ri];
      const ry = y + ri * ROW_H;
      const rowY = ry + ROW_H / 2;

      // alternating subtle row background
      if (ri % 2 === 0) {
        ctx.fillStyle = INK06;
        ctx.fillRect(0, ry, W, ROW_H);
      }

      // Highlight current season (most recent = first row) — background only, no bar
      if (ri === 0) {
        ctx.fillStyle = `rgba(${parseInt(TEAM_C.slice(1,3)||'0',16)},${parseInt(TEAM_C.slice(3,5)||'0',16)},${parseInt(TEAM_C.slice(5,7)||'0',16)},0.08)`;
        ctx.fillRect(0, ry, W, ROW_H);
      }

      // row bottom border
      ctx.fillStyle = INK06;
      ctx.fillRect(0, ry + ROW_H - 1, W, 1);

      // Season label (e.g. "2025-26")
      const seasonLabel = s.season ? s.season.replace('-', '–') : '—';
      ctx.font = ri === 0 ? '700 12px "JetBrains Mono", monospace' : '500 12px "JetBrains Mono", monospace';
      ctx.fillStyle = ri === 0 ? INK : INK48;
      ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(seasonLabel, COL1_X, rowY);

      // GP sub-label
      if (s.gp != null) {
        ctx.font = '400 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32;
        ctx.fillText(s.gp + ' GP', COL1_X + 56, rowY);
      }

      // Helper to draw a percentile value cell
      function drawPctCell(colX, val) {
        const displayVal = val != null ? Math.round(val) + '%' : '—';
        const color = val != null ? tierColor(val) : INK32;
        ctx.font = val != null ? '700 13px "JetBrains Mono", monospace' : '400 13px "JetBrains Mono", monospace';
        ctx.fillStyle = color;
        ctx.textAlign = 'right';
        ctx.fillText(displayVal, colX + COL_VAL_W, rowY);
      }

      // hgb_rating_pct / war_pct / impact_pct will be null until pipeline writes them
      drawPctCell(COL2_X, s.hgb_rating_pct);
      drawPctCell(COL3_X, s.war_pct);
      drawPctCell(COL4_X, s.impact_pct);
    }

    y += N * ROW_H;

    // ── FOOTER ──────────────────────────────────────────────────────────
    ctx.fillStyle = INK06;
    ctx.fillRect(0, y, W, FOOT_H);
    ctx.font = '700 8px "Barlow Condensed", sans-serif';
    ctx.fillStyle = INK32;
    ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
    ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · RATING/WAR/IMPACT PERCENTILE VS. FORWARDS', W / 2, y + FOOT_H / 2);

    return canvas;
  }

  // ── EXPANDED CARD — Rating Card (left) + History Table (right) in one landscape card ──
  async function drawExpandedCard() {
    const D = _card;
    const seasons = _seasonStats;

    const INK     = '#0D0D14';
    const BG      = '#EFEEE8';
    const SURFACE = '#FFFFFF';
    const RED     = '#E8002D';
    const INK06   = 'rgba(13,13,20,0.06)';
    const INK10   = 'rgba(13,13,20,0.10)';
    const INK14   = 'rgba(13,13,20,0.14)';
    const INK32   = 'rgba(13,13,20,0.32)';
    const INK48   = 'rgba(13,13,20,0.48)';
    const TEAM_C  = D.teamColor || INK;
    const SCALE   = 2;

    const L_W = 520, R_W = 520, W = L_W + R_W;
    const PAD = 24, R_PAD = 20;

    // Shared header
    const HDR_H = 52, CHIP_H = 34;

    // Left panel content (below header): gap + identity + sep + section-hdr + 11 bars + pad
    const ID_H = 122, BAR_ROW_H = 33, BAR_ROWS = 11;
    const L_CONTENT_H = 6 + ID_H + 1 + 20 + 12 + BAR_ROWS * BAR_ROW_H + 12;

    // Right panel content (below header): col headers + rows
    const COL_H = 36, ROW_H = 36;
    const displaySeasons = seasons.slice(0, 10);
    const N = displaySeasons.length;
    const R_CONTENT_H = COL_H + N * ROW_H;

    const FOOT_H    = 36;
    const CONTENT_H = Math.max(L_CONTENT_H, R_CONTENT_H);
    const H         = HDR_H + CHIP_H + CONTENT_H + FOOT_H;

    // Local helpers (rrect / loadImg not in scope outside the IIFE)
    function rrect(ctx, x, y, w, h, r) {
      ctx.beginPath();
      if (typeof ctx.roundRect === 'function') { ctx.roundRect(x, y, w, h, r); }
      else {
        ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
        ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
        ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
        ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath();
      }
    }
    function loadImg(src) {
      return new Promise(res => {
        const img = new Image(); img.crossOrigin = 'anonymous';
        img.onload = () => res(img); img.onerror = () => res(null);
        img.src = src;
      });
    }

    const canvas = document.createElement('canvas');
    canvas.width  = W * SCALE;
    canvas.height = H * SCALE;
    const ctx = canvas.getContext('2d');
    ctx.scale(SCALE, SCALE);

    // Background
    ctx.fillStyle = BG;
    ctx.fillRect(0, 0, W, H);

    // Left accent bar (full card height)
    ctx.fillStyle = TEAM_C;
    ctx.fillRect(0, 0, 4, H);

    // ── SHARED HEADER (white band) ──────────────────────────────────────────
    ctx.fillStyle = SURFACE;
    ctx.fillRect(0, 0, W, HDR_H + CHIP_H);
    ctx.fillStyle = INK14;
    ctx.fillRect(0, HDR_H + CHIP_H - 1, W, 1);

    ctx.font = '800 24px "Barlow Condensed", sans-serif';
    ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
    ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, HDR_H / 2);

    ctx.font = '700 10px "JetBrains Mono", monospace';
    ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
    ctx.fillText('EXPANDED PROFILE', W - PAD, HDR_H / 2);

    // Chips row
    const TEAM_NAMES = { ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS' };
    const chipH = 18, chipY0 = HDR_H + (CHIP_H - chipH) / 2;
    const chips = [(TEAM_NAMES[D.team] || D.team), D.posLabel.toUpperCase(), '2025-26'];
    let cx = PAD;
    ctx.font = '700 9px "Barlow Condensed", sans-serif';
    for (let ci = 0; ci < chips.length; ci++) {
      const cw = ctx.measureText(chips[ci]).width + 18;
      rrect(ctx, cx, chipY0, cw, chipH, 3);
      ctx.fillStyle = ci === 0 ? TEAM_C : INK; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
      cx += cw + 8;
    }
    const brand = 'HOCKEYGAMEBOT';
    const bcw = ctx.measureText(brand).width + 18;
    rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
    ctx.fillStyle = RED; ctx.fill();
    ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
    ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);

    // Panel divider
    ctx.fillStyle = INK14;
    ctx.fillRect(L_W, HDR_H + CHIP_H, 1, CONTENT_H);

    // ── LEFT PANEL — identity row ────────────────────────────────────────────
    let y = HDR_H + CHIP_H + 6;

    const R = 36, HS_CX = PAD + R, HS_CY = y + ID_H / 2;
    const hsImg = await loadImg(D.headshotUrl);
    ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
    if (hsImg) {
      ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
    } else {
      ctx.fillStyle = INK10; ctx.fill();
      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText((D.firstName[0] + D.lastName[0]).toUpperCase(), HS_CX, HS_CY);
    }
    ctx.restore();
    ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
    ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

    const heroX = HS_CX + R + 18;
    const heroW = (L_W - heroX - PAD) / 3;
    const ratingPctVal = D.hgb_rating_percentile;
    const warPctVal    = D.warPct ?? (D.impactPct != null ? Math.round(D.impactPct) : null);
    const impPctVal    = D.impactPct != null ? Math.round(D.impactPct) : null;
    const heroTiles = [
      { label: 'HGB RATING', pct: ratingPctVal, sub: D.hgb_rating != null ? (D.hgb_rating >= 0 ? '+' : '') + D.hgb_rating.toFixed(2) + ' Rating' : '—' },
      { label: 'HGB WAR',    pct: warPctVal,    sub: D.war != null ? D.war.toFixed(2) + ' WAR' : '—' },
      { label: 'HGB IMPACT', pct: impPctVal,    sub: D.avgGsDisplay != null ? D.avgGsDisplay.toFixed(2) + ' Avg' : '—' },
    ];
    for (let i = 0; i < heroTiles.length; i++) {
      const t = heroTiles[i];
      const tcx = heroX + i * heroW + heroW / 2;
      if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(heroX + i * heroW, y + 18, 1, ID_H - 36); }
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
      ctx.fillText(t.label, tcx, y + 20);
      ctx.font = '900 36px "Barlow Condensed", sans-serif';
      ctx.fillStyle = t.pct != null ? TEAM_C : INK32;
      ctx.fillText(t.pct != null ? t.pct + '%' : '—', tcx, y + 33);
      ctx.font = '800 12px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK48; ctx.textBaseline = 'top';
      ctx.fillText(t.sub, tcx, y + 78);
    }
    y += ID_H;

    ctx.fillStyle = INK14; ctx.fillRect(0, y, L_W, 1); y += 1;
    y += 20;

    // Section header
    const isF = D.posGroup === 'F';
    ctx.font = '700 10px "JetBrains Mono", monospace';
    ctx.fillStyle = INK48; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
    ctx.fillText('3-YEAR PROFILE', PAD, y);
    const eyeW = ctx.measureText('3-YEAR PROFILE').width;
    ctx.fillStyle = RED;
    ctx.fillText('  ' + (isF ? 'VS. FORWARDS' : 'VS. DEFENSEMEN'), PAD + eyeW, y);
    y += 12;

    // 11 profile bars
    const pct3 = D.percentiles;
    const v3 = (a, b) => (a != null ? a : (b != null ? b : null));
    const profileBars = [
      { label: 'EV Offense',   val: D.hgb_rating_off_pct,                   kind: 'performance' },
      { label: 'EV Defense',   val: D.hgb_rating_def_pct,                   kind: 'context'     },
      { label: 'Goals / 60',   val: v3(D.g_60_pct_3yr,   pct3.goals),       kind: 'performance' },
      { label: 'A1 / 60',      val: v3(D.a1_60_pct_3yr,  pct3.a1),          kind: 'performance' },
      { label: 'xG / 60',      val: v3(D.xg_60_pct_3yr,  pct3.ixg),         kind: 'performance' },
      { label: 'Finishing',    val: v3(D.finishing_pct_3yr, pct3.finishing), kind: 'performance' },
      { label: 'Pen. Diff',    val: v3(D.pen_diff_pct_3yr, pct3.pen_diff),   kind: 'performance' },
      { label: 'Power Play',   val: pct3.pp_off ?? null,                     kind: 'performance' },
      { label: 'Penalty Kill', val: pct3.pk_def ?? null,                     kind: 'performance' },
      { label: 'Opp. Quality', val: v3(D.qoc_pct_3yr, D.qoc),               kind: 'context'     },
      { label: 'Mate Quality', val: v3(D.qot_pct_3yr, D.qot),               kind: 'context'     },
    ];

    const BAR_H_PX = 13, BAR_LABEL_W = 96, BAR_RANK_W = 40;
    const BAR_AVAIL = L_W - PAD * 2 - BAR_LABEL_W - BAR_RANK_W - 8;

    function barFill(pct, kind) {
      if (kind === 'context') return '#4285f4';
      if (pct == null) return 'rgba(13,13,20,0.20)';
      if (pct >= 75) return '#137333';
      if (pct >= 55) return '#4CAF50';
      if (pct >= 40) return 'rgba(13,13,20,0.35)';
      if (pct >= 25) return '#E57373';
      return '#E8002D';
    }
    function pctColorL(pct, kind) {
      if (kind === 'context') return '#4285f4';
      if (pct == null) return 'rgba(13,13,20,0.35)';
      if (pct >= 75) return '#137333';
      if (pct >= 55) return '#4CAF50';
      if (pct >= 40) return 'rgba(13,13,20,0.50)';
      if (pct >= 25) return '#E57373';
      return '#E8002D';
    }

    for (let bi = 0; bi < profileBars.length; bi++) {
      const b = profileBars[bi];
      const rowY = y + bi * BAR_ROW_H;
      const bby  = rowY + (BAR_ROW_H - BAR_H_PX) / 2;
      const val  = b.val;
      ctx.font = '600 11px "Barlow", sans-serif';
      ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(b.label, PAD, rowY + BAR_ROW_H / 2);
      const bx = PAD + BAR_LABEL_W;
      rrect(ctx, bx, bby, BAR_AVAIL, BAR_H_PX, 3); ctx.fillStyle = INK10; ctx.fill();
      if (val != null) {
        rrect(ctx, bx, bby, Math.max(6, (val / 100) * BAR_AVAIL), BAR_H_PX, 3);
        ctx.fillStyle = barFill(val, b.kind); ctx.fill();
      }
      ctx.font = '800 15px "Barlow Condensed", sans-serif';
      ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
      if (val == null) {
        ctx.fillStyle = 'rgba(13,13,20,0.32)';
        ctx.fillText('—', L_W - PAD, rowY + BAR_ROW_H / 2);
      } else {
        ctx.fillStyle = pctColorL(val, b.kind);
        ctx.fillText(Math.round(val) + '%', L_W - PAD, rowY + BAR_ROW_H / 2);
      }
    }

    // ── RIGHT PANEL — season history table ──────────────────────────────────
    const RX = L_W;
    const R_COL_VAL_W = 115;
    const COL1_X = RX + R_PAD;
    const COL2_X = RX + 105;   // RATING right edge = RX+220
    const COL3_X = RX + 240;   // WAR right edge = RX+355
    const COL4_X = RX + 375;   // IMPACT right edge = RX+490

    function tierColor(val) {
      if (val == null) return INK32;
      if (val >= 70)  return '#137333';
      if (val <= 30)  return '#E8002D';
      return INK48;
    }

    const ry0 = HDR_H + CHIP_H;

    ctx.font = '700 10px "JetBrains Mono", monospace';
    ctx.fillStyle = INK32; ctx.textBaseline = 'middle';
    ['SEASON', 'RATING', 'WAR', 'IMPACT'].forEach((label, i) => {
      const x = [COL1_X, COL2_X, COL3_X, COL4_X][i];
      ctx.textAlign = i === 0 ? 'left' : 'right';
      ctx.fillText(label, i === 0 ? x : x + R_COL_VAL_W, ry0 + COL_H / 2);
    });
    ctx.fillStyle = INK10;
    ctx.fillRect(RX, ry0 + COL_H - 1, R_W, 1);

    for (let ri = 0; ri < displaySeasons.length; ri++) {
      const s = displaySeasons[ri];
      const rowStartY = ry0 + COL_H + ri * ROW_H;
      const rowCY = rowStartY + ROW_H / 2;

      if (ri % 2 === 0) { ctx.fillStyle = INK06; ctx.fillRect(RX, rowStartY, R_W, ROW_H); }
      if (ri === 0) {
        const [rc, gc, bc2] = [parseInt(TEAM_C.slice(1,3),16), parseInt(TEAM_C.slice(3,5),16), parseInt(TEAM_C.slice(5,7),16)];
        ctx.fillStyle = 'rgba(' + rc + ',' + gc + ',' + bc2 + ',0.08)';
        ctx.fillRect(RX, rowStartY, R_W, ROW_H);
      }
      ctx.fillStyle = INK06; ctx.fillRect(RX, rowStartY + ROW_H - 1, R_W, 1);

      // Gap indicator between non-consecutive seasons
      if (ri > 0) {
        const prevSeason = displaySeasons[ri - 1].season || '';
        const currSeason = s.season || '';
        const prevYear = parseInt(prevSeason.slice(0, 4));
        const currYear = parseInt(currSeason.slice(0, 4));
        if (prevYear - currYear > 1) {
          ctx.fillStyle = INK14;
          ctx.fillRect(RX + R_PAD, rowStartY, R_W - R_PAD * 2, 1);
        }
      }

      const seasonLabel = s.season ? s.season.replace('-', '–') : '—';
      ctx.font = ri === 0 ? '700 12px "JetBrains Mono", monospace' : '500 12px "JetBrains Mono", monospace';
      ctx.fillStyle = ri === 0 ? INK : INK48;
      ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(seasonLabel, COL1_X, rowCY);

      if (s.gp != null) {
        ctx.font = '400 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32;
        ctx.fillText(s.gp + ' GP', COL1_X + 58, rowCY);
      }

      const drawPctCell = (colX, val) => {
        ctx.font = val != null ? '700 13px "JetBrains Mono", monospace' : '400 13px "JetBrains Mono", monospace';
        ctx.fillStyle = val != null ? tierColor(val) : INK32;
        ctx.textAlign = 'right';
        ctx.fillText(val != null ? Math.round(val) + '%' : '—', colX + R_COL_VAL_W, rowCY);
      };
      drawPctCell(COL2_X, s.hgb_rating_pct);
      drawPctCell(COL3_X, s.war_pct);
      drawPctCell(COL4_X, s.impact_pct);
    }

    // ── FOOTER ──────────────────────────────────────────────────────────────
    const footY = HDR_H + CHIP_H + CONTENT_H;
    ctx.fillStyle = INK06; ctx.fillRect(0, footY, W, FOOT_H);
    ctx.font = '700 8px "Barlow Condensed", sans-serif';
    ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
    ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · RATING / WAR / IMPACT PERCENTILE VS. POSITION · 2025-26', W / 2, footY + FOOT_H / 2);

    return canvas;
  }
</script>

<script>
  // ── SEASON / RATING·3yr toggle ─────────────────────────────────────────
  // Drives the unified PERCENTILE PROFILE card. All bars (EV Offence/Defence
  // + counting stats) live in #pct-profile-card. In RATING·3yr mode:
  //   • RAPM bars  → hgb_rating_off/def_pct (data-rating-val on [data-bar-key])
  //   • Counting bars → 3yr weighted percentiles + 3yr raw rate
  (function() {
    function tierColor(val, isBlue, isRed) {
      if (val >= 75) return isBlue ? '#4285f4' : isRed ? '#842029' : '#137333';
      if (val >= 50) return isBlue ? '#7baaf7' : isRed ? '#c03244' : '#34a853';
      if (val >= 25) return 'rgba(13,13,20,0.32)';
      return '#E8002D';
    }

    function updateBar(row, isRating, opts) {
      const isBlue    = row.dataset.isBlue === 'true';
      const isRed     = row.dataset.isRed === 'true';
      const seasonVal = parseFloat(row.dataset.seasonVal ?? '0');
      const ratingRaw = row.dataset.ratingVal;
      const hasRating = ratingRaw !== '' && ratingRaw != null;

      const val    = (isRating && hasRating) ? parseFloat(ratingRaw) : seasonVal;
      const isNull = isRating && !hasRating;

      const fill  = row.querySelector('.pct-fill');
      const pctEl = row.querySelector('.pct-pct');

      // Swap the raw rate column for counting-stat bars between season / 3yr.
      if (opts && opts.swapRate) {
        const rateEl = row.querySelector('.pct-rate');
        if (rateEl) {
          const seasonRate = row.dataset.seasonRate;
          const ratingRate = row.dataset.ratingRate;
          if (isRating) {
            rateEl.textContent = (ratingRate !== '' && ratingRate != null) ? ratingRate : '—';
          } else {
            rateEl.textContent = (seasonRate !== '' && seasonRate != null) ? seasonRate : '—';
          }
        }
      }

      if (isNull) {
        if (fill)  { fill.style.width = '0%'; fill.style.background = 'rgba(13,13,20,0.14)'; }
        if (pctEl) { pctEl.textContent = '—'; pctEl.style.color = 'rgba(13,13,20,0.32)'; }
      } else {
        const color = tierColor(val, isBlue, isRed);
        if (fill)  { fill.style.width = val.toFixed(1) + '%'; fill.style.background = color; }
        if (pctEl) { pctEl.textContent = Math.round(val) + '%'; pctEl.style.color = color; }
      }
    }

    function applyRapmMode(mode) {
      const isRating = mode === 'rating';

      document.querySelectorAll<HTMLElement>('#rapm-mode-filter button').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.rapmMode === mode);
      });

      // RAPM bars (EV Offence / Defence — identified by data-bar-key)
      document.querySelectorAll<HTMLElement>('#pct-profile-card .pct-row[data-bar-key]').forEach(row => {
        const suffix = row.querySelector<HTMLElement>('.rapm-bar-3yr-suffix');
        if (suffix) suffix.style.display = isRating ? 'inline' : 'none';
        // Hide the single-season RAPM note when in HGB RATING mode
        const seasonNote = row.querySelector<HTMLElement>('.rapm-bar-season-note');
        if (seasonNote) seasonNote.style.display = isRating ? 'none' : '';
        updateBar(row, isRating, null);
      });

      // Counting-stat bars (identified by data-rate-key) — also swap raw rate
      document.querySelectorAll('#pct-profile-card .pct-row[data-rate-key]').forEach(row => {
        updateBar(row, isRating, { swapRate: true });
      });
    }

    document.querySelectorAll<HTMLElement>('#rapm-mode-filter button').forEach(btn => {
      btn.addEventListener('click', () => applyRapmMode(btn.dataset.rapmMode));
    });
  })();

  // Similar Players WAR / Rating toggle
  (() => {
    const filter = document.getElementById('peers-mode-filter');
    if (!filter) return;
    filter.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.peersMode;
        filter.querySelectorAll('button').forEach(b => b.classList.toggle('active', b === btn));
        document.getElementById('peers-war').style.display    = mode === 'war'    ? '' : 'none';
        document.getElementById('peers-rating').style.display = mode === 'rating' ? '' : 'none';
      });
    });
  })();

  // ── Season selector — drives EV Offense/Defense RAPM bars ─────────────────
  // When the user clicks a season row in the career stats table (dispatched as
  // a custom event), or in the history card table, we update the SEASON tab EV
  // bars to reflect that season's single-season RAPM percentiles.
  (() => {
    // _seasonStats and _evOffFallback / _evDefFallback come from define:vars above
    // (they are globals serialized into this script's scope by Astro).
    const seasonMap = {};
    // _seasonStats is injected by define:vars into the inline script block above.
    // Access via window to cross the module boundary safely.
    ((typeof _seasonStats !== 'undefined' ? _seasonStats : (window as any)._seasonStats) || [])
      .forEach((s: any) => { seasonMap[s.season] = s; });

    // Current RAPM mode — we only update EV bars in SEASON mode
    let currentRapmMode = 'season';
    document.querySelectorAll('#rapm-mode-filter button').forEach(btn => {
      btn.addEventListener('click', () => {
        currentRapmMode = btn.dataset.rapmMode || 'season';
      });
    });

    function tierColor(val, isBlue) {
      if (val >= 75) return isBlue ? '#4285f4' : '#137333';
      if (val >= 50) return isBlue ? '#7baaf7' : '#34a853';
      if (val >= 25) return 'rgba(13,13,20,0.32)';
      return '#E8002D';
    }

    // Apply a season's RAPM data to the EV bars (SEASON mode only)
    function applySeasonToEvBars(seasonStr) {
      const entry = seasonMap[seasonStr];
      const _off = typeof _evOffFallback !== 'undefined' ? _evOffFallback : (window as any)._evOffFallback ?? 50;
      const _def = typeof _evDefFallback !== 'undefined' ? _evDefFallback : (window as any)._evDefFallback ?? 50;
      const offVal = (entry?.rapm_off_pct != null) ? entry.rapm_off_pct : _off;
      const defVal = (entry?.rapm_def_pct != null) ? entry.rapm_def_pct : _def;

      document.querySelectorAll('#pct-profile-card .pct-row[data-bar-key]').forEach(row => {
        const key    = row.dataset.barKey;
        const isBlue = row.dataset.isBlue === 'true';
        const val    = key === 'ev_offence' ? offVal : defVal;

        // Update data-season-val for future mode toggles
        row.dataset.seasonVal = val.toFixed(1);

        // Only update DOM if currently in SEASON mode
        if (currentRapmMode !== 'season') return;

        const fill  = row.querySelector('.pct-fill');
        const pctEl = row.querySelector('.pct-pct');
        const color = tierColor(val, isBlue);
        if (fill)  { fill.style.width = val.toFixed(1) + '%'; fill.style.background = color; }
        if (pctEl) { pctEl.textContent = Math.round(val) + '%'; pctEl.style.color = color; }
      });
    }

    // Listen for season selection events dispatched by the career table.
    // React (PlayerCareerTable) owns its own row highlight via activeSeason state.
    // This handler only needs to update the EV bars.
    document.addEventListener('hgb:season-select', (e) => {
      const season = e.detail?.season;
      if (!season) return;
      const btn = document.getElementById('download-season-card-btn');
      if (btn) btn.textContent = `${season} Player Card →`;
      try { applySeasonToEvBars(season); } catch(err) {}
    });
  })();

  // Impact trend chart — dot hover tooltips
  const tip = document.getElementById('imp-tip');
  if (tip) {
    document.querySelectorAll<HTMLElement>('.impact-dot').forEach(dot => {
      dot.addEventListener('mouseenter', e => {
        const me = e as MouseEvent;
        const val = parseFloat(dot.dataset.val ?? '0');
        const tipText = dot.dataset.tip ?? '';
        // Split "2025-10-30 vs NYR · -0.69" into context + value
        const parts = tipText.split(' · ');
        const ctx = parts.slice(0, -1).join(' · ');
        const valStr = parts[parts.length - 1];
        const valColor = val >= 0 ? '#1a7a3e' : '#E8002D';
        tip.innerHTML = `<span class="tip-ctx">${ctx}</span><span class="tip-val" style="color:${valColor}">${valStr}</span>`;
        tip.style.display = 'block';
        const x = me.clientX + 12, y = me.clientY - 28;
        tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? me.clientX - tip.offsetWidth - 8 : x) + 'px';
        tip.style.top  = Math.max(4, y) + 'px';
      });
      dot.addEventListener('mousemove', e => {
        const mm = e as MouseEvent;
        const x = mm.clientX + 12, y = mm.clientY - 28;
        tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? mm.clientX - tip.offsetWidth - 8 : x) + 'px';
        tip.style.top  = Math.max(4, y) + 'px';
      });
      dot.addEventListener('mouseleave', () => { tip.style.display = 'none'; });
    });
  }
</script>

</body>
</html>
