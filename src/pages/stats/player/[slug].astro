---
import Nav from '../../../components/Nav.astro';
import ThemeScript from '../../../components/ThemeScript.astro';
import Fonts from '../../../components/Fonts.astro';
import Table from '../../../components/Table.astro';
import ChipGroup from '../../../components/ChipGroup.astro';
import { loadPlayers, loadPlayerGames, loadPlayerShots, type GameLogEntry, type PlayerSummary, type PlayerShot } from '../../../lib/stats-loader';
import { buildPlayerShotMapSVG } from '../../../lib/rink-svg';
import { pickTeamColor } from '../../../lib/team-colors';

export async function getStaticPaths() {
  const players = loadPlayers();

  // HGBScore rank within pos_group
  const forwards = [...players].filter(p => p.pos_group === 'F').sort((a, b) => b.avg_gs_centered - a.avg_gs_centered);
  const defense  = [...players].filter(p => p.pos_group === 'D').sort((a, b) => b.avg_gs_centered - a.avg_gs_centered);
  const rankMap = new Map<number, { rank: number; total: number }>();
  forwards.forEach((p, i) => rankMap.set(p.player_id, { rank: i + 1, total: forwards.length }));
  defense.forEach( (p, i) => rankMap.set(p.player_id, { rank: i + 1, total: defense.length }));

  // RAPM rank within pos_group and overall
  const withRapm    = players.filter(p => p.rapm != null);
  const rapmF       = [...withRapm].filter(p => p.pos_group === 'F').sort((a, b) => (b.rapm ?? 0) - (a.rapm ?? 0));
  const rapmD       = [...withRapm].filter(p => p.pos_group === 'D').sort((a, b) => (b.rapm ?? 0) - (a.rapm ?? 0));
  const rapmAll     = [...withRapm].sort((a, b) => (b.rapm ?? 0) - (a.rapm ?? 0));
  const rapmRankMap = new Map<number, { rankPos: number; totalPos: number; rankAll: number; totalAll: number }>();
  rapmF.forEach((p, i) => rapmRankMap.set(p.player_id, { rankPos: i+1, totalPos: rapmF.length, rankAll: 0, totalAll: rapmAll.length }));
  rapmD.forEach((p, i) => rapmRankMap.set(p.player_id, { rankPos: i+1, totalPos: rapmD.length, rankAll: 0, totalAll: rapmAll.length }));
  rapmAll.forEach((p, i) => { const r = rapmRankMap.get(p.player_id); if (r) r.rankAll = i + 1; });

  // WAR percentile within pos_group (for card hero stat)
  const withWar  = players.filter(p => p.war != null);
  const warF     = [...withWar].filter(p => p.pos_group === 'F').sort((a, b) => (b.war ?? 0) - (a.war ?? 0));
  const warD     = [...withWar].filter(p => p.pos_group === 'D').sort((a, b) => (b.war ?? 0) - (a.war ?? 0));
  const warPctMap = new Map<number, number>();
  warF.forEach((p, i) => warPctMap.set(p.player_id, Math.round(100 - (i / warF.length) * 100)));
  warD.forEach((p, i) => warPctMap.set(p.player_id, Math.round(100 - (i / warD.length) * 100)));

  function findPeers(all: PlayerSummary[], current: PlayerSummary, mode: 'war' | 'rating' = 'war') {
    const curVal = mode === 'rating' ? (current.hgb_rating ?? current.war ?? 0) : (current.war ?? 0);
    const candidates = all
      .filter(p => {
        if (p.player_id === current.player_id) return false;
        if (p.pos_group !== current.pos_group) return false;
        return mode === 'rating' ? (p.hgb_rating != null) : (p.war != null);
      })
      .sort((a, b) => {
        const aVal = mode === 'rating' ? (a.hgb_rating ?? 0) : (a.war ?? 0);
        const bVal = mode === 'rating' ? (b.hgb_rating ?? 0) : (b.war ?? 0);
        return Math.abs(aVal - curVal) - Math.abs(bVal - curVal);
      });
    for (const band of [0.5, 1.5, 3]) {
      const inBand = candidates.filter(p => {
        const v = mode === 'rating' ? (p.hgb_rating ?? 0) : (p.war ?? 0);
        return Math.abs(v - curVal) <= band;
      });
      if (inBand.length >= 3) return inBand.slice(0, 4);
    }
    return candidates.slice(0, 4);
  }

  return players.map(player => {
    const playerGames = loadPlayerGames(player.player_id);
    const rankInfo    = rankMap.get(player.player_id)    ?? { rank: 0, total: 0 };
    const rapmRank    = rapmRankMap.get(player.player_id) ?? null;
    const mapPeer = (p: PlayerSummary) => ({
      player_id: p.player_id, slug: p.slug,
      first_name: p.first_name, last_name: p.last_name,
      display_name: p.display_name, team_abbrev: p.team_abbrev,
      pos: p.pos, gp: p.gp, rapm: p.rapm, war: p.war,
      hgb_rating: p.hgb_rating,
    });
    const peers        = findPeers(players, player, 'war').map(mapPeer);
    const peersRating  = findPeers(players, player, 'rating').map(mapPeer);
    const warPct = warPctMap.get(player.player_id) ?? null;
    return { params: { slug: player.slug }, props: { player, playerGames, rankInfo, rapmRank, peers, peersRating, warPct } };
  });
}

interface Props {
  player: PlayerSummary;
  playerGames: GameLogEntry[];
  rankInfo: { rank: number; total: number };
  rapmRank: { rankPos: number; totalPos: number; rankAll: number; totalAll: number } | null;
  peers: Array<{
    player_id: number; slug: string; first_name: string; last_name: string;
    display_name: string; team_abbrev: string; pos: string; gp: number;
    rapm: number | null; war: number | null; hgb_rating: number | null;
  }>;
  peersRating: Array<{
    player_id: number; slug: string; first_name: string; last_name: string;
    display_name: string; team_abbrev: string; pos: string; gp: number;
    rapm: number | null; war: number | null; hgb_rating: number | null;
  }>;
  warPct: number | null;
}

const { player, playerGames, rankInfo, rapmRank, peers, peersRating, warPct } = Astro.props;

function fmtToi(sec: number): string {
  const m = Math.floor(sec / 60);
  const s = Math.round(sec % 60);
  return `${m}:${s.toString().padStart(2, '0')}`;
}
function fmtDate(d: string): string {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const [, mm, dd] = d.split('-');
  return `${months[parseInt(mm) - 1]} ${parseInt(dd)}`;
}
function sign(n: number): string { return n >= 0 ? '+' : ''; }
function ordinalSuffix(n: number): string {
  const abs = Math.round(n);
  const m10 = abs % 10, m100 = abs % 100;
  if (m100 >= 11 && m100 <= 13) return `${abs}th`;
  if (m10 === 1) return `${abs}st`;
  if (m10 === 2) return `${abs}nd`;
  if (m10 === 3) return `${abs}rd`;
  return `${abs}th`;
}

// RAPM values are already per-60 units — use directly
const rapmNet = player.rapm     ?? null;
const rapmOff = player.rapm_off ?? null;
const rapmDef = player.rapm_def ?? null;

const teamColor     = pickTeamColor(player.team_abbrev);
const headshotUrl   = `https://api.hockeygamebot.com/v1/proxy/headshot/${player.team_abbrev}/${player.player_id}`;
const allGames      = [...playerGames].sort((a, b) => a.game_date.localeCompare(b.game_date));
const recentGames   = [...allGames].reverse();  // all games, newest first
const totalGoals    = playerGames.reduce((s, g) => s + g.goals,   0);
const totalAssists  = playerGames.reduce((s, g) => s + g.assists, 0);

// Points/60 (total TOI, includes PP)
const totTOIhr = (player.toi_avg_sec * player.gp) / 3600;
const pts60 = totTOIhr > 0 ? +((totalGoals + totalAssists) / totTOIhr).toFixed(2) : null;

// ── Impact season trend chart ─────────────────────────────────────────────
const IW = 680, IH = 160;
const IP = { t: 16, r: 8, b: 24, l: 38 };
const iCW = IW - IP.l - IP.r, iCH = IH - IP.t - IP.b;
const iN   = allGames.length || 1;
const iGS  = allGames.map(g => g.gs_display);
const iMin = -5, iMax = 12;  // fixed scale matches sparklines
const ipx  = (i: number) => IP.l + (i / (iN - 1 || 1)) * iCW;
const ipy  = (v: number) => IP.t + iCH - ((v - iMin) / (iMax - iMin)) * iCH;
const ipy0 = ipy(0);
const iPath = allGames.map((g, i) =>
  `${i === 0 ? 'M' : 'L'}${ipx(i).toFixed(1)},${ipy(g.gs_display).toFixed(1)}`
).join(' ');
const iArea = allGames.length >= 2
  ? `${iPath} L${ipx(iN-1).toFixed(1)},${ipy0.toFixed(1)} L${IP.l},${ipy0.toFixed(1)} Z`
  : '';
const posLabel      = player.pos_group === 'F' ? 'Forward' : 'Defenseman';
const posPlural     = player.pos_group === 'F' ? 'forwards' : 'defensemen';

// ── Shot map data ──────────────────────────────────────────────────────────
const playerShots = loadPlayerShots(player.player_id);
const shotMapSVG  = playerShots.length > 0
  ? buildPlayerShotMapSVG(playerShots, teamColor)
  : '';

const pctBars = [
  { label: 'EV Offense', key: 'ev_offence', val: player.percentiles_vs_pos.ev_offence, grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'EV Defense', key: 'ev_defence', val: player.percentiles_vs_pos.ev_defence, grad: 'linear-gradient(90deg,#e8f0fe,#4285f4)' },
  { label: 'Goals / 60', key: 'goals',      val: player.percentiles_vs_pos.goals,       grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'A1 / 60',    key: 'a1',         val: player.percentiles_vs_pos.a1,          grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'xG / 60',    key: 'ixg',        val: player.percentiles_vs_pos.ixg,         grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'Finishing',  key: 'finishing',  val: player.percentiles_vs_pos.finishing,    grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'Shots / 60', key: 'shots',      val: player.percentiles_vs_pos.shots,       grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'Pen. Diff',  key: 'pen_diff',   val: player.percentiles_vs_pos.pen_diff,    grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  ...(player.qoc != null ? [{ label: 'Opp. Quality', key: 'qoc', val: player.qoc, grad: 'linear-gradient(90deg,#f8d7da,#842029)' }] : []),
  ...(player.qot != null ? [{ label: 'Mate Quality', key: 'qot', val: player.qot, grad: 'linear-gradient(90deg,#e8f0fe,#4285f4)' }] : []),
];

// ── Table.astro column schemas for the two tables on this page ──────────────
// Defined in the frontmatter (real TypeScript) because inline {...} template
// expressions don't accept TS type annotations (Astro gotcha — see
// Table.astro JSDoc).

const CURRENT_SEASON = '20252026';
const fmtSeason = (s: string) => s.length === 8 ? `${s.slice(0,4)}–${s.slice(6,8)}` : s;
const fmtToi5v5 = (sec: number, gp: number) => {
  const avg = gp > 0 ? sec / gp : 0;
  const m = Math.floor(avg / 60);
  const s = Math.round(avg % 60);
  return `${m}:${s.toString().padStart(2, '0')}`;
};

const careerSorted = [...(player.career_seasons ?? [])].sort((a, b) => b.season.localeCompare(a.season));
const careerRows = careerSorted.map(row => ({
  season:     row.season,
  season_fmt: fmtSeason(row.season),
  team:       row.team,
  gp:         row.gp,
  toi_gp:     fmtToi5v5(row.toi_5v5_sec, row.gp),
  gf_pct:     row.gf_pct,
  xgf_pct:    row.xgf_pct,
  is_current: row.season === CURRENT_SEASON,
}));

const pctColorCb = (v: number | null, _r: any, tok?: { pos: string; neg: string }) => {
  if (v == null) return undefined;
  if (v >= 55) return tok?.pos;
  if (v <= 45) return tok?.neg;
  return undefined;
};

const careerColumns = [
  { key: 'season_fmt', label: 'Season', type: 'label' as const, bold: true },
  { key: 'team',       label: 'Team',   type: 'team' as const },
  { key: 'gp',         label: 'GP',     type: 'number' as const },
  { key: 'toi_gp',     label: 'TOI/GP', type: 'number' as const },
  { key: 'gf_pct',     label: 'GF%',    type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(1) + '%',
    color: pctColorCb },
  { key: 'xgf_pct',    label: 'xGF%',   type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(1) + '%',
    color: pctColorCb },
];

const _hasToi = recentGames.some(x => x.toi_sec != null);
const _hasIxg = recentGames.some(x => x.ixg != null);
const fmtToiCb = (v: any) => {
  if (v == null) return '—';
  const sec = Number(v);
  const m = Math.floor(sec / 60);
  const s = Math.round(sec % 60);
  return `${m}:${s.toString().padStart(2, '0')}`;
};
const signedColor = (v: any, _r: any, tok?: { pos: string; neg: string }) => {
  if (v == null) return undefined;
  return v >= 0 ? tok?.pos : tok?.neg;
};
const resultColor = (_v: any, row: any): string | undefined => {
  if (row.result_w) return 'var(--stats-pos)';
  if (row.result_ot) return 'var(--ink-48)';
  return 'var(--stats-neg)';
};

const gameLogRows = recentGames.map(g => {
  const win    = g.team_score > g.opp_score;
  const result = win ? 'W' : (g.team_score < g.opp_score ? 'L' : 'OT');
  const vs     = g.is_home ? 'vs' : '@';
  return {
    game_id:    g.game_id,
    date:       fmtDate(g.game_date),
    opp:        `${vs} ${g.opp_abbrev}`,
    result:     `${result} ${g.team_score}–${g.opp_score}`,
    result_w:   win,
    result_ot:  result === 'OT',
    goals:      g.goals,
    assists:    g.assists,
    points:     g.goals + g.assists,
    toi_sec:    g.toi_sec,
    ixg:        g.ixg,
    gs_display: g.gs_display,
  };
});

// Per-60 transform on counting stats REMOVED — game log stays as totals always.
const gameLogColumns = [
  { key: 'date',    label: 'Date',   type: 'label' as const },
  { key: 'opp',     label: 'Opp',    type: 'label' as const },
  { key: 'result',  label: 'Result', type: 'label' as const, color: resultColor, bold: true },
  { key: 'goals',   label: 'G',      type: 'number' as const },
  { key: 'assists', label: 'A',      type: 'number' as const },
  { key: 'points',  label: 'PTS',    type: 'number' as const, bold: true },
  ...(_hasToi ? [{ key: 'toi_sec', label: 'TOI', type: 'number' as const, format: fmtToiCb }] : []),
  ...(_hasIxg ? [{ key: 'ixg',     label: 'xG',  type: 'number' as const, format: (v: any) => v == null ? '—' : Number(v).toFixed(2) }] : []),
  { key: 'gs_display', label: 'Impact', type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : (v >= 0 ? '+' : '') + Number(v).toFixed(2),
    color: signedColor },
];
---
<!doctype html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{player.first_name} {player.last_name} — HGB Stats</title>
  <meta name="description" content={`${player.first_name} ${player.last_name} (${player.team_abbrev}, ${player.pos}) — ${player.gp} GP, ${totalGoals}G ${totalAssists}A. Season rates, percentiles, and RAPM.`} />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:      #EFEEE8;
      --ink:     #0d0d14;
      --red:     #E8002D;
      --surface: #FFFFFF;
      --ink-06:  rgba(13,13,20,0.06);
      --ink-10:  rgba(13,13,20,0.10);
      --ink-14:  rgba(13,13,20,0.14);
      --ink-20:  rgba(13,13,20,0.20);
      --ink-32:  rgba(13,13,20,0.32);
      --ink-48:  rgba(13,13,20,0.48);
      --ink-72:  rgba(13,13,20,0.72);
      --display:   'Barlow Condensed', sans-serif;
      --body:      'Barlow', sans-serif;
      --mono:      'JetBrains Mono', monospace;
      --grid-line: rgba(13,13,20,0.04);
    }
    /* ── MASTHEAD REDESIGN ── */
    .mast-card {
      background: var(--surface); border: 1px solid var(--ink-14);
      border-left: 6px solid currentColor; padding: 28px 32px;
      display: flex; align-items: center; gap: 0; position: relative;
    }
    .mast-left { display: flex; align-items: center; gap: 28px; flex: 1; min-width: 0; }
    .headshot-circle-wrap { flex-shrink: 0; }
    .headshot-circle {
      width: 110px; height: 110px; border-radius: 50%; object-fit: cover;
      border: 3px solid var(--team-c, var(--ink)); display: block;
    }
    .identity-text { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
    .player-name {
      font-family: var(--display); font-weight: 800; font-size: clamp(36px,4.5vw,56px);
      text-transform: uppercase; line-height: 0.95; letter-spacing: -0.01em; color: var(--ink);
    }
    .player-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; }

    /* Hero tiles — flex row, shrink-0 on the right */
    .mast-right { display: flex; gap: 12px; flex-shrink: 0; margin-left: 28px; }
    .hero-tile {
      background: var(--bg); border: 1px solid var(--ink-14);
      padding: 16px 10px; text-align: center; min-width: 150px;
      flex: 1 1 0;
    }
    .tile-label { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 6px; }
    .tile-big { font-family: var(--display); font-weight: 800; font-size: 44px; line-height: 1; letter-spacing: -0.02em; }
    .tile-sub { font-family: var(--mono); font-size: 10px; color: var(--ink-48); margin-top: 4px; }

    /* G·A top row / PTS bottom — 2-row season tile */
    .season-tile { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; gap: 0; padding: 14px 10px; min-width: 130px; }
    .season-cell { text-align: center; padding: 4px 8px; }
    .season-cell.ga { border-bottom: 1px solid var(--ink-06); }
    .season-cell.ga + .season-cell.ga { border-left: 1px solid var(--ink-06); }
    .season-cell.pts { grid-column: 1 / -1; padding-top: 8px; }
    .season-cell-val { font-family: var(--display); font-weight: 800; font-size: 26px; line-height: 1; color: var(--ink); }
    .season-cell-lbl { font-family: var(--mono); font-size: 10px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-32); margin-top: 3px; }

    /* Shot map */
    .shot-map-wrap { padding: 12px 16px 16px; overflow: hidden; }
    .shot-map-svg { width: 100%; height: auto; display: block; overflow: visible; }
    .shot-map-legend { display: flex; align-items: center; gap: 16px; font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.04em; margin-top: 8px; justify-content: center; }
    .sm-legend-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; vertical-align: middle; margin-right: 4px; }
    .sm-legend-shot { background: transparent; border: 1.5px solid; }

    /* Breadcrumb */
    .breadcrumb { font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; color: var(--ink-32); margin-bottom: 14px; }
    .breadcrumb a { color: var(--ink-48); text-decoration: none; }
    .breadcrumb a:hover { color: var(--ink); }

    /* WAR breakdown card — matches percentile bar design language */
    .war-components { display: flex; flex-direction: column; gap: 0; padding: 0; }
    .war-row { display: grid; grid-template-columns: 110px 1fr 52px; align-items: center; gap: 10px; padding: 10px 18px; border-bottom: 1px solid var(--ink-06); }
    .war-row:last-child { border-bottom: 0; }
    .war-row-label { font-family: var(--display); font-weight: 500; font-size: 13px; color: rgba(13,13,20,0.72); }
    .war-bar-track { height: 10px; background: var(--ink-06); border-radius: 2px; overflow: hidden; }
    .war-bar-fill { height: 100%; border-radius: 2px; }
    .war-row-val { font-family: var(--mono); font-weight: 700; font-size: 14px; text-align: right; font-variant-numeric: tabular-nums; }
    .war-total-row { display: flex; align-items: center; justify-content: space-between; margin: 4px 18px 0; padding: 14px 0; border-top: 1px solid var(--ink-06); }
    .war-total-label { font-family: var(--display); font-weight: 700; font-size: 11px; color: rgba(13,13,20,0.72); text-transform: uppercase; letter-spacing: 0.08em; }
    .war-total-val { font-family: var(--mono); font-weight: 800; font-size: 22px; line-height: 1; }
    .war-total-val.pos { color: #00A86B; }
    .war-total-val.neg { color: var(--red); }
    .war-rank-note { font-family: var(--mono); font-size: 10px; color: var(--ink-32); text-align: center; padding: 0 18px 14px; letter-spacing: 0.03em; }

    /* Career stats table — chrome lives in Table.astro now; only the card wrap
       is page-specific. */
    .career-card .tbl-wrap { border: none; }

    /* Percentile bars */
    .pct-row { display: grid; grid-template-columns: 100px 40px 1fr 44px; align-items: center; gap: 10px; padding: 10px 18px; border-bottom: 1px solid var(--ink-06); }
    .pct-row:last-child { border-bottom: 0; }
    .pct-label { font-family: var(--display); font-weight: 500; font-size: 13px; color: rgba(13,13,20,0.72); }
    .pct-rate { font-family: var(--mono); font-weight: 400; font-size: 10px; color: rgba(13,13,20,0.45); min-width: 32px; text-align: right; font-variant-numeric: tabular-nums; }
    .pct-track { height: 10px; background: var(--ink-06); border-radius: 2px; overflow: hidden; }
    .pct-fill { height: 100%; border-radius: 2px; }
    .pct-pct { font-family: var(--mono); font-weight: 700; font-size: 12px; text-align: right; font-variant-numeric: tabular-nums; }

    /* RAPM grid */
    .rapm-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; }

    /* Rate stats sidebar grid */
    .rate-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--ink-06); }
    .rate-cell { background: var(--surface); padding: 14px 16px; }
    .rate-lbl { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32); margin-bottom: 4px; }
    .rate-val { font-family: var(--display); font-weight: 800; font-size: 26px; line-height: 1; letter-spacing: -0.01em; color: var(--ink); }
    .rate-val.neg { color: var(--red); }
    .rate-val.pos-green { color: #14803c; }

    /* Quick links sidebar */
    .quick-links { display: flex; flex-direction: column; }
    .quick-link { display: flex; align-items: center; justify-content: space-between; padding: 12px 18px; border-bottom: 1px solid var(--ink-06); text-decoration: none; color: var(--ink); font-family: var(--mono); font-size: 11px; letter-spacing: 0.04em; }
    .quick-link:last-child { border-bottom: none; }
    .quick-link:hover { background: var(--bg); }
    .quick-link-arrow { color: var(--ink-32); }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; }


    /* Layout */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

    /* Masthead — full-bleed grid (matches Teams/Home/Stats pattern) */
    .mast {
      position: relative; overflow: hidden;
      border-bottom: 2px solid var(--ink);
      background-color: var(--bg);
      background-image:
        linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px;
    }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-top a { color: var(--ink-48); text-decoration: none; }
    .mast-top a:hover { color: var(--ink); }
    /* .mast-card defined above in NEW DESIGN ADDITIONS — no override here */
    .hero { display: grid; grid-template-columns: auto 1fr; gap: 28px; align-items: start; }
    .headshot-wrap { position: relative; width: 168px; flex-shrink: 0; }
    .headshot { width: 168px; height: 168px; object-fit: cover; border: 2px solid var(--ink-14); background: var(--surface); display: block; }
    .headshot-team-bar { position: absolute; bottom: 0; left: 0; right: 0; height: 4px; }
    .hero-identity { display: flex; flex-direction: column; gap: 8px; }
    .hero-badges { display: flex; gap: 6px; flex-wrap: wrap; }
    .badge { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-48); border: 1px solid var(--ink-14); padding: 2px 8px; }
    .hero-name { font-family: var(--display); font-weight: 800; text-transform: uppercase; line-height: 0.92; letter-spacing: -0.01em; }
    .hero-name .first { font-size: 24px; color: var(--ink-48); font-weight: 700; }
    .hero-name .last  { font-size: clamp(40px, 5vw, 64px); color: var(--ink); display: block; }

    /* Stats table */
    .stats-table { display: grid; grid-template-columns: 110px repeat(6, 1fr); border-top: 1px solid var(--ink-10); margin-top: 10px; }
    .stat-val.war-pos { color: #14803c; }
    .stat-val.war-neg { color: var(--red); }
    .stats-cell { padding: 8px 6px 6px; }
    .stats-cell.col-header { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32); padding-bottom: 4px; border-bottom: 1px solid var(--ink-10); text-align: center; }
    .stats-cell.season-lbl { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-48); border-bottom: 1px solid var(--ink-06); display: flex; align-items: center; }
    .stats-cell.stat-val { font-family: var(--mono); font-weight: 700; font-size: 18px; color: var(--ink); letter-spacing: -0.01em; font-variant-numeric: tabular-nums; border-bottom: 1px solid var(--ink-06); text-align: center; }

    /* Content grid */
    .content { display: grid; grid-template-columns: 1fr 280px; gap: 24px; padding: 28px 0 80px; align-items: start; }
    .explore-pills { display: flex; flex-wrap: wrap; gap: 8px; }
    .explore-pill { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-48); border: 1px solid var(--ink-14); padding: 5px 10px; text-decoration: none; transition: color 0.1s, border-color 0.1s; white-space: nowrap; }
    .explore-pill:hover { color: var(--ink); border-color: var(--ink-32); }

    /* Card-head chip groups push to the right edge (was inline margin-left:auto) */
    :global(.chip-group.rapm-mode-chips),
    :global(.chip-group.peers-mode-chips) { margin-left: auto; }
    .content-main { display: flex; flex-direction: column; gap: 16px; }
    .content-side { display: flex; flex-direction: column; gap: 16px; }

    /* Cards */
    .card { background: var(--surface); border: 1px solid var(--ink-14); box-shadow: 0 1px 3px rgba(13,13,20,0.06); }
    .card-head { padding: 14px 18px 12px; border-bottom: 1px solid var(--ink-06); display: flex; align-items: baseline; justify-content: space-between; }
    .card-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(13,13,20,0.72); }
    .card-eyebrow .accent { color: var(--red); }
    .card-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* RAPM */
    .rapm-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; }
    .rapm-cell { padding: 18px 16px 16px; border-right: 1px solid var(--ink-06); text-align: center; }
    .rapm-cell:last-child { border-right: 0; }
    .rapm-cell.net { background: var(--bg); }
    .rapm-val { font-family: var(--display); font-weight: 800; font-size: 44px; line-height: 1; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
    .rapm-val.pos { color: #14803c; }
    .rapm-val.neg { color: var(--red); }
    .rapm-val.net-val { font-size: 56px; }
    .rapm-val.null-val { font-size: 32px; color: var(--ink-32); }
    .rapm-dim { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-32); margin-top: 4px; }
    .rapm-context { padding: 10px 18px; border-top: 1px solid var(--ink-06); font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; }
    .rapm-context strong { color: var(--ink); }

    /* Percentile bars — layout defined above in NEW DESIGN ADDITIONS */
    .pct-rows { display: flex; flex-direction: column; gap: 0; }

    /* Game log */
    /* Game log — chrome lives in Table.astro now. */

    /* ── Impact trend chart ── */
    .impact-chart-wrap { padding: 0 2px 4px; }
    .impact-chart-svg  { width: 100%; height: auto; display: block; overflow: visible; }
    .impact-dot { cursor: crosshair; }
    #imp-tip { position: fixed; pointer-events: none; display: none; z-index: 100;
      background: var(--surface); color: var(--ink); padding: 6px 10px;
      font-family: var(--mono); font-size: 10px; white-space: nowrap; border-radius: 2px;
      border: 1px solid var(--ink-14); box-shadow: 0 2px 8px rgba(13,13,20,0.12); }
    #imp-tip .tip-ctx  { color: var(--ink-48); margin-right: 6px; }
    #imp-tip .tip-val  { font-weight: 700; }

    /* CTA sidebar card */
    .cta-card { background: var(--ink); padding: 22px 18px; }
    .cta-title { font-family: var(--display); font-weight: 800; font-size: 22px; text-transform: uppercase; color: #fff; letter-spacing: 0.01em; margin-bottom: 6px; }
    .cta-desc { font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.4); letter-spacing: 0.04em; margin-bottom: 16px; line-height: 1.6; }
    .cta-formats { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
    .cta-fmt { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 8px; border: 1px solid rgba(255,255,255,0.16); color: rgba(255,255,255,0.48); cursor: pointer; }
    .cta-btn { display: block; width: 100%; background: var(--red); color: #fff; font-family: var(--display); font-weight: 800; font-size: 15px; letter-spacing: 0.14em; text-transform: uppercase; padding: 12px 16px; border: none; cursor: pointer; text-align: center; text-decoration: none; }
    .cta-note { font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; color: rgba(255,255,255,0.24); margin-top: 8px; text-align: center; }

    /* Similar players */
    .peer-strip { display: flex; flex-direction: column; gap: 0; }
    .peer-row { display: flex; align-items: center; gap: 10px; padding: 10px 18px; border-bottom: 1px solid var(--ink-06); text-decoration: none; color: inherit; }
    .peer-row:last-child { border-bottom: 0; }
    .peer-row:hover { background: var(--bg); }
    .peer-name { font-family: var(--display); font-weight: 500; font-size: 13px; color: rgba(13,13,20,0.72); flex: 1; }
    .peer-meta { font-family: var(--display); font-weight: 400; font-size: 10px; color: rgba(13,13,20,0.48); letter-spacing: 0; }
    .peer-rapm { font-family: var(--mono); font-weight: 700; font-size: 14px; font-variant-numeric: tabular-nums; }
    .peer-rapm.pos { color: #00A86B; }
    .peer-rapm.neg { color: var(--red); }

    /* Methodology */
    .method-card { padding: 14px 18px; }
    .method-text { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.03em; line-height: 1.65; }
    .method-link { display: inline-block; margin-top: 10px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--red); text-decoration: none; }

    /* Footer */
    footer { background: var(--ink); padding: 32px 0; font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.24); letter-spacing: 0.06em; text-align: center; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .mast-inner { padding: 24px 20px; }
      .mast-top { flex-direction: column; align-items: flex-start; gap: 6px; }
      .hero { grid-template-columns: 1fr; gap: 18px; }
      .headshot-wrap { width: 120px; }
      .headshot { width: 120px; height: 120px; }
      .stats-table { overflow-x: auto; display: block; white-space: nowrap; }
      /* minmax(0,1fr) stops 1fr expanding to children's min-content width */
      .content { grid-template-columns: minmax(0, 1fr); gap: 16px; padding: 20px 0 60px; }
      .content-main, .content-side { min-width: 0; overflow: hidden; }
      .wrap { padding: 0 20px; }
      .rapm-val.net-val { font-size: 44px; }
      .rapm-val { font-size: 36px; }

      /* ── Masthead: stack left (headshot+name) above right (tiles) ── */
      .mast-card {
        flex-direction: column;
        align-items: stretch;
        padding: 16px 18px 14px;
        gap: 14px;
      }
      .mast-left { gap: 16px; }
      .headshot-circle { width: 72px; height: 72px; }
      .player-name { font-size: clamp(28px, 7vw, 44px); }
      /* Tiles become equal-width flex row across full card width */
      .mast-right {
        margin-left: 0;
        gap: 8px;
      }
      .hero-tile {
        flex: 1;
        min-width: 0;
        padding: 10px 8px;
      }
      .tile-big { font-size: 28px; }
      .tile-label { font-size: 10px; margin-bottom: 4px; }
      .tile-sub { font-size: 10px; }
      .season-tile { min-width: 0; padding: 10px 8px; }
      .season-cell-val { font-size: 20px; }
      .season-cell-lbl { font-size: 10px; }
    }

    @media (max-width: 480px) {
      .mast-inner { padding: 16px; }
      .mast-card { padding: 14px 14px 12px; gap: 12px; }
      .wrap { padding: 0 16px; }
      .headshot-circle { width: 64px; height: 64px; }
      .player-name { font-size: clamp(24px, 7.5vw, 38px); }
      .hero-name .last { font-size: clamp(32px, 8vw, 52px); }
      .headshot-wrap { width: 100px; }
      .headshot { width: 100px; height: 100px; }
      .rapm-grid { grid-template-columns: 1fr 1fr; }
      .rapm-cell.net { grid-column: 1 / -1; border-bottom: 1px solid var(--ink-06); border-right: none; }
      .rapm-val.net-val { font-size: 40px; }
      .rapm-val { font-size: 32px; }
      /* Percentile bars: compress rate column */
      .pct-row { grid-template-columns: 76px 32px 1fr 36px; gap: 5px; padding: 8px 12px; }
      .pct-label { font-size: 11px; }
      .pct-rate { font-size: 9px; }
      .pct-pct { font-size: 11px; }
      .content { padding: 16px 0 48px; }
      /* WAR breakdown: tighter label column */
      .war-row { grid-template-columns: 90px 1fr 44px; gap: 8px; padding: 9px 12px; }
      .war-row-label { font-size: 11px; }
      .war-row-val { font-size: 13px; }
      /* Card heads: allow meta to wrap below eyebrow */
      .card-head { flex-wrap: wrap; gap: 2px 8px; padding: 12px 14px 10px; }
      .card-meta { font-size: 9px; }
    }

    /* ── NHL EDGE section ── */
    .edge-stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--ink-06); border-bottom: 1px solid var(--ink-06); }
    .edge-stat-cell { background: var(--surface); padding: 14px 18px 12px; display: flex; flex-direction: column; gap: 4px; }
    .edge-stat-lbl  { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.08em; text-transform: uppercase; }
    .edge-stat-val  { font-family: var(--display); font-weight: 800; font-size: 28px; line-height: 1; color: var(--ink); }
    .edge-stat-unit { font-family: var(--body); font-weight: 600; font-size: 14px; color: var(--ink-48); }
    .edge-bar-track { height: 7px; background: var(--ink-06); border-radius: 2px; overflow: hidden; }
    .edge-bar-fill  { height: 100%; border-radius: 2px; transition: width 0.3s; }
    .edge-stat-pct  { font-family: var(--body); font-weight: 600; font-size: 11px; }
    .edge-stat-avg  { font-family: var(--mono); font-size: 10px; color: var(--ink-32); }

    .edge-zone { padding: 16px 18px 14px; border-bottom: 1px solid var(--ink-06); }
    .edge-zone-lbl  { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px; }
    .edge-zone-note { color: var(--team-color, var(--ink)); font-weight: 700; }
    .edge-zone-bar  { height: 20px; display: flex; border-radius: 4px; overflow: hidden; margin-bottom: 10px; }
    .edge-zone-oz   { background: var(--team-color, var(--ink)); }
    .edge-zone-nz   { background: rgba(13,13,20,0.15); }
    .edge-zone-dz   { background: rgba(232,0,45,0.28); }
    .edge-zone-labels { display: flex; }
    .edge-zone-seg  { display: flex; flex-direction: column; min-width: 0; }
    .edge-zone-pct  { font-family: var(--display); font-weight: 800; font-size: 18px; color: var(--ink); line-height: 1; }
    .edge-zone-name { font-family: var(--mono); font-size: 10px; color: var(--ink-48); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px; }

    .edge-shot-header { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.08em; text-transform: uppercase; padding: 14px 18px 10px; border-bottom: 1px solid var(--ink-06); }
    .edge-shot-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: var(--ink-06); }
    .edge-shot-col  { background: var(--surface); padding: 12px 14px 14px; display: flex; flex-direction: column; gap: 8px; }
    .edge-shot-chip { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 7px; border-radius: 2px; background: var(--ink-06); color: var(--ink-48); width: fit-content; }
    .edge-shot-chip.accent-chip { background: rgba(var(--team-color-rgb, 0,32,91), 0.10); color: var(--team-color, var(--ink)); }
    .edge-shot-row  { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .edge-shot-sublbl { font-family: var(--mono); font-size: 10px; color: var(--ink-32); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1px; }
    .edge-shot-n    { font-family: var(--display); font-weight: 800; font-size: 22px; color: var(--ink); line-height: 1; }
    .edge-shot-pct  { font-family: var(--body); font-size: 10px; font-weight: 600; margin: 1px 0; }
    .edge-mini-bar  { height: 4px; background: var(--ink-06); border-radius: 2px; overflow: hidden; }
    .edge-mini-fill { height: 100%; border-radius: 2px; }
  </style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<!-- MASTHEAD -->
<section class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="breadcrumb">
      <a href="/stats">HGB Stats</a> / <a href="/stats/skaters">Players</a> / {player.first_name} {player.last_name}
    </div>
    <div class="mast-card" style={`border-left-color: ${teamColor}; color: ${teamColor}; --team-c: ${teamColor}`}>
      <!-- Left: headshot + identity -->
      <div class="mast-left">
        <div class="headshot-circle-wrap">
          <img class="headshot-circle" src={headshotUrl}
            alt={`${player.first_name} ${player.last_name}`}
            width="110" height="110" style={`border-color: ${teamColor}`} />
        </div>
        <div class="identity-text">
          <div class="player-name">{player.first_name}<br/>{player.last_name}</div>
          <div class="player-meta">
            {player.team_abbrev} · {posLabel} · {player.gp} GP · 2025–26
          </div>
        </div>
      </div>

      <!-- Right: 3 stat tiles -->
      <div class="mast-right">
        <div class="hero-tile">
          <div class="tile-label">HGB Rating</div>
          <div class="tile-big" style={`color:${teamColor}`}>
            {player.hgb_rating_percentile != null ? `${player.hgb_rating_percentile}%` : '—'}
          </div>
          <div class="tile-sub">
            {player.hgb_rating != null ? `${player.hgb_rating > 0 ? '+' : ''}${player.hgb_rating.toFixed(2)} Rating` : '—'}
            {(player.hgb_rating_confidence === 'limited' || player.hgb_rating_confidence === 'limited_sample') ? ' · limited sample' : ''}
          </div>
        </div>
        <div class="hero-tile">
          <div class="tile-label">HGB WAR</div>
          <div class="tile-big" style={`color:${teamColor}`}>
            {warPct != null ? `${warPct}%` : '—'}
          </div>
          <div class="tile-sub">
            {player.war != null ? `${sign(player.war)}${player.war.toFixed(2)} WAR` : '—'}
          </div>
        </div>
        <div class="hero-tile">
          <div class="tile-label">HGB Game Impact</div>
          <div class="tile-big" style={`color:${teamColor}`}>
            {Math.round(player.percentiles_vs_pos.game_score)}%
          </div>
          <div class="tile-sub">{sign(player.avg_gs_display)}{player.avg_gs_display.toFixed(2)} avg</div>
        </div>
        <div class="hero-tile season-tile">
          <div class="season-cell ga">
            <div class="season-cell-val" id="gap-g-val"
              data-totals={String(totalGoals)}
              data-per60={player.rates_per_60.goals.toFixed(2)}>{totalGoals}</div>
            <div class="season-cell-lbl" id="gap-g-lbl">G</div>
          </div>
          <div class="season-cell ga">
            <div class="season-cell-val" id="gap-a-val"
              data-totals={String(totalAssists)}
              data-per60={totTOIhr > 0 ? (totalAssists / totTOIhr).toFixed(2) : '—'}>{totalAssists}</div>
            <div class="season-cell-lbl" id="gap-a-lbl">A</div>
          </div>
          <div class="season-cell pts">
            <div class="season-cell-val" id="gap-p-val" style={`color:${teamColor}`}
              data-totals={String(totalGoals + totalAssists)}
              data-per60={pts60 != null ? pts60.toFixed(2) : '—'}>{totalGoals + totalAssists}</div>
            <div class="season-cell-lbl" id="gap-p-lbl">PTS</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="wrap">
  <div class="content">

    <!-- MAIN -->
    <div class="content-main">

      <!-- EXPLORE PILLS -->
      <div class="explore-pills">
        <a href={`/stats/lines?team=${player.team_abbrev}&player=${player.player_id}`} class="explore-pill">{player.first_name}'s Line Combos →</a>
        <a href={`/stats/wowy?player=${player.player_id}`} class="explore-pill">WOWY — With or Without →</a>
        <a href="/stats/skaters" class="explore-pill">Leaderboards →</a>
      </div>

      <!-- WAR BREAKDOWN -->
      {player.war != null && (() => {
        const wc          = player.war_components;
        const ev5RapmComp = wc?.ev5_rapm_war  ?? wc?.ev5 ?? 0;
        const finishComp  = wc?.finishing_war  ?? 0;
        const ppComp      = wc?.pp  ?? 0;
        const pkComp      = wc?.pk  ?? 0;
        const penComp     = wc?.pen ?? 0;
        const fmt     = (v: number) => (v >= 0 ? '+' : '') + v.toFixed(2);
        // Fixed reference scale: WAR=4.0 fills 100% — bars comparable across all players
        const BAR_REF = 4.0;
        const pct     = (v: number) => Math.max(0, Math.min(100, (Math.abs(v) / BAR_REF) * 100)).toFixed(1);
        const mkRow = (label: string, val: number, isFirst: boolean) => ({
          label, val,
          barC: val >= 0.02 ? (isFirst ? teamColor : '#34a853') : val <= -0.02 ? 'var(--red)' : 'rgba(13,13,20,0.20)',
          valC: val >= 0.02 ? (isFirst ? teamColor : '#14803c') : val <= -0.02 ? 'var(--red)' : 'var(--ink-32)',
        });
        const rows = [
          mkRow('EV5 RAPM',          ev5RapmComp, true),
          mkRow('Finishing',         finishComp,  false),
          mkRow('PP RAPM',           ppComp,      false),
          mkRow('PK RAPM',           pkComp,      false),
          mkRow('Pen. Differential', penComp,     false),
        ].filter(r => wc != null || r.label === 'EV5 RAPM');
        return (
          <div class="card">
            <div class="card-head">
              <span class="card-eyebrow">WAR <span class="accent">Breakdown</span></span>
              <span class="card-meta">2025–26 season · WAR components</span>
            </div>
            <div class="war-components">
              {rows.map(r => (
                <div class="war-row">
                  <div class="war-row-label">{r.label}</div>
                  <div class="war-bar-track">
                    <div class="war-bar-fill" style={`width:${pct(r.val)}%;background:${r.barC}`}></div>
                  </div>
                  <div class="war-row-val" style={`color:${r.valC}`}>{fmt(r.val)}</div>
                </div>
              ))}
            </div>
            <div class="war-total-row">
              <div class="war-total-label">Total WAR</div>
              <div class={`war-total-val ${player.war >= 0 ? 'pos' : 'neg'}`}>{fmt(player.war)}</div>
            </div>
          </div>
        );
      })()}

      <!-- CAREER STATS TABLE -->
      {player.career_seasons && player.career_seasons.length > 0 && (
        <div class="card career-card">
          <div class="card-head">
            <span class="card-eyebrow">Career Stats &nbsp;<span class="accent">Season by Season</span></span>
            <span class="card-meta">5v5 · min 600 TOI</span>
          </div>
          <Table
            columns={careerColumns}
            rows={careerRows}
            defaultSort={{ column: 'season_fmt', direction: 'desc' }}
            sticky={false}
            ariaLabel="Career season-by-season stats"
          />
        </div>
      )}

      <!-- PERCENTILE PROFILE (all bars unified — SEASON / RATING·3yr toggle) -->
      {(() => {
        // EV RAPM bars — swap between season percentile and 3yr Rating percentile
        const rapmBars = [
          {
            label: 'EV Offense',
            key: 'ev_offence',
            val: player.percentiles_vs_pos.ev_offence,
            ratingVal: player.hgb_rating_off_pct ?? null,
            isBlue: false,
            isRed: false,
          },
          {
            label: 'EV Defense',
            key: 'ev_defence',
            val: player.percentiles_vs_pos.ev_defence,
            ratingVal: player.hgb_rating_def_pct ?? null,
            isBlue: true,
            isRed: false,
          },
        ];
        // Counting stat bars — swap between season and 3yr weighted percentiles
        const rateBars = [
          { label: 'Goals / 60', key: 'goals',    val: player.percentiles_vs_pos.goals,     ratingPct: player.g_60_pct_3yr ?? null,        ratingRate: player.g_60_3yr ?? null,        isBlue: false, isRed: false },
          { label: 'A1 / 60',    key: 'a1',       val: player.percentiles_vs_pos.a1,        ratingPct: player.a1_60_pct_3yr ?? null,       ratingRate: player.a1_60_3yr ?? null,       isBlue: false, isRed: false },
          { label: 'xG / 60',    key: 'ixg',      val: player.percentiles_vs_pos.ixg,       ratingPct: player.xg_60_pct_3yr ?? null,       ratingRate: player.xg_60_3yr ?? null,       isBlue: false, isRed: false },
          { label: 'Finishing',  key: 'finishing', val: player.percentiles_vs_pos.finishing, ratingPct: player.finishing_pct_3yr ?? null,   ratingRate: player.finishing_3yr ?? null,   isBlue: false, isRed: false },
          { label: 'Shots / 60', key: 'shots',    val: player.percentiles_vs_pos.shots,     ratingPct: player.s_60_pct_3yr ?? null,        ratingRate: player.s_60_3yr ?? null,        isBlue: false, isRed: false },
          { label: 'Pen. Diff',  key: 'pen_diff', val: player.percentiles_vs_pos.pen_diff,  ratingPct: player.pen_diff_pct_3yr ?? null,    ratingRate: player.pen_diff_60_3yr ?? null, isBlue: false, isRed: false },
          ...(player.qoc != null ? [{ label: 'Opp. Quality', key: 'qoc', val: player.qoc, ratingPct: player.qoc_pct_3yr ?? null, ratingRate: null, isBlue: false, isRed: true }] : []),
          ...(player.qot != null ? [{ label: 'Mate Quality', key: 'qot', val: player.qot, ratingPct: player.qot_pct_3yr ?? null, ratingRate: null, isBlue: true,  isRed: false }] : []),
        ];
        return (
          <div class="card" id="pct-profile-card">
            <div class="card-head">
              <span class="card-eyebrow">Percentile Profile &nbsp;<span class="accent">vs. {posPlural}</span></span>
              <ChipGroup
                id="rapm-mode-filter"
                name="rapm-mode"
                className="rapm-mode-chips"
                items={[
                  { label: 'Season', value: 'season', active: true },
                  { label: 'Rating · 3yr', value: 'rating' },
                ]}
              />
            </div>
            <div class="pct-rows">
              {rapmBars.map(bar => {
                const tierC = bar.val >= 75
                  ? (bar.isBlue ? '#4285f4' : '#137333')
                  : bar.val >= 50
                    ? (bar.isBlue ? '#7baaf7' : '#34a853')
                    : bar.val >= 25 ? 'rgba(13,13,20,0.32)' : '#E8002D';
                return (
                  <div class="pct-row"
                    data-bar-key={bar.key}
                    data-season-val={bar.val.toFixed(1)}
                    data-rating-val={bar.ratingVal != null ? bar.ratingVal.toFixed(1) : ''}
                    data-is-blue={bar.isBlue ? 'true' : 'false'}
                    data-is-red="false"
                  >
                    <span class="pct-label"><span class="rapm-bar-base-label">{bar.label}</span><span class="rapm-bar-3yr-suffix" style="display:none;font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:400;color:rgba(13,13,20,0.45);margin-left:4px;">· 3yr</span></span>
                    <span class="pct-rate"></span>
                    <div class="pct-track">
                      <div class="pct-fill" style={`width:${bar.val.toFixed(1)}%;background:${tierC}`}></div>
                    </div>
                    <span class="pct-pct" style={`color:${tierC}`}>{Math.round(bar.val)}%</span>
                  </div>
                );
              })}
              {rateBars.map(bar => {
                const rate = player.rates_per_60[bar.key as keyof typeof player.rates_per_60] as number | undefined;
                const tierC = bar.val >= 75
                  ? (bar.isBlue ? '#4285f4' : bar.isRed ? '#842029' : '#137333')
                  : bar.val >= 50
                    ? (bar.isBlue ? '#7baaf7' : bar.isRed ? '#c03244' : '#34a853')
                    : bar.val >= 25 ? 'rgba(13,13,20,0.32)' : '#E8002D';
                return (
                  <div class="pct-row"
                    data-rate-key={bar.key}
                    data-season-val={bar.val.toFixed(1)}
                    data-rating-val={bar.ratingPct != null ? Number(bar.ratingPct).toFixed(1) : ''}
                    data-season-rate={rate != null ? rate.toFixed(2) : ''}
                    data-rating-rate={bar.ratingRate != null ? Number(bar.ratingRate).toFixed(2) : ''}
                    data-is-blue={bar.isBlue ? 'true' : 'false'}
                    data-is-red={bar.isRed ? 'true' : 'false'}
                  >
                    <span class="pct-label">{bar.label}</span>
                    <span class="pct-rate">{rate != null ? rate.toFixed(2) : '—'}</span>
                    <div class="pct-track">
                      <div class="pct-fill" style={`width:${bar.val.toFixed(1)}%;background:${tierC}`}></div>
                    </div>
                    <span class="pct-pct" style={`color:${tierC}`}>{Math.round(bar.val)}%</span>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })()}

      <!-- SHOT MAP -->
      {shotMapSVG && (
        <div class="card">
          <div class="card-head">
            <span class="card-eyebrow">Shot Map &nbsp;<span class="accent">Offensive Zone</span></span>
            <span class="card-meta">{playerShots.length} shots · all situations · 2025–26</span>
          </div>
          <div class="shot-map-wrap">
            <Fragment set:html={shotMapSVG} />
            <div class="shot-map-legend">
              <span class="sm-legend-dot" style={`background:${teamColor};opacity:0.9`}></span> Goals
              <span class="sm-legend-dot sm-legend-shot" style={`border-color:${teamColor}`}></span> Shots
            </div>
          </div>
        </div>
      )}

      <!-- IMPACT TREND -->
      <div class="card">
        <div class="card-head">
          <span class="card-eyebrow">HGB Impact &nbsp;<span class="accent">Season Trend</span></span>
          <span class="card-meta">Avg {sign(player.avg_gs_display)}{player.avg_gs_display.toFixed(2)} · {allGames.length} games</span>
        </div>
        {allGames.length > 1 && (
          <div class="impact-chart-wrap">
            <svg class="impact-chart-svg" viewBox={`0 0 ${IW} ${IH}`} preserveAspectRatio="xMidYMid meet">
              <line x1={IP.l} y1={ipy0.toFixed(1)} x2={(IP.l+iCW).toFixed(1)} y2={ipy0.toFixed(1)}
                stroke="rgba(13,13,20,0.18)" stroke-width="1" stroke-dasharray="3 3" />
              {[-4, 0, 4, 8, 12].map(v => (
                <text x={(IP.l-4).toFixed(1)} y={ipy(v).toFixed(1)} text-anchor="end"
                  dominant-baseline="middle" font-family="JetBrains Mono,monospace"
                  font-size="9" fill="rgba(13,13,20,0.28)">
                  {v >= 0 ? '+' : ''}{v}
                </text>
              ))}
              {iArea && <path d={iArea} fill={teamColor} fill-opacity="0.08" />}
              <path d={iPath} fill="none" stroke={teamColor} stroke-width="2"
                stroke-linejoin="round" stroke-linecap="round" />
              {allGames.map((g, i) => {
                const cx = ipx(i).toFixed(1), cy = ipy(g.gs_display).toFixed(1);
                const sgn = g.gs_display >= 0 ? '+' : '';
                const tip = `${g.game_date} ${g.is_home ? 'vs' : '@'} ${g.opp_abbrev} · ${sgn}${g.gs_display.toFixed(2)}`;
                return (
                  <circle cx={cx} cy={cy} r="6" fill="transparent" class="impact-dot"
                    data-tip={tip} data-val={g.gs_display} />
                );
              })}
            </svg>
            <div id="imp-tip"></div>
          </div>
        )}
      </div>

      <!-- NHL EDGE DATA -->
      {player.edge != null && (() => {
        const e = player.edge!;
        const oz = e.oz_pct ?? 0, nz = e.nz_pct ?? 0, dz = e.dz_pct ?? 0;
        const total = oz + nz + dz || 1;
        return (
          <div class="card" id="edge-section" style={`--team-color:${teamColor}`}>
            <div class="card-head">
              <span class="card-eyebrow">NHL EDGE &nbsp;<span class="accent">Athlete Tracking</span></span>
              <span class="card-meta">2025–26 season</span>
            </div>
            <!-- Speed + Distance 2×2 grid -->
            <div class="edge-stat-grid">
              {[
                { lbl: 'Top Speed',        val: e.speed_max_mph,        unit: 'mph', pct: e.speed_max_pct,         avg: e.speed_max_league_avg_mph,        avgUnit: 'mph' },
                { lbl: 'Miles Skated',     val: e.distance_mi,          unit: 'mi',  pct: e.distance_pct,           avg: e.distance_league_avg_mi,          avgUnit: 'mi'  },
                { lbl: 'Bursts > 20 mph',  val: e.bursts_over_20,       unit: '',    pct: e.bursts_over_20_pct,     avg: e.bursts_over_20_league_avg,       avgUnit: ''    },
                { lbl: 'Hardest Shot',     val: e.shot_speed_max_mph,   unit: 'mph', pct: e.shot_speed_max_pct,     avg: e.shot_speed_max_league_avg_mph,   avgUnit: 'mph' },
              ].map(stat => {
                const pct = stat.pct ?? 0;
                const tierC = pct >= 75 ? '#137333' : pct >= 50 ? '#34a853' : pct >= 25 ? 'rgba(13,13,20,0.32)' : '#E8002D';
                return (
                  <div class="edge-stat-cell">
                    <div class="edge-stat-lbl">{stat.lbl}</div>
                    {stat.val != null
                      ? <div class="edge-stat-val">{stat.val}<span class="edge-stat-unit">{stat.unit ? ` ${stat.unit}` : ''}</span></div>
                      : <div class="edge-stat-val">—</div>}
                    <div class="edge-bar-track">
                      <div class="edge-bar-fill" style={`width:${pct}%;background:${tierC}`}></div>
                    </div>
                    <div class="edge-stat-pct" style={`color:${tierC}`}>
                      {stat.pct != null ? `${Math.round(stat.pct)}th percentile` : '—'}
                    </div>
                    {stat.avg != null && <div class="edge-stat-avg">avg {stat.avg}{stat.avgUnit ? ` ${stat.avgUnit}` : ''}</div>}
                  </div>
                );
              })}
            </div>

            <!-- Zone time -->
            <div class="edge-zone">
              <div class="edge-zone-lbl">Zone Time — Even Strength
                {e.oz_ev_pct_pct != null && <span class="edge-zone-note"> · OZ {Math.round(e.oz_ev_pct_pct)}th percentile</span>}
              </div>
              <div class="edge-zone-bar">
                <div class="edge-zone-oz" style={`width:${(oz/total*100).toFixed(1)}%`}></div>
                <div class="edge-zone-nz" style={`width:${(nz/total*100).toFixed(1)}%`}></div>
                <div class="edge-zone-dz" style={`width:${(dz/total*100).toFixed(1)}%`}></div>
              </div>
              <div class="edge-zone-labels">
                <div class="edge-zone-seg" style={`width:${(oz/total*100).toFixed(1)}%`}>
                  <span class="edge-zone-pct">{oz.toFixed(0)}%</span>
                  <span class="edge-zone-name">Offensive</span>
                </div>
                <div class="edge-zone-seg" style={`width:${(nz/total*100).toFixed(1)}%`}>
                  <span class="edge-zone-pct">{nz.toFixed(0)}%</span>
                  <span class="edge-zone-name">Neutral</span>
                </div>
                <div class="edge-zone-seg" style={`width:${(dz/total*100).toFixed(1)}%`}>
                  <span class="edge-zone-pct">{dz.toFixed(0)}%</span>
                  <span class="edge-zone-name">Defensive</span>
                </div>
              </div>
            </div>

            <!-- Shot location by danger zone -->
            <div class="edge-shot-header">Shot Location by Danger Zone</div>
            <div class="edge-shot-grid">
              {[
                { lbl: 'High Danger', n: e.shots_high, np: e.shots_high_pct, sh: e.shooting_pct_high, shp: e.shooting_pct_high_pct, accent: true },
                { lbl: 'Mid Range',   n: e.shots_mid,  np: e.shots_mid_pct,  sh: e.shooting_pct_mid,  shp: e.shooting_pct_mid_pct,  accent: false },
                { lbl: 'Long Range',  n: e.shots_long, np: e.shots_long_pct, sh: e.shooting_pct_long, shp: e.shooting_pct_long_pct, accent: false },
              ].map(z => {
                const np = z.np ?? 0, shp = z.shp ?? 0;
                const npC  = np  >= 75 ? '#137333' : np  >= 50 ? '#34a853' : np  >= 25 ? 'rgba(13,13,20,0.32)' : '#E8002D';
                const shpC = shp >= 75 ? '#137333' : shp >= 50 ? '#34a853' : shp >= 25 ? 'rgba(13,13,20,0.32)' : '#E8002D';
                return (
                  <div class="edge-shot-col">
                    <div class={`edge-shot-chip ${z.accent ? 'accent-chip' : ''}`}>{z.lbl}</div>
                    <div class="edge-shot-row">
                      <div>
                        <div class="edge-shot-sublbl">Attempts</div>
                        <div class="edge-shot-n">{z.n ?? '—'}</div>
                        <div class="edge-shot-pct" style={`color:${npC}`}>{z.np != null ? `${Math.round(z.np)}th` : ''}</div>
                        <div class="edge-mini-bar"><div class="edge-mini-fill" style={`width:${np}%;background:${npC}`}></div></div>
                      </div>
                      <div>
                        <div class="edge-shot-sublbl">Sh%</div>
                        <div class="edge-shot-n">{z.sh != null ? `${z.sh}%` : '—'}</div>
                        <div class="edge-shot-pct" style={`color:${shpC}`}>{z.shp != null ? `${Math.round(z.shp)}th` : ''}</div>
                        <div class="edge-mini-bar"><div class="edge-mini-fill" style={`width:${shp}%;background:${shpC}`}></div></div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })()}

      <!-- GAME LOG -->
      <div class="card">
        <div class="card-head">
          <span class="card-eyebrow">Game log &nbsp;<span class="accent">2025–26</span></span>
          <span class="card-meta">{recentGames.length} games · newest first</span>
        </div>
        <Table
          columns={gameLogColumns}
          rows={gameLogRows}
          rowHref={(r) => r.game_id ? `/games/${r.game_id}` : undefined}
          sticky={false}
          ariaLabel="Game log"
        />
      </div>

    </div>

    <!-- SIDEBAR -->
    <aside class="content-side">

      <!-- Share Card CTA — three card options -->
      <div class="cta-card">
        <button id="download-rating-card-btn" class="cta-btn" style={`width:100%;cursor:pointer;border:none;margin-bottom:8px;background:${teamColor};color:#ffffff;font-weight:800;`}>
          Rating Card →
        </button>
        <button id="download-card-btn" class="cta-btn" style={`width:100%;cursor:pointer;border:none;margin-bottom:8px;background:${teamColor};color:#ffffff;font-weight:700;opacity:0.85;`}>
          Player Card →
        </button>
        <button id="download-expanded-btn" class="cta-btn" style={`width:100%;cursor:pointer;border:1px solid ${teamColor};margin-bottom:8px;background:#0D0D14;color:${teamColor};`}>
          Expanded Card →
        </button>
        <button id="download-edge-btn" class="cta-btn" style={`width:100%;cursor:pointer;border:1px solid ${teamColor};background:#0D0D14;color:${teamColor};`}>
          NHL EDGE Card →
        </button>
        <div class="cta-note" id="card-status">750px · Discord-friendly · 2× retina PNG</div>
      </div>

      <!-- Similar Players -->
      {peers.length > 0 && (
        <div class="card" id="peers-card">
          <div class="card-head">
            <span class="card-eyebrow">Similar &nbsp;<span class="accent">{posPlural}</span></span>
            <ChipGroup
              id="peers-mode-filter"
              name="peers-mode"
              className="peers-mode-chips"
              items={[
                { label: 'WAR', value: 'war', active: true },
                { label: 'Rating', value: 'rating' },
              ]}
            />
          </div>
          {/* WAR peers */}
          <div class="peer-strip" id="peers-war">
            {peers.map(peer => (
              <a href={`/stats/player/${peer.slug}`} class="peer-row">
                <div style="flex:1">
                  <div class="peer-name">{peer.first_name[0]}. {peer.last_name}</div>
                  <div class="peer-meta">{peer.team_abbrev} · {peer.pos} · {peer.gp} GP</div>
                </div>
                {peer.war != null
                  ? <span class={`peer-rapm ${peer.war >= 0 ? 'pos' : 'neg'}`}>{sign(peer.war)}{peer.war.toFixed(2)}</span>
                  : <span class="peer-rapm" style="color:var(--ink-32)">—</span>}
              </a>
            ))}
          </div>
          {/* Rating peers */}
          <div class="peer-strip" id="peers-rating" style="display:none">
            {peersRating.map(peer => (
              <a href={`/stats/player/${peer.slug}`} class="peer-row">
                <div style="flex:1">
                  <div class="peer-name">{peer.first_name[0]}. {peer.last_name}</div>
                  <div class="peer-meta">{peer.team_abbrev} · {peer.pos} · {peer.gp} GP</div>
                </div>
                {peer.hgb_rating != null
                  ? <span class={`peer-rapm ${peer.hgb_rating >= 0 ? 'pos' : 'neg'}`}>{sign(peer.hgb_rating)}{peer.hgb_rating.toFixed(2)}</span>
                  : <span class="peer-rapm" style="color:var(--ink-32)">—</span>}
              </a>
            ))}
          </div>
        </div>
      )}


      <!-- Methodology note -->
      <div class="card">
        <div class="method-card">
          <p class="method-text">
            HGB Impact combines individual shot quality, on-ice xG, finishing skill, and penalties — rate-adjusted per 60 min. WAR isolates contribution controlling for linemates and opponents. Percentiles vs {posPlural} with ≥20 GP.
          </p>
          <a href="/stats" class="method-link">Methodology →</a>
        </div>
      </div>

    </aside>
  </div>
</div>

<footer>hockeygamebot.com · HGB Stats · 2025–26</footer>

<script define:vars={{
  _card: {
    firstName:   player.first_name,
    lastName:    player.last_name,
    pos:         player.pos,
    posLabel:    posLabel,
    team:        player.team_abbrev,
    gp:          player.gp,
    toiAvgSec:   player.toi_avg_sec,
    war:                    player.war,
    warPct:                 warPct,
    hgb_rating:             player.hgb_rating ?? null,
    hgb_rating_percentile:  player.hgb_rating_percentile ?? null,
    hgb_rating_confidence:  player.hgb_rating_confidence ?? 'full',
    impact:        player.avg_gs_centered,
    impactPct:     player.percentiles_vs_pos.game_score,
    avgGsDisplay:  player.avg_gs_display,
    penDrawn:      player.penalties_drawn ?? 0,
    penTaken:      player.penalties_taken ?? 0,
    totalG:        totalGoals,
    totalA:        totalAssists,
    totalS:        player.rates_per_60.shots * (player.toi_avg_sec * player.gp / 3600),
    ratesG:        player.rates_per_60.goals,
    ratesA1:       player.rates_per_60.a1,
    ratesXg:       player.rates_per_60.ixg,
    finishing:     player.rates_per_60.finishing,
    ppToiSec:      player.toi_pp_sec_total ?? 0,
    totalToiSec:   player.toi_avg_sec * player.gp,
    percentiles: {
      ...player.percentiles_vs_pos,
      pp_off: player.percentiles_vs_pos.pp_off ?? null,
      pk_def: player.percentiles_vs_pos.pk_def ?? null,
    },
    qoc: player.qoc ?? null,
    qot: player.qot ?? null,
    hgb_rating_off_pct: player.hgb_rating_off_pct ?? (player as any).hgb_rating_components?.rating_off_pct ?? null,
    hgb_rating_def_pct: player.hgb_rating_def_pct ?? (player as any).hgb_rating_components?.rating_def_pct ?? null,
    hgb_rating_n_prior: (player as any).hgb_rating_components?.n_prior_seasons ?? null,
    // 3-year profile percentiles (fall back to season percentiles when null)
