        ctx.moveTo(spX(0), spY(gs[0]));
        for (let i = 1; i < gs.length; i++) ctx.lineTo(spX(i), spY(gs[i]));
        ctx.lineTo(spX(gs.length - 1), sp0);
        ctx.lineTo(spX(0), sp0);
        ctx.closePath();
        ctx.fillStyle = 'rgba(20,128,60,0.12)';
        ctx.fill();

        // zero line
        ctx.strokeStyle = INK14; ctx.lineWidth = 1; ctx.setLineDash([3, 3]);
        ctx.beginPath(); ctx.moveTo(PAD, sp0); ctx.lineTo(W - PAD, sp0); ctx.stroke();
        ctx.setLineDash([]);

        // line
        ctx.beginPath();
        ctx.moveTo(spX(0), spY(gs[0]));
        for (let i = 1; i < gs.length; i++) ctx.lineTo(spX(i), spY(gs[i]));
        ctx.strokeStyle = '#14803c'; ctx.lineWidth = 2; ctx.stroke();

        // dots
        for (let i = 0; i < gs.length; i++) {
          ctx.beginPath(); ctx.arc(spX(i), spY(gs[i]), 3, 0, Math.PI * 2);
          ctx.fillStyle = gs[i] >= 0 ? '#14803c' : RED; ctx.fill();
        }
      }
      y += SP_H;

      // ── footer ───────────────────────────────────────────────────────────
      ctx.fillStyle = INK06; ctx.fillRect(0, y, W, FOOT_H);
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · 2025-26', W / 2, y + FOOT_H / 2);

      return canvas;
    }

    // ── Landscape card (900×500) ─────────────────────────────────────────
    async function drawCardWide() {
      const BG      = '#EFEEE8';
      const SURFACE = '#FFFFFF';
      const SCALE = 2;
      const W = 900, H = 500;
      const DIVX = 280;  // left column width
      const PAD  = 28;
      const FOOT = 20;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // background
      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, H);

      // white right panel inset
      ctx.fillStyle = SURFACE; ctx.fillRect(DIVX + 12, 16, W - DIVX - 28, H - FOOT - 32);

      // 6px team-color left border strip
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 6, H - FOOT);

      // ── LEFT COLUMN ─────────────────────────────────────────────────────
      const hsImg = await loadImg(D.headshotUrl);
      const R = 58, HS_CX = DIVX / 2, HS_CY = 88;
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
      } else {
        ctx.fillStyle = INK10; ctx.fill();
        ctx.font = '800 36px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText((D.firstName[0] + D.lastName[0]).toUpperCase(), HS_CX, HS_CY);
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 3; ctx.stroke();

      // first name small above last name
      const LX = 34;
      ctx.font = '600 13px "Barlow", sans-serif';
      ctx.fillStyle = INK48; ctx.textBaseline = 'top'; ctx.textAlign = 'left';
      ctx.fillText(D.firstName.toUpperCase(), LX, 162);
      ctx.font = '800 52px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK;
      ctx.fillText(D.lastName.toUpperCase(), LX, 174);

      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.letterSpacing = '0.06em';
      ctx.fillText(D.team + ' · ' + D.pos + ' · 2025-26', LX, 234);

      // hairline separator
      ctx.fillStyle = INK14; ctx.fillRect(LX, 252, DIVX - LX - 12, 1);

      // WAR hero number
      const warNum = D.war != null ? D.war.toFixed(1) : '—';
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'top';
      ctx.fillText('WAR', LX, 263);
      ctx.font = '800 58px "Barlow Condensed", sans-serif';
      ctx.fillStyle = D.war != null && D.war > 0 ? TEAM_C : INK;
      ctx.fillText(warNum, LX, 272);
      ctx.font = '700 11px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32;
      ctx.fillText(ordinal(D.impactPct) + ' vs ' + D.posLabel.toLowerCase() + 's', LX, 338);

      // ── RIGHT COLUMN ────────────────────────────────────────────────────
      const RX = DIVX + 24;  // right content start x
      const RW = W - RX - 16;  // right content width

      // 4 headline KPIs
      const hKpis = [
        { label: 'G / 60',  val: D.ratesG.toFixed(2),  pct: ordinal(D.percentiles.goals) },
        { label: 'A1 / 60', val: D.ratesA1.toFixed(2), pct: ordinal(D.percentiles.a1) },
        { label: 'xG / 60', val: D.ratesXg.toFixed(2), pct: ordinal(D.percentiles.ixg) },
        { label: 'TOI / GP',val: fmtToi(D.toiAvgSec),  pct: String(D.gp) + ' GP' },
      ];
      const kW = RW / 4;
      for (let i = 0; i < hKpis.length; i++) {
        const kx = RX + i * kW + kW / 2;
        if (i > 0) { ctx.fillStyle = INK14; ctx.fillRect(RX + i * kW, 28, 1, 118); }
        ctx.font = '800 38px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText(hKpis[i].val, kx, 82);
        ctx.font = '700 9px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK48;
        ctx.fillText(hKpis[i].label, kx, 112);
        ctx.font = '700 12px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32;
        ctx.fillText(hKpis[i].pct, kx, 128);
      }

      // divider below KPIs
      ctx.fillStyle = INK14; ctx.fillRect(RX, 148, RW, 1);

      // 10 percentile bars in 2 columns of 5
      const pct = D.percentiles;
      const leftBars = [
        { label: 'EV Offense', val: pct.ev_offence, rate: D.ratesG.toFixed(2),  blue: false },
        { label: 'EV Defense', val: pct.ev_defence, rate: '',                    blue: true  },
        { label: 'Goals / 60', val: pct.goals,      rate: D.ratesG.toFixed(2),  blue: false },
        { label: 'A1 / 60',   val: pct.a1,         rate: D.ratesA1.toFixed(2), blue: false },
        { label: 'xG / 60',   val: pct.ixg,        rate: D.ratesXg.toFixed(2), blue: false },
      ];
      const ppPct  = pct.pp_off ?? null;
      const pkPct  = pct.pk_def ?? null;
      const finStr = (D.finishing >= 0 ? '+' : '') + D.finishing.toFixed(2);
      const rightBars = [
        { label: 'Finishing',  val: pct.finishing,  rate: finStr, blue: false },
        { label: 'Shots / 60', val: pct.shots,      rate: '',     blue: false },
        { label: 'Pen. Diff',  val: pct.pen_diff,   rate: '',     blue: false },
        ...(ppPct !== null ? [{ label: 'PP RAPM', val: ppPct, rate: '', blue: false }] : []),
        ...(pkPct !== null ? [{ label: 'PK RAPM', val: pkPct, rate: '', blue: false }] : []),
      ];

      const BAR_COL_W  = RW / 2 - 8;
      const BAR_H_PX   = 10;
      const BAR_ROW_H  = 54;
      const BAR_LABEL_W = 76;
      const BAR_TRACK_W = BAR_COL_W - BAR_LABEL_W - 34;
      const BAR_Y0     = 160;

      function drawBarColumn(bars, colX) {
        for (let bi = 0; bi < bars.length; bi++) {
          const row = bars[bi];
          const ry = BAR_Y0 + bi * BAR_ROW_H;
          const barY = ry + 30;

          // label
          ctx.font = '600 9px "Barlow", sans-serif';
          ctx.fillStyle = INK48; ctx.textBaseline = 'top'; ctx.textAlign = 'left';
          ctx.fillText(row.label, colX, ry + 8);

          // rate value right of label
          if (row.rate) {
            ctx.font = '700 9px "JetBrains Mono", monospace';
            ctx.fillStyle = INK32; ctx.textAlign = 'left';
            ctx.fillText(row.rate, colX + BAR_LABEL_W - 4, ry + 8);
          }

          // bar track
          const bx = colX + BAR_LABEL_W;
          rrect(ctx, bx, barY, BAR_TRACK_W, BAR_H_PX, 3);
          ctx.fillStyle = INK10; ctx.fill();

          // bar fill
          const fillW = Math.max(6, (row.val / 100) * BAR_TRACK_W);
          rrect(ctx, bx, barY, fillW, BAR_H_PX, 3);
          const isNeg = row.val < 25;
          ctx.fillStyle = row.val >= 75 ? (row.blue ? '#4285f4' : '#14803c')
                        : row.val >= 50 ? (row.blue ? '#7baaf7' : '#34a853')
                        : row.val >= 25 ? INK32 : RED;
          ctx.fill();

          // ordinal — big and right-aligned
          ctx.font = '800 14px "Barlow Condensed", sans-serif';
          ctx.fillStyle = row.val >= 50 ? INK : (row.val >= 25 ? INK32 : RED);
          ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
          ctx.fillText(ordinal(row.val), colX + BAR_COL_W, barY + BAR_H_PX / 2);
        }
      }

      drawBarColumn(leftBars,  RX);
      // center divider between bar columns
      ctx.fillStyle = INK10; ctx.fillRect(RX + BAR_COL_W + 8, 148, 1, H - 148 - FOOT - 20);
      drawBarColumn(rightBars, RX + BAR_COL_W + 16);

      // ── footer ──────────────────────────────────────────────────────────
      ctx.fillStyle = INK06; ctx.fillRect(0, H - FOOT, W, FOOT);
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · 2025-26', W / 2, H - FOOT / 2);

      return canvas;
    }

    // ── EDGE drawing helpers ─────────────────────────────────────────────
    function edgeTierColor(pct, blue) {
      if (pct == null) return INK32;
      if (pct >= 75) return blue ? '#4285f4' : '#137333';
      if (pct >= 50) return blue ? '#7baaf7' : '#34a853';
      if (pct >= 25) return INK32;
      return RED;
    }

    function drawEdgeStatBox(ctx, x, y, w, h, lbl, valStr, pct, avgStr, blue) {
      const PAD = 10;
      // box background
      ctx.fillStyle = '#FFFFFF'; ctx.beginPath();
      ctx.roundRect(x, y, w, h, 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.roundRect(x, y, w, h, 4); ctx.stroke();
      // label
      ctx.font = '700 7.5px "JetBrains Mono", monospace';
      ctx.fillStyle = INK45; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText(lbl.toUpperCase(), x + PAD, y + 9);
      // value
      ctx.font = '800 28px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'top';
      ctx.fillText(valStr, x + PAD, y + 20);
      // bar
      const bx = x + PAD, bw = w - PAD * 2, bh = 6, by = y + h - 30;
      ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(bx, by, bw, bh, 2); ctx.fill();
      if (pct != null) {
        const fc = edgeTierColor(pct, blue);
        ctx.fillStyle = fc;
        ctx.beginPath(); ctx.roundRect(bx, by, Math.max(6, (pct / 100) * bw), bh, 2); ctx.fill();
        // pct label
        ctx.font = '600 10px "Barlow", sans-serif';
        ctx.fillStyle = fc; ctx.textBaseline = 'top';
        ctx.fillText(`${Math.round(pct)}th percentile`, x + PAD, y + h - 22);
      }
      // avg
      if (avgStr) {
        ctx.font = '400 7.5px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textBaseline = 'bottom';
        ctx.fillText(avgStr, x + PAD, y + h - 4);
      }
    }

    function drawEdgePairs(ctx, y, W, PAD, e) {
      const bw = (W - PAD * 2 - 10) / 2;
      const bh = 86;
      const pairs = [
        ['TOP SPEED', e.speed_max_mph != null ? `${e.speed_max_mph} mph` : '—', e.speed_max_pct, e.speed_max_league_avg_mph != null ? `avg ${e.speed_max_league_avg_mph} mph` : '', false],
        ['MILES SKATED', e.distance_mi != null ? `${e.distance_mi} mi` : '—', e.distance_pct, e.distance_league_avg_mi != null ? `avg ${e.distance_league_avg_mi} mi` : '', false],
        ['BURSTS > 20 MPH', e.bursts_over_20 != null ? `${e.bursts_over_20}` : '—', e.bursts_over_20_pct, e.bursts_over_20_league_avg != null ? `avg ${e.bursts_over_20_league_avg}` : '', false],
        ['HARDEST SHOT', e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : '', false],
      ];
      for (let i = 0; i < pairs.length; i++) {
        const col = i % 2;
        const row = Math.floor(i / 2);
        const x = PAD + col * (bw + 10);
        const by = y + row * (bh + 10);
        drawEdgeStatBox(ctx, x, by, bw, bh, pairs[i][0], pairs[i][1], pairs[i][2], pairs[i][3], pairs[i][4]);
      }
      return y + 2 * (bh + 10) - 10;
    }

    function drawZoneBar(ctx, y, W, PAD, e, TEAM_C) {
      const oz = e.oz_pct ?? 45, nz = e.nz_pct ?? 32, dz = e.dz_pct ?? 23;
      const bw = W - PAD * 2, bh = 20, bx = PAD;
      // background rounded rect
      ctx.fillStyle = '#FFFFFF'; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 10, W - PAD * 2 + 4, 90, 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 10, W - PAD * 2 + 4, 90, 4); ctx.stroke();
      // title
      ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
      ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('ZONE TIME — EVEN STRENGTH', PAD + 6, y - 4);
      y += 14;
      // segmented bar
      ctx.save(); ctx.beginPath(); ctx.roundRect(bx, y, bw, bh, 3); ctx.clip();
      ctx.fillStyle = TEAM_C; ctx.fillRect(bx, y, bw * oz / 100, bh);
      ctx.fillStyle = 'rgba(13,13,20,0.18)'; ctx.fillRect(bx + bw * oz / 100, y, bw * nz / 100, bh);
      ctx.fillStyle = 'rgba(232,0,45,0.30)'; ctx.fillRect(bx + bw * (oz + nz) / 100, y, bw * dz / 100, bh);
      ctx.restore();
      y += bh + 8;
      // labels
      const segs = [['OFFENSIVE ZONE', `${oz.toFixed(0)}%`, oz], ['NEUTRAL ZONE', `${nz.toFixed(0)}%`, nz], ['DEFENSIVE ZONE', `${dz.toFixed(0)}%`, dz]];
      let lx = PAD + 6;
      for (const [name, pct, w] of segs) {
        ctx.font = '800 16px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK; ctx.textBaseline = 'top'; ctx.textAlign = 'left';
        ctx.fillText(pct, lx, y);
        ctx.font = '600 8px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
        ctx.fillText(name, lx, y + 18);
        lx += bw * w / 100;
      }
      // OZ percentile note
      if (e.oz_ev_pct_pct != null) {
        ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = TEAM_C; ctx.textBaseline = 'bottom';
        ctx.fillText(`OZ time: ${Math.round(e.oz_ev_pct_pct)}th percentile`, PAD + 6, y + 40);
      }
      return y + 44;
    }

    function drawShotDanger(ctx, y, W, PAD, e) {
      const colW = (W - PAD * 2 - 16) / 3;
      const zones = [
        { lbl: 'HIGH DANGER', color: TEAM_C,    n: e.shots_high,  np: e.shots_high_pct,  sh: e.shooting_pct_high,  shp: e.shooting_pct_high_pct },
        { lbl: 'MID RANGE',   color: INK32,     n: e.shots_mid,   np: e.shots_mid_pct,   sh: e.shooting_pct_mid,   shp: e.shooting_pct_mid_pct },
        { lbl: 'LONG RANGE',  color: INK32,     n: e.shots_long,  np: e.shots_long_pct,  sh: e.shooting_pct_long,  shp: e.shooting_pct_long_pct },
      ];
      // background card
      ctx.fillStyle = '#FFFFFF'; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 10, W - PAD * 2 + 4, 185, 4); ctx.fill();
      ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(PAD - 2, y - 10, W - PAD * 2 + 4, 185, 4); ctx.stroke();
      ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('SHOT LOCATION BY DANGER ZONE', PAD + 6, y - 4);
      y += 12;
      for (let i = 0; i < 3; i++) {
        const z = zones[i];
        const cx = PAD + i * (colW + 8);
        const ry = y;
        // zone chip
        const chipColor = i === 0 ? `rgba(${parseInt(TEAM_C.slice(1,3),16)},${parseInt(TEAM_C.slice(3,5),16)},${parseInt(TEAM_C.slice(5,7),16)},0.14)` : 'rgba(13,13,20,0.06)';
        ctx.fillStyle = chipColor; ctx.beginPath(); ctx.roundRect(cx, ry, colW, 16, 2); ctx.fill();
        ctx.font = '700 7px "JetBrains Mono", monospace'; ctx.fillStyle = i === 0 ? TEAM_C : INK45;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(z.lbl, cx + colW / 2, ry + 8);
        // Attempts
        ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK32; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
        ctx.fillText('ATTEMPTS', cx, ry + 22);
        ctx.font = '800 24px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
        ctx.fillText(z.n != null ? `${z.n}` : '—', cx, ry + 30);
        const npColor = edgeTierColor(z.np, false);
        ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = npColor;
        ctx.fillText(z.np != null ? `${Math.round(z.np)}th` : '', cx, ry + 56);
        const abw = colW, abh = 5;
        ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(cx, ry + 66, abw, abh, 2); ctx.fill();
        if (z.np != null) { ctx.fillStyle = npColor; ctx.beginPath(); ctx.roundRect(cx, ry + 66, Math.max(4, (z.np/100)*abw), abh, 2); ctx.fill(); }
        // Shooting %
        ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK32; ctx.textBaseline = 'top';
        ctx.fillText('SHOOTING %', cx, ry + 78);
        ctx.font = '800 20px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
        ctx.fillText(z.sh != null ? `${z.sh}%` : '—', cx, ry + 88);
        const shpColor = edgeTierColor(z.shp, false);
        ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = shpColor;
        ctx.fillText(z.shp != null ? `${Math.round(z.shp)}th` : '', cx, ry + 110);
        ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(cx, ry + 121, abw, abh, 2); ctx.fill();
        if (z.shp != null) { ctx.fillStyle = shpColor; ctx.beginPath(); ctx.roundRect(cx, ry + 121, Math.max(4, (z.shp/100)*abw), abh, 2); ctx.fill(); }
      }
      return y + 133;
    }

    function drawEdgeDivider(ctx, y, W) {
      ctx.fillStyle = INK10; ctx.fillRect(20, y + 10, (W - 40) / 2 - 80, 1);
      ctx.font = '700 8px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('NHL EDGE ATHLETE TRACKING', W / 2, y + 10);
      ctx.fillStyle = INK10; ctx.fillRect(W / 2 + 80, y + 10, (W - 40) / 2 - 80, 1);
      return y + 24;
    }

    // ── Expanded card: existing card + EDGE section appended ─────────────
    async function drawExpandedCard() {
      const e = D.edge;
      const W = 560, SCALE = 2, PAD = 20;
      // draw the base portrait card first
      const base = await drawCard();
      const baseH = base.height / SCALE;
      // compute EDGE section height
      // Traced: divider(24)+gap(8)+pairs(194)+gap(12)+zone(86)+gap(12)+shot(145)+gap(10)+footer(36)+init(6) = 533 + 8 buffer
      const EDGE_H = e ? 541 : 60;
      const TOTAL_H = baseH + EDGE_H;
      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = TOTAL_H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);
      // copy base card
      ctx.drawImage(base, 0, 0, W * SCALE, baseH * SCALE, 0, 0, W, baseH);
      if (!e) {
        ctx.fillStyle = INK10; ctx.fillRect(0, baseH, W, EDGE_H);
        ctx.font = '700 10px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('EDGE DATA NOT YET AVAILABLE', W / 2, baseH + EDGE_H / 2);
        return canvas;
      }
      // EDGE section background
      ctx.fillStyle = '#EFEEE8'; ctx.fillRect(0, baseH, W, EDGE_H);
      let y = baseH + 6;
      y = drawEdgeDivider(ctx, y, W);
      y += 8;
      // draw pairs
      const bw = (W - PAD * 2 - 10) / 2, bh = 86;
      const pairs = [
        ['TOP SPEED', e.speed_max_mph != null ? `${e.speed_max_mph} mph` : '—', e.speed_max_pct, e.speed_max_league_avg_mph != null ? `avg ${e.speed_max_league_avg_mph} mph` : ''],
        ['MILES SKATED', e.distance_mi != null ? `${e.distance_mi} mi` : '—', e.distance_pct, e.distance_league_avg_mi != null ? `avg ${e.distance_league_avg_mi} mi` : ''],
        ['BURSTS > 20 MPH', e.bursts_over_20 != null ? `${e.bursts_over_20}` : '—', e.bursts_over_20_pct, e.bursts_over_20_league_avg != null ? `avg ${e.bursts_over_20_league_avg}` : ''],
        ['HARDEST SHOT', e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : ''],
      ];
      for (let i = 0; i < 4; i++) {
        const col = i % 2, row = Math.floor(i / 2);
        drawEdgeStatBox(ctx, PAD + col * (bw + 10), y + row * (bh + 10), bw, bh, pairs[i][0], pairs[i][1], pairs[i][2], pairs[i][3], false);
      }
      y += 2 * (bh + 10) - 10 + 12;
      y = drawZoneBar(ctx, y, W, PAD, e, TEAM_C);
      y += 12;
      y = drawShotDanger(ctx, y, W, PAD, e);
      y += 10;
      // footer
      ctx.fillStyle = INK10; ctx.fillRect(0, y, W, 36);
      ctx.font = '700 8px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · 2025-26 · EDGE DATA: NHL, INC.', W / 2, y + 18);
      return canvas;
    }

    // ── EDGE card: hero + EDGE data (no percentile bars) ─────────────────
    async function drawEdgeCard() {
      const e = D.edge;
      const W = 560, SCALE = 2, PAD = 20;
      // heights
      const HDR_H = 48, CHIP_H = 32, HERO_H = 88, SEP_H = 1, KPI_H = 60;
      // Traced: divider(24)+gap(8)+pairs(194)+gap(12)+zone(86)+gap(12)+shot(145) = 481 + 8 buffer
      const EDGE_SEC_H = e ? 489 : 80;
      const FOOT_H = 36;
      const TOTAL_H = HDR_H + CHIP_H + HERO_H + SEP_H + KPI_H + 16 + EDGE_SEC_H + 12 + FOOT_H;
      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = TOTAL_H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);
      ctx.fillStyle = '#EFEEE8'; ctx.fillRect(0, 0, W, TOTAL_H);
      let y = 0;
      // uses INK, RED, INK06..INK48, TEAM_C from outer IIFE scope
      const rrect = (ctx, x, y, w, h, r) => { ctx.beginPath(); ctx.roundRect(x, y, w, h, r); };
      // ── Header ───────────────────────────────────────────────────────────
      ctx.fillStyle = '#FFFFFF'; ctx.fillRect(0, y, W, HDR_H);
      ctx.font = '800 22px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText(`${D.firstName.toUpperCase()} ${D.lastName.toUpperCase()}`, PAD, y + HDR_H / 2);
      ctx.fillStyle = INK14; ctx.fillRect(0, y + HDR_H - 1, W, 1);
      y += HDR_H;
      // ── Chips ────────────────────────────────────────────────────────────
      const chips = [D.team, D.posLabel.toUpperCase(), '2025-26', 'HOCKEYGAMEBOT'];
      let cx2 = PAD;
      chips.forEach((txt, i) => {
        ctx.font = '700 8px "JetBrains Mono", monospace';
        const tw = ctx.measureText(txt).width + 16;
        ctx.fillStyle = i === 0 ? TEAM_C : i < 3 ? INK : INK10;
        rrect(ctx, cx2, y + 7, tw, 18, 2); ctx.fill();
        ctx.fillStyle = i < 3 ? '#FFFFFF' : INK;
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText(txt, cx2 + 8, y + 16);
        cx2 += tw + 6;
      });
      y += CHIP_H;
      // ── Hero row ────────────────────────────────────────────────────────
      ctx.fillStyle = '#FFFFFF'; ctx.fillRect(0, y, W, HERO_H);
      ctx.fillStyle = INK06; ctx.fillRect(0, y, W, 1);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, y, 6, HERO_H);
      // headshot circle
      ctx.save();
      ctx.beginPath(); ctx.arc(6 + 14 + 34, y + HERO_H / 2, 34, 0, Math.PI * 2); ctx.clip();
      ctx.fillStyle = INK10; ctx.fillRect(6, y, 82, HERO_H);
      ctx.restore();
      ctx.strokeStyle = INK14; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.arc(6 + 14 + 34, y + HERO_H / 2, 34, 0, Math.PI * 2); ctx.stroke();
      // hero tiles
      const tileX = 100;
      const tiles = [
        [D.warPct != null ? `${D.warPct}%` : '—', D.war != null ? `${D.war >= 0 ? '+' : ''}${D.war.toFixed(2)} WAR` : '—', TEAM_C],
        [D.impactPct != null ? `${Math.round(D.impactPct)}%` : '—', `${D.avgGsDisplay?.toFixed(2) ?? '—'} GS avg`, INK],
        [`${D.gp} GP`, `${D.totalG}G · ${D.totalA}A`, INK],
      ];
      const tileW = (W - tileX) / 3;
      tiles.forEach(([big, small, color], i) => {
        const tx = tileX + i * tileW;
        if (i > 0) { ctx.fillStyle = INK06; ctx.fillRect(tx, y + 16, 1, HERO_H - 32); }
        ctx.font = '800 32px "Barlow Condensed", sans-serif';
        ctx.fillStyle = color; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(big, tx + tileW / 2, y + HERO_H / 2 - 8);
        ctx.font = '400 8.5px "JetBrains Mono", monospace';
        ctx.fillStyle = INK48; ctx.fillText(small, tx + tileW / 2, y + HERO_H / 2 + 14);
      });
      ctx.fillStyle = INK14; ctx.fillRect(0, y + HERO_H - 1, W, 1);
      y += HERO_H + SEP_H;
      // ── KPI strip ────────────────────────────────────────────────────────
      ctx.fillStyle = '#FFFFFF'; ctx.fillRect(0, y, W, KPI_H);
      const kpis = [
        ['G / 60', D.ratesG?.toFixed(2) ?? '—'],['A1 / 60', D.ratesA1?.toFixed(2) ?? '—'],
        ['xG / 60', D.ratesXg?.toFixed(2) ?? '—'],['Finishing', (D.finishing >= 0 ? '+' : '') + D.finishing?.toFixed(2)],
        ['Shots / 60', ((D.totalS ?? 0) / Math.max(D.gp * D.toiAvgSec / 3600, 0.01)).toFixed(1)],
      ];
      kpis.forEach(([lbl, val], i) => {
        const kx = PAD + i * ((W - PAD * 2) / 5);
        if (i > 0) { ctx.fillStyle = INK06; ctx.fillRect(kx, y + 10, 1, KPI_H - 20); }
        ctx.font = '800 20px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(val, kx + (W - PAD * 2) / 10, y + KPI_H / 2 - 6);
        ctx.font = '700 8px "JetBrains Mono", monospace';
        ctx.fillStyle = INK48;
        ctx.fillText(lbl.toUpperCase(), kx + (W - PAD * 2) / 10, y + KPI_H / 2 + 10);
      });
      ctx.fillStyle = INK14; ctx.fillRect(0, y + KPI_H - 1, W, 1);
      y += KPI_H + 16;
      // ── EDGE section ─────────────────────────────────────────────────────
      if (!e) {
        ctx.fillStyle = INK10; ctx.fillRect(PAD, y, W - PAD * 2, 60);
        ctx.font = '700 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('EDGE DATA NOT YET AVAILABLE', W / 2, y + 30);
        y += 72;
      } else {
        y = drawEdgeDivider(ctx, y, W);
        y += 8;
        const bw2 = (W - PAD * 2 - 10) / 2, bh2 = 86;
        const pairs2 = [
          ['TOP SPEED', e.speed_max_mph != null ? `${e.speed_max_mph} mph` : '—', e.speed_max_pct, e.speed_max_league_avg_mph != null ? `avg ${e.speed_max_league_avg_mph} mph` : ''],
          ['MILES SKATED', e.distance_mi != null ? `${e.distance_mi} mi` : '—', e.distance_pct, e.distance_league_avg_mi != null ? `avg ${e.distance_league_avg_mi} mi` : ''],
          ['BURSTS > 20 MPH', e.bursts_over_20 != null ? `${e.bursts_over_20}` : '—', e.bursts_over_20_pct, e.bursts_over_20_league_avg != null ? `avg ${e.bursts_over_20_league_avg}` : ''],
          ['HARDEST SHOT', e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : ''],
        ];
        for (let i = 0; i < 4; i++) {
          const col = i % 2, row = Math.floor(i / 2);
          drawEdgeStatBox(ctx, PAD + col * (bw2 + 10), y + row * (bh2 + 10), bw2, bh2, pairs2[i][0], pairs2[i][1], pairs2[i][2], pairs2[i][3], false);
        }
        y += 2 * (bh2 + 10) - 10 + 12;
        y = drawZoneBar(ctx, y, W, PAD, e, TEAM_C);
        y += 12;
        y = drawShotDanger(ctx, y, W, PAD, e);
        y += 10;
      }
      // ── Footer ───────────────────────────────────────────────────────────
      ctx.fillStyle = INK10; ctx.fillRect(0, y, W, FOOT_H);
      ctx.font = '700 8px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('HOCKEYGAMEBOT.COM · HGB STATS · 2025-26 · EDGE DATA: NHL, INC.', W / 2, y + FOOT_H / 2);
      return canvas;
    }

    // ── Landscape card: portrait left (560px) + teal divider + EDGE right (339px) ──
    async function drawLandscapeCard() {
      const SCALE   = 2;
      const PORT_W  = 560;
      const DIV_W   = 1;
      const RIGHT_W = 339;
      const TOTAL_W = PORT_W + DIV_W + RIGHT_W;   // 900
      const FOOT_H  = 36;
      const PAD     = 16;
      const TEAL    = '#006D75';

      // Build portrait first — its height determines the landscape height
      const portrait = await drawCard();
      const TOTAL_H  = portrait.height / SCALE;

      const canvas  = document.createElement('canvas');
      canvas.width  = TOTAL_W * SCALE;
      canvas.height = TOTAL_H * SCALE;
      const ctx     = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      ctx.fillStyle = '#EFEEE8'; ctx.fillRect(0, 0, TOTAL_W, TOTAL_H);
      // Copy portrait to the left
      ctx.drawImage(portrait, 0, 0, PORT_W * SCALE, TOTAL_H * SCALE, 0, 0, PORT_W, TOTAL_H);
      // Teal 1px divider
      ctx.fillStyle = TEAL; ctx.fillRect(PORT_W, 0, DIV_W, TOTAL_H);

      const RX = PORT_W + DIV_W;
      const e  = D.edge;

      if (!e) {
        ctx.fillStyle = INK10; ctx.fillRect(RX, 0, RIGHT_W, TOTAL_H);
        ctx.font = '700 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('EDGE DATA NOT AVAILABLE', RX + RIGHT_W / 2, TOTAL_H / 2);
        return canvas;
      }

      let ry = 0;

      // ── Edge header (40px) ───────────────────────────────────────────────
      const EDGE_HDR_H = 40;
      ctx.fillStyle = INK14; ctx.fillRect(RX, ry + EDGE_HDR_H - 1, RIGHT_W, 1);
      ctx.font = '800 13px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText('NHL EDGE', RX + PAD, ry + EDGE_HDR_H / 2);
      ctx.fillStyle = TEAL; ctx.textAlign = 'right';
      ctx.fillText('TRACKING', RX + RIGHT_W - PAD, ry + EDGE_HDR_H / 2);
      ry += EDGE_HDR_H;

      // ── 2×2 stat tiles ───────────────────────────────────────────────────
      const TILE_PAD_V = 10;
      const TILE_GAP   = 8;
      const tileW      = (RIGHT_W - PAD * 2 - TILE_GAP) / 2;
      const TILE_H     = 80;
      const tilePairs  = [
        ['TOP SPEED',      e.speed_max_mph    != null ? `${e.speed_max_mph} mph`     : '—', e.speed_max_pct,       e.speed_max_league_avg_mph   != null ? `avg ${e.speed_max_league_avg_mph} mph`   : ''],
        ['MILES SKATED',   e.distance_mi      != null ? `${e.distance_mi} mi`        : '—', e.distance_pct,        e.distance_league_avg_mi     != null ? `avg ${e.distance_league_avg_mi} mi`     : ''],
        ['BURSTS >20 MPH', e.bursts_over_20   != null ? `${e.bursts_over_20}`        : '—', e.bursts_over_20_pct,  e.bursts_over_20_league_avg  != null ? `avg ${e.bursts_over_20_league_avg}`     : ''],
        ['HARDEST SHOT',   e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : ''],
      ];
      const tilesStartY = ry + TILE_PAD_V;
      for (let i = 0; i < 4; i++) {
        const col = i % 2, row = Math.floor(i / 2);
        drawEdgeStatBox(ctx, RX + PAD + col * (tileW + TILE_GAP), tilesStartY + row * (TILE_H + TILE_GAP), tileW, TILE_H, ...tilePairs[i]);
      }
      ry = tilesStartY + 2 * (TILE_H + TILE_GAP) - TILE_GAP + TILE_PAD_V;

      // ── Zone time ─────────────────────────────────────────────────────────
      ctx.fillStyle = INK14; ctx.fillRect(RX + PAD, ry, RIGHT_W - PAD * 2, 1); ry += 9;
      ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
      ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('ZONE TIME — EVEN STRENGTH', RX + PAD, ry);
      if (e.oz_ev_pct_pct != null) {
        ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = TEAL; ctx.textAlign = 'right';
        ctx.fillText(`OZ: ${Math.round(e.oz_ev_pct_pct)}th`, RX + RIGHT_W - PAD, ry);
      }
      ry += 14;
      const oz = e.oz_pct ?? 45, nz = e.nz_pct ?? 32, dz = e.dz_pct ?? 23;
      const zbw = RIGHT_W - PAD * 2, zbx = RX + PAD;
      ctx.save(); ctx.beginPath(); ctx.roundRect(zbx, ry, zbw, 20, 3); ctx.clip();
      ctx.fillStyle = TEAL;                       ctx.fillRect(zbx,                     ry, zbw * oz / 100,   20);
      ctx.fillStyle = 'rgba(13,13,20,0.18)';      ctx.fillRect(zbx + zbw * oz / 100,    ry, zbw * nz / 100,   20);
      ctx.fillStyle = 'rgba(232,0,45,0.30)';      ctx.fillRect(zbx + zbw*(oz+nz)/100,   ry, zbw * dz / 100,   20);
      ctx.restore();
      ry += 26;
      const zSegs = [['OZ', `${oz.toFixed(0)}%`, oz], ['NZ', `${nz.toFixed(0)}%`, nz], ['DZ', `${dz.toFixed(0)}%`, dz]];
      let lx2 = zbx;
      for (const [name, pctStr, w] of zSegs) {
        ctx.font = '800 14px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
        ctx.textAlign = 'left'; ctx.textBaseline = 'top'; ctx.fillText(pctStr, lx2, ry);
        ctx.font = '600 7px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
        ctx.fillText(name, lx2, ry + 16); lx2 += zbw * w / 100;
      }
      ry += 30;

      // ── Shot location — 3 horizontal rows (fills remaining height) ────────
      ctx.fillStyle = INK14; ctx.fillRect(RX + PAD, ry, RIGHT_W - PAD * 2, 1); ry += 9;
      ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
      ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('SHOT LOCATION BY DANGER ZONE', RX + PAD, ry); ry += 14;

      const shotZones = [
        { chip: 'HIGH DGR',  n: e.shots_high, np: e.shots_high_pct, sh: e.shooting_pct_high, shp: e.shooting_pct_high_pct, hi: true  },
        { chip: 'MID RANGE', n: e.shots_mid,  np: e.shots_mid_pct,  sh: e.shooting_pct_mid,  shp: e.shooting_pct_mid_pct,  hi: false },
        { chip: 'LNG RANGE', n: e.shots_long, np: e.shots_long_pct, sh: e.shooting_pct_long, shp: e.shooting_pct_long_pct, hi: false },
      ];
      const shotRowH = (TOTAL_H - FOOT_H - ry) / 3;
      const CHIP_W   = 72;
      const STAT_GAP = 8;
      const statW    = (RIGHT_W - PAD * 2 - CHIP_W - 10 - STAT_GAP) / 2;

      for (let zi = 0; zi < 3; zi++) {
        const z    = shotZones[zi];
        const rowY = ry + zi * shotRowH;
        if (zi > 0) { ctx.fillStyle = INK06; ctx.fillRect(RX + PAD, rowY, RIGHT_W - PAD * 2, 1); }

        // zone chip
        const chipX = RX + PAD;
        const chipY = rowY + (shotRowH - 22) / 2;
        ctx.beginPath(); ctx.roundRect(chipX, chipY, CHIP_W, 22, 3);
        if (z.hi) {
          const r2 = parseInt(TEAM_C.slice(1,3),16), g3 = parseInt(TEAM_C.slice(3,5),16), b3 = parseInt(TEAM_C.slice(5,7),16);
          ctx.fillStyle = `rgba(${r2},${g3},${b3},0.14)`;
        } else {
          ctx.fillStyle = INK06;
        }
        ctx.fill();
        ctx.font = '800 7px "Barlow Condensed", sans-serif';
        ctx.fillStyle = z.hi ? TEAM_C : INK45;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(z.chip, chipX + CHIP_W / 2, chipY + 11);

        // two mini-stat blocks (ATTEMPTS | SHOOT%)
        const contentH   = 56;
        const contentTop = rowY + (shotRowH - contentH) / 2;
        const stat1X = RX + PAD + CHIP_W + 10;
        const stat2X = stat1X + statW + STAT_GAP;

        function drawMiniStat(sx, displayVal, pctVal, label) {
          const pctC = edgeTierColor(pctVal, false);
          ctx.font = '600 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
          ctx.textAlign = 'left'; ctx.textBaseline = 'top';
          ctx.fillText(label, sx, contentTop);
          ctx.font = '800 24px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK;
          ctx.fillText(displayVal != null ? `${displayVal}` : '—', sx, contentTop + 11);
          ctx.font = '600 11px "Barlow", sans-serif'; ctx.fillStyle = pctC;
          ctx.fillText(pctVal != null ? `${Math.round(pctVal)}th` : '', sx, contentTop + 36);
          ctx.fillStyle = INK10; ctx.beginPath(); ctx.roundRect(sx, contentTop + 50, statW - 2, 4, 2); ctx.fill();
          if (pctVal != null) {
            ctx.fillStyle = pctC; ctx.beginPath();
            ctx.roundRect(sx, contentTop + 50, Math.max(3, (pctVal / 100) * (statW - 2)), 4, 2); ctx.fill();
          }
        }

        drawMiniStat(stat1X, z.n,                              z.np,  'ATTEMPTS');
        drawMiniStat(stat2X, z.sh != null ? `${z.sh}%` : null, z.shp, 'SHOOTING%');
      }

      // ── Footer ───────────────────────────────────────────────────────────
      ctx.fillStyle = INK06; ctx.fillRect(RX, TOTAL_H - FOOT_H, RIGHT_W, FOOT_H);
      ctx.font = '700 8px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('EDGE DATA: NHL, INC.', RX + RIGHT_W / 2, TOTAL_H - FOOT_H / 2);

      return canvas;
    }

    // ── HGB Rating Card (JFresh-style blended component card) ────────────
    // ── Rating Card — portrait 520×720, 3-year talent profile ──────────────
    // Clean shareable card focused on the 3-year weighted talent profile.
    // Header is copied exactly from drawCard's header/chips block.
    async function drawRatingCard() {
      const BG      = '#EFEEE8';
      const SURFACE = '#FFFFFF';
      const SCALE   = 2;
      const W       = 520;
      const PAD     = 28;

      // Compute content height: header+chips(86) + gap(6) + identity(122) + sep(1)
      // + section gap(20) + section label(12) + 11 bars(363) + bottom pad(12) + footer(36)
      const _HDR = 52, _CHIP = 34, _ID = 122, _BAR_ROWS = 11, _BAR_ROW = 33, _FOOT = 36;
      const H = _HDR + _CHIP + 6 + _ID + 1 + 20 + 12 + _BAR_ROWS * _BAR_ROW + 12 + _FOOT;

      const canvas = document.createElement('canvas');
      canvas.width  = W * SCALE;
      canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // background
      ctx.fillStyle = BG;
      ctx.fillRect(0, 0, W, H);

      // team full name lookup (same table as drawCard)
      const TEAM_NAMES = {
        ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',
        BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',
        CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',
        DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',
        FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',
        MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',
        NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',
        PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',
        SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',
        TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',
        VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS',
      };
      const teamFullName = TEAM_NAMES[D.team] || D.team;

      let y = 0;

      // ════════ SECTION 1 — WHITE BAND: orange accent bar + name + chips ════════
      const HDR_H  = 52;
      const CHIP_H = 34;

      // White fills the full name+chips area; orange accent bar spans the full white band
      ctx.fillStyle = SURFACE;
      ctx.fillRect(0, y, W, HDR_H + CHIP_H);
      // Orange left accent bar — 4px, full height of white band
      ctx.fillStyle = TEAM_C;
      ctx.fillRect(0, y, 4, HDR_H + CHIP_H);
      // Player name
      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK;
      ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, y + HDR_H / 2);
      y += HDR_H;

      // Chips row — team | position | season  +  HOCKEYGAMEBOT (right)
      // Still inside the white band (white fill covers HDR_H + CHIP_H)
      const chipH = 18, chipY0 = y + (CHIP_H - chipH) / 2;
      const chips = [teamFullName, D.posLabel.toUpperCase(), '2025-26'];
      let cx = PAD;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chips.length; ci++) {
        const tw = ctx.measureText(chips[ci]).width;
        const cw = tw + 18;
        rrect(ctx, cx, chipY0, cw, chipH, 3);
        ctx.fillStyle = ci === 0 ? TEAM_C : INK;
        ctx.fill();
        ctx.fillStyle = BG;
        ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
        cx += cw + 8;
      }
      const brand = 'HOCKEYGAMEBOT';
      const btw = ctx.measureText(brand).width;
      const bcw = btw + 18;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);
      // Bottom border of white band
      ctx.fillStyle = 'rgba(13,13,20,0.08)';
      ctx.fillRect(0, y + CHIP_H - 1, W, 1);
      y += CHIP_H;

      // ════════ SECTION 2 — IDENTITY ROW (headshot + 3 hero tiles) ════════
      const ID_H = 122;
      y += 6;

      // headshot circle (same style as drawCard — team-color border)
      const R = 36, HS_CX = PAD + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(D.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
      } else {
        ctx.fillStyle = INK10; ctx.fill();
        ctx.font = '800 24px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText((D.firstName[0] + D.lastName[0]).toUpperCase(), HS_CX, HS_CY);
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      // 3 hero tiles to the right of headshot
      const heroX  = HS_CX + R + 18;
      const heroW  = (W - heroX - PAD) / 3;

      const ratingPctVal = D.hgb_rating_percentile;
      const ratingRawStr = D.hgb_rating != null
        ? (D.hgb_rating >= 0 ? '+' : '') + D.hgb_rating.toFixed(2) + ' Rating'
        : '—';
      const warPctVal  = D.warPct  ?? (D.impactPct != null ? Math.round(D.impactPct) : null);
      const impPctVal  = D.impactPct != null ? Math.round(D.impactPct) : null;
      const warRawStr  = D.war != null ? D.war.toFixed(2) + ' WAR' : '—';
      const impRawStr  = D.avgGsDisplay != null ? D.avgGsDisplay.toFixed(2) + ' Avg' : '—';

      const heroTiles = [
        { label: 'HGB RATING', pct: ratingPctVal, sub: ratingRawStr, tag: '' },
        { label: 'HGB WAR',    pct: warPctVal,    sub: warRawStr,    tag: '2025-26' },
        { label: 'HGB IMPACT', pct: impPctVal,    sub: impRawStr,    tag: '2025-26' },
      ];
      for (let i = 0; i < heroTiles.length; i++) {
        const t  = heroTiles[i];
        const tcx = heroX + i * heroW + heroW / 2;
        if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(heroX + i * heroW, y + 18, 1, ID_H - 36); }
        // label
        ctx.font = '700 9px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText(t.label, tcx, y + 20);
        // big percentile
        ctx.font = '900 36px "Barlow Condensed", sans-serif';
        ctx.fillStyle = t.pct != null ? TEAM_C : INK32;
        ctx.fillText(t.pct != null ? t.pct + '%' : '—', tcx, y + 33);
        // sub raw value
        ctx.font = '800 12px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK48; ctx.textBaseline = 'top';
        ctx.fillText(t.sub, tcx, y + 78);
        // small season tag (current-season signal)
        if (t.tag) {
          ctx.font = '700 8px "JetBrains Mono", monospace';
          ctx.fillStyle = INK32; ctx.textBaseline = 'top';
          ctx.fillText(t.tag, tcx, y + 96);
        }
      }
      y += ID_H;

      // separator
      ctx.fillStyle = INK14; ctx.fillRect(0, y, W, 1); y += 1;

      // ════════ SECTION 3 — 3-YEAR PROFILE BARS ════════
      y += 20;

      // section header: eyebrow + red "VS. X" + right-aligned meta
      const isF = D.posGroup === 'F';
      const vsLabel = isF ? 'VS. FORWARDS' : 'VS. DEFENSEMEN';
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK48; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('3-YEAR PROFILE', PAD, y);
      const eyeW = ctx.measureText('3-YEAR PROFILE').width;
      ctx.fillStyle = RED;
      ctx.fillText('  ' + vsLabel, PAD + eyeW, y);
      ctx.textAlign = 'left';
      y += 12;

      // 11 bars, single column. Fall back to season percentiles when 3yr null.
      const pct3 = D.percentiles;
      const v3 = (a, b) => (a != null ? a : (b != null ? b : null));
      const profileBars = [
        { label: 'EV Offense',   val: D.hgb_rating_off_pct,                            kind: 'green' },
        { label: 'EV Defense',   val: D.hgb_rating_def_pct,                            kind: 'blue'  },
        { label: 'Goals / 60',   val: v3(D.g_60_pct_3yr,      pct3.goals),             kind: 'green' },
        { label: 'A1 / 60',      val: v3(D.a1_60_pct_3yr,     pct3.a1),                kind: 'green' },
        { label: 'xG / 60',      val: v3(D.xg_60_pct_3yr,     pct3.ixg),               kind: 'green' },
        { label: 'Finishing',    val: v3(D.finishing_pct_3yr, pct3.finishing),         kind: 'green' },
        { label: 'Pen. Diff',    val: v3(D.pen_diff_pct_3yr,  pct3.pen_diff),          kind: 'green' },
        { label: 'Power Play',   val: pct3.pp_off ?? null,                             kind: 'perf'  },
        { label: 'Penalty Kill', val: pct3.pk_def ?? null,                             kind: 'perf'  },
        { label: 'Opp. Quality', val: v3(D.qoc_pct_3yr,       D.qoc),                  kind: 'red'   },
        { label: 'Mate Quality', val: v3(D.qot_pct_3yr,       D.qot),                  kind: 'blue'  },
      ];

      const BAR_ROW_H   = 33;
      const BAR_H_PX    = 13;
      const BAR_LABEL_W = 96;
      const BAR_RANK_W  = 44;
      const BAR_AVAIL   = W - PAD * 2 - BAR_LABEL_W - BAR_RANK_W - 8;

      function barFill(pct) {
        if (pct == null) return 'rgba(13,13,20,0.20)';
        if (pct >= 75) return '#137333';           // elite — dark green
        if (pct >= 55) return '#4CAF50';           // above avg — light green
        if (pct >= 40) return 'rgba(13,13,20,0.35)'; // average — neutral gray
        if (pct >= 25) return '#E57373';           // below avg — light red
        return '#E8002D';                          // poor — dark red
      }
      function pctColor(pct) {
        if (pct == null) return 'rgba(13,13,20,0.35)';
        if (pct >= 75) return '#137333';
        if (pct >= 55) return '#4CAF50';
        if (pct >= 40) return 'rgba(13,13,20,0.50)';
        if (pct >= 25) return '#E57373';
        return '#E8002D';
      }

      function makeHatchPattern(ctx) {
        const sz = 6;
        const pc = document.createElement('canvas');
        pc.width = sz; pc.height = sz;
        const px = pc.getContext('2d');
        px.strokeStyle = 'rgba(13,13,20,0.18)';
        px.lineWidth = 1;
        px.beginPath();
        px.moveTo(0, sz); px.lineTo(sz, 0);
        px.stroke();
        return ctx.createPattern(pc, 'repeat');
      }

      for (let bi = 0; bi < profileBars.length; bi++) {
        const b = profileBars[bi];
        const rowY = y + bi * BAR_ROW_H;
        const by   = rowY + (BAR_ROW_H - BAR_H_PX) / 2;
        const val  = b.val;

        // label
        ctx.font = '600 11px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(b.label, PAD, rowY + BAR_ROW_H / 2);

        // track
        const bx = PAD + BAR_LABEL_W;
        rrect(ctx, bx, by, BAR_AVAIL, BAR_H_PX, 3);
        ctx.fillStyle = INK10; ctx.fill();

        if (val == null) {
          // hatch pattern fill for no-data bars
          const hatch = makeHatchPattern(ctx);
          rrect(ctx, bx, by, BAR_AVAIL, BAR_H_PX, 3);
          ctx.fillStyle = hatch; ctx.fill();
        } else {
          const tierC = barFill(val);
          // fill
          const fillW = Math.max(6, (val / 100) * BAR_AVAIL);
          rrect(ctx, bx, by, fillW, BAR_H_PX, 3);
          ctx.fillStyle = tierC; ctx.fill();
        }

        // percentage (right-aligned) — skip for null bars, show muted dash instead
        ctx.font = '800 15px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        if (val == null) {
          ctx.fillStyle = 'rgba(13,13,20,0.32)';
          ctx.fillText('—', W - PAD, rowY + BAR_ROW_H / 2);
        } else {
          ctx.fillStyle = pctColor(val);
          ctx.fillText(Math.round(val) + '%', W - PAD, rowY + BAR_ROW_H / 2);
        }
      }
      y += profileBars.length * BAR_ROW_H + 12;

      // ════════ SECTION 4 — FOOTER ════════
      const FOOT_H = 36;
      const footY = y;
      ctx.fillStyle = INK06; ctx.fillRect(0, footY, W, FOOT_H);
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText('HOCKEYGAMEBOT · HGB STATS · 2025-26', W / 2, footY + FOOT_H / 2);

      return canvas;
    }

    // ── shared canvas download helper ────────────────────────────────────
    function downloadCanvas(canvas, filename) {
      canvas.toBlob(blob => {
        if (!blob) return;
        const url = URL.createObjectURL(blob);
        const a   = document.createElement('a');
        a.href = url; a.download = filename;
        document.body.appendChild(a); a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      }, 'image/png');
    }

    function bindCardBtn(id, label, drawFn, filename, sizeLabel = '560px · 2× retina PNG') {
      const b = document.getElementById(id);
      if (!b) return;
      b.addEventListener('click', async () => {
        b.textContent = 'Generating…'; b.disabled = true;
        status.textContent = 'Drawing…';
        try {
          if (document.fonts && document.fonts.ready) await document.fonts.ready;
          const canvas = await drawFn();
          downloadCanvas(canvas, filename);
          status.textContent = 'Downloaded ✓';
          setTimeout(() => { status.textContent = sizeLabel; }, 3000);
        } catch (e) {
          console.error(e);
          status.textContent = 'Error — try again';
        } finally {
          b.textContent = label; b.disabled = false;
        }
      });
    }

    bindCardBtn('download-card-btn',     'Player Card →',      drawCard,              `hgb_${D.slug}_25-26.png`);
    bindCardBtn('download-expanded-btn', 'Expanded Card →',    drawLandscapeCard,     `hgb_${D.slug}_expanded_25-26.png`, '900px · 2× retina PNG');
    bindCardBtn('download-edge-btn',     'NHL EDGE Card →',    drawEdgeCard,          `hgb_${D.slug}_edge_25-26.png`);
    bindCardBtn('download-rating-card-btn', 'Rating Card →',   drawRatingCard,        `hgb_rating_${D.slug}_25-26.png`, '520×720px · 2× retina PNG');
  })();
</script>

<script>
  // ── SEASON / RATING·3yr toggle ─────────────────────────────────────────
  // Drives the unified PERCENTILE PROFILE card. All bars (EV Offence/Defence
  // + counting stats) live in #pct-profile-card. In RATING·3yr mode:
  //   • RAPM bars  → hgb_rating_off/def_pct (data-rating-val on [data-bar-key])
  //   • Counting bars → 3yr weighted percentiles + 3yr raw rate
  (function() {
    function tierColor(val, isBlue, isRed) {
      if (val >= 75) return isBlue ? '#4285f4' : isRed ? '#842029' : '#137333';
      if (val >= 50) return isBlue ? '#7baaf7' : isRed ? '#c03244' : '#34a853';
      if (val >= 25) return 'rgba(13,13,20,0.32)';
      return '#E8002D';
    }

    function updateBar(row, isRating, opts) {
      const isBlue    = row.dataset.isBlue === 'true';
      const isRed     = row.dataset.isRed === 'true';
      const seasonVal = parseFloat(row.dataset.seasonVal ?? '0');
      const ratingRaw = row.dataset.ratingVal;
      const hasRating = ratingRaw !== '' && ratingRaw != null;

      const val    = (isRating && hasRating) ? parseFloat(ratingRaw) : seasonVal;
      const isNull = isRating && !hasRating;

      const fill  = row.querySelector('.pct-fill');
      const pctEl = row.querySelector('.pct-pct');

      // Swap the raw rate column for counting-stat bars between season / 3yr.
      if (opts && opts.swapRate) {
        const rateEl = row.querySelector('.pct-rate');
        if (rateEl) {
          const seasonRate = row.dataset.seasonRate;
          const ratingRate = row.dataset.ratingRate;
          if (isRating) {
            rateEl.textContent = (ratingRate !== '' && ratingRate != null) ? ratingRate : '—';
          } else {
            rateEl.textContent = (seasonRate !== '' && seasonRate != null) ? seasonRate : '—';
          }
        }
      }

      if (isNull) {
        if (fill)  { fill.style.width = '0%'; fill.style.background = 'rgba(13,13,20,0.14)'; }
        if (pctEl) { pctEl.textContent = '—'; pctEl.style.color = 'rgba(13,13,20,0.32)'; }
      } else {
        const color = tierColor(val, isBlue, isRed);
        if (fill)  { fill.style.width = val.toFixed(1) + '%'; fill.style.background = color; }
        if (pctEl) { pctEl.textContent = Math.round(val) + '%'; pctEl.style.color = color; }
      }
    }

    function applyRapmMode(mode) {
      const isRating = mode === 'rating';

      document.querySelectorAll('#rapm-mode-filter button').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.rapmMode === mode);
      });

      // RAPM bars (EV Offence / Defence — identified by data-bar-key)
      document.querySelectorAll('#pct-profile-card .pct-row[data-bar-key]').forEach(row => {
        const suffix = row.querySelector('.rapm-bar-3yr-suffix');
        if (suffix) suffix.style.display = isRating ? 'inline' : 'none';
        updateBar(row, isRating, null);
      });

      // Counting-stat bars (identified by data-rate-key) — also swap raw rate
      document.querySelectorAll('#pct-profile-card .pct-row[data-rate-key]').forEach(row => {
        updateBar(row, isRating, { swapRate: true });
      });
    }

    document.querySelectorAll('#rapm-mode-filter button').forEach(btn => {
      btn.addEventListener('click', () => applyRapmMode(btn.dataset.rapmMode));
    });
  })();

  // Similar Players WAR / Rating toggle
  (() => {
    const filter = document.getElementById('peers-mode-filter');
    if (!filter) return;
    filter.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.peersMode;
        filter.querySelectorAll('button').forEach(b => b.classList.toggle('active', b === btn));
        document.getElementById('peers-war').style.display    = mode === 'war'    ? '' : 'none';
        document.getElementById('peers-rating').style.display = mode === 'rating' ? '' : 'none';
      });
    });
  })();

  // Impact trend chart — dot hover tooltips
  const tip = document.getElementById('imp-tip');
  if (tip) {
    document.querySelectorAll('.impact-dot').forEach(dot => {
      dot.addEventListener('mouseenter', e => {
        const val = parseFloat(dot.dataset.val ?? '0');
        const tipText = dot.dataset.tip ?? '';
        // Split "2025-10-30 vs NYR · -0.69" into context + value
        const parts = tipText.split(' · ');
        const ctx = parts.slice(0, -1).join(' · ');
        const valStr = parts[parts.length - 1];
        const valColor = val >= 0 ? '#1a7a3e' : '#E8002D';
        tip.innerHTML = `<span class="tip-ctx">${ctx}</span><span class="tip-val" style="color:${valColor}">${valStr}</span>`;
        tip.style.display = 'block';
        const x = e.clientX + 12, y = e.clientY - 28;
        tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? e.clientX - tip.offsetWidth - 8 : x) + 'px';
        tip.style.top  = Math.max(4, y) + 'px';
      });
      dot.addEventListener('mousemove', e => {
        const x = e.clientX + 12, y = e.clientY - 28;
        tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? e.clientX - tip.offsetWidth - 8 : x) + 'px';
        tip.style.top  = Math.max(4, y) + 'px';
      });
      dot.addEventListener('mouseleave', () => { tip.style.display = 'none'; });
    });
  }
</script>

</body>
</html>
