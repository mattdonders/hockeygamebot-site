        const tx = tileX + i * tileW;
        if (i > 0) { ctx.fillStyle = INK06; ctx.fillRect(tx, y + 16, 1, HERO_H - 32); }
        ctx.font = '800 32px "Barlow Condensed", sans-serif';
        ctx.fillStyle = color; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(big, tx + tileW / 2, y + HERO_H / 2 - 8);
        ctx.font = '400 8.5px "JetBrains Mono", monospace';
        ctx.fillStyle = INK48; ctx.fillText(small, tx + tileW / 2, y + HERO_H / 2 + 14);
      });
      ctx.fillStyle = INK14; ctx.fillRect(0, y + HERO_H - 1, W, 1);
      y += HERO_H + SEP_H;
      // ── KPI strip ────────────────────────────────────────────────────────
      ctx.fillStyle = '#FFFFFF'; ctx.fillRect(0, y, W, KPI_H);
      const kpis = [
        ['G / 60', D.ratesG?.toFixed(2) ?? '—'],['A1 / 60', D.ratesA1?.toFixed(2) ?? '—'],
        ['xG / 60', D.ratesXg?.toFixed(2) ?? '—'],['Finishing', (D.finishing >= 0 ? '+' : '') + D.finishing?.toFixed(2)],
        ['Shots / 60', ((D.totalS ?? 0) / Math.max(D.gp * D.toiAvgSec / 3600, 0.01)).toFixed(1)],
      ];
      kpis.forEach(([lbl, val], i) => {
        const kx = PAD + i * ((W - PAD * 2) / 5);
        if (i > 0) { ctx.fillStyle = INK06; ctx.fillRect(kx, y + 10, 1, KPI_H - 20); }
        ctx.font = '800 20px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(val, kx + (W - PAD * 2) / 10, y + KPI_H / 2 - 6);
        ctx.font = '700 8px "JetBrains Mono", monospace';
        ctx.fillStyle = INK48;
        ctx.fillText(lbl.toUpperCase(), kx + (W - PAD * 2) / 10, y + KPI_H / 2 + 10);
      });
      ctx.fillStyle = INK14; ctx.fillRect(0, y + KPI_H - 1, W, 1);
      y += KPI_H + 16;
      // ── EDGE section ─────────────────────────────────────────────────────
      if (!e) {
        ctx.fillStyle = INK10; ctx.fillRect(PAD, y, W - PAD * 2, 60);
        ctx.font = '700 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('EDGE DATA NOT YET AVAILABLE', W / 2, y + 30);
        y += 72;
      } else {
        y = drawEdgeDivider(ctx, y, W);
        y += 8;
        const bw2 = (W - PAD * 2 - 10) / 2, bh2 = 86;
        const pairs2 = [
          ['TOP SPEED', e.speed_max_mph != null ? `${e.speed_max_mph} mph` : '—', e.speed_max_pct, e.speed_max_league_avg_mph != null ? `avg ${e.speed_max_league_avg_mph} mph` : ''],
          ['MILES SKATED', e.distance_mi != null ? `${e.distance_mi} mi` : '—', e.distance_pct, e.distance_league_avg_mi != null ? `avg ${e.distance_league_avg_mi} mi` : ''],
          ['BURSTS > 20 MPH', e.bursts_over_20 != null ? `${e.bursts_over_20}` : '—', e.bursts_over_20_pct, e.bursts_over_20_league_avg != null ? `avg ${e.bursts_over_20_league_avg}` : ''],
          ['HARDEST SHOT', e.shot_speed_max_mph != null ? `${e.shot_speed_max_mph} mph` : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? `avg ${e.shot_speed_max_league_avg_mph} mph` : ''],
        ];
        for (let i = 0; i < 4; i++) {
          const col = i % 2, row = Math.floor(i / 2);
          drawEdgeStatBox(ctx, PAD + col * (bw2 + 10), y + row * (bh2 + 10), bw2, bh2, pairs2[i][0], pairs2[i][1], pairs2[i][2], pairs2[i][3], false);
        }
        y += 2 * (bh2 + 10) - 10 + 12;
        y = drawZoneBar(ctx, y, W, PAD, e, TEAM_C);
        y += 12;
        y = drawShotDanger(ctx, y, W, PAD, e);
        y += 10;
      }
      // ── Footer ───────────────────────────────────────────────────────────
      ctx.fillStyle = INK10; ctx.fillRect(0, y, W, FOOT_H);
      ctx.font = '700 8px "Barlow Condensed", sans-serif';
      ctx.fillStyle = FOOT_INK; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(D.footers.edge, W / 2, y + FOOT_H / 2);
      return canvas;
    }

    // ── Season Card: single-season stats left + EDGE right ───────────────────
    async function drawSeasonCard(selectedSeason) {
      const BG = '#EFEEE8', SURFACE = '#FFFFFF';
      const SCALE = 2;
      const L_W = 520, R_W = 520;
      const PAD = 24, R_PAD = 20;

      // Look up season data — current season uses D.percentiles, historical uses _seasonStats
      var allSeasons = typeof _seasonStats !== 'undefined' ? _seasonStats : (window._seasonStats || []);
      var seasonData = null;
      if (selectedSeason && selectedSeason !== D.currentSeason) {
        seasonData = allSeasons.find(function(s) { return s.season === selectedSeason; }) || null;
      }
      var isHistorical = !!seasonData;
      var isLimited = isHistorical && seasonData.limited;
      // For the current season, we still want RAPM percentiles from allSeasons (they're not on D.percentiles)
      var currentSeasonEntry = !isHistorical
        ? (allSeasons.find(function(s) { return s.season === (selectedSeason || D.currentSeason); }) || null)
        : null;

      // EDGE source for the selected season: current → D.edge; historical → edge_history[season].
      // NHL EDGE only exists 2021-22+, so older seasons have no EDGE → render a narrow card.
      const e = isHistorical
        ? (D.edgeHistory ? (D.edgeHistory[selectedSeason] || null) : null)
        : D.edge;
      const hasEdge = !!e;
      const W = hasEdge ? L_W + R_W : L_W;
      // Season label for header + chips (defined early; hero tiles reuse it)
      var heroSeason = isHistorical ? selectedSeason : (D.currentSeason || '2025-26');
      // Theme the whole card to the SEASON's team (historical players may have moved).
      // Shadows the module-level TEAM_C for every reference inside this function.
      var seasonTeam = isHistorical ? (seasonData.team || D.team) : D.team;
      const TEAM_C = (D.teamColors && D.teamColors[seasonTeam]) ? D.teamColors[seasonTeam] : (D.teamColor || INK);

      // Helper to pick current vs historical percentile.
      // For historical seasons: pull from seasonData. For current season: prefer RAPM from
      // allSeasons (rapm_off_pct / rapm_def_pct) over the raw on-ice percentile on D.percentiles.
      function sp(currentVal, histKey) {
        if (isHistorical) {
          var v = seasonData[histKey];
          return v != null ? v : null;
        }
        if (currentSeasonEntry && currentSeasonEntry[histKey] != null) return currentSeasonEntry[histKey];
        return currentVal;
      }

      // Heights
      const HDR_H = 52, CHIP_H = 34;
      const ID_H = 122, BAR_ROW_H = 29, BAR_ROWS = 11;
      const COUNTS_H_S = 68;
      const L_CONTENT_H = 6 + ID_H + COUNTS_H_S + 1 + 20 + 12 + BAR_ROWS * BAR_ROW_H + 12;
      const EDGE_CONTENT_H = e ? 473 : 80; // measured: 44(hdr)+194(tiles)+92(zone)+143(shot)
      const CONTENT_H = Math.max(L_CONTENT_H, EDGE_CONTENT_H);
      const FOOT_H = 36;
      const H = HDR_H + CHIP_H + CONTENT_H + FOOT_H;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // Background + left accent bar
      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 4, H);

      // ── SHARED HEADER (white band) ─────────────────────────────────────────
      ctx.fillStyle = SURFACE; ctx.fillRect(0, 0, W, HDR_H + CHIP_H);
      ctx.fillStyle = INK14; ctx.fillRect(0, HDR_H + CHIP_H - 1, W, 1);

      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, HDR_H / 2);
      ctx.font = '800 14px "JetBrains Mono", monospace';
      ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
      ctx.fillText('SEASON CARD · ' + heroSeason, W - PAD, HDR_H / 2);

      // Chips
      const TEAM_NAMES_S = { ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS' };
      const chipH = 18, chipY0 = HDR_H + (CHIP_H - chipH) / 2;
      // Age at Oct 1 of the displayed season (heroSeason = "2022-23" → yr 2022)
      const _sznYr = heroSeason ? parseInt(heroSeason.slice(0, 4)) : null;
      const _sznAge = (D.birthDate && _sznYr)
        ? Math.floor((new Date(_sznYr, 9, 1) - new Date(D.birthDate)) / (365.25 * 24 * 3.6e6))
        : null;
      const _numSzn  = D.sweaterNumber != null ? [`#${D.sweaterNumber}`] : [];
      const _scSzn   = D.shootsCatches ? [`SHOOTS: ${D.shootsCatches}`] : [];
      const chips = [..._numSzn, (TEAM_NAMES_S[seasonTeam] || seasonTeam), D.posLabel.toUpperCase(), heroSeason, ...(_sznAge != null ? [`AGE: ${_sznAge}`] : []), ..._scSzn];
      const _tcSzn = 1 + _numSzn.length;
      let cx = PAD;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chips.length; ci++) {
        const cw = ctx.measureText(chips[ci]).width + 18;
        rrect(ctx, cx, chipY0, cw, chipH, 3);
        ctx.fillStyle = ci < _tcSzn ? TEAM_C : INK; ctx.fill();
        ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
        cx += cw + 8;
      }
      const brand = 'HOCKEYGAMEBOT';
      const bcw = ctx.measureText(brand).width + 18;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);

      // Panel divider (only when the EDGE panel is present)
      if (hasEdge) { ctx.fillStyle = INK14; ctx.fillRect(L_W, HDR_H + CHIP_H, 1, CONTENT_H); }

      // ── LEFT PANEL — identity + single-season bars ─────────────────────────
      let y = HDR_H + CHIP_H + 6;

      const R = 36, HS_CX = PAD + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(D.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) { ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2); }
      else { ctx.fillStyle = INK10; ctx.fill(); }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      const heroX = HS_CX + R + 18;
      const heroW = (L_W - heroX - PAD) / 2;
      var _rnd = function(v) { return v != null ? Math.round(v) : null; };
      var heroWarPct    = _rnd(isHistorical ? seasonData.war_pct        : D.warPct);
      var heroImpPct    = _rnd(isHistorical ? seasonData.impact_pct     : D.impactPct);
      var heroGp        = isHistorical ? (seasonData.gp || '—') : D.gp;
      // Percentile-only: no raw-value subtitles (only the season tag for historical / limited note).
      const heroTiles = [
        { label: 'HGB WAR · ' + heroSeason,    pct: heroWarPct,    sub: isLimited ? 'limited sample' : '' },
        { label: 'HGB IMPACT · ' + heroSeason, pct: heroImpPct,    sub: '' },
      ];
      // Two tiles now → much bigger numbers + larger labels so they survive
      // social-thumbnail scale. Label / number / sub stacked, centered in the ID row.
      for (let i = 0; i < heroTiles.length; i++) {
        const t = heroTiles[i];
        const tcx = heroX + i * heroW + heroW / 2;
        if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(heroX + i * heroW, y + 18, 1, ID_H - 36); }
        // Hero label — JetBrains Mono eyebrow, matching the SINGLE SEASON section
        // header convention (darker gray for legibility).
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.52)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText(t.label, tcx, y + 18);
        ctx.font = '900 58px "Barlow Condensed", sans-serif';
        ctx.fillStyle = t.pct != null ? TEAM_C : INK32;
        ctx.fillText(t.pct != null ? t.pct + '%' : '—', tcx, y + 34);
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top';
        ctx.fillText(t.sub, tcx, y + 98);
      }
      y += ID_H;

      // ── Counting stats strip — G / A / PTS / GP / TOI/GP ─────────────────
      ctx.fillStyle = SURFACE; ctx.fillRect(4, y, L_W - 4, COUNTS_H_S);
      // Pick goals/assists/points/toi from the selected season (historical from
      // _seasonStats, current from players.json D fields).
      const cG   = isHistorical ? seasonData.goals   : D.totalG;
      const cA   = isHistorical ? seasonData.assists : D.totalA;
      const cP   = isHistorical ? seasonData.points  : (D.totalG + D.totalA);
      const cToi = isHistorical ? seasonData.toi_avg_sec : D.toiAvgSec;
      const fmtToiStr = (sec) => sec != null ? `${Math.floor(sec/60)}:${String(Math.round(sec%60)).padStart(2,'0')}` : '—';
      const countCols = [
        { label: 'GOALS',   val: cG != null ? String(cG) : '—', color: cG != null ? INK : INK32 },
        { label: 'ASSISTS', val: cA != null ? String(cA) : '—', color: cA != null ? INK : INK32 },
        { label: 'POINTS',  val: cP != null ? String(cP) : '—', color: cP != null ? TEAM_C : INK32 },
        { label: 'GP',      val: String(heroGp),                color: INK },
        { label: 'TOI/GP',  val: fmtToiStr(cToi),               color: cToi != null ? INK : INK32 },
      ];
      const cColW = (L_W - PAD * 2) / countCols.length;
      for (let ci = 0; ci < countCols.length; ci++) {
        const cc = countCols[ci];
        const ccx = PAD + ci * cColW + cColW / 2;
        if (ci > 0) { ctx.fillStyle = INK06; ctx.fillRect(PAD + ci * cColW, y + 10, 1, COUNTS_H_S - 20); }
        ctx.font = '800 32px "Barlow Condensed", sans-serif';
        ctx.fillStyle = cc.color; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText(cc.val, ccx, y + COUNTS_H_S / 2 - 8);
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle';
        ctx.fillText(cc.label, ccx, y + COUNTS_H_S / 2 + 16);
      }
      y += COUNTS_H_S;

      ctx.fillStyle = INK14; ctx.fillRect(0, y, L_W, 1); y += 1 + 20;

      // Section header (kept: red "VS. X" stays here on the Season card)
      const isF = D.posGroup === 'F';
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('SINGLE SEASON', PAD, y);
      var ssW = ctx.measureText('SINGLE SEASON').width;
      ctx.fillStyle = RED;
      ctx.fillText('  ' + (isF ? 'VS. FORWARDS' : 'VS. DEFENSEMEN'), PAD + ssW, y);
      y += 12;

      // Single-season bars
      const pct = D.percentiles;
      const bars_ev_off  = sp(pct.ev_offence,  'rapm_off_pct');
      const bars_ev_def  = sp(pct.ev_defence,  'rapm_def_pct');
      const bars_goals   = sp(pct.goals,        'goals_pct');
      const bars_a1      = sp(pct.a1,           'a1_pct');
      const bars_ixg     = sp(pct.ixg,          'ixg_pct');
      const bars_fin     = sp(pct.finishing,     'rapm_finishing_pct');
      const bars_pen     = sp(pct.pen_diff,      'pen_diff_pct');
      const bars_pp      = sp(pct.pp_off ?? null,'rapm_pp_pct');
      const bars_pk      = sp(pct.pk_def ?? null,'rapm_pk_pct');
      const bars_qoc     = sp(D.qoc,             'qoc_pct');
      const bars_qot     = sp(D.qot,             'qot_pct');
      function barFillS(v, kind) {
        if (kind === 'context') return '#4285f4';
        if (v == null) return 'rgba(13,13,20,0.20)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.35)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      function pctColorS(v, kind) {
        if (kind === 'context') return '#4285f4';
        if (v == null) return 'rgba(13,13,20,0.35)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.50)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      const bars = [
        { label: 'EV Offense',       val: bars_ev_off, kind: 'performance' },
        { label: 'EV Defense',       val: bars_ev_def, kind: 'performance' },
        { label: 'Goals / 60',       val: bars_goals,  kind: 'performance' },
        { label: 'A1 / 60',          val: bars_a1,     kind: 'performance' },
        { label: 'xG / 60',          val: bars_ixg,    kind: 'performance' },
        { label: 'Pen Diff',         val: bars_pen,    kind: 'performance' },
        { label: 'Power Play',       val: bars_pp,     kind: 'performance' },
        { label: 'Penalty Kill',     val: bars_pk,     kind: 'performance' },
        { label: 'Finishing',        val: bars_fin,    kind: 'context'     },
        { label: 'Opponent Quality', val: bars_qoc,    kind: 'context'     },
        { label: 'Teammate Quality', val: bars_qot,    kind: 'context'     },
      ];
      const BAR_H_PX = 13, BAR_LABEL_W = 108, BAR_RANK_W = 40;
      const BAR_AVAIL = L_W - PAD * 2 - BAR_LABEL_W - BAR_RANK_W - 8;
      for (let bi = 0; bi < bars.length; bi++) {
        const b = bars[bi], rowY = y + bi * BAR_ROW_H, bby = rowY + (BAR_ROW_H - BAR_H_PX) / 2;
        ctx.font = '600 11px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(b.label, PAD, rowY + BAR_ROW_H / 2);
        const bx = PAD + BAR_LABEL_W;
        rrect(ctx, bx, bby, BAR_AVAIL, BAR_H_PX, 3); ctx.fillStyle = INK10; ctx.fill();
        if (b.val != null) {
          rrect(ctx, bx, bby, Math.max(6, (b.val / 100) * BAR_AVAIL), BAR_H_PX, 3);
          ctx.fillStyle = barFillS(b.val, b.kind); ctx.fill();
        }
        ctx.font = PCT_VALUE_FONT;
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        ctx.fillStyle = b.val == null ? 'rgba(13,13,20,0.32)' : pctColorS(b.val, b.kind);
        ctx.fillText(b.val == null ? '—' : Math.round(b.val) + '%', L_W - PAD, rowY + BAR_ROW_H / 2);
      }

      // ── RIGHT PANEL — NHL EDGE (only when the season has EDGE data) ─────────
      const RX = L_W + 1;
      let ry = HDR_H + CHIP_H;
      if (hasEdge) {
        // EDGE header
        const EDGE_HDR_H = 36;
        ctx.fillStyle = INK14; ctx.fillRect(RX, ry + EDGE_HDR_H - 1, R_W, 1);
        ctx.font = '800 13px "Barlow Condensed", sans-serif';
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillStyle = INK; ctx.fillText('NHL EDGE ', RX + R_PAD, ry + EDGE_HDR_H / 2);
        const edgeLabelW = ctx.measureText('NHL EDGE ').width;
        ctx.fillStyle = '#006D75'; ctx.fillText('TRACKING', RX + R_PAD + edgeLabelW, ry + EDGE_HDR_H / 2);
        if (isHistorical) {
          ctx.font = '600 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32; ctx.textAlign = 'right';
          ctx.fillText(selectedSeason, RX + R_W - R_PAD, ry + EDGE_HDR_H / 2);
        }
        ry += EDGE_HDR_H + 10;

        // 2×2 stat tiles
        const tileW = (R_W - R_PAD * 2 - 10) / 2, tileH = 90;
        const pairs = [
          ['TOP SPEED',      e.speed_max_mph != null ? e.speed_max_mph + ' mph' : '—',       e.speed_max_pct,      e.speed_max_league_avg_mph != null ? 'avg ' + e.speed_max_league_avg_mph + ' mph' : '', false],
          ['MILES SKATED',   e.distance_mi   != null ? e.distance_mi + ' mi' : '—',          e.distance_pct,       e.distance_league_avg_mi != null ? 'avg ' + e.distance_league_avg_mi + ' mi' : '',  false],
          ['BURSTS > 20 MPH',e.bursts_over_20 != null ? String(e.bursts_over_20) : '—',      e.bursts_over_20_pct, e.bursts_over_20_league_avg != null ? 'avg ' + e.bursts_over_20_league_avg : '',     false],
          ['HARDEST SHOT',   e.shot_speed_max_mph != null ? e.shot_speed_max_mph + ' mph' : '—', e.shot_speed_max_pct, e.shot_speed_max_league_avg_mph != null ? 'avg ' + e.shot_speed_max_league_avg_mph + ' mph' : '', false],
        ];
        for (let i = 0; i < 4; i++) {
          const col = i % 2, row = Math.floor(i / 2);
          drawEdgeStatBox(ctx, RX + R_PAD + col * (tileW + 10), ry + row * (tileH + 10), tileW, tileH, pairs[i][0], pairs[i][1], pairs[i][2], pairs[i][3], pairs[i][4]);
        }
        ry += 2 * (tileH + 10) - 10 + 25;
        // Zone bar — white card aligned with tiles; 6px inner padding keeps bar off the card edges
        const oz2 = e.oz_pct ?? 45, nz2 = e.nz_pct ?? 32, dz2 = e.dz_pct ?? 23;
        const zbw = R_W - R_PAD * 2, zbx = RX + R_PAD;
        const zBarPad = 10, zBarW = zbw - zBarPad * 2, zBarX = zbx + zBarPad;
        ctx.fillStyle = '#FFFFFF'; ctx.beginPath(); ctx.roundRect(zbx, ry - 10, zbw, 100, 4); ctx.fill();
        ctx.strokeStyle = INK10; ctx.lineWidth = 1; ctx.beginPath(); ctx.roundRect(zbx, ry - 10, zbw, 100, 4); ctx.stroke();
        ctx.font = '700 7.5px "JetBrains Mono", monospace'; ctx.fillStyle = INK45; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
        ctx.fillText('ZONE TIME — EVEN STRENGTH', zbx + 10, ry - 1);
        if (e.oz_ev_pct_pct != null) {
          ctx.font = '600 9px "Barlow", sans-serif'; ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
          ctx.fillText('OZ: ' + ordinal(e.oz_ev_pct_pct), zbx + zbw - 10, ry - 1);
        }
        ry += 14;
        ctx.save(); ctx.beginPath(); ctx.roundRect(zBarX, ry, zBarW, 20, 3); ctx.clip();
        ctx.fillStyle = TEAM_C;                    ctx.fillRect(zBarX,                         ry, zBarW * oz2 / 100, 20);
        ctx.fillStyle = 'rgba(13,13,20,0.18)';     ctx.fillRect(zBarX + zBarW * oz2 / 100,     ry, zBarW * nz2 / 100, 20);
        ctx.fillStyle = 'rgba(232,0,45,0.30)';     ctx.fillRect(zBarX + zBarW*(oz2+nz2)/100,   ry, zBarW * dz2 / 100, 20);
        ctx.restore();
        ry += 26;
        const zSegs2 = [['OZ', oz2.toFixed(0) + '%', oz2], ['NZ', nz2.toFixed(0) + '%', nz2], ['DZ', dz2.toFixed(0) + '%', dz2]];
        let zlx = zBarX;
        for (let zi = 0; zi < zSegs2.length; zi++) {
          const [abbr, pctStr, w] = zSegs2[zi];
          ctx.font = '800 14px "Barlow Condensed", sans-serif'; ctx.fillStyle = INK; ctx.textBaseline = 'top'; ctx.textAlign = 'left';
          ctx.fillText(pctStr, zlx, ry);
          ctx.font = '600 10px "JetBrains Mono", monospace'; ctx.fillStyle = INK45;
          ctx.fillText(abbr, zlx, ry + 16);
          zlx += zBarW * w / 100;
        }
        ry += 74; // 14(num)+10(lbl)+6(gap) + 8(afterSegGap) + 36(afterZoneGap)

        // Shot danger — clip aligned with tiles (R_PAD); pass R_PAD+2 so background card aligns exactly
        ctx.save();
        ctx.translate(RX, 0);
        ctx.beginPath(); ctx.rect(R_PAD, 0, R_W - R_PAD * 2, H); ctx.clip();
        ry = drawShotDanger(ctx, ry, R_W, R_PAD + 2, e, 10) + 10;
        ctx.restore();
      }

      // Footer — larger text; dynamic "vs Forwards"/"vs Defensemen" in red
      // (matching the Talent card footer's red position treatment).
      ctx.fillStyle = INK10; ctx.fillRect(0, H - FOOT_H, W, FOOT_H);
      ctx.font = '700 11px "Barlow Condensed", sans-serif';
      ctx.textBaseline = 'middle';
      const sSeg1 = D.footers.season.pre;
      const seasVs = D.footers.season.vs;
      const sSeg3 = D.footers.season.post;
      const sW1 = ctx.measureText(sSeg1).width;
      const sW2 = ctx.measureText(seasVs).width;
      const sW3 = ctx.measureText(sSeg3).width;
      let sfx = (W - (sW1 + sW2 + sW3)) / 2;
      const sfy = H - FOOT_H / 2;
      ctx.textAlign = 'left';
      ctx.fillStyle = FOOT_INK; ctx.fillText(sSeg1, sfx, sfy); sfx += sW1;
      ctx.fillStyle = RED;      ctx.fillText(seasVs, sfx, sfy); sfx += sW2;
      ctx.fillStyle = FOOT_INK; ctx.fillText(sSeg3, sfx, sfy);

      return canvas;
    }

    // ── Shotmap Card: identical left panel to Season Card + shot map PNG right ──
    async function drawShotmapCard() {
      const BG = '#EFEEE8', SURFACE = '#FFFFFF';
      const SCALE = 2;
      const L_W = 520, R_W = 520;
      const PAD = 24, R_PAD = 20;

      // Always current season, never historical
      var allSeasons = typeof _seasonStats !== 'undefined' ? _seasonStats : (window._seasonStats || []);
      var currentSeasonEntry = allSeasons.find(function(s) { return s.season === D.currentSeason; }) || null;
      var seasonTeam = D.team;
      const TEAM_C = (D.teamColors && D.teamColors[seasonTeam]) ? D.teamColors[seasonTeam] : (D.teamColor || INK);

      function sp(currentVal, histKey) {
        if (currentSeasonEntry && currentSeasonEntry[histKey] != null) return currentSeasonEntry[histKey];
        return currentVal;
      }

      const HDR_H = 52, CHIP_H = 34;
      const ID_H = 122, BAR_ROW_H = 29, BAR_ROWS = 11;
      const COUNTS_H_S = 68;
      const L_CONTENT_H = 6 + ID_H + COUNTS_H_S + 1 + 20 + 12 + BAR_ROWS * BAR_ROW_H + 12;
      const R_CONTENT_H = 473;
      const CONTENT_H = Math.max(L_CONTENT_H, R_CONTENT_H);
      const FOOT_H = 36;
      const W = L_W + R_W;
      const H = HDR_H + CHIP_H + CONTENT_H + FOOT_H;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 4, H);

      // ── SHARED HEADER (white band) ─────────────────────────────────────────
      ctx.fillStyle = SURFACE; ctx.fillRect(0, 0, W, HDR_H + CHIP_H);
      ctx.fillStyle = INK14; ctx.fillRect(0, HDR_H + CHIP_H - 1, W, 1);
      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, HDR_H / 2);
      ctx.font = '800 14px "JetBrains Mono", monospace';
      ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
      const heroSeason = D.currentSeason || '2025-26';
      ctx.fillText('SHOTMAP CARD · ' + heroSeason, W - PAD, HDR_H / 2);

      // Chips
      const TEAM_NAMES_SM = { ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS' };
      const chipH = 18, chipY0 = HDR_H + (CHIP_H - chipH) / 2;
      const _sznYr = heroSeason ? parseInt(heroSeason.slice(0, 4)) : null;
      const _sznAge = (D.birthDate && _sznYr) ? Math.floor((new Date(_sznYr, 9, 1) - new Date(D.birthDate)) / (365.25 * 24 * 3.6e6)) : null;
      const _numSzn  = D.sweaterNumber != null ? [`#${D.sweaterNumber}`] : [];
      const _scSzn   = D.shootsCatches ? [`SHOOTS: ${D.shootsCatches}`] : [];
      const chips = [..._numSzn, (TEAM_NAMES_SM[seasonTeam] || seasonTeam), D.posLabel.toUpperCase(), heroSeason, ...(_sznAge != null ? [`AGE: ${_sznAge}`] : []), ..._scSzn];
      const _tcSzn = 1 + _numSzn.length;
      let cx = PAD;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chips.length; ci++) {
        const cw = ctx.measureText(chips[ci]).width + 18;
        rrect(ctx, cx, chipY0, cw, chipH, 3);
        ctx.fillStyle = ci < _tcSzn ? TEAM_C : INK; ctx.fill();
        ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
        cx += cw + 8;
      }
      const brand = 'HOCKEYGAMEBOT';
      const bcw = ctx.measureText(brand).width + 18;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);

      // Panel divider
      ctx.fillStyle = INK14; ctx.fillRect(L_W, HDR_H + CHIP_H, 1, CONTENT_H);

      // ── LEFT PANEL — exact copy of drawSeasonCard left panel ──────────────
      let y = HDR_H + CHIP_H + 6;

      const R = 36, HS_CX = PAD + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(D.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) { ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2); }
      else { ctx.fillStyle = INK10; ctx.fill(); }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      const heroX = HS_CX + R + 18;
      const heroW = (L_W - heroX - PAD) / 2;
      var _rnd = function(v) { return v != null ? Math.round(v) : null; };
      var heroWarPct = _rnd(D.warPct);
      var heroImpPct = _rnd(D.impactPct);
      const heroTiles = [
        { label: 'HGB WAR · ' + heroSeason,    pct: heroWarPct,  sub: '' },
        { label: 'HGB IMPACT · ' + heroSeason, pct: heroImpPct,  sub: '' },
      ];
      for (let i = 0; i < heroTiles.length; i++) {
        const t = heroTiles[i];
        const tcx = heroX + i * heroW + heroW / 2;
        if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(heroX + i * heroW, y + 18, 1, ID_H - 36); }
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.52)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText(t.label, tcx, y + 18);
        ctx.font = '900 58px "Barlow Condensed", sans-serif';
        ctx.fillStyle = t.pct != null ? TEAM_C : INK32;
        ctx.fillText(t.pct != null ? t.pct + '%' : '—', tcx, y + 34);
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top';
        ctx.fillText(t.sub, tcx, y + 98);
      }
      y += ID_H;

      // Counting stats strip
      ctx.fillStyle = SURFACE; ctx.fillRect(4, y, L_W - 4, COUNTS_H_S);
      const cG   = D.totalG;
      const cA   = D.totalA;
      const cP   = (D.totalG != null && D.totalA != null) ? D.totalG + D.totalA : null;
      const cToi = D.toiAvgSec;
      const fmtToiStr = (sec) => sec != null ? `${Math.floor(sec/60)}:${String(Math.round(sec%60)).padStart(2,'0')}` : '—';
      const countCols = [
        { label: 'GOALS',   val: cG != null ? String(cG) : '—', color: cG != null ? INK : INK32 },
        { label: 'ASSISTS', val: cA != null ? String(cA) : '—', color: cA != null ? INK : INK32 },
        { label: 'POINTS',  val: cP != null ? String(cP) : '—', color: cP != null ? TEAM_C : INK32 },
        { label: 'GP',      val: D.gp != null ? String(D.gp) : '—', color: INK },
        { label: 'TOI/GP',  val: fmtToiStr(cToi), color: cToi != null ? INK : INK32 },
      ];
      const cColW = (L_W - PAD * 2) / countCols.length;
      for (let ci2 = 0; ci2 < countCols.length; ci2++) {
        const cc = countCols[ci2];
        const ccx = PAD + ci2 * cColW + cColW / 2;
        if (ci2 > 0) { ctx.fillStyle = INK06; ctx.fillRect(PAD + ci2 * cColW, y + 10, 1, COUNTS_H_S - 20); }
        ctx.font = '800 32px "Barlow Condensed", sans-serif';
        ctx.fillStyle = cc.color; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText(cc.val, ccx, y + COUNTS_H_S / 2 - 8);
        ctx.font = '700 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle';
        ctx.fillText(cc.label, ccx, y + COUNTS_H_S / 2 + 16);
      }
      y += COUNTS_H_S;

      ctx.fillStyle = INK14; ctx.fillRect(0, y, L_W, 1); y += 1 + 20;

      // Section header
      const isF = D.posGroup === 'F';
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('SINGLE SEASON', PAD, y);
      var ssW = ctx.measureText('SINGLE SEASON').width;
      ctx.fillStyle = RED;
      ctx.fillText('  ' + (isF ? 'VS. FORWARDS' : 'VS. DEFENSEMEN'), PAD + ssW, y);
      y += 12;

      // Single-season bars — identical to drawSeasonCard
      const pct = D.percentiles;
      const bars_ev_off = sp(pct.ev_offence, 'rapm_off_pct');
      const bars_ev_def = sp(pct.ev_defence, 'rapm_def_pct');
      const bars_goals  = sp(pct.goals,      'goals_pct');
      const bars_a1     = sp(pct.a1,         'a1_pct');
      const bars_ixg    = sp(pct.ixg,        'ixg_pct');
      const bars_fin    = sp(pct.finishing,   'rapm_finishing_pct');
      const bars_pen    = sp(pct.pen_diff,    'pen_diff_pct');
      const bars_pp     = sp(pct.pp_off ?? null, 'rapm_pp_pct');
      const bars_pk     = sp(pct.pk_def ?? null, 'rapm_pk_pct');
      const bars_qoc    = sp(D.qoc,           'qoc_pct');
      const bars_qot    = sp(D.qot,           'qot_pct');
      function barFillSM(v, kind) {
        if (kind === 'context') return '#4285f4';
        if (v == null) return 'rgba(13,13,20,0.20)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.35)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      function pctColorSM(v, kind) {
        if (kind === 'context') return '#4285f4';
        if (v == null) return 'rgba(13,13,20,0.35)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.50)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      const bars = [
        { label: 'EV Offense',       val: bars_ev_off, kind: 'performance' },
        { label: 'EV Defense',       val: bars_ev_def, kind: 'performance' },
        { label: 'Goals / 60',       val: bars_goals,  kind: 'performance' },
        { label: 'A1 / 60',          val: bars_a1,     kind: 'performance' },
        { label: 'xG / 60',          val: bars_ixg,    kind: 'performance' },
        { label: 'Pen Diff',         val: bars_pen,    kind: 'performance' },
        { label: 'Power Play',       val: bars_pp,     kind: 'performance' },
        { label: 'Penalty Kill',     val: bars_pk,     kind: 'performance' },
        { label: 'Finishing',        val: bars_fin,    kind: 'context'     },
        { label: 'Opponent Quality', val: bars_qoc,    kind: 'context'     },
        { label: 'Teammate Quality', val: bars_qot,    kind: 'context'     },
      ];
      const BAR_H_PX = 13, BAR_LABEL_W = 108, BAR_RANK_W = 40;
      const BAR_AVAIL = L_W - PAD * 2 - BAR_LABEL_W - BAR_RANK_W - 8;
      for (let bi = 0; bi < bars.length; bi++) {
        const b = bars[bi], rowY = y + bi * BAR_ROW_H, bby = rowY + (BAR_ROW_H - BAR_H_PX) / 2;
        ctx.font = '600 11px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(b.label, PAD, rowY + BAR_ROW_H / 2);
        const bx = PAD + BAR_LABEL_W;
        rrect(ctx, bx, bby, BAR_AVAIL, BAR_H_PX, 3); ctx.fillStyle = INK10; ctx.fill();
        if (b.val != null) {
          rrect(ctx, bx, bby, Math.max(6, (b.val / 100) * BAR_AVAIL), BAR_H_PX, 3);
          ctx.fillStyle = barFillSM(b.val, b.kind); ctx.fill();
        }
        ctx.font = PCT_VALUE_FONT;
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        ctx.fillStyle = b.val == null ? 'rgba(13,13,20,0.32)' : pctColorSM(b.val, b.kind);
        ctx.fillText(b.val == null ? '—' : Math.round(b.val) + '%', L_W - PAD, rowY + BAR_ROW_H / 2);
      }

      // ── RIGHT PANEL — Shot Map PNG ─────────────────────────────────────────
      const RX = L_W + 1;
      let ry = HDR_H + CHIP_H;
      const shotmapUrl = `https://media.hockeygamebot.com/stats/skater-shot-maps/skater_shot_map_${D.playerId}_20252026_5v5.png`;
      const shotmapImg = await loadImg(shotmapUrl);

      const MAP_HDR_H = 36;
      ctx.fillStyle = INK14; ctx.fillRect(RX, ry + MAP_HDR_H - 1, R_W, 1);
      ctx.font = '800 13px "Barlow Condensed", sans-serif';
      ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillStyle = INK; ctx.fillText('SHOT LOCATION ', RX + R_PAD, ry + MAP_HDR_H / 2);
      const slw = ctx.measureText('SHOT LOCATION ').width;
      ctx.fillStyle = RED; ctx.fillText('MAP', RX + R_PAD + slw, ry + MAP_HDR_H / 2);
      ctx.font = '600 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32; ctx.textAlign = 'right';
      ctx.fillText('5V5 · VS LEAGUE AVG', RX + R_W - R_PAD, ry + MAP_HDR_H / 2);
      ry += MAP_HDR_H + 8;

      if (shotmapImg) {
        const MAP_BOT = H - FOOT_H - 28;
        const availH = MAP_BOT - ry;
        const availW = R_W - R_PAD * 2;
        const imgAspect = shotmapImg.naturalWidth / shotmapImg.naturalHeight;
        let drawW = availW, drawH = availW / imgAspect;
        if (drawH > availH) { drawH = availH; drawW = availH * imgAspect; }
        const drawX = RX + R_PAD + (availW - drawW) / 2;
        const drawY = ry + (availH - drawH) / 2;
        ctx.drawImage(shotmapImg, drawX, drawY, drawW, drawH);

        // Legend
        const LX = RX + R_PAD, LY = H - FOOT_H - 18;
        const gradW = 90, gradH = 5;
        const grad = ctx.createLinearGradient(LX, 0, LX + gradW, 0);
        grad.addColorStop(0, '#1a56c4'); grad.addColorStop(0.5, '#f5f4f0'); grad.addColorStop(1, '#b51a1a');
        ctx.fillStyle = grad; ctx.fillRect(LX, LY, gradW, gradH);
        ctx.font = '700 8px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText('FEWER', LX, LY - 6);
        ctx.textAlign = 'right';
        ctx.fillText('MORE', LX + gradW, LY - 6);
      } else {
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('SHOT MAP UNAVAILABLE', RX + R_W / 2, HDR_H + CHIP_H + CONTENT_H / 2);
        ctx.font = '600 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK14;
        ctx.fillText('(map generates nightly)', RX + R_W / 2, HDR_H + CHIP_H + CONTENT_H / 2 + 20);
      }

      // Footer
      ctx.fillStyle = INK10; ctx.fillRect(0, H - FOOT_H, W, FOOT_H);
      ctx.font = '700 11px "Barlow Condensed", sans-serif'; ctx.fillStyle = FOOT_INK;
      ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      ctx.fillText('WAR = single-season, percentile vs ' + (isF ? 'Forwards' : 'Defensemen') + '  ·  HOCKEYGAMEBOT.COM  ·  5V5 SHOT LOCATION vs LEAGUE AVERAGE', W / 2, H - FOOT_H / 2);

      return canvas;
    }

    // ── Talent Shotmap Card: 3-year Talent left panel + 3-year shot map right ──
    // Mirrors drawShotmapCard's L/R geometry and drawSeasonCard's gray-track bar
    // renderer, but sources the Talent hero (D.hgb_rating_percentile), the 3-year
    // Talent percentile set (same as the portrait Talent card), and relocates the
    // PAST SINGLE-SEASON WAR history (D.priorWar) into the white strip — directly
    // analogous to the goalie Talent card. Right panel loads the all-situations,
    // positional 3-year shot-location map ({player_id}_3yr.png). RED = shoots MORE
    // than the position average from that spot; BLUE = fewer (NOT worse/better —
    // shooting more isn't inherently "better" for a skater).
    // NOTE: Built HORIZONTAL (left bars / right shotmap) per the maintainer's
    // "shotmap on the right panel" description, which requires a wide layout. If a
    // narrow PORTRAIT variant was intended instead, this needs a rework — flagged.
    async function drawTalentShotmapCard() {
      const BG = '#EFEEE8', SURFACE = '#FFFFFF';
      const SCALE = 2;
      const L_W = 520, R_W = 520;
      const PAD = 24, R_PAD = 20;

      const seasonTeam = D.team;
      const TEAM_C = (D.teamColors && D.teamColors[seasonTeam]) ? D.teamColors[seasonTeam] : (D.teamColor || INK);

      const HDR_H = 52, CHIP_H = 34;
      const ID_H = 122, BAR_ROW_H = 29, BAR_ROWS = 11;
      const STRIP_H = 68;
      const L_CONTENT_H = 6 + ID_H + STRIP_H + 1 + 20 + 12 + BAR_ROWS * BAR_ROW_H + 12;
      const R_CONTENT_H = 473;
      const CONTENT_H = Math.max(L_CONTENT_H, R_CONTENT_H);
      const FOOT_H = 36;
      const W = L_W + R_W;
      const H = HDR_H + CHIP_H + CONTENT_H + FOOT_H;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 4, H);

      // ── SHARED HEADER (white band) ─────────────────────────────────────────
      ctx.fillStyle = SURFACE; ctx.fillRect(0, 0, W, HDR_H + CHIP_H);
      ctx.fillStyle = INK14; ctx.fillRect(0, HDR_H + CHIP_H - 1, W, 1);
      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, HDR_H / 2);
      ctx.font = '800 14px "JetBrains Mono", monospace';
      ctx.fillStyle = TEAM_C; ctx.textAlign = 'right';
      const heroSeason = D.currentSeason || '2025-26';
      ctx.fillText('TALENT CARD · MULTI-YEAR', W - PAD, HDR_H / 2);

      // Chips (same as Season/Shotmap cards)
      const TEAM_NAMES_TS = { ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS' };
      const chipH = 18, chipY0 = HDR_H + (CHIP_H - chipH) / 2;
      const _sznYr = heroSeason ? parseInt(heroSeason.slice(0, 4)) : null;
      const _sznAge = (D.birthDate && _sznYr) ? Math.floor((new Date(_sznYr, 9, 1) - new Date(D.birthDate)) / (365.25 * 24 * 3.6e6)) : null;
      const _numSzn  = D.sweaterNumber != null ? [`#${D.sweaterNumber}`] : [];
      const _scSzn   = D.shootsCatches ? [`SHOOTS: ${D.shootsCatches}`] : [];
      const chips = [..._numSzn, (TEAM_NAMES_TS[seasonTeam] || seasonTeam), D.posLabel.toUpperCase(), heroSeason, ...(_sznAge != null ? [`AGE: ${_sznAge}`] : []), ..._scSzn];
      const _tcSzn = 1 + _numSzn.length;
      let cx = PAD;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chips.length; ci++) {
        const cw = ctx.measureText(chips[ci]).width + 18;
        rrect(ctx, cx, chipY0, cw, chipH, 3);
        ctx.fillStyle = ci < _tcSzn ? TEAM_C : INK; ctx.fill();
        ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
        cx += cw + 8;
      }
      const brand = 'HOCKEYGAMEBOT';
      const bcw = ctx.measureText(brand).width + 18;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);

      // Panel divider
      ctx.fillStyle = INK14; ctx.fillRect(L_W, HDR_H + CHIP_H, 1, CONTENT_H);

      // ── LEFT PANEL — headshot + Talent hero ────────────────────────────────
      let y = HDR_H + CHIP_H + 6;

      const R = 36, HS_CX = PAD + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(D.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) { ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2); }
      else { ctx.fillStyle = INK10; ctx.fill(); }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      // Talent hero — single centered HGB TALENT % (multi-year blended WAR
      // percentile). A second AVAILABILITY box was tried, but a games-played RATE
      // reads ambiguously next to a percentile RANK, so it's one confident number.
      const heroTalentPct = D.hgb_rating_percentile != null ? Math.round(D.hgb_rating_percentile) : null;
      const heroX = HS_CX + R + 18;
      const heroCX = heroX + (L_W - heroX - PAD) / 2;   // centered across the full hero width
      // eyebrow / big % / sublabel — balanced gaps, block vertically centered on the
      // headshot (HS_CY = y + ID_H/2). The 60px digits end ~y+85, so the sublabel sits
      // at y+94 (not y+102, which left it floating) for even spacing above and below.
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = 'rgba(13,13,20,0.52)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
      ctx.fillText('HGB TALENT · MULTI-YEAR', heroCX, y + 16);
      ctx.font = '900 60px "Barlow Condensed", sans-serif';
      ctx.fillStyle = heroTalentPct != null ? TEAM_C : INK32;
      ctx.fillText(heroTalentPct != null ? heroTalentPct + '%' : '—', heroCX, y + 33);
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top';
      ctx.fillText('MULTI-YEAR BLENDED WAR', heroCX, y + 94);
      y += ID_H;

      // ── WHITE STRIP — PAST SINGLE-SEASON WAR history ───────────────────────
      // Relocated here from the Talent hero, matching the goalie Talent card.
      ctx.fillStyle = SURFACE; ctx.fillRect(4, y, L_W - 4, STRIP_H);
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
      ctx.fillText('PAST SINGLE-SEASON WAR', L_W / 2, y + 9);
      function fmtSznTS(s) {
        if (!s) return '';
        if (s.includes('-')) return s.slice(2, 4) + '-' + s.slice(5, 7);
        return s.slice(2, 4) + '-' + s.slice(6, 8);
      }
      const priorWarTS = (D.priorWar ?? []).slice().reverse(); // oldest → newest, left → right
      if (priorWarTS.length > 0) {
        const wCols = priorWarTS.length;
        const colW = (L_W - PAD * 2) / wCols;
        for (let wi = 0; wi < wCols; wi++) {
          const entry = priorWarTS[wi];
          const ccx = PAD + wi * colW + colW / 2;
          if (wi > 0) { ctx.fillStyle = INK06; ctx.fillRect(PAD + wi * colW, y + 26, 1, STRIP_H - 32); }
          ctx.font = '800 28px "Barlow Condensed", sans-serif';
          ctx.fillStyle = entry.pct != null ? INK : INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
          ctx.fillText(entry.pct != null ? entry.pct + '%' : '—', ccx, y + 40);
          ctx.font = '700 9px "JetBrains Mono", monospace';
          ctx.fillStyle = INK32; ctx.textBaseline = 'middle';
          ctx.fillText(fmtSznTS(entry.season), ccx, y + 58);
        }
      } else {
        ctx.font = '600 11px "Barlow", sans-serif';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText('No prior single-season WAR on record', L_W / 2, y + STRIP_H / 2 + 6);
      }
      y += STRIP_H;

      ctx.fillStyle = INK14; ctx.fillRect(0, y, L_W, 1); y += 1 + 20;

      // Section header
      const isF = D.posGroup === 'F';
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('MULTI-YEAR TALENT', PAD, y);
      var tsW = ctx.measureText('MULTI-YEAR TALENT').width;
      ctx.fillStyle = RED;
      ctx.fillText('  ' + (isF ? 'VS. FORWARDS' : 'VS. DEFENSEMEN'), PAD + tsW, y);
      y += 12;

      // ── Talent bars — same set as the portrait Talent card, 3yr → season fallback
      const pct3 = D.percentiles;
      const v3 = (a, b) => (a != null ? a : (b != null ? b : null));
      const bars = [
        { label: 'EV Offense',       val: D.hgb_rating_off_pct,                    kind: 'performance' },
        { label: 'EV Defense',       val: D.hgb_rating_def_pct,                    kind: 'performance' },
        { label: 'Goals / 60',       val: v3(D.g_60_pct_3yr,      pct3.goals),     kind: 'performance' },
        { label: 'A1 / 60',          val: v3(D.a1_60_pct_3yr,     pct3.a1),        kind: 'performance' },
        { label: 'xG / 60',          val: v3(D.xg_60_pct_3yr,     pct3.ixg),       kind: 'performance' },
        { label: 'Pen Diff',         val: v3(D.pen_diff_pct_3yr,  pct3.pen_diff),  kind: 'performance' },
        { label: 'Power Play',       val: pct3.pp_off ?? null,                     kind: 'performance' },
        { label: 'Penalty Kill',     val: pct3.pk_def ?? null,                     kind: 'performance' },
        { label: 'Finishing',        val: v3(D.finishing_pct_3yr, pct3.finishing), kind: 'context'     },
        { label: 'Opponent Quality', val: v3(D.qoc_pct_3yr,       D.qoc),          kind: 'context'     },
        { label: 'Teammate Quality', val: v3(D.qot_pct_3yr,       D.qot),          kind: 'context'     },
      ];
      function barFillTS(v, kind) {
        if (kind === 'context') return '#4285f4';
        if (v == null) return 'rgba(13,13,20,0.20)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.35)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      function pctColorTS(v, kind) {
        if (kind === 'context') return '#4285f4';
        if (v == null) return 'rgba(13,13,20,0.35)';
        if (v >= 75) return '#137333'; if (v >= 55) return '#4CAF50';
        if (v >= 40) return 'rgba(13,13,20,0.50)'; if (v >= 25) return '#E57373';
        return '#E8002D';
      }
      const BAR_H_PX = 13, BAR_LABEL_W = 108, BAR_RANK_W = 40;
      const BAR_AVAIL = L_W - PAD * 2 - BAR_LABEL_W - BAR_RANK_W - 8;
      for (let bi = 0; bi < bars.length; bi++) {
        const b = bars[bi], rowY = y + bi * BAR_ROW_H, bby = rowY + (BAR_ROW_H - BAR_H_PX) / 2;
        ctx.font = '600 11px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(b.label, PAD, rowY + BAR_ROW_H / 2);
        const bx = PAD + BAR_LABEL_W;
        rrect(ctx, bx, bby, BAR_AVAIL, BAR_H_PX, 3); ctx.fillStyle = INK10; ctx.fill();
        if (b.val != null) {
          rrect(ctx, bx, bby, Math.max(6, (b.val / 100) * BAR_AVAIL), BAR_H_PX, 3);
          ctx.fillStyle = barFillTS(b.val, b.kind); ctx.fill();
        }
        ctx.font = PCT_VALUE_FONT;
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        ctx.fillStyle = b.val == null ? 'rgba(13,13,20,0.32)' : pctColorTS(b.val, b.kind);
        ctx.fillText(b.val == null ? '—' : Math.round(b.val) + '%', L_W - PAD, rowY + BAR_ROW_H / 2);
      }

      // ── RIGHT PANEL — 3-year shot map PNG ──────────────────────────────────
      const RX = L_W + 1;
      let ry = HDR_H + CHIP_H;
      const shotmapUrl = `https://media.hockeygamebot.com/stats/skater-shot-maps/${D.playerId}_3yr.png`;
      const shotmapImg = await loadImg(shotmapUrl);

      const MAP_HDR_H = 36;
      ctx.fillStyle = INK14; ctx.fillRect(RX, ry + MAP_HDR_H - 1, R_W, 1);
      ctx.font = '800 13px "Barlow Condensed", sans-serif';
      ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillStyle = INK; ctx.fillText('SHOT LOCATION MAP ', RX + R_PAD, ry + MAP_HDR_H / 2);
      const slw = ctx.measureText('SHOT LOCATION MAP ').width;
      ctx.fillStyle = RED; ctx.fillText('MULTI-YEAR', RX + R_PAD + slw, ry + MAP_HDR_H / 2);
      ctx.font = '600 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK32; ctx.textAlign = 'right';
      ctx.fillText('VS POSITION · PER 60', RX + R_W - R_PAD, ry + MAP_HDR_H / 2);
      ry += MAP_HDR_H + 8;

      if (shotmapImg) {
        const MAP_BOT = H - FOOT_H - 28;
        const availH = MAP_BOT - ry;
        const availW = R_W - R_PAD * 2;
        const imgAspect = shotmapImg.naturalWidth / shotmapImg.naturalHeight;
        let drawW = availW, drawH = availW / imgAspect;
        if (drawH > availH) { drawH = availH; drawW = availH * imgAspect; }
        const drawX = RX + R_PAD + (availW - drawW) / 2;
        const drawY = ry + (availH - drawH) / 2;
        ctx.drawImage(shotmapImg, drawX, drawY, drawW, drawH);

        // Legend — FEWER … MORE (red = shoots more than position avg, blue = fewer)
        const LX = RX + R_PAD, LY = H - FOOT_H - 18;
        const gradW = 90, gradH = 5;
        const grad = ctx.createLinearGradient(LX, 0, LX + gradW, 0);
        grad.addColorStop(0, '#1a56c4'); grad.addColorStop(0.5, '#f5f4f0'); grad.addColorStop(1, '#b51a1a');
        ctx.fillStyle = grad; ctx.fillRect(LX, LY, gradW, gradH);
        ctx.font = '700 8px "JetBrains Mono", monospace'; ctx.fillStyle = INK32;
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText('FEWER', LX, LY - 6);
        ctx.textAlign = 'right';
        ctx.fillText('MORE', LX + gradW, LY - 6);
      } else {
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('MULTI-YEAR SHOT MAP UNAVAILABLE', RX + R_W / 2, HDR_H + CHIP_H + CONTENT_H / 2);
        ctx.font = '600 9px "JetBrains Mono", monospace'; ctx.fillStyle = INK14;
        ctx.fillText('(fewer than 50 shots over 3 seasons)', RX + R_W / 2, HDR_H + CHIP_H + CONTENT_H / 2 + 20);
      }

      // Footer — Talent footer (position phrase in red), matching the Talent cards
      ctx.fillStyle = INK10; ctx.fillRect(0, H - FOOT_H, W, FOOT_H);
      ctx.font = '700 11px "Barlow Condensed", sans-serif';
      ctx.textBaseline = 'middle';
      const tSeg1 = D.footers.talent.pre;
      const tVs   = D.footers.talent.vs;
      const tSeg3 = D.footers.talent.post;
      const tW1 = ctx.measureText(tSeg1).width;
      const tW2 = ctx.measureText(tVs).width;
      const tW3 = ctx.measureText(tSeg3).width;
      let tfx = (W - (tW1 + tW2 + tW3)) / 2;
      const tfy = H - FOOT_H / 2;
      ctx.textAlign = 'left';
      ctx.fillStyle = FOOT_INK; ctx.fillText(tSeg1, tfx, tfy); tfx += tW1;
      ctx.fillStyle = RED;      ctx.fillText(tVs,   tfx, tfy); tfx += tW2;
      ctx.fillStyle = FOOT_INK; ctx.fillText(tSeg3, tfx, tfy);

      return canvas;
    }

    // ── HGB Talent Card (JFresh-style blended component card) ────────────
    // ── Rating Card — portrait 520×720, 3-year talent profile ──────────────
    async function drawRatingCardPortrait() {
      const BG      = '#EFEEE8';
      const SURFACE = '#FFFFFF';
      const SCALE   = 2;
      const W       = 520;
      const PAD     = 28;

      // Reflow hero: tighter identity band (no mini-boxes), bigger Talent number,
      // and slightly taller bar rows so the bars/tiles read intentional in the space.
      // header+chips(86) + gap(6) + identity(108) + sep(1) + section gap(18) +
      // section label(12) + 11 bars(385) + bottom pad(12) + footer(36)
      const _HDR = 52, _CHIP = 34, _ID = 108, _BAR_ROWS = 11, _BAR_ROW = 35, _FOOT = 36;
      const H = _HDR + _CHIP + 6 + _ID + 1 + 18 + 12 + _BAR_ROWS * _BAR_ROW + 12 + _FOOT;

      const canvas = document.createElement('canvas');
      canvas.width  = W * SCALE;
      canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      // background
      ctx.fillStyle = BG;
      ctx.fillRect(0, 0, W, H);

      // team full name lookup
      const TEAM_NAMES = {
        ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',
        BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',
        CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',
        DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',
        FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',
        MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',
        NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',
        PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',
        SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',
        TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',
        VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS',
      };
      const teamFullName = TEAM_NAMES[D.team] || D.team;

      let y = 0;

      // ════════ SECTION 1 — WHITE BAND: orange accent bar + name + chips ════════
      const HDR_H  = 52;
      const CHIP_H = 34;

      // White fills the full name+chips area; orange accent bar spans the full white band
      ctx.fillStyle = SURFACE;
      ctx.fillRect(0, y, W, HDR_H + CHIP_H);
      // Orange left accent bar — 4px, full height of white band
      ctx.fillStyle = TEAM_C;
      ctx.fillRect(0, y, 4, HDR_H + CHIP_H);
      // Player name
      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = INK;
      ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, y + HDR_H / 2);
      y += HDR_H;

      // Chips row — team | position | season | age  +  HOCKEYGAMEBOT (right)
      // Still inside the white band (white fill covers HDR_H + CHIP_H)
      const chipH = 18, chipY0 = y + (CHIP_H - chipH) / 2;
      const ageChip  = D.ageAtSeason   != null ? `AGE: ${D.ageAtSeason}`       : null;
      const _numPort = D.sweaterNumber  != null ? [`#${D.sweaterNumber}`]        : [];
      const _scPort  = D.shootsCatches           ? [`SHOOTS: ${D.shootsCatches}`] : [];
      const chips = [..._numPort, teamFullName, D.posLabel.toUpperCase(), D.currentSeason, ...(ageChip ? [ageChip] : []), ..._scPort];
      const _tcPort = 1 + _numPort.length;
      let cx = PAD;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      for (let ci = 0; ci < chips.length; ci++) {
        const tw = ctx.measureText(chips[ci]).width;
        const cw = tw + 18;
        rrect(ctx, cx, chipY0, cw, chipH, 3);
        ctx.fillStyle = ci < _tcPort ? TEAM_C : INK;
        ctx.fill();
        ctx.fillStyle = BG;
        ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
        cx += cw + 8;
      }
      const brand = 'HOCKEYGAMEBOT';
      const btw = ctx.measureText(brand).width;
      const bcw = btw + 18;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);
      // Bottom border of white band
      ctx.fillStyle = 'rgba(13,13,20,0.08)';
      ctx.fillRect(0, y + CHIP_H - 1, W, 1);
      y += CHIP_H;

      // ════════ SECTION 2 — IDENTITY ROW (headshot + Talent hero, reflow) ════════
      const ID_H = 108;
      y += 6;

      // headshot circle — team-color border
      const R = 36, HS_CX = PAD + R, HS_CY = y + ID_H / 2;
      const hsImg = await loadImg(D.headshotUrl);
      ctx.save(); ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - R, HS_CY - R, R * 2, R * 2);
      } else {
        ctx.fillStyle = INK10; ctx.fill();
        ctx.font = '800 24px "Barlow Condensed", sans-serif';
        ctx.fillStyle = INK32; ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
        ctx.fillText((D.firstName[0] + D.lastName[0]).toUpperCase(), HS_CX, HS_CY);
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

      // Talent hero to the right of headshot — mirrors the SEASON card's hero:
      // two BARE stat halves split by a thin vertical divider, numbers sitting
      // directly on the cream (no surface boxes/borders). LEFT = Talent,
      // RIGHT = Current WAR + Model View. Without talent_context the Talent half
      // centers across the full hero with no divider (graceful fallback).
      const heroX  = HS_CX + R + 18;
      const heroW  = (W - heroX - PAD);

      const ratingPctVal = D.hgb_rating_percentile;
      const priorTalentP = D.priorWar ?? [];
      const hasContextPanel = priorTalentP.length > 0;

      // Two balanced halves when prior talent exists; otherwise one full-width half.
      const halfW = hasContextPanel ? heroW / 2 : heroW;

      // Formats season string to short display label. Handles "20222023" and "2022-23".
      function fmtSzn(s) {
        if (!s) return '';
        if (s.includes('-')) return s.slice(2,4) + '-' + s.slice(5,7);
        return s.slice(2,4) + '-' + s.slice(6,8);
      }

      // LEFT half — Talent (bare): HGB TALENT eyebrow / big % / subtitle.
      {
        const tcx = heroX + halfW / 2;
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.72)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText('HGB TALENT', tcx, y + 14);
        ctx.font = '900 60px "Barlow Condensed", sans-serif';
        ctx.fillStyle = ratingPctVal != null ? TEAM_C : INK32;
        ctx.fillText(ratingPctVal != null ? ratingPctVal + '%' : '—', tcx, y + 28);
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top';
        ctx.fillText('MULTI-YEAR BLENDED WAR', tcx, y + 90);
      }

      // RIGHT half — 3 prior seasons of Historical Talent, horizontal timeline.
      // Eyebrow "TALENT HISTORY" + 3 columns (oldest→newest) with arrows between.
      if (hasContextPanel) {
        const L_RIGHT = heroX + halfW;
        const rcx = L_RIGHT + halfW / 2;
        ctx.fillStyle = INK10; ctx.fillRect(L_RIGHT, y + 18, 1, ID_H - 36);

        // Eyebrow
        ctx.font = '700 10px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(13,13,20,0.72)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText('PAST SINGLE-SEASON WAR', rcx, y + 8);

        // 3 evenly-spaced column centers across the right half. No arrows — standalone
        // blocks avoid implying a causal trend (volatile profiles read as past model outputs).
        const PAD_INNER = 14;
        const usable = halfW - PAD_INNER * 2;
        const cols = priorTalentP.slice().reverse(); // oldest→newest left→right
        const colCenters = cols.map((_, i) => L_RIGHT + PAD_INNER + usable * (i + 0.5) / cols.length);
        const SZN_Y = y + 24, NUM_Y = y + 36, NUM_SZ = 34;

        cols.forEach((entry, i) => {
          const cx = colCenters[i];
          // Season label
          ctx.font = '700 9px "Barlow", sans-serif';
          ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
          ctx.fillText(fmtSzn(entry.season), cx, SZN_Y);
          // Number — no arrows between columns
          ctx.font = `800 ${NUM_SZ}px "Barlow Condensed", sans-serif`;
          ctx.fillStyle = INK;
          ctx.fillText(String(entry.pct) + '%', cx, NUM_Y);
        });
      }
      y += ID_H;

      // separator
      ctx.fillStyle = INK14; ctx.fillRect(0, y, W, 1); y += 1;

      // ════════ SECTION 3 — 3-YEAR PROFILE BARS ════════
      y += 18;

      // section header — just "HGB TALENT PROFILE" (vs Forwards moved to footer)
      ctx.font = '700 10px "JetBrains Mono", monospace';
      ctx.fillStyle = INK48; ctx.textBaseline = 'alphabetic'; ctx.textAlign = 'left';
      ctx.fillText('HGB TALENT PROFILE', PAD, y);
      y += 12;

      // 11 bars, single column. Fall back to season percentiles when 3yr null.
      const pct3 = D.percentiles;
      const v3 = (a, b) => (a != null ? a : (b != null ? b : null));
      // kind: 'context' → blue (QoC / QoT only — deployment context, not skill).
      // All other bars use the 5-tier green/gray/red performance scale.
      const profileBars = [
        { label: 'EV Offense',       val: D.hgb_rating_off_pct,                    kind: 'performance' },
        { label: 'EV Defense',       val: D.hgb_rating_def_pct,                    kind: 'performance' },
        { label: 'Goals / 60',       val: v3(D.g_60_pct_3yr,      pct3.goals),     kind: 'performance' },
        { label: 'A1 / 60',          val: v3(D.a1_60_pct_3yr,     pct3.a1),        kind: 'performance' },
        { label: 'xG / 60',          val: v3(D.xg_60_pct_3yr,     pct3.ixg),       kind: 'performance' },
        { label: 'Pen Diff',         val: v3(D.pen_diff_pct_3yr,  pct3.pen_diff),  kind: 'performance' },
        { label: 'Power Play',       val: pct3.pp_off ?? null,                     kind: 'performance' },
        { label: 'Penalty Kill',     val: pct3.pk_def ?? null,                     kind: 'performance' },
        { label: 'Finishing',        val: v3(D.finishing_pct_3yr, pct3.finishing), kind: 'context'     },
        { label: 'Opponent Quality', val: v3(D.qoc_pct_3yr,       D.qoc),          kind: 'context'     },
        { label: 'Teammate Quality', val: v3(D.qot_pct_3yr,       D.qot),          kind: 'context'     },
      ];

      const BAR_ROW_H   = 35;
      const BAR_H_PX    = 15;
      const BAR_LABEL_W = 108;
      const BAR_RANK_W  = 44;
      const BAR_AVAIL   = W - PAD * 2 - BAR_LABEL_W - BAR_RANK_W - 8;

      function barFill(pct, kind) {
        // contextual metrics (EV Defense, QoC, QoT) — always blue.
        // High here is "tough deployment / context", not "good player skill".
        if (kind === 'context') return '#4285f4';
        if (pct == null) return 'rgba(13,13,20,0.20)';
        if (pct >= 75) return '#137333';           // elite — dark green
        if (pct >= 55) return '#4CAF50';           // above avg — light green
        if (pct >= 40) return 'rgba(13,13,20,0.35)'; // average — neutral gray
        if (pct >= 25) return '#E57373';           // below avg — light red
        return '#E8002D';                          // poor — dark red
      }
      function pctColor(pct, kind) {
        if (kind === 'context') return '#4285f4';
        if (pct == null) return 'rgba(13,13,20,0.35)';
        if (pct >= 75) return '#137333';
        if (pct >= 55) return '#4CAF50';
        if (pct >= 40) return 'rgba(13,13,20,0.50)';
        if (pct >= 25) return '#E57373';
        return '#E8002D';
      }

      function makeHatchPattern(ctx) {
        const sz = 6;
        const pc = document.createElement('canvas');
        pc.width = sz; pc.height = sz;
        const px = pc.getContext('2d');
        px.strokeStyle = 'rgba(13,13,20,0.18)';
        px.lineWidth = 1;
        px.beginPath();
        px.moveTo(0, sz); px.lineTo(sz, 0);
        px.stroke();
        return ctx.createPattern(pc, 'repeat');
      }

      for (let bi = 0; bi < profileBars.length; bi++) {
        const b = profileBars[bi];
        const rowY = y + bi * BAR_ROW_H;
        const by   = rowY + (BAR_ROW_H - BAR_H_PX) / 2;
        const val  = b.val;

        // label
        ctx.font = '600 11px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.85)'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(b.label, PAD, rowY + BAR_ROW_H / 2);

        // track
        const bx = PAD + BAR_LABEL_W;
        rrect(ctx, bx, by, BAR_AVAIL, BAR_H_PX, 3);
        ctx.fillStyle = INK10; ctx.fill();

        if (val == null) {
          // hatch pattern fill for no-data bars
          const hatch = makeHatchPattern(ctx);
          rrect(ctx, bx, by, BAR_AVAIL, BAR_H_PX, 3);
          ctx.fillStyle = hatch; ctx.fill();
        } else {
          const tierC = barFill(val, b.kind);
          // fill
          const fillW = Math.max(6, (val / 100) * BAR_AVAIL);
          rrect(ctx, bx, by, fillW, BAR_H_PX, 3);
          ctx.fillStyle = tierC; ctx.fill();
        }

        // percentage (right-aligned) — skip for null bars, show muted dash instead
        ctx.font = PCT_VALUE_FONT;
        ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
        if (val == null) {
          ctx.fillStyle = 'rgba(13,13,20,0.32)';
          ctx.fillText('—', W - PAD, rowY + BAR_ROW_H / 2);
        } else {
          ctx.fillStyle = pctColor(val, b.kind);
          ctx.fillText(Math.round(val) + '%', W - PAD, rowY + BAR_ROW_H / 2);
        }
      }
      y += profileBars.length * BAR_ROW_H + 12;

      // ════════ SECTION 4 — FOOTER ════════
      // "Talent = current + 3 prior seasons · percentile [vs Forwards] · hockeygamebot.com"
      // ("Multi-Year Blended WAR" lives once, in the hero subtitle; position phrase red.)
      const FOOT_H = 36;
      const footY = y;
      ctx.fillStyle = INK06; ctx.fillRect(0, footY, W, FOOT_H);
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      ctx.textBaseline = 'middle';
      const vsPhrase = D.footers.talent.vs;
      const fSeg1 = D.footers.talent.pre;
      const fSeg3 = D.footers.talent.post;
      const fW1 = ctx.measureText(fSeg1).width;
      const fW2 = ctx.measureText(vsPhrase).width;
      const fW3 = ctx.measureText(fSeg3).width;
      let fx = (W - (fW1 + fW2 + fW3)) / 2;
      ctx.textAlign = 'left';
      ctx.fillStyle = FOOT_INK; ctx.fillText(fSeg1, fx, footY + FOOT_H / 2); fx += fW1;
      ctx.fillStyle = RED;      ctx.fillText(vsPhrase, fx, footY + FOOT_H / 2); fx += fW2;
      ctx.fillStyle = FOOT_INK; ctx.fillText(fSeg3, fx, footY + FOOT_H / 2);

      return canvas;
    }
    async function drawRatingCardHorizontal() {
      const BG      = '#EFEEE8';
      const SURFACE = '#FFFFFF';
      const SCALE   = 2;
      const W       = 1200;
      const H       = 680;

      // Hero is split: white name+chips strip on top, cream headshot+stats below
      const HDR_H     = 136;   // white strip: name + chips (taller for breathing room)
      const HERO_STAT = 174;   // cream strip: headshot + 3 big stats (slightly shorter)
      const HERO_H    = HDR_H + HERO_STAT;   // 310 total — same as V2
      const FOOTER_H  = 46;
      const METRICS_H = H - HERO_H - FOOTER_H;  // same as V2

      const canvas = document.createElement('canvas');
      canvas.width  = W * SCALE;
      canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      function pctTier(v) {
        if (v == null) return { color: '#888888' };
        if (v >= 85)   return { color: '#15803d' };
        if (v >= 70)   return { color: '#22a559' };
        if (v >= 40)   return { color: '#888888' };
        if (v >= 20)   return { color: '#e05c2d' };
        return               { color: '#E8002D'  };
      }

      // Full cream background
      ctx.fillStyle = BG;
      ctx.fillRect(0, 0, W, H);

      // ── WHITE STRIP: name + chips ─────────────────────────────────────────
      const PAD = 32;
      ctx.fillStyle = SURFACE;
      ctx.fillRect(0, 0, W, HDR_H);
      // 4px team-color left accent
      ctx.fillStyle = TEAM_C;
      ctx.fillRect(0, 0, 4, HDR_H);
      // Bottom border
      ctx.fillStyle = 'rgba(13,13,20,0.10)';
      ctx.fillRect(0, HDR_H - 1, W, 1);

      // Player name — large, left-aligned, vertically centered in top half
      const fullName = (D.firstName + ' ' + D.lastName).toUpperCase();
      let nfs = 64;
      ctx.font = `900 ${nfs}px "Barlow Condensed", sans-serif`;
      while (ctx.measureText(fullName).width > W * 0.65 && nfs > 32) {
        nfs -= 2;
        ctx.font = `900 ${nfs}px "Barlow Condensed", sans-serif`;
      }
      ctx.fillStyle = INK;
      ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(fullName, PAD, 46);

      // Chips row — match vertical card style: full team name, pos, season + brand right
      const TEAM_NAMES = {
        ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',
        BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',
        CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',
        DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',
        FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',
        MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',
        NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',
        PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',
        SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',
        TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',
        VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS',
      };
      const teamFull = TEAM_NAMES[D.team] || D.team;
      const chipH  = 28;
      const chipY0 = HDR_H - chipH - 14;
      const _numHoriz = D.sweaterNumber != null ? [{ label: `#${D.sweaterNumber}`,      bg: TEAM_C }] : [];
      const _ageChipH = D.ageAtSeason  != null ? [{ label: `AGE: ${D.ageAtSeason}`,    bg: INK    }] : [];
      const _scHoriz  = D.shootsCatches         ? [{ label: `SHOOTS: ${D.shootsCatches}`, bg: INK  }] : [];
      const chipDefs = [
        ..._numHoriz,
        { label: teamFull,                 bg: TEAM_C },
        { label: D.posLabel.toUpperCase(), bg: INK    },
        { label: D.currentSeason,          bg: INK    },
        ..._ageChipH,
        ..._scHoriz,
      ];
      ctx.font = '700 13px "Barlow Condensed", sans-serif';
      let cx = PAD;
      for (const chip of chipDefs) {
        const cw = ctx.measureText(chip.label).width + 22;
        rrect(ctx, cx, chipY0, cw, chipH, 3);
        ctx.fillStyle = chip.bg; ctx.fill();
        ctx.fillStyle = BG;
        ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chip.label, cx + 11, chipY0 + chipH / 2);
        cx += cw + 10;
      }
      // Brand chip right-aligned
      const brand = 'HOCKEYGAMEBOT';
      const bcw = ctx.measureText(brand).width + 22;
      rrect(ctx, W - PAD - bcw, chipY0, bcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(brand, W - PAD - bcw + 11, chipY0 + chipH / 2);

      // ── CREAM STRIP: headshot + 3 headline stats ──────────────────────────
      const STAT_TOP = HDR_H;
      const HS_R  = 72;
      const HS_CX = PAD + 4 + HS_R;  // flush with left accent
      const HS_CY = STAT_TOP + HERO_STAT / 2;
      const hsImg = await loadImg(D.headshotUrl);
      ctx.save();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, HS_R, 0, Math.PI * 2); ctx.clip();
      if (hsImg) {
        ctx.drawImage(hsImg, HS_CX - HS_R, HS_CY - HS_R, HS_R * 2, HS_R * 2);
      } else {
        ctx.fillStyle = '#dde2ee'; ctx.fill();
      }
      ctx.restore();
      ctx.beginPath(); ctx.arc(HS_CX, HS_CY, HS_R, 0, Math.PI * 2);
      ctx.strokeStyle = TEAM_C; ctx.lineWidth = 4; ctx.stroke();

      // Hero — mirrors the SEASON card: two BARE stat halves split by a thin
      // vertical divider, numbers directly on the cream (no surface boxes).
      // LEFT = Talent, RIGHT = Current WAR + Model View. Without talent_context
      // the Talent half centers across the full hero, no divider (fallback).
      const STAT_X = HS_CX + HS_R + 28;
      const heroTalentPct = D.hgb_rating_percentile;
      const priorTalentH = D.priorWar ?? [];
      const hasCtxPanelH = priorTalentH.length > 0;

      const HERO_SPAN = (W - STAT_X - PAD);
      const halfWH = hasCtxPanelH ? HERO_SPAN / 2 : HERO_SPAN;

      // Formats season string to short display label, e.g. "22-23".
      // Handles both "20222023" (8-digit) and "2022-23" (already normalized).
      function fmtSznH(s) {
        if (!s) return '';
        if (s.includes('-')) return s.slice(2,4) + '-' + s.slice(5,7);
        return s.slice(2,4) + '-' + s.slice(6,8);
      }

      // LEFT half — Talent (bare): big percentile, eyebrow above, subtitle below.
      // blockTop pinned to STAT_TOP + 14 — same anchor used by the right half.
      {
        const mid = STAT_X + halfWH / 2;
        const NUM_SIZE = 108;
        const LABEL_H = 20, GAP1 = 4, GAP2 = 14;
        const blockTop = STAT_TOP + 14;

        ctx.font = '700 15px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.72)';
        ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText('HGB TALENT', mid, blockTop);

        ctx.font = `800 ${NUM_SIZE}px "Barlow Condensed", sans-serif`;
        ctx.fillStyle = heroTalentPct != null ? TEAM_C : INK32;
        ctx.fillText(heroTalentPct != null ? String(heroTalentPct) + '%' : '—', mid, blockTop + LABEL_H + GAP1);

        ctx.font = '600 13px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.55)';
        ctx.fillText('Multi-Year Blended WAR', mid, blockTop + LABEL_H + GAP1 + NUM_SIZE + GAP2);
      }

      // RIGHT half — 3 prior seasons of Historical Talent, horizontal timeline.
      // oldest → newest left to right, arrows between, "TALENT HISTORY" eyebrow.
      if (hasCtxPanelH) {
        const L_RIGHT = STAT_X + halfWH;
        const rcx = L_RIGHT + halfWH / 2;
        ctx.fillStyle = INK10; ctx.fillRect(L_RIGHT, STAT_TOP + 26, 1, HERO_STAT - 52);

        // "PAST TALENT RATINGS" pinned to same top anchor as left "HGB TALENT".
        // No arrows — standalone season blocks avoid implying a causal trend line
        // (volatile profiles like Murphy read as "past model outputs", not "blend inputs").
        const EYEBROW_SZ = 15, eyebrowTop = STAT_TOP + 14;
        const SZN_SZ = 13, SZN_GAP = 8, NUM_SZ = 42;
        const colBlockH = SZN_SZ + SZN_GAP + NUM_SZ;
        const eyebrowBottom = eyebrowTop + EYEBROW_SZ;
        const stripBottom = STAT_TOP + HERO_STAT;
        const szn_y = eyebrowBottom + Math.max(8, (stripBottom - eyebrowBottom - colBlockH) / 2);
        const num_y = szn_y + SZN_SZ + SZN_GAP;

        ctx.font = '700 15px "Barlow", sans-serif';
        ctx.fillStyle = 'rgba(13,13,20,0.72)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
        ctx.fillText('PAST SINGLE-SEASON WAR', rcx, eyebrowTop);

        // 3 columns oldest→newest across the right half (padded 36px each side)
        const PAD_INNER = 36;
        const usable = halfWH - PAD_INNER * 2;
        const cols = priorTalentH.slice().reverse(); // oldest first = left
        const colCenters = cols.map((_, i) => L_RIGHT + PAD_INNER + usable * (i + 0.5) / cols.length);

        cols.forEach((entry, i) => {
          const cx = colCenters[i];
          // Season label
          ctx.font = '700 12px "Barlow", sans-serif';
          ctx.fillStyle = 'rgba(13,13,20,0.55)'; ctx.textBaseline = 'top'; ctx.textAlign = 'center';
          ctx.fillText(fmtSznH(entry.season), cx, szn_y);
          // Percentile number (no arrows between columns — avoids implying trend causality)
          ctx.font = `800 ${NUM_SZ}px "Barlow Condensed", sans-serif`;
          ctx.fillStyle = INK;
          ctx.fillText(String(entry.pct) + '%', cx, num_y);
        });
      }

      // ── METRICS GRID (exact copy from V2) ────────────────────────────────
      const MET_TOP  = HERO_H;
      const MET_PAD  = 26;
      const MET_PTOP = 20;
      const MET_PBOT = 14;
      const TILE_GAP = 12;
      const TILE_COLS = 5;
      const TILE_ROWS = 2;
      const TILE_H = Math.floor((METRICS_H - MET_PTOP - MET_PBOT - TILE_GAP * (TILE_ROWS - 1)) / TILE_ROWS);
      const TILE_W = (W - MET_PAD * 2 - TILE_GAP * (TILE_COLS - 1)) / TILE_COLS;

      const pct = D.percentiles;
      function v3h(a, b) { return a != null ? a : (b != null ? b : null); }
      const posPlural = D.posGroup === 'F' ? 'FORWARDS' : 'DEFENSEMEN';

      // 8 green/red skill tiles, then Finishing as its OWN blue tile, then the
      // Context tile (Opponent + Teammate Quality only → 2 values, no overflow).
      const gridCells = [
        { label: 'EV OFFENSE',       val: v3h(D.hgb_rating_off_pct, pct.ev_offence) },
        { label: 'EV DEFENSE',       val: v3h(D.hgb_rating_def_pct, pct.ev_defence) },
        { label: 'GOALS / 60',       val: v3h(D.g_60_pct_3yr, pct.goals)            },
        { label: 'A1 / 60',          val: v3h(D.a1_60_pct_3yr, pct.a1)              },
        { label: 'XG / 60',          val: v3h(D.xg_60_pct_3yr, pct.ixg)             },
        { label: 'PEN DIFF',         val: v3h(D.pen_diff_pct_3yr, pct.pen_diff)     },
        { label: 'POWER PLAY',       val: pct.pp_off ?? null                         },
        { label: 'PENALTY KILL',     val: pct.pk_def ?? null                         },
        { label: 'FINISHING',        val: v3h(D.finishing_pct_3yr, pct.finishing), isBlue: true },
        { isContext: true },
      ];

      const TILE_PAD = 22;
      for (let i = 0; i < gridCells.length; i++) {
        const col  = i % TILE_COLS;
        const row  = Math.floor(i / TILE_COLS);
        const tx   = MET_PAD + col * (TILE_W + TILE_GAP);
        const ty   = MET_TOP + MET_PTOP + row * (TILE_H + TILE_GAP);
        const cell = gridCells[i];
        // Finishing is a blue (context / read-with-caution) tile; all other
        // single-value tiles use the green/red heat scale.
        const tier = cell.isBlue ? { color: '#4285f4' } : pctTier(cell.val);

        rrect(ctx, tx, ty, TILE_W, TILE_H, 3);
        ctx.fillStyle = cell.isContext ? 'rgba(13,13,20,0.04)' : 'rgba(255,255,255,0.65)';
        ctx.fill();
        ctx.strokeStyle = 'rgba(13,13,20,0.13)'; ctx.lineWidth = 1; ctx.stroke();

        if (cell.isContext) {
          ctx.font = '700 17px "Barlow", sans-serif';
          ctx.fillStyle = 'rgba(13,13,20,0.65)';
          ctx.textBaseline = 'top'; ctx.textAlign = 'left';
          ctx.fillText('CONTEXT', tx + TILE_PAD, ty + 14);
          const ctxStats = [
            { label: 'OPPONENT QUALITY', val: D.qoc_pct_3yr ?? D.qoc },
            { label: 'TEAMMATE QUALITY', val: D.qot_pct_3yr ?? D.qot },
          ];
          const TITLE_H = 40;
          const ctxRowH = Math.floor((TILE_H - TITLE_H) / ctxStats.length);
          const bw = TILE_W - TILE_PAD * 2;
          ctxStats.forEach((s, si) => {
            const ry = ty + TITLE_H + si * ctxRowH;
            // Text row: label + pct share middle baseline, centered in upper 60% of row
            const textMid = ry + Math.round(ctxRowH * 0.38);
            const barY    = ry + Math.round(ctxRowH * 0.62);
            ctx.font = '700 12px "Barlow", sans-serif';
            ctx.fillStyle = 'rgba(13,13,20,0.55)';
            ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
            ctx.fillText(s.label, tx + TILE_PAD, textMid);
            if (s.val != null) {
              ctx.font = '900 24px "Barlow Condensed", sans-serif';
              ctx.fillStyle = '#4285f4';
              ctx.textBaseline = 'middle'; ctx.textAlign = 'right';
              ctx.fillText(Math.round(s.val) + '%', tx + TILE_W - TILE_PAD, textMid);
            }
            ctx.fillStyle = 'rgba(13,13,20,0.12)';
            ctx.fillRect(tx + TILE_PAD, barY, bw, 7);
            if (s.val != null) {
              ctx.fillStyle = '#4285f4';
              ctx.fillRect(tx + TILE_PAD, barY, (s.val / 100) * bw, 7);
            }
          });
        } else {
          ctx.font = '700 17px "Barlow", sans-serif';
          ctx.fillStyle = INK;
          ctx.textBaseline = 'top'; ctx.textAlign = 'left';
          ctx.fillText(cell.label, tx + TILE_PAD, ty + 14);
          if (cell.val != null) {
            ctx.font = '900 55px "Barlow Condensed", sans-serif';
            ctx.fillStyle = tier.color;
            ctx.textBaseline = 'top'; ctx.textAlign = 'left';
            ctx.fillText(String(Math.round(cell.val)) + '%', tx + TILE_PAD, ty + 44);
          } else {
            ctx.font = '900 42px "Barlow Condensed", sans-serif';
            ctx.fillStyle = 'rgba(13,13,20,0.38)';
            ctx.textBaseline = 'top'; ctx.textAlign = 'left';
            ctx.fillText('—', tx + TILE_PAD, ty + 48);
          }
          const barW = TILE_W - TILE_PAD * 2;
          const barY = ty + TILE_H - 22;
          ctx.fillStyle = 'rgba(13,13,20,0.12)';
          ctx.fillRect(tx + TILE_PAD, barY, barW, 12);
          if (cell.val != null) {
            ctx.fillStyle = tier.color;
            ctx.fillRect(tx + TILE_PAD, barY, (cell.val / 100) * barW, 12);
          }
        }
      }

      // ── FOOTER ───────────────────────────────────────────────────────────
      // Matches the portrait card; position phrase ("vs Forwards") in red.
      const footY = HERO_H + METRICS_H;
      ctx.fillStyle = 'rgba(13,13,20,0.07)';
      ctx.fillRect(0, footY, W, 1);
      ctx.font = '700 15px "Barlow Condensed", sans-serif';
      ctx.textBaseline = 'middle';
      const vsPhrase = D.footers.talent.vs;
      const fSeg1 = D.footers.talent.pre;
      const fSeg3 = D.footers.talent.post;
      const fW1 = ctx.measureText(fSeg1).width;
      const fW2 = ctx.measureText(vsPhrase).width;
      const fW3 = ctx.measureText(fSeg3).width;
      let fx = (W - (fW1 + fW2 + fW3)) / 2;
      ctx.textAlign = 'left';
      ctx.fillStyle = FOOT_INK; ctx.fillText(fSeg1, fx, footY + FOOTER_H / 2); fx += fW1;
      ctx.fillStyle = RED;      ctx.fillText(vsPhrase, fx, footY + FOOTER_H / 2); fx += fW2;
      ctx.fillStyle = FOOT_INK; ctx.fillText(fSeg3, fx, footY + FOOTER_H / 2);

      return canvas;
    }

    // ── canvas download — delegates to shared HGB_Export modal ──────────
    function showCardModal(canvas, filename) {
      window.HGB_Export.showCardModal(canvas, filename);
    }
    function downloadCanvas(canvas, filename) {
      window.HGB_Export.showCardModal(canvas, filename);
    }

    // ── RAPM z-score horizontal bar card ─────────────────────────────────────
    async function drawRapmCard() {
      const R = D.rapm;
      if (!R || R.ev_xgf60_z == null) throw new Error('No RAPM data for this player');

      const BG = '#EFEEE8', SURFACE = '#FFFFFF';
      const RED = '#CC0000', BAR_NEG = 'rgba(13,13,20,0.18)';
      const MUTED = 'rgba(13,13,20,0.45)', GRID = 'rgba(13,13,20,0.09)';
      const SCALE = 2, W = 780;
      const PAD = 36, LABEL_W = 76, VAL_W = 58;
      const CHART_L = PAD + LABEL_W, CHART_R = W - PAD - VAL_W;
      const CHART_W = CHART_R - CHART_L;
      const Z_MAX = 3, ZERO_X = CHART_L + CHART_W / 2;
      const PX_PER_Z = CHART_W / (Z_MAX * 2);
      const ROW_H = 52, AXIS_H = 32, SEC_H = 36;

      const evRows = [
        { label: 'GF/60',  z: R.ev_gf60_z  },
        { label: 'xGF/60', z: R.ev_xgf60_z },
        { label: 'xGA/60', z: R.ev_xga60_z },
        { label: 'CF/60',  z: R.ev_cf60_z  },
        { label: 'CA/60',  z: R.ev_ca60_z  },
      ].filter(r => r.z != null);
      const ppRows = [
        { label: 'GF/60',  z: R.pp_gf60_z  },
        { label: 'xGF/60', z: R.pp_xgf60_z },
        { label: 'CF/60',  z: R.pp_cf60_z  },
      ].filter(r => r.z != null);

      const HERO_H = 86; // 52 name row + 34 chip row, matches Rating Card
      const EV_H = SEC_H + evRows.length * ROW_H + AXIS_H;
      const PP_H = ppRows.length > 0 ? SEC_H + ppRows.length * ROW_H + AXIS_H + 20 : 0;
      const H = HERO_H + EV_H + PP_H + 28;

      const canvas = document.createElement('canvas');
      canvas.width = W * SCALE; canvas.height = H * SCALE;
      const ctx = canvas.getContext('2d');
      ctx.scale(SCALE, SCALE);

      const TEAM_C = D.teamColor || '#CC0000';
      const TEAM_NAMES_R = { ANA:'ANAHEIM DUCKS',BOS:'BOSTON BRUINS',BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SJS:'SAN JOSE SHARKS',SEA:'SEATTLE KRAKEN',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS' };
      const teamFull = TEAM_NAMES_R[D.team] || D.team;

      // ── Background ──
      ctx.fillStyle = BG; ctx.fillRect(0, 0, W, H);

      // ── Hero: white band + 4px team accent (matches Rating Card) ──
      ctx.fillStyle = SURFACE; ctx.fillRect(0, 0, W, HERO_H);
      ctx.fillStyle = TEAM_C; ctx.fillRect(0, 0, 4, HERO_H);

      // Name row
      const fn = D.firstName && D.lastName ? `${D.firstName} ${D.lastName}` : (D.firstName || '');
      ctx.font = '800 24px "Barlow Condensed", sans-serif';
      ctx.fillStyle = '#0D0D14'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(fn.toUpperCase(), PAD, HERO_H / 2 - 12);

      // Chips row
      const chipH = 18, chipY0 = HERO_H / 2 + 4;
      const _numRapm = D.sweaterNumber != null ? [`#${D.sweaterNumber}`] : [];
      const _scRapm  = D.shootsCatches ? [`SHOOTS: ${D.shootsCatches}`] : [];
      const chips = [..._numRapm, teamFull, D.posLabel ? D.posLabel.toUpperCase() : D.pos, D.currentSeason, 'REG SEASON', ..._scRapm];
      const _tcRapm = 1 + _numRapm.length;
      let cx2 = PAD;
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      chips.forEach((chip, ci) => {
        const tw = ctx.measureText(chip).width, cw = tw + 18;
        rrect(ctx, cx2, chipY0, cw, chipH, 3);
        ctx.fillStyle = ci < _tcRapm ? TEAM_C : '#0D0D14'; ctx.fill();
        ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
        ctx.fillText(chip, cx2 + 9, chipY0 + chipH / 2);
        cx2 += cw + 8;
      });
      // RAPM label pill right-aligned
      const rapmLabel = ppRows.length > 0 ? 'EV & PP RAPM' : 'EV RAPM';
      ctx.font = '700 9px "Barlow Condensed", sans-serif';
      const rtw = ctx.measureText(rapmLabel).width, rcw = rtw + 18;
      rrect(ctx, W - PAD - rcw, chipY0, rcw, chipH, 3);
      ctx.fillStyle = RED; ctx.fill();
      ctx.fillStyle = BG; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(rapmLabel, W - PAD - rcw + 9, chipY0 + chipH / 2);

      // Bottom border
      ctx.fillStyle = 'rgba(13,13,20,0.08)'; ctx.fillRect(0, HERO_H - 1, W, 1);

      function drawSection(label, rows, toi, yStart) {
        // Section header
        ctx.textAlign = 'left';
        ctx.font = '800 13px "Barlow Condensed", sans-serif'; ctx.fillStyle = RED;
        ctx.fillText(label.toUpperCase(), PAD, yStart + 24);
        if (toi != null) {
          ctx.textAlign = 'right';
          ctx.font = '400 10px "JetBrains Mono", monospace'; ctx.fillStyle = MUTED;
          ctx.fillText(`${label === 'Even Strength' ? 'EV' : 'PP'} TOI: ${toi.toFixed(1)} min`, W - PAD, yStart + 24);
        }

        const chartTop = yStart + SEC_H;

        // Chart bg + gridlines
        ctx.fillStyle = SURFACE; ctx.fillRect(CHART_L, chartTop, CHART_W, rows.length * ROW_H);
        [-3,-2,-1,0,1,2,3].forEach(v => {
          const x = Math.round(ZERO_X + v * PX_PER_Z) + 0.5;
          ctx.beginPath(); ctx.strokeStyle = v === 0 ? 'rgba(13,13,20,0.22)' : GRID;
          ctx.lineWidth = v === 0 ? 1.5 : 1;
          ctx.setLineDash(v === 0 ? [5, 4] : []);
          ctx.moveTo(x, chartTop); ctx.lineTo(x, chartTop + rows.length * ROW_H);
          ctx.stroke(); ctx.setLineDash([]);
        });

        // Row separators
        rows.forEach((_, i) => {
          if (i > 0) { ctx.fillStyle = GRID; ctx.fillRect(CHART_L, chartTop + i * ROW_H, CHART_W, 1); }
        });

        // Bars + labels + values
        rows.forEach((r, i) => {
          const cy = chartTop + i * ROW_H + ROW_H / 2;
          const z = Math.max(-3, Math.min(3, r.z));
          const barW = Math.abs(z) * PX_PER_Z;
          const barX = z >= 0 ? ZERO_X : ZERO_X - barW;
          const barH = ROW_H * 0.42;

          ctx.fillStyle = z >= 0 ? TEAM_C : BAR_NEG;
          ctx.fillRect(barX, cy - barH / 2, barW, barH);

          // Metric label — Barlow Condensed at ≥12px, JetBrains Mono only for tiny text
          ctx.textAlign = 'right'; ctx.fillStyle = MUTED;
          ctx.font = '600 12px "Barlow Condensed", sans-serif';
          ctx.fillText(r.label, CHART_L - 10, cy + 5);

          // Value — bold, larger
          const sign = r.z >= 0 ? '+' : '';
          ctx.textAlign = 'left';
          ctx.fillStyle = r.z >= 0 ? TEAM_C : MUTED;
          ctx.font = '700 13px "Barlow Condensed", sans-serif';
          ctx.fillText(`${sign}${r.z.toFixed(2)}`, CHART_R + 10, cy + 5);
        });

        // Axis numbers — JetBrains Mono (numeric data, small)
        const axisY = chartTop + rows.length * ROW_H + 20;
        ctx.font = '400 10px "JetBrains Mono", monospace'; ctx.fillStyle = MUTED; ctx.textAlign = 'center';
        [-3,-2,-1,0,1,2,3].forEach(v => {
          ctx.fillText(String(v), ZERO_X + v * PX_PER_Z, axisY);
        });
      }

      let y = HERO_H + 6;
      drawSection('Even Strength', evRows, R.ev_toi, y);
      y += SEC_H + evRows.length * ROW_H + AXIS_H + 16;
      if (ppRows.length > 0) drawSection('Power Play', ppRows, R.pp_toi, y);

      return canvas;
    }

    function bindCardBtn(id, label, drawFn, filename, sizeLabel = '560px · 2× retina PNG') {
      const b = document.getElementById(id);
      if (!b) return;
      b.addEventListener('click', async () => {
        b.textContent = 'Generating…'; b.disabled = true;
        status.textContent = 'Drawing…';
        try {
          if (document.fonts) {
            await document.fonts.ready;
            await Promise.all([
              document.fonts.load('900 1px "Barlow Condensed"'),
              document.fonts.load('700 1px "JetBrains Mono"'),
              document.fonts.load('600 1px "Barlow"'),
            ]);
          }
          const canvas = await drawFn();
          if (canvas == null) return; // draw fn handled its own modal (e.g. carousel)
          downloadCanvas(canvas, filename);
          status.textContent = 'Downloaded ✓';
          setTimeout(() => { status.textContent = sizeLabel; }, 3000);
        } catch (e) {
          console.error(e);
          status.textContent = 'Error — try again';
        } finally {
          b.textContent = label; b.disabled = false;
        }
      });
    }

    // Season WAR card — season-aware binding (season can change via row click)
    (() => {
      let _selectedSeason = D.currentSeason ?? '2025-26';
      // Earliest season with NHL EDGE data (launched 2021-22) — drives the availability note
      const _edgeSeasons = D.edgeHistory ? Object.keys(D.edgeHistory).sort() : [];
      const _earliestEdge = _edgeSeasons.length ? _edgeSeasons[0] : null;
      const _edgeNote = document.getElementById('edge-availability-note');
      function _updateEdgeNote() {
        if (!_edgeNote) return;
        const hasEdge = D.edgeHistory ? !!D.edgeHistory[_selectedSeason] : (_selectedSeason === D.currentSeason);
        if (!hasEdge && _earliestEdge) {
          _edgeNote.textContent = `* NHL EDGE tracking data available from ${_earliestEdge} onward — the ${_selectedSeason} card shows season stats only.`;
          _edgeNote.style.display = 'block';
        } else {
          _edgeNote.style.display = 'none';
        }
      }
      document.addEventListener('hgb:season-select', function(e) { _selectedSeason = e.detail?.season ?? _selectedSeason; _updateEdgeNote(); });
      _updateEdgeNote();
      const btn = document.getElementById('download-season-card-btn');
      const status = document.getElementById('card-status');
      if (btn) btn.addEventListener('click', async function() {
        const label = btn.textContent ?? '';
        btn.textContent = 'Generating…'; btn.disabled = true;
        if (status) status.style.display = 'block';
        try {
          if (document.fonts) {
            await document.fonts.ready;
            await Promise.all([
              document.fonts.load('900 1px "Barlow Condensed"'),
              document.fonts.load('700 1px "JetBrains Mono"'),
              document.fonts.load('600 1px "Barlow"'),
            ]);
          }
          // Player Card carousel: Season (Edge) + Shotmap in one modal.
          const [seasonCanvas, shotmapCanvas] = await Promise.all([
            drawSeasonCard(_selectedSeason),
            drawShotmapCard(),
          ]);
          window.HGB_Export.showCardModal([
            { canvas: seasonCanvas,  filename: `hgb_season_${D.slug}_${_selectedSeason}.png`,          label: 'Season Card'  },
            { canvas: shotmapCanvas, filename: `hgb_shotmap_${D.slug}_${D.currentSeason || '2025-26'}.png`, label: 'Shotmap Card' },
          ]);
          if (status) { status.style.display = 'none'; }
        } catch(err) { console.error(err); if (status) status.textContent = 'Error — try again'; }
        finally { btn.textContent = label; btn.disabled = false; }
      });
    })();

    // ── Player Talent Card carousel — Talent+Shotmap (new) + Talent 5×2 grid ─
    bindCardBtn(
      'download-rating-card-btn',
      'Player Talent Card →',
      async function() {
        // Draw the horizontal Talent+Shotmap card + the 5×2 social grid; modal
        // gets the arrow carousel automatically. Portrait card intentionally dropped.
        const [talentShotmap, socialV3] = await Promise.all([drawTalentShotmapCard(), drawRatingCardHorizontal()]);
        window.HGB_Export.showCardModal([
          { canvas: talentShotmap, filename: `hgb_talent_shotmap_${D.slug}_25-26.png`, label: 'Talent + Shotmap' },
          { canvas: socialV3,      filename: `hgb_social_${D.slug}_25-26.png`,         label: 'Social 1200×680' },
        ]);
        // Return null so bindCardBtn skips its own modal call
        return null;
      },
      null,
      '1040×auto + 1200×628 · 2× retina PNG'
    );
    bindCardBtn('download-rapm-card-btn',   'RAPM Card →',     drawRapmCard,          `hgb_rapm_${D.slug}_25-26.png`,   '760px · 2× retina PNG');
    bindCardBtn('download-history-card-btn','History Card →',  drawHistoryCard,       `hgb_history_${D.slug}.png`,      '560×auto · 2× retina PNG');
  })();

  // ── HISTORY CARD draw function ─────────────────────────────────────────────
  // Defined outside the main IIFE so it can reference _seasonStats + _card.
  async function drawHistoryCard() {
    const D = _card;
    const seasons = _seasonStats; // sorted descending by season

    const INK    = '#0D0D14';
    const RED    = '#E8002D';
    const INK06  = 'rgba(13,13,20,0.06)';
    const INK10  = 'rgba(13,13,20,0.10)';
    const INK14  = 'rgba(13,13,20,0.14)';
    const INK32  = 'rgba(13,13,20,0.32)';
    const INK48  = 'rgba(13,13,20,0.48)';
    const FOOT_INK = 'rgba(13,13,20,0.55)';
    const TEAM_C = D.teamColor || INK;

    function tierColor(val) {
      if (val == null) return INK32;
      if (val >= 70) return '#137333';
      if (val <= 30) return '#E8002D';
      return INK48;
    }

    const SCALE = 2;
    const W = 560;
    const PAD = 28;

    // Header: 52px name + 34px chips = 86px
    const HDR_H  = 52;
    const CHIP_H = 34;
    const HERO_H = 88;  // 3-tile hero: HGB RATING | HGB WAR | HGB IMPACT
    const SEP_H  = 1;
    const COL_H  = 36;  // column headers
    const ROW_H  = 36;  // each season row
    const FOOT_H = 36;

    const displaySeasons = seasons.slice(0, 10);
    const N = displaySeasons.length;

    const TOTAL_H = HDR_H + CHIP_H + HERO_H + SEP_H + COL_H + N * ROW_H + FOOT_H;

    const canvas = document.createElement('canvas');
    canvas.width  = W * SCALE;
    canvas.height = TOTAL_H * SCALE;
    const ctx = canvas.getContext('2d');
    ctx.scale(SCALE, SCALE);

    // ── Background (light card — cream editorial style) ─────────────────
    ctx.fillStyle = '#EFEEE8';
    ctx.fillRect(0, 0, W, TOTAL_H);

    // 4px left accent bar (team color, full height)
    ctx.fillStyle = TEAM_C;
    ctx.fillRect(0, 0, 4, TOTAL_H);

    let y = 0;

    // ── HEADER (white band) ─────────────────────────────────────────────
    ctx.fillStyle = '#FFFFFF';
    ctx.fillRect(0, y, W, HDR_H + CHIP_H);
    // Bottom border of header
    ctx.fillStyle = INK14;
    ctx.fillRect(0, y + HDR_H + CHIP_H - 1, W, 1);

    // Player name
    ctx.font = '800 24px "Barlow Condensed", sans-serif';
    ctx.fillStyle = INK;
    ctx.textBaseline = 'middle';
    ctx.textAlign = 'left';
    ctx.fillText((D.firstName + ' ' + D.lastName).toUpperCase(), PAD, y + HDR_H / 2);
    // "SEASON HISTORY" label right-aligned
    ctx.font = '700 10px "JetBrains Mono", monospace';
    ctx.fillStyle = TEAM_C;
    ctx.textAlign = 'right';
    ctx.fillText('SEASON HISTORY', W - PAD, y + HDR_H / 2);
    y += HDR_H;

    // Chips row
    const chipH = 18;
    const chipY0 = y + (CHIP_H - chipH) / 2;
    const TEAM_NAMES_H = { ANA:'ANAHEIM DUCKS',ARI:'ARIZONA COYOTES',BOS:'BOSTON BRUINS',BUF:'BUFFALO SABRES',CGY:'CALGARY FLAMES',CAR:'CAROLINA HURRICANES',CHI:'CHICAGO BLACKHAWKS',COL:'COLORADO AVALANCHE',CBJ:'COLUMBUS BLUE JACKETS',DAL:'DALLAS STARS',DET:'DETROIT RED WINGS',EDM:'EDMONTON OILERS',FLA:'FLORIDA PANTHERS',LAK:'LOS ANGELES KINGS',MIN:'MINNESOTA WILD',MTL:'MONTREAL CANADIENS',NSH:'NASHVILLE PREDATORS',NJD:'NEW JERSEY DEVILS',NYI:'NEW YORK ISLANDERS',NYR:'NEW YORK RANGERS',OTT:'OTTAWA SENATORS',PHI:'PHILADELPHIA FLYERS',PIT:'PITTSBURGH PENGUINS',SEA:'SEATTLE KRAKEN',SJS:'SAN JOSE SHARKS',STL:'ST. LOUIS BLUES',TBL:'TAMPA BAY LIGHTNING',TOR:'TORONTO MAPLE LEAFS',UTA:'UTAH HOCKEY CLUB',VAN:'VANCOUVER CANUCKS',VGK:'VEGAS GOLDEN KNIGHTS',WSH:'WASHINGTON CAPITALS',WPG:'WINNIPEG JETS' };
    const teamFull = TEAM_NAMES_H[D.team] || D.team;
    const _numLast = D.sweaterNumber != null ? [`#${D.sweaterNumber}`] : [];
    const _scLast  = D.shootsCatches ? [`SHOOTS: ${D.shootsCatches}`] : [];
    const chips = [..._numLast, teamFull, (D.posLabel || D.pos).toUpperCase(), ..._scLast];
    const _tcLast = 1 + _numLast.length;
    let cx = PAD;
    ctx.font = '700 9px "Barlow Condensed", sans-serif';
    for (let ci = 0; ci < chips.length; ci++) {
      const tw = ctx.measureText(chips[ci]).width;
      const cw = tw + 18;
      ctx.beginPath(); ctx.roundRect(cx, chipY0, cw, chipH, 3);
      ctx.fillStyle = ci < _tcLast ? TEAM_C : INK;
      ctx.fill();
      ctx.fillStyle = '#FFFFFF';
      ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(chips[ci], cx + 9, chipY0 + chipH / 2);
      cx += cw + 8;
    }
    const brand = 'HOCKEYGAMEBOT';
    const btw = ctx.measureText(brand).width;
    const bcw = btw + 18;
    ctx.beginPath(); ctx.roundRect(W - PAD - bcw, chipY0, bcw, chipH, 3);
    ctx.fillStyle = RED; ctx.fill();
    ctx.fillStyle = '#FFFFFF'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
    ctx.fillText(brand, W - PAD - bcw + 9, chipY0 + chipH / 2);
    y += CHIP_H;

    // ── HERO ROW — exact same pattern as Rating Card: headshot + 3 stat tiles ──
    const heroR = 38, hsCX = PAD + heroR, hsCY = y + HERO_H / 2;
    const hsImgH = await (function li(src) {
      return new Promise(res => { const i = new Image(); i.crossOrigin='anonymous'; i.onload=()=>res(i); i.onerror=()=>res(null); i.src=src; });
    })(D.headshotUrl);
    ctx.save(); ctx.beginPath(); ctx.arc(hsCX, hsCY, heroR, 0, Math.PI*2); ctx.clip();
    if (hsImgH) {
      ctx.drawImage(hsImgH, hsCX-heroR, hsCY-heroR, heroR*2, heroR*2);
    } else {
      ctx.fillStyle = INK10; ctx.fill();
      ctx.font = '800 24px "Barlow Condensed",sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline='middle'; ctx.textAlign='center';
      ctx.fillText((D.firstName[0]+D.lastName[0]).toUpperCase(), hsCX, hsCY);
    }
    ctx.restore();
    ctx.beginPath(); ctx.arc(hsCX, hsCY, heroR, 0, Math.PI*2);
    ctx.strokeStyle = TEAM_C; ctx.lineWidth = 2; ctx.stroke();

    // 3 stat tiles to the right of headshot
    const statX = hsCX + heroR + 18;
    const statW = (W - statX - PAD) / 3;
    const ratingPctVal = D.hgb_rating_percentile ?? null;
    const warPctVal  = D.warPct ?? Math.round(D.impactPct);
    const impPctVal  = Math.round(D.impactPct);
    // Percentile-only heroes (raw value subtitles dropped, matching Season/Talent cards).
    const heroStats  = [
      { label: 'HGB TALENT',      big: ratingPctVal != null ? ratingPctVal+'%' : '—' },
      { label: 'HGB WAR',         big: warPctVal+'%' },
      { label: 'HGB GAME IMPACT', big: impPctVal+'%' },
    ];
    for (let i = 0; i < heroStats.length; i++) {
      const hs = heroStats[i];
      const sx = statX + i * statW + statW / 2;
      if (i > 0) { ctx.fillStyle = INK10; ctx.fillRect(statX + i*statW, y+14, 1, HERO_H-28); }
      ctx.font = '700 9px "Barlow Condensed",sans-serif';
      ctx.fillStyle = INK32; ctx.textBaseline='top'; ctx.textAlign='center';
      ctx.fillText(hs.label, sx, y+14);
      ctx.font = '800 30px "Barlow Condensed",sans-serif';
      ctx.fillStyle = TEAM_C; ctx.textBaseline='top';
      ctx.fillText(hs.big, sx, y+27);
    }
    ctx.fillStyle = INK14; ctx.fillRect(0, y+HERO_H-1, W, 1);
    y += HERO_H;

    // separator
    ctx.fillStyle = INK10;
    ctx.fillRect(0, y, W, SEP_H);
    y += SEP_H;

    // ── COLUMN HEADERS ───────────────────────────────────────────────────
    // Season column is left-aligned; the three value columns are evenly spaced
    // and centered (header + cell share the same center x).
    const SEASON_W = 120;            // width reserved for the SEASON column
    const COL1_X   = PAD;            // SEASON label (left-aligned)
    const VAL_AREA = W - PAD - (PAD + SEASON_W);
    const VAL_COL_W = VAL_AREA / 4;
    const VAL_CX_0  = PAD + SEASON_W + VAL_COL_W / 2;  // center x of first value col
    const valCenterX = (i) => VAL_CX_0 + i * VAL_COL_W;

    ctx.font = '700 10px "JetBrains Mono", monospace';
    ctx.fillStyle = INK32;
    ctx.textBaseline = 'middle';
    ctx.textAlign = 'left';
    ctx.fillText('SEASON', COL1_X, y + COL_H / 2);
    ctx.textAlign = 'center';
    ['WAR', 'IMPACT', 'GF%', 'xGF%'].forEach((label, i) => {
      ctx.fillText(label, valCenterX(i), y + COL_H / 2);
    });
    // header bottom border
    ctx.fillStyle = INK10;
    ctx.fillRect(0, y + COL_H - 1, W, 1);
    y += COL_H;

    // ── SEASON ROWS ──────────────────────────────────────────────────────
    for (let ri = 0; ri < displaySeasons.length; ri++) {
      const s = displaySeasons[ri];
      const ry = y + ri * ROW_H;
      const rowY = ry + ROW_H / 2;

      // alternating subtle row background
      if (ri % 2 === 0) {
        ctx.fillStyle = INK06;
        ctx.fillRect(0, ry, W, ROW_H);
      }

      // Highlight current season (most recent = first row) — background only, no bar
      if (ri === 0) {
        ctx.fillStyle = `rgba(${parseInt(TEAM_C.slice(1,3)||'0',16)},${parseInt(TEAM_C.slice(3,5)||'0',16)},${parseInt(TEAM_C.slice(5,7)||'0',16)},0.08)`;
        ctx.fillRect(0, ry, W, ROW_H);
      }

      // row bottom border
      ctx.fillStyle = INK06;
      ctx.fillRect(0, ry + ROW_H - 1, W, 1);

      // Season label (e.g. "2025-26")
      const seasonLabel = s.season ? s.season.replace('-', '–') : '—';
      ctx.font = ri === 0 ? '700 12px "JetBrains Mono", monospace' : '500 12px "JetBrains Mono", monospace';
      ctx.fillStyle = ri === 0 ? INK : INK48;
      ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      ctx.fillText(seasonLabel, COL1_X, rowY);

      // GP sub-label
      if (s.gp != null) {
        ctx.font = '400 9px "JetBrains Mono", monospace';
        ctx.fillStyle = INK32;
        ctx.textAlign = 'left';
        ctx.fillText(s.gp + ' GP', COL1_X + 56, rowY);
      }

      // Percentile cell — color by tier (WAR, IMPACT).
      function drawPctCell(centerX, val) {
        const displayVal = val != null ? Math.round(val) + '%' : '—';
        const color = val != null ? tierColor(val) : INK32;
        ctx.font = val != null ? '700 13px "JetBrains Mono", monospace' : '400 13px "JetBrains Mono", monospace';
        ctx.fillStyle = color;
        ctx.textAlign = 'center';
        ctx.fillText(displayVal, centerX, rowY);
      }
      // Raw on-ice % cell — color relative to 50% midpoint (GF%, xGF%).
      function drawOnIcePctCell(centerX, val) {
        if (val == null) {
          ctx.font = '400 13px "JetBrains Mono", monospace';
          ctx.fillStyle = INK32; ctx.textAlign = 'center';
          ctx.fillText('—', centerX, rowY);
          return;
        }
        const color = val >= 52 ? '#15803d' : val >= 48 ? '#888888' : '#E8002D';
        ctx.font = '700 13px "JetBrains Mono", monospace';
        ctx.fillStyle = color; ctx.textAlign = 'center';
        ctx.fillText(val.toFixed(1) + '%', centerX, rowY);
      }

      drawPctCell(valCenterX(0), s.war_pct);
      drawPctCell(valCenterX(1), s.impact_pct);
      drawOnIcePctCell(valCenterX(2), s.gf_pct);
      drawOnIcePctCell(valCenterX(3), s.xgf_pct);
    }

    y += N * ROW_H;

    // ── FOOTER ──────────────────────────────────────────────────────────
    ctx.fillStyle = INK06;
    ctx.fillRect(0, y, W, FOOT_H);
    ctx.font = '700 8px "Barlow Condensed", sans-serif';
    ctx.fillStyle = FOOT_INK;
    ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
    ctx.fillText(D.footers.history, W / 2, y + FOOT_H / 2);

    return canvas;
  }

</script>

<script>
  // ── Shot map view toggle ─────────────────────────────────────────────────
  (function() {
    const btns = document.querySelectorAll('.sm-toggle-btn');
    const scatter = document.getElementById('sm-view-scatter');
    const heatmap = document.getElementById('sm-view-heatmap');
    if (!btns.length) return;
    btns.forEach(btn => {
      btn.addEventListener('click', function() {
        if (this.disabled) return;
        btns.forEach(b => b.classList.remove('sm-toggle-active'));
        this.classList.add('sm-toggle-active');
        const view = this.dataset.view;
        if (scatter) scatter.style.display = view === 'scatter' ? '' : 'none';
        if (heatmap) heatmap.style.display = view === 'heatmap' ? '' : 'none';
      });
    });
  })();

  // ── SEASON / RATING·3yr toggle ─────────────────────────────────────────
  // Drives the unified PERCENTILE PROFILE card. All bars (EV Offence/Defence
  // + counting stats) live in #pct-profile-card. In RATING·3yr mode:
  //   • RAPM bars  → hgb_rating_off/def_pct (data-rating-val on [data-bar-key])
  //   • Counting bars → 3yr weighted percentiles + 3yr raw rate
  (function() {
    function tierColor(val, isBlue, isRed) {
      if (val >= 75) return isBlue ? '#4285f4' : isRed ? '#842029' : '#137333';
      if (val >= 50) return isBlue ? '#7baaf7' : isRed ? '#c03244' : '#34a853';
      if (val >= 25) return 'rgba(13,13,20,0.32)';
      return '#E8002D';
    }

    function updateBar(row, isRating, opts) {
      const isBlue    = row.dataset.isBlue === 'true';
      const isRed     = row.dataset.isRed === 'true';
      const seasonVal = parseFloat(row.dataset.seasonVal ?? '0');
      const ratingRaw = row.dataset.ratingVal;
      const hasRating = ratingRaw !== '' && ratingRaw != null;

      const val    = (isRating && hasRating) ? parseFloat(ratingRaw) : seasonVal;
      const isNull = isRating && !hasRating;

      const fill  = row.querySelector('.pct-fill');
      const pctEl = row.querySelector('.pct-pct');

      // Swap the raw rate column for counting-stat bars between season / 3yr.
      if (opts && opts.swapRate) {
        const rateEl = row.querySelector('.pct-rate');
        if (rateEl) {
          const seasonRate = row.dataset.seasonRate;
          const ratingRate = row.dataset.ratingRate;
          if (isRating) {
            rateEl.textContent = (ratingRate !== '' && ratingRate != null) ? ratingRate : '—';
          } else {
            rateEl.textContent = (seasonRate !== '' && seasonRate != null) ? seasonRate : '—';
          }
        }
      }

      if (isNull) {
        if (fill)  { fill.style.width = '0%'; fill.style.background = 'rgba(13,13,20,0.14)'; }
        if (pctEl) { pctEl.textContent = '—'; pctEl.style.color = 'rgba(13,13,20,0.32)'; }
      } else {
        const color = tierColor(val, isBlue, isRed);
        if (fill)  { fill.style.width = val.toFixed(1) + '%'; fill.style.background = color; }
        if (pctEl) { pctEl.textContent = Math.round(val) + '%'; pctEl.style.color = color; }
      }
    }

    function applyRapmMode(mode) {
      const isRating = mode === 'rating';

      document.querySelectorAll<HTMLElement>('#rapm-mode-filter button').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.rapmMode === mode);
      });

      // RAPM bars (EV Offence / Defence — identified by data-bar-key)
      document.querySelectorAll<HTMLElement>('#pct-profile-card .pct-row[data-bar-key]').forEach(row => {
        const suffix = row.querySelector<HTMLElement>('.rapm-bar-3yr-suffix');
        if (suffix) suffix.style.display = isRating ? 'inline' : 'none';
        // Hide the single-season RAPM note when in HGB RATING mode
        const seasonNote = row.querySelector<HTMLElement>('.rapm-bar-season-note');
        if (seasonNote) seasonNote.style.display = isRating ? 'none' : '';
        updateBar(row, isRating, null);
      });

      // Counting-stat bars (identified by data-rate-key) — also swap raw rate
      document.querySelectorAll('#pct-profile-card .pct-row[data-rate-key]').forEach(row => {
        updateBar(row, isRating, { swapRate: true });
      });
    }

    document.querySelectorAll<HTMLElement>('#rapm-mode-filter button').forEach(btn => {
      btn.addEventListener('click', () => applyRapmMode(btn.dataset.rapmMode));
    });
  })();

  // Similar Players WAR / Rating toggle
  (() => {
    const filter = document.getElementById('peers-mode-filter');
    if (!filter) return;
    filter.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.peersMode;
        filter.querySelectorAll('button').forEach(b => b.classList.toggle('active', b === btn));
        document.getElementById('peers-war').style.display    = mode === 'war'    ? '' : 'none';
        document.getElementById('peers-rating').style.display = mode === 'rating' ? '' : 'none';
      });
    });
  })();

  // ── Season selector — drives EV Offense/Defense RAPM bars ─────────────────
  // When the user clicks a season row in the career stats table (dispatched as
  // a custom event), or in the history card table, we update the SEASON tab EV
  // bars to reflect that season's single-season RAPM percentiles.
  (() => {
    // _seasonStats and _evOffFallback / _evDefFallback come from define:vars above
    // (they are globals serialized into this script's scope by Astro).
    const seasonMap = {};
    // _seasonStats is injected by define:vars into the inline script block above.
    // Access via window to cross the module boundary safely.
    ((typeof _seasonStats !== 'undefined' ? _seasonStats : (window as any)._seasonStats) || [])
      .forEach((s: any) => { seasonMap[s.season] = s; });

    // Current RAPM mode — we only update EV bars in SEASON mode
    let currentRapmMode = 'season';
    document.querySelectorAll('#rapm-mode-filter button').forEach(btn => {
      btn.addEventListener('click', () => {
        currentRapmMode = btn.dataset.rapmMode || 'season';
      });
    });

    function tierColor(val, isBlue) {
      if (val >= 75) return isBlue ? '#4285f4' : '#137333';
      if (val >= 50) return isBlue ? '#7baaf7' : '#34a853';
      if (val >= 25) return 'rgba(13,13,20,0.32)';
      return '#E8002D';
    }

    // Apply a season's RAPM data to the EV bars (SEASON mode only)
    function applySeasonToEvBars(seasonStr) {
      const entry = seasonMap[seasonStr];
      const _off = typeof _evOffFallback !== 'undefined' ? _evOffFallback : (window as any)._evOffFallback ?? 50;
      const _def = typeof _evDefFallback !== 'undefined' ? _evDefFallback : (window as any)._evDefFallback ?? 50;
      const offVal = (entry?.rapm_off_pct != null) ? entry.rapm_off_pct : _off;
      const defVal = (entry?.rapm_def_pct != null) ? entry.rapm_def_pct : _def;

      document.querySelectorAll('#pct-profile-card .pct-row[data-bar-key]').forEach(row => {
        const key    = row.dataset.barKey;
        const isBlue = row.dataset.isBlue === 'true';
        const val    = key === 'ev_offence' ? offVal : defVal;

        // Update data-season-val for future mode toggles
        row.dataset.seasonVal = val.toFixed(1);

        // Only update DOM if currently in SEASON mode
        if (currentRapmMode !== 'season') return;

        const fill  = row.querySelector('.pct-fill');
        const pctEl = row.querySelector('.pct-pct');
        const color = tierColor(val, isBlue);
        if (fill)  { fill.style.width = val.toFixed(1) + '%'; fill.style.background = color; }
        if (pctEl) { pctEl.textContent = Math.round(val) + '%'; pctEl.style.color = color; }
      });
    }

    // Listen for season selection events dispatched by the career table.
    // React (PlayerCareerTable) owns its own row highlight via activeSeason state.
    // This handler only needs to update the EV bars.
    document.addEventListener('hgb:season-select', (e) => {
      const season = e.detail?.season;
      if (!season) return;
      const btn = document.getElementById('download-season-card-btn');
      if (btn) btn.textContent = `${season} Player Card →`;
      // NOTE: the standalone shotmap button was folded into the Player Card
      // carousel; only the availability note remains season-reactive.
      const smNote = document.getElementById('shotmap-availability-note');
      if (smNote) {
        const [startYr, endSuffix] = season.split(/[-–]/);
        const seasonRaw = startYr + startYr.slice(0, 2) + endSuffix.padStart(2, '0');
        const url = `https://media.hockeygamebot.com/stats/skater-shot-maps/skater_shot_map_${_card.playerId}_${seasonRaw}_5v5.png`;
        fetch(url, { method: 'HEAD' }).then(r => {
          smNote.style.display = r.ok ? 'none' : 'block';
        }).catch(() => { smNote.style.display = 'block'; });
      }
      try { applySeasonToEvBars(season); } catch(err) {}
    });
  })();

  // Impact trend chart — dot hover tooltips
  const tip = document.getElementById('imp-tip');
  if (tip) {
    document.querySelectorAll<HTMLElement>('.impact-dot').forEach(dot => {
      dot.addEventListener('mouseenter', e => {
        const me = e as MouseEvent;
        const val = parseFloat(dot.dataset.val ?? '0');
        const tipText = dot.dataset.tip ?? '';
        // Split "2025-10-30 vs NYR · -0.69" into context + value
        const parts = tipText.split(' · ');
        const ctx = parts.slice(0, -1).join(' · ');
        const valStr = parts[parts.length - 1];
        const valColor = val >= 0 ? '#1a7a3e' : '#E8002D';
        tip.innerHTML = `<span class="tip-ctx">${ctx}</span><span class="tip-val" style="color:${valColor}">${valStr}</span>`;
        tip.style.display = 'block';
        const x = me.clientX + 12, y = me.clientY - 28;
        tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? me.clientX - tip.offsetWidth - 8 : x) + 'px';
        tip.style.top  = Math.max(4, y) + 'px';
      });
      dot.addEventListener('mousemove', e => {
        const mm = e as MouseEvent;
        const x = mm.clientX + 12, y = mm.clientY - 28;
        tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? mm.clientX - tip.offsetWidth - 8 : x) + 'px';
        tip.style.top  = Math.max(4, y) + 'px';
      });
      dot.addEventListener('mouseleave', () => { tip.style.display = 'none'; });
    });
  }
</script>

</StatsLayout>
