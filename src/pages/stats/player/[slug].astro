---
import Nav from '../../../components/Nav.astro';
import ThemeScript from '../../../components/ThemeScript.astro';
import Fonts from '../../../components/Fonts.astro';
import { loadPlayers, loadPlayerGames, type GameLogEntry, type PlayerSummary } from '../../../lib/stats-loader';
import { pickTeamColor } from '../../../lib/team-colors';

export async function getStaticPaths() {
  const players = loadPlayers();

  // HGBScore rank within pos_group
  const forwards = [...players].filter(p => p.pos_group === 'F').sort((a, b) => b.avg_gs_centered - a.avg_gs_centered);
  const defense  = [...players].filter(p => p.pos_group === 'D').sort((a, b) => b.avg_gs_centered - a.avg_gs_centered);
  const rankMap = new Map<number, { rank: number; total: number }>();
  forwards.forEach((p, i) => rankMap.set(p.player_id, { rank: i + 1, total: forwards.length }));
  defense.forEach( (p, i) => rankMap.set(p.player_id, { rank: i + 1, total: defense.length }));

  // RAPM rank within pos_group and overall
  const withRapm    = players.filter(p => p.rapm != null);
  const rapmF       = [...withRapm].filter(p => p.pos_group === 'F').sort((a, b) => (b.rapm ?? 0) - (a.rapm ?? 0));
  const rapmD       = [...withRapm].filter(p => p.pos_group === 'D').sort((a, b) => (b.rapm ?? 0) - (a.rapm ?? 0));
  const rapmAll     = [...withRapm].sort((a, b) => (b.rapm ?? 0) - (a.rapm ?? 0));
  const rapmRankMap = new Map<number, { rankPos: number; totalPos: number; rankAll: number; totalAll: number }>();
  rapmF.forEach((p, i) => rapmRankMap.set(p.player_id, { rankPos: i+1, totalPos: rapmF.length, rankAll: 0, totalAll: rapmAll.length }));
  rapmD.forEach((p, i) => rapmRankMap.set(p.player_id, { rankPos: i+1, totalPos: rapmD.length, rankAll: 0, totalAll: rapmAll.length }));
  rapmAll.forEach((p, i) => { const r = rapmRankMap.get(p.player_id); if (r) r.rankAll = i + 1; });

  function findPeers(all: PlayerSummary[], current: PlayerSummary) {
    const curWar = (current.rapm ?? 0) * 60;
    const candidates = all
      .filter(p => p.player_id !== current.player_id && p.pos_group === current.pos_group)
      .sort((a, b) => Math.abs((a.rapm ?? 0) * 60 - curWar) - Math.abs((b.rapm ?? 0) * 60 - curWar));
    for (const band of [2, 5, 10]) {
      const inBand = candidates.filter(p => Math.abs((p.rapm ?? 0) * 60 - curWar) <= band);
      if (inBand.length >= 3) return inBand.slice(0, 4);
    }
    return candidates.slice(0, 4);
  }

  return players.map(player => {
    const playerGames = loadPlayerGames(player.player_id);
    const rankInfo    = rankMap.get(player.player_id)    ?? { rank: 0, total: 0 };
    const rapmRank    = rapmRankMap.get(player.player_id) ?? null;
    const peers       = findPeers(players, player).map(p => ({
      player_id: p.player_id, slug: p.slug,
      first_name: p.first_name, last_name: p.last_name,
      display_name: p.display_name, team_abbrev: p.team_abbrev,
      pos: p.pos, gp: p.gp, rapm: p.rapm,
    }));
    return { params: { slug: player.slug }, props: { player, playerGames, rankInfo, rapmRank, peers } };
  });
}

interface Props {
  player: PlayerSummary;
  playerGames: GameLogEntry[];
  rankInfo: { rank: number; total: number };
  rapmRank: { rankPos: number; totalPos: number; rankAll: number; totalAll: number } | null;
  peers: Array<{
    player_id: number; slug: string; first_name: string; last_name: string;
    display_name: string; team_abbrev: string; pos: string; gp: number; rapm: number | null;
  }>;
}

const { player, playerGames, rankInfo, rapmRank, peers } = Astro.props;

function fmtToi(sec: number): string {
  const m = Math.floor(sec / 60);
  const s = Math.round(sec % 60);
  return `${m}:${s.toString().padStart(2, '0')}`;
}
function fmtDate(d: string): string {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const [, mm, dd] = d.split('-');
  return `${months[parseInt(mm) - 1]} ${parseInt(dd)}`;
}
function sign(n: number): string { return n >= 0 ? '+' : ''; }
function ordinalSuffix(n: number): string {
  const abs = Math.round(n);
  const m10 = abs % 10, m100 = abs % 100;
  if (m100 >= 11 && m100 <= 13) return `${abs}th`;
  if (m10 === 1) return `${abs}st`;
  if (m10 === 2) return `${abs}nd`;
  if (m10 === 3) return `${abs}rd`;
  return `${abs}th`;
}

// RAPM values are already per-60 units — use directly
const rapmNet = player.rapm     ?? null;
const rapmOff = player.rapm_off ?? null;
const rapmDef = player.rapm_def ?? null;

const teamColor     = pickTeamColor(player.team_abbrev);
const headshotUrl   = `https://assets.nhle.com/mugs/nhl/20252026/${player.team_abbrev}/${player.player_id}.png`;
const allGames      = [...playerGames].sort((a, b) => a.game_date.localeCompare(b.game_date));
const recentGames   = [...allGames].reverse();  // all games, newest first
const totalGoals    = playerGames.reduce((s, g) => s + g.goals,   0);
const totalAssists  = playerGames.reduce((s, g) => s + g.assists, 0);

// ── Impact season trend chart ─────────────────────────────────────────────
const IW = 680, IH = 110;
const IP = { t: 10, r: 8, b: 20, l: 38 };
const iCW = IW - IP.l - IP.r, iCH = IH - IP.t - IP.b;
const iN   = allGames.length || 1;
const iGS  = allGames.map(g => g.gs_display);
const iMin = -5, iMax = 12;  // fixed scale matches sparklines
const ipx  = (i: number) => IP.l + (i / (iN - 1 || 1)) * iCW;
const ipy  = (v: number) => IP.t + iCH - ((v - iMin) / (iMax - iMin)) * iCH;
const ipy0 = ipy(0);
const iPath = allGames.map((g, i) =>
  `${i === 0 ? 'M' : 'L'}${ipx(i).toFixed(1)},${ipy(g.gs_display).toFixed(1)}`
).join(' ');
const iArea = allGames.length >= 2
  ? `${iPath} L${ipx(iN-1).toFixed(1)},${ipy0.toFixed(1)} L${IP.l},${ipy0.toFixed(1)} Z`
  : '';
const posLabel      = player.pos_group === 'F' ? 'Forward' : 'Defenseman';
const posPlural     = player.pos_group === 'F' ? 'forwards' : 'defensemen';

const pctBars = [
  { label: 'EV Offence', key: 'ev_offence', val: player.percentiles_vs_pos.ev_offence, grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'Goals / 60', key: 'goals',      val: player.percentiles_vs_pos.goals,       grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'xG / 60',    key: 'ixg',        val: player.percentiles_vs_pos.ixg,         grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'A1 / 60',    key: 'a1',         val: player.percentiles_vs_pos.a1,          grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'Finishing',  key: 'finishing',  val: player.percentiles_vs_pos.finishing,    grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'EV Defense', key: 'ev_defence', val: player.percentiles_vs_pos.ev_defence,  grad: 'linear-gradient(90deg,#e8f0fe,#4285f4)' },
  { label: 'Shots / 60', key: 'shots',      val: player.percentiles_vs_pos.shots,       grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
  { label: 'Pen. Diff',  key: 'pen_diff',   val: player.percentiles_vs_pos.pen_diff,    grad: 'linear-gradient(90deg,#c8e6d0,#137333)' },
];
---
<!doctype html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{player.first_name} {player.last_name} — HGB Stats</title>
  <meta name="description" content={`${player.first_name} ${player.last_name} (${player.team_abbrev}, ${player.pos}) — ${player.gp} GP, ${totalGoals}G ${totalAssists}A. Season rates, percentiles, and RAPM.`} />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:      #EFEEE8;
      --ink:     #0d0d14;
      --red:     #E8002D;
      --surface: #FFFFFF;
      --ink-06:  rgba(13,13,20,0.06);
      --ink-10:  rgba(13,13,20,0.10);
      --ink-14:  rgba(13,13,20,0.14);
      --ink-20:  rgba(13,13,20,0.20);
      --ink-32:  rgba(13,13,20,0.32);
      --ink-48:  rgba(13,13,20,0.48);
      --ink-72:  rgba(13,13,20,0.72);
      --display:   'Barlow Condensed', sans-serif;
      --body:      'Barlow', sans-serif;
      --mono:      'JetBrains Mono', monospace;
      --grid-line: rgba(13,13,20,0.04);
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; }


    /* Layout */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

    /* Masthead — full-bleed grid (matches Teams/Home/Stats pattern) */
    .mast {
      position: relative; overflow: hidden;
      border-bottom: 2px solid var(--ink);
      background-color: var(--bg);
      background-image:
        linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px;
    }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-top a { color: var(--ink-48); text-decoration: none; }
    .mast-top a:hover { color: var(--ink); }
    /* White card — left border uses team color */
    .mast-card { background: var(--surface); border: 1px solid var(--ink); border-left-width: 4px; padding: 24px 28px; }
    /* Hero grid inside card */
    .hero { display: grid; grid-template-columns: auto 1fr; gap: 28px; align-items: start; }
    .headshot-wrap { position: relative; width: 168px; flex-shrink: 0; }
    .headshot { width: 168px; height: 168px; object-fit: cover; border: 2px solid var(--ink-14); background: var(--surface); display: block; }
    .headshot-team-bar { position: absolute; bottom: 0; left: 0; right: 0; height: 4px; }
    .hero-identity { display: flex; flex-direction: column; gap: 8px; }
    .hero-badges { display: flex; gap: 6px; flex-wrap: wrap; }
    .badge { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-48); border: 1px solid var(--ink-14); padding: 2px 8px; }
    .hero-name { font-family: var(--display); font-weight: 800; text-transform: uppercase; line-height: 0.92; letter-spacing: -0.01em; }
    .hero-name .first { font-size: 24px; color: var(--ink-48); font-weight: 700; }
    .hero-name .last  { font-size: clamp(40px, 5vw, 64px); color: var(--ink); display: block; }

    /* Stats table */
    .stats-table { display: grid; grid-template-columns: 110px repeat(6, 1fr); border-top: 1px solid var(--ink-10); margin-top: 10px; }
    .stat-val.war-pos { color: #14803c; }
    .stat-val.war-neg { color: var(--red); }
    .stats-cell { padding: 8px 6px 6px; }
    .stats-cell.col-header { font-family: var(--mono); font-size: 9.5px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32); padding-bottom: 4px; border-bottom: 1px solid var(--ink-10); text-align: center; }
    .stats-cell.season-lbl { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-48); border-bottom: 1px solid var(--ink-06); display: flex; align-items: center; }
    .stats-cell.stat-val { font-family: var(--mono); font-weight: 700; font-size: 18px; color: var(--ink); letter-spacing: -0.01em; font-variant-numeric: tabular-nums; border-bottom: 1px solid var(--ink-06); text-align: center; }

    /* Content grid */
    .content { display: grid; grid-template-columns: 1fr 340px; gap: 24px; padding: 28px 0 80px; align-items: start; }
    .content-main { display: flex; flex-direction: column; gap: 16px; }
    .content-side { display: flex; flex-direction: column; gap: 16px; }

    /* Cards */
    .card { background: var(--surface); border: 1px solid var(--ink-14); box-shadow: 0 1px 3px rgba(13,13,20,0.06); }
    .card-head { padding: 14px 18px 12px; border-bottom: 1px solid var(--ink-06); display: flex; align-items: baseline; justify-content: space-between; }
    .card-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-32); }
    .card-eyebrow .accent { color: var(--red); }
    .card-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* RAPM */
    .rapm-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; }
    .rapm-cell { padding: 18px 16px 16px; border-right: 1px solid var(--ink-06); text-align: center; }
    .rapm-cell:last-child { border-right: 0; }
    .rapm-cell.net { background: var(--bg); }
    .rapm-val { font-family: var(--display); font-weight: 800; font-size: 44px; line-height: 1; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
    .rapm-val.pos { color: #14803c; }
    .rapm-val.neg { color: var(--red); }
    .rapm-val.net-val { font-size: 56px; }
    .rapm-val.null-val { font-size: 32px; color: var(--ink-32); }
    .rapm-dim { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-32); margin-top: 4px; }
    .rapm-context { padding: 10px 18px; border-top: 1px solid var(--ink-06); font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; }
    .rapm-context strong { color: var(--ink); }

    /* Percentile bars */
    .pct-rows { display: flex; flex-direction: column; gap: 0; }
    .pct-row { display: grid; grid-template-columns: 110px 1fr 36px; align-items: center; gap: 10px; padding: 10px 18px; border-bottom: 1px solid var(--ink-06); }
    .pct-row:last-child { border-bottom: 0; }
    .pct-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-48); }
    .pct-track { height: 6px; background: var(--ink-06); position: relative; overflow: hidden; }
    .pct-fill { height: 100%; }
    .pct-pct { font-family: var(--mono); font-weight: 700; font-size: 12px; color: var(--ink); text-align: right; font-variant-numeric: tabular-nums; }

    /* Game log */
    .gl-table { width: 100%; border-collapse: collapse; }
    .gl-table th { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-32); padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--ink-10); }
    .gl-table th:not(:first-child) { text-align: right; }
    .gl-table td { padding: 9px 14px; border-bottom: 1px solid var(--ink-06); font-family: var(--mono); font-size: 12.5px; color: var(--ink); font-variant-numeric: tabular-nums; }
    .gl-table td:not(:first-child) { text-align: right; }
    .gl-table tr:last-child td { border-bottom: none; }
    .gl-table tr:hover td { background: var(--bg); }
    .gl-win  { color: #14803c; font-weight: 700; }
    .gl-loss { color: var(--red); font-weight: 700; }
    .gl-muted { color: var(--ink-32); }
    .gl-imp { font-weight: 700; }
    .gl-imp.pos { color: #14803c; }
    .gl-imp.neg { color: var(--red); }
    .gl-table th.th-impact { text-align: center; }
    .gl-table td.td-impact { text-align: center; }

    /* ── Impact trend chart ── */
    .impact-chart-wrap { padding: 0 2px 4px; }
    .impact-chart-svg  { width: 100%; height: auto; display: block; overflow: visible; }
    .impact-dot { cursor: crosshair; }
    #imp-tip { position: fixed; pointer-events: none; display: none; z-index: 100;
      background: var(--surface); color: var(--ink); padding: 6px 10px;
      font-family: var(--mono); font-size: 10px; white-space: nowrap; border-radius: 2px;
      border: 1px solid var(--ink-14); box-shadow: 0 2px 8px rgba(13,13,20,0.12); }
    #imp-tip .tip-ctx  { color: var(--ink-48); margin-right: 6px; }
    #imp-tip .tip-val  { font-weight: 700; }
    .gl-table-wrap { max-height: 420px; overflow-y: auto; }
    .gl-game-link { color: inherit; text-decoration: none; border-bottom: 1px solid var(--ink-14); transition: border-color 0.15s; }
    .gl-game-link:hover { border-color: var(--red); color: var(--ink); }

    /* CTA sidebar card */
    .cta-card { background: var(--ink); padding: 22px 18px; }
    .cta-title { font-family: var(--display); font-weight: 800; font-size: 22px; text-transform: uppercase; color: #fff; letter-spacing: 0.01em; margin-bottom: 6px; }
    .cta-desc { font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.4); letter-spacing: 0.04em; margin-bottom: 16px; line-height: 1.6; }
    .cta-formats { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
    .cta-fmt { font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 8px; border: 1px solid rgba(255,255,255,0.16); color: rgba(255,255,255,0.48); cursor: pointer; }
    .cta-btn { display: block; width: 100%; background: var(--red); color: #fff; font-family: var(--display); font-weight: 800; font-size: 15px; letter-spacing: 0.14em; text-transform: uppercase; padding: 12px 16px; border: none; cursor: pointer; text-align: center; text-decoration: none; }
    .cta-note { font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.06em; color: rgba(255,255,255,0.24); margin-top: 8px; text-align: center; }

    /* Similar players */
    .peer-strip { display: flex; flex-direction: column; gap: 0; }
    .peer-row { display: flex; align-items: center; gap: 10px; padding: 10px 18px; border-bottom: 1px solid var(--ink-06); text-decoration: none; color: inherit; }
    .peer-row:last-child { border-bottom: 0; }
    .peer-row:hover { background: var(--bg); }
    .peer-name { font-family: var(--body); font-weight: 600; font-size: 13px; flex: 1; }
    .peer-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.04em; }
    .peer-rapm { font-family: var(--display); font-weight: 800; font-size: 16px; font-variant-numeric: tabular-nums; }
    .peer-rapm.pos { color: #14803c; }
    .peer-rapm.neg { color: var(--red); }

    /* Methodology */
    .method-card { padding: 14px 18px; }
    .method-text { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.03em; line-height: 1.65; }
    .method-link { display: inline-block; margin-top: 10px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--red); text-decoration: none; }

    /* Footer */
    footer { background: var(--ink); padding: 32px 0; font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.24); letter-spacing: 0.06em; text-align: center; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .mast-inner { padding: 24px 20px; }
      .mast-card { padding: 20px 20px 16px; }
      .mast-top { flex-direction: column; align-items: flex-start; gap: 6px; }
      /* Hero: stack headshot + identity vertically */
      .hero { grid-template-columns: 1fr; gap: 18px; }
      .headshot-wrap { width: 120px; }
      .headshot { width: 120px; height: 120px; }
      /* Stats table: allow horizontal scroll */
      .stats-table { overflow-x: auto; display: block; white-space: nowrap; }
      /* Content: collapse sidebar to single column */
      .content { grid-template-columns: 1fr; gap: 16px; padding: 20px 0 60px; }
      .wrap { padding: 0 20px; }
      /* RAPM: smaller font */
      .rapm-val.net-val { font-size: 44px; }
      .rapm-val { font-size: 36px; }
      /* Game log table: show fewer columns via overflow */
      .gl-table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    }
    @media (max-width: 480px) {
      .mast-inner { padding: 18px 16px; }
      .mast-card { padding: 16px 14px 14px; }
      .wrap { padding: 0 16px; }
      .hero-name .last { font-size: clamp(32px, 8vw, 52px); }
      .headshot-wrap { width: 100px; }
      .headshot { width: 100px; height: 100px; }
      .rapm-grid { grid-template-columns: 1fr 1fr; }
      .rapm-cell.net { grid-column: 1 / -1; border-bottom: 1px solid var(--ink-06); border-right: none; }
      .rapm-val.net-val { font-size: 40px; }
      .rapm-val { font-size: 32px; }
      .pct-row { grid-template-columns: 90px 1fr 30px; gap: 6px; padding: 9px 14px; }
      .content { padding: 16px 0 48px; }
    }
  </style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<!-- MASTHEAD — full-bleed grid -->
<section class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div><a href="/stats">← Stats</a> &nbsp;/&nbsp; <a href="/stats">Skaters</a></div>
      <div>{player.team_abbrev} · {player.pos} · {player.gp} GP</div>
    </div>
    <div class="mast-card" style={`border-left-color: ${teamColor}`}>
      <div class="hero">
        <div class="headshot-wrap">
          <img class="headshot" src={headshotUrl} alt={`${player.first_name} ${player.last_name}`} width="168" height="168" />
          <div class="headshot-team-bar" style={`background:${teamColor}`}></div>
        </div>
        <div class="hero-identity">
          <div class="hero-badges">
            <span class="badge">{player.team_abbrev}</span>
            <span class="badge">{player.pos}</span>
            <span class="badge">{posLabel}</span>
            {rapmRank && <span class="badge">#{rapmRank.rankPos} WAR · {posPlural}</span>}
          </div>
          <div class="hero-name">
            <span class="first">{player.first_name}</span>
            <span class="last">{player.last_name}</span>
          </div>
          <div class="stats-table">
            <div class="stats-cell col-header"></div>
            <div class="stats-cell col-header">WAR</div>
            <div class="stats-cell col-header">GP</div>
            <div class="stats-cell col-header">G</div>
            <div class="stats-cell col-header">A</div>
            <div class="stats-cell col-header">PTS</div>
            <div class="stats-cell col-header">G/60</div>
            <div class="stats-cell season-lbl">Regular</div>
            <div class={`stats-cell stat-val${player.war != null ? (player.war >= 0 ? ' war-pos' : ' war-neg') : ''}`}>
              {player.war != null ? `${sign(player.war)}${player.war.toFixed(1)}` : '—'}
            </div>
            <div class="stats-cell stat-val">{player.gp}</div>
            <div class="stats-cell stat-val">{totalGoals}</div>
            <div class="stats-cell stat-val">{totalAssists}</div>
            <div class="stats-cell stat-val">{totalGoals + totalAssists}</div>
            <div class="stats-cell stat-val">{player.rates_per_60.goals.toFixed(2)}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="wrap">

  <!-- CONTENT GRID -->
  <div class="content">

    <!-- MAIN -->
    <div class="content-main">

      <!-- RAPM -->
      <div class="card">
        <div class="card-head">
          <span class="card-eyebrow">Regularized Adjusted Plus/Minus &nbsp;<span class="accent">RAPM</span></span>
          <span class="card-meta">per 60 min · 2025–26</span>
        </div>
        <div class="rapm-grid">
          <div class="rapm-cell">
            {rapmOff != null
              ? <div class={`rapm-val ${rapmOff >= 0 ? 'pos' : 'neg'}`}>{sign(rapmOff)}{rapmOff.toFixed(2)}</div>
              : <div class="rapm-val null-val">—</div>
            }
            <div class="rapm-dim">Offensive</div>
          </div>
          <div class="rapm-cell net">
            {rapmNet != null
              ? <div class={`rapm-val net-val ${rapmNet >= 0 ? 'pos' : 'neg'}`}>{sign(rapmNet)}{rapmNet.toFixed(2)}</div>
              : <div class="rapm-val null-val">—</div>
            }
            <div class="rapm-dim">Net &nbsp;·&nbsp; Goals above replacement / 60</div>
          </div>
          <div class="rapm-cell">
            {rapmDef != null
              ? <div class={`rapm-val ${rapmDef >= 0 ? 'pos' : 'neg'}`}>{sign(rapmDef)}{rapmDef.toFixed(2)}</div>
              : <div class="rapm-val null-val">—</div>
            }
            <div class="rapm-dim">Defensive</div>
          </div>
        </div>
        {rapmRank && (
          <div class="rapm-context">
            <strong>{ordinalSuffix(rapmRank.rankPos)}</strong> among {posPlural}
            &nbsp;·&nbsp;
            <strong>{ordinalSuffix(rapmRank.rankAll)}</strong> overall (all skaters)
            &nbsp;·&nbsp;
            top <strong>{(rapmRank.rankAll / rapmRank.totalAll * 100).toFixed(1)}%</strong>
          </div>
        )}
      </div>

      <!-- PERCENTILE FINGERPRINT -->
      <div class="card">
        <div class="card-head">
          <span class="card-eyebrow">Percentile fingerprint &nbsp;<span class="accent">vs. {posPlural}</span></span>
          <span class="card-meta">min 20 GP · 2025–26</span>
        </div>
        <div class="pct-rows">
          {pctBars.map(bar => (
            <div class="pct-row">
              <span class="pct-label">{bar.label}</span>
              <div class="pct-track">
                <div class="pct-fill" style={`width:${bar.val.toFixed(1)}%;background:${bar.grad}`}></div>
              </div>
              <span class="pct-pct">{Math.round(bar.val)}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- IMPACT TREND -->
      <div class="card">
        <div class="card-head">
          <span class="card-eyebrow">HGB <span class="accent">Impact</span> — Season Trend</span>
          <span class="card-meta">Avg {player.avg_gs_display >= 0 ? '+' : ''}{player.avg_gs_display.toFixed(2)} · {allGames.length} games</span>
        </div>
        {allGames.length > 1 && (
          <div class="impact-chart-wrap">
            <svg class="impact-chart-svg" viewBox={`0 0 ${IW} ${IH}`} preserveAspectRatio="xMidYMid meet">
              <!-- Zero line -->
              <line x1={IP.l} y1={ipy0.toFixed(1)} x2={(IP.l+iCW).toFixed(1)} y2={ipy0.toFixed(1)}
                stroke="rgba(13,13,20,0.18)" stroke-width="1" stroke-dasharray="3 3" />
              <!-- Y-axis labels -->
              {[-4, 0, 4, 8, 12].map(v => (
                <text x={(IP.l-4).toFixed(1)} y={ipy(v).toFixed(1)} text-anchor="end"
                  dominant-baseline="middle" font-family="JetBrains Mono,monospace"
                  font-size="8" fill="rgba(13,13,20,0.28)">
                  {v >= 0 ? '+' : ''}{v}
                </text>
              ))}
              <!-- Area fill -->
              {iArea && <path d={iArea} fill={teamColor} fill-opacity="0.06" />}
              <!-- Line -->
              <path d={iPath} fill="none" stroke={teamColor} stroke-width="1.5"
                stroke-linejoin="round" stroke-linecap="round" />
              <!-- Hover dots (transparent, wide target) -->
              {allGames.map((g, i) => {
                const cx = ipx(i).toFixed(1), cy = ipy(g.gs_display).toFixed(1);
                const sgn = g.gs_display >= 0 ? '+' : '';
                const tip = `${g.game_date} ${g.is_home ? 'vs' : '@'} ${g.opp_abbrev} · ${sgn}${g.gs_display.toFixed(2)}`;
                return (
                  <circle cx={cx} cy={cy} r="5" fill="transparent" class="impact-dot"
                    data-tip={tip} data-val={g.gs_display} />
                );
              })}
            </svg>
            <div id="imp-tip"></div>
          </div>
        )}
      </div>

      <!-- GAME LOG -->
      <div class="card">
        <div class="card-head">
          <span class="card-eyebrow">Game log &nbsp;<span class="accent">2025–26</span></span>
          <span class="card-meta">{recentGames.length} games · newest first</span>
        </div>
        <div class="gl-table-wrap">
          <table class="gl-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Opp</th>
                <th>Result</th>
                <th>G</th>
                <th>A</th>
                <th>PTS</th>
                <th class="th-impact">Impact</th>
              </tr>
            </thead>
            <tbody>
              {recentGames.map(g => {
                const win    = g.team_score > g.opp_score;
                const result = win ? 'W' : (g.team_score < g.opp_score ? 'L' : 'T');
                const vs     = g.is_home ? 'vs' : '@';
                const href   = g.game_id ? `/games/${g.game_id}` : null;
                const impCls = g.gs_display >= 0 ? 'pos' : 'neg';
                const impSign = g.gs_display >= 0 ? '+' : '';
                return (
                  <tr>
                    <td class="gl-muted">
                      {href ? <a href={href} class="gl-game-link">{fmtDate(g.game_date)}</a> : fmtDate(g.game_date)}
                    </td>
                    <td>
                      {href ? <a href={href} class="gl-game-link">{vs} {g.opp_abbrev}</a> : `${vs} ${g.opp_abbrev}`}
                    </td>
                    <td class={win ? 'gl-win' : 'gl-loss'}>{result} {g.team_score}–{g.opp_score}</td>
                    <td>{g.goals}</td>
                    <td>{g.assists}</td>
                    <td>{g.goals + g.assists}</td>
                    <td class="td-impact"><span class={`gl-imp ${impCls}`}>{impSign}{g.gs_display.toFixed(2)}</span></td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- SIDEBAR -->
    <div class="content-side">

      <!-- Generate Card CTA -->
      <div class="cta-card">
        <div class="cta-title">Generate Card</div>
        <div class="cta-desc">Export a publication-quality PNG for this player. Same format the bots ship during games.</div>
        <div class="cta-formats">
          <span class="cta-fmt">HGB Impact</span>
          <span class="cta-fmt">RAPM</span>
          <span class="cta-fmt">Game Log</span>
          <span class="cta-fmt">With / Without</span>
        </div>
        <a href={`/cards?player=${player.player_id}`} class="cta-btn">Generate Card →</a>
        <div class="cta-note">3 free per day · Unlimited with Patreon</div>
      </div>

      <!-- Similar Players -->
      {peers.length > 0 && (
        <div class="card">
          <div class="card-head">
            <span class="card-eyebrow">Similar &nbsp;<span class="accent">{posPlural}</span></span>
          </div>
          <div class="peer-strip">
            {peers.map(peer => {
              const peerRapm = peer.rapm != null ? peer.rapm * 60 : null;
              return (
                <a href={`/stats/player/${peer.slug}`} class="peer-row">
                  <div style="flex:1">
                    <div class="peer-name">{peer.first_name[0]}. {peer.last_name}</div>
                    <div class="peer-meta">{peer.team_abbrev} · {peer.pos} · {peer.gp} GP</div>
                  </div>
                  {peerRapm != null
                    ? <span class={`peer-rapm ${peerRapm >= 0 ? 'pos' : 'neg'}`}>{sign(peerRapm)}{peerRapm.toFixed(2)}</span>
                    : <span class="peer-rapm" style="color:var(--ink-32)">—</span>
                  }
                </a>
              );
            })}
          </div>
        </div>
      )}

      <!-- Methodology -->
      <div class="card">
        <div class="method-card">
          <p class="method-text">
            HGB Impact combines individual shot quality, on-ice xG, finishing skill, and penalties drawn/taken — all rate-adjusted per 60 minutes. WAR (RAPM ×60) isolates each player's true contribution controlling for linemates and opponents. Percentiles vs {posPlural} with 20+ GP.
          </p>
          <a href="/stats" class="method-link">Methodology →</a>
        </div>
      </div>

    </div>
  </div>
</div>

<footer>hockeygamebot.com · HGB Stats · 2025–26</footer>

<script>
  // Impact trend chart — dot hover tooltips
  const tip = document.getElementById('imp-tip');
  if (tip) {
    document.querySelectorAll('.impact-dot').forEach(dot => {
      dot.addEventListener('mouseenter', e => {
        const val = parseFloat(dot.dataset.val ?? '0');
        const tipText = dot.dataset.tip ?? '';
        // Split "2025-10-30 vs NYR · -0.69" into context + value
        const parts = tipText.split(' · ');
        const ctx = parts.slice(0, -1).join(' · ');
        const valStr = parts[parts.length - 1];
        const valColor = val >= 0 ? '#1a7a3e' : '#E8002D';
        tip.innerHTML = `<span class="tip-ctx">${ctx}</span><span class="tip-val" style="color:${valColor}">${valStr}</span>`;
        tip.style.display = 'block';
        const x = e.clientX + 12, y = e.clientY - 28;
        tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? e.clientX - tip.offsetWidth - 8 : x) + 'px';
        tip.style.top  = Math.max(4, y) + 'px';
      });
      dot.addEventListener('mousemove', e => {
        const x = e.clientX + 12, y = e.clientY - 28;
        tip.style.left = (x + tip.offsetWidth > window.innerWidth - 8 ? e.clientX - tip.offsetWidth - 8 : x) + 'px';
        tip.style.top  = Math.max(4, y) + 'px';
      });
      dot.addEventListener('mouseleave', () => { tip.style.display = 'none'; });
    });
  }
</script>

</body>
</html>
