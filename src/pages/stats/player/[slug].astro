---
import '../../../styles/stats-tokens.css';
import PageHeader from '../../../components/stats/PageHeader.astro';
import SectionEyebrow from '../../../components/stats/SectionEyebrow.astro';
import PercentileTile from '../../../components/stats/PercentileTile.astro';
import StatsSEO from '../../../components/StatsSEO.astro';
import ModeFoucScript from '../../../components/ModeFoucScript.astro';
import { loadPlayers, loadPlayerGames, type GameLogEntry, type PlayerSummary } from '../../../lib/stats-loader';
import { pickTeamColor } from '../../../lib/team-colors';

export async function getStaticPaths() {
  const players = loadPlayers();

  const forwards = [...players].filter(p => p.pos_group === 'F').sort((a, b) => b.avg_gs_centered - a.avg_gs_centered);
  const defense  = [...players].filter(p => p.pos_group === 'D').sort((a, b) => b.avg_gs_centered - a.avg_gs_centered);
  const rankMap = new Map<number, { rank: number; total: number }>();
  forwards.forEach((p, i) => rankMap.set(p.player_id, { rank: i + 1, total: forwards.length }));
  defense.forEach( (p, i) => rankMap.set(p.player_id, { rank: i + 1, total: defense.length  }));

  function findPeers(allPlayers: PlayerSummary[], current: PlayerSummary) {
    const candidates = allPlayers
      .filter(p => p.player_id !== current.player_id && p.pos_group === current.pos_group)
      .sort((a, b) => Math.abs(a.avg_gs_display - current.avg_gs_display) - Math.abs(b.avg_gs_display - current.avg_gs_display));

    // Widen band until we have 3+ peers; fall back to closest-5 for extreme outliers
    for (const band of [0.25, 0.50, 0.75]) {
      const inBand = candidates.filter(p => Math.abs(p.avg_gs_display - current.avg_gs_display) <= band);
      if (inBand.length >= 3) return inBand.slice(0, 5);
    }
    return candidates.slice(0, 5);
  }

  return players.map(player => {
    const playerGames = loadPlayerGames(player.player_id);
    const rankInfo = rankMap.get(player.player_id) ?? { rank: 0, total: 0 };
    const peers = findPeers(players, player).map(p => ({
      player_id: p.player_id, slug: p.slug, display_name: p.display_name,
      team_abbrev: p.team_abbrev, pos: p.pos, gp: p.gp,
      avg_gs_display: p.avg_gs_display, gs_pct: p.gs_pct,
      pcts: [
        p.gs_pct,
        p.percentiles_vs_pos.ixg,
        p.percentiles_vs_pos.shots,
        p.percentiles_vs_pos.finishing,
        p.percentiles_vs_pos.pen_diff,
        p.percentiles_vs_pos.ev_defence,
      ],
    }));

    return { params: { slug: player.slug }, props: { player, playerGames, rankInfo, peers } };
  });
}

interface Props {
  player: PlayerSummary;
  playerGames: GameLogEntry[];
  rankInfo: { rank: number; total: number };
  peers: Array<{
    player_id: number; slug: string; display_name: string;
    team_abbrev: string; pos: string; gp: number;
    avg_gs_display: number; gs_pct: number;
    pcts: number[];
  }>;
}

const { player, playerGames, rankInfo, peers } = Astro.props;

function fmtToi(sec: number): string {
  const m = Math.floor(sec / 60);
  const s = Math.round(sec % 60);
  return `${m}:${s.toString().padStart(2, '0')}`;
}

function fmtDate(d: string): string {
  const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const parts = d.split('-');
  return `${months[parseInt(parts[1]) - 1]} ${parseInt(parts[2])}`;
}

function ordinalSuffix(n: number): string {
  const abs = Math.round(n);
  const m10 = abs % 10, m100 = abs % 100;
  if (m100 >= 11 && m100 <= 13) return `${abs}TH`;
  if (m10 === 1) return `${abs}ST`;
  if (m10 === 2) return `${abs}ND`;
  if (m10 === 3) return `${abs}RD`;
  return `${abs}TH`;
}

const teamColor  = pickTeamColor(player.team_abbrev);
const posPlural  = player.pos_group === 'F' ? 'FORWARDS' : 'DEFENSEMEN';
const avgGs      = player.avg_gs_display;
const gsSign     = avgGs >= 0 ? '+' : '';
const isNeg      = avgGs < 0;

// Peer bar
const pct        = player.gs_pct;
const markerPct  = Math.max(0, Math.min(pct, 100));
// ── Radar helpers ─────────────────────────────────────────────────────────────
function radarPt(axisIdx: number, pctVal: number, maxR = 118): [number, number] {
  const angle = axisIdx * (Math.PI / 3);
  const r = Math.min(Math.max(pctVal, 0), 100) / 100 * maxR;
  return [+(Math.sin(angle) * r).toFixed(1), +(-Math.cos(angle) * r).toFixed(1)];
}
function radarPts(pctVals: number[], maxR = 118): string {
  return pctVals.map((p, i) => { const [x, y] = radarPt(i, p, maxR); return `${x},${y}`; }).join(' ');
}

// ── Calendar heatmap ──────────────────────────────────────────────────────────
const MONTH_NAMES = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
function heatLevel(gs: number, avg: number): string {
  const hi  = Math.max(avg * 1.8, 2.0);
  const mid = Math.max(avg * 1.0, 1.0);
  const lo  = Math.max(avg * 0.4, 0.4);
  if (gs >= hi)   return 'l4';
  if (gs >= mid)  return 'l3';
  if (gs >= lo)   return 'l2';
  if (gs >= 0)    return 'l1';
  if (gs >= -0.5) return 'n1';
  return 'n2';
}
type HeatGame = { gs: number; win: boolean; level: string };
type HeatMonth = { label: string; games: HeatGame[] };
const calMonths: HeatMonth[] = [];
const seenMonths = new Map<string, HeatGame[]>();
for (const g of playerGames) {
  const key = g.game_date.slice(0, 7);
  const mIdx = parseInt(g.game_date.slice(5, 7)) - 1;
  if (!seenMonths.has(key)) {
    const arr: HeatGame[] = [];
    seenMonths.set(key, arr);
    calMonths.push({ label: MONTH_NAMES[mIdx], games: arr });
  }
  seenMonths.get(key)!.push({ gs: g.gs_display, win: g.team_score > g.opp_score, level: heatLevel(g.gs_display, avgGs) });
}
const calCols = Math.max(...calMonths.map(m => m.games.length), 1);

// ── Radar data ────────────────────────────────────────────────────────────────
const playerPcts = [
  player.gs_pct,
  player.percentiles_vs_pos.ixg,
  player.percentiles_vs_pos.shots,
  player.percentiles_vs_pos.finishing,
  player.percentiles_vs_pos.pen_diff,
  player.percentiles_vs_pos.ev_defence,
];
const playerRadarPts   = radarPts(playerPcts);
const playerRadarNodes = playerPcts.map((p, i) => radarPt(i, p));
const rings     = [25, 50, 75, 100].map(r => radarPts([r,r,r,r,r,r]));
const axisEnds  = [0,1,2,3,4,5].map(i => radarPt(i, 100));
const peerColors = peers.map(p => pickTeamColor(p.team_abbrev));

// ── Season sparkline (bar + 5-game rolling avg) ───────────────────────────────
const gsVals  = playerGames.map(g => g.gs_display);
const TL_H = 90, TL_PAD = 5;
const dataMax = Math.max(...gsVals, 0.01);
const dataMin = Math.min(...gsVals, -0.01);
// Zero line sits proportionally so bars always fill their half
const totalRange = dataMax - dataMin;
const TL_MID = Math.round(TL_PAD + (dataMax / totalRange) * (TL_H - TL_PAD * 2));
const TL_POS_H = TL_MID - TL_PAD;
const TL_NEG_H = TL_H - TL_PAD - TL_MID;
const tlAvgPts = playerGames.map((_, i) => {
  const w   = gsVals.slice(Math.max(0, i - 4), i + 1);
  const avg = w.reduce((s, v) => s + v, 0) / w.length;
  const y   = avg >= 0
    ? TL_MID - (avg / dataMax) * TL_POS_H
    : TL_MID + (Math.abs(avg) / Math.abs(dataMin)) * TL_NEG_H;
  return `${(i + 0.5).toFixed(1)},${y.toFixed(1)}`;
}).join(' ');

// ── Recent games ──────────────────────────────────────────────────────────────
const recentGames  = [...playerGames].reverse().slice(0, 15);
const recentBestI  = recentGames.reduce((bi, g, i) => g.gs_display > recentGames[bi].gs_display ? i : bi, 0);
const recentWorstI = recentGames.reduce((wi, g, i) => g.gs_display < recentGames[wi].gs_display ? i : wi, 0);
const totalGoals   = playerGames.reduce((s, g) => s + g.goals, 0);
const totalAssists = playerGames.reduce((s, g) => s + g.assists, 0);

function hexToRgba(hex: string, alpha: number): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}
function dotColor(pct: number): string {
  return pct >= 90 ? '#00c078' : pct >= 70 ? '#60a5fa' : pct >= 40 ? '#8a8a82' : '#e8002d';
}
function rankStr(n: number): string {
  return String(n).padStart(2, '0');
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <ModeFoucScript />
  <meta name="color-scheme" content="light dark">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <StatsSEO
    title={`${player.first_name} ${player.last_name} — HGB Stats`}
    description={`${player.first_name} ${player.last_name} (${player.team_abbrev}, ${player.pos}) — ${player.gp} games played, ${player.goals}G ${player.assists}A, HGBScore ${player.avg_gs_display.toFixed(2)}. Season rates, percentiles, heatmap, and game-by-game log.`}
    ogType="profile"
  />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { min-height: 100vh; -webkit-font-smoothing: antialiased; }
    body {
      background: var(--site-bg);
      color: var(--site-white);
      font-family: var(--font-site-body, 'Space Grotesk', sans-serif);
    }

    /* ── Shell ──────────────────────────────────────────────────────── */
    .player-main {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 24px 80px;
    }

    /* ── Breadcrumb ─────────────────────────────────────────────────── */
    .p-breadcrumb { padding: 20px 0 14px; }
    .p-breadcrumb a {
      font-family: var(--font-card-display);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--site-muted);
      text-decoration: none;
      transition: color 0.12s;
    }
    .p-breadcrumb a:hover { color: var(--site-white); }

    /* ── Hero card ──────────────────────────────────────────────────── */
    .p-hero {
      background: var(--card-bg);
      border: 1px solid var(--card-rule);
      border-radius: var(--radius-md);
      overflow: hidden;
      border-left-width: 4px;
      border-left-style: solid;
    }
    [data-mode="light"] .p-hero {
      background: #ffffff;
      border-color: var(--site-border);
    }
    .p-hero-top {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 20px;
      padding: 22px 22px 18px;
      border-bottom: 1px solid var(--card-rule);
    }
    [data-mode="light"] .p-hero-top { border-bottom-color: var(--site-border); }

    .p-hero-identity { display: flex; align-items: center; gap: 18px; }
    .p-hero-logo { width: 60px; height: 60px; object-fit: contain; flex-shrink: 0; }
    .p-hero-badges { display: flex; gap: 6px; margin-bottom: 7px; }
    .p-badge {
      font-family: var(--font-card-display);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--card-muted);
      background: var(--card-panel-bg);
      border: 1px solid var(--card-rule);
      padding: 2px 8px;
      border-radius: var(--radius-pill);
    }
    .p-hero-name {
      font-family: var(--font-card-display);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.01em;
      line-height: 1;
      color: var(--card-text);
    }
    .p-first {
      font-size: 20px;
      font-weight: 600;
      letter-spacing: 0.04em;
      display: block;
      margin-bottom: 2px;
      color: var(--card-muted);
    }
    .p-last { font-size: clamp(32px, 4vw, 46px); display: block; }

    /* GS chip */
    .p-gs-chip {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      justify-content: center;
      padding: 14px 20px;
      border-radius: var(--radius-md);
      background: #2dd48e;
      color: #0d0d14;
      min-width: 150px;
      text-align: right;
      flex-shrink: 0;
    }
    .p-gs-chip.chip-neg { background: #ff5577; }
    [data-mode="light"] .p-gs-chip          { background: #00a86b; color: #0d0d14; }
    [data-mode="light"] .p-gs-chip.chip-neg { background: #e8002d; color: #ffffff; }
    .p-chip-val {
      font-family: var(--font-card-display);
      font-size: 42px;
      font-weight: 800;
      line-height: 1;
      letter-spacing: 0.02em;
      font-variant-numeric: tabular-nums;
    }
    .p-chip-label {
      font-family: var(--font-card-display);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-top: 5px;
      opacity: 0.9;
    }

    /* Tiles */
    .p-tiles-wrap {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      padding: 12px;
    }
    @media (max-width: 560px) { .p-tiles-wrap { grid-template-columns: repeat(2, 1fr); } }
    .p-tiles-dark  { display: grid; }
    .p-tiles-light { display: none; }
    [data-mode="light"] .p-tiles-dark  { display: none; }
    [data-mode="light"] .p-tiles-light { display: grid; }

    /* ── Season strip ───────────────────────────────────────────────── */
    .p-strip {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 4px;
      padding: 16px 0;
      border-bottom: 1px solid var(--site-border);
    }
    .p-strip-item {
      font-family: var(--font-card-display);
      font-size: 16px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--site-white);
      white-space: nowrap;
    }
    .p-strip-dot { color: var(--site-muted); font-size: 16px; padding: 0 5px; }
    .p-strip-gs { color: #2dd48e; }
    [data-mode="light"] .p-strip-gs { color: #00874e; }
    .p-strip-gs.strip-neg { color: #ff5577; }
    [data-mode="light"] .p-strip-gs.strip-neg { color: #e8002d; }
    .p-strip-rank { color: var(--site-muted); font-size: 15px; }

    /* ── Section wrapper ────────────────────────────────────────────── */
    .p-section {
      padding: 28px 0;
      border-bottom: 1px solid var(--site-border);
    }
    .p-section:last-of-type { border-bottom: none; }
    .p-section-body { margin-top: 16px; }

    /* Override SectionEyebrow size in player page context */
    .p-section :global(.eyebrow) {
      font-size: 12px;
      letter-spacing: 0.2em;
    }

    /* ── Peer percentile bar ────────────────────────────────────────── */
    .peer-panel {
      background: var(--card-panel-bg);
      border: 1px solid var(--card-rule);
      border-radius: var(--radius-md);
      padding: 18px 22px 22px;
    }
    [data-mode="light"] .peer-panel { border-color: var(--site-border); }

    .peer-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 24px;
    }
    .peer-title {
      font-family: var(--font-card-display);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--card-muted);
    }
    .peer-rank-label {
      font-family: var(--font-card-display);
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--card-text);
    }

    /* Tick labels row above track */
    .peer-tick-row {
      position: relative;
      height: 18px;
      margin-bottom: 6px;
    }
    .peer-tick-lbl {
      position: absolute;
      transform: translateX(-50%);
      font-family: var(--font-card-display);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: var(--card-muted);
      text-transform: uppercase;
      line-height: 1;
    }

    /* Track */
    .peer-track {
      position: relative;
      height: 36px;
      background: var(--card-rule);
      border-radius: var(--radius-sm);
    }

    /* Crosshatch fill for the "covered" portion to the left of marker */
    .peer-fill {
      position: absolute;
      top: 0; bottom: 0; left: 0;
      border-radius: var(--radius-sm) 0 0 var(--radius-sm);
      background: repeating-linear-gradient(
        -45deg,
        transparent, transparent 3px,
        rgba(255,255,255,0.08) 3px,
        rgba(255,255,255,0.08) 5px
      );
    }
    [data-mode="light"] .peer-fill {
      background: repeating-linear-gradient(
        -45deg,
        transparent, transparent 3px,
        rgba(13,13,20,0.07) 3px,
        rgba(13,13,20,0.07) 5px
      );
    }

    /* Tick division lines inside the track */
    .peer-tick-line {
      position: absolute;
      top: 0; bottom: 0;
      width: 1px;
      background: rgba(255,255,255,0.15);
      z-index: 1;
    }
    [data-mode="light"] .peer-tick-line { background: rgba(13,13,20,0.15); }

    /* Marker pill — extends above and below track via negative margin */
    .peer-marker {
      position: absolute;
      top: -6px; bottom: -6px;
      transform: translateX(-50%);
      width: 14px;
      z-index: 2;
    }
    .peer-marker-inner {
      width: 100%;
      height: 100%;
      border-radius: var(--radius-sm);
      background: #2dd48e;
      box-shadow: 0 0 0 2px var(--card-bg);
    }
    [data-mode="light"] .peer-marker-inner { background: #00a86b; box-shadow: 0 0 0 2px #ffffff; }
    .peer-marker-inner.dot-neg { background: #ff5577; }
    [data-mode="light"] .peer-marker-inner.dot-neg { background: #e8002d; }

    /* Label below track with clear separation */
    .peer-pct-label {
      position: absolute;
      text-align: center;
      font-family: var(--font-card-display);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--card-text);
      white-space: nowrap;
      top: calc(36px + 14px); /* track height + gap */
    }

    /* Wrap needs position:relative and room for the label below */
    .peer-track-wrap {
      position: relative;
      padding-bottom: 32px;
    }

    /* ── Timeline ───────────────────────────────────────────────────── */
    .tl-wrap {
      background: var(--card-panel-bg);
      border: 1px solid var(--card-rule);
      border-radius: var(--radius-md);
      padding: 16px 16px 12px;
    }
    [data-mode="light"] .tl-wrap { border-color: var(--site-border); }
    .tl-svg { width: 100%; height: 130px; display: block; overflow: visible; }
    /* Zero axis — more visible than card rule */
    .tl-zero { stroke: rgba(255,255,255,0.22); stroke-width: 1; }
    [data-mode="light"] .tl-zero { stroke: rgba(13,13,20,0.18); }
    .tl-pos  { fill: #2dd48e; }
    .tl-neg  { fill: #ff5577; }
    [data-mode="light"] .tl-pos { fill: #00874e; }
    [data-mode="light"] .tl-neg { fill: #e8002d; }
    .tl-avg  {
      stroke: rgba(255,255,255,0.55);
      stroke-width: 2;
      stroke-linejoin: round;
      stroke-linecap: round;
    }
    [data-mode="light"] .tl-avg { stroke: rgba(13,13,20,0.4); }
    .tl-dates {
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
      font-family: var(--font-card-display);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--card-muted);
    }

    /* Tooltip */
    .tl-tooltip {
      position: fixed;
      display: none;
      padding: 6px 10px;
      background: var(--card-bg);
      border: 1px solid var(--card-rule);
      border-radius: var(--radius-md);
      font-family: var(--font-card-display);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--card-text);
      pointer-events: none;
      z-index: 9999;
      white-space: nowrap;
    }
    [data-mode="light"] .tl-tooltip { background: #ffffff; border-color: var(--site-border); }

    /* ── Game log ───────────────────────────────────────────────────── */
    .gl-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .gl-table th {
      font-family: var(--font-card-display);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--site-muted);
      padding: 0 12px 10px;
      text-align: left;
      border-bottom: 1px solid var(--site-border);
    }
    .gl-table th:not(:first-child) { text-align: right; }
    /* Tighten OPP column — biggest source of excess whitespace */
    .gl-table th.gl-th-opp,
    .gl-table td.gl-opp { width: 90px; }
    .gl-table td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--site-border);
      font-family: var(--font-card-display);
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--site-white);
    }
    .gl-table td:not(:first-child) { text-align: right; }
    .gl-table tr:last-child td { border-bottom: none; }
    .gl-table tr:hover td { background: var(--card-panel-bg); }

    /* Specificity: .gl-table .gl-xxx beats .gl-table td so colors apply in both modes */
    .gl-table .gl-opp  { color: var(--site-muted); }
    .gl-table .gl-win  { color: #2dd48e; }
    .gl-table .gl-loss { color: #ff5577; }
    [data-mode="light"] .gl-table .gl-win  { color: #00874e; }
    [data-mode="light"] .gl-table .gl-loss { color: #e8002d; }
    .gl-table .gl-pos  { color: #2dd48e; font-size: 15px; }
    .gl-table .gl-neg  { color: #ff5577; font-size: 15px; }
    [data-mode="light"] .gl-table .gl-pos { color: #00874e; }
    [data-mode="light"] .gl-table .gl-neg { color: #e8002d; }

    .gl-view-all {
      display: block;
      margin-top: 12px;
      font-family: var(--font-card-display);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--site-muted);
      text-decoration: none;
      text-align: right;
      transition: color 0.12s;
    }
    .gl-view-all:hover { color: var(--site-white); }

    /* ── Peers section — editorial roster rows ──────────────────────── */
    .peers-list {
      background: var(--site-card);
      border: 1px solid var(--site-border);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .peers-list .lb-row:last-child { border-bottom: none; }
    .peers-list .lb-row:hover,
    .peers-list .lb-row--top:hover { background: var(--card-panel-bg); }

    .lb-row {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px;
      border-left: 3px solid transparent;
      border-bottom: 1px solid var(--site-border);
      text-decoration: none; color: inherit;
      background: transparent; transition: background 0.12s;
    }
    .lb-row--top { padding: 13px 14px; background: var(--row-tint, transparent); }
    .lb-rank {
      font-family: var(--font-card-display); font-size: 18px; font-weight: 900;
      color: rgba(255,255,255,0.16); min-width: 26px; text-align: right;
      letter-spacing: -0.01em; font-variant-numeric: tabular-nums; flex-shrink: 0;
    }
    [data-mode="light"] .lb-rank { color: rgba(13,13,20,0.18); }
    .lb-row--top .lb-rank { color: rgba(255,255,255,0.5); font-size: 22px; }
    [data-mode="light"] .lb-row--top .lb-rank { color: rgba(13,13,20,0.5); }
    .lb-logo { width: 20px; height: 20px; object-fit: contain; flex-shrink: 0; opacity: 0.88; }
    .lb-row--top .lb-logo { width: 26px; height: 26px; opacity: 1; }
    .lb-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .lb-name {
      font-family: var(--font-site-body); font-size: 13px; font-weight: 600;
      color: var(--site-white); white-space: nowrap; overflow: hidden;
      text-overflow: ellipsis; line-height: 1.2;
    }
    .lb-row--top .lb-name { font-size: 14px; }
    .lb-meta {
      font-family: var(--font-card-display); font-size: 10px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--site-muted);
    }
    .lb-val {
      font-family: var(--font-site-display); font-size: 15px; font-weight: 700;
      font-variant-numeric: tabular-nums; color: var(--site-white);
      min-width: 40px; text-align: right; flex-shrink: 0;
    }
    .lb-row--top .lb-val { font-size: 18px; min-width: 46px; }
    .lb-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    /* ── Methodology ────────────────────────────────────────────────── */
    .p-method {
      padding: 20px 0 4px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
    }
    .p-method-text { font-size: 13px; color: var(--site-muted); line-height: 1.55; }
    .p-method-link {
      font-family: var(--font-card-display);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--site-muted);
      text-decoration: none;
      transition: color 0.12s;
      white-space: nowrap;
    }
    .p-method-link:hover { color: var(--site-white); }

    /* ── Footer ─────────────────────────────────────────────────────── */
    .stats-footer {
      text-align: center;
      padding: 20px 0;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--site-muted);
      font-family: var(--font-mono);
    }

    /* ══ Component A: Upgraded percentile bar ════════════════════════ */
    .pct-b {
      background: var(--card-panel-bg);
      border: 1px solid var(--card-rule);
      border-radius: var(--radius-md);
      padding: 18px 22px 22px;
    }
    [data-mode="light"] .pct-b { border-color: var(--site-border); }
    .pct-b-hdr { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:14px; }
    .pct-b-eyebrow {
      font-family: var(--font-card-display); font-weight:700;
      font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:var(--card-muted);
    }
    .pct-b-rank {
      font-family: var(--font-card-display); font-weight:700;
      font-size:22px; color:#00e676; letter-spacing:.01em;
    }
    .pct-b-rank.pct-neg { color:#ff5577; }
    [data-mode="light"] .pct-b-rank { color:#00874e; }
    [data-mode="light"] .pct-b-rank.pct-neg { color:#e8002d; }
    .pct-b-rank .tot { color:var(--card-muted); font-family:var(--font-mono); font-weight:400; font-size:13px; margin-left:4px; }
    .pct-b-track {
      position:relative; height:14px;
      background:#0e0e0e; border:1px solid #1a1a1a; border-radius:2px; overflow:visible;
    }
    [data-mode="light"] .pct-b-track { background:var(--card-rule); border-color:var(--site-border); }
    .pct-b-fill {
      position:absolute; left:0; top:0; bottom:0;
      background: linear-gradient(90deg, rgba(0,192,120,0) 0%, rgba(0,192,120,.45) 70%, #00c078 100%);
      border-radius:2px;
    }
    .pct-b-fill.pct-neg {
      background: linear-gradient(90deg, rgba(255,85,119,0) 0%, rgba(255,85,119,.45) 70%, #ff5577 100%);
    }
    [data-mode="light"] .pct-b-fill { background: linear-gradient(90deg, rgba(0,135,78,0) 0%, rgba(0,135,78,.5) 70%, #00874e 100%); }
    [data-mode="light"] .pct-b-fill.pct-neg { background: linear-gradient(90deg, rgba(232,0,45,0) 0%, rgba(232,0,45,.5) 70%, #e8002d 100%); }
    .pct-b-marks { position:absolute; inset:0; display:flex; }
    .pct-b-marks span { flex:1; border-right:1px solid rgba(255,255,255,.03); }
    [data-mode="light"] .pct-b-marks span { border-right-color: rgba(13,13,20,.06); }
    .pct-b-you {
      position:absolute; top:-4px; bottom:-4px; width:3px;
      transform:translateX(-50%);
      background:#00c078; box-shadow:0 0 10px rgba(0,192,120,.8);
      z-index:2; border-radius:1px;
    }
    .pct-b-you.pct-neg { background:#ff5577; box-shadow:0 0 10px rgba(255,85,119,.8); }
    [data-mode="light"] .pct-b-you { background:#00874e; box-shadow:none; }
    [data-mode="light"] .pct-b-you.pct-neg { background:#e8002d; box-shadow:none; }
    .pct-b-ticks {
      display:flex; justify-content:space-between;
      font-family:var(--font-mono); font-size:9.5px; color:var(--card-muted);
      letter-spacing:.08em; margin-top:7px;
    }
    .pct-b-you-label { color:#00e676; font-weight:700; }
    [data-mode="light"] .pct-b-you-label { color:#00874e; }

    /* ══ Component B: Radar overlay ══════════════════════════════════ */
    .radar-card {
      background: var(--card-panel-bg);
      border: 1px solid var(--card-rule);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    [data-mode="light"] .radar-card { border-color: var(--site-border); }
    .radar-hdr {
      padding: 12px 18px;
      display:flex; justify-content:space-between; align-items:baseline;
      border-bottom: 1px solid var(--card-rule);
    }
    [data-mode="light"] .radar-hdr { border-bottom-color: var(--site-border); }
    .radar-eyebrow {
      font-family:var(--font-card-display); font-weight:700;
      font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:var(--card-muted);
    }
    .radar-legend {
      display:flex; gap:12px;
      font-family:var(--font-mono); font-size:10px; color:var(--card-muted); align-items:center;
    }
    .radar-legend .sw { display:inline-block; width:10px; height:3px; margin-right:5px; vertical-align:2px; border-radius:1px; }
    .radar-grid { display:grid; grid-template-columns: 280px 1fr; }
    @media (max-width:640px) { .radar-grid { grid-template-columns:1fr; } }
    .radar-wrap { padding:14px; }
    .radar-wrap svg { width:100%; height:auto; display:block; }
    .radar-list { border-left: 1px solid var(--card-rule); padding:14px 18px; }
    [data-mode="light"] .radar-list { border-left-color: var(--site-border); }
    .radar-row {
      display:grid; grid-template-columns: 22px 16px 1fr 64px 10px;
      gap:10px; align-items:center;
      padding:8px 0; border-bottom: 1px solid var(--card-rule);
    }
    [data-mode="light"] .radar-row { border-bottom-color: var(--site-border); }
    .radar-row:last-of-type { border-bottom:none; }
    .radar-dot-n { font-family:var(--font-mono); color:var(--card-muted); font-size:11px; }
    .radar-puck { width:14px; height:14px; border-radius:50%; border:2px solid; flex-shrink:0; }
    .radar-nm {
      font-family:var(--font-card-display); font-weight:600;
      color:var(--card-text); letter-spacing:.015em; font-size:13px;
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    .radar-nm .rt { color:var(--card-muted); font-family:var(--font-mono); font-size:10.5px; margin-left:6px; font-weight:400; }
    .radar-v {
      font-family:var(--font-card-display); font-variant-numeric:tabular-nums;
      color:var(--card-text); font-weight:700; text-align:right; font-size:14px; letter-spacing:.02em;
    }
    .radar-dot-pct { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
    .radar-caption { margin-top:12px; font-size:12px; color:var(--card-muted); line-height:1.55; }

    /* ══ Component C: Calendar heatmap ═══════════════════════════════ */
    .hm-card {
      background: var(--card-panel-bg);
      border: 1px solid var(--card-rule);
      border-radius: var(--radius-md);
      padding: 18px 20px 20px;
    }
    [data-mode="light"] .hm-card { border-color: var(--site-border); }
    .hm-hdr { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:16px; }
    .hm-eyebrow {
      font-family:var(--font-card-display); font-weight:700;
      font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:var(--card-muted);
    }
    .hm-hint { font-family:var(--font-mono); font-size:10px; color:var(--card-muted); }
    .hm-cal { display:grid; grid-template-columns: 28px repeat(var(--hm-cols), 1fr); gap:3px; align-items:center; }
    .hm-row { display:contents; }
    .hm-label { font-family:var(--font-mono); font-size:12px; color:var(--card-muted); letter-spacing:.1em; text-transform:uppercase; text-align:right; padding-right:5px; }
    .hm-cell { aspect-ratio:1; border-radius:2px; background:#0e0e0e; border:1px solid #161616; position:relative; cursor:default; transition:opacity .1s; }
    .hm-cell:hover { opacity:.8; }
    .hm-cell.l1 { background:#143822; border-color:#1b5232; }
    .hm-cell.l2 { background:#1e5e33; border-color:#268046; }
    .hm-cell.l3 { background:#2aa15a; border-color:#3dc16f; }
    .hm-cell.l4 { background:#00e676; border-color:#00e676; box-shadow:0 0 6px rgba(0,230,118,.35); }
    .hm-cell.n1 { background:#3a1220; border-color:#551a2c; }
    .hm-cell.n2 { background:#801930; border-color:var(--hgb-red); }
    [data-mode="light"] .hm-cell    { background:rgba(13,13,20,.05); border-color:var(--site-border); }
    [data-mode="light"] .hm-cell.l1 { background:#d4f0df; border-color:#b8e4c7; }
    [data-mode="light"] .hm-cell.l2 { background:#a8d8be; border-color:#85c7a0; }
    [data-mode="light"] .hm-cell.l3 { background:#5bb585; border-color:#3e9e6c; }
    [data-mode="light"] .hm-cell.l4 { background:#00874e; border-color:#00874e; box-shadow:none; }
    [data-mode="light"] .hm-cell.n1 { background:#fce4e4; border-color:#f5b8b8; }
    [data-mode="light"] .hm-cell.n2 { background:#f5b8b8; border-color:var(--hgb-red); }
    .hm-legend { display:flex; justify-content:space-between; align-items:center; margin-top:16px; flex-wrap:wrap; gap:10px; }
    .hm-scale { display:flex; align-items:center; gap:5px; font-family:var(--font-mono); font-size:12px; color:var(--card-muted); letter-spacing:.06em; }
    .hm-scale .sw { width:11px; height:11px; border-radius:2px; flex-shrink:0; }
    .hm-summary { display:flex; gap:20px; }
    .hm-stat { display:flex; flex-direction:column; }
    .hm-stat .k { font-family:var(--font-mono); font-size:12px; color:var(--card-muted); letter-spacing:.1em; text-transform:uppercase; }
    .hm-stat .v { font-family:var(--font-card-display); font-weight:700; font-size:18px; color:var(--card-text); letter-spacing:.01em; font-variant-numeric:tabular-nums; }
    .hm-stat .v.good { color:#00e676; }
    [data-mode="light"] .hm-stat .v.good { color:#00874e; }

    /* ══ Season sparkline ══════════════════════════════════════════════ */
    .tl-wrap { margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--card-rule); }
    .tl-label-row {
      display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;
      font-family: var(--font-mono); font-size: 10px; letter-spacing: .12em;
      text-transform: uppercase; color: var(--card-muted);
    }
    .tl-trend-tag { display: flex; align-items: center; gap: 5px; }
    .tl-trend-line { width: 18px; height: 2px; background: rgba(255,255,255,0.55); border-radius: 1px; }
    [data-mode="light"] .tl-trend-line { background: rgba(0,0,0,0.35); }
    .tl-svg { width: 100%; height: 90px; display: block; }
    /* Season sparkline trendline (5-game rolling avg) — paired with .tl-trend-line. */
    .tl-sparkline-avg { stroke: rgba(255,255,255,0.55); }
    [data-mode="light"] .tl-sparkline-avg { stroke: rgba(13,13,20,0.4); }

    /* ══ Game log divider ═══════════════════════════════════════════════ */
    .gl-div {
      display: flex; align-items: center; gap: 10px; margin: 14px 0 0;
      font-family: var(--font-mono); font-size: 10px; letter-spacing: .16em;
      text-transform: uppercase; color: var(--site-muted);
    }
    .gl-div::before, .gl-div::after { content: ''; flex: 1; height: 1px; background: var(--site-border); }

    /* ══ Component D: Inline spark recent games ════════════════════════ */
    .sg-card { background:var(--site-card); border:1px solid var(--site-border); border-radius:var(--radius-md); overflow:hidden; }
    .sg-hdr { padding:12px 20px 10px; display:flex; justify-content:space-between; align-items:baseline; border-bottom:1px solid var(--site-border); }
    .sg-eyebrow { font-family:var(--font-card-display); font-weight:700; font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:var(--site-muted); }
    .sg-sub { font-family:var(--font-mono); font-size:10px; color:var(--site-muted); letter-spacing:.06em; }
    .sg-colh {
      display:grid; grid-template-columns: 72px 72px 72px 1fr 56px 80px;
      gap:12px; padding:8px 20px;
      font-family:var(--font-mono); font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--site-muted);
      border-bottom:1px solid var(--site-border);
    }
    .sg-row {
      display:grid; grid-template-columns: 72px 72px 72px 1fr 56px 80px;
      gap:12px; padding:9px 20px; align-items:center;
      border-bottom:1px solid var(--site-border);
      position:relative; font-size:13px; transition:background .1s;
    }
    .sg-row:last-of-type { border-bottom:none; }
    .sg-row:hover { background:rgba(255,255,255,.03); }
    [data-mode="light"] .sg-row:hover { background:rgba(13,13,20,.03); }
    .sg-row.sg-best  { background: linear-gradient(90deg, rgba(0,192,120,.07), transparent 35%); }
    .sg-row.sg-worst { background: linear-gradient(90deg, rgba(232,0,45,.08), transparent 35%); }
    .sg-row::before { content:""; position:absolute; left:0; top:4px; bottom:4px; width:2px; background:transparent; }
    .sg-row.sg-best::before  { background:#00c078; }
    .sg-row.sg-worst::before { background:var(--hgb-red); }
    .sg-date { font-family:var(--font-mono); color:var(--site-muted); font-size:11px; letter-spacing:.06em; }
    .sg-opp  { font-family:var(--font-card-display); font-weight:600; color:var(--site-white); font-size:13px; letter-spacing:.02em; white-space:nowrap; }
    .sg-res  { font-family:var(--font-card-display); font-weight:700; font-size:12px; letter-spacing:.04em; }
    .sg-res-w { color:#00c078; }
    .sg-res-l { color:var(--hgb-red); }
    [data-mode="light"] .sg-res-w { color:#00874e; }
    .sg-spark { display:flex; align-items:center; gap:3px; height:22px; }
    .sg-seg {
      height:16px; border-radius:1px; display:flex; align-items:center; justify-content:flex-start;
      font-family:var(--font-mono); font-size:10px; color:rgba(0,0,0,.6); font-weight:700;
      padding:0 4px; letter-spacing:0; min-width:1px;
    }
    .sg-g { background:#00c078; }
    .sg-a { background:#7ee2a8; }
    [data-mode="light"] .sg-g { background:#00874e; color:rgba(255,255,255,.8); }
    [data-mode="light"] .sg-a { background:#5db88a; color:rgba(255,255,255,.8); }
    .sg-empty { background:#151515; height:2px; flex:1; min-width:20px; border-radius:1px; }
    [data-mode="light"] .sg-empty { background:var(--site-border); }
    .sg-pts { font-family:var(--font-card-display); font-variant-numeric:tabular-nums; color:var(--site-white); font-weight:700; font-size:14px; text-align:right; letter-spacing:.02em; }
    .sg-hgb { font-family:var(--font-card-display); font-variant-numeric:tabular-nums; font-weight:700; font-size:15px; text-align:right; letter-spacing:.02em; }
    .sg-pos { color:#00c078; }
    .sg-neg { color:var(--hgb-red); }
    [data-mode="light"] .sg-pos { color:#00874e; }
    .sg-callout {
      position:absolute; top:7px; right:24px;
      font-family:var(--font-card-display); font-weight:700; font-size:10px;
      letter-spacing:.18em; padding:1px 5px; border-radius:2px; text-transform:uppercase;
    }
    .sg-callout-b { color:#00c078; border:1px solid rgba(0,192,120,.3); background:rgba(0,192,120,.06); }
    .sg-callout-w { color:var(--hgb-red); border:1px solid rgba(232,0,45,.35); background:rgba(232,0,45,.06); }
    .sg-foot {
      display:flex; justify-content:space-between; padding:12px 20px;
      border-top:1px solid var(--site-border);
      font-family:var(--font-card-display); font-weight:700; font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--site-muted);
    }
    .sg-foot a { color:var(--hgb-red); text-decoration:none; }
    .sg-foot a:hover { opacity:.7; }
  </style>
</head>
<body>
  <PageHeader activePage="stats" />

  <main class="player-main">

    <!-- BREADCRUMB -->
    <nav class="p-breadcrumb"><a href="/stats">← STATS</a></nav>

    <!-- HERO CARD -->
    <div class="p-hero" style={`border-left-color: ${teamColor}`}>
      <div class="p-hero-top">
        <div class="p-hero-identity">
          <img
            class="p-hero-logo"
            src={`https://assets.nhle.com/logos/nhl/svg/${player.team_abbrev}_light.svg`}
            alt={player.team_abbrev}
            width="60" height="60"
          />
          <div>
            <div class="p-hero-badges">
              <span class="p-badge">{player.pos}</span>
              <span class="p-badge">{player.team_abbrev}</span>
            </div>
            <div class="p-hero-name">
              <span class="p-first">{player.first_name}</span>
              <span class="p-last">{player.last_name}</span>
            </div>
          </div>
        </div>
        <div class={`p-gs-chip${isNeg ? ' chip-neg' : ''}`}>
          <div class="p-chip-val">{gsSign}{avgGs.toFixed(2)}</div>
          <div class="p-chip-label">AVG HGB GAME SCORE</div>
        </div>
      </div>

      <div class="p-tiles-wrap p-tiles-dark">
        <PercentileTile label="HGBScore V2" rawVal={`${gsSign}${avgGs.toFixed(2)}`}       pct={player.percentiles_vs_pos.game_score} mode="dark" />
        <PercentileTile label="Goals / 60"  rawVal={player.rates_per_60.goals.toFixed(2)} pct={player.percentiles_vs_pos.goals}      mode="dark" />
        <PercentileTile label="xG / 60"     rawVal={player.rates_per_60.ixg.toFixed(2)}   pct={player.percentiles_vs_pos.ixg}        mode="dark" />
        <PercentileTile label="A1 / 60"     rawVal={player.rates_per_60.a1.toFixed(2)}    pct={player.percentiles_vs_pos.a1}         mode="dark" />
      </div>
      <div class="p-tiles-wrap p-tiles-light">
        <PercentileTile label="HGBScore V2" rawVal={`${gsSign}${avgGs.toFixed(2)}`}       pct={player.percentiles_vs_pos.game_score} mode="light" />
        <PercentileTile label="Goals / 60"  rawVal={player.rates_per_60.goals.toFixed(2)} pct={player.percentiles_vs_pos.goals}      mode="light" />
        <PercentileTile label="xG / 60"     rawVal={player.rates_per_60.ixg.toFixed(2)}   pct={player.percentiles_vs_pos.ixg}        mode="light" />
        <PercentileTile label="A1 / 60"     rawVal={player.rates_per_60.a1.toFixed(2)}    pct={player.percentiles_vs_pos.a1}         mode="light" />
      </div>
    </div>

    <!-- SEASON STRIP -->
    <div class="p-strip">
      <span class="p-strip-item">{player.gp} GP</span>
      <span class="p-strip-dot">·</span>
      <span class="p-strip-item">{fmtToi(player.toi_avg_sec)} TOI/g</span>
      <span class="p-strip-dot">·</span>
      <span class="p-strip-item">{totalGoals} G</span>
      <span class="p-strip-dot">·</span>
      <span class="p-strip-item">{totalAssists} A</span>
      <span class="p-strip-dot">·</span>
      <span class="p-strip-item">{totalGoals + totalAssists} PTS</span>
      <span class="p-strip-dot">·</span>
      <span class={`p-strip-item p-strip-gs${isNeg ? ' strip-neg' : ''}`}>{gsSign}{avgGs.toFixed(2)} HGBScore V2</span>
      <span class="p-strip-dot">·</span>
      <span class="p-strip-rank">#{rankInfo.rank} of {rankInfo.total} {posPlural.toLowerCase()}</span>
    </div>

    <!-- COMPONENT A: Upgraded percentile bar with gradient + glow -->
    <section class="p-section">
      <SectionEyebrow label={`VS ${posPlural} THIS SEASON`} color="muted" />
      <div class="p-section-body">
        <div class="pct-b">
          <div class="pct-b-hdr">
            <span class="pct-b-eyebrow">position peers · min 20 GP</span>
            <span class={`pct-b-rank${isNeg ? ' pct-neg' : ''}`}>
              #{rankInfo.rank}<span class="tot"> / {rankInfo.total}</span>
            </span>
          </div>
          <div class="pct-b-track">
            <div class={`pct-b-fill${isNeg ? ' pct-neg' : ''}`} style={`width:${markerPct.toFixed(1)}%`}></div>
            <div class="pct-b-marks">{Array.from({length:10}).map(() => <span></span>)}</div>
            <div class={`pct-b-you${isNeg ? ' pct-neg' : ''}`} style={`left:${markerPct.toFixed(1)}%`}></div>
          </div>
          <div class="pct-b-ticks">
            <span>P10</span><span>P25</span><span>P50</span><span>P75</span><span>P90</span>
            <span class={pct >= 99 ? 'pct-b-you-label' : ''}>
              {pct >= 99 ? 'YOU · ' : ''}{ordinalSuffix(pct)} PCT
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- COMPONENT B: Radar overlay — shows shape, not just rank -->
    {peers.length > 0 && (
      <section class="p-section">
        <SectionEyebrow label={`SIMILAR ${posPlural} THIS SEASON`} color="muted" />
        <div class="p-section-body">
          <div class="radar-card">
            <div class="radar-hdr">
              <span class="radar-eyebrow">6-axis comparison · vector distance</span>
              <span class="radar-legend">
                <span><span class="sw" style={`background:${teamColor}`}></span>You</span>
                {peers.slice(0, 3).map((peer, pi) => (
                  <span>
                    <span class="sw" style={`background:${peerColors[pi]}`}></span>
                    {peer.display_name.split(' ')[0][0]}. {peer.display_name.split(' ').slice(1).join(' ')}
                  </span>
                ))}
              </span>
            </div>
            <div class="radar-grid">
              <div class="radar-wrap">
                <svg viewBox="-160 -160 320 320">
                  <!-- rings -->
                  <g fill="none" stroke="#1a1a1a" stroke-width="1">
                    {rings.map(r => <polygon points={r}/>)}
                  </g>
                  <!-- axis lines -->
                  <g stroke="#1a1a1a" stroke-width="1">
                    {axisEnds.map(([x, y]) => <line x1="0" y1="0" x2={x} y2={y}/>)}
                  </g>
                  <!-- axis labels -->
                  <g font-family="Oswald, sans-serif" font-size="9.5" fill="#777" font-weight="700" letter-spacing="1.4">
                    <text x="0" y="-134" text-anchor="middle">HGBSCORE</text>
                    <text x="124" y="-66" text-anchor="start">xG/60</text>
                    <text x="124" y="74" text-anchor="start">SHOTS</text>
                    <text x="0" y="148" text-anchor="middle">FINISHING</text>
                    <text x="-124" y="74" text-anchor="end">PEN DRAWN</text>
                    <text x="-124" y="-66" text-anchor="end">DEFENSE</text>
                  </g>
                  <!-- peer polygons behind -->
                  {peers.slice(0, 3).map((peer, pi) => (
                    <polygon
                      points={radarPts(peer.pcts)}
                      fill={hexToRgba(peerColors[pi], 0.12)}
                      stroke={peerColors[pi]}
                      stroke-width="1.4"
                      stroke-dasharray={pi > 0 ? "4 3" : undefined}
                    />
                  ))}
                  <!-- current player on top -->
                  <polygon
                    points={playerRadarPts}
                    fill={hexToRgba(teamColor, 0.22)}
                    stroke={teamColor}
                    stroke-width="2.2"
                  />
                  {playerRadarNodes.map(([x, y]) => (
                    <circle cx={x} cy={y} r="3.5" fill={teamColor}/>
                  ))}
                </svg>
              </div>
              <div class="radar-list">
                <!-- Current player row -->
                <div class="radar-row">
                  <span class="radar-dot-n">—</span>
                  <span class="radar-puck" style={`border-color:${teamColor}; background:${teamColor};`}></span>
                  <span class="radar-nm">{player.display_name} <span class="rt">{player.team_abbrev} · {player.gp} GP</span></span>
                  <span class="radar-v">{gsSign}{avgGs.toFixed(2)}</span>
                  <span class="radar-dot-pct" style={`background:${dotColor(pct)}`}></span>
                </div>
                {peers.map((peer, pi) => (
                  <div class="radar-row">
                    <span class="radar-dot-n">0{pi + 1}</span>
                    <span class="radar-puck" style={`border-color:${peerColors[pi]}; border-style:${pi > 0 ? 'dashed' : 'solid'};`}></span>
                    <span class="radar-nm">
                      <a href={`/stats/player/${peer.slug}`} style="color:inherit;text-decoration:none">{peer.display_name}</a>
                      {' '}<span class="rt">{peer.team_abbrev} · {peer.gp} GP</span>
                    </span>
                    <span class="radar-v">{peer.avg_gs_display >= 0 ? '+' : ''}{peer.avg_gs_display.toFixed(2)}</span>
                    <span class="radar-dot-pct" style={`background:${dotColor(peer.gs_pct)}`}></span>
                  </div>
                ))}
                <p class="radar-caption">Shape matters more than rank — the radar shows <em>why</em> these players are similar, not just that they are.</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- COMPONENT C+D: Calendar heatmap + recent games — stacked as one section -->
    <section class="p-section">
      <SectionEyebrow label="GAME LOG" color="muted" />
      <div class="p-section-body">
        <div class="hm-card">
          <div class="hm-hdr">
            <span class="hm-eyebrow">Season heatmap · HGBScore intensity</span>
            <span class="hm-hint">{playerGames.length} games · hover for detail</span>
          </div>
          <div class="hm-cal" style={`--hm-cols:${calCols}`}>
            {calMonths.map(month => (
              <div class="hm-row">
                <span class="hm-label">{month.label}</span>
                {month.games.map(g => (
                  <span
                    class={`hm-cell ${g.level} ${g.win ? 'win' : 'loss'}`}
                    title={`${g.gs >= 0 ? '+' : ''}${g.gs.toFixed(2)} · ${g.win ? 'W' : 'L'}`}
                  ></span>
                ))}
                {Array.from({length: calCols - month.games.length}).map(() => (
                  <span class="hm-cell l0"></span>
                ))}
              </div>
            ))}
          </div>
          <div class="hm-legend">
            <div class="hm-scale">
              <span>LOW</span>
              <span class="sw" style="background:#0e0e0e; border:1px solid #1a1a1a;"></span>
              <span class="sw" style="background:#143822;"></span>
              <span class="sw" style="background:#1e5e33;"></span>
              <span class="sw" style="background:#2aa15a;"></span>
              <span class="sw" style="background:#00e676;"></span>
              <span>ELITE</span>
              <span style="margin-left:10px;">·</span>
              <span class="sw" style="background:#801930; margin-left:6px;"></span>
              <span>BELOW AVG</span>
            </div>
            <div class="hm-summary">
              <div class="hm-stat">
                <span class="k">SEASON AVG</span>
                <span class={`v${!isNeg ? ' good' : ''}`}>{gsSign}{avgGs.toFixed(2)}</span>
              </div>
              <div class="hm-stat">
                <span class="k">TOTAL G</span>
                <span class="v">{totalGoals}</span>
              </div>
              <div class="hm-stat">
                <span class="k">TOTAL A</span>
                <span class="v">{totalAssists}</span>
              </div>
            </div>
          </div>
          <!-- Season sparkline -->
          <div class="tl-wrap">
            <div class="tl-label-row">
              <span>Game 1 → {playerGames.length}</span>
              <span class="tl-trend-tag">
                <span class="tl-trend-line"></span>
                5-game rolling avg
              </span>
            </div>
            <svg class="tl-svg" viewBox={`0 0 ${playerGames.length} ${TL_H}`} preserveAspectRatio="none">
              <line x1="0" y1={TL_MID} x2={playerGames.length} y2={TL_MID} stroke="#2a2a2a" stroke-width="0.5"/>
              {playerGames.map((g, i) => {
                const pos = g.gs_display >= 0;
                const bh  = pos
                  ? Math.max((g.gs_display / dataMax) * TL_POS_H, 0.8)
                  : Math.max((Math.abs(g.gs_display) / Math.abs(dataMin)) * TL_NEG_H, 0.8);
                return <rect
                  x={i + 0.08}
                  y={pos ? (TL_MID - bh).toFixed(1) : TL_MID.toString()}
                  width="0.84"
                  height={bh.toFixed(1)}
                  fill={pos ? '#1e5e33' : '#801930'}
                />;
              })}
              <polyline class="tl-sparkline-avg" points={tlAvgPts} fill="none" stroke-width="0.6" stroke-linejoin="round" stroke-linecap="round"/>
            </svg>
          </div>
        </div>
        <div class="gl-div">LAST {recentGames.length} GAMES</div>
        <div class="sg-card" style="margin-top:12px;">
          <div class="sg-hdr">
            <span class="sg-eyebrow">Last {recentGames.length} games · full season log →</span>
            <span class="sg-sub">avg HGB {gsSign}{avgGs.toFixed(2)} · {fmtToi(player.toi_avg_sec)} TOI/g</span>
          </div>
          <div class="sg-colh">
            <span>Date</span><span>Opp</span><span>Result</span>
            <span style="padding-left:4px">Performance</span>
            <span style="text-align:right">Pts</span><span style="text-align:right">HGBScore</span>
          </div>
          {recentGames.map((g, i) => {
            const isBest  = i === recentBestI;
            const isWorst = i === recentWorstI;
            const result  = g.team_score > g.opp_score ? 'W' : g.team_score < g.opp_score ? 'L' : 'T';
            const vs      = g.is_home ? 'vs' : '@';
            const pts     = g.goals + g.assists;
            const s2      = g.gs_display >= 0 ? '+' : '';
            const goalW   = Math.min(g.goals * 14, 40);
            const assistW = Math.min(g.assists * 11, 33);
            return (
              <div class={`sg-row${isBest ? ' sg-best' : isWorst ? ' sg-worst' : ''}`}>
                <span class="sg-date">{fmtDate(g.game_date)}</span>
                <span class="sg-opp">{vs} {g.opp_abbrev}</span>
                <span class={`sg-res sg-res-${result.toLowerCase()}`}>{result} {g.team_score}–{g.opp_score}</span>
                <div class="sg-spark">
                  {g.goals > 0 && <span class="sg-seg sg-g" style={`width:${goalW}%`}>{g.goals}G</span>}
                  {g.assists > 0 && <span class="sg-seg sg-a" style={`width:${assistW}%`}>{g.assists}A</span>}
                  <span class="sg-empty"></span>
                </div>
                <span class="sg-pts">{pts}</span>
                <span class={`sg-hgb sg-${g.gs_display >= 0 ? 'pos' : 'neg'}`}>{s2}{g.gs_display.toFixed(2)}</span>
                {isBest  && <span class="sg-callout sg-callout-b">★ SEASON HIGH</span>}
                {isWorst && <span class="sg-callout sg-callout-w">QUIETEST</span>}
              </div>
            );
          })}
          <div class="sg-foot">
            <span>{recentGames.length} OF {playerGames.length} GAMES</span>
            <a href="#">VIEW FULL SEASON LOG →</a>
          </div>
        </div>
      </div>
    </section>


    <!-- METHODOLOGY -->
    <div class="p-method">
      <span class="p-method-text">
        HGBScore V2 combines individual shot quality, on-ice xG, finishing skill, and penalties drawn/taken — all rate-adjusted per 60 minutes. Percentiles vs {posPlural.toLowerCase()} with 20+ GP.
      </span>
      <a href="/stats" class="p-method-link">HOW WE MEASURE →</a>
    </div>

  </main>

  <footer class="stats-footer">HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026</footer>

  <div class="tl-tooltip" id="tl-tip"></div>

  <script>
    const tip = document.getElementById('tl-tip')!;
    document.querySelectorAll<SVGRectElement>('.tl-bar').forEach(bar => {
      bar.addEventListener('mousemove', (e: MouseEvent) => {
        const d = bar.dataset;
        const gs = parseFloat(d.gs ?? '0');
        const vs = d.home === '1' ? 'vs' : '@';
        tip.textContent = `${d.date} · ${vs} ${d.opp} · ${gs >= 0 ? '+' : ''}${gs.toFixed(2)}`;
        tip.style.display = 'block';
        tip.style.left = `${e.clientX + 12}px`;
        tip.style.top  = `${e.clientY - 32}px`;
      });
      bar.addEventListener('mouseleave', () => { tip.style.display = 'none'; });
    });
    document.addEventListener('scroll', () => { tip.style.display = 'none'; });
  </script>

</body>
</html>
