---
// HockeyGameBot — /stats/edge-compare — Labs
// Pick two players, view their NHL Edge tracking side-by-side. Reuses the shared
// Edge panel design (src/styles/edge-panel.css + src/lib/edge-panel.ts) so it
// stays pixel-faithful to the single-season player page.
import Nav from '../../components/Nav.astro';
import ExploreSubnav from '../../components/ExploreSubnav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import EdgeCompare, { type EdgePlayer } from '../../components/react/EdgeCompare';
import { loadPlayers } from '../../lib/stats-loader';

// Flatten to the fields the tool needs: PlayerSearch fields + the edge object.
const comparePlayers: EdgePlayer[] = loadPlayers().map(p => ({
  player_id:    p.player_id,
  slug:         p.slug,
  display_name: p.display_name,
  first_name:   p.first_name,
  last_name:    p.last_name,
  team_abbrev:  p.team_abbrev,
  pos:          p.pos,
  gp:           p.gp,
  // PlayerSearch matches against this pre-computed string (API ships it null).
  search_text:  `${p.first_name} ${p.last_name} ${p.display_name} ${p.team_abbrev}`.toLowerCase(),
  edge:         (p.edge ?? null) as EdgePlayer['edge'],
}));

// Two interesting defaults so the page isn't empty on load.
const pick = (last: string) => comparePlayers.find(p => p.last_name === last)?.display_name;
const defaultLeft  = pick('McDavid')   ?? comparePlayers[0]?.display_name;
const defaultRight  = pick('MacKinnon') ?? comparePlayers[1]?.display_name;
---
<!doctype html>
<html lang="en">
<head>
<ThemeScript />
<Fonts />
<meta charset="utf-8" />
<title>Edge Compare — NHL Edge Side-by-Side · HockeyGameBot</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="description" content="Compare any two NHL skaters' Edge tracking data side by side: top speed, hardest shot, bursts, miles skated, zone time, and shot-danger profile. 2025–26 season." />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
<link rel="apple-touch-icon" href="/favicon-180x180.png" />

<meta property="og:title" content="Edge Compare · NHL Edge Side-by-Side · HockeyGameBot" />
<meta property="og:description" content="Compare two NHL skaters' Edge tracking — speed, shot, bursts, zone time — side by side." />
<meta property="og:image" content="https://hockeygamebot.com/og/explore.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://hockeygamebot.com/stats/edge-compare" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="https://hockeygamebot.com/og/explore.png" />

<style is:global>
/* Shared Edge panel styles must be imported before any other rules. */
@import '../../styles/edge-panel.css';

/* ── TOKENS (shared with /stats/explore) ─────────────────────── */
:root {
  --bg:      #EFEEE8;
  --bg-2:    #E8E7E0;
  --surface: #FFFFFF;
  --ink:     #0d0d14;
  --ink-86:  rgba(13,13,20,0.86);
  --ink-72:  rgba(13,13,20,0.72);
  --ink-56:  rgba(13,13,20,0.56);
  --ink-48:  rgba(13,13,20,0.48);
  --ink-32:  rgba(13,13,20,0.32);
  --ink-20:  rgba(13,13,20,0.20);
  --ink-14:  rgba(13,13,20,0.14);
  --ink-10:  rgba(13,13,20,0.10);
  --ink-06:  rgba(13,13,20,0.06);
  --ink-04:  rgba(13,13,20,0.04);
  --red:     #E8002D;
  --green:   #22c55e;
  --grid-line: rgba(13,13,20,0.04);
  --display: "Barlow Condensed", sans-serif;
  --body:    "Barlow", sans-serif;
  --mono:    "JetBrains Mono", monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
  background: var(--bg);
  color: var(--ink);
  font-family: var(--body);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
  min-height: 100vh;
}
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }

/* ── MASTHEAD (matches /stats/explore) ───────────────────────── */
.mast {
  position: relative; overflow: hidden; padding: 0;
  border-bottom: 2px solid var(--ink);
  background-color: var(--bg);
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 96px 96px;
}
.mast-ghost {
  position: absolute; pointer-events: none; user-select: none; z-index: 0;
  font-family: var(--display); font-weight: 800; font-size: 200px; line-height: 0.86;
  text-transform: uppercase; letter-spacing: -0.02em; white-space: nowrap;
  color: rgba(13,13,20,0.06);
  top: 50%; left: 50%; transform: translate(-50%, -50%);
}
.mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.mast-corners .corner { position: absolute; width: 16px; height: 16px; }
.mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 48px 32px 40px; }
.mast-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--display); font-weight: 700;
  font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--ink-48); margin-bottom: 16px;
}
.mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
.mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
.mast-headline {
  font-family: var(--display); font-weight: 800;
  font-size: clamp(36px, 5.5vw, 64px);
  text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em;
  color: var(--ink); margin-bottom: 14px;
}
.mast-headline em { color: var(--red); font-style: normal; }
.mast-lede { font-size: 14px; line-height: 1.65; color: var(--ink-56); max-width: 680px; }
.mast-lede strong { color: var(--ink-86); font-weight: 600; }

.wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

/* ── CARD CHROME (from player page, so EdgePanel renders identically) ── */
.card { background: var(--surface); border: 1px solid var(--ink-14); box-shadow: 0 1px 3px rgba(13,13,20,0.06); }
.card-head { padding: 14px 18px 12px; border-bottom: 1px solid var(--ink-06); display: flex; align-items: baseline; justify-content: space-between; }
.card-eyebrow { font-family: var(--body); font-weight: 700; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(13,13,20,0.72); }
.card-eyebrow .accent { color: var(--red); }
.card-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

/* ── COMPARE TOOL ────────────────────────────────────────────── */
.edge-cmp { padding-top: 32px; }
.edge-cmp-selectors {
  display: grid; grid-template-columns: 1fr auto 1fr; gap: 16px; align-items: end;
  margin-bottom: 16px;
}
.edge-cmp-sel { display: flex; flex-direction: column; gap: 6px; }
.edge-cmp-sel-lbl {
  font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--ink-48);
}
.edge-cmp-vs {
  font-family: var(--display); font-weight: 800; font-size: 18px;
  text-transform: uppercase; color: var(--ink-32); padding-bottom: 9px;
}
.edge-cmp-actions {
  display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  margin-bottom: 20px;
}
.edge-cmp-btn {
  font-family: var(--display); font-weight: 800; font-size: 13px;
  letter-spacing: 0.06em; text-transform: uppercase;
  background: var(--ink); color: var(--bg); border: none;
  padding: 10px 18px; cursor: pointer; transition: opacity 0.15s;
}
.edge-cmp-btn:hover:not(:disabled) { opacity: 0.86; }
.edge-cmp-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.edge-cmp-hint { font-size: 10px; color: var(--ink-48); letter-spacing: 0.04em; }

.edge-cmp-capture { background: var(--bg); padding: 4px; }
.edge-cmp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: start; }

/* Player identity strip atop each panel */
.edge-cmp-id { display: flex; align-items: center; gap: 12px; padding: 12px 18px; background: var(--surface); border-bottom: 1px solid var(--ink-06); }
.edge-cmp-logo { display: inline-flex; align-items: center; justify-content: center; width: 26px; height: 26px; flex-shrink: 0; line-height: 0; }
.edge-cmp-logo svg { width: 100%; height: 100%; display: block; }
.edge-cmp-name { font-family: var(--display); font-weight: 800; font-size: 22px; line-height: 1; color: var(--ink); }
.edge-cmp-meta { font-size: 10px; color: var(--ink-48); letter-spacing: 0.06em; margin-top: 3px; }

.edge-cmp-watermark {
  text-align: center; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--ink-32); padding: 12px 0 4px;
}

@media (max-width: 760px) {
  .mast-inner { padding: 36px 16px 28px; }
  .wrap { padding: 0 16px 60px; }
  .edge-cmp-selectors { grid-template-columns: 1fr; gap: 10px; }
  .edge-cmp-vs { display: none; }
  .edge-cmp-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<!-- MASTHEAD -->
<section class="mast">
  <div class="mast-ghost">EDGE</div>
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-eyebrow"><span class="pip"></span>HGB Edge Compare &middot; Labs</div>
    <div class="mast-card">
      <h1 class="mast-headline">Edge.<br><em>Head to head.</em></h1>
      <p class="mast-lede">
        Pick <strong>two skaters</strong> and put their NHL Edge tracking side by side —
        top speed, hardest shot, bursts, miles skated, zone time, and shot-danger profile.
        Each panel themes to the player's team; <strong>▲</strong> marks who leads each metric.
        2025–26 season.
      </p>
    </div>
  </div>
</section>

<ExploreSubnav currentPath={Astro.url.pathname} />

<div class="wrap">
  <EdgeCompare
    client:load
    players={comparePlayers}
    defaultLeft={defaultLeft}
    defaultRight={defaultRight}
  />
</div>

</body>
</html>
