---
// HockeyGameBot — /stats/edge-compare — Labs
// Pick two players, view their NHL Edge tracking side-by-side. Reuses the shared
// Edge panel design (src/styles/edge-panel.css + src/lib/edge-panel.ts) so it
// stays pixel-faithful to the single-season player page.
import StatsLayout from '../../layouts/StatsLayout.astro';
import StatsMasthead from '../../components/StatsMasthead.astro';
import EdgeCompare, { type EdgePlayer } from '../../components/react/EdgeCompare';
import { loadPlayers } from '../../lib/stats-loader';

// Flatten to the fields the tool needs: PlayerSearch fields + the edge object.
const comparePlayers: EdgePlayer[] = loadPlayers().map(p => ({
  player_id:    p.player_id,
  slug:         p.slug,
  display_name: p.display_name,
  first_name:   p.first_name,
  last_name:    p.last_name,
  team_abbrev:  p.team_abbrev,
  pos:          p.pos,
  gp:           p.gp,
  // PlayerSearch matches against this pre-computed string (API ships it null).
  search_text:  `${p.first_name} ${p.last_name} ${p.display_name} ${p.team_abbrev}`.toLowerCase(),
  edge:         (p.edge ?? null) as EdgePlayer['edge'],
}));

// Two interesting defaults so the page isn't empty on load.
const pick = (last: string) => comparePlayers.find(p => p.last_name === last)?.display_name;
const defaultLeft  = pick('McDavid')   ?? comparePlayers[0]?.display_name;
const defaultRight  = pick('MacKinnon') ?? comparePlayers[1]?.display_name;
---
<StatsLayout
  title="Edge Compare — NHL Edge Side-by-Side · HockeyGameBot"
  description="Compare any two NHL skaters' Edge tracking data side by side: top speed, hardest shot, bursts, miles skated, zone time, and shot-danger profile. 2025–26 season."
  ogImage="/og/explore.png"
  currentPath={Astro.url.pathname}
>

<StatsMasthead slot="mast" eyebrow="HGB Labs · Edge" ghost="EDGE">
  <Fragment slot="headline">Edge.<br><em>Head to head.</em></Fragment>
  <Fragment slot="lede">
    Put two skaters' NHL Edge tracking side by side: top speed, hardest shot, bursts, miles skated, zone time, and shot-danger profile. Each panel themes to the player's team; <strong>▲</strong> marks who leads.
  </Fragment>
</StatsMasthead>

<div class="wrap">
  <EdgeCompare
    client:load
    players={comparePlayers}
    defaultLeft={defaultLeft}
    defaultRight={defaultRight}
  />
</div>

</StatsLayout>

<style is:global>
/* Shared Edge panel styles must be imported before any other rules. */
@import '../../styles/edge-panel.css';

/* ── CARD CHROME (from player page, so EdgePanel renders identically) ── */
.card { background: var(--surface); border: 1px solid var(--ink-14); box-shadow: 0 1px 3px rgba(13,13,20,0.06); }
.card-head { padding: 14px 18px 12px; border-bottom: 1px solid var(--ink-06); display: flex; align-items: baseline; justify-content: space-between; }
.card-eyebrow { font-family: var(--body); font-weight: 700; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(13,13,20,0.72); }
.card-eyebrow .accent { color: var(--red); }
.card-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

/* ── COMPARE TOOL ────────────────────────────────────────────── */
.edge-cmp { padding-top: 32px; }
.edge-cmp-selectors {
  display: grid; grid-template-columns: 1fr auto 1fr; gap: 16px; align-items: end;
  margin-bottom: 16px;
}
.edge-cmp-sel { display: flex; flex-direction: column; gap: 6px; }
.edge-cmp-sel-lbl {
  font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--ink-48);
}
.edge-cmp-vs {
  font-family: var(--display); font-weight: 800; font-size: 18px;
  text-transform: uppercase; color: var(--ink-32); padding-bottom: 9px;
}
.edge-cmp-actions {
  display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  margin-bottom: 20px;
}
.edge-cmp-btn {
  font-family: var(--display); font-weight: 800; font-size: 13px;
  letter-spacing: 0.06em; text-transform: uppercase;
  background: var(--ink); color: var(--bg); border: none;
  padding: 10px 18px; cursor: pointer; transition: opacity 0.15s;
}
.edge-cmp-btn:hover:not(:disabled) { opacity: 0.86; }
.edge-cmp-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.edge-cmp-hint { font-size: 10px; color: var(--ink-48); letter-spacing: 0.04em; }

.edge-cmp-capture { background: var(--bg); padding: 4px; }
.edge-cmp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: start; }

/* ── BRANDED HERO HEADER (matches player-card masthead) ──────── */
.edge-cmp-hero {
  background: var(--surface);
  border: 1px solid var(--ink-14);
  border-top: 3px solid var(--ink);
  padding: 18px 22px 16px;
  margin-bottom: 16px;
}
.edge-cmp-hero-top {
  display: flex; align-items: baseline; justify-content: space-between; gap: 16px;
  margin-bottom: 8px;
}
.edge-cmp-hero-kicker {
  font-family: var(--display); font-weight: 700; font-size: 11px;
  letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-48);
}
.edge-cmp-hero-eyebrow {
  font-family: var(--mono); font-weight: 700; font-size: 10px;
  letter-spacing: 0.1em; text-transform: uppercase; color: var(--red);
  white-space: nowrap;
}
.edge-cmp-hero-name {
  font-family: var(--display); font-weight: 800;
  text-transform: uppercase; line-height: 0.95; letter-spacing: -0.01em;
  color: var(--ink); margin-bottom: 12px;
}
.edge-cmp-hero-vs {
  font-family: var(--display); font-weight: 700;
  font-size: 0.45em; color: var(--ink-32);
  margin: 0 0.4em; vertical-align: 0.22em; letter-spacing: 0.04em;
}
.edge-cmp-hero-chips { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
.edge-cmp-chip {
  font-family: var(--display); font-weight: 700; font-size: 11px;
  letter-spacing: 0.04em; text-transform: uppercase;
  padding: 4px 10px; border-radius: 3px; white-space: nowrap;
}
.edge-cmp-chip-ink   { background: var(--ink); color: var(--bg); }
.edge-cmp-chip-brand { background: var(--red); color: var(--bg); margin-left: auto; }

/* Player identity strip atop each panel */
.edge-cmp-id { display: flex; align-items: center; gap: 12px; padding: 12px 18px; background: var(--surface); border-bottom: 1px solid var(--ink-06); }
.edge-cmp-logo { display: inline-flex; align-items: center; justify-content: center; width: 26px; height: 26px; flex-shrink: 0; line-height: 0; }
.edge-cmp-logo svg { width: 100%; height: 100%; display: block; }
.edge-cmp-name { font-family: var(--display); font-weight: 800; font-size: 22px; line-height: 1; color: var(--ink); }
.edge-cmp-meta { font-size: 10px; color: var(--ink-48); letter-spacing: 0.06em; margin-top: 3px; }

.edge-cmp-watermark {
  text-align: center; font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--ink-72); padding: 14px 0 6px;
}

@media (max-width: 760px) {
  .edge-cmp-selectors { grid-template-columns: 1fr; gap: 10px; }
  .edge-cmp-vs { display: none; }
  .edge-cmp-grid { grid-template-columns: 1fr; }
}

/* While capturing for PNG export, force the side-by-side 2-column layout at a
   fixed desktop width — even on a narrow viewport — so the downloaded card is
   always horizontal. The .exporting class is added to .edge-cmp-capture for the
   duration of toCanvas() and removed afterward. !important beats the mobile
   media query above. */
.edge-cmp-capture.exporting { width: 1040px !important; }
.edge-cmp-capture.exporting .edge-cmp-grid { grid-template-columns: 1fr 1fr !important; }
</style>
