---
// HockeyGameBot — /stats/series/[slug] — Playoff Series Stats Page
// Statically generated from /v1/playoffs/round/1–4 at build time.
// Slug format: {year}-r{round}-{series_id}   e.g. 2026-r1-car-ott
//              {year}-scf-{series_id}          e.g. 2026-scf-car-vgk
import Nav from '../../../components/Nav.astro';
import ThemeScript from '../../../components/ThemeScript.astro';
import Fonts from '../../../components/Fonts.astro';
import { loadLines, loadPlayers, loadMeta, loadSeriesStats } from '../../../lib/stats-loader';
import { toLineSlug } from '../../../lib/line-slug';
import { buildSeriesShotMapSVG, type FullRinkShot } from '../../../lib/rink-svg';
import { pickTeamColor } from '../../../lib/team-colors';

type SeriesData = {
  series_id:  string;
  round:      number;
  season:     string;
  team_a:     string;
  team_b:     string;
  win_pct_a:  number;
  win_pct_b:  number;
  games:      (string | null)[];
  is_complete: boolean;
  winner:     string | null;
  winner_in:  number | null;
  updated_at: string | null;
};

export async function getStaticPaths() {
  const _API = 'https://api.hockeygamebot.com';
  const _roundCode = (r: number) => r === 4 ? 'scf' : `r${r}`;
  const _slug = (s: SeriesData) => `${s.season.slice(4)}-${_roundCode(s.round)}-${s.series_id}`;

  const rounds = await Promise.all(
    [1, 2, 3, 4].map(n =>
      fetch(`${_API}/v1/playoffs/round/${n}`)
        .then(r => r.ok ? r.json() : null)
        .catch(() => null)
    )
  );

  const seen  = new Set<string>();
  const paths = [];
  for (const data of rounds) {
    if (!data?.series) continue;
    for (const s of data.series as SeriesData[]) {
      // Deduplicate: some rounds return both `a-b` and `b-a` for the same matchup
      const canonical = [s.team_a, s.team_b].sort().join('-');
      const dedupKey  = `${s.round}-${s.season}-${canonical}`;
      if (seen.has(dedupKey)) continue;
      seen.add(dedupKey);
      const slug = _slug(s);
      paths.push({ params: { slug }, props: { series: s } });
    }
  }
  return paths;
}

interface Props { series: SeriesData }
const { series } = Astro.props;

const year         = series.season.slice(4);
const seasonLabel  = series.season.slice(0, 4) + '–' + series.season.slice(4); // "2025–26"
const roundLabel   = series.round === 4 ? 'Stanley Cup Final'
  : series.round === 3 ? 'Conference Finals'
  : series.round === 2 ? 'Second Round'
  : 'First Round';

// ── Series score from games array ──────────────────────────────────────────
const playedGames  = series.games.filter(g => g !== null);
const winsA        = series.games.filter(g => g === series.team_a).length;
const winsB        = series.games.filter(g => g === series.team_b).length;
const gamesPlayed  = playedGames.length;

// ── Stats freshness ────────────────────────────────────────────────────────
const _meta      = loadMeta();
const _statsDate = (() => {
  const d = new Date(_meta.generated_at);
  return d.getFullYear() >= 2020
    ? d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
    : null;
})();

// ── Lines, players, and series stats for these two teams ──────────────────
const allLines      = loadLines();
const allPlayers    = loadPlayers();
const allSeriesStats = loadSeriesStats();

const teams = [series.team_a, series.team_b];
const colorA = pickTeamColor(series.team_a);
const colorB = pickTeamColor(series.team_b);

const seriesLines = allLines.filter(l =>
  l.game_type === 3 && teams.includes(l.team) && l.toi_min >= 30
);

const seriesPlayers = allPlayers.filter(p => teams.includes(p.team_abbrev));
const topSkaters = (t: string) => seriesPlayers
  .filter(p => p.team_abbrev === t && p.gp >= 3)
  .sort((a, b) => ((b.goals ?? 0) + (b.assists ?? 0)) - ((a.goals ?? 0) + (a.assists ?? 0)))
  .slice(0, 5);

// Pre-compute row data in frontmatter to avoid nested block-body maps in JSX
type LineRow = { players: string; slug: string; toi: string; xgfPct: string; xgfCls: string; gfga: string };
type PlayerRow = { name: string; slug: string; pos: string; gp: number; goals: number; assists: number; rating: string };

function lineRows(t: string, type: 'F' | 'D'): LineRow[] {
  const ls = seriesLines.filter(l => l.type === type && l.team === t).sort((a, b) => b.toi_min - a.toi_min).slice(0, type === 'F' ? 4 : 3);
  return ls.map(l => ({
    players: l.players,
    slug:    toLineSlug(l),
    toi:     toMMSS(l.toi_min),
    xgfPct:  fmtXgf(l.xgf_pct),
    xgfCls:  (l.xgf_pct ?? 50) >= 55 ? 'xgf-pos' : (l.xgf_pct ?? 50) <= 45 ? 'xgf-neg' : '',
    gfga:    `${l.gf ?? '—'}/${l.ga ?? '—'}`,
  }));
}

// Series-specific line rows: filter game_log to game_type=3 vs this opponent
function seriesLineRows(t: string, type: 'F' | 'D', opp: string): LineRow[] {
  const ls = allLines.filter(l => l.type === type && l.team === t && l.game_type === 3);
  return ls
    .map(l => {
      const games = (l.game_log ?? []).filter(g => g.game_type === 3 && g.opp_abbrev === opp);
      if (!games.length) return null;
      const toi = games.reduce((s, g) => s + g.toi_min, 0);
      const xgf = games.reduce((s, g) => s + g.xgf, 0);
      const xga = games.reduce((s, g) => s + g.xga, 0);
      const gf  = games.reduce((s, g) => s + g.gf, 0);
      const ga  = games.reduce((s, g) => s + g.ga, 0);
      const xgfPct = xgf + xga > 0 ? (xgf / (xgf + xga)) * 100 : null;
      return { l, toi, xgf, xga, xgfPct, gf, ga };
    })
    .filter((x): x is NonNullable<typeof x> => x !== null)
    .sort((a, b) => b.toi - a.toi)
    .slice(0, type === 'F' ? 4 : 3)
    .map(({ l, toi, xgfPct, gf, ga }) => ({
      players: l.players,
      slug:    toLineSlug(l),
      toi:     toMMSS(toi),
      xgfPct:  xgfPct != null ? xgfPct.toFixed(1) + '%' : '—',
      xgfCls:  (xgfPct ?? 50) >= 55 ? 'xgf-pos' : (xgfPct ?? 50) <= 45 ? 'xgf-neg' : '',
      gfga:    `${gf}/${ga}`,
    }));
}

function playerRows(t: string): PlayerRow[] {
  return topSkaters(t).map(p => ({
    name:   p.display_name,
    slug:   p.slug,
    pos:    p.pos,
    gp:     p.gp,
    goals:   p.goals ?? 0,
    assists: p.assists ?? 0,
    rating: p.hgb_rating_percentile != null ? p.hgb_rating_percentile + '%' : '—',
  }));
}

const fLinesA   = lineRows(series.team_a, 'F');
const fLinesB   = lineRows(series.team_b, 'F');
const dPairsA   = lineRows(series.team_a, 'D');
const dPairsB   = lineRows(series.team_b, 'D');
// Series-specific (filtered to games_type=3 vs this opponent)
const sfLinesA  = seriesLineRows(series.team_a, 'F', series.team_b);
const sfLinesB  = seriesLineRows(series.team_b, 'F', series.team_a);
const sdPairsA  = seriesLineRows(series.team_a, 'D', series.team_b);
const sdPairsB  = seriesLineRows(series.team_b, 'D', series.team_a);
const hasSeriesLines = sfLinesA.length > 0 || sfLinesB.length > 0;
const skatersA  = playerRows(series.team_a);
const skatersB  = playerRows(series.team_b);

// 5v5 aggregate for each team from playoff F-lines only.
// F-lines and D-pairs both accumulate the same shift xGF from rapm_shifts,
// so summing both would double-count every shot. F-lines are the canonical source.
function teamXgSummary(team: string) {
  const tlines = seriesLines.filter(l => l.team === team && l.type === 'F');
  if (!tlines.length) return null;
  const xgf = tlines.reduce((s, l) => s + (l.xgf ?? 0), 0);
  const xga = tlines.reduce((s, l) => s + (l.xga ?? 0), 0);
  const gf  = tlines.reduce((s, l) => s + (l.gf ?? 0), 0);
  const ga  = tlines.reduce((s, l) => s + (l.ga ?? 0), 0);
  const toi = tlines.reduce((s, l) => s + (l.toi_min ?? 0), 0);
  const xgfPct = xgf + xga > 0 ? ((xgf / (xgf + xga)) * 100) : null;
  return { xgf: +xgf.toFixed(2), xga: +xga.toFixed(2), xgfPct: xgfPct ? +xgfPct.toFixed(1) : null, gf, ga, toi: +toi.toFixed(0) };
}

const summA = teamXgSummary(series.team_a);
const summB = teamXgSummary(series.team_b);

// ── This-series stats: read from series_stats.json (correct, pipeline-computed).
// game_log was removed from lines.json (too large). series_stats.json has per-team
// xgf_5v5/xga_5v5 computed from player_game_features — the authoritative source.
// series.season is 8-digit ("20252026"); series_stats uses dashed ("2025-26")
const _normSeason = (s: string) => /^\d{8}$/.test(s) ? `${s.slice(0, 4)}-${s.slice(6)}` : s;
const _matchedSeries = allSeriesStats.series.find((s: any) =>
  _normSeason(s.season) === _normSeason(series.season) &&
  s.round  === series.round  &&
  series.team_a in s.teams   &&
  series.team_b in s.teams
);
function _seriesTeamSumm(team: string) {
  if (!_matchedSeries) return null;
  const t = _matchedSeries.teams[team];
  if (!t) return null;
  const xgf = t.xgf_5v5 ?? 0, xga = t.xga_5v5 ?? 0;
  const xgfPct = xgf + xga > 0 ? (xgf / (xgf + xga)) * 100 : null;
  return {
    xgf: +xgf.toFixed(2), xga: +xga.toFixed(2),
    xgfPct: xgfPct ? +xgfPct.toFixed(1) : null,
    gf: t.gf ?? 0, ga: t.ga ?? 0,
    games: _matchedSeries.games_played ?? 0,
  };
}
const seriesSummA = _seriesTeamSumm(series.team_a);
const seriesSummB = _seriesTeamSumm(series.team_b);
const hasSeriesData = !!(seriesSummA || seriesSummB);

// ── Series shot map ────────────────────────────────────────────────────────
// API shape: [x, y, is_goal, shot_type, team_abbrev, game_number]
// Shot map is loaded client-side to avoid fetching for every series at build time.
// The API endpoint reads ~4,600 D1 rows per call; with 30+ series pages × frequent
// deploys that was 6M+ rows/day. Client-side load means we only fetch when the user
// actually views the page.
const shotMapSeriesId = series.series_id;
const shotMapTeamA    = series.team_a;
const shotMapTeamB    = series.team_b;

function toMMSS(min: number): string {
  const m = Math.floor(min), s = Math.round((min - m) * 60);
  return `${m}:${String(s).padStart(2, '0')}`;
}
function fmt1(n: number | null | undefined): string { return n != null ? n.toFixed(1) : '—'; }
function fmt2(n: number | null | undefined): string { return n != null ? n.toFixed(2) : '—'; }
function fmtXgf(v: number | null | undefined): string { return v != null ? v.toFixed(1) + '%' : '—'; }

const canonUrl = `https://hockeygamebot.com/stats/series/${Astro.params.slug}`;
const title    = `${series.team_a} vs ${series.team_b} · ${year} ${roundLabel}`;

// ── Client-side series data: build-time lookups passed via define:vars ──────
// playoffLineMap: sorted player_ids key → full-playoff TOI/xGF% + line slug.
// Client joins series-specific data vs season-long playoff data in one row.
const playoffLineMap: Record<string, { toi: string; xgfPct: string; xgfCls: string; slug: string }> = {};
for (const l of seriesLines) {
  const key = [...l.player_ids].sort((a, b) => a - b).join(',');
  if (key) {
    playoffLineMap[key] = {
      toi:    toMMSS(l.toi_min),
      xgfPct: fmtXgf(l.xgf_pct),
      xgfCls: (l.xgf_pct ?? 50) >= 55 ? 'xgf-pos' : (l.xgf_pct ?? 50) <= 45 ? 'xgf-neg' : '',
      slug:   toLineSlug(l),
    };
  }
}
// player_id → slug for series skater links
const playerSlugMap: Record<number, string> = {};
for (const p of seriesPlayers) {
  if (p.player_id != null && p.slug) playerSlugMap[p.player_id] = p.slug;
}
const clientSeriesId = _matchedSeries?.series_id ?? null;
const clientTeamA    = series.team_a;
const clientTeamB    = series.team_b;
---
<!doctype html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} · HGB Stats</title>
  <meta name="description" content={`${series.team_a} vs ${series.team_b} series stats — ${seasonLabel} ${roundLabel}. 5v5 xGF, top lines, and player analytics. HockeyGameBot.`} />
  <link rel="canonical" href={canonUrl} />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #EFEEE8; --ink: #0d0d14; --red: #E8002D; --surface: #FFFFFF;
      --ink-06: rgba(13,13,20,0.06); --ink-10: rgba(13,13,20,0.10);
      --ink-14: rgba(13,13,20,0.14); --ink-20: rgba(13,13,20,0.20);
      --ink-32: rgba(13,13,20,0.32); --ink-48: rgba(13,13,20,0.48);
      --ink-72: rgba(13,13,20,0.72);
      --display: 'Barlow Condensed', sans-serif;
      --body:    'Barlow', sans-serif;
      --mono:    'JetBrains Mono', monospace;
      --pos-clr: #166534; --neg-clr: #991b1b;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }
    @media (max-width: 768px) { .wrap { padding: 0 16px 60px; } }

    /* ── Mast — matches other stats pages ── */
    .mast { position: relative; border-bottom: 2px solid var(--ink); background: var(--bg);
      background-image: linear-gradient(rgba(13,13,20,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(13,13,20,0.04) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-eyebrow { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .series-matchup { display: flex; align-items: center; gap: 20px; margin-bottom: 16px; flex-wrap: wrap; justify-content: space-between; }
    .series-teams { display: flex; align-items: center; gap: 20px; }
    .series-team { font-family: var(--display); font-weight: 800; font-size: clamp(40px, 8vw, 72px); text-transform: uppercase; letter-spacing: -0.01em; line-height: 1; }
    .series-vs { font-family: var(--mono); font-size: 16px; color: var(--ink-32); letter-spacing: 0.12em; text-transform: uppercase; }
    .series-score { display: flex; align-items: center; gap: 12px; }
    .score-num { font-family: var(--display); font-weight: 800; font-size: clamp(32px, 5vw, 52px); line-height: 1; }
    .score-dash { font-family: var(--mono); color: var(--ink-32); font-size: 20px; }
    .mast-sub { display: flex; align-items: flex-end; justify-content: space-between; gap: 12px; flex-wrap: wrap; margin-top: 14px; font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.08em; text-transform: uppercase; }
    .mast-sub-left { display: flex; flex-direction: column; gap: 4px; }
    .series-status { font-family: var(--mono); font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
    .status-complete { color: var(--pos-clr); }
    .status-live { color: var(--red); }

    /* ── Sections ── */
    .section { padding: 32px 0 0; }
    .section-label { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.20em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 12px; display: block; }

    /* ── Team comparison table ── */
    /* ── Scope toggle ── */
    .scope-toggle { display: inline-flex; border: 1px solid var(--ink-14); margin-bottom: 12px; }
    .scope-btn { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; padding: 6px 14px; border: none; border-right: 1px solid var(--ink-14); background: transparent; color: var(--ink-48); cursor: pointer; transition: background 0.1s, color 0.1s; }
    .scope-btn:last-child { border-right: none; }
    .scope-btn.active { background: var(--ink); color: var(--bg); }
    .scope-btn:disabled { opacity: 0.35; cursor: not-allowed; }
    .scope-view { display: none; }
    .scope-view.active { display: block; }
    .no-series-data { font-family: var(--mono); font-size: 11px; color: var(--ink-32); padding: 20px; text-align: center; background: var(--surface); border: 1px solid var(--ink-14); letter-spacing: 0.04em; }
    .scope-note { font-family: var(--mono); font-size: 10px; color: var(--ink-32); margin-top: 8px; }

    .compare-grid { display: grid; grid-template-columns: 1fr auto 1fr; gap: 2px; background: var(--ink-10); border: 1px solid var(--ink-14); }
    .cg-header { padding: 10px 16px; background: var(--surface); text-align: center; font-family: var(--display); font-weight: 800; font-size: 20px; text-transform: uppercase; letter-spacing: 0.04em; }
    .cg-label { padding: 10px 14px; background: var(--surface); text-align: center; font-family: var(--mono); font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-48); }
    .cg-val { padding: 10px 16px; background: var(--surface); text-align: center; font-family: var(--mono); font-size: 14px; font-weight: 700; color: var(--ink); }
    .cg-val.better { color: var(--pos-clr); }
    .cg-val.worse  { color: var(--neg-clr); }

    /* ── Line tables ── */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 0; }
    @media (max-width: 640px) { .two-col { grid-template-columns: 1fr; } }
    .team-block { }
    .team-label { font-family: var(--display); font-weight: 800; font-size: 16px; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; padding-bottom: 6px; border-bottom: 2px solid var(--ink); }
    .line-table { width: 100%; border-collapse: collapse; background: var(--surface); border: 1px solid var(--ink-14); font-size: 12px; }
    .line-table th { padding: 7px 10px; font-family: var(--mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-48); border-bottom: 1px solid var(--ink-14); text-align: center; white-space: nowrap; }
    .line-table th:first-child { text-align: left; }
    .line-table td { padding: 8px 10px; border-bottom: 1px solid var(--ink-06); font-family: var(--mono); font-variant-numeric: tabular-nums; text-align: center; color: var(--ink-72); }
    .line-table td:first-child { text-align: left; font-size: 11px; }
    .line-table tr:last-child td { border-bottom: none; }
    .line-table tr:hover td { background: rgba(13,13,20,0.03); }
    .line-table a { color: var(--ink); text-decoration: none; font-weight: 600; }
    .line-table a:hover { color: var(--red); }
    .xgf-pos { color: var(--pos-clr); font-weight: 700; }
    .xgf-neg { color: var(--neg-clr); font-weight: 700; }

    /* ── Player table ── */
    .player-table { width: 100%; border-collapse: collapse; background: var(--surface); border: 1px solid var(--ink-14); font-size: 12px; }
    .player-table th { padding: 7px 10px; font-family: var(--mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-48); border-bottom: 1px solid var(--ink-14); text-align: center; }
    .player-table th:first-child { text-align: left; }
    .player-table td { padding: 8px 10px; border-bottom: 1px solid var(--ink-06); font-family: var(--mono); font-variant-numeric: tabular-nums; text-align: center; color: var(--ink-72); }
    .player-table td:first-child { text-align: left; }
    .player-table tr:last-child td { border-bottom: none; }
    .player-table a { color: var(--ink); text-decoration: none; font-weight: 600; }
    .player-table a:hover { color: var(--red); }
    .pos-badge { font-family: var(--mono); font-size: 9px; padding: 1px 5px; border: 1px solid var(--ink-20); color: var(--ink-48); margin-left: 4px; vertical-align: middle; }

    /* ── Games played ── */
    .games-strip { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 0; }
    .game-chip { padding: 6px 14px; border: 1px solid var(--ink-14); background: var(--surface); font-family: var(--mono); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }
    .game-chip.win-a { background: var(--ink); color: var(--bg); border-color: var(--ink); }
    .game-chip.unplayed { color: var(--ink-32); border-style: dashed; }

    /* ── Footer ── */
    .page-foot { border-top: 1px solid var(--ink-14); padding: 24px 0; margin-top: 48px; font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.08em; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  </style>
</head>
<body>
<Nav currentPath="/stats" />

<!-- MASTHEAD -->
<section class="mast">
  <div class="mast-inner">
    <div class="mast-eyebrow">
      <span class="pip"></span>
      <a href="/stats" style="color:inherit;text-decoration:none">HGB Stats</a>
      <span>·</span>
      <a href="/playoffs/2026" style="color:inherit;text-decoration:none">2026 Playoffs</a>
      <span>·</span>
      {roundLabel}
    </div>
    <div class="mast-card">
      <div class="series-matchup">
        <div class="series-teams">
          <span class="series-team">{series.team_a}</span>
          <span class="series-vs">vs</span>
          <span class="series-team">{series.team_b}</span>
        </div>
        <div class="series-score">
          <span class="score-num">{winsA}</span>
          <span class="score-dash">–</span>
          <span class="score-num">{winsB}</span>
        </div>
      </div>
      <div class="mast-sub">
        <div class="mast-sub-left">
          <span>{seasonLabel} {roundLabel}</span>
          {_statsDate && <span>Stats updated {_statsDate}</span>}
        </div>
        {series.is_complete && series.winner ? (
          <span class="series-status status-complete">{series.winner} wins in {series.winner_in}</span>
        ) : gamesPlayed > 0 ? (
          <span class="series-status status-live">Series in progress · {gamesPlayed} game{gamesPlayed !== 1 ? 's' : ''} played</span>
        ) : (
          <span class="series-status">Series upcoming</span>
        )}
      </div>
    </div>
  </div>
</section>

<div class="wrap">

  <!-- MODEL PREDICTION — top of page, only when series is live/upcoming -->
  {!series.is_complete && (
    <div class="section">
      <span class="section-label">Model Prediction</span>
      <div style="background:var(--surface);border:1px solid var(--ink-14);padding:16px 20px;display:flex;gap:32px;flex-wrap:wrap;align-items:center">
        <div style="text-align:center">
          <div style="font-family:var(--display);font-weight:800;font-size:36px;letter-spacing:-0.01em">{series.team_a}</div>
          <div style="font-family:var(--mono);font-size:20px;font-weight:700;color:var(--red)">{series.win_pct_a}%</div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--ink-32);letter-spacing:0.08em;text-transform:uppercase;margin-top:2px">Win %</div>
        </div>
        <div style="flex:1;min-width:0">
          <div style="height:10px;background:var(--ink-10);border-radius:2px;overflow:hidden">
            <div style={`height:100%;width:${series.win_pct_a}%;background:var(--red)`}></div>
          </div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--ink-32);margin-top:8px">HGB model · 10,000 Monte Carlo simulations · <a href="/methodology" style="color:var(--ink-48);text-decoration:underline">How it works</a></div>
        </div>
        <div style="text-align:center">
          <div style="font-family:var(--display);font-weight:800;font-size:36px;letter-spacing:-0.01em">{series.team_b}</div>
          <div style="font-family:var(--mono);font-size:20px;font-weight:700;color:var(--ink-48)">{series.win_pct_b}%</div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--ink-32);letter-spacing:0.08em;text-transform:uppercase;margin-top:2px">Win %</div>
        </div>
      </div>
    </div>
  )}

  <!-- GAME-BY-GAME -->
  {gamesPlayed > 0 && (
    <div class="section">
      <span class="section-label">Games</span>
      <div class="games-strip">
        {series.games.map((winner, i) => {
          const wc = winner === series.team_a ? colorA : winner === series.team_b ? colorB : null;
          return (
            <div class={`game-chip ${winner === null ? 'unplayed' : 'played'}`}
                 style={wc ? `background:${wc};color:#fff;border-color:${wc};` : ''}>
              G{i + 1}{winner !== null ? ` · ${winner}` : ''}
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- TEAM COMPARISON — scope toggle -->
  {(summA || summB) && (
    <div class="section" id="compare-section">
      <span class="section-label">5v5 Expected Goals</span>

      {hasSeriesData ? (
        <>
          <div class="compare-grid">
            <div class="cg-header">{series.team_a}</div>
            <div class="cg-label">Metric</div>
            <div class="cg-header">{series.team_b}</div>

            <div class={`cg-val ${seriesSummA && seriesSummB && seriesSummA.xgf > seriesSummB.xgf ? 'better' : ''}`}>{fmt2(seriesSummA?.xgf)}</div>
            <div class="cg-label">xGF</div>
            <div class={`cg-val ${seriesSummA && seriesSummB && seriesSummB.xgf > seriesSummA.xgf ? 'better' : ''}`}>{fmt2(seriesSummB?.xgf)}</div>

            <div class={`cg-val ${seriesSummA && seriesSummB && seriesSummA.xga < seriesSummB.xga ? 'better' : seriesSummA && seriesSummB && seriesSummA.xga > seriesSummB.xga ? 'worse' : ''}`}>{fmt2(seriesSummA?.xga)}</div>
            <div class="cg-label">xGA</div>
            <div class={`cg-val ${seriesSummA && seriesSummB && seriesSummB.xga < seriesSummA.xga ? 'better' : seriesSummA && seriesSummB && seriesSummB.xga > seriesSummA.xga ? 'worse' : ''}`}>{fmt2(seriesSummB?.xga)}</div>

            <div class={`cg-val ${seriesSummA && seriesSummB && (seriesSummA.xgfPct ?? 0) > (seriesSummB.xgfPct ?? 0) ? 'better' : seriesSummA && seriesSummB && (seriesSummA.xgfPct ?? 0) < (seriesSummB.xgfPct ?? 0) ? 'worse' : ''}`}>{fmtXgf(seriesSummA?.xgfPct)}</div>
            <div class="cg-label">xGF%</div>
            <div class={`cg-val ${seriesSummA && seriesSummB && (seriesSummB.xgfPct ?? 0) > (seriesSummA.xgfPct ?? 0) ? 'better' : seriesSummA && seriesSummB && (seriesSummB.xgfPct ?? 0) < (seriesSummA.xgfPct ?? 0) ? 'worse' : ''}`}>{fmtXgf(seriesSummB?.xgfPct)}</div>

            <div class="cg-val">{seriesSummA?.gf ?? '—'}</div>
            <div class="cg-label">GF</div>
            <div class="cg-val">{seriesSummB?.gf ?? '—'}</div>

            <div class="cg-val">{seriesSummA?.ga ?? '—'}</div>
            <div class="cg-label">GA</div>
            <div class="cg-val">{seriesSummB?.ga ?? '—'}</div>
          </div>
          <p class="scope-note">{seriesSummA?.games ?? seriesSummB?.games ?? 0} game{(seriesSummA?.games ?? 0) !== 1 ? 's' : ''} in this series · 5v5, min 30 min TOI</p>
        </>
      ) : (
        <div class="no-series-data">No games played in this series yet</div>
      )}
    </div>
  )}

  <!-- TOP SKATERS — client-side from /v1/series/{series_id}/players -->
  <div class="section" id="skaters-section" style="display:none">
    <span class="section-label">Top Skaters — This Series</span>
    <div class="two-col">
      <div class="team-block" id="skaters-a">
        <div class="team-label">{series.team_a}</div>
        <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:12px 0">Loading…</div>
      </div>
      <div class="team-block" id="skaters-b">
        <div class="team-label">{series.team_b}</div>
        <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:12px 0">Loading…</div>
      </div>
    </div>
  </div>

  <!-- FORWARD LINES — client-side from /v1/series/{series_id}/lines -->
  <!-- Columns: Line | Series TOI | Series xGF% | Playoff TOI | Playoff xGF% -->
  <!-- Playoff columns joined at build time via sorted player_ids → playoffLineMap -->
  <div class="section" id="flines-section" style="display:none">
    <span class="section-label">Top Forward Lines — This Series</span>
    <div class="two-col">
      <div class="team-block" id="flines-a">
        <div class="team-label">{series.team_a}</div>
        <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:12px 0">Loading…</div>
      </div>
      <div class="team-block" id="flines-b">
        <div class="team-label">{series.team_b}</div>
        <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:12px 0">Loading…</div>
      </div>
    </div>
  </div>

  <!-- DEFENSIVE PAIRS — client-side from /v1/series/{series_id}/lines -->
  <div class="section" id="dpairs-section" style="display:none">
    <span class="section-label">Top Defensive Pairs — This Series</span>
    <div class="two-col">
      <div class="team-block" id="dpairs-a">
        <div class="team-label">{series.team_a}</div>
        <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:12px 0">Loading…</div>
      </div>
      <div class="team-block" id="dpairs-b">
        <div class="team-label">{series.team_b}</div>
        <div style="font-family:var(--mono);font-size:11px;color:var(--ink-32);padding:12px 0">Loading…</div>
      </div>
    </div>
  </div>

  <!-- SHOT MAP — loaded client-side to avoid D1 reads at build time -->
  <div class="section" id="shot-map-section"
       data-series-id={shotMapSeriesId}
       data-team-a={shotMapTeamA}
       data-team-b={shotMapTeamB}
       data-color-a={colorA}
       data-color-b={colorB}>
    <span class="section-label">Shot Map — {series.team_a} for · {series.team_b} against · This Series</span>
    <div id="shot-map-container" style="background:var(--surface);border:1px solid var(--ink-14);padding:8px;min-height:60px;display:flex;align-items:center;justify-content:center;color:var(--ink-32);font-size:12px">
      Loading shot map…
    </div>
    <p style="font-family:var(--mono);font-size:10px;color:var(--ink-32);margin-top:8px">Solid = goal · Open = shot · <span style={`color:${colorA};font-weight:700`}>{series.team_a}</span> for · <span style={`color:${colorB};font-weight:700`}>{series.team_b}</span> against · This series</p>
  </div>


  <div class="page-foot">
    <span>HOCKEYGAMEBOT.COM · HGB STATS · {year} PLAYOFFS</span>
    {_statsDate && <span>Updated {_statsDate} · nightly</span>}
  </div>

</div>

<script define:vars={{ clientSeriesId, clientTeamA, clientTeamB, playoffLineMap, playerSlugMap }}>
// Series player + line sections — fetch /v1/series/{id}/players and /lines
(async () => {
  if (!clientSeriesId) return;
  const API = 'https://api.hockeygamebot.com';

  function mmss(min) {
    const m = Math.floor(min), s = Math.round((min - m) * 60);
    return `${m}:${String(s).padStart(2, '0')}`;
  }
  function xgfFmt(v) { return v != null ? v.toFixed(1) + '%' : '—'; }
  function xgfCls(v) { return (v ?? 50) >= 55 ? 'xgf-pos' : (v ?? 50) <= 45 ? 'xgf-neg' : ''; }

  const [playersRes, linesRes] = await Promise.all([
    fetch(`${API}/v1/series/${clientSeriesId}/players`).catch(() => null),
    fetch(`${API}/v1/series/${clientSeriesId}/lines`).catch(() => null),
  ]);

  // ── Top Skaters ────────────────────────────────────────────────────────────
  if (playersRes?.ok) {
    const data = await playersRes.json();
    const players = data.players ?? [];
    if (players.length) {
      const section = document.getElementById('skaters-section');
      if (section) {
        section.style.display = '';
        for (const [teamId, elId] of [[clientTeamA, 'skaters-a'], [clientTeamB, 'skaters-b']]) {
          const tp = players.filter(p => p.team === teamId).slice(0, 5);
          const el = document.getElementById(elId);
          if (!el || !tp.length) continue;
          const rows = tp.map(p => {
            const slug = playerSlugMap[p.player_id];
            const name = slug ? `<a href="/stats/player/${slug}">${p.name}</a>` : p.name;
            return `<tr>
              <td>${name}</td>
              <td>${p.pos}</td>
              <td>${p.gp}</td><td>${p.goals}</td><td>${p.a1 + p.a2}</td><td>${p.points}</td>
            </tr>`;
          }).join('');
          el.innerHTML = `<div class="team-label">${teamId}</div>
            <table class="player-table">
              <thead><tr><th>Player</th><th>Pos</th><th>GP</th><th>G</th><th>A</th><th>PTS</th></tr></thead>
              <tbody>${rows}</tbody>
            </table>`;
        }
      }
    }
  }

  // ── Forward Lines + Defensive Pairs ───────────────────────────────────────
  if (linesRes?.ok) {
    const data = await linesRes.json();
    const lines = data.lines ?? [];
    if (lines.length) {
      for (const [type, secId, slotA, slotB, maxRows, label] of [
        ['F', 'flines-section', 'flines-a', 'flines-b', 4, 'Line'],
        ['D', 'dpairs-section', 'dpairs-a', 'dpairs-b', 3, 'Pair'],
      ]) {
        const section = document.getElementById(secId);
        if (!section) continue;
        let anyRendered = false;

        for (const [teamId, elId] of [[clientTeamA, slotA], [clientTeamB, slotB]]) {
          const tl = lines
            .filter(l => l.type === type && l.team === teamId)
            .sort((a, b) => b.toi_min - a.toi_min)
            .slice(0, maxRows);
          const el = document.getElementById(elId);
          if (!el || !tl.length) continue;
          anyRendered = true;

          const rows = tl.map(l => {
            // Join series line vs full-playoff aggregate by sorted player_ids key
            const key = l.player_ids.slice().sort((a, b) => a - b).join(',');
            const po  = playoffLineMap[key] ?? null;
            const nameCell = po?.slug
              ? `<a href="/stats/lines/${po.slug}">${l.players}</a>`
              : l.players;
            return `<tr>
              <td>${nameCell}</td>
              <td>${mmss(l.toi_min)}</td>
              <td class="${xgfCls(l.xgf_pct)}">${xgfFmt(l.xgf_pct)}</td>
              <td>${po?.toi ?? '—'}</td>
              <td class="${po?.xgfCls ?? ''}">${po?.xgfPct ?? '—'}</td>
            </tr>`;
          }).join('');

          el.innerHTML = `<div class="team-label">${teamId}</div>
            <table class="line-table">
              <thead><tr>
                <th>${label}</th>
                <th>Series TOI</th><th>Series xGF%</th>
                <th>PO TOI</th><th>PO xGF%</th>
              </tr></thead>
              <tbody>${rows}</tbody>
            </table>`;
        }

        if (anyRendered) section.style.display = '';
      }
    }
  }
})();
</script>

<script>
import { buildSeriesShotMapSVG, type FullRinkShot } from '../../../lib/rink-svg';

// Load shot map client-side — kept out of Astro build to avoid D1 reads per deploy
(async () => {
  const section = document.getElementById('shot-map-section');
  const container = document.getElementById('shot-map-container');
  if (!section || !container) return;
  const seriesId = section.dataset.seriesId;
  const teamA = section.dataset.teamA;
  const teamB = section.dataset.teamB;
  const colorAv = section.dataset.colorA;
  const colorBv = section.dataset.colorB;
  if (!seriesId || !teamA) return;
  try {
    const res = await fetch(`https://api.hockeygamebot.com/v1/series/${seriesId}/shots`);
    if (!res.ok) { container.textContent = ''; return; }
    const data = await res.json();
    if (!data.shots?.length) { container.textContent = ''; return; }
    // Split into for (team A) / against (team B), fold to one end via abs(x), and
    // render with the proper full-rink builder. NOTE: the series shots endpoint has
    // no per-shot xG, so xg is passed as 0 — goals still render larger, but dot-size-
    // by-danger and the xGF% bar are flat until the API adds xG (see DE prompt).
    // API tuple: [x, y, is_goal, shot_type, team, ...]
    const sf: FullRinkShot[] = [];
    const sa: FullRinkShot[] = [];
    for (const s of data.shots as [number, number, number, string, string][]) {
      const [x, y, isGoal, , team] = s;
      const shot: FullRinkShot = [Math.abs(x), y, 0, isGoal];
      (team === teamA ? sf : sa).push(shot);
    }
    const { svg } = buildSeriesShotMapSVG(sf, sa, {
      teamFor: teamA, teamAgainst: teamB,
      colorFor: colorAv, colorAgainst: colorBv,
      showXgBar: false, // series shots endpoint has no per-shot xG yet
    });
    container.innerHTML = svg;
    container.style.padding = '0';
  } catch (_) { container.textContent = ''; }
})();
</script>
</body>
</html>
