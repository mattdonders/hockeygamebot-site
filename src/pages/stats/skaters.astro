---
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import Table from '../../components/Table.astro';
import ChipGroup from '../../components/ChipGroup.astro';
import { loadPlayers, loadMeta } from '../../lib/stats-loader';

const allPlayers = loadPlayers();
const eligible   = allPlayers.filter(p => p.gp >= 20);
const _meta      = loadMeta();
const _statsDate = (() => { const d = new Date(_meta.generated_at); return d.getFullYear() >= 2020 ? d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : null; })();

// Pre-sort rapm arrays for O(n log n) percentile lookup at build time
const fwdRapm = eligible.filter(p => p.pos_group === 'F').map(p => p.rapm ?? 0).sort((a,b) => a - b);
const defRapm = eligible.filter(p => p.pos_group === 'D').map(p => p.rapm ?? 0).sort((a,b) => a - b);

function warPct(rapm: number | null, group: 'F' | 'D'): number | null {
  if (rapm == null) return null;
  const arr = group === 'F' ? fwdRapm : defRapm;
  let lo = 0, hi = arr.length;
  while (lo < hi) { const mid = (lo + hi) >>> 1; if (arr[mid] <= rapm) lo = mid + 1; else hi = mid; }
  return Math.round((lo / arr.length) * 100);
}

const toi60 = (p: typeof eligible[0]) => (p.toi_avg_sec * p.gp) / 3600 || 1;

const tableRows = eligible.map(p => {
  const evOff    = p.rates_per_60.ev_offence;
  const evDef    = p.rates_per_60.ev_defence;
  const xgfTotal = evOff + evDef;
  const tot60    = toi60(p);
  const goals    = p.goals;
  const assists  = p.assists;
  const rawSog   = Math.round(p.rates_per_60.shots * tot60);
  const rawIxg   = p.rates_per_60.ixg * tot60;

  // Strength-state splits
  const goalsPp  = p.goals_pp  ?? 0;
  const goalsSh  = p.goals_sh  ?? 0;
  const goalsEv  = p.goals_ev  ?? 0;
  const aPp      = (p.a1_pp ?? 0) + (p.a2_pp ?? 0);
  const aPk      = (p.a1_pk ?? 0) + (p.a2_pk ?? 0);
  const aEv      = Math.max(0, assists - aPp - aPk);
  const shotsPp  = p.shots_pp ?? 0;
  const shotsPk  = p.shots_pk ?? 0;
  const shotsEv  = Math.max(0, rawSog - shotsPp - shotsPk);
  const ixgPp    = p.sum_xg_pp ?? 0;
  const ixgPk    = p.sum_xg_pk ?? 0;
  const ixgEv    = Math.max(0, rawIxg - ixgPp - ixgPk);
  const toiPpSec = p.toi_pp_sec_total ?? 0;
  const toiPkSec = p.toi_pk_sec_total ?? 0;
  const toiEvSec = p.toi_ev_sec_total ?? 0;

  return {
    slug:     p.slug,
    name:     p.display_name,
    searchText: `${p.first_name} ${p.last_name} ${p.display_name} ${p.team_abbrev}`.toLowerCase(),
    team:     p.team_abbrev,
    pos:      p.pos,
    group:    p.pos_group,
    gp:       p.gp,
    // Counting stats (all-situations)
    goals,
    assists,
    points:   goals + assists,
    sog:      rawSog,
    ixg:      +rawIxg.toFixed(2),
    toi_pg:   +(p.toi_avg_sec / 60).toFixed(1),
    // Rates
    g60:      +p.rates_per_60.goals.toFixed(2),
    a60:      +(assists / tot60).toFixed(2),
    p60:      +((goals + assists) / tot60).toFixed(2),
    x60:      +p.rates_per_60.ixg.toFixed(2),
    sog60:    +p.rates_per_60.shots.toFixed(2),
    // Advanced
    war:      p.war ?? null,
    war_p:    warPct(p.rapm, p.pos_group),
    fin:      +p.rates_per_60.finishing.toFixed(2),
    fin_p:    Math.round(p.percentiles_vs_pos.finishing),
    imp:      +p.avg_gs_display.toFixed(2),
    imp_p:    Math.round(p.gs_pct),
    rapm:     p.rapm != null ? +p.rapm.toFixed(3) : null,
    // 5v5 on-ice
    xgf_pct:  xgfTotal > 0 ? +(evOff / xgfTotal * 100).toFixed(1) : 50.0,
    xgf60:    +evOff.toFixed(2),
    xga60:    +evDef.toFixed(2),
    sc60:     +(p.rates_per_60.sc_per60 ?? 0).toFixed(2),
    hdc60:    +(p.rates_per_60.hdc_per60 ?? 0).toFixed(2),
    hdc_pct:  +(p.hdc_pct ?? 50).toFixed(1),
    // PP (legacy fields kept for compat)
    pp_toi:   toiPpSec > 0 ? +(toiPpSec / p.gp / 60).toFixed(1) : 0,
    pp_g:     goalsPp,
    pp_xg60:  +(p.rates_per_60.xg_pp_per60 ?? 0).toFixed(2),
    // Strength-state raw fields (used by client-side filter)
    goals_ev: goalsEv,  goals_pp: goalsPp,  goals_sh: goalsSh,
    a_ev:     aEv,      a_pp:     aPp,      a_pk:     aPk,
    shots_ev: shotsEv,  shots_pp: shotsPp,  shots_pk: shotsPk,
    ixg_ev:   +ixgEv.toFixed(2),
    ixg_pp:   +ixgPp.toFixed(2),
    ixg_pk:   +ixgPk.toFixed(2),
    toi_ev_sec: toiEvSec,
    toi_pp_sec: toiPpSec,
    toi_pk_sec: toiPkSec,
    // Playoff counting — null if player didn't play playoffs
    po_gp:      p.playoff_gp      ?? null,
    po_goals:   p.playoff_goals   ?? null,
    po_assists: p.playoff_assists  ?? null,
    po_points:  p.playoff_points   ?? null,
    po_sog:     p.playoff_sog      ?? null,
    po_ixg:     p.playoff_ixg      ?? null,
    po_toi_pg:  p.playoff_toi_sec != null && p.playoff_gp
                  ? +(p.playoff_toi_sec / p.playoff_gp / 60).toFixed(1)
                  : null,
  };
});

// SSR initial: counting tab, sorted by points desc, top 50.
const ssrRows = tableRows
  .slice()
  .sort((a, b) => (b.points ?? 0) - (a.points ?? 0))
  .slice(0, 50)
  .map((r, i) => ({ ...r, _rank: i + 1 }));

// SSR column set: counting tab (gets swapped by JS on tab change).
const initialColumns = [
  { key: '_rank',  label: '#',      type: 'rank' as const, sortable: false },
  { key: 'name',   label: 'Player', type: 'player' as const, sub: (r: any) => `${r.team} · ${r.pos} · ${r.gp} GP` },
  { key: 'pos',    label: 'Pos',    type: 'position' as const, sortable: true },
  { key: 'gp',     label: 'GP',     type: 'number' as const },
  { key: 'goals',  label: 'G',      type: 'number' as const },
  { key: 'assists',label: 'A',      type: 'number' as const },
  { key: 'points', label: 'P',      type: 'number' as const, bold: true },
  { key: 'sog',    label: 'SOG',    type: 'number' as const },
  { key: 'ixg',    label: 'ixG',    type: 'number' as const, format: (v: any) => v != null ? Number(v).toFixed(2) : '—' },
  { key: 'toi_pg', label: 'TOI',    type: 'number' as const, format: (v: any) => v != null ? Number(v).toFixed(1) : '—' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Leaderboards — HGB Stats — HockeyGameBot</title>
  <meta name="description" content="All NHL skaters ranked by WAR, Goals/60, xG/60, finishing, and HGB Impact. Sortable table, min 20 GP, 2025–26 season." />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #EFEEE8;
      --ink:      #0d0d14;
      --red:      #E8002D;
      --surface:  #FFFFFF;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04:   rgba(13,13,20,0.04);
      --ink-06:   rgba(13,13,20,0.06);
      --ink-10:   rgba(13,13,20,0.10);
      --ink-14:   rgba(13,13,20,0.14);
      --ink-20:   rgba(13,13,20,0.20);
      --ink-32:   rgba(13,13,20,0.32);
      --ink-48:   rgba(13,13,20,0.48);
      --ink-72:   rgba(13,13,20,0.72);
      --display:  'Barlow Condensed', sans-serif;
      --body:     'Barlow', sans-serif;
      --mono:     'JetBrains Mono', monospace;
      --stats-pos: #166534;
      --stats-neg: #991b1b;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    /* ── Masthead ── */
    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
      margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-eyebrow { font-family: var(--mono); font-weight: 500; font-size: 11px; letter-spacing: 0.12em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px);
      text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px; }
    .mast-headline em { color: var(--red); font-style: normal; }
    .mast-lede { font-size: 13.5px; line-height: 1.6; color: var(--ink-48); max-width: 640px; }
    .mast-lede .mono { font-family: var(--mono); font-size: 12px; color: var(--ink-72); }

    /* ── Layout ── */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

    /* ── Table section ── */
    .lb-section { padding: 40px 0 0; }
    .lb-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px;
      margin-bottom: 8px; }
    .lb-title { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px);
      text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
    .lb-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32);
      letter-spacing: 0.12em; text-transform: uppercase; }
    .dl-limit-note { font-family: var(--mono); font-size: 10px; color: var(--ink-48); white-space: nowrap; }

    /* ── Filter controls bar ── */
    .controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
    select { background: var(--surface); border: 1px solid var(--ink-14); padding: 6px 10px;
      font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em;
      color: var(--ink); cursor: pointer; outline: none; }
    .slider-wrap { display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--mono); font-size: 11px; color: var(--ink-48); }
    .slider-wrap input[type=range] { width: 100px; accent-color: var(--red); }
    #name-search { background: var(--surface); border: 1px solid var(--ink-14); padding: 6px 10px;
      font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em;
      color: var(--ink); outline: none; width: 160px; }
    #name-search::placeholder { color: var(--ink-32); font-weight: 400; }

    /* ── Mobile filter grouping ─────────────────────────────────────────── */
    /* Desktop: wrapper divs are transparent — children flow into .controls  */
    .filter-group { display: contents; }
    .filter-toggle-row { display: none; }

    @media (max-width: 768px) {
      .controls { flex-direction: column; align-items: stretch; gap: 0; margin-bottom: 8px; }

      .filter-group {
        display: flex; flex-wrap: wrap; gap: 8px;
        padding: 10px 0;
      }
      .filter-group--primary { padding-top: 12px; padding-bottom: 8px; }
      .filter-group--secondary {
        display: none;
        border-top: 1px solid var(--ink-10);
        padding-top: 12px;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: flex-start;
        gap: 8px;
      }
      .filter-group--secondary.is-open { display: flex; }
      /* Hide player count in header on mobile — redundant with mast copy */
      .lb-count-desktop { display: none; }
      .filter-group--search { padding-top: 10px; }

      .filter-toggle-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 7px 0;
        border-top: 1px solid var(--ink-10);
        border-bottom: 1px solid var(--ink-10);
        gap: 12px;
      }
      .filter-summary {
        font-family: var(--mono); font-size: 10px; color: var(--ink-48);
        letter-spacing: 0.06em; flex: 1; min-width: 0;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .filter-toggle-btn {
        flex-shrink: 0;
        font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em;
        text-transform: uppercase; white-space: nowrap;
        background: none; border: 1px solid var(--ink-20); color: var(--ink-48);
        cursor: pointer; padding: 5px 10px; display: flex; align-items: center; gap: 4px;
      }
      .filter-toggle-arrow { display: inline-block; font-size: 8px; transition: transform 0.15s; }
      .filter-toggle-btn[aria-expanded="true"] .filter-toggle-arrow { transform: rotate(180deg); }

    }

    /* ── Show-all row ── */
    .lb-more { padding: 14px 18px; border-top: 1px solid var(--ink-06); text-align: center; }
    .lb-more-btn {
      font-family: var(--mono); font-weight: 500; font-size: 10.5px;
      letter-spacing: 0.12em; text-transform: uppercase; padding: 7px 20px;
      border: 1px solid var(--ink-14); background: transparent; color: var(--ink-48);
      cursor: pointer; transition: all 0.1s;
    }
    .lb-more-btn:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }

    /* ── Stat cell percentile sub-line (Round 3) ─────────────────────────
       The skaters page renders "Advanced" cells as a two-line stack: the
       value (Impact, WAR, etc.) over the percentile rank ("90th"). Lives
       inside the .tbl-td so cells stay aligned with everything else. */
    .stat-stack { display: flex; flex-direction: column; align-items: center; gap: 1px; line-height: 1.2; }
    .stat-stack .sp {
      display: block; font-family: var(--mono); font-size: 10px;
      font-variant-numeric: tabular-nums;
    }
    .stat-stack .pe { color: #00c078; }   /* 90th+ */
    .stat-stack .pg { color: #60a5fa; }   /* 70th+ */
    .stat-stack .pa { color: var(--ink-32); } /* 40th+ */
    .stat-stack .pl { color: var(--red); opacity: 0.65; } /* <40th */
    .stat-stack .nil { color: var(--ink-32); }

    /* ── Methodology ── */
    .lb-method { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; margin-top: 40px; }
    .lb-method-h { padding: 12px 18px; border-bottom: 1px solid var(--ink-06);
      display: flex; justify-content: space-between; align-items: center; }
    .lb-method-h .title { font-family: var(--mono); font-weight: 500; font-size: 11px;
      letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-72); }
    .lb-method-h .tag  { font-family: var(--mono); font-size: 10px; color: var(--ink-32); }
    .lb-method-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
    @media (max-width: 640px) { .lb-method-grid { grid-template-columns: 1fr; } }
    .lb-method-card { padding: 20px; border-right: 1px solid var(--ink-06); }
    .lb-method-card:last-child { border-right: none; }
    .lb-method-card .k { font-family: var(--display); font-weight: 700; font-size: 13px;
      color: var(--ink); letter-spacing: 0.02em; text-transform: uppercase;
      margin-bottom: 6px; display: flex; align-items: baseline; justify-content: space-between; }
    .badge { font-family: var(--mono); font-size: 10px; padding: 1px 5px; letter-spacing: 0.1em; font-weight: 700; }
    .badge-core { color: var(--red); border: 1px solid rgba(232,0,45,0.4); }
    .lb-method-card .v { font-size: 12.5px; color: var(--ink-48); line-height: 1.55; }

    /* ── Footer ── */
    .lb-footer { text-align: center; margin-top: 48px; color: var(--ink-32);
      font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }

    @media (max-width: 768px) {
      .mast-inner { padding: 28px 20px; }
      .mast-card  { padding: 24px 20px 20px; }
      .wrap { padding: 0 20px 60px; }
    }
    @media (max-width: 480px) {
      .mast-inner { padding: 20px 16px; }
      .mast-card  { padding: 18px 14px 16px; }
      .wrap { padding: 0 16px 48px; }
    }
  </style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<!-- MASTHEAD -->
<section class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div class="mast-eyebrow"><span class="pip"></span> HGB Stats · Skaters</div>
      <div>min 20 GP · 2025–2026</div>
    </div>
    <div class="mast-card">
      <h1 class="mast-headline">All skaters.<br><em>Every stat.</em></h1>
      <p class="mast-lede">All {eligible.length} skaters sortable by counting stats, rates, or advanced metrics. Switch views with the tabs below.</p>
    </div>
  </div>
</section>

<main class="wrap">

  <!-- SKATER TABLE -->
  <section class="lb-section">
    <div class="lb-head">
      <span class="lb-title">Skater Stats</span>
      <span class="lb-meta lb-count-desktop" id="lb-count">{eligible.length} players · 2025–26{_statsDate ? ` · updated ${_statsDate}` : ''}</span>
    </div>
    <div class="controls" id="filter-controls">
      <!-- Primary: season type + stat group — always visible on mobile -->
      <div class="filter-group filter-group--primary">
        <ChipGroup
          id="gametype-filter"
          name="gametype"
          items={[
            { label: 'Regular Season', value: '2', active: true },
            { label: 'Playoffs',       value: '3' },
          ]}
        />
        <ChipGroup
          id="view-filter"
          name="view"
          items={[
            { label: 'Counting',   value: 'counting', active: true },
            { label: 'Rates',      value: 'rates' },
            { label: 'Advanced',   value: 'advanced' },
            { label: 'On-Ice 5v5', value: 'onice' },
          ]}
        />
      </div>

      <!-- Mobile-only: active filter summary + More filters toggle -->
      <div class="filter-toggle-row" role="button" aria-controls="filter-secondary">
        <span class="filter-summary" id="filter-summary" aria-live="polite"></span>
        <button class="filter-toggle-btn" id="filter-toggle-btn" type="button" aria-expanded="false" aria-controls="filter-secondary">
          Filters <span class="filter-toggle-arrow">▾</span>
        </button>
      </div>

      <!-- Secondary: collapsible on mobile, always visible on desktop -->
      <div class="filter-group filter-group--secondary" id="filter-secondary">
        <ChipGroup
          id="pos-filter"
          name="pos"
          items={[
            { label: 'All',  value: 'all', active: true },
            { label: 'Fwds', value: 'F' },
            { label: 'Def',  value: 'D' },
          ]}
        />
        <ChipGroup
          id="display-filter"
          name="display"
          items={[
            { label: 'Totals', value: 'totals', active: true },
            { label: 'Per 60', value: 'per60' },
          ]}
        />
        <ChipGroup
          id="strength-filter"
          name="strength"
          items={[
            { label: 'All', value: 'all', active: true },
            { label: '5v5', value: '5v5' },
            { label: 'PP',  value: 'pp' },
            { label: 'PK',  value: 'pk' },
          ]}
        />
        <select id="team-filter">
          <option value="all">All Teams</option>
        </select>
        <div class="slider-wrap">
          Min TOI: <span id="toi-label">—</span>
          <input type="range" id="toi-slider" min="0" max="28" value="0" step="1">
        </div>
        <ChipGroup
          id="topn-filter"
          name="topn"
          items={[
            { label: 'All',    value: '', active: true },
            { label: 'Top 10', value: '10' },
            { label: 'Top 20', value: '20' },
            { label: 'Top 50', value: '50' },
          ]}
        />
      </div>

      <!-- Search: always visible -->
      <div class="filter-group filter-group--search">
        <input type="search" id="name-search" placeholder="Search players…" autocomplete="off">
      </div>
    </div>

    <div style="display:flex;align-items:center;justify-content:flex-end;min-height:14px;margin-bottom:4px">
      <span class="dl-limit-note" id="dl-limit-note" style="display:none">Use Top 10/20/50 to export</span>
    </div>

    <Table
      columns={initialColumns}
      rows={ssrRows}
      rowHref={(r) => `/stats/player/${r.slug}`}
      defaultSort={{ column: 'points', direction: 'desc' }}
      scrollable
      maxHeight={700}
      exportFilename="hgb-skaters.png"
      exportTitle="Skater Stats"
      ariaLabel="NHL skater leaderboard"
    />
    <div class="lb-more" id="lb-more" style="display:none">
      <button class="lb-more-btn" id="lb-more-btn">Show all players →</button>
    </div>
  </section>

  <!-- METHODOLOGY -->
  <div class="lb-method">
    <div class="lb-method-h">
      <span class="title">How we measure</span>
      <span class="tag">methodology · 2025–2026</span>
    </div>
    <div class="lb-method-grid">
      <div class="lb-method-card">
        <div class="k">WAR <span class="badge badge-core">CORE</span></div>
        <div class="v">Wins Above Replacement — RAPM × total 5v5 TOI × 0.1, where RAPM (Regularized Adjusted Plus-Minus) controls for linemates and opponents via ridge regression. Cumulative season value; use for overall impact comparisons.</div>
      </div>
      <div class="lb-method-card">
        <div class="k">Expected goals (xG)</div>
        <div class="v">Probability a shot scores, based on location, angle, shot type, and context. Better signal than raw shot count — Tkachuk getting 16 shots/60 and only 1.44 xG/60 tells the real story.</div>
      </div>
      <div class="lb-method-card">
        <div class="k">Finishing</div>
        <div class="v">Goals/60 minus xG/60 — how much a player over- or under-performs their shot quality. Positive means they're converting at a rate above expected; negative suggests regression risk.</div>
      </div>
    </div>
  </div>

</main>

<footer class="lb-footer">HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026 · SKATERS V1</footer>

<!-- Client dataset -->
<script type="application/json" id="skaters-data" set:html={JSON.stringify(tableRows)}></script>

<script is:inline src="/js/table-export.js"></script>

<script define:vars={{ }}>
// ── Skaters page interactivity ───────────────────────────────────────────────
// View tab + filter changes drive a full tbody re-render + (optional) column
// schema swap via HGB_Table.replaceColumns. Sort is handled by Table.astro.
(function() {
  const PAGE = 50;
  const sgn2 = v => v >= 0 ? '+' : '';

  const dataEl = document.getElementById('skaters-data');
  if (!dataEl) return;
  const DATA = JSON.parse(dataEl.textContent || '[]');

  // ── State ──────────────────────────────────────────────────────────────
  let gameType    = 2;
  let viewTab     = 'counting';
  let posFilter   = 'all';
  let teamFilter  = 'all';
  let minToi      = 0;
  let sortKey     = 'points';
  let showAll     = false;
  let topN        = null;
  let searchQuery = '';
  let displayMode   = 'totals';
  let strengthMode  = 'all';

  // ── Tab definitions ────────────────────────────────────────────────────
  // Each tab specifies its non-fixed (stat) columns. Fixed columns (#, Player,
  // Pos, GP) prepend automatically. `poKey` is used for playoff data access
  // + sorting. `signed` enables ±value formatting + threshold color.
  // `pctKey` enables the stat-stack percentile sub-line.
  const TABS = {
    counting: {
      defaultSort: 'points',
      poDefaultSort: 'po_points',
      regOnly: false,
      cols: [
        { label: 'G',    key: 'goals',   poKey: 'po_goals' },
        { label: 'A',    key: 'assists', poKey: 'po_assists' },
        { label: 'P',    key: 'points',  poKey: 'po_points',  bold: true },
        { label: 'SOG',  key: 'sog',     poKey: 'po_sog' },
        { label: 'ixG',  key: 'ixg',     poKey: 'po_ixg',     fmt: v => Number(v).toFixed(2) },
        { label: 'TOI',  key: 'toi_pg',  poKey: 'po_toi_pg',  fmt: v => Number(v).toFixed(1) },
      ],
    },
    rates: {
      defaultSort: 'p60', regOnly: true,
      cols: [
        { label: 'G/60',  key: 'g60',  fmt: v => Number(v).toFixed(2) },
        { label: 'A/60',  key: 'a60',  fmt: v => Number(v).toFixed(2) },
        { label: 'P/60',  key: 'p60',  bold: true, fmt: v => Number(v).toFixed(2) },
        { label: 'xG/60', key: 'x60',  fmt: v => Number(v).toFixed(2) },
        { label: 'TOI/G', key: 'toi_pg', fmt: v => Number(v).toFixed(1) },
      ],
    },
    advanced: {
      defaultSort: 'imp', regOnly: true,
      cols: [
        { label: 'Impact', key: 'imp',  signed: true, bold: true, pctKey: 'imp_p',
          fmt: v => v != null ? sgn2(v) + Number(v).toFixed(2) : '—' },
        { label: 'WAR',    key: 'war',  signed: true, pctKey: 'war_p',
          fmt: v => v != null ? sgn2(v) + Number(v).toFixed(2) : '—' },
        { label: 'Finishing', key: 'fin', signed: true, pctKey: 'fin_p',
          fmt: v => v != null ? sgn2(v) + Number(v).toFixed(2) : '—' },
        { label: 'RAPM/60',   key: 'rapm', signed: true,
          fmt: v => v != null ? sgn2(v) + Number(v).toFixed(3) : '—' },
      ],
    },
    onice: {
      defaultSort: 'xgf_pct', regOnly: true,
      cols: [
        { label: 'xGF%',   key: 'xgf_pct', bold: true,
          fmt: v => Number(v).toFixed(1) + '%',
          color: v => v >= 55 ? 'var(--stats-pos)' : v <= 45 ? 'var(--stats-neg)' : null },
        { label: 'xGF/60', key: 'xgf60', fmt: v => Number(v).toFixed(2) },
        { label: 'xGA/60', key: 'xga60', fmt: v => Number(v).toFixed(2) },
        { label: 'SC/60',  key: 'sc60',  fmt: v => Number(v).toFixed(2) },
        { label: 'HDC/60', key: 'hdc60', fmt: v => Number(v).toFixed(2) },
      ],
    },
  };

  const COUNTING_PER60_COLS = [
    { label: 'G/60',   key: 'g60',    fmt: v => Number(v).toFixed(2) },
    { label: 'A/60',   key: 'a60',    fmt: v => Number(v).toFixed(2) },
    { label: 'P/60',   key: 'p60',    bold: true, fmt: v => Number(v).toFixed(2) },
    { label: 'SOG/60', key: 'sog60',  fmt: v => Number(v).toFixed(2) },
    { label: 'ixG/60', key: 'x60',    fmt: v => Number(v).toFixed(2) },
    { label: 'TOI/G',  key: 'toi_pg', fmt: v => Number(v).toFixed(1) },
  ];
  const TOTALS_TO_P60 = { points: 'p60', goals: 'g60', assists: 'a60', sog: 'sog60', ixg: 'x60' };
  const P60_TO_TOTALS = { p60: 'points', g60: 'goals', a60: 'assists', sog60: 'sog', x60: 'ixg' };

  // ── Strength-state helpers ─────────────────────────────────────────────
  function getStrengthStats(r, mode) {
    if (mode === 'all') return { goals: r.goals, assists: r.assists, points: r.points, sog: r.sog, ixg: r.ixg, toi_sec: null, toi_pg: r.toi_pg };
    let goals, assists, sog, ixg, toiSec;
    if (mode === '5v5') {
      goals = r.goals_ev ?? 0; assists = r.a_ev ?? 0; sog = r.shots_ev ?? 0; ixg = r.ixg_ev ?? 0; toiSec = r.toi_ev_sec ?? 0;
    } else if (mode === 'pp') {
      goals = r.goals_pp ?? 0; assists = r.a_pp ?? 0; sog = r.shots_pp ?? 0; ixg = r.ixg_pp ?? 0; toiSec = r.toi_pp_sec ?? 0;
    } else {
      goals = r.goals_sh ?? 0; assists = r.a_pk ?? 0; sog = r.shots_pk ?? 0; ixg = r.ixg_pk ?? 0; toiSec = r.toi_pk_sec ?? 0;
    }
    return { goals, assists, points: goals + assists, sog, ixg, toi_sec: toiSec, toi_pg: toiSec > 0 ? toiSec / r.gp / 60 : 0 };
  }

  function getStatValue(r, key, st, hr) {
    switch (key) {
      case 'goals':   return st.goals;
      case 'assists': return st.assists;
      case 'points':  return st.points;
      case 'sog':     return st.sog;
      case 'ixg':     return st.ixg;
      case 'toi_pg':  return st.toi_pg;
      case 'g60':     return st.goals   / hr;
      case 'a60':     return st.assists / hr;
      case 'p60':     return st.points  / hr;
      case 'sog60':   return st.sog     / hr;
      case 'x60':     return st.ixg     / hr;
      default:        return r[key];
    }
  }

  function getActiveCols() {
    let cols;
    if (viewTab === 'counting' && displayMode === 'per60' && gameType !== 3) {
      cols = COUNTING_PER60_COLS;
    } else {
      cols = TABS[viewTab].cols;
    }
    if (strengthMode !== 'all' && (viewTab === 'counting' || viewTab === 'rates')) {
      const prefix = { '5v5': 'EV ', pp: 'PP ', pk: 'SH ' }[strengthMode];
      const strengthKeys = new Set(['goals','assists','points','sog','ixg','toi_pg','g60','a60','p60','sog60','x60']);
      return cols.map(c => strengthKeys.has(c.key) ? { ...c, label: prefix + c.label } : c);
    }
    return cols;
  }

  function resolveDefaultSort(tab, gt) {
    const isPlayoff = (gt ?? gameType) === 3;
    return (isPlayoff && TABS[tab].poDefaultSort) ? TABS[tab].poDefaultSort : TABS[tab].defaultSort;
  }

  function readUrl() {
    const p = new URLSearchParams(window.location.search);
    if (p.get('game_type') === '3' || p.get('season') === 'playoff') gameType = 3;
    const tab = p.get('tab');
    if (tab && TABS[tab]) { viewTab = tab; }
    sortKey = resolveDefaultSort(viewTab, gameType);
    const team = p.get('team');
    if (team) teamFilter = team;
    const toi = parseInt(p.get('toi') || '0');
    if (!isNaN(toi)) minToi = toi;
    if (p.get('display') === 'per60') {
      displayMode = 'per60';
      if (viewTab === 'counting' && TOTALS_TO_P60[sortKey]) sortKey = TOTALS_TO_P60[sortKey];
    }
    const strength = p.get('strength');
    if (strength && ['5v5', 'pp', 'pk'].includes(strength)) strengthMode = strength;
  }

  function updateUrl() {
    const p = new URLSearchParams();
    if (gameType === 3) p.set('game_type', '3');
    if (viewTab !== 'counting') p.set('tab', viewTab);
    if (teamFilter !== 'all') p.set('team', teamFilter);
    if (minToi > 0) p.set('toi', String(minToi));
    if (displayMode === 'per60') p.set('display', 'per60');
    if (strengthMode !== 'all') p.set('strength', strengthMode);
    history.replaceState(null, '', p.toString() ? `?${p}` : window.location.pathname);
  }

  function syncUi() {
    const isPlayoff = gameType === 3;

    document.querySelectorAll('#gametype-filter button').forEach(btn => {
      btn.classList.toggle('active', parseInt(btn.dataset.gametype) === gameType);
    });
    if (isPlayoff && TABS[viewTab]?.regOnly) {
      viewTab = 'counting';
      sortKey = resolveDefaultSort('counting');
    }
    document.querySelectorAll('#view-filter button').forEach(btn => {
      const v = btn.dataset.view;
      const regOnly = TABS[v]?.regOnly;
      btn.classList.toggle('active', v === viewTab);
      btn.style.opacity = (isPlayoff && regOnly) ? '0.35' : '';
      btn.style.pointerEvents = (isPlayoff && regOnly) ? 'none' : '';
    });
    document.querySelectorAll('#display-filter button').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.display === displayMode);
      const isPer60 = btn.dataset.display === 'per60';
      if (isPer60) {
        btn.style.opacity      = isPlayoff ? '0.35' : '';
        btn.style.pointerEvents = isPlayoff ? 'none' : '';
      }
    });
    const strengthOk = !isPlayoff && (viewTab === 'counting' || viewTab === 'rates');
    document.querySelectorAll('#strength-filter button').forEach(btn => {
      const sm = btn.dataset.strength;
      btn.classList.toggle('active', sm === strengthMode);
      if (sm !== 'all') {
        btn.style.opacity       = strengthOk ? '' : '0.35';
        btn.style.pointerEvents = strengthOk ? '' : 'none';
      }
    });
  }

  // ── Filter + sort the row set ──────────────────────────────────────────
  function getRows() {
    const isPlayoff = gameType === 3;
    let rows = DATA.slice();
    if (isPlayoff) rows = rows.filter(r => r.po_gp != null && r.po_gp > 0);
    if (posFilter !== 'all') rows = rows.filter(r => r.group === posFilter);
    if (teamFilter !== 'all') rows = rows.filter(r => r.team === teamFilter);
    if (minToi > 0) {
      const toiKey = (isPlayoff && viewTab === 'counting') ? 'po_toi_pg' : 'toi_pg';
      rows = rows.filter(r => (r[toiKey] ?? 0) >= minToi);
    }
    if (searchQuery) {
      const q = searchQuery.toLowerCase();
      rows = rows.filter(r => (r.searchText || r.name.toLowerCase()).includes(q));
    }
    rows.sort((a, b) => {
      let av, bv;
      if (strengthMode !== 'all' && (viewTab === 'counting' || viewTab === 'rates') && gameType !== 3) {
        const sta = getStrengthStats(a, strengthMode);
        const stb = getStrengthStats(b, strengthMode);
        const hra = (sta.toi_sec / 3600) || 0.001;
        const hrb = (stb.toi_sec / 3600) || 0.001;
        av = getStatValue(a, sortKey, sta, hra) ?? -Infinity;
        bv = getStatValue(b, sortKey, stb, hrb) ?? -Infinity;
      } else {
        av = a[sortKey] ?? -Infinity;
        bv = b[sortKey] ?? -Infinity;
      }
      return bv - av;
    });
    if (topN != null) rows = rows.slice(0, topN);
    return rows;
  }

  function pctCls(p) {
    if (p == null) return 'pa';
    return p >= 90 ? 'pe' : p >= 70 ? 'pg' : p >= 40 ? 'pa' : 'pl';
  }
  function ordinal(p) {
    if (p == null) return '—';
    const s = (p % 100 >= 11 && p % 100 <= 13) ? 'th' :
      p % 10 === 1 ? 'st' : p % 10 === 2 ? 'nd' : p % 10 === 3 ? 'rd' : 'th';
    return `${p}${s}`;
  }
  function esc(s) {
    return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  // ── Build a single <tr> matching Table.astro's output ────────────────
  function rowHtml(r, rank, activeCols) {
    const isPlayoff = gameType === 3;
    const gp = (isPlayoff && viewTab === 'counting') ? r.po_gp : r.gp;
    const useStrength = strengthMode !== 'all' && (viewTab === 'counting' || viewTab === 'rates') && !isPlayoff;
    const st = useStrength ? getStrengthStats(r, strengthMode) : null;
    const hr = st ? ((st.toi_sec / 3600) || 0.001) : 1;
    const href = `/stats/player/${r.slug}`;
    const teamAbbr = esc(r.team || '');
    const nameEsc = esc(r.name);
    const subText = `${r.team} · ${r.pos} · ${gp} GP`;

    const cells = [];
    // Rank
    cells.push(`<td class="tbl-td td-rk align-right">${String(rank).padStart(2, '0')}</td>`);
    // Player
    cells.push(
      `<td class="tbl-td td-player align-left">` +
      `<div class="td-player-inner">` +
      (teamAbbr ? `<img class="td-logo" src="https://assets.nhle.com/logos/nhl/svg/${teamAbbr}_light.svg" width="22" height="22" alt="${teamAbbr}" loading="lazy" onerror="this.style.display='none'" />` : '') +
      `<div class="td-player-meta">` +
      `<span class="td-name">${nameEsc}</span>` +
      `<span class="td-sub">${esc(subText)}</span>` +
      `</div></div></td>`
    );
    // Pos
    cells.push(`<td class="tbl-td align-center"><span class="pos-badge">${esc(r.pos)}</span></td>`);
    // GP
    cells.push(`<td class="tbl-td align-center type-number">${gp == null ? '—' : String(gp)}</td>`);

    // Stat cells
    for (const c of activeCols) {
      const dataKey = (isPlayoff && c.poKey) ? c.poKey : c.key;
      const val = st ? getStatValue(r, c.key, st, hr) : r[dataKey];
      const cls = ['tbl-td', 'align-center', 'type-number', c.bold ? 'bold' : ''].filter(Boolean).join(' ');
      let color;
      if (c.signed && val != null) color = val >= 0 ? 'var(--stats-pos)' : 'var(--stats-neg)';
      else if (c.color && val != null) color = c.color(val);
      const style = color ? ` style="color:${color}"` : '';

      let content;
      if (val == null) {
        content = '—';
      } else if (c.fmt) {
        content = c.fmt(val);
      } else {
        content = String(val);
      }

      // If a percentile sub-line is configured (Advanced view), stack it under
      // the value. Otherwise plain text.
      if (c.pctKey) {
        const pct = r[c.pctKey];
        const pctLabel = ordinal(pct);
        const pctCol = pctCls(pct);
        content = `<div class="stat-stack"><span>${content}</span><span class="sp ${pctCol}">${pctLabel}</span></div>`;
      }
      cells.push(`<td class="${cls}"${style}>${content}</td>`);
    }

    return `<tr class="tbl-tr clickable" tabindex="0" data-href="${href}" role="link">${cells.join('')}</tr>`;
  }

  // ── Map active stat columns to Table.astro schema entries ──────────────
  function buildSchema(activeCols) {
    const schema = [
      { key: '_rank',  label: '#',      type: 'rank', sortable: false },
      { key: 'name',   label: 'Player', type: 'player', sortable: true },
      { key: 'pos',    label: 'Pos',    type: 'position', sortable: true },
      { key: 'gp',     label: 'GP',     type: 'number', sortable: true },
    ];
    for (const c of activeCols) {
      const dataKey = (gameType === 3 && c.poKey) ? c.poKey : c.key;
      schema.push({
        key: dataKey,
        label: c.label,
        type: 'number',
        sortable: true,
        bold: !!c.bold,
      });
    }
    return schema;
  }

  // ── Render ─────────────────────────────────────────────────────────────
  const wrap = document.querySelector('.tbl-wrap[data-tbl-id]');
  if (!wrap) return;
  const tblId = wrap.dataset.tblId;
  const tbody = wrap.querySelector('tbody');

  function render() {
    const activeCols = getActiveCols();
    const allRows = getRows();
    const total = allRows.length;
    const visible = showAll ? allRows : allRows.slice(0, PAGE);

    // Replace column schema (header + colgroup) — must run BEFORE tbody swap
    // so the schema index lines up with the cells.
    const newSchema = buildSchema(activeCols);
    const replacer = window.HGB_Table && window.HGB_Table.replaceColumns;
    if (typeof replacer === 'function') replacer(tblId, newSchema);

    if (visible.length === 0) {
      const colspan = newSchema.length;
      tbody.innerHTML = `<tr class="tbl-empty"><td colspan="${colspan}">${gameType === 3 ? 'Playoff data available once postseason begins' : 'No data'}</td></tr>`;
    } else {
      tbody.innerHTML = visible.map((r, i) => rowHtml(r, i + 1, activeCols)).join('');
    }
    wrap.dispatchEvent(new CustomEvent('tbl:rows-changed'));

    // Count + "show all" pagination chrome
    const countEl = document.getElementById('lb-count');
    if (countEl) {
      const season = gameType === 3 ? '2025–26 playoffs' : '2025–26';
      const label  = topN != null ? `Top ${total} · ${season}` : `${total} players · ${season}`;
      countEl.textContent = label;
    }
    const moreDiv = document.getElementById('lb-more');
    const moreBtn = document.getElementById('lb-more-btn');
    if (moreDiv && moreBtn) {
      if (!showAll && total > PAGE) {
        moreDiv.style.display = '';
        moreBtn.textContent = `Show all ${total} players →`;
      } else {
        moreDiv.style.display = 'none';
      }
    }

    // Export guard: disable when too many rows and no Top N limit
    const exportBtn = wrap.querySelector('button.tbl-export-btn');
    const dlNote  = document.getElementById('dl-limit-note');
    const tooMany = topN == null && total > 20;
    if (exportBtn) { exportBtn.disabled = tooMany; exportBtn.style.opacity = tooMany ? '0.35' : ''; }
    if (dlNote) { dlNote.style.display = tooMany ? '' : 'none'; }
    if (typeof updateFilterSummary === 'function') updateFilterSummary();
  }

  // ── Event handlers ─────────────────────────────────────────────────────
  document.querySelectorAll('#gametype-filter button').forEach(btn => {
    btn.addEventListener('click', () => {
      const gt = parseInt(btn.dataset.gametype);
      if (gt === gameType) return;
      gameType = gt;
      if (gt === 3) strengthMode = 'all';
      sortKey  = resolveDefaultSort(viewTab, gt);
      showAll  = false;
      updateUrl();
      syncUi();
      render();
    });
  });
  document.querySelectorAll('#view-filter button').forEach(btn => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.view;
      if (v === viewTab || (gameType === 3 && TABS[v]?.regOnly)) return;
      viewTab = v;
      if (v !== 'counting' && v !== 'rates') strengthMode = 'all';
      sortKey = resolveDefaultSort(v);
      showAll = false;
      updateUrl();
      syncUi();
      render();
    });
  });
  document.querySelectorAll('[data-pos]').forEach(btn => {
    btn.addEventListener('click', () => {
      posFilter = btn.dataset.pos;
      showAll   = false;
      document.querySelectorAll('[data-pos]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      render();
    });
  });
  document.querySelectorAll('#display-filter button').forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.display;
      if (mode === displayMode || gameType === 3) return;
      if (mode === 'per60'   && TOTALS_TO_P60[sortKey]) sortKey = TOTALS_TO_P60[sortKey];
      if (mode === 'totals'  && P60_TO_TOTALS[sortKey]) sortKey = P60_TO_TOTALS[sortKey];
      displayMode = mode;
      showAll = false;
      updateUrl();
      syncUi();
      render();
    });
  });
  document.querySelectorAll('#strength-filter button').forEach(btn => {
    btn.addEventListener('click', () => {
      const sm = btn.dataset.strength;
      if (sm === strengthMode || gameType === 3) return;
      if (sm !== 'all' && viewTab !== 'counting' && viewTab !== 'rates') return;
      strengthMode = sm;
      showAll = false;
      updateUrl();
      syncUi();
      render();
    });
  });

  document.getElementById('lb-more-btn')?.addEventListener('click', () => {
    showAll = true;
    render();
  });

  // Team + TOI + topN + search
  (function() {
    const teams = [...new Set(DATA.map(r => r.team))].sort();
    const sel = document.getElementById('team-filter');
    teams.forEach(t => {
      const opt = document.createElement('option');
      opt.value = t; opt.textContent = t;
      sel.appendChild(opt);
    });
    if (teamFilter !== 'all') sel.value = teamFilter;
  })();
  function syncToiLabel() {
    const el = document.getElementById('toi-label');
    if (el) el.textContent = minToi > 0 ? `${minToi}m` : '—';
    const slider = document.getElementById('toi-slider');
    if (slider) slider.value = String(minToi);
  }
  document.getElementById('team-filter')?.addEventListener('change', function() {
    teamFilter = this.value;
    showAll = false;
    updateUrl();
    render();
  });
  document.getElementById('toi-slider')?.addEventListener('input', function() {
    minToi = parseInt(this.value);
    syncToiLabel();
    showAll = false;
    updateUrl();
    render();
  });
  document.querySelectorAll('#topn-filter button').forEach(btn => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.topn;
      topN = v ? parseInt(v) : null;
      showAll = false;
      document.querySelectorAll('#topn-filter button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      render();
    });
  });
  document.getElementById('name-search')?.addEventListener('input', function() {
    searchQuery = this.value.trim();
    showAll = false;
    render();
  });

  // ── Mobile filter toggle ───────────────────────────────────────────────
  const filterToggleBtn = document.getElementById('filter-toggle-btn');
  const filterSecondary = document.getElementById('filter-secondary');
  if (filterToggleBtn && filterSecondary) {
    filterToggleBtn.addEventListener('click', () => {
      const isOpen = filterSecondary.classList.toggle('is-open');
      filterToggleBtn.setAttribute('aria-expanded', String(isOpen));
    });
  }

  // ── Active filter summary (mobile) ─────────────────────────────────────
  function updateFilterSummary() {
    const el = document.getElementById('filter-summary');
    if (!el) return;
    const parts = [];
    if (gameType !== 2) parts.push('Playoffs');
    const viewLabels = { rates: 'Rates', advanced: 'Advanced', onice: 'On-Ice' };
    if (viewTab !== 'counting') parts.push(viewLabels[viewTab] || viewTab);
    if (posFilter !== 'all') parts.push(posFilter === 'F' ? 'Fwds' : 'Defs');
    if (displayMode !== 'totals') parts.push('Per 60');
    if (strengthMode !== 'all') parts.push(strengthMode.toUpperCase());
    if (teamFilter !== 'all') parts.push(teamFilter);
    if (minToi > 0) parts.push(minToi + '+ min TOI');
    if (topN) parts.push('Top ' + topN);
    if (searchQuery) parts.push('"' + searchQuery + '"');
    el.textContent = parts.length ? parts.join(' · ') : 'All defaults';
  }

  readUrl();
  syncUi();
  syncToiLabel();
  render();
  updateFilterSummary();
})();
</script>

</body>
</html>
