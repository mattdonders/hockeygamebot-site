---
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import { loadPlayers } from '../../lib/stats-loader';

const allPlayers = loadPlayers();
const eligible   = allPlayers.filter(p => p.gp >= 20);

// Pre-sort rapm arrays for O(n log n) percentile lookup at build time
const fwdRapm = eligible.filter(p => p.pos_group === 'F').map(p => p.rapm ?? 0).sort((a,b) => a - b);
const defRapm = eligible.filter(p => p.pos_group === 'D').map(p => p.rapm ?? 0).sort((a,b) => a - b);

function warPct(rapm: number | null, group: 'F' | 'D'): number | null {
  if (rapm == null) return null;
  const arr = group === 'F' ? fwdRapm : defRapm;
  let lo = 0, hi = arr.length;
  while (lo < hi) { const mid = (lo + hi) >>> 1; if (arr[mid] <= rapm) lo = mid + 1; else hi = mid; }
  return Math.round((lo / arr.length) * 100);
}

const toi60 = (p: typeof eligible[0]) => (p.toi_avg_sec * p.gp) / 3600 || 1;

const tableRows = eligible.map(p => {
  const evOff    = p.rates_per_60.ev_offence;
  const evDef    = p.rates_per_60.ev_defence;
  const xgfTotal = evOff + evDef;
  const tot60    = toi60(p);
  const goals    = p.goals;
  const assists  = p.assists;
  return {
    slug:     p.slug,
    name:     p.display_name,
    team:     p.team_abbrev,
    pos:      p.pos,
    group:    p.pos_group,
    gp:       p.gp,
    // Counting stats
    goals,
    assists,
    points:   goals + assists,
    sog:      Math.round(p.rates_per_60.shots * tot60),
    ixg:      +(p.rates_per_60.ixg * tot60).toFixed(2),
    toi_pg:   +(p.toi_avg_sec / 60).toFixed(1),
    // Rates
    g60:      +p.rates_per_60.goals.toFixed(2),
    a60:      +(assists / tot60).toFixed(2),
    p60:      +((goals + assists) / tot60).toFixed(2),
    x60:      +p.rates_per_60.ixg.toFixed(2),
    // Advanced
    war:      p.war ?? null,
    war_p:    warPct(p.rapm, p.pos_group),
    fin:      +p.rates_per_60.finishing.toFixed(2),
    fin_p:    Math.round(p.percentiles_vs_pos.finishing),
    imp:      +p.avg_gs_display.toFixed(2),
    imp_p:    Math.round(p.gs_pct),
    rapm:     p.rapm != null ? +p.rapm.toFixed(3) : null,
    // 5v5 (kept for future tabs)
    xgf_pct:  xgfTotal > 0 ? +(evOff / xgfTotal * 100).toFixed(1) : 50.0,
    xgf60:    +evOff.toFixed(2),
    xga60:    +evDef.toFixed(2),
    sc60:     +(p.rates_per_60.sc_per60 ?? 0).toFixed(2),
    hdc60:    +(p.rates_per_60.hdc_per60 ?? 0).toFixed(2),
    hdc_pct:  +(p.hdc_pct ?? 50).toFixed(1),
    // PP
    pp_toi:   p.toi_pp_sec_total != null ? +(p.toi_pp_sec_total / p.gp / 60).toFixed(1) : 0,
    pp_g:     p.goals_pp ?? 0,
    pp_xg60:  +(p.rates_per_60.xg_pp_per60 ?? 0).toFixed(2),
    // Playoff counting — null if player didn't play playoffs
    po_gp:      p.playoff_gp      ?? null,
    po_goals:   p.playoff_goals   ?? null,
    po_assists: p.playoff_assists  ?? null,
    po_points:  p.playoff_points   ?? null,
    po_sog:     p.playoff_sog      ?? null,
    po_ixg:     p.playoff_ixg      ?? null,
    po_toi_pg:  p.playoff_toi_sec != null && p.playoff_gp
                  ? +(p.playoff_toi_sec / p.playoff_gp / 60).toFixed(1)
                  : null,
  };
});

---
<!DOCTYPE html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Leaderboards — HGB Stats — HockeyGameBot</title>
  <meta name="description" content="All NHL skaters ranked by WAR, Goals/60, xG/60, finishing, and HGB Impact. Sortable table, min 20 GP, 2025–26 season." />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #EFEEE8;
      --ink:      #0d0d14;
      --red:      #E8002D;
      --surface:  #FFFFFF;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04:   rgba(13,13,20,0.04);
      --ink-06:   rgba(13,13,20,0.06);
      --ink-10:   rgba(13,13,20,0.10);
      --ink-14:   rgba(13,13,20,0.14);
      --ink-20:   rgba(13,13,20,0.20);
      --ink-32:   rgba(13,13,20,0.32);
      --ink-48:   rgba(13,13,20,0.48);
      --ink-72:   rgba(13,13,20,0.72);
      --display:  'Barlow Condensed', sans-serif;
      --body:     'Barlow', sans-serif;
      --mono:     'JetBrains Mono', monospace;
      --stats-pos: #166534;
      --stats-neg: #991b1b;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    /* ── Masthead ── */
    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
      margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px);
      text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px; }
    .mast-headline em { color: var(--red); font-style: normal; }
    .mast-lede { font-size: 13.5px; line-height: 1.6; color: var(--ink-48); max-width: 640px; }
    .mast-lede .mono { font-family: var(--mono); font-size: 12px; color: var(--ink-72); }

    /* ── Layout ── */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

    /* ── Table section ── */
    .lb-section { padding: 40px 0 0; }
    .lb-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px;
      margin-bottom: 8px; }
    .lb-title { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px);
      text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
    .lb-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32);
      letter-spacing: 0.12em; text-transform: uppercase; }
    .lb-dl-btn { background: none; border: 1px solid var(--ink-20); padding: 5px 12px; cursor: pointer; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-48); transition: all 0.15s; border-radius: 2px; white-space: nowrap; }
    .lb-dl-btn:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }

    /* ── Filter controls bar ── */
    .controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
    .btn-group { display: inline-flex; border: 1px solid var(--ink-14); }
    .btn-group button { background: var(--surface); border: none; border-right: 1px solid var(--ink-14);
      padding: 6px 14px; cursor: pointer; font-family: var(--body); font-weight: 600;
      font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--ink-48); transition: background 0.1s, color 0.1s; }
    .btn-group button:last-child { border-right: none; }
    .btn-group button.active { background: var(--ink); color: var(--bg); }
    .btn-group button:hover:not(.active) { background: var(--ink-06); color: var(--ink); }
    select { background: var(--surface); border: 1px solid var(--ink-14); padding: 6px 10px;
      font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em;
      color: var(--ink); cursor: pointer; outline: none; }
    .slider-wrap { display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--mono); font-size: 11px; color: var(--ink-48); }
    .slider-wrap input[type=range] { width: 100px; accent-color: var(--red); }
    #name-search { background: var(--surface); border: 1px solid var(--ink-14); padding: 6px 10px;
      font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em;
      color: var(--ink); outline: none; width: 160px; }
    #name-search::placeholder { color: var(--ink-32); font-weight: 400; }
    .lb-dl-btn:disabled { opacity: 0.35; cursor: not-allowed; }
    .dl-limit-note { font-family: var(--mono); font-size: 10px; color: var(--ink-48); white-space: nowrap; }

    /* ── Table ── */
    .lb-wrap { background: var(--surface); border: 1px solid var(--ink-14);
      overflow-x: auto; overflow-y: auto; max-height: 700px; }
    table { width: 100%; border-collapse: collapse; font-family: var(--body); font-size: 13px; }

    thead { position: sticky; top: 0; z-index: 20; background: var(--surface);
      box-shadow: 0 2px 0 var(--ink); }
    thead th {
      padding: 9px 12px; font-family: var(--display); font-weight: 700; font-size: 12px;
      letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-48);
      border-bottom: 2px solid var(--ink); text-align: right;
      cursor: pointer; user-select: none; white-space: nowrap; transition: color 0.1s;
    }
    thead th:first-child  { text-align: left; padding-left: 16px; cursor: default; }
    thead th.th-player    { text-align: left; cursor: default; }
    thead th:hover        { color: var(--ink); }
    thead th.sorted       { color: var(--ink); }
    .sort-arrow { display: inline-block; margin-left: 4px; opacity: 0.4; font-size: 9px; }
    thead th.sorted .sort-arrow { opacity: 1; color: var(--red); }

    tbody tr { border-bottom: 1px solid var(--ink-06); transition: background 0.08s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--ink-04); }

    td { padding: 8px 12px; vertical-align: middle; }
    td:first-child { padding-left: 16px; }

    /* Rank */
    .td-rk { font-family: var(--mono); font-size: 11px; color: var(--ink-32);
      text-align: left; font-variant-numeric: tabular-nums; min-width: 24px; }
    tbody tr:nth-child(-n+3) .td-rk { color: var(--red); font-weight: 700; }

    /* Player */
    .td-player { display: flex; align-items: center; gap: 10px; min-width: 150px; }
    .td-logo   { width: 22px; height: 22px; object-fit: contain; opacity: 0.85; flex-shrink: 0; }
    .td-info   { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .td-name   { font-family: var(--body); font-size: 15px; font-weight: 600; color: var(--ink);
      text-decoration: none; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .td-name:hover { color: var(--red); }
    .td-sub    { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32);
      letter-spacing: 0.04em; white-space: nowrap; }

    /* Pos + GP */
    .td-pos { font-family: var(--mono); font-size: 10.5px; color: var(--ink-32);
      text-align: center; letter-spacing: 0.04em; }
    .td-gp  { font-family: var(--mono); font-size: 11px; color: var(--ink-32); text-align: right; }

    /* Stat cells: value + percentile on two lines */
    .td-stat { text-align: right; white-space: nowrap; }
    .sv {
      display: block; font-family: var(--mono); font-size: 13px; font-weight: 700;
      font-variant-numeric: tabular-nums; color: var(--ink); line-height: 1.25;
    }
    .sv.pos { color: var(--stats-pos); }
    .sv.neg { color: var(--stats-neg); }
    .sv.nil { color: var(--ink-32); font-weight: 400; font-size: 12px; }
    .sp {
      display: block; font-family: var(--mono); font-size: 9px;
      font-variant-numeric: tabular-nums; line-height: 1.2;
    }
    .pe { color: #00c078; }   /* 90th+ */
    .pg { color: #60a5fa; }   /* 70th+ */
    .pa { color: var(--ink-32); } /* 40th+ */
    .pl { color: var(--red); opacity: 0.65; } /* <40th */

    /* Show-all row */
    .lb-more { padding: 14px 18px; border-top: 1px solid var(--ink-06); text-align: center; }
    .lb-more-btn {
      font-family: var(--display); font-weight: 700; font-size: 10.5px;
      letter-spacing: 0.18em; text-transform: uppercase; padding: 7px 20px;
      border: 1px solid var(--ink-14); background: transparent; color: var(--ink-48);
      cursor: pointer; transition: all 0.1s;
    }
    .lb-more-btn:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }

    /* ── Methodology ── */
    .lb-method { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; margin-top: 40px; }
    .lb-method-h { padding: 12px 18px; border-bottom: 1px solid var(--ink-06);
      display: flex; justify-content: space-between; align-items: center; }
    .lb-method-h .title { font-family: var(--display); font-weight: 700; font-size: 11px;
      letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-72); }
    .lb-method-h .tag  { font-family: var(--mono); font-size: 10px; color: var(--ink-32); }
    .lb-method-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
    @media (max-width: 640px) { .lb-method-grid { grid-template-columns: 1fr; } }
    .lb-method-card { padding: 20px; border-right: 1px solid var(--ink-06); }
    .lb-method-card:last-child { border-right: none; }
    .lb-method-card .k { font-family: var(--display); font-weight: 700; font-size: 13px;
      color: var(--ink); letter-spacing: 0.02em; text-transform: uppercase;
      margin-bottom: 6px; display: flex; align-items: baseline; justify-content: space-between; }
    .badge { font-family: var(--mono); font-size: 10px; padding: 1px 5px; letter-spacing: 0.1em; font-weight: 700; }
    .badge-core { color: var(--red); border: 1px solid rgba(232,0,45,0.4); }
    .lb-method-card .v { font-size: 12.5px; color: var(--ink-48); line-height: 1.55; }

    /* ── Footer ── */
    .lb-footer { text-align: center; margin-top: 48px; color: var(--ink-32);
      font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .c-a60, .c-imp { display: none; }
    }
    @media (max-width: 640px) {
      .c-fin, .c-pos { display: none; }
      .td-sub { display: none; }
    }
    @media (max-width: 768px) {
      .mast-inner { padding: 28px 20px; }
      .mast-card  { padding: 24px 20px 20px; }
      .wrap { padding: 0 20px 60px; }
    }
    @media (max-width: 480px) {
      .mast-inner { padding: 20px 16px; }
      .mast-card  { padding: 18px 14px 16px; }
      .wrap { padding: 0 16px 48px; }
    }
  </style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<!-- MASTHEAD -->
<section class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div class="mast-eyebrow"><span class="pip"></span> HGB Stats · Skaters</div>
      <div>min 20 GP · 2025–2026</div>
    </div>
    <div class="mast-card">
      <h1 class="mast-headline">All skaters.<br><em>Every stat.</em></h1>
      <p class="mast-lede">All {eligible.length} skaters sortable by counting stats, rates, or advanced metrics. Switch views with the tabs below.</p>
    </div>
  </div>
</section>

<main class="wrap">

  <!-- SKATER TABLE -->
  <section class="lb-section">
    <div class="lb-head">
      <span class="lb-title">Skater Stats</span>
      <div style="display:flex;align-items:center;gap:12px">
        <span class="lb-meta" id="lb-count">{eligible.length} players · 2025–26</span>
        <span class="dl-limit-note" id="dl-limit-note" style="display:none">Use Top 10/20/50 to export</span>
        <button class="lb-dl-btn" id="dl-btn">↓ PNG</button>
      </div>
    </div>
    <div class="controls">
      <div class="btn-group" id="gametype-filter">
        <button class="active" data-gametype="2">Regular Season</button>
        <button data-gametype="3">Playoffs</button>
      </div>
      <div class="btn-group" id="view-filter">
        <button class="active" data-view="counting">Counting</button>
        <button data-view="rates">Rates</button>
        <button data-view="advanced">Advanced</button>
        <button data-view="onice">On-Ice 5v5</button>
      </div>
      <div class="btn-group" id="pos-filter">
        <button class="active" data-pos="all">All</button>
        <button data-pos="F">Fwds</button>
        <button data-pos="D">Def</button>
      </div>
      <select id="team-filter">
        <option value="all">All Teams</option>
      </select>
      <div class="slider-wrap">
        Min TOI: <span id="toi-label">—</span>
        <input type="range" id="toi-slider" min="0" max="28" value="0" step="1">
      </div>
      <div class="btn-group" id="topn-filter">
        <button class="active" data-topn="">All</button>
        <button data-topn="10">Top 10</button>
        <button data-topn="20">Top 20</button>
        <button data-topn="50">Top 50</button>
      </div>
      <input type="search" id="name-search" placeholder="Search players…" autocomplete="off">
    </div>

    <div class="lb-wrap" id="lb-reg-wrap">
      <table>
        <thead><tr id="lb-thead-row"></tr></thead>
        <tbody id="lb-tbody"></tbody>
      </table>
      <div class="lb-more" id="lb-more" style="display:none">
        <button class="lb-more-btn" id="lb-more-btn">Show all players →</button>
      </div>
    </div>
  </section>

  <!-- METHODOLOGY -->
  <div class="lb-method">
    <div class="lb-method-h">
      <span class="title">How we measure</span>
      <span class="tag">methodology · 2025–2026</span>
    </div>
    <div class="lb-method-grid">
      <div class="lb-method-card">
        <div class="k">WAR <span class="badge badge-core">CORE</span></div>
        <div class="v">Wins Above Replacement — RAPM × total 5v5 TOI × 0.1, where RAPM (Regularized Adjusted Plus-Minus) controls for linemates and opponents via ridge regression. Cumulative season value; use for overall impact comparisons.</div>
      </div>
      <div class="lb-method-card">
        <div class="k">Expected goals (xG)</div>
        <div class="v">Probability a shot scores, based on location, angle, shot type, and context. Better signal than raw shot count — Tkachuk getting 16 shots/60 and only 1.44 xG/60 tells the real story.</div>
      </div>
      <div class="lb-method-card">
        <div class="k">Finishing</div>
        <div class="v">Goals/60 minus xG/60 — how much a player over- or under-performs their shot quality. Positive means they're converting at a rate above expected; negative suggests regression risk.</div>
      </div>
    </div>
  </div>

</main>

<footer class="lb-footer">HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026 · SKATERS V1</footer>

</body>
</html>

<script is:inline src="/js/table-export.js"></script>
<script define:vars={{ rows: tableRows }}>
const DATA = rows;
const PAGE = 50;
const sgn2 = v => v >= 0 ? '+' : '';

// ── State ────────────────────────────────────────────────────────────────────
let gameType    = 2;
let viewTab     = 'counting';
let posFilter   = 'all';
let teamFilter  = 'all';
let minToi      = 0;
let sortKey     = 'points';
let sortAsc     = false;
let showAll     = false;
let topN        = null;   // null = no limit; number = slice after sort
let searchQuery = '';

// ── Tab column definitions ────────────────────────────────────────────────────
// Fixed columns in every tab: #, Player, Pos, GP
// Each tab defines its own stat columns after those fixed columns.
// In playoff/counting mode, poKey is used instead of key for data access + sorting.
const TABS = {
  counting: {
    defaultSort: 'points',
    poDefaultSort: 'po_points',
    regOnly: false,
    cols: [
      { label: 'G',    key: 'goals',   poKey: 'po_goals' },
      { label: 'A',    key: 'assists', poKey: 'po_assists' },
      { label: 'P',    key: 'points',  poKey: 'po_points' },
      { label: 'SOG',  key: 'sog',     poKey: 'po_sog' },
      { label: 'ixG',  key: 'ixg',     poKey: 'po_ixg',    fmt: v => v.toFixed(2) },
      { label: 'TOI',  key: 'toi_pg',  poKey: 'po_toi_pg', fmt: v => v.toFixed(1) },
    ],
  },
  rates: {
    defaultSort: 'p60',
    regOnly: true,
    cols: [
      { label: 'G/60',  key: 'g60',  fmt: v => v.toFixed(2) },
      { label: 'A/60',  key: 'a60',  fmt: v => v.toFixed(2) },
      { label: 'P/60',  key: 'p60',  fmt: v => v.toFixed(2) },
      { label: 'xG/60', key: 'x60',  fmt: v => v.toFixed(2) },
      { label: 'TOI/G', key: 'toi_pg', fmt: v => v.toFixed(1) },
    ],
  },
  advanced: {
    defaultSort: 'imp',
    regOnly: true,
    cols: [
      { label: 'Impact', key: 'imp',  fmt: v => v != null ? sgn2(v) + v.toFixed(2) : '—', signed: true },
      { label: 'WAR',    key: 'war',  fmt: v => v != null ? sgn2(v) + v.toFixed(2) : '—', signed: true },
      { label: 'Finishing', key: 'fin',  fmt: v => v != null ? sgn2(v) + v.toFixed(2) : '—', signed: true },
      { label: 'RAPM/60',   key: 'rapm', fmt: v => v != null ? sgn2(v) + v.toFixed(3) : '—', signed: true },
    ],
  },
  onice: {
    defaultSort: 'xgf_pct',
    regOnly: true,
    cols: [
      { label: 'xGF%',   key: 'xgf_pct', fmt: v => v.toFixed(1) + '%' },
      { label: 'xGF/60', key: 'xgf60',   fmt: v => v.toFixed(2) },
      { label: 'xGA/60', key: 'xga60',   fmt: v => v.toFixed(2) },
      { label: 'SC/60',  key: 'sc60',    fmt: v => v.toFixed(2) },
      { label: 'HDC/60', key: 'hdc60',   fmt: v => v.toFixed(2) },
    ],
  },
};

function resolveDefaultSort(tab, gt) {
  const isPlayoff = (gt ?? gameType) === 3;
  return (isPlayoff && TABS[tab].poDefaultSort) ? TABS[tab].poDefaultSort : TABS[tab].defaultSort;
}

function readUrl() {
  const p = new URLSearchParams(window.location.search);
  if (p.get('game_type') === '3' || p.get('season') === 'playoff') gameType = 3;
  const tab = p.get('tab');
  if (tab && TABS[tab]) { viewTab = tab; }
  sortKey = resolveDefaultSort(viewTab, gameType);
  const team = p.get('team');
  if (team) teamFilter = team;
  const toi = parseInt(p.get('toi') || '0');
  if (!isNaN(toi)) minToi = toi;
}

function updateUrl() {
  const p = new URLSearchParams();
  if (gameType === 3) p.set('game_type', '3');
  if (viewTab !== 'counting') p.set('tab', viewTab);
  if (teamFilter !== 'all') p.set('team', teamFilter);
  if (minToi > 0) p.set('toi', String(minToi));
  history.replaceState(null, '', p.toString() ? `?${p}` : window.location.pathname);
}

// ── syncUi ────────────────────────────────────────────────────────────────────
function syncUi() {
  const isPlayoff = gameType === 3;

  document.querySelectorAll('#gametype-filter button').forEach(btn => {
    btn.classList.toggle('active', parseInt(btn.dataset.gametype) === gameType);
  });

  // Fall back to counting if current tab is reg-only and we're switching to playoff
  if (isPlayoff && TABS[viewTab]?.regOnly) {
    viewTab = 'counting';
    sortKey = resolveDefaultSort('counting');
    sortAsc = false;
  }

  document.querySelectorAll('#view-filter button').forEach(btn => {
    const v = btn.dataset.view;
    const regOnly = TABS[v]?.regOnly;
    btn.classList.toggle('active', v === viewTab);
    btn.style.opacity = (isPlayoff && regOnly) ? '0.35' : '';
    btn.style.pointerEvents = (isPlayoff && regOnly) ? 'none' : '';
  });
}

// ── getRows ───────────────────────────────────────────────────────────────────
function getRows() {
  const isPlayoff = gameType === 3;
  let rows = DATA.slice();
  if (isPlayoff) rows = rows.filter(r => r.po_gp != null && r.po_gp > 0);
  if (posFilter !== 'all') rows = rows.filter(r => r.group === posFilter);
  if (teamFilter !== 'all') rows = rows.filter(r => r.team === teamFilter);
  if (minToi > 0) {
    const toiKey = (isPlayoff && viewTab === 'counting') ? 'po_toi_pg' : 'toi_pg';
    rows = rows.filter(r => (r[toiKey] ?? 0) >= minToi);
  }
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    rows = rows.filter(r => r.name.toLowerCase().includes(q));
  }
  rows.sort((a, b) => {
    const av = a[sortKey] ?? (sortAsc ? Infinity : -Infinity);
    const bv = b[sortKey] ?? (sortAsc ? Infinity : -Infinity);
    return sortAsc ? av - bv : bv - av;
  });
  if (topN != null) rows = rows.slice(0, topN);
  return rows;
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function pctCls(p) {
  if (p == null) return 'pa';
  return p >= 90 ? 'pe' : p >= 70 ? 'pg' : p >= 40 ? 'pa' : 'pl';
}
function ordinal(p) {
  if (p == null) return '—';
  const s = (p % 100 >= 11 && p % 100 <= 13) ? 'th' :
    p % 10 === 1 ? 'st' : p % 10 === 2 ? 'nd' : p % 10 === 3 ? 'rd' : 'th';
  return `${p}${s}`;
}

// ── renderHeader ──────────────────────────────────────────────────────────────
function renderHeader() {
  const thead = document.getElementById('lb-thead-row');
  if (!thead) return;
  const isPlayoff = gameType === 3;
  const tab = TABS[viewTab];

  const gpKey = (isPlayoff && viewTab === 'counting') ? 'po_gp' : 'gp';
  const sortGp = sortKey === gpKey;
  const fixed = [
    `<th>#</th>`,
    `<th class="th-player">Player</th>`,
    `<th class="c-pos" style="text-align:center">Pos</th>`,
    `<th data-sort="${gpKey}" style="cursor:pointer;text-align:right">GP<span class="sort-arrow">${sortGp?(sortAsc?'↑':'↓'):''}</span></th>`,
  ];

  const statCols = tab.cols.map(c => {
    const activeKey = (isPlayoff && c.poKey) ? c.poKey : c.key;
    const active = sortKey === c.key || (c.poKey && sortKey === c.poKey);
    const arrow  = active ? (sortAsc ? '↑' : '↓') : '';
    return `<th class="${active ? 'sorted' : ''}" data-sort="${activeKey}" style="cursor:pointer;text-align:right">${c.label}<span class="sort-arrow">${arrow}</span></th>`;
  });

  thead.innerHTML = [...fixed, ...statCols].join('');
}

// ── renderBody ────────────────────────────────────────────────────────────────
const PCT_MAP = { imp: 'imp_p', war: 'war_p', fin: 'fin_p' };

function renderBody(visibleRows) {
  const isPlayoff = gameType === 3;
  const tab = TABS[viewTab];
  const tbody = document.getElementById('lb-tbody');
  if (!tbody) return;

  if (visibleRows.length === 0) {
    const colspan = 4 + tab.cols.length;
    tbody.innerHTML = `<tr><td colspan="${colspan}" style="text-align:center;padding:60px;font-family:var(--mono);font-size:13px;color:var(--ink-48);letter-spacing:0.04em">${isPlayoff ? 'Playoff data available once postseason begins' : 'No data'}</td></tr>`;
    return;
  }

  tbody.innerHTML = visibleRows.map((r, i) => {
    const gp = (isPlayoff && viewTab === 'counting') ? r.po_gp : r.gp;

    const statTds = tab.cols.map(c => {
      const dataKey = (isPlayoff && c.poKey) ? c.poKey : c.key;
      const val = r[dataKey];
      let html;
      if (c.signed) {
        const pctKey = PCT_MAP[c.key];
        const pct = pctKey ? r[pctKey] : null;
        if (val == null) {
          html = `<span class="sv nil">—</span><span class="sp pa">—</span>`;
        } else {
          const cls = val >= 0 ? 'pos' : 'neg';
          html = `<span class="sv ${cls}">${c.fmt(val)}</span><span class="sp ${pctCls(pct)}">${ordinal(pct)}</span>`;
        }
      } else if (c.fmt) {
        html = val != null ? `<span class="sv">${c.fmt(val)}</span>` : `<span class="sv nil">—</span>`;
      } else {
        html = val != null ? `<span class="sv">${val}</span>` : `<span class="sv nil">—</span>`;
      }
      return `<td class="td-stat">${html}</td>`;
    }).join('');

    return `<tr>
      <td class="td-rk">${String(i + 1).padStart(2, '0')}</td>
      <td><div class="td-player">
        <img class="td-logo" src="https://assets.nhle.com/logos/nhl/svg/${r.team}_light.svg" alt="${r.team}" width="22" height="22" loading="lazy">
        <div class="td-info">
          <a href="/stats/player/${r.slug}" class="td-name">${r.name}</a>
          <span class="td-sub">${r.team} · ${r.pos} · ${gp} GP</span>
        </div>
      </div></td>
      <td class="td-pos c-pos">${r.pos}</td>
      <td class="td-gp">${gp}</td>
      ${statTds}
    </tr>`;
  }).join('');
}

// ── render ────────────────────────────────────────────────────────────────────
function render() {
  renderHeader();
  const allRows = getRows();
  const total = allRows.length;
  const visible = showAll ? allRows : allRows.slice(0, PAGE);
  renderBody(visible);

  const countEl = document.getElementById('lb-count');
  if (countEl) {
    const season = gameType === 3 ? '2025–26 playoffs' : '2025–26';
    const label  = topN != null ? `Top ${total} · ${season}` : `${total} players · ${season}`;
    countEl.textContent = label;
  }

  const moreDiv = document.getElementById('lb-more');
  const moreBtn = document.getElementById('lb-more-btn');
  if (moreDiv && moreBtn) {
    if (!showAll && total > PAGE) {
      moreDiv.style.display = '';
      moreBtn.textContent = `Show all ${total} players →`;
    } else {
      moreDiv.style.display = 'none';
    }
  }

  // Export guard: disable when too many rows and no Top N limit
  const dlBtn   = document.getElementById('dl-btn');
  const dlNote  = document.getElementById('dl-limit-note');
  const tooMany = topN == null && total > 20;
  if (dlBtn)  { dlBtn.disabled = tooMany; }
  if (dlNote) { dlNote.style.display = tooMany ? '' : 'none'; }
}

// ── Event handlers ────────────────────────────────────────────────────────────

document.querySelectorAll('#gametype-filter button').forEach(btn => {
  btn.addEventListener('click', () => {
    const gt = parseInt(btn.dataset.gametype);
    if (gt === gameType) return;
    gameType = gt;
    sortKey  = resolveDefaultSort(viewTab, gt);
    sortAsc  = false;
    showAll  = false;
    updateUrl();
    syncUi();
    render();
  });
});

document.querySelectorAll('#view-filter button').forEach(btn => {
  btn.addEventListener('click', () => {
    const v = btn.dataset.view;
    if (v === viewTab || (gameType === 3 && TABS[v]?.regOnly)) return;
    viewTab = v;
    sortKey = resolveDefaultSort(v);
    sortAsc = false;
    showAll = false;
    updateUrl();
    syncUi();
    render();
  });
});

document.querySelectorAll('[data-pos]').forEach(btn => {
  btn.addEventListener('click', () => {
    posFilter = btn.dataset.pos;
    showAll   = false;
    document.querySelectorAll('[data-pos]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    render();
  });
});

document.querySelector('thead')?.addEventListener('click', e => {
  const th = e.target?.closest('th[data-sort]');
  if (!th) return;
  const key = th.dataset.sort;
  if (sortKey === key) { sortAsc = !sortAsc; }
  else { sortKey = key; sortAsc = false; }
  showAll = false;
  render();
});

document.getElementById('lb-more-btn')?.addEventListener('click', () => {
  showAll = true;
  render();
});

// ── Team + TOI filter init + events ──────────────────────────────────────────

// Populate team dropdown from data
(function() {
  const teams = [...new Set(DATA.map(r => r.team))].sort();
  const sel = document.getElementById('team-filter');
  teams.forEach(t => {
    const opt = document.createElement('option');
    opt.value = t; opt.textContent = t;
    sel.appendChild(opt);
  });
  if (teamFilter !== 'all') sel.value = teamFilter;
})();

function syncToiLabel() {
  const el = document.getElementById('toi-label');
  if (el) el.textContent = minToi > 0 ? `${minToi}m` : '—';
  const slider = document.getElementById('toi-slider');
  if (slider) slider.value = String(minToi);
}

document.getElementById('team-filter')?.addEventListener('change', function() {
  teamFilter = this.value;
  showAll = false;
  updateUrl();
  render();
});

document.getElementById('toi-slider')?.addEventListener('input', function() {
  minToi = parseInt(this.value);
  syncToiLabel();
  showAll = false;
  updateUrl();
  render();
});

// ── Top N filter ──────────────────────────────────────────────────────────────
document.querySelectorAll('#topn-filter button').forEach(btn => {
  btn.addEventListener('click', () => {
    const v = btn.dataset.topn;
    topN = v ? parseInt(v) : null;
    showAll = false;
    document.querySelectorAll('#topn-filter button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    render();
  });
});

// ── Name search ───────────────────────────────────────────────────────────────
document.getElementById('name-search')?.addEventListener('input', function() {
  searchQuery = this.value.trim();
  showAll = false;
  render();
});

readUrl();
syncUi();
syncToiLabel();
render();

// ── PNG Export ────────────────────────────────────────────────────────────────
const EXPORT_COLS = {
  counting: [
    { label: '#',      key: '_rank', width: 44,  align: 'center' },
    { label: 'Player', key: 'name',  width: 240, align: 'left', fontFamily: 'body', bold: true },
    { label: 'Team',   key: 'team',  width: 58,  align: 'center' },
    { label: 'Pos',    key: 'pos',   width: 48,  align: 'center' },
    { label: 'GP',     key: '_gp',   width: 52,  align: 'center' },
    { label: 'G',      key: '_g',    width: 60,  align: 'center' },
    { label: 'A',      key: '_a',    width: 60,  align: 'center' },
    { label: 'P',      key: '_p',    width: 60,  align: 'center', bold: true },
    { label: 'SOG',    key: '_sog',  width: 66,  align: 'center' },
    { label: 'ixG',    key: '_ixg',  width: 70,  align: 'center', format: v => v != null ? v.toFixed(2) : '—' },
    { label: 'TOI',    key: '_toi',  width: 64,  align: 'center', format: v => v != null ? v.toFixed(1) : '—' },
  ],
  rates: [
    { label: '#',      key: '_rank',  width: 44,  align: 'center' },
    { label: 'Player', key: 'name',   width: 240, align: 'left', fontFamily: 'body', bold: true },
    { label: 'Team',   key: 'team',   width: 58,  align: 'center' },
    { label: 'Pos',    key: 'pos',    width: 48,  align: 'center' },
    { label: 'GP',     key: 'gp',     width: 52,  align: 'center' },
    { label: 'G/60',   key: 'g60',    width: 76,  align: 'center', format: v => v != null ? v.toFixed(2) : '—' },
    { label: 'A/60',   key: 'a60',    width: 76,  align: 'center', format: v => v != null ? v.toFixed(2) : '—' },
    { label: 'P/60',   key: 'p60',    width: 76,  align: 'center', format: v => v != null ? v.toFixed(2) : '—', bold: true },
    { label: 'xG/60',  key: 'x60',    width: 82,  align: 'center', format: v => v != null ? v.toFixed(2) : '—' },
    { label: 'TOI/G',  key: 'toi_pg', width: 76,  align: 'center', format: v => v != null ? v.toFixed(1) : '—' },
  ],
  advanced: [
    { label: '#',      key: '_rank', width: 44,  align: 'center' },
    { label: 'Player', key: 'name',  width: 240, align: 'left', fontFamily: 'body', bold: true },
    { label: 'Team',   key: 'team',  width: 58,  align: 'center' },
    { label: 'Pos',    key: 'pos',   width: 48,  align: 'center' },
    { label: 'GP',     key: 'gp',    width: 52,  align: 'center' },
    { label: 'Impact', key: 'imp',   width: 90,  align: 'center', bold: true,
      format: v => v != null ? sgn2(v) + v.toFixed(2) : '—',
      color:  (v, _r, tok) => v != null ? (v >= 0 ? tok.pos : tok.neg) : null },
    { label: 'WAR',    key: 'war',   width: 86,  align: 'center',
      format: v => v != null ? sgn2(v) + v.toFixed(2) : '—',
      color:  (v, _r, tok) => v != null ? (v >= 0 ? tok.pos : tok.neg) : null },
    { label: 'Fin',    key: 'fin',   width: 76,  align: 'center',
      format: v => v != null ? sgn2(v) + v.toFixed(2) : '—',
      color:  (v, _r, tok) => v != null ? (v >= 0 ? tok.pos : tok.neg) : null },
    { label: 'RAPM',   key: 'rapm',  width: 82,  align: 'center',
      format: v => v != null ? sgn2(v) + v.toFixed(3) : '—',
      color:  (v, _r, tok) => v != null ? (v >= 0 ? tok.pos : tok.neg) : null },
  ],
  onice: [
    { label: '#',      key: '_rank',   width: 44,  align: 'center' },
    { label: 'Player', key: 'name',    width: 240, align: 'left', fontFamily: 'body', bold: true },
    { label: 'Team',   key: 'team',    width: 58,  align: 'center' },
    { label: 'Pos',    key: 'pos',     width: 48,  align: 'center' },
    { label: 'GP',     key: 'gp',      width: 52,  align: 'center' },
    { label: 'xGF%',   key: 'xgf_pct', width: 82, align: 'center', bold: true,
      format: v => v != null ? v.toFixed(1) + '%' : '—',
      color: (v, _r, tok) => v != null ? (v >= 52 ? tok.pos : v <= 48 ? tok.neg : null) : null },
    { label: 'xGF/60', key: 'xgf60',   width: 84, align: 'center', format: v => v != null ? v.toFixed(2) : '—' },
    { label: 'xGA/60', key: 'xga60',   width: 84, align: 'center', format: v => v != null ? v.toFixed(2) : '—' },
    { label: 'SC/60',  key: 'sc60',    width: 76, align: 'center', format: v => v != null ? v.toFixed(2) : '—' },
    { label: 'HDC/60', key: 'hdc60',   width: 76, align: 'center', format: v => v != null ? v.toFixed(2) : '—' },
  ],
};

function getExportChips() {
  const isPlayoff = gameType === 3;
  const tabLabel = { counting: 'Counting', rates: 'Rates', advanced: 'Advanced', onice: 'On-Ice 5v5' }[viewTab];
  const chips = [isPlayoff ? 'Playoffs' : 'Regular Season', tabLabel];
  if (topN != null) chips.push(`Top ${topN}`);
  if (posFilter !== 'all') chips.push(posFilter === 'F' ? 'Forwards' : 'Defense');
  if (teamFilter !== 'all') chips.push(teamFilter);
  if (minToi > 0) chips.push(`${minToi}+ min TOI`);
  return chips;
}

document.getElementById('dl-btn').addEventListener('click', function() {
  const isPlayoff = gameType === 3;
  const allRows = getRows();

  const exportRows = allRows.map((r, i) => ({
    ...r,
    _rank: i + 1,
    _gp:   (isPlayoff && viewTab === 'counting') ? r.po_gp      : r.gp,
    _g:    (isPlayoff && viewTab === 'counting') ? r.po_goals    : r.goals,
    _a:    (isPlayoff && viewTab === 'counting') ? r.po_assists  : r.assists,
    _p:    (isPlayoff && viewTab === 'counting') ? r.po_points   : r.points,
    _sog:  (isPlayoff && viewTab === 'counting') ? r.po_sog      : r.sog,
    _ixg:  (isPlayoff && viewTab === 'counting') ? r.po_ixg      : r.ixg,
    _toi:  (isPlayoff && viewTab === 'counting') ? r.po_toi_pg   : r.toi_pg,
  }));

  const tabLabel = { counting: 'Counting', rates: 'Rates', advanced: 'Advanced' }[viewTab];
  const season   = isPlayoff ? 'Playoff' : 'Season';

  window.HGB_Export.downloadTablePng({
    title: `${season} ${tabLabel} Stats`,
    filterChips: getExportChips(),
    sortLabel: sortKey,
    rows: exportRows,
    columns: EXPORT_COLS[viewTab],
    filename: `hgb-skaters-${viewTab}${isPlayoff ? '-playoff' : ''}.png`,
  });
});
</script>
