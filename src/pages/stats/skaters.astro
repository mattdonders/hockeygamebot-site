---
import StatsLayout from '../../layouts/StatsLayout.astro';
import StatsMasthead from '../../components/StatsMasthead.astro';
import Table from '../../components/Table.astro';
import ChipGroup from '../../components/ChipGroup.astro';
import { loadPlayers, loadMeta, loadIsPlayoffSeason } from '../../lib/stats-loader';
import { fmtSeasonLong } from '../../lib/format-season';
import SkatersTable from '../../components/react/SkatersTable';

const allPlayers = loadPlayers();
const eligible   = allPlayers.filter(p => p.gp >= 20 || ((p as any).playoff_gp ?? 0) > 0);
const _meta           = loadMeta();
const _currentSeasonNorm = fmtSeasonLong(_meta.season);
const isPlayoffSeason = loadIsPlayoffSeason();
const _statsDate = (() => { const d = new Date(_meta.generated_at); return d.getFullYear() >= 2020 ? d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : null; })();

// Pre-sort rapm arrays for O(n log n) percentile lookup at build time
const fwdWar = eligible.filter(p => p.pos_group === 'F' && p.war != null).map(p => p.war as number).sort((a,b) => a - b);
const defWar = eligible.filter(p => p.pos_group === 'D' && p.war != null).map(p => p.war as number).sort((a,b) => a - b);

function warPct(war: number | null, group: 'F' | 'D'): number | null {
  if (war == null) return null;
  const arr = group === 'F' ? fwdWar : defWar;
  let lo = 0, hi = arr.length;
  while (lo < hi) { const mid = (lo + hi) >>> 1; if (arr[mid] <= war) lo = mid + 1; else hi = mid; }
  return Math.round((lo / arr.length) * 100);
}

const toi60 = (p: typeof eligible[0]) => (p.toi_avg_sec * p.gp) / 3600 || 1;

const tableRows = eligible.map(p => {
  const evOff    = p.rates_per_60.ev_offence;
  const evDef    = p.rates_per_60.ev_defence;
  const xgfTotal = evOff + evDef;
  const tot60    = toi60(p);
  const goals    = p.goals;
  const assists  = p.assists;
  // Prefer absolute counts from export; fall back to rate × TOI for older builds
  const rawSog   = p.shots != null ? p.shots : Math.round(p.rates_per_60.shots * tot60);
  const rawIxg   = p.ixg   != null ? p.ixg   : p.rates_per_60.ixg * tot60;

  // Strength-state splits — keep null when upstream data is absent so the
  // client filter can render — instead of showing zero as real data.
  const hasSplits = p.goals_pp != null || p.goals_sh != null || p.toi_pp_sec_total != null;
  const goalsPp  = p.goals_pp  ?? null;
  const goalsSh  = p.goals_sh  ?? null;
  const goalsEv  = p.goals_ev  ?? null;
  const _aPp     = (p.a1_pp ?? 0) + (p.a2_pp ?? 0);
  const _aPk     = (p.a1_pk ?? 0) + (p.a2_pk ?? 0);
  const aPp      = p.a1_pp != null || p.a2_pp != null ? _aPp : null;
  const aPk      = p.a1_pk != null || p.a2_pk != null ? _aPk : null;
  const aEv      = hasSplits ? Math.max(0, assists - _aPp - _aPk) : null;
  const shotsPp  = p.shots_pp ?? null;
  const shotsPk  = p.shots_pk ?? null;
  const shotsEv  = hasSplits ? Math.max(0, rawSog - (p.shots_pp ?? 0) - (p.shots_pk ?? 0)) : null;
  const ixgPp    = p.sum_xg_pp ?? null;
  const ixgPk    = p.sum_xg_pk ?? null;
  const ixgEv    = hasSplits ? Math.max(0, rawIxg - (p.sum_xg_pp ?? 0) - (p.sum_xg_pk ?? 0)) : null;
  const toiPpSec = p.toi_pp_sec_total ?? null;
  const toiPkSec = p.toi_pk_sec_total ?? null;
  const toiEvSec = p.toi_ev_sec_total ?? null;

  return {
    slug:     p.slug,
    name:     p.display_name,
    first_name: p.first_name,
    last_name:  p.last_name,
    searchText: `${p.first_name} ${p.last_name} ${p.display_name} ${p.team_abbrev}`.toLowerCase(),
    team:     p.team_abbrev,
    pos:      p.pos,
    group:    p.pos_group,
    gp:       p.gp,
    // Counting stats (all-situations)
    goals,
    assists,
    points:   goals + assists,
    sog:      rawSog,
    ixg:      +rawIxg.toFixed(2),
    toi_pg:   +(p.toi_avg_sec / 60).toFixed(1),
    // Rates
    g60:      +p.rates_per_60.goals.toFixed(2),
    a60:      +(assists / tot60).toFixed(2),
    p60:      +((goals + assists) / tot60).toFixed(2),
    x60:      +p.rates_per_60.ixg.toFixed(2),
    sog60:    +p.rates_per_60.shots.toFixed(2),
    // Advanced
    war:      p.war ?? null,
    war_p:    warPct(p.war ?? null, p.pos_group),
    fin:      +p.rates_per_60.finishing.toFixed(2),
    fin_p:    Math.round(p.percentiles_vs_pos.finishing),
    imp:      +p.avg_gs_display.toFixed(2),
    imp_p:    Math.round(p.gs_pct),
    rapm:     p.rapm != null ? +p.rapm.toFixed(3) : null,
    rating:   p.hgb_rating != null ? +p.hgb_rating.toFixed(2) : null,
    rating_p: p.hgb_rating_percentile != null ? Math.round(p.hgb_rating_percentile) : null,
    // 5v5 on-ice
    xgf_pct:  xgfTotal > 0 ? +(evOff / xgfTotal * 100).toFixed(1) : 50.0,
    xgf60:    +evOff.toFixed(2),
    xga60:    +evDef.toFixed(2),
    sc60:     +(p.rates_per_60.sc_per60 ?? 0).toFixed(2),
    hdc60:    +(p.rates_per_60.hdc_per60 ?? 0).toFixed(2),
    gf_diff:    p.gf_diff ?? 0,
    gf_diff_60: p.gf_diff_60 ?? 0,
    hdc_pct:  +(p.hdc_pct ?? 50).toFixed(1),
    // PP (legacy fields kept for compat)
    pp_toi:   toiPpSec != null && toiPpSec > 0 ? +(toiPpSec / p.gp / 60).toFixed(1) : null,
    pp_g:     goalsPp,
    pp_xg60:  +(p.rates_per_60.xg_pp_per60 ?? 0).toFixed(2),
    // Strength-state raw fields (used by client-side filter)
    goals_ev: goalsEv,  goals_pp: goalsPp,  goals_sh: goalsSh,
    a_ev:     aEv,      a_pp:     aPp,      a_pk:     aPk,
    shots_ev: shotsEv,  shots_pp: shotsPp,  shots_pk: shotsPk,
    ixg_ev:   ixgEv != null ? +ixgEv.toFixed(2) : null,
    ixg_pp:   ixgPp != null ? +ixgPp.toFixed(2) : null,
    ixg_pk:   ixgPk != null ? +ixgPk.toFixed(2) : null,
    toi_ev_sec: toiEvSec,
    toi_pp_sec: toiPpSec,
    toi_pk_sec: toiPkSec,
    // EDGE skating (current season regular only — null when unavailable)
    edge_speed_mph:   p.edge?.speed_max_mph        ?? null,
    edge_speed_pct:   p.edge?.speed_max_pct        ?? null,
    edge_dist_mi:     p.edge?.distance_mi           ?? null,
    edge_dist_pct:    p.edge?.distance_pct          ?? null,
    edge_bursts:      p.edge?.bursts_over_20        ?? null,
    edge_bursts_pct:  p.edge?.bursts_over_20_pct   ?? null,
    edge_shot_mph:    p.edge?.shot_speed_max_mph    ?? null,
    edge_shot_pct:    p.edge?.shot_speed_max_pct    ?? null,
    // Physical / faceoff
    hits:      p.hits      ?? 0,
    hits_taken:p.hits_taken?? 0,
    blocks:    p.blocks    ?? 0,
    fo_wins:   p.fo_wins   ?? 0,
    fo_losses: p.fo_losses ?? 0,
    // Playoff counting — null if player didn't play playoffs
    po_gp:      p.playoff_gp      ?? null,
    po_goals:   p.playoff_goals   ?? null,
    po_assists: p.playoff_assists  ?? null,
    po_points:  p.playoff_points   ?? null,
    po_sog:     p.playoff_sog      ?? null,
    po_ixg:     p.playoff_ixg      ?? null,
    po_toi_pg:  p.playoff_toi_sec != null && p.playoff_gp
                  ? +(p.playoff_toi_sec / p.playoff_gp / 60).toFixed(1)
                  : null,
  };
});

// SSR initial: counting tab, sorted by points desc, top 50.
const ssrRows = tableRows
  .slice()
  .sort((a, b) => (b.points ?? 0) - (a.points ?? 0))
  .slice(0, 50)
  .map((r, i) => ({ ...r, _rank: i + 1 }));

// SSR column set: counting tab (gets swapped by JS on tab change).
const initialColumns = [
  { key: '_rank',  label: '#',      type: 'rank' as const, sortable: false },
  { key: 'name',   label: 'Player', type: 'player' as const, sub: (r: any) => `${r.team} · ${r.pos} · ${r.gp} GP` },
  { key: 'pos',    label: 'Pos',    type: 'position' as const, sortable: true },
  { key: 'gp',     label: 'GP',     type: 'number' as const },
  { key: 'goals',  label: 'G',      type: 'number' as const },
  { key: 'assists',label: 'A',      type: 'number' as const },
  { key: 'points', label: 'P',      type: 'number' as const, bold: true },
  { key: 'sog',    label: 'SOG',    type: 'number' as const },
  { key: 'ixg',    label: 'ixG',    type: 'number' as const, format: (v: any) => v != null ? Number(v).toFixed(2) : '—' },
  { key: 'toi_pg', label: 'TOI',    type: 'number' as const, format: (v: any) => v != null ? Number(v).toFixed(1) : '—' },
];
---
<StatsLayout
  title="Leaderboards — HGB Stats — HockeyGameBot"
  description={`All NHL skaters ranked by WAR, Goals/60, xG/60, finishing, and HGB Impact. Sortable table, min 20 GP, ${_currentSeasonNorm} season.`}
  ogImage="/og/skaters.png"
  currentPath={Astro.url.pathname}
>

<StatsMasthead slot="mast" eyebrow="HGB Stats · Skaters">
  <Fragment slot="headline">All skaters.<br /><em>Every stat.</em></Fragment>
  <Fragment slot="lede">Every NHL skater ranked by WAR, xG, finishing, and more. Counting stats, rates, or advanced metrics — switch views with the tabs.</Fragment>
</StatsMasthead>

<main class="wrap">

  <section class="lb-section">
    <div class="lb-head">
      <span class="lb-title">Skater Stats</span>
    </div>
    <SkatersTable rows={tableRows} statsDate={_statsDate} currentSeason={_meta.season} isPlayoffSeason={isPlayoffSeason} client:load />
  </section>

  <div class="lb-method">
    <div class="lb-method-h">
      <span class="title">How we measure</span>
      <span class="tag">methodology · 2025–2026</span>
    </div>
    <div class="lb-method-grid">
      <div class="lb-method-card">
        <div class="k">WAR <span class="badge badge-core">CORE</span></div>
        <div class="v">Wins Above Replacement — RAPM × total 5v5 TOI × 0.1, where RAPM (Regularized Adjusted Plus-Minus) controls for linemates and opponents via ridge regression. Cumulative season value; use for overall impact comparisons.</div>
      </div>
      <div class="lb-method-card">
        <div class="k">Expected goals (xG)</div>
        <div class="v">Probability a shot scores, based on location, angle, shot type, and context. Better signal than raw shot count — Tkachuk getting 16 shots/60 and only 1.44 xG/60 tells the real story.</div>
      </div>
      <div class="lb-method-card">
        <div class="k">Finishing</div>
        <div class="v">Goals/60 minus xG/60 — how much a player over- or under-performs their shot quality. Positive means they're converting at a rate above expected; negative suggests regression risk.</div>
      </div>
    </div>
  </div>

</main>

</StatsLayout>

<style is:global>
  .lb-section { padding: 40px 0 0; }
  .lb-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 8px; }
  .lb-title { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px); text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
  .lb-meta { font-family: var(--body); font-size: 10px; color: var(--ink-32); letter-spacing: 0.12em; text-transform: uppercase; }
  .dl-limit-note { font-family: var(--body); font-size: 10px; color: var(--ink-48); white-space: nowrap; }

  .controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
  select { background: var(--surface); border: 1px solid var(--ink-14); padding: 6px 10px; font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em; color: var(--ink); cursor: pointer; outline: none; }
  .slider-wrap { display: inline-flex; align-items: center; gap: 8px; font-family: var(--body); font-size: 11px; color: var(--ink-48); }
  .slider-wrap input[type=range] { width: 100px; accent-color: var(--red); }
  #name-search { background: var(--surface); border: 1px solid var(--ink-14); padding: 6px 10px; font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em; color: var(--ink); outline: none; width: 160px; }
  #name-search::placeholder { color: var(--ink-32); font-weight: 400; }

  .filter-group { display: contents; }
  .filter-toggle-row { display: none; }

  @media (max-width: 768px) {
    .controls { flex-direction: column; align-items: stretch; gap: 0; margin-bottom: 8px; }
    .filter-group { display: flex; flex-wrap: wrap; gap: 8px; padding: 10px 0; }
    .filter-group--primary { padding-top: 12px; padding-bottom: 8px; }
    .filter-group--secondary { display: none; border-top: 1px solid var(--ink-10); padding-top: 12px; flex-direction: row; flex-wrap: wrap; align-items: flex-start; gap: 8px; }
    .filter-group--secondary.is-open { display: flex; }
    .lb-count-desktop { display: none; }
    .filter-group--search { padding-top: 10px; }
    .filter-toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 7px 0; border-top: 1px solid var(--ink-10); border-bottom: 1px solid var(--ink-10); gap: 12px; }
    .filter-summary { font-family: var(--body); font-size: 10px; color: var(--ink-48); letter-spacing: 0.06em; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .filter-toggle-btn { flex-shrink: 0; font-family: var(--body); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; white-space: nowrap; background: none; border: 1px solid var(--ink-20); color: var(--ink-48); cursor: pointer; padding: 5px 10px; display: flex; align-items: center; gap: 4px; }
    .filter-toggle-arrow { display: inline-block; font-size: 8px; transition: transform 0.15s; }
    .filter-toggle-btn[aria-expanded="true"] .filter-toggle-arrow { transform: rotate(180deg); }
  }

  .lb-more { padding: 14px 18px; border-top: 1px solid var(--ink-06); text-align: center; }
  .lb-more-btn { font-family: var(--body); font-weight: 500; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; padding: 7px 20px; border: 1px solid var(--ink-14); background: transparent; color: var(--ink-48); cursor: pointer; transition: all 0.1s; }
  .lb-more-btn:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }

  .stat-stack { display: flex; flex-direction: column; align-items: center; gap: 1px; line-height: 1.2; }
  .stat-stack .sp { display: block; font-family: var(--mono); font-size: 10px; font-variant-numeric: tabular-nums; }
  .stat-stack .pe { color: #00c078; }
  .stat-stack .pg { color: #60a5fa; }
  .stat-stack .pa { color: var(--ink-32); }
  .stat-stack .pl { color: var(--red); opacity: 0.65; }
  .stat-stack .nil { color: var(--ink-32); }

  .lb-method { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; margin-top: 40px; }
  .lb-method-h { padding: 12px 18px; border-bottom: 1px solid var(--ink-06); display: flex; justify-content: space-between; align-items: center; }
  .lb-method-h .title { font-family: var(--body); font-weight: 500; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-72); }
  .lb-method-h .tag { font-family: var(--body); font-size: 10px; color: var(--ink-32); }
  .lb-method-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 640px) { .lb-method-grid { grid-template-columns: 1fr; } }
  .lb-method-card { padding: 20px; border-right: 1px solid var(--ink-06); }
  .lb-method-card:last-child { border-right: none; }
  .lb-method-card .k { font-family: var(--body); font-weight: 700; font-size: 13px; color: var(--ink); letter-spacing: 0.02em; text-transform: uppercase; margin-bottom: 6px; display: flex; align-items: baseline; justify-content: space-between; }
  .badge { font-family: var(--body); font-size: 10px; padding: 1px 5px; letter-spacing: 0.1em; font-weight: 700; }
  .badge-core { color: var(--red); border: 1px solid rgba(232,0,45,0.4); }
  .lb-method-card .v { font-size: 12.5px; color: var(--ink-48); line-height: 1.55; }
</style>
