---
// HockeyGameBot — /stats/wowy — With Or Without You
// Pick two teammates, get the 4-segment WOWY breakdown.
import Nav from '../../components/Nav.astro';
import StatsSubnav from '../../components/StatsSubnav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import Table from '../../components/Table.astro';
import PlayerSearch from '../../components/react/PlayerSearch';
import type { PlayerSearchItem } from '../../components/react/PlayerSearch';
import { loadPlayers } from '../../lib/stats-loader';

const searchPlayers: PlayerSearchItem[] = loadPlayers().map(p => ({
  display_name: p.display_name,
  first_name:   p.first_name ?? '',
  last_name:    p.last_name  ?? '',
  team_abbrev:  p.team_abbrev,
  pos:          p.pos,
  gp:           p.gp,
  slug:         p.slug,
  search_text:  `${p.display_name} ${p.last_name} ${p.team_abbrev}`.toLowerCase(),
  player_id:    p.player_id,
} as PlayerSearchItem & { player_id: number }));

// 4 fixed rows. SSR with empty rows; client fills via tbl:rows-changed.
const columns = [
  { key: 'segment', label: 'Segment',  type: 'label' as const, sortable: false },
  { key: 'toi_min', label: 'TOI (min)',type: 'number' as const },
  { key: 'games',   label: 'Games',    type: 'number' as const },
  { key: 'xgf_pct', label: 'xGF%',     type: 'number' as const, bold: true },
  { key: 'xgf',     label: 'xGF',      type: 'number' as const },
  { key: 'xga',     label: 'xGA',      type: 'number' as const },
  { key: 'xgf_60',  label: 'xGF/60',   type: 'number' as const },
  { key: 'xga_60',  label: 'xGA/60',   type: 'number' as const },
];
---
<!doctype html>
<html lang="en">
<head>
<ThemeScript />
<Fonts />
<meta charset="utf-8" />
<title>WOWY — With Or Without You · HockeyGameBot</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="description" content="NHL player-pair WOWY. Pick two teammates and see how each performs together, apart, and how the team does without both." />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
<link rel="apple-touch-icon" href="/favicon-180x180.png" />

<style is:global>
:root {
  --bg:      #EFEEE8;
  --bg-2:    #E8E7E0;
  --surface: #FFFFFF;
  --ink:     #0d0d14;
  --ink-86:  rgba(13,13,20,0.86);
  --ink-72:  rgba(13,13,20,0.72);
  --ink-56:  rgba(13,13,20,0.56);
  --ink-48:  rgba(13,13,20,0.48);
  --ink-32:  rgba(13,13,20,0.32);
  --ink-20:  rgba(13,13,20,0.20);
  --ink-14:  rgba(13,13,20,0.14);
  --ink-10:  rgba(13,13,20,0.10);
  --ink-06:  rgba(13,13,20,0.06);
  --ink-04:  rgba(13,13,20,0.04);
  --red:     #E8002D;
  --green:   #4ade80;
  --stats-pos: #166534;
  --stats-neg: #991b1b;
  --grid-line: rgba(13,13,20,0.04);
  --display: "Barlow Condensed", sans-serif;
  --body:    "Barlow", sans-serif;
  --mono:    "JetBrains Mono", monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; overflow-x: hidden; min-height: 100vh; }
a { color: inherit; text-decoration: none; }

.mast { position: relative; overflow: hidden; padding: 0; border-bottom: 2px solid var(--ink); background-color: var(--bg); background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px); background-size: 96px 96px; }
.mast-ghost { position: absolute; pointer-events: none; user-select: none; z-index: 0; font-family: var(--display); font-weight: 800; font-size: 260px; line-height: 0.86; text-transform: uppercase; letter-spacing: -0.02em; white-space: nowrap; color: rgba(13,13,20,0.07); top: 50%; left: 50%; transform: translate(-50%, -50%); }
.mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.mast-corners .corner { position: absolute; width: 16px; height: 16px; }
.mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 48px 32px 40px; }
.mast-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 16px; }
.mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
.mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
.mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px); text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px; }
.mast-lede { font-size: 14px; line-height: 1.65; color: var(--ink-56); max-width: 640px; }
.mast-lede .mono { font-family: var(--mono); font-size: 12px; color: var(--ink-72); }

.wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

#loading-state { padding: 80px 0; text-align: center; font-family: var(--mono); font-size: 13px; color: var(--ink-48); letter-spacing: 0.06em; }
#loading-state .spinner { width: 20px; height: 20px; border: 2px solid var(--ink-14); border-top-color: var(--red); border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 14px; }
@keyframes spin { to { transform: rotate(360deg); } }
#main-content { display: none; }

.section-block { padding: 40px 0 0; }
.section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 6px; }
.section-head h2 { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px); text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
.section-lede { font-size: 13px; color: var(--ink-48); max-width: 780px; line-height: 1.6; margin-bottom: 16px; }

.picker-row { display: flex; align-items: flex-end; gap: 16px; flex-wrap: wrap; margin-bottom: 24px; }
.picker-group { display: flex; flex-direction: column; gap: 6px; min-width: 200px; flex: 1; max-width: 280px; }
.picker-label { font-family: var(--display); font-weight: 700; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-48); }
.picker-vs { font-family: var(--display); font-weight: 800; font-size: 24px; color: var(--ink-32); align-self: flex-end; padding-bottom: 8px; }

.autocomplete-wrap { position: relative; }
.autocomplete-wrap input {
  width: 100%; background: var(--surface); border: 1px solid var(--ink-20);
  padding: 9px 12px; font-family: var(--body); font-size: 13px; color: var(--ink);
  outline: none; transition: border-color 0.15s;
}
.autocomplete-wrap input:focus { border-color: var(--ink); }
.autocomplete-wrap input.selected { border-color: var(--ink); background: var(--surface); }
.autocomplete-dropdown {
  position: absolute; top: 100%; left: 0; right: 0; z-index: 100;
  background: var(--surface); border: 1px solid var(--ink); border-top: none;
  max-height: 220px; overflow-y: auto; display: none;
}
.autocomplete-dropdown.open { display: block; }
.autocomplete-item {
  padding: 8px 12px; cursor: pointer; font-family: var(--body); font-size: 13px;
  color: var(--ink); display: flex; justify-content: space-between; align-items: center;
}
.autocomplete-item:hover, .autocomplete-item.active { background: var(--ink-06); }
.autocomplete-item .item-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32); }

.season-wrap { display: flex; flex-direction: column; gap: 6px; }
.season-wrap select {
  background: #fff; border: 1.5px solid rgba(13,13,20,0.20);
  padding: 11px 12px; font-family: var(--body); font-weight: 500;
  font-size: 14px; color: var(--ink);
  cursor: pointer; outline: none; width: 100%;
}
.season-wrap select:focus { border-color: var(--ink); }

/* WOWY result chrome */
.wowy-result { display: none; }
.wowy-result.visible { display: block; }
.wowy-header { margin-bottom: 16px; }
.wowy-title { font-family: var(--display); font-weight: 800; font-size: 22px; text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
.wowy-subtitle { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.06em; margin-top: 4px; }

.wowy-no-data { padding: 32px; background: var(--surface); border: 1px solid var(--ink-14); font-family: var(--mono); font-size: 13px; color: var(--ink-48); text-align: center; display: none; }
.wowy-no-data.visible { display: block; }

/* Segment label cell — two-line stack with optional TOGETHER badge.
   Row tinting REMOVED per TABLES.md §3: differentiation now comes from
   the badge + bolded primary line, not a background color. */
.seg-label { display: flex; flex-direction: column; gap: 2px; }
.seg-name  { font-weight: 700; font-family: var(--body); font-size: 13px; }
.seg-desc  { font-family: var(--mono); font-size: 10px; color: var(--ink-48); font-weight: 400; }
.seg-with-badge { display: inline-block; background: var(--ink); color: var(--bg); font-family: var(--display); font-weight: 700; font-size: 9px; letter-spacing: 0.1em; padding: 1px 6px; margin-left: 6px; vertical-align: middle; }

.picker-hint { padding: 48px 0; text-align: center; }
.picker-hint-icon { font-size: 40px; margin-bottom: 12px; opacity: 0.3; }
.picker-hint-text { font-family: var(--mono); font-size: 13px; color: var(--ink-48); letter-spacing: 0.04em; }

.foot { border-top: 1px solid var(--ink-14); padding: 32px 0; font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; }
.foot-inner { max-width: 1200px; margin: 0 auto; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
.foot-wordmark { font-family: var(--display); font-weight: 800; font-size: 18px; letter-spacing: 0.04em; text-transform: uppercase; display: inline-flex; align-items: center; }
.foot-wordmark .dot { width: 5px; height: 5px; background: var(--red); border-radius: 50%; margin: 0 6px; display: inline-block; }

@media (max-width: 680px) {
  .mast-inner { padding: 32px 20px 28px; }
  .wrap { padding: 0 20px 60px; }
  .mast-ghost { font-size: 120px; }
  .picker-row { flex-direction: column; }
  .picker-vs { display: none; }
}
</style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<section class="mast">
  <div class="mast-ghost">WOWY</div>
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-eyebrow"><span class="pip"></span>HockeyGameBot Analytics</div>
    <div class="mast-card">
      <h1 class="mast-headline">With Or Without You</h1>
      <p class="mast-lede">
        Pick any two teammates · see how they perform together, apart, and how the team
        does without both · 5v5 regular season · 2022–23 through 2025–26
      </p>
    </div>
  </div>
</section>
<StatsSubnav currentPath={Astro.url.pathname} />
<div class="wrap">
  <div id="loading-state">
    <div class="spinner"></div>
    Loading WOWY data...
  </div>

  <div id="main-content">
    <div class="section-block">
      <div class="section-head">
        <h2>Player Comparison</h2>
      </div>
      <p class="section-lede">
        Search for any two players who've been teammates. Results show all seasons they played together — use the season selector to narrow down.
      </p>

      <div class="picker-row">
        <div class="picker-group">
          <span class="picker-label">Player A</span>
          <PlayerSearch
            players={searchPlayers}
            placeholder="Search player A…"
            dispatchEvent="hgb:wowy-a"
            maxResults={8}
            client:load
          />
        </div>
        <div class="picker-vs">&amp;</div>
        <div class="picker-group">
          <span class="picker-label">Player B</span>
          <PlayerSearch
            players={searchPlayers}
            placeholder="Search player B…"
            dispatchEvent="hgb:wowy-b"
            maxResults={8}
            client:load
          />
        </div>
        <div class="season-wrap">
          <span class="picker-label">Season</span>
          <select id="season-filter">
            <option value="all">All Seasons</option>
            <option value="20252026">2025–26</option>
            <option value="20242025">2024–25</option>
            <option value="20232024">2023–24</option>
            <option value="20222023">2022–23</option>
          </select>
        </div>
      </div>

      <div id="picker-hint" class="picker-hint">
        <div class="picker-hint-icon">↑</div>
        <div class="picker-hint-text">Select two players above to see their WOWY breakdown</div>
      </div>

      <div id="wowy-no-data" class="wowy-no-data">
        No qualifying data — these players have &lt;50 min of 5v5 time together, or weren't teammates.
      </div>

      <div id="wowy-result" class="wowy-result">
        <div class="wowy-header">
          <div class="wowy-title" id="wowy-title"></div>
          <div class="wowy-subtitle" id="wowy-subtitle"></div>
        </div>

        <Table
          columns={columns}
          rows={[]}
          sticky={false}
          ariaLabel="WOWY 4-segment breakdown"
        />
      </div>
    </div>
  </div>
</div>

<footer class="foot">
  <div class="foot-inner">
    <span class="foot-wordmark">Hockey<span class="dot"></span>Gamebot</span>
    <span>5v5 · Regular Season · 2022–26 · Data via HGB Analytics</span>
  </div>
</footer>

<script is:inline>
(function () {
  'use strict';

  let allPairs = [];
  let playerIndex = {};
  let selectedA = null;
  let selectedB = null;
  let seasonFilter = 'all';

  function buildPlayerIndex() {
    const seen = new Set();
    allPairs.forEach(r => {
      ['player1', 'player2'].forEach((k, i) => {
        const id  = i === 0 ? r.player1_id : r.player2_id;
        const key = `${id}`;
        if (seen.has(key)) return;
        seen.add(key);
        const name = r[k];
        if (!playerIndex[name]) playerIndex[name] = { id, name };
      });
    });
  }

  function matchPlayers(query) {
    const q = query.toLowerCase().trim();
    if (!q) return [];
    return Object.values(playerIndex)
      .filter(p => p.name.toLowerCase().includes(q))
      .slice(0, 20);
  }

  function findPairs(idA, idB) {
    return allPairs.filter(r =>
      (r.player1_id === idA && r.player2_id === idB) ||
      (r.player1_id === idB && r.player2_id === idA)
    );
  }

  function aggregateSegments(records) {
    const w  = { toi:0, xgf:0, xga:0, games:0 };
    const a  = { toi:0, xgf:0, xga:0 };
    const b  = { toi:0, xgf:0, xga:0 };
    const n  = { toi:0, xgf:0, xga:0 };
    records.forEach(r => {
      if (r.with)    { w.toi  += (r.with.toi_min||0)*60;   w.xgf  += r.with.xgf||0;   w.xga  += r.with.xga||0;   w.games += r.with.games||0; }
      if (r.a_wo_b)  { a.toi  += (r.a_wo_b.toi_min||0)*60; a.xgf  += r.a_wo_b.xgf||0; a.xga  += r.a_wo_b.xga||0; }
      if (r.b_wo_a)  { b.toi  += (r.b_wo_a.toi_min||0)*60; b.xgf  += r.b_wo_a.xgf||0; b.xga  += r.b_wo_a.xga||0; }
      if (r.neither) { n.toi  += (r.neither.toi_min||0)*60; n.xgf  += r.neither.xgf||0; n.xga  += r.neither.xga||0; }
    });
    function toSeg(acc, extraGames) {
      const tot = acc.xgf + acc.xga;
      const min = round1(acc.toi / 60);
      return {
        toi_min:  min,
        games:    extraGames,
        xgf_pct:  tot > 0 ? round1(acc.xgf / tot * 100) : null,
        xgf:      round2(acc.xgf),
        xga:      round2(acc.xga),
        xgf_60:   acc.toi > 0 ? round2(acc.xgf / acc.toi * 3600) : null,
        xga_60:   acc.toi > 0 ? round2(acc.xga / acc.toi * 3600) : null,
      };
    }
    return {
      with:    toSeg(w, w.games),
      a_wo_b:  toSeg(a, null),
      b_wo_a:  toSeg(b, null),
      neither: toSeg(n, null),
    };
  }

  function round1(v) { return Math.round(v * 10) / 10; }
  function round2(v) { return Math.round(v * 100) / 100; }

  function xgfColor(v) {
    if (v == null) return '';
    if (v >= 55) return 'var(--stats-pos)';
    if (v <= 45) return 'var(--stats-neg)';
    return '';
  }
  function fmt1(v) { return v != null ? v.toFixed(1) : '—'; }
  function fmt2(v) { return v != null ? v.toFixed(2) : '—'; }
  function esc(s)  { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  function renderRow(seg, labelHtml) {
    const xCol = xgfColor(seg.xgf_pct);
    const xStyle = xCol ? ` style="color:${xCol}"` : '';
    const games = seg.games != null ? seg.games : '—';
    return `<tr class="tbl-tr">
      <td class="tbl-td type-label align-left">${labelHtml}</td>
      <td class="tbl-td align-center type-number">${fmt1(seg.toi_min)}</td>
      <td class="tbl-td align-center type-number">${games}</td>
      <td class="tbl-td align-center type-number bold"${xStyle}>${seg.xgf_pct != null ? seg.xgf_pct.toFixed(1)+'%' : '—'}</td>
      <td class="tbl-td align-center type-number">${fmt2(seg.xgf)}</td>
      <td class="tbl-td align-center type-number">${fmt2(seg.xga)}</td>
      <td class="tbl-td align-center type-number">${fmt2(seg.xgf_60)}</td>
      <td class="tbl-td align-center type-number">${fmt2(seg.xga_60)}</td>
    </tr>`;
  }

  function renderResult() {
    const hint    = document.getElementById('picker-hint');
    const noData  = document.getElementById('wowy-no-data');
    const result  = document.getElementById('wowy-result');

    if (!selectedA || !selectedB) {
      hint.style.display = '';
      noData.classList.remove('visible');
      result.classList.remove('visible');
      return;
    }
    hint.style.display = 'none';
    let records = findPairs(selectedA.id, selectedB.id);
    if (seasonFilter !== 'all') {
      records = records.filter(r => r.season === seasonFilter);
    }
    if (!records.length) {
      noData.classList.add('visible');
      result.classList.remove('visible');
      return;
    }
    noData.classList.remove('visible');
    result.classList.add('visible');

    const ref = records[0];
    const aIsP1 = ref.player1_id === selectedA.id;
    const nameA = selectedA.name;
    const nameB = selectedB.name;

    const segs = aggregateSegments(
      aIsP1
        ? records
        : records.map(r => ({ ...r, a_wo_b: r.b_wo_a, b_wo_a: r.a_wo_b }))
    );

    const teams   = [...new Set(records.map(r => r.team))].join('/');
    const seasons = [...new Set(records.map(r => {
      const y = r.season;
      return `${y.slice(0,4)}–${y.slice(6,8)}`;
    }))].join(', ');

    document.getElementById('wowy-title').textContent = `${nameA} & ${nameB}`;
    document.getElementById('wowy-subtitle').textContent = `${teams} · ${seasons} · 5v5 regular season`;

    const rows = [
      renderRow(segs.with,
        `<div class="seg-label"><span class="seg-name">${esc(nameA)} &amp; ${esc(nameB)} <span class="seg-with-badge">TOGETHER</span></span></div>`),
      renderRow(segs.a_wo_b,
        `<div class="seg-label"><span class="seg-name">${esc(nameA)}</span><span class="seg-desc">without ${esc(nameB)}</span></div>`),
      renderRow(segs.b_wo_a,
        `<div class="seg-label"><span class="seg-name">${esc(nameB)}</span><span class="seg-desc">without ${esc(nameA)}</span></div>`),
      renderRow(segs.neither,
        `<div class="seg-label"><span class="seg-name">${esc(teams)}</span><span class="seg-desc">without either</span></div>`),
    ];

    const wrap = document.querySelector('.tbl-wrap[data-tbl-id]');
    const tbody = wrap ? wrap.querySelector('tbody') : null;
    if (tbody) {
      tbody.innerHTML = rows.join('');
      wrap.dispatchEvent(new CustomEvent('tbl:rows-changed'));
    }
  }

  async function init() {
    try {
      const res = await fetch('https://api.hockeygamebot.com/v1/stats/wowy', { cache: 'no-store' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      allPairs = await res.json();
    } catch (err) {
      document.getElementById('loading-state').innerHTML =
        `<p style="font-family:var(--mono);font-size:13px;color:var(--red)">Failed to load: ${err.message}</p>`;
      return;
    }
    buildPlayerIndex();
    document.getElementById('loading-state').style.display = 'none';
    document.getElementById('main-content').style.display = 'block';

    // React PlayerSearch islands dispatch these events on player select/clear
    document.addEventListener('hgb:wowy-a', (e) => {
      const p = e.detail;
      selectedA = p ? { id: p.player_id ?? p.id, name: p.display_name ?? p.name } : null;
      renderResult();
    });
    document.addEventListener('hgb:wowy-b', (e) => {
      const p = e.detail;
      selectedB = p ? { id: p.player_id ?? p.id, name: p.display_name ?? p.name } : null;
      renderResult();
    });

    document.getElementById('season-filter').addEventListener('change', e => {
      seasonFilter = e.target.value;
      renderResult();
    });

    renderResult();
  }
  init();
})();
</script>
