---
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import Table from '../../components/Table.astro';
import { loadPlayers, loadLeaderboard, loadPlayoffLeaderboard, loadGoalies } from '../../lib/stats-loader';

const allPlayers  = loadPlayers();
const eligible    = allPlayers.filter(p => p.gp >= 20);
const allGoalies  = loadGoalies();

// ── Regular season data ──────────────────────────────────────────────────────

const regPoints = [...eligible]
  .sort((a, b) => (b.goals + b.assists) - (a.goals + a.assists))
  .slice(0, 10)
  .map((p, i) => ({
    rank: i + 1,
    slug: p.slug,
    display_name: p.display_name,
    team_abbrev: p.team_abbrev,
    pos: p.pos,
    gp: p.gp,
    goals: p.goals,
    assists: p.assists,
    points: p.goals + p.assists,
  }));

const regGoals = [...eligible]
  .sort((a, b) => b.goals - a.goals)
  .slice(0, 10)
  .map((p, i) => ({ rank: i + 1, slug: p.slug, display_name: p.display_name, team_abbrev: p.team_abbrev, pos: p.pos, gp: p.gp, goals: p.goals }));

const regAssists = [...eligible]
  .sort((a, b) => b.assists - a.assists)
  .slice(0, 10)
  .map((p, i) => ({ rank: i + 1, slug: p.slug, display_name: p.display_name, team_abbrev: p.team_abbrev, pos: p.pos, gp: p.gp, assists: p.assists }));

const regXg = [...eligible]
  .sort((a, b) => b.rates_per_60.ixg - a.rates_per_60.ixg)
  .slice(0, 10)
  .map((p, i) => ({ rank: i + 1, slug: p.slug, display_name: p.display_name, team_abbrev: p.team_abbrev, pos: p.pos, gp: p.gp, xg60: +p.rates_per_60.ixg.toFixed(2) }));

const regImpact = loadLeaderboard('game_score').slice(0, 10).map((p, i) => ({ ...p, rank: i + 1 }));

const regPts60 = [...eligible]
  .map(p => ({
    rank: 0,
    slug: p.slug,
    display_name: p.display_name,
    team_abbrev: p.team_abbrev,
    pos: p.pos,
    gp: p.gp,
    pts60: +((p.goals + p.assists) / Math.max(p.toi_avg_sec * p.gp / 3600, 0.001)).toFixed(2),
  }))
  .sort((a, b) => b.pts60 - a.pts60)
  .slice(0, 10)
  .map((p, i) => ({ ...p, rank: i + 1 }));

const regGsax = [...allGoalies]
  .sort((a, b) => b.gsax - a.gsax)
  .slice(0, 10)
  .map((g, i) => ({
    rank: i + 1,
    goalie_id: g.goalie_id,
    name: g.name,
    team_abbrev: g.team_abbrev,
    sa: g.sa,
    gsax: +g.gsax.toFixed(2),
  }));

// ── Playoff data ─────────────────────────────────────────────────────────────

const poGoalsRaw   = loadPlayoffLeaderboard('goals');
const poAssistsRaw = loadPlayoffLeaderboard('assists');
const poXgRaw      = loadPlayoffLeaderboard('xg');

const poGoals   = poGoalsRaw.map((r, i)   => ({ ...r, rank: i + 1, goals: r.value }));
const poAssists = poAssistsRaw.map((r, i) => ({ ...r, rank: i + 1, assists: r.value }));
const poXg      = poXgRaw.map((r, i)      => ({ ...r, rank: i + 1, xg60: r.value }));

// Merge goals + assists lists by player_id to compute points
const poMap = new Map<number, any>();
for (const r of poGoalsRaw)   { poMap.set(r.player_id, { ...r, goals: r.value, assists: 0 }); }
for (const r of poAssistsRaw) {
  if (poMap.has(r.player_id)) poMap.get(r.player_id)!.assists = r.value;
  else poMap.set(r.player_id, { ...r, goals: 0, assists: r.value });
}
const poPoints = [...poMap.values()]
  .sort((a, b) => (b.goals + b.assists) - (a.goals + a.assists))
  .slice(0, 10)
  .map((p, i) => ({ ...p, rank: i + 1, points: p.goals + p.assists }));

const hasPlayoffData = poPoints.length > 0;

const poGsax = allGoalies
  .filter(g => g.playoff_gsax != null && (g.playoff_sa ?? 0) > 0)
  .sort((a, b) => (b.playoff_gsax ?? 0) - (a.playoff_gsax ?? 0))
  .slice(0, 10)
  .map((g, i) => ({
    rank: i + 1,
    goalie_id: g.goalie_id,
    name: g.name,
    team_abbrev: g.team_abbrev,
    sa: g.playoff_sa ?? 0,
    gsax: +(g.playoff_gsax ?? 0).toFixed(2),
    games: g.playoff_games ?? null,
  }));

// Search index (kept from previous version — useful entry point for player lookup)
const searchIndex = allPlayers.map(p => ({
  slug: p.slug,
  name: `${p.first_name} ${p.last_name}`,
  team: p.team_abbrev,
  pos:  p.pos,
  gp:   p.gp,
}));

function sgn(n: number): string { return n >= 0 ? '+' : ''; }

// ── Table.astro column schemas for the 7 mini-leaderboards ──────────────────
// Each card is a tiny 10-row table — sticky thead is unnecessary
// (TABLES.md §2). PNG export is wired on the 6 cards that had it before.

const signedColor = (v: any, _r: any, tok?: { pos: string; neg: string }) => {
  if (v == null) return undefined;
  return v >= 0 ? tok?.pos : tok?.neg;
};

const pointsColumns = [
  { key: 'rank',         label: '#',      type: 'rank' as const, sortable: false },
  { key: 'display_name', label: 'Player', type: 'player' as const, sub: (r: any) => `${r.team_abbrev} · ${r.pos}` },
  { key: 'goals',        label: 'G',      type: 'number' as const },
  { key: 'assists',      label: 'A',      type: 'number' as const },
  { key: 'points',       label: 'P',      type: 'number' as const, bold: true },
];

const impactColumns = [
  { key: 'rank',         label: '#',      type: 'rank' as const, sortable: false },
  { key: 'display_name', label: 'Player', type: 'player' as const, sub: (r: any) => `${r.team_abbrev} · ${r.pos}` },
  { key: 'gp',           label: 'GP',     type: 'number' as const },
  { key: 'value',        label: 'Impact', type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : (v >= 0 ? '+' : '') + Number(v).toFixed(2),
    color: signedColor },
];

const gsaxColumns = [
  { key: 'rank',        label: '#',      type: 'rank' as const, sortable: false },
  { key: 'name',        label: 'Goalie', type: 'player' as const, sub: (r: any) => `${r.team_abbrev}${r.games != null ? ' · ' + r.games + ' GP' : ''}` },
  { key: 'sa',          label: 'SA',     type: 'number' as const,
    format: (v: any) => v == null ? '—' : Number(v).toLocaleString() },
  { key: 'gsax',        label: 'GSAx',   type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : (v >= 0 ? '+' : '') + Number(v).toFixed(2),
    color: signedColor },
];

const goalsColumns = [
  { key: 'rank',         label: '#',      type: 'rank' as const, sortable: false },
  { key: 'display_name', label: 'Player', type: 'player' as const, sub: (r: any) => `${r.team_abbrev} · ${r.pos}` },
  { key: 'gp',           label: 'GP',     type: 'number' as const },
  { key: 'goals',        label: 'G',      type: 'number' as const, bold: true },
];

const assistsColumns = [
  { key: 'rank',         label: '#',      type: 'rank' as const, sortable: false },
  { key: 'display_name', label: 'Player', type: 'player' as const, sub: (r: any) => `${r.team_abbrev} · ${r.pos}` },
  { key: 'gp',           label: 'GP',     type: 'number' as const },
  { key: 'assists',      label: 'A',      type: 'number' as const, bold: true },
];

const xgColumns = [
  { key: 'rank',         label: '#',      type: 'rank' as const, sortable: false },
  { key: 'display_name', label: 'Player', type: 'player' as const, sub: (r: any) => `${r.team_abbrev} · ${r.pos}` },
  { key: 'gp',           label: 'GP',     type: 'number' as const },
  { key: 'xg60',         label: 'xG/60',  type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(2) },
];

const pts60Columns = [
  { key: 'rank',         label: '#',      type: 'rank' as const, sortable: false },
  { key: 'display_name', label: 'Player', type: 'player' as const, sub: (r: any) => `${r.team_abbrev} · ${r.pos}` },
  { key: 'gp',           label: 'GP',     type: 'number' as const },
  { key: 'pts60',        label: 'P/60',   type: 'number' as const, bold: true,
    format: (v: any) => v == null ? '—' : Number(v).toFixed(2) },
];

// Rows need `team` so Table.astro's td-player can render the team logo.
function withTeam(rs: any[]) { return rs.map(r => ({ ...r, team: r.team_abbrev })); }
const regPointsT  = withTeam(regPoints);
const regImpactT  = withTeam(regImpact);
const regGsaxT    = withTeam(regGsax);
const regGoalsT   = withTeam(regGoals);
const regAssistsT = withTeam(regAssists);
const regXgT      = withTeam(regXg);
const regPts60T   = withTeam(regPts60);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>HGB Stats Dashboard — HockeyGameBot</title>
  <meta name="description" content="NHL stats leaderboards — Points, HGB Impact, and Goalie GSAx. Regular season and playoffs. Updated nightly." />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:        #EFEEE8;
      --ink:       #0d0d14;
      --red:       #E8002D;
      --surface:   #FFFFFF;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04:    rgba(13,13,20,0.04);
      --ink-06:    rgba(13,13,20,0.06);
      --ink-10:    rgba(13,13,20,0.10);
      --ink-14:    rgba(13,13,20,0.14);
      --ink-20:    rgba(13,13,20,0.20);
      --ink-32:    rgba(13,13,20,0.32);
      --ink-48:    rgba(13,13,20,0.48);
      --stats-pos: #166534;
      --stats-neg: #991b1b;
      --display:   'Barlow Condensed', sans-serif;
      --body:      'Barlow', sans-serif;
      --mono:      'JetBrains Mono', monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    /* ── Masthead ── */
    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
      margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px);
      text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 16px; }
    .mast-headline em { color: var(--red); font-style: normal; }

    /* Player search */
    .search-wrap { position: relative; max-width: 480px; }
    .search-input { width: 100%; padding: 11px 44px 11px 16px; font-family: var(--body); font-size: 14px;
      font-weight: 500; background: var(--bg); color: var(--ink); border: 1.5px solid var(--ink-20);
      outline: none; transition: border-color 0.15s; }
    .search-input::placeholder { color: var(--ink-32); }
    .search-input:focus { border-color: var(--ink); }
    .search-icon { position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
      color: var(--ink-32); pointer-events: none; font-size: 13px; font-family: var(--mono); }
    .search-results { position: absolute; top: calc(100% + 2px); left: 0; right: 0; z-index: 50;
      background: var(--surface); border: 2px solid var(--ink); display: none; flex-direction: column; }
    .search-results.open { display: flex; }
    .search-result { display: flex; align-items: center; gap: 12px; padding: 10px 14px;
      border-bottom: 1px solid var(--ink-10); text-decoration: none; color: var(--ink); }
    .search-result:last-child { border-bottom: 0; }
    .search-result:hover, .search-result.focused { background: var(--bg); }
    .sr-name { font-weight: 600; font-size: 14px; flex: 1; }
    .sr-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.05em; }
    .sr-empty { padding: 12px 14px; font-family: var(--mono); font-size: 11px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* ── Layout ── */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

    /* ── Toggle ── */
    .dash-head { display: flex; align-items: center; justify-content: space-between; gap: 16px;
      padding: 32px 0 20px; flex-wrap: wrap; }
    .dash-title { font-family: var(--display); font-weight: 800; font-size: 22px;
      text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
    .dash-meta { font-family: var(--mono); font-size: 10.5px; color: var(--ink-32); letter-spacing: 0.06em; }
    .btn-group { display: inline-flex; border: 1px solid var(--ink-14); }
    .btn-group button { background: var(--surface); border: none; border-right: 1px solid var(--ink-14);
      padding: 6px 14px; cursor: pointer; font-family: var(--body); font-weight: 600; font-size: 11.5px;
      letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-48);
      transition: background 0.1s, color 0.1s; }
    .btn-group button:last-child { border-right: none; }
    .btn-group button.active { background: var(--ink); color: var(--bg); }
    .btn-group button:hover:not(.active) { background: var(--ink-06); color: var(--ink); }

    /* ── Card grid ── */
    .card-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    @media (max-width: 900px)  { .card-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 580px)  { .card-grid { grid-template-columns: 1fr; } }

    /* ── Individual card ── */
    .lb-card { background: var(--surface); border: 1px solid var(--ink-14); display: flex; flex-direction: column; }
    .lb-card-head { display: flex; align-items: center; justify-content: space-between;
      padding: 14px 16px 12px; border-bottom: 2px solid var(--ink); }
    .lb-card-title { font-family: var(--display); font-weight: 800; font-size: 16px;
      text-transform: uppercase; letter-spacing: 0.02em; color: var(--ink); }
    .lb-card-desc { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32);
      letter-spacing: 0.08em; text-transform: uppercase; margin-top: 2px; }
    /* Card table chrome lives in Table.astro now. We do drop the wrap's own
       border because the card itself already provides one. */
    .lb-card .tbl-wrap { border: none; background: transparent; }
    .lb-card .tbl-actions { padding: 6px 12px; }

    /* card footer */
    .lb-card-foot { display: flex; align-items: center; justify-content: flex-end;
      padding: 10px 14px; border-top: 1px solid var(--ink-06); margin-top: auto; }
    .lb-card-link { font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.10em;
      text-transform: uppercase; color: var(--ink-32); text-decoration: none; }
    .lb-card-link:hover { color: var(--red); }

    .no-data { padding: 40px 16px; text-align: center; font-family: var(--mono); font-size: 11px;
      color: var(--ink-32); letter-spacing: 0.06em; }

    /* ── Footer ── */
    .page-footer { max-width: 1200px; margin: 0 auto; padding: 20px 32px;
      font-family: var(--mono); font-size: 9px; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--ink-20); }

    @media (max-width: 768px) {
      .wrap, .mast-inner { padding-left: 16px; padding-right: 16px; }
    }
  </style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<!-- ── Masthead ── -->
<header class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div class="mast-eyebrow"><span class="pip"></span> HGB Stats · Dashboard</div>
      <span>{eligible.length} qualifying skaters · 2025–26</span>
    </div>
    <div class="mast-card">
      <h1 class="mast-headline">2025–26 <em>Season Leaders</em></h1>
      <div class="search-wrap" id="search-wrap">
        <input type="search" class="search-input" id="player-search"
          placeholder="Search players — MacKinnon, Caufield, …"
          autocomplete="off" spellcheck="false" />
        <span class="search-icon">↗</span>
        <div class="search-results" id="search-results" role="listbox"></div>
      </div>
    </div>
  </div>
</header>

<main class="wrap">

  <!-- ── Section head + toggle ── -->
  <div class="dash-head">
    <div>
      <div class="dash-title" id="dash-title">Leaders</div>
      <div class="dash-meta" id="dash-meta">Points · HGB Impact · Goalie GSAx · 2025–26 regular season</div>
    </div>
    <div class="btn-group" id="gametype-filter">
      <button class="active" data-gametype="2">Regular Season</button>
      <button data-gametype="3">Playoffs</button>
    </div>
  </div>

  <!-- ── Card grid ── -->
  <div class="card-grid">

    <!-- POINTS card -->
    <article class="lb-card" id="card-points">
      <div class="lb-card-head">
        <div>
          <div class="lb-card-title">Points</div>
          <div class="lb-card-desc" id="points-desc">Goals + Assists · Regular Season</div>
        </div>
      </div>
      <Table
        columns={pointsColumns}
        rows={regPointsT}
        rowHref={(r) => `/stats/player/${r.slug}`}
        sticky={false}
        exportFilename="hgb-points.png"
        exportTitle="Points Leaders"
        ariaLabel="Points leaderboard"
      />
      <div class="lb-card-foot">
        <a class="lb-card-link" href="/stats/skaters">See all skaters →</a>
      </div>
    </article>

    <!-- HGB IMPACT card -->
    <article class="lb-card" id="card-impact">
      <div class="lb-card-head">
        <div>
          <div class="lb-card-title">HGB Impact</div>
          <div class="lb-card-desc" id="impact-desc">Per-game avg · Regular Season</div>
        </div>
      </div>
      <Table
        columns={impactColumns}
        rows={regImpactT}
        rowHref={(r) => `/stats/player/${r.slug}`}
        sticky={false}
        exportFilename="hgb-impact.png"
        exportTitle="HGB Impact Leaders"
        ariaLabel="HGB Impact leaderboard"
      />
      <div class="lb-card-foot">
        <a class="lb-card-link" href="/stats/skaters">See all skaters →</a>
      </div>
    </article>

    <!-- GOALIE GSAx card -->
    <article class="lb-card" id="card-gsax">
      <div class="lb-card-head">
        <div>
          <div class="lb-card-title">Goalie GSAx</div>
          <div class="lb-card-desc" id="gsax-desc">Goals Saved Above Expected · Regular Season</div>
        </div>
      </div>
      <Table
        columns={gsaxColumns}
        rows={regGsaxT}
        rowHref={(r) => `/stats/goalies/${r.goalie_id}`}
        sticky={false}
        exportFilename="hgb-gsax.png"
        exportTitle="Goalie GSAx Leaders"
        ariaLabel="Goalie GSAx leaderboard"
      />
      <div class="lb-card-foot">
        <a class="lb-card-link" href="/stats/goalies">See all goalies →</a>
      </div>
    </article>

    <!-- GOALS card -->
    <article class="lb-card" id="card-goals">
      <div class="lb-card-head">
        <div>
          <div class="lb-card-title">Goals</div>
          <div class="lb-card-desc" id="goals-desc">Total goals · Regular Season</div>
        </div>
      </div>
      <Table
        columns={goalsColumns}
        rows={regGoalsT}
        rowHref={(r) => `/stats/player/${r.slug}`}
        sticky={false}
        exportFilename="hgb-goals.png"
        exportTitle="Goals Leaders"
        ariaLabel="Goals leaderboard"
      />
      <div class="lb-card-foot">
        <a class="lb-card-link" href="/stats/skaters">See all skaters →</a>
      </div>
    </article>

    <!-- ASSISTS card -->
    <article class="lb-card" id="card-assists">
      <div class="lb-card-head">
        <div>
          <div class="lb-card-title">Assists</div>
          <div class="lb-card-desc" id="assists-desc">Total assists · Regular Season</div>
        </div>
      </div>
      <Table
        columns={assistsColumns}
        rows={regAssistsT}
        rowHref={(r) => `/stats/player/${r.slug}`}
        sticky={false}
        exportFilename="hgb-assists.png"
        exportTitle="Assists Leaders"
        ariaLabel="Assists leaderboard"
      />
      <div class="lb-card-foot">
        <a class="lb-card-link" href="/stats/skaters">See all skaters →</a>
      </div>
    </article>

    <!-- xG card -->
    <article class="lb-card" id="card-xg">
      <div class="lb-card-head">
        <div>
          <div class="lb-card-title">Exp. Goals</div>
          <div class="lb-card-desc" id="xg-desc">Individual xG/60 · Regular Season</div>
        </div>
      </div>
      <Table
        columns={xgColumns}
        rows={regXgT}
        rowHref={(r) => `/stats/player/${r.slug}`}
        sticky={false}
        exportFilename="hgb-xg.png"
        exportTitle="Expected Goals Leaders"
        ariaLabel="Expected goals leaderboard"
      />
      <div class="lb-card-foot">
        <a class="lb-card-link" href="/stats/skaters">See all skaters →</a>
      </div>
    </article>

    <!-- POINTS/60 card -->
    <article class="lb-card" id="card-pts60">
      <div class="lb-card-head">
        <div>
          <div class="lb-card-title">Points/60</div>
          <div class="lb-card-desc">Total pts per 60 min · Regular Season</div>
        </div>
      </div>
      <Table
        columns={pts60Columns}
        rows={regPts60T}
        rowHref={(r) => `/stats/player/${r.slug}`}
        sticky={false}
        ariaLabel="Points/60 leaderboard"
      />
      <div class="lb-card-foot">
        <a class="lb-card-link" href="/stats/skaters">See all skaters →</a>
      </div>
    </article>

  </div><!-- /.card-grid -->

</main>

<footer class="page-footer">HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026 · DASHBOARD</footer>

<script is:inline src="/js/table-export.js"></script>
<script define:vars={{ regPoints, poPoints, regGoals, poGoals, regAssists, poAssists, regXg, poXg, regImpact, regGsax, poGsax, hasPlayoffData, searchIndex }}>

// ── State ────────────────────────────────────────────────────────────────────
let gameType = 2;

function readUrl() {
  const p = new URLSearchParams(window.location.search);
  if (p.get('game_type') === '3' || p.get('season') === 'playoff') gameType = 3;
}
function updateUrl() {
  const p = new URLSearchParams();
  if (gameType === 3) p.set('game_type', '3');
  const qs = p.toString();
  history.replaceState(null, '', qs ? `?${qs}` : window.location.pathname);
}

// ── Table renderers ──────────────────────────────────────────────────────────
// SSR-rendered rows use Table.astro's own markup. On playoff toggle the JS
// rebuilds the tbody contents matching that markup, then dispatches
// tbl:rows-changed so the component re-snapshots + re-binds row navigation.

function escHtml(s) {
  return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// Build a Table.astro player-row <tr> matching the SSR output.
function tblRow(opts) {
  // opts: { rank, href, name, team, sub, cells }
  // cells: array of { text, bold?, color? }
  const teamAbbr = escHtml(opts.team || '');
  const nameEsc = escHtml(opts.name);
  const subEsc = escHtml(opts.sub || '');
  const cellsHtml = opts.cells.map(c => {
    const cls = ['tbl-td', 'align-center', 'type-number', c.bold ? 'bold' : ''].filter(Boolean).join(' ');
    const style = c.color ? ` style="color:${c.color}"` : '';
    return `<td class="${cls}"${style}>${c.text}</td>`;
  }).join('');
  const trAttrs = opts.href ? `class="tbl-tr clickable" tabindex="0" data-href="${opts.href}" role="link"` : 'class="tbl-tr"';
  return `<tr ${trAttrs}>
    <td class="tbl-td td-rk align-right">${String(opts.rank).padStart(2, '0')}</td>
    <td class="tbl-td td-player align-left">
      <div class="td-player-inner">
        ${teamAbbr ? `<img class="td-logo" src="https://assets.nhle.com/logos/nhl/svg/${teamAbbr}_light.svg" width="22" height="22" alt="${teamAbbr}" loading="lazy" onerror="this.style.display='none'" />` : ''}
        <div class="td-player-meta">
          <span class="td-name">${nameEsc}</span>
          <span class="td-sub">${subEsc}</span>
        </div>
      </div>
    </td>
    ${cellsHtml}
  </tr>`;
}

function fillCard(cardId, rows, rowBuilder, colspan, emptyMsg) {
  const wrap = document.querySelector(`#${cardId} .tbl-wrap[data-tbl-id]`);
  if (!wrap) return;
  const tbody = wrap.querySelector('tbody');
  if (!tbody) return;
  if (!rows || rows.length === 0) {
    tbody.innerHTML = `<tr class="tbl-empty"><td colspan="${colspan}">${emptyMsg}</td></tr>`;
  } else {
    tbody.innerHTML = rows.map((r, i) => rowBuilder(r, i + 1)).join('');
  }
  wrap.dispatchEvent(new CustomEvent('tbl:rows-changed'));
}

function renderPointsTable() {
  if (gameType !== 3) return; // SSR already has regular season
  fillCard('card-points', poPoints, (r, i) => tblRow({
    rank: i, href: `/stats/player/${r.slug}`, name: r.display_name, team: r.team_abbrev,
    sub: `${r.team_abbrev} · ${r.pos}`,
    cells: [{ text: String(r.goals) }, { text: String(r.assists) }, { text: String(r.points), bold: true }],
  }), 5, 'No playoff data yet');
}

function renderCountingCard(cardId, regRows, poRows, valKey, valFmt) {
  if (gameType !== 3) return; // SSR already has regular
  fillCard(cardId, poRows, (r, i) => tblRow({
    rank: i, href: `/stats/player/${r.slug}`, name: r.display_name, team: r.team_abbrev,
    sub: `${r.team_abbrev} · ${r.pos}`,
    cells: [{ text: String(r.gp ?? '—') }, { text: valFmt(r[valKey]), bold: true }],
  }), 4, 'No playoff data yet');
}

function renderImpactTable() {
  if (gameType !== 3) return;
  fillCard('card-impact', [], null, 4, 'Regular season only — playoff Impact coming soon');
}

function renderGsaxTable() {
  if (gameType !== 3) return;
  fillCard('card-gsax', poGsax, (r, i) => {
    const color = r.gsax >= 0 ? 'var(--stats-pos)' : 'var(--stats-neg)';
    return tblRow({
      rank: i, href: `/stats/goalies/${r.goalie_id}`, name: r.name, team: r.team_abbrev,
      sub: `${r.team_abbrev}${r.games != null ? ' · ' + r.games + ' GP' : ''}`,
      cells: [
        { text: r.sa.toLocaleString() },
        { text: (r.gsax >= 0 ? '+' : '') + r.gsax.toFixed(2), bold: true, color },
      ],
    });
  }, 4, 'No playoff data yet');
}

function restoreRegular() {
  // For the regular path we'd ideally just reload SSR rows. Since SSR is the
  // canonical source for the regular dataset, simplest path is to refresh the
  // page when switching back from playoff. Toggle code below uses a tiny
  // helper that re-rebuilds the rows in place from JSON copies.
  function buildPointsRow(r, i) {
    return tblRow({
      rank: i, href: `/stats/player/${r.slug}`, name: r.display_name, team: r.team_abbrev,
      sub: `${r.team_abbrev} · ${r.pos}`,
      cells: [{ text: String(r.goals) }, { text: String(r.assists) }, { text: String(r.points), bold: true }],
    });
  }
  function buildCountingRow(r, i, valKey, fmt) {
    return tblRow({
      rank: i, href: `/stats/player/${r.slug}`, name: r.display_name, team: r.team_abbrev,
      sub: `${r.team_abbrev} · ${r.pos}`,
      cells: [{ text: String(r.gp ?? '—') }, { text: fmt(r[valKey]), bold: true }],
    });
  }
  fillCard('card-points',  regPoints,  buildPointsRow, 5, 'No data');
  fillCard('card-goals',   regGoals,   (r, i) => buildCountingRow(r, i, 'goals',   v => String(v)), 4, 'No data');
  fillCard('card-assists', regAssists, (r, i) => buildCountingRow(r, i, 'assists', v => String(v)), 4, 'No data');
  fillCard('card-xg',      regXg,      (r, i) => buildCountingRow(r, i, 'xg60',    v => Number(v).toFixed(2)), 4, 'No data');
  fillCard('card-impact',  regImpact,  (r, i) => {
    const color = r.value >= 0 ? 'var(--stats-pos)' : 'var(--stats-neg)';
    return tblRow({
      rank: i, href: `/stats/player/${r.slug}`, name: r.display_name, team: r.team_abbrev,
      sub: `${r.team_abbrev} · ${r.pos}`,
      cells: [
        { text: String(r.gp ?? '—') },
        { text: (r.value >= 0 ? '+' : '') + r.value.toFixed(2), bold: true, color },
      ],
    });
  }, 4, 'No data');
  fillCard('card-gsax',    regGsax,    (r, i) => {
    const color = r.gsax >= 0 ? 'var(--stats-pos)' : 'var(--stats-neg)';
    return tblRow({
      rank: i, href: `/stats/goalies/${r.goalie_id}`, name: r.name, team: r.team_abbrev,
      sub: r.team_abbrev,
      cells: [
        { text: r.sa.toLocaleString() },
        { text: (r.gsax >= 0 ? '+' : '') + r.gsax.toFixed(2), bold: true, color },
      ],
    });
  }, 4, 'No data');
}

function syncUi() {
  const isPlayoff = gameType === 3;
  const mode = isPlayoff ? 'Playoffs' : 'Regular Season';

  document.getElementById('dash-title').textContent   = isPlayoff ? 'Playoff Leaders' : 'Season Leaders';
  document.getElementById('dash-meta').textContent    = `Points · Goals · Assists · xG · HGB Impact · GSAx · 2025–26 ${mode.toLowerCase()}`;
  document.getElementById('points-desc').textContent  = `Goals + Assists · ${mode}`;
  document.getElementById('goals-desc').textContent   = `Total goals · ${mode}`;
  document.getElementById('assists-desc').textContent = `Total assists · ${mode}`;
  document.getElementById('xg-desc').textContent      = `Individual xG/60 · ${mode}`;
  document.getElementById('impact-desc').textContent  = `Per-game avg · ${isPlayoff ? 'Regular Season only' : 'Regular Season'}`;
  document.getElementById('gsax-desc').textContent    = `Goals Saved Above Expected · ${mode}`;

  document.querySelectorAll('#gametype-filter button').forEach(btn => {
    btn.classList.toggle('active', parseInt(btn.dataset.gametype) === gameType);
  });
}

function renderAll() {
  if (gameType === 3) {
    renderPointsTable();
    renderCountingCard('card-goals',   regGoals,   poGoals,   'goals',   v => String(v));
    renderCountingCard('card-assists', regAssists, poAssists, 'assists', v => String(v));
    renderCountingCard('card-xg',      regXg,      poXg,      'xg60',    v => typeof v === 'number' ? v.toFixed(2) : String(v));
    renderImpactTable();
    renderGsaxTable();
  } else {
    restoreRegular();
  }
  syncUi();
}

// ── Toggle wiring ─────────────────────────────────────────────────────────────
document.querySelectorAll('#gametype-filter button').forEach(btn => {
  btn.addEventListener('click', () => {
    const gt = parseInt(btn.dataset.gametype);
    if (gt === gameType) return;
    gameType = gt;
    updateUrl();
    renderAll();
  });
});

// ── PNG export ───────────────────────────────────────────────────────────────
// Wired natively by Table.astro via the exportFilename prop on each card.
// The component reads cell text from the active rows + the closed-over schema
// at click time so the PNG mirrors what's on screen.

// ── Player search ─────────────────────────────────────────────────────────────
const input   = document.getElementById('player-search');
const results = document.getElementById('search-results');
let focusedIdx = -1, lastQuery = '';

function renderSearch(query) {
  lastQuery = query;
  const q = query.trim().toLowerCase();
  if (!q) { results.classList.remove('open'); return; }
  const hits = searchIndex.filter(p => p.name.toLowerCase().includes(q)).slice(0, 8);
  if (!hits.length) {
    results.innerHTML = '<div class="sr-empty">No players found</div>';
    results.classList.add('open'); focusedIdx = -1; return;
  }
  results.innerHTML = hits.map((p, i) =>
    `<a class="search-result" href="/stats/player/${p.slug}" role="option" data-idx="${i}">
      <span class="sr-name">${p.name}</span>
      <span class="sr-meta">${p.team} · ${p.pos} · ${p.gp} GP</span>
    </a>`
  ).join('');
  results.classList.add('open'); focusedIdx = -1;
}
function moveFocus(dir) {
  const items = results.querySelectorAll('.search-result');
  if (!items.length) return;
  items[focusedIdx]?.classList.remove('focused');
  focusedIdx = (focusedIdx + dir + items.length) % items.length;
  const el = items[focusedIdx]; el.classList.add('focused'); el.scrollIntoView({ block: 'nearest' });
}
input.addEventListener('input', e => renderSearch(e.target.value));
input.addEventListener('keydown', e => {
  if (e.key === 'ArrowDown')  { e.preventDefault(); moveFocus(1); }
  if (e.key === 'ArrowUp')    { e.preventDefault(); moveFocus(-1); }
  if (e.key === 'Enter') { const f = results.querySelector('.search-result.focused'); if (f) window.location.href = f.href; }
  if (e.key === 'Escape') { results.classList.remove('open'); input.blur(); }
});
document.addEventListener('click', e => { if (!e.target.closest('#search-wrap')) results.classList.remove('open'); });
input.addEventListener('focus', () => { if (lastQuery) renderSearch(lastQuery); });

// ── Init ──────────────────────────────────────────────────────────────────────
readUrl();
renderAll();
</script>

</body>
</html>
