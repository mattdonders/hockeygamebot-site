---
import '../../styles/stats-tokens.css';
import PageHeader from '../../components/stats/PageHeader.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Anti-FOUC: sets html[data-mode] before CSS renders — zero flash.
       keep in sync with stats/dev/components.astro; extract to shared layout in SS-8. -->
  <script is:inline>
    (function() {
      try {
        var saved = localStorage.getItem('hgb-mode');
        var system = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.dataset.mode = saved || system;
      } catch (_) {
        document.documentElement.dataset.mode = 'dark';
      }
    })();
  </script>
  <meta name="color-scheme" content="light dark">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>HGB Stats — Coming Soon</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    body {
      background: var(--site-bg);
      color: var(--site-white);
      font-family: var(--font-site-display);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .wordmark {
      font-size: 3rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      line-height: 1;
    }

    .accent {
      width: 100%;
      height: 3px;
      background: var(--hgb-red);
      margin-top: 0.5rem;
    }

    .coming-soon {
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--site-muted);
      margin-top: 1.25rem;
      font-family: var(--font-site-body);
    }

    footer {
      position: fixed;
      bottom: 1rem;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--site-muted);
      font-family: var(--font-mono);
    }
  </style>
</head>
<body>
  <PageHeader activePage="stats" />
  <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;">
    <h1 class="wordmark">HOCKEYGAMEBOT STATS</h1>
    <div class="accent"></div>
    <p class="coming-soon">Coming Soon</p>
  </div>
  <footer>SS-2b &middot; rewrite branch &middot; 2026-04-22</footer>
</body>
</html>
