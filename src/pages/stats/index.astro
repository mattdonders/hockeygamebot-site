---
// /stats — Command Center (Concept C: "Minimal Cockpit")
// TONIGHT strip → YOUR TEAMS → YOUR PLAYERS → TOP SIGNALS → (date-gated) DRAFT CAPITAL.
// Logged-in: real session. Logged-out: C-shaped teaser. Dev-only override: ?devprefs=1 (see auth-client.ts).
import Base from '../../layouts/Base.astro';
import StatsSubnav from '../../components/StatsSubnav.astro';
import { loadPlayers, loadLeaderboard, loadGoalies, loadMeta } from '../../lib/stats-loader';
import { DashboardTopImpact, type TopImpactRow } from '../../components/react/DashboardPlayersTable';
import { DashboardTeamCards } from '../../components/react/DashboardPersonalized';
import { CommandCenterTonight, CommandCenterPlayers, CommandCenterSignals, CommandCenterSignalsPreview, CommandCenterTopImpact, CommandCenterOddsMover } from '../../components/react/CommandCenter';
import { CommandCenterDraftCapital } from '../../components/react/CommandCenterDraftCapital';
import GlobalPlayerSearch, { type PlayerSearchItem } from '../../components/react/GlobalPlayerSearch';

// ── Build-time data for search index + logged-out public leaderboards ─────────
// (Static leaderboard data, not personalized/time-sensitive — safe to bake at
// build time; nothing on this page re-fetches it client-side.)
const allPlayers = loadPlayers();
const allGoalies = loadGoalies();
const _meta = loadMeta();

const playerSearchIndex: PlayerSearchItem[] = [
  ...allPlayers.map(p => ({
    display_name: p.display_name, first_name: p.first_name, last_name: p.last_name,
    team_abbrev: p.team_abbrev, pos: p.pos, gp: p.gp, slug: p.slug,
    search_text: `${p.first_name} ${p.last_name} ${p.display_name} ${p.team_abbrev}`.toLowerCase(),
    type: 'skater' as const,
  })),
  ...allGoalies.map(g => ({
    display_name: g.name, first_name: g.first_name, last_name: g.last_name,
    team_abbrev: g.team_abbrev, pos: 'G', gp: g.gp ?? 0, slug: g.slug || `goalie-${g.goalie_id}`,
    search_text: `${g.first_name} ${g.last_name} ${g.name} ${g.team_abbrev} goalie g`.toLowerCase(),
    type: 'goalie' as const,
  })),
];

const _playerById = new Map(allPlayers.map(p => [p.player_id, p]));
const topImpact: TopImpactRow[] = loadLeaderboard('game_score').slice(0, 5).map((p) => {
  const full = _playerById.get((p as any).player_id);
  return {
    display_name: full ? `${full.first_name} ${full.last_name}` : ((p as any).display_name ?? ''),
    slug: (p as any).slug ?? '', team_abbrev: (p as any).team_abbrev ?? '',
    pos: (p as any).pos ?? '', gp: (p as any).gp ?? 0, value: (p as any).value ?? 0,
  };
});

const _isDev = import.meta.env.DEV;
---
<Base
  title="Command Center — HockeyGameBot"
  description="Your personalized NHL stats command center. Tonight's games, followed teams, tracked players, and model signals — one screen."
  ogImage="/og/stats.png"
  currentPath={Astro.url.pathname}
>

<style is:global>
  /* ── Masthead (shared logged-in/out) ── */
  .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
    background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 96px 96px; }
  .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
  .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
  .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
  .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
  .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
  .mast-inner { position: relative; z-index: 2; padding: 40px 32px 32px; display: block; }
  .mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--ink-48); display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
  .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; flex-shrink: 0; }
  .mast-user { margin-left: auto; font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.08em; font-weight: 400; text-transform: none; }
  .mast-card { max-width: 900px; margin: 0 auto; background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
  .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(30px,4.5vw,48px);
    text-transform: uppercase; line-height: 1; margin-bottom: 10px; }
  .mast-headline em { color: var(--red); font-style: normal; }
  .mast-sub { font-family: var(--body); font-size: 14px; color: var(--ink-48); margin-bottom: 20px; line-height: 1.5; }
  .mast-search-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-32); margin-bottom: 6px; }
  .mast-mobile-cta { display: none; margin-top: 14px; }
  @media (max-width: 640px) { .mast-mobile-cta { display: block; } }
  .cta-btn { font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 11px 28px; background: var(--ink); color: #EFEEE8; cursor: pointer; border: none; display: inline-block; }
  .cta-btn:hover { background: var(--red); }

  /* ── Cockpit layout ── */
  .cockpit { max-width: 900px; margin: 0 auto; padding: 32px 32px 80px; }
  .cc-section { margin-bottom: 32px; }
  .cc-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 12px; gap: 12px; }
  .cc-title { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--ink-48); padding-bottom: 10px; border-bottom: 1px solid var(--ink-14); flex: 1; }
  .cc-link { font-family: var(--mono); font-size: 9px; letter-spacing: 0.08em; color: var(--ink-32);
    white-space: nowrap; padding-bottom: 10px; border-bottom: 1px solid var(--ink-14); }
  .cc-link:hover { color: var(--red); }
  .cc-idle { padding: 14px 16px; background: var(--surface); border: 1px solid var(--ink-14);
    font-family: var(--body); font-size: 13px; color: var(--ink-48); }

  /* ── Tonight rail ── */
  .cc-rail { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px; }
  .cc-pill { display: block; background: var(--surface); border: 1px solid var(--ink-14); padding: 12px 16px; }
  .cc-pill:hover { border-color: var(--ink-32); }
  .cc-pill-matchup { font-family: var(--display); font-weight: 800; font-size: 18px; text-transform: uppercase; letter-spacing: -0.01em; }
  .cc-pill-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.06em; margin-top: 3px; display: flex; align-items: center; gap: 6px; }
  .cc-live-dot { width: 6px; height: 6px; background: var(--red); border-radius: 50%; display: inline-block; animation: cc-pulse 1.4s ease-in-out infinite; }
  @keyframes cc-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  .cc-pill-bar { display: flex; height: 4px; margin-top: 8px; border-radius: 1px; overflow: hidden; }

  /* ── Your Teams (DashboardTeamCards) ── */
  .team-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .team-cards > .team-card:only-child { grid-column: 1 / -1; }
  .team-card { background: var(--surface); border: 1px solid var(--ink-14); padding: 18px 18px 14px; position: relative; overflow: hidden; border-top: 3px solid var(--ink-14); }
  .team-card[data-color] { border-top-color: var(--team-color, var(--ink-14)); }
  .odds-badge { position: absolute; top: 14px; right: 14px; font-family: var(--mono); font-size: 9px;
    font-weight: 700; letter-spacing: 0.10em; padding: 3px 7px; }
  .odds-badge.high { background: var(--green-bg); color: var(--green); }
  .odds-badge.low  { background: var(--ink-04);   color: var(--ink-48); }
  .odds-badge.eliminated { background: rgba(13,13,20,0.06); color: var(--ink-48); letter-spacing: 0.08em; }
  .team-card-head { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
  .team-logo { width: 40px; height: 40px; object-fit: contain; flex-shrink: 0; }
  .team-abbrev { font-family: var(--display); font-weight: 700; font-size: 18px; letter-spacing: 0.01em; line-height: 1.1; }
  .team-record { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; margin-top: 2px; }
  .team-editorial-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; margin-bottom: 12px; }
  .team-card-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0;
    border-top: 1px solid var(--ink-06); border-bottom: 1px solid var(--ink-06); padding: 10px 0; margin-bottom: 12px; }
  .team-stat { padding: 0 8px; border-right: 1px solid var(--ink-06); }
  .team-stat:first-child { padding-left: 0; }
  .team-stat:last-child  { border-right: none; }
  .team-stat-k { font-family: var(--body); font-size: 10px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink-48); margin-bottom: 4px; }
  .team-stat-v { font-family: var(--mono); font-size: 14px; font-weight: 700; color: var(--ink); }
  .team-card-links { display: flex; gap: 0; justify-content: space-between; }
  .team-card-link { font-family: var(--body); font-size: 11px; font-weight: 600; color: var(--ink-48); padding: 4px 0; }
  .team-card-link::after { content: ' →'; font-weight: 400; }
  .team-card-link:last-child { border-right: none; }
  .team-card-link:hover { color: var(--red); }

  /* ── Odds Mover ── */
  /* Stat-group columns matching the team cards above (label over value);
     the shared grid makes every row's columns self-align. */
  .cc-odds-stack { display: flex; flex-direction: column; background: var(--surface); border: 1px solid var(--ink-14); }
  .cc-odds-row { display: grid; grid-template-columns: 72px 1fr 1fr 1fr; align-items: center; column-gap: 16px; padding: 14px 18px; border-bottom: 1px solid var(--ink-06); }
  .cc-odds-row:last-child { border-bottom: none; }
  .cc-odds-team { font-family: var(--display); font-weight: 800; font-size: 19px; letter-spacing: 0.01em; color: var(--ink); }
  .cc-odds-team:hover { color: var(--red); }
  .cc-odds-cell { min-width: 0; }
  .cc-odds-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.1em; color: var(--ink-48); margin-bottom: 3px; }
  .cc-odds-value { font-family: var(--mono); font-size: 15px; font-weight: 700; color: var(--ink); display: flex; align-items: baseline; gap: 8px; white-space: nowrap; }
  .cc-odds-delta { font-size: 12px; font-weight: 700; }
  .cc-odds-delta.up { color: var(--stats-pos); }
  .cc-odds-delta.down { color: var(--stats-neg); }
  .cc-odds-delta.flat { color: var(--ink-32); font-weight: 400; }
  .cc-odds-first-note { grid-column: 1 / -1; font-family: var(--body); font-size: 10.5px; color: var(--ink-32); margin-top: 4px; }
  @media (max-width: 640px) {
    .cc-odds-row { grid-template-columns: 52px 1fr 1fr 1fr; column-gap: 10px; padding: 12px 12px; }
    .cc-odds-team { font-size: 16px; }
    .cc-odds-value { font-size: 13px; gap: 5px; }
    .cc-odds-delta { font-size: 10.5px; }
  }
  @media (max-width: 640px) {
    .cc-odds-row { align-items: flex-start; }
    .cc-odds-metrics { gap: 2px 6px; font-size: 11px; }
    .cc-odds-sep { display: none; }
    .cc-odds-metric { flex-basis: 100%; }
  }

  /* ── Your Players (dense table) ── */
  .cc-ptable-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .cc-ptable { width: 100%; border-collapse: collapse; min-width: 360px; }
  .cc-ptable thead th { font-family: var(--display); font-weight: 700; font-size: 12px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-48); text-align: right; padding: 8px 14px; border-bottom: 1px solid var(--ink-14); white-space: nowrap; }
  .cc-ptable thead th:first-child { text-align: left; }
  .cc-ptable tbody tr { border-bottom: 1px solid var(--ink-06); cursor: pointer; }
  .cc-ptable tbody tr:last-child { border-bottom: none; }
  .cc-ptable tbody tr:hover td { background: var(--ink-04); }
  .cc-ptable td { padding: 8px 14px; text-align: right; font-family: var(--mono); font-size: 12px; color: var(--ink-72); white-space: nowrap; }
  .cc-ptable th.cc-pct-col, .cc-ptable td.cc-pct-col { text-align: center; }
  .cc-name-cell { text-align: left; font-family: var(--body); font-weight: 600; font-size: 13px; color: var(--ink); }
  /* Two-line name cell on ALL widths (same pattern as iOS): name over team
     chip. Keeps long names from crowding the first stat column. */
  .cc-name-cell a { display: flex; flex-direction: column; align-items: flex-start; color: var(--ink); }
  .cc-name-cell a:hover { color: var(--red); }
  .cc-name-cell .cc-tm { display: block; margin-left: 0; margin-top: 2px; }
  .cc-tm { font-family: var(--mono); font-size: 9px; color: var(--ink-32); font-weight: 700; letter-spacing: 0.06em; margin-left: 8px; }
  .cc-tm-ga { display: none; }
  .cc-players-note { margin-top: 8px; font-family: var(--body); font-size: 11px; color: var(--ink-48); }
  @media (max-width: 640px) {
    .cc-ptable th.cc-ga-col, .cc-ptable td.cc-ga-col { display: none; }
    .cc-tm-ga { display: inline; }
    /* Tighter cells so all four stat columns fit a 390px viewport. */
    .cc-ptable thead th, .cc-ptable td { padding: 8px 6px; }
    .cc-ptable thead th:first-child, .cc-ptable td:first-child { padding-left: 12px; }
    .cc-ptable thead th:last-child, .cc-ptable td:last-child { padding-right: 12px; }
  }
  .cc-ptable th.cc-p-col, .cc-ptable td.cc-p-col { text-align: center; }

  /* ── Top Signals ── */
  .cc-signal-stack { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 10px; }
  .cc-signal { display: block; background: var(--surface); border: 1px solid var(--ink-10); border-left: 6px solid var(--red); padding: 12px 14px; }
  .cc-signal--locked { opacity: 0.6; pointer-events: none; }
  .cc-signal-cat { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--red); opacity: 0.7; margin-bottom: 6px; }
  .cc-signal-body { font-family: var(--body); font-weight: 600; font-size: 12.5px; line-height: 1.5; color: var(--ink-72); }
  .cc-signal-count { margin-top: 8px; font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.08em; text-align: right; }

  /* ── Draft capital (date-gated) ── */
  .cc-draft-stack { display: flex; flex-direction: column; gap: 8px; background: var(--surface); border: 1px solid var(--ink-14); }
  .cc-draft-row { display: flex; align-items: baseline; gap: 10px; padding: 10px 16px; border-bottom: 1px solid var(--ink-06); }
  .cc-draft-row:last-child { border-bottom: none; }
  .cc-draft-overall { font-family: var(--display); font-weight: 800; font-size: 16px; color: var(--ink); min-width: 36px; }
  .cc-draft-team { font-family: var(--body); font-weight: 600; font-size: 13px; flex: 1; }
  .cc-draft-meta { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.05em; }

  /* ── Logged-out teaser ── */
  .lo-cta-bar { background: var(--ink); color: #EFEEE8; padding: 20px 28px; display: flex; align-items: center;
    justify-content: space-between; gap: 20px; flex-wrap: wrap; margin-bottom: 32px; }
  .lo-cta-headline { font-family: var(--display); font-weight: 800; font-size: 20px; text-transform: uppercase; }
  .lo-cta-sub { font-family: var(--body); font-weight: 500; font-size: 10px; color: rgba(239,238,232,0.5); margin-top: 4px; letter-spacing: 0.06em; max-width: 480px; line-height: 1.5; }
  .lo-cta-btn { font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 10px 24px; background: var(--red); color: #fff; white-space: nowrap; }
  .lo-cta-btn:hover { opacity: 0.9; }
  @media (max-width: 640px) { .lo-cta-bar { display: none; } }

  /* ── Visibility ── */
  .view-li { display: block; }
  .view-lo { display: none; }
  body.logged-out .view-li { display: none; }
  body.logged-out .view-lo { display: block; }
  body.logged-out .mast-logged-in  { display: none; }
  body.logged-out .mast-logged-out { display: block; }
  .mast-logged-out { display: none; }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    html, body { overflow-x: hidden; }
    .mast-inner { padding: 24px 16px 24px; }
    .mast-card { padding: 20px 18px 18px; }
    .cockpit { padding: 24px 16px 60px; }
    .cc-rail { grid-template-columns: 1fr; }
    .cc-signal-stack { grid-template-columns: 1fr; }
    .team-cards { grid-template-columns: 1fr; }
    .stats-subnav-inner { padding: 0 16px; max-width: 100%; }
    .stats-subnav a { font-size: 9px; padding: 8px 10px; }
    .subnav-dashboard { font-size: 9px; padding: 8px 12px; }
  }
</style>

<!-- ── LOGGED-IN MAST ── -->
<section class="mast mast-logged-in">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-eyebrow">
      <span class="pip"></span>HGB Stats &middot; Command Center
      <span class="mast-user" id="mast-user-display"></span>
    </div>
    <div class="mast-card">
      <h1 class="mast-headline">Your Hockey <em>Command Center</em></h1>
      <p class="mast-sub">Tonight's games, followed teams, tracked players, and model signals — one screen.</p>
      <div class="mast-search-label">Search any player</div>
      <GlobalPlayerSearch players={playerSearchIndex} client:load />
    </div>
  </div>
</section>

<!-- ── LOGGED-OUT MAST ── -->
<section class="mast mast-logged-out">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-eyebrow"><span class="pip"></span>HGB Stats &middot; Command Center</div>
    <div class="mast-card">
      <h1 class="mast-headline">Build <em>Your Command Center</em></h1>
      <p class="mast-sub">Follow teams and players to get tonight's games, model signals, and trend alerts in one place.</p>
      <div class="mast-search-label">Search any player</div>
      <GlobalPlayerSearch players={playerSearchIndex} client:load />
      <div class="mast-mobile-cta">
        <a href="/account" class="cta-btn">Sign in free →</a>
      </div>
    </div>
  </div>
</section>

<StatsSubnav currentPath={Astro.url.pathname} />

<!-- ═══════════════════════════ LOGGED-IN VIEW ═══════════════════════════ -->
<div class="view-li">
<div class="cockpit">

  <!-- TONIGHT -->
  <div class="cc-section">
    <div class="cc-head"><span class="cc-title">Tonight</span></div>
    <CommandCenterTonight mode="personal" client:load />
  </div>

  <!-- YOUR TEAMS -->
  <div class="cc-section">
    <div class="cc-head">
      <span class="cc-title">Your Teams</span>
      <a href="/account" class="cc-link">Edit follows →</a>
    </div>
    <DashboardTeamCards client:load />
  </div>

  <!-- ODDS MOVER — self-contained section, renders null entirely when the
       /v1/stats/odds-movers feed has no data (pre-first-publish is expected). -->
  <CommandCenterOddsMover client:load />

  <!-- YOUR PLAYERS -->
  <div class="cc-section">
    <div class="cc-head">
      <span class="cc-title">Your Players</span>
      <span class="cc-link" style="cursor:default;">By Impact%</span>
    </div>
    <CommandCenterPlayers client:load />
    <div class="cc-players-note">TALENT% / WAR% / IMPACT% = percentile vs. position group · Talent is multi-season · top 5 by Impact</div>
  </div>

  <!-- TOP SIGNALS -->
  <div class="cc-section">
    <div class="cc-head"><span class="cc-title">Top Signals</span></div>
    <CommandCenterSignals client:load />
  </div>

  <!-- DRAFT CAPITAL — client-side date-gated, see src/lib/draft-capital-window.ts.
       Component owns its own section header and renders null entirely when inactive. -->
  <CommandCenterDraftCapital client:load />

</div><!-- /cockpit -->
</div><!-- /view-li -->

<!-- ═══════════════════════════ LOGGED-OUT VIEW (C-shaped teaser) ═══════════════════════════ -->
<div class="view-lo">
<div class="cockpit">

  <div class="lo-cta-bar">
    <div>
      <div class="lo-cta-headline">Build Your Command Center</div>
      <div class="lo-cta-sub">Follow teams and players to get tonight's games, model signals, and trend alerts in one place.</div>
    </div>
    <a href="/account" class="lo-cta-btn">Sign in free →</a>
  </div>

  <!-- TONIGHT (league-wide, public) -->
  <div class="cc-section">
    <div class="cc-head"><span class="cc-title">Tonight — League</span></div>
    <CommandCenterTonight mode="public" client:load />
  </div>

  <!-- TOP PLAYERS (public leaderboard, stands in for Your Teams/Players) -->
  <div class="cc-section">
    <div class="cc-head"><span class="cc-title">Top Players — HGB Impact</span></div>
    <CommandCenterTopImpact players={topImpact} client:load />
  </div>

  <!-- SIGNALS TEASER -->
  <div class="cc-section">
    <div class="cc-head"><span class="cc-title">Top Signals — Preview</span></div>
    <CommandCenterSignalsPreview client:load />
    <div style="margin-top:12px;">
      <a href="/account" class="cta-btn" style="display:inline-block;font-size:11px;padding:9px 20px;">Personalize your dashboard →</a>
    </div>
  </div>

</div><!-- /cockpit -->
</div><!-- /view-lo -->

<script is:inline define:vars={{ _isDev }}>
  // Determine auth state before paint
  var hasSession = false;
  try { hasSession = !!localStorage.getItem('hgb_session'); } catch(e) {}

  // ?lo=0 / ?lo=1 override: dev builds only. In production _isDev is false,
  // so query-param overrides are silently ignored and no visitor can force
  // the mock logged-in state. ?devprefs=1 (handled inside auth-client.ts)
  // also implies the logged-in view since it only fires in dev builds.
  var isDev = _isDev === true;
  var params = new URLSearchParams(location.search);
  var forceLo = isDev && params.get('lo') === '1';
  var forceIn = isDev && (params.get('lo') === '0' || params.get('devprefs') === '1');

  if (forceLo || (!hasSession && !forceIn)) {
    document.body.classList.add('logged-out');
  }

  // Show user email in mast if available
  if (hasSession && !forceLo) {
    try {
      var el = document.getElementById('mast-user-display');
      var email = localStorage.getItem('hgb_user_email');
      if (el && email) el.textContent = '// ' + email;
    } catch(e) {}
  }

  // Async fallback: localStorage check can miss cookie-based sessions (e.g. Google OAuth
  // on a new device). If we set logged-out but cookies are valid, fix it after load.
  if (!hasSession && !forceLo && !forceIn) {
    fetch('https://api.hockeygamebot.com/v1/auth/me', { credentials: 'include' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        if (!data || !data.user) return;
        document.body.classList.remove('logged-out');
        try {
          var el = document.getElementById('mast-user-display');
          if (el && data.user.email) {
            try { localStorage.setItem('hgb_user_email', data.user.email); } catch(e) {}
            el.textContent = '// ' + data.user.email;
          }
        } catch(e) {}
      })
      .catch(function() {});
  }

  // Validate stale localStorage token — if server rejects it, flip to logged-out view.
  if (hasSession && !forceLo) {
    var _tok = ''; try { _tok = localStorage.getItem('hgb_session') || ''; } catch(e) {}
    fetch('https://api.hockeygamebot.com/v1/auth/me', {
      headers: _tok ? { 'Authorization': 'Bearer ' + _tok } : {},
      credentials: 'include'
    })
      .then(function(r) { return r.ok ? null : 'expired'; })
      .then(function(expired) {
        if (!expired) return;
        try { localStorage.removeItem('hgb_session'); localStorage.removeItem('hgb_user_email'); } catch(e) {}
        document.body.classList.add('logged-out');
      })
      .catch(function() {});
  }
</script>

</Base>
