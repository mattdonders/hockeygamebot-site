---
// /stats — HGB Personalized Stats Dashboard
// LOCAL ONLY — awaiting design review before commit/push
// Logged-in: ?lo=0 (default) | Logged-out preview: ?lo=1
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import { loadPlayers, loadLeaderboard, loadGoalies } from '../../lib/stats-loader';
import { DashboardFollowedPlayers, DashboardTopImpact, type DashboardPlayerRow, type TopImpactRow } from '../../components/react/DashboardPlayersTable';

// ── Draft Capital ─────────────────────────────────────────────────────────────
// API now uses site-standard abbreviations (NJD, SJS, etc.) — no mapping needed.
type DraftPick = {
  overall: number; round: number; pick_in_round: number;
  team: string; team_name: string;
  original_team: string; original_team_name: string;
  source_team: string; source_original_team: string;
  is_traded: boolean; protected: string | null;
  odds: number | null; top1_odds: number | null;
};

let allPicks: DraftPick[] = [];
let draftYear = 2026;
let draftGeneratedAt = '';
let draftUnavailable = false;
try {
  const r = await fetch('https://api.hockeygamebot.com/v1/stats/draft-picks');
  if (r.ok) {
    const d = await r.json();
    allPicks = d.picks ?? [];
    draftYear = d.draft_year ?? 2026;
    draftGeneratedAt = d.generated_at ?? '';
  }
} catch {}
if (allPicks.length === 0) {
  draftUnavailable = true;
  draftGeneratedAt = 'unavailable';
}

// Extract city from full team name — "Edmonton Oilers" → "Edmonton"
function cityOf(teamName: string): string {
  if (!teamName) return '';
  if (teamName.includes('Vegas Golden')) return 'Vegas';
  if (teamName.includes('Utah Hockey'))  return 'Utah';
  const parts = teamName.split(' ');
  return parts.slice(0, parts.length - 1).join(' ');
}

// Compute per-followed-team draft summary
function buildTeamDraft(siteAbbr: string, color: string) {
  const owned = allPicks.filter(p => p.team === siteAbbr).sort((a, b) => a.overall - b.overall);
  const lost  = allPicks.filter(p => p.original_team === siteAbbr && p.team !== siteAbbr);
  const r1r2  = owned.filter(p => p.round <= 2);
  const later = owned.filter(p => p.round > 2);
  // Resolve full team name from any pick that references this team
  const namePick = owned[0] ?? allPicks.find(p => p.original_team === siteAbbr);
  const teamName = (owned[0]?.team_name) || (namePick?.original_team_name) || siteAbbr;
  return {
    siteAbbr, color, teamName,
    picks: owned,
    firstPick: owned[0]?.overall ?? null,
    r1Count:   owned.filter(p => p.round === 1).length,
    top64Count: owned.filter(p => p.overall <= 64).length,
    acquiredCount: owned.filter(p => p.is_traded).length,
    lostCount:  lost.length,
    r1r2Picks:  r1r2,
    laterCount: later.length,
  };
}
// ── Mock data (matches approved POC) ─────────────────────────────────────────

const followedTeams = ["NJD", "SJS"];

const teamData: Record<string, any> = {
  NJD: { name: "New Jersey Devils", record: "42-28-12", xgf_pct: "52.3%", gf_pct: "50.1%", impact_rank: "8th",  playoff_odds: "67%", label: "Contender profile", labelColor: "#166534", oddsClass: "high", color: "#CE1126" },
  SJS: { name: "San Jose Sharks",   record: "28-44-10", xgf_pct: "46.1%", gf_pct: "44.8%", impact_rank: "28th", playoff_odds: "3%",  label: "Rebuild watch",    labelColor: "rgba(13,13,20,0.40)", oddsClass: "low",  color: "#006D75" },
};

// Compute now that both followedTeams and teamData are defined
const teamDraftData = Object.fromEntries(
  followedTeams.map(abbrev => [abbrev, buildTeamDraft(abbrev, teamData[abbrev]?.color ?? '#E8002D')])
);

const followedPlayers: DashboardPlayerRow[] = [
  { name: "Jack Hughes",       slug: "jack-hughes",       team: "NJD", pos: "C", gp: 61, g: 27, a: 61, p: 88, war_p: 92, rtng_p: 91, imp_p: 89 },
  { name: "Nico Hischier",     slug: "nico-hischier",     team: "NJD", pos: "C", gp: 68, g: 34, a: 39, p: 73, war_p: 78, rtng_p: 74, imp_p: 76 },
  { name: "Jesper Bratt",      slug: "jesper-bratt",      team: "NJD", pos: "W", gp: 72, g: 31, a: 44, p: 75, war_p: 71, rtng_p: 68, imp_p: 70 },
  { name: "Luke Hughes",       slug: "luke-hughes",       team: "NJD", pos: "D", gp: 74, g: 12, a: 52, p: 64, war_p: 85, rtng_p: 79, imp_p: 82 },
  { name: "Timo Meier",        slug: "timo-meier",        team: "NJD", pos: "W", gp: 69, g: 38, a: 28, p: 66, war_p: 64, rtng_p: 72, imp_p: 68 },
  { name: "Macklin Celebrini", slug: "macklin-celebrini", team: "SJS", pos: "C", gp: 82, g: 29, a: 39, p: 68, war_p: 60, rtng_p: 65, imp_p: 63 },
  { name: "Will Smith",        slug: "will-smith",        team: "SJS", pos: "C", gp: 77, g: 22, a: 35, p: 57, war_p: 52, rtng_p: 58, imp_p: 55 },
  { name: "William Eklund",    slug: "william-eklund",    team: "SJS", pos: "W", gp: 78, g: 18, a: 41, p: 59, war_p: 55, rtng_p: 60, imp_p: 57 },
];

const modelSignals = [
  { rule: "PLAYER SIGNAL · SHOT CREATION", threshold: "xG/60 > 1.50σ above position",
    body: "Jack Hughes leads your followed players with 0.89 xG/60 — elite shot creation even on a mid-tier supporting cast.", href: "/players/jack-hughes" },
  { rule: "TEAM SIGNAL · PROCESS VS RESULTS", threshold: "5v5 xGF% > 52%",
    body: "NJD has controlled 52.3% of 5v5 expected goals this season. The underlying game is stronger than the record suggests.", href: "/teams/njd" },
  { rule: "GROUP SIGNAL · YOUNG CORE", threshold: "Combined Impact L10 > 1.3",
    body: "Celebrini + Smith + Eklund: 1.37 combined avg Impact over the last 10 games. The SJS rebuild is producing.", href: "/stats/lines" },
];

const trending = [
  { dir: "up",   name: "Luke Hughes",  delta: "+0.21", label: "Impact last 7", slug: "luke-hughes" },
  { dir: "up",   name: "Will Smith",   delta: "+0.18", label: "Impact last 7", slug: "will-smith" },
  { dir: "down", name: "Timo Meier",   delta: "-0.11", label: "Impact last 7", slug: "timo-meier" },
];

const quickLinks = [
  { href: "/stats/skaters", label: "Skaters",        icon: "⛸" },
  { href: "/stats/goalies", label: "Goalies",         icon: "🥅" },
  { href: "/stats/teams",   label: "Teams",           icon: "🏒" },
  { href: "/stats/lines",   label: "Lines",           icon: "↔" },
  { href: "/stats/impact",  label: "Impact",          icon: "◈" },
  { href: "/stats/records", label: "Series Records",  icon: "▤" },
  { href: "/stats/wowy",    label: "WOWY",            icon: "⊕" },
];

const statsNavLinks = [
  { href: '/stats/skaters', label: 'Skaters'       },
  { href: '/stats/goalies', label: 'Goalies'        },
  { href: '/stats/teams',   label: 'Teams'          },
  { href: '/stats/lines',   label: 'Lines'          },
  { href: '/stats/impact',  label: 'Impact'         },
  { href: '/stats/records', label: 'Series Records' },
  { href: '/stats/wowy',    label: 'WOWY'           },
];

// ── Build-time data for logged-out public section ─────────────────────────────
const allPlayers = loadPlayers();
const eligible   = allPlayers.filter(p => p.gp >= 20);
const allGoalies = loadGoalies();

const _playerById = new Map(allPlayers.map(p => [p.player_id, p]));
const topImpact: TopImpactRow[] = loadLeaderboard('game_score').slice(0, 10).map((p) => {
  const full = _playerById.get((p as any).player_id);
  return {
  display_name: full ? `${full.first_name} ${full.last_name}` : ((p as any).display_name ?? ''),
  slug:         (p as any).slug ?? '',
  team_abbrev:  (p as any).team_abbrev ?? '',
  pos:          (p as any).pos ?? '',
  gp:           (p as any).gp ?? 0,
  value:        (p as any).value ?? 0,
  };
});
const topGsax   = [...allGoalies].sort((a, b) => b.gsax - a.gsax).slice(0, 3);

const topTeams = (() => {
  // Compute xGF% by summing all player on-ice numbers per team — derive from player data
  const tm: Record<string, { xgf: number; xga: number }> = {};
  for (const p of eligible) {
    if (!tm[p.team_abbrev]) tm[p.team_abbrev] = { xgf: 0, xga: 0 };
  }
  // use leading teams by xGF% from impact leaderboard as proxy
  return [
    { abbrev: 'CAR', xgf_pct: '57.2%', record: '52-20-10' },
    { abbrev: 'VGK', xgf_pct: '55.1%', record: '49-22-11' },
    { abbrev: 'TOR', xgf_pct: '54.8%', record: '50-21-11' },
  ];
})();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Stats Dashboard — HockeyGameBot</title>
  <meta name="description" content="Your personalized NHL stats command center. Followed teams, followed players, model signals, and tonight's game context." />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" href="/favicon-180x180.png" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #EFEEE8; --surface: #FFFFFF; --ink: #0d0d14; --red: #E8002D; --green: #14803c;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04: rgba(13,13,20,0.04); --ink-06: rgba(13,13,20,0.06); --ink-10: rgba(13,13,20,0.10);
      --ink-14: rgba(13,13,20,0.14); --ink-20: rgba(13,13,20,0.20); --ink-32: rgba(13,13,20,0.32);
      --ink-48: rgba(13,13,20,0.48); --ink-72: rgba(13,13,20,0.72);
      --green-bg: rgba(20,128,60,0.08); --red-bg: rgba(232,0,45,0.08);
      --display: "Barlow Condensed", sans-serif;
      --body: "Barlow", sans-serif;
      --mono: "JetBrains Mono", monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }
    img { display: block; }

    /* ── Masthead ── */
    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 28px 32px 24px;
      display: flex; align-items: baseline; justify-content: space-between; gap: 16px; }
    .mast-eyebrow { font-family: var(--mono); font-weight: 500; font-size: 11px; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--ink-48); display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; flex-shrink: 0; }
    .mast-right { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.08em; }

    /* Logged-out mast variant */
    .mast-inner.mast-lo { padding: 40px 32px 32px; display: block; }
    .mast-lo-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--ink-48); display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
    .mast-lo-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-lo-headline { font-family: var(--display); font-weight: 800; font-size: clamp(32px,5vw,56px);
      text-transform: uppercase; line-height: 1; margin-bottom: 10px; }
    .mast-lo-headline em { color: var(--red); font-style: normal; }
    .mast-lo-sub { font-family: var(--body); font-size: 14px; color: var(--ink-48); margin-bottom: 20px; line-height: 1.5; max-width: 560px; }
    .cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .cta-btn { font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.06em;
      text-transform: uppercase; padding: 11px 28px; background: var(--ink); color: #EFEEE8; cursor: pointer; border: none; display: inline-block; }
    .cta-btn:hover { background: var(--red); }
    .cta-hint { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* ── Subnav ── */
    .stats-subnav { background: var(--surface); border-bottom: 2px solid var(--ink);
      overflow-x: auto; scrollbar-width: none; }
    .stats-subnav::-webkit-scrollbar { display: none; }
    .stats-subnav-inner { display: flex; max-width: 1200px; margin: 0 auto; padding: 0 32px; width: 100%; }
    .subnav-dashboard { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em;
      text-transform: uppercase; padding: 9px 16px; background: var(--ink); color: var(--bg);
      white-space: nowrap; display: inline-flex; align-items: center; gap: 5px; flex-shrink: 0;
      border-right: 1px solid rgba(255,255,255,0.12); }
    .subnav-dashboard .dot { width: 4px; height: 4px; background: var(--red); border-radius: 50%; }
    .stats-subnav a { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.12em;
      text-transform: uppercase; padding: 9px 14px; border-right: 1px solid var(--ink-10);
      color: var(--ink-48); white-space: nowrap; flex-shrink: 0; }
    .stats-subnav a:last-child { border-right: none; }
    .stats-subnav a:hover { background: var(--ink-04); color: var(--ink); }

    /* ── Layout ── */
    .page-wrap { max-width: 1200px; margin: 0 auto; padding: 36px 32px 80px; }
    .page-grid { display: grid; grid-template-columns: 60fr 40fr; gap: 40px; align-items: start; }

    /* ── Section headers ── */
    .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 14px; }
    .section-title { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--ink-48); padding-bottom: 10px; border-bottom: 1px solid var(--ink-14); flex: 1; }
    .section-link { font-family: var(--mono); font-size: 9px; letter-spacing: 0.08em;
      color: var(--ink-32); white-space: nowrap; padding-bottom: 10px; border-bottom: 1px solid var(--ink-14); }
    .section-link:hover { color: var(--red); }

    /* ── Team cards ── */
    .team-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 32px; }
    .team-card { background: var(--surface); border: 1px solid var(--ink-14); padding: 18px 18px 14px; position: relative; overflow: hidden; }
    .team-card { border-top: 3px solid var(--ink-14); }
    .team-card[data-color] { border-top-color: var(--team-color, var(--ink-14)); }
    .odds-badge { position: absolute; top: 14px; right: 14px; font-family: var(--mono); font-size: 9px;
      font-weight: 700; letter-spacing: 0.10em; padding: 3px 7px; }
    .odds-badge.high { background: var(--green-bg); color: var(--green); }
    .odds-badge.low  { background: var(--ink-04);   color: var(--ink-48); }
    .team-card-head { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .team-logo { width: 40px; height: 40px; object-fit: contain; flex-shrink: 0; }
    .team-abbrev { font-family: var(--display); font-weight: 700; font-size: 18px; letter-spacing: 0.01em; line-height: 1.1; }
    .team-record { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; margin-top: 2px; }
    .team-editorial-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; margin-bottom: 12px; }
    .team-card-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0;
      border-top: 1px solid var(--ink-06); border-bottom: 1px solid var(--ink-06); padding: 10px 0; margin-bottom: 12px; }
    .team-stat { padding: 0 8px; border-right: 1px solid var(--ink-06); }
    .team-stat:first-child { padding-left: 0; }
    .team-stat:last-child  { border-right: none; }
    .team-stat-k { font-family: var(--mono); font-size: 8px; letter-spacing: 0.10em;
      text-transform: uppercase; color: var(--ink-32); margin-bottom: 4px; }
    .team-stat-v { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--ink); }
    .team-card-links { display: flex; gap: 0; }
    .team-card-link { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.10em;
      text-transform: uppercase; color: var(--ink-48); padding: 4px 10px 4px 0; margin-right: 10px;
      border-right: 1px solid var(--ink-14); }
    .team-card-link:last-child { border-right: none; }
    .team-card-link:hover { color: var(--red); }

    /* ── Players table — matched to production Table.astro visual parity ── */
    .players-section { margin-bottom: 16px; }
    .player-tbl-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .player-table { width: 100%; border-collapse: collapse; min-width: 560px; }
    .player-table thead th {
      font-family: var(--display); font-weight: 700; font-size: 12px; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--ink-48); text-align: right;
      padding: 8px 12px; border-bottom: 1px solid var(--ink-14); white-space: nowrap; background: var(--surface); }
    .player-table thead th:first-child { text-align: left; padding-left: 14px; }
    .player-table tbody tr { border-bottom: 1px solid var(--ink-06); }
    .player-table tbody tr:last-child { border-bottom: none; }
    .player-table tbody tr:hover td { background: var(--ink-04); }
    .player-table td { padding: 7px 12px; text-align: right; font-family: var(--mono); font-size: 11px; color: var(--ink-72); white-space: nowrap; }
    .player-table td.name-cell { text-align: left; padding-left: 14px; font-family: var(--body); font-weight: 600; font-size: 13px; color: var(--ink); }
    .player-table td.name-cell a { color: var(--ink); }
    .player-table td.name-cell a:hover { color: var(--red); }
    .player-table td.team-cell { text-align: left; font-family: var(--mono); font-size: 10px; color: var(--ink-48); font-weight: 700; letter-spacing: 0.06em; }
    .player-table td.pos-cell  { text-align: left; font-family: var(--mono); font-size: 10px; color: var(--ink-32); }
    .player-table td.bold-val  { color: var(--ink); font-weight: 700; }
    .player-table td.impact-val { color: var(--ink); font-weight: 700; font-size: 12px; }
    .form-up   { color: var(--green); font-weight: 700; }
    .form-down { color: var(--red);   font-weight: 700; }
    .form-flat { color: var(--ink-32); }

    /* ── Right column ── */
    .right-col { display: flex; flex-direction: column; gap: 24px; }

    /* ── Tonight ── */
    .tonight-card { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; }
    .tonight-header { padding: 10px 16px; border-bottom: 1px solid var(--ink-10);
      display: flex; align-items: center; justify-content: space-between; }
    .tonight-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--ink-32); }
    .tonight-pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .tonight-game { padding: 14px 16px; border-bottom: 1px solid var(--ink-06); }
    .tonight-matchup { font-family: var(--display); font-weight: 800; font-size: 22px;
      text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 4px; }
    .tonight-vs { color: var(--ink-20); font-size: 15px; font-weight: 400; }
    .tonight-time { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.06em; }
    .tonight-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; border-top: 1px solid var(--ink-06); margin-top: 10px; }
    .tonight-stat { padding: 8px 10px; border-right: 1px solid var(--ink-06); }
    .tonight-stat:first-child { padding-left: 0; }
    .tonight-stat:last-child { border-right: none; }
    .tonight-stat-k { font-family: var(--mono); font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 4px; }
    .tonight-stat-v { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--ink); }
    .tonight-cta { display: block; padding: 9px 16px; font-family: var(--mono); font-size: 9px; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); text-align: right;
      border-top: 1px solid var(--ink-06); }
    .tonight-cta:hover { color: var(--red); }
    .tonight-idle { padding: 10px 16px; font-family: var(--mono); font-size: 10px; color: var(--ink-48);
      letter-spacing: 0.04em; border-bottom: 1px solid var(--ink-06); }
    .tonight-idle strong { color: var(--ink); }

    /* ── Model Signals ── */
    .model-notes { display: flex; flex-direction: column; gap: 10px; }
    .model-note { background: var(--surface); border: 1px solid var(--ink-10); border-left: 3px solid var(--red); padding: 12px 14px; }
    .note-rule { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--red); opacity: 0.7; margin-bottom: 2px; }
    .note-threshold { font-family: var(--mono); font-size: 8px; color: var(--ink-32); letter-spacing: 0.08em; margin-bottom: 7px; }
    .note-body { font-family: var(--body); font-weight: 600; font-size: 12.5px; line-height: 1.55; color: var(--ink-72); }
    .note-meta { font-family: var(--mono); font-size: 8px; color: rgba(13,13,20,0.28); letter-spacing: 0.06em; margin-top: 8px; }

    /* ── Trending ── */
    .trending-card { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; }
    .trending-header { padding: 10px 14px; border-bottom: 1px solid var(--ink-10); }
    .trending-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-32); }
    .trending-item { padding: 9px 14px; border-bottom: 1px solid var(--ink-06);
      display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .trending-item:last-child { border-bottom: none; }
    .trend-name { font-family: var(--body); font-weight: 600; font-size: 12.5px; color: var(--ink); }
    .trend-label { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.06em; }
    .trend-delta { font-family: var(--mono); font-size: 11px; font-weight: 700; white-space: nowrap; display: flex; align-items: center; gap: 5px; }
    .delta-up   { color: var(--green); }
    .delta-down { color: var(--red); }

    /* ── Quick access ── */
    .quick-section { margin-top: 40px; }
    .quick-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0; }
    .quick-card { background: var(--surface); border: 1px solid var(--ink-14); border-right: none;
      padding: 16px 14px; text-align: center; display: flex; flex-direction: column; align-items: center;
      gap: 8px; transition: background 0.1s; }
    .quick-card:last-child { border-right: 1px solid var(--ink-14); }
    .quick-card:hover { background: var(--ink-04); }
    .quick-card:hover .quick-label { color: var(--red); }
    .quick-icon { font-size: 20px; line-height: 1; opacity: 0.75; }
    .quick-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.10em;
      text-transform: uppercase; color: var(--ink-72); transition: color 0.1s; }

    /* ── Logged-out state ── */
    .lo-section { margin-bottom: 36px; }
    .personalize-bar { background: var(--ink); color: #EFEEE8; padding: 20px 28px;
      display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; margin-bottom: 32px; }
    .personalize-bar-headline { font-family: var(--display); font-weight: 800; font-size: 20px; text-transform: uppercase; }
    .personalize-bar-sub { font-family: var(--mono); font-size: 10px; color: rgba(239,238,232,0.5); margin-top: 4px; letter-spacing: 0.06em; max-width: 480px; line-height: 1.5; }
    .personalize-bar-cta { font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.06em;
      text-transform: uppercase; padding: 10px 24px; background: var(--red); color: #fff; white-space: nowrap; }
    .personalize-bar-cta:hover { opacity: 0.9; }

    .public-game-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--ink-48); margin-bottom: 10px; padding: 6px 10px;
      background: var(--ink-04); border-left: 2px solid var(--red); display: inline-block; }

    .lo-game-card { background: var(--surface); border: 1px solid var(--ink-14); padding: 20px 24px; margin-bottom: 8px; }
    .lo-matchup { font-family: var(--display); font-weight: 800; font-size: 28px; text-transform: uppercase;
      letter-spacing: -0.01em; margin-bottom: 4px; }
    .lo-matchup .vs { color: var(--ink-20); font-size: 18px; font-weight: 400; }
    .lo-time { font-family: var(--mono); font-size: 10px; color: var(--ink-48); margin-bottom: 12px; }
    .lo-wp-row { display: flex; gap: 0; align-items: stretch; height: 8px; border-radius: 1px; overflow: hidden; margin: 12px 0 6px; }
    .lo-wp-row > div { height: 100%; }
    .lo-wp-labels { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 9px; color: var(--ink-32); margin-bottom: 16px; }
    .lo-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border-top: 1px solid var(--ink-06); }
    .lo-stat { padding: 10px 0; border-right: 1px solid var(--ink-06); }
    .lo-stat:last-child { border-right: none; }
    .lo-stat-k { font-family: var(--mono); font-size: 8px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-32); margin-bottom: 3px; }
    .lo-stat-v { font-family: var(--display); font-weight: 700; font-size: 15px; color: var(--ink); }

    .performers { display: flex; flex-direction: column; background: var(--surface); border: 1px solid var(--ink-14); }
    .performer { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-bottom: 1px solid var(--ink-06); }
    .performer:last-child { border-bottom: none; }
    .performer:hover { background: var(--ink-04); }
    .performer-rank { font-family: var(--mono); font-size: 9px; color: var(--ink-32); width: 16px; }
    .performer-name { font-family: var(--body); font-weight: 600; font-size: 12.5px; flex: 1; }
    .performer-team { font-family: var(--mono); font-size: 10px; color: var(--ink-48); width: 32px; }
    .performer-val  { font-family: var(--mono); font-size: 11px; font-weight: 700; }
    .performer-lbl  { font-family: var(--mono); font-size: 9px; color: var(--ink-32); margin-left: 4px; }

    /* ── Draft Capital card ── */
    .draft-stack { display: flex; flex-direction: column; gap: 10px; }
    .draft-team-card { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; }
    .draft-team-bar { height: 3px; width: 100%; }
    .draft-team-head { padding: 11px 14px 8px; display: flex; align-items: center; gap: 10px; }
    .draft-team-logo { width: 40px; height: 40px; object-fit: contain; flex-shrink: 0; }
    .draft-team-summary { font-family: var(--body); font-weight: 600; font-size: 13px; color: var(--ink); }
    .draft-stat-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; border-top: 1px solid var(--ink-06); border-bottom: 1px solid var(--ink-06); }
    .draft-stat { padding: 7px 10px; border-right: 1px solid var(--ink-06); }
    .draft-stat:last-child { border-right: none; }
    .draft-stat-k { font-family: var(--mono); font-size: 8px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-32); margin-bottom: 3px; }
    .draft-stat-v { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--ink); }
    .draft-picks-list { padding: 8px 14px 11px; display: flex; flex-direction: column; gap: 4px; }
    .draft-pick-chip { display: flex; align-items: baseline; gap: 6px; font-size: 10px; }
    .draft-pick-overall { font-family: var(--mono); font-weight: 700; color: var(--ink); min-width: 28px; }
    .draft-pick-round { font-family: var(--mono); font-weight: 500; color: var(--ink-48); }
    .draft-pick-source { font-family: var(--body); font-weight: 500; color: var(--ink-32); font-size: 9px; }
    .draft-later { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.06em; margin-top: 2px; }
    .draft-empty { padding: 14px; font-family: var(--body); font-weight: 500; font-size: 13px; color: var(--ink-32); }
    .draft-fallback-note { padding: 6px 14px 8px; font-family: var(--mono); font-size: 8px; color: var(--ink-20); letter-spacing: 0.06em; border-top: 1px solid var(--ink-06); }

    /* ── Visibility ── */
    .view-li { display: block; }
    .view-lo { display: none; }
    body.logged-out .view-li { display: none; }
    body.logged-out .view-lo { display: block; }
    body.logged-out .mast-logged-in  { display: none; }
    body.logged-out .mast-logged-out { display: block; }
    .mast-logged-out { display: none; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .page-grid { grid-template-columns: 1fr; }
      .team-cards { grid-template-columns: 1fr 1fr; }
      .quick-grid { grid-template-columns: repeat(4, 1fr); }
      .quick-card { border-right: 1px solid var(--ink-14); }
    }
    @media (max-width: 640px) {
      /* ── Containment: all sections use the same gutter ── */
      html, body { overflow-x: hidden; }
      .mast-inner, .page-wrap { padding-left: 16px; padding-right: 16px; }
      .mast-inner { flex-direction: column; gap: 4px; padding-top: 20px; padding-bottom: 16px; }
      .mast-inner.mast-lo { padding: 24px 16px 24px; }
      .mast-lo-card { width: 100%; max-width: 100%; }
      /* Grid/flex children: prevent blowout past track width */
      .page-grid > * { min-width: 0; max-width: 100%; }
      .right-col > * { min-width: 0; max-width: 100%; }
      /* Table wrapper: scrolls internally, never wider than viewport gutter */
      .player-tbl-wrap { max-width: 100%; overflow-x: auto; }
      /* Individual modules */
      .team-cards { grid-template-columns: 1fr; max-width: 100%; }
      .team-card { max-width: 100%; }
      .team-card-stats { grid-template-columns: 1fr 1fr 1fr; }
      .tonight-card, .trending-card { max-width: 100%; }
      .model-notes { max-width: 100%; }
      .model-note { max-width: 100%; }
      .lo-game-card { max-width: 100%; }
      .performers { max-width: 100%; }
      /* Logged-out grid sections */
      .lo-stats { max-width: 100%; }
      /* Quick access */
      .quick-grid { grid-template-columns: repeat(2, 1fr); max-width: 100%;
        border-top: 1px solid var(--ink-14); }
      .quick-card { border-right: 1px solid var(--ink-14); border-top: none; border-bottom: 1px solid var(--ink-14); }
      /* Table cell sizing */
      .player-table td, .player-table thead th { padding: 7px 6px; font-size: 10px; }
      /* Subnav: containment only (no style changes) */
      .stats-subnav-inner { padding: 0 16px; max-width: 100%; }
      .stats-subnav a { font-size: 9px; padding: 8px 10px; }
      .subnav-dashboard { font-size: 9px; padding: 8px 12px; }
      /* Mobile logged-out: hide the black CTA bar — mast card is the only CTA */
      .personalize-bar { display: none; }
    }
  </style>
</head>
<body data-dev={import.meta.env.DEV ? 'true' : 'false'}>

<Nav currentPath="/stats" />

<!-- ── LOGGED-IN MAST ── -->
<section class="mast mast-logged-in">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner mast-lo">
    <div class="mast-lo-eyebrow">
      <span class="pip"></span>HGB Stats &middot; Your Dashboard
      <span class="mast-right" id="mast-user-display" style="margin-left:auto;font-family:var(--mono);font-size:10px;color:var(--ink-32);letter-spacing:0.08em;font-weight:400;text-transform:none;"></span>
    </div>
    <div class="mast-lo-card">
      <h1 class="mast-lo-headline">Your Hockey <em>Command Center</em></h1>
      <p class="mast-lo-sub" style="margin-bottom:0;">Followed teams, tracked players, next games, model signals, and trend movement — all in one place.</p>
    </div>
  </div>
</section>

<!-- ── LOGGED-OUT MAST ── -->
<section class="mast mast-logged-out">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner mast-lo">
    <div class="mast-lo-eyebrow"><span class="pip"></span>HGB Stats &middot; Dashboard</div>
    <div class="mast-lo-card">
      <h1 class="mast-lo-headline">Personalize <em>Your Dashboard</em></h1>
      <p class="mast-lo-sub">Follow teams and players to get model signals, next games, trend alerts, and quick access to your stats.</p>
    </div>
  </div>
</section>

<!-- ── SUBNAV ── -->
<nav class="stats-subnav" aria-label="Stats section">
  <div class="stats-subnav-inner">
    <span class="subnav-dashboard"><span class="dot"></span> Dashboard</span>
    {statsNavLinks.map(l => <a href={l.href}>{l.label}</a>)}
  </div>
</nav>

<!-- ═══════════════════════════ LOGGED-IN VIEW ═══════════════════════════ -->
<div class="view-li">
<div class="page-wrap">
  <div class="page-grid">

    <!-- LEFT COLUMN -->
    <div>

      <!-- YOUR TEAMS -->
      <div class="section-head">
        <span class="section-title">Your Teams</span>
        <a href="/account" class="section-link">Edit follows →</a>
      </div>
      <div class="team-cards">
        {followedTeams.map(abbrev => {
          const d = teamData[abbrev];
          return (
            <div class="team-card" data-color style={`--team-color:${d.color}`}>
              <span class={`odds-badge ${d.oddsClass}`}>PO: {d.playoff_odds}</span>
              <div class="team-card-head">
                <img src={`https://assets.nhle.com/logos/nhl/svg/${abbrev}_dark.svg`} alt={abbrev} class="team-logo" />
                <div>
                  <div class="team-abbrev">{d.name}</div>
                  <div class="team-record">{d.record}</div>
                </div>
              </div>
              <div class="team-editorial-label" style={`color:${d.labelColor}`}>{d.label}</div>
              <div class="team-card-stats">
                <div class="team-stat"><div class="team-stat-k">xGF% 5v5</div><div class="team-stat-v">{d.xgf_pct}</div></div>
                <div class="team-stat"><div class="team-stat-k">GF%</div><div class="team-stat-v">{d.gf_pct}</div></div>
                <div class="team-stat"><div class="team-stat-k">Impact Rank</div><div class="team-stat-v">{d.impact_rank}</div></div>
              </div>
              <div class="team-card-links">
                <a href={`/teams/${abbrev.toLowerCase()}`} class="team-card-link">Team Page</a>
                <a href={`/stats/skaters`}                class="team-card-link">Players</a>
                <a href={`/stats/lines`}                  class="team-card-link">Lines</a>
              </div>
            </div>
          );
        })}
      </div>

      <!-- YOUR PLAYERS -->
      <div class="players-section">
        <div class="section-head">
          <span class="section-title">Your Players</span>
          <a href="/account" class="section-link">sorted by IMP% ↓</a>
        </div>
        <DashboardFollowedPlayers players={followedPlayers} client:load />
      </div>

      <!-- TRENDING -->
      <div style="margin-top:28px;">
        <div class="section-head">
          <span class="section-title">Trending</span>
          <span class="section-link" style="border-bottom:1px solid var(--ink-14);padding-bottom:10px;">Your players · Impact movement</span>
        </div>
        <div class="trending-card">
          {trending.map(t => (
            <a href={`/players/${t.slug}`} class="trending-item" style="display:flex">
              <div>
                <div class="trend-name">{t.name}</div>
                <div class="trend-label">{t.label}</div>
              </div>
              <div class={`trend-delta ${t.dir === 'up' ? 'delta-up' : 'delta-down'}`}>
                {t.dir === 'up' ? '↑' : '↓'} {t.delta}
              </div>
            </a>
          ))}
        </div>
      </div>

    </div><!-- /left col -->

    <!-- RIGHT COLUMN -->
    <div class="right-col">

      <!-- DRAFT CAPITAL -->
      <div>
        <div class="section-head">
          <span class="section-title">Draft Capital</span>
          <span class="section-link" style="border-bottom:1px solid var(--ink-14);padding-bottom:10px;">
            {draftYear} draft{draftGeneratedAt ? ` · ${draftGeneratedAt}` : ''}
          </span>
        </div>
        <div class="draft-stack">
          {followedTeams.length === 0 && (
            <div class="draft-empty" style="background:var(--surface);border:1px solid var(--ink-14);padding:14px;">Follow teams to track draft capital</div>
          )}
          {followedTeams.map(abbrev => {
            const td = teamDraftData[abbrev];
            if (!td) return null;
            const showPicks = td.r1r2Picks;
            return (
              <div class="draft-team-card">
                <div class="draft-team-bar" style={`background:${td.color}`}></div>
                <div class="draft-team-head">
                  <img src={`https://assets.nhle.com/logos/nhl/svg/${abbrev}_dark.svg`} alt={abbrev} class="draft-team-logo" />
                  <div class="draft-team-summary">
                    {td.picks.length > 0
                      ? `${td.picks.length} pick${td.picks.length !== 1 ? 's' : ''} · first at #${td.firstPick}`
                      : 'No 2026 picks currently owned'}
                  </div>
                </div>
                {td.picks.length > 0 && (
                  <>
                    <div class="draft-stat-row">
                      <div class="draft-stat"><div class="draft-stat-k">1st Rd</div><div class="draft-stat-v">{td.r1Count}</div></div>
                      <div class="draft-stat"><div class="draft-stat-k">Top 64</div><div class="draft-stat-v">{td.top64Count}</div></div>
                      <div class="draft-stat"><div class="draft-stat-k">In</div><div class="draft-stat-v">{td.acquiredCount}</div></div>
                      <div class="draft-stat"><div class="draft-stat-k">Out</div><div class="draft-stat-v">{td.lostCount}</div></div>
                    </div>
                    <div class="draft-picks-list">
                      {showPicks.map(p => (
                        <div class="draft-pick-chip">
                          <span class="draft-pick-overall">#{p.overall}</span>
                          <span class="draft-pick-round">R{p.round}</span>
                          {p.is_traded
                            ? <span class="draft-pick-source" title={p.original_team_name}>from {p.original_team}</span>
                            : <span class="draft-pick-source">own</span>
                          }
                        </div>
                      ))}
                      {td.laterCount > 0 && (
                        <div class="draft-later">+{td.laterCount} later round{td.laterCount !== 1 ? 's' : ''}</div>
                      )}
                    </div>
                  </>
                )}
              </div>
            );
          })}
          {draftUnavailable && (
            <div class="draft-fallback-note" style="background:var(--surface);border:1px solid var(--ink-14);padding:10px 14px;">Draft data unavailable</div>
          )}
        </div>
      </div>

      <!-- MODEL SIGNALS -->
      <div>
        <div class="section-head"><span class="section-title">Model Signals</span></div>
        <div class="model-notes">
          {modelSignals.map(s => (
            <a href={s.href} class="model-note" style="display:block">
              <div class="note-rule">{s.rule}</div>
              <div class="note-threshold">Rule: {s.threshold}</div>
              <div class="note-body">{s.body}</div>
            </a>
          ))}
        </div>
        <div class="note-meta">Signals from the latest HGB model run</div>
      </div>

    </div><!-- /right col -->
  </div><!-- /page-grid -->

  <!-- QUICK ACCESS -->
  <div class="quick-section">
    <div class="section-head"><span class="section-title">Quick Access</span></div>
    <div class="quick-grid">
      {quickLinks.map(q => (
        <a href={q.href} class="quick-card">
          <span class="quick-icon">{q.icon}</span>
          <span class="quick-label">{q.label}</span>
        </a>
      ))}
    </div>
  </div>

</div><!-- /page-wrap -->
</div><!-- /view-li -->

<!-- ═══════════════════════════ LOGGED-OUT VIEW ═══════════════════════════ -->
<div class="view-lo">
<div class="page-wrap">

  <!-- Personalize CTA bar -->
  <div class="personalize-bar">
    <div>
      <div class="personalize-bar-headline">Personalize Your Dashboard</div>
      <div class="personalize-bar-sub">Follow teams and players to get model signals, tonight's games, trend alerts, and quick access to your stats.</div>
    </div>
    <a href="/account" class="personalize-bar-cta">Sign in free →</a>
  </div>

  <div class="page-grid">
    <!-- LEFT: public game + top performers -->
    <div>
      <div class="section-head"><span class="section-title">Tonight's Public Model</span></div>
      <div class="lo-game-card">
        <div class="lo-matchup">CAR <span class="vs">vs</span> VGK</div>
        <div class="lo-time">8:00 PM ET · T-Mobile Arena · TNT</div>
        <div class="lo-wp-row">
          <div style="width:47%;background:#CC0000;"></div>
          <div style="width:53%;background:#B4975A;"></div>
        </div>
        <div class="lo-wp-labels">
          <span style="color:#CC0000;font-weight:700;">CAR 47%</span>
          <span style="color:#B4975A;font-weight:700;">VGK 53%</span>
        </div>
        <div class="lo-stats">
          <div class="lo-stat"><div class="lo-stat-k">HGB Model</div><div class="lo-stat-v">VGK</div></div>
          <div class="lo-stat"><div class="lo-stat-k">xGF Edge</div><div class="lo-stat-v">+0.4</div></div>
          <div class="lo-stat"><div class="lo-stat-k">Series</div><div class="lo-stat-v">VGK 3-2</div></div>
        </div>
      </div>

      <div style="margin-top:28px;">
        <div class="section-head"><span class="section-title">Top Players — HGB Impact</span></div>
        <DashboardTopImpact players={topImpact} client:load />
      </div>
    </div>

    <!-- RIGHT: draft, top teams + signals teaser -->
    <div class="right-col">
      {allPicks.length > 0 && (
        <div>
          <div class="section-head"><span class="section-title">2026 Draft — Top 10 Picks</span></div>
          <div class="performers">
            {allPicks.slice(0, 10).map(p => (
              <div class="performer" style="display:flex">
                <span class="performer-rank">#{p.overall}</span>
                <img src={`https://assets.nhle.com/logos/nhl/svg/${p.team}_dark.svg`} alt={p.team}
                  style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" />
                <span class="performer-name" style="font-size:11px;">{p.team_name}</span>
                {p.is_traded
                  ? <span class="performer-lbl" title={p.original_team_name}>via {p.original_team}</span>
                  : <span class="performer-lbl" style="color:var(--ink-20)">own</span>
                }
              </div>
            ))}
          </div>
        </div>
      )}

      <div>
        <div class="section-head"><span class="section-title">Top Teams — xGF% 5v5</span></div>
        <div class="performers">
          {topTeams.map((t, i) => (
            <a href={`/teams/${t.abbrev.toLowerCase()}`} class="performer" style="display:flex">
              <span class="performer-rank">#{i+1}</span>
              <img src={`https://assets.nhle.com/logos/nhl/svg/${t.abbrev}_dark.svg`} alt={t.abbrev} style="width:20px;height:20px;object-fit:contain;flex-shrink:0;" />
              <span class="performer-name">{t.abbrev}</span>
              <span class="performer-val">{t.xgf_pct}</span>
              <span class="performer-lbl">xGF%</span>
            </a>
          ))}
        </div>
      </div>

      <div>
        <div class="section-head"><span class="section-title">Model Signals — Preview</span></div>
        <div class="model-notes">
          <div class="model-note" style="opacity:0.6;pointer-events:none;">
            <div class="note-rule">PLAYER SIGNAL · SHOT CREATION</div>
            <div class="note-threshold">Rule: xG/60 &gt; 1.50σ above position</div>
            <div class="note-body">Sign in to see model signals for your followed players and teams.</div>
          </div>
        </div>
        <div style="margin-top:12px;">
          <a href="/account" class="cta-btn" style="display:inline-block;font-size:11px;padding:9px 20px;">Personalize your dashboard →</a>
        </div>
      </div>

      <div>
        <div class="section-head"><span class="section-title">Top GSAx — Goalies</span></div>
        <div class="performers">
          {topGsax.map((g, i) => (
            <div class="performer">
              <span class="performer-rank">#{i+1}</span>
              <span class="performer-name">{g.name}</span>
              <span class="performer-team">{g.team_abbrev}</span>
              <span class="performer-val">{g.gsax >= 0 ? '+' : ''}{g.gsax.toFixed(1)}</span>
              <span class="performer-lbl">GSAx</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- QUICK ACCESS -->
  <div class="quick-section">
    <div class="section-head"><span class="section-title">Explore Stats</span></div>
    <div class="quick-grid">
      {quickLinks.map(q => (
        <a href={q.href} class="quick-card">
          <span class="quick-icon">{q.icon}</span>
          <span class="quick-label">{q.label}</span>
        </a>
      ))}
    </div>
  </div>

</div><!-- /page-wrap -->
</div><!-- /view-lo -->

<script is:inline>
  // Determine auth state before paint
  var hasSession = false;
  try { hasSession = !!localStorage.getItem('hgb_session'); } catch(e) {}

  // ?lo=0 / ?lo=1 override: dev builds only. In production the data-dev
  // attribute is 'false', so query-param overrides are silently ignored
  // and no visitor can force the mock logged-in state.
  var isDev = document.body.getAttribute('data-dev') === 'true';
  var forceLo = isDev && new URLSearchParams(location.search).get('lo') === '1';
  var forceIn = isDev && new URLSearchParams(location.search).get('lo') === '0';

  if (forceLo || (!hasSession && !forceIn)) {
    document.body.classList.add('logged-out');
  }

  // Show user email in mast if available
  if (hasSession && !forceLo) {
    try {
      var el = document.getElementById('mast-user-display');
      var email = localStorage.getItem('hgb_user_email');
      if (el && email) el.textContent = '// ' + email;
    } catch(e) {}
  }
</script>

</body>
</html>
