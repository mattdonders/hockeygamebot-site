<script is:inline>
(function() {
  var API = 'https://api.hockeygamebot.com';
  var token = null;
  try { token = localStorage.getItem('hgb_session'); } catch(e) {}
  if (!token) return; // cookie-only session path handled separately

  var TEAM_COLORS = {
    'ANA':'#FC4C02','BOS':'#FFB81C','BUF':'#003087','CGY':'#C8102E','CAR':'#CC0000',
    'CHI':'#CF0A2C','COL':'#6F263D','CBJ':'#002654','DAL':'#006847','DET':'#CE1126',
    'EDM':'#FF4C00','FLA':'#C8102E','LAK':'#A2AAAD','MIN':'#154734','MTL':'#AF1E2D',
    'NSH':'#FFB81C','NJD':'#CE1126','NYI':'#F47D30','NYR':'#0038A8','OTT':'#C8102E',
    'PHI':'#F74902','PIT':'#FCB514','SJS':'#006D75','SEA':'#99D9D9','STL':'#002F87',
    'TBL':'#002868','TOR':'#00205B','UTA':'#6CACE4','VAN':'#00843D','VGK':'#B4975A',
    'WSH':'#C8102E','WPG':'#004C97','ARI':'#8C2633'
  };
  var TEAM_NAMES = {
    'ANA':'Ducks','BOS':'Bruins','BUF':'Sabres','CGY':'Flames','CAR':'Hurricanes',
    'CHI':'Blackhawks','COL':'Avalanche','CBJ':'Blue Jackets','DAL':'Stars','DET':'Red Wings',
    'EDM':'Oilers','FLA':'Panthers','LAK':'Kings','MIN':'Wild','MTL':'Canadiens',
    'NSH':'Predators','NJD':'Devils','NYI':'Islanders','NYR':'Rangers','OTT':'Senators',
    'PHI':'Flyers','PIT':'Penguins','SJS':'Sharks','SEA':'Kraken','STL':'Blues',
    'TBL':'Lightning','TOR':'Maple Leafs','UTA':'Utah HC','VAN':'Canucks','VGK':'Golden Knights',
    'WSH':'Capitals','WPG':'Jets','ARI':'Coyotes'
  };

  function tc(a) { return TEAM_COLORS[a] || '#E8002D'; }

  function computeWarPct(allPlayers, player) {
    var grp = player.pos_group;
    var peers = allPlayers.filter(function(p) { return p.pos_group === grp && p.war != null; });
    peers.sort(function(a, b) { return a.war - b.war; });
    var idx = peers.findIndex(function(p) { return p.player_id === player.player_id; });
    if (idx < 0 || peers.length < 2) return null;
    return Math.round((idx / (peers.length - 1)) * 100);
  }

  function getCurrentTeamStats(teamsData, abbrev) {
    return (teamsData.regular || []).find(function(t) {
      return t.team_abbrev === abbrev && t.season === '2025-26';
    }) || null;
  }

  function computeImpactRank(teamsData, abbrev) {
    var current = (teamsData.regular || []).filter(function(t) { return t.season === '2025-26'; });
    current.sort(function(a, b) { return b.xgf_pct_5v5 - a.xgf_pct_5v5; });
    var idx = current.findIndex(function(t) { return t.team_abbrev === abbrev; });
    return idx >= 0 ? idx + 1 : null;
  }

  function teamLabel(rank) {
    if (!rank) return { text: '—', color: 'rgba(13,13,20,0.40)' };
    if (rank <= 8)  return { text: 'Contender Profile', color: '#166534' };
    if (rank <= 16) return { text: 'Playoff Fringe',    color: '#92400e' };
    if (rank <= 24) return { text: 'Rebuild Watch',     color: 'rgba(13,13,20,0.40)' };
    return              { text: 'Full Rebuild',         color: 'rgba(13,13,20,0.40)' };
  }

  function ordinal(n) { return n + (n===1?'st':n===2?'nd':n===3?'rd':'th'); }

  function renderTeamCard(abbrev, stats, rank, playoffActive, playoffOdds) {
    var color = tc(abbrev);
    var record = stats ? stats.wins + '-' + stats.losses + '-' + stats.ot_losses : '—';
    var xgf = stats ? (stats.xgf_pct_5v5 * 100).toFixed(1) + '%' : '—';
    var gf  = stats ? (stats.gf_pct_5v5  * 100).toFixed(1) + '%' : '—';
    var lbl = teamLabel(rank);
    var rankStr = rank ? ordinal(rank) : '—';
    var isActive = playoffActive && playoffActive.indexOf(abbrev) >= 0;
    var odds = playoffOdds && playoffOdds[abbrev] != null ? Math.round(playoffOdds[abbrev] * 100) : null;
    var badge = isActive && odds != null
      ? '<span class="odds-badge ' + (odds > 50 ? 'high' : 'low') + '">PO: ' + odds + '%</span>'
      : '<span class="odds-badge eliminated">ELIM</span>';
    var fullName = (abbrev === 'UTA' ? 'Utah Hockey Club' : (abbrev + ' ' + (TEAM_NAMES[abbrev] || '')));
    return '<div class="team-card" data-color style="--team-color:' + color + '">' +
      badge +
      '<div class="team-editorial-label" style="color:' + lbl.color + ';margin-bottom:8px;">' + lbl.text + '</div>' +
      '<div class="team-card-head">' +
        '<img src="https://assets.nhle.com/logos/nhl/svg/' + abbrev + '_light.svg" alt="' + abbrev + '" class="team-logo" style="width:52px;height:52px;" />' +
        '<div><div class="team-abbrev">' + fullName + '</div><div class="team-record">' + record + '</div></div>' +
      '</div>' +
      '<div class="team-card-stats">' +
        '<div class="team-stat"><div class="team-stat-k">xGF% 5v5</div><div class="team-stat-v">' + xgf + '</div></div>' +
        '<div class="team-stat"><div class="team-stat-k">GF%</div><div class="team-stat-v">' + gf + '</div></div>' +
        '<div class="team-stat"><div class="team-stat-k">Impact Rank</div><div class="team-stat-v">' + rankStr + '</div></div>' +
      '</div>' +
      '<div class="team-card-links">' +
        '<a href="/teams/' + abbrev.toLowerCase() + '" class="team-card-link">Team Page</a>' +
        '<a href="/stats/skaters" class="team-card-link">Players</a>' +
        '<a href="/stats/lines" class="team-card-link">Lines</a>' +
      '</div>' +
    '</div>';
  }

  function pctColor(v) {
    if (v == null) return 'rgba(13,13,20,0.32)';
    if (v >= 75) return '#166534';
    if (v <= 35) return '#991b1b';
    return 'rgba(13,13,20,0.72)';
  }

  function renderPlayerTable(players, allPlayers) {
    if (!players.length) return '<div style="color:var(--ink-48);font-size:13px;padding:12px 0;">No players followed. <a href="/account">Add players →</a></div>';
    var rows = players.map(function(p) {
      var warPct = computeWarPct(allPlayers, p);
      var rtng = p.hgb_rating_percentile != null ? Math.round(p.hgb_rating_percentile) : null;
      var imp  = p.gs_pct != null ? Math.round(p.gs_pct) : null;
      var g = p.goals || 0, a = p.assists || 0, pts = g + a;
      var name = p.first_name + ' ' + p.last_name;
      function cell(v) { return v != null ? '<span style="font-weight:700;color:' + pctColor(v) + '">' + v + '</span>' : '—'; }
      return '<tr class="player-row" style="cursor:pointer" onclick="location.href=\'/stats/player/' + (p.slug || '') + '\'">' +
        '<td class="name-cell"><a href="/stats/player/' + (p.slug||'') + '" style="display:flex;align-items:center;gap:8px;text-decoration:none"><img src="https://assets.nhle.com/logos/nhl/svg/' + p.team_abbrev + '_light.svg" style="width:28px;height:28px;object-fit:contain;flex-shrink:0" onerror="this.style.display=\'none\'">' + name + '</a></td>' +
        '<td>' + p.team_abbrev + '</td>' +
        '<td>' + p.pos + '</td>' +
        '<td>' + p.gp + '</td>' +
        '<td>' + g + '</td>' +
        '<td>' + a + '</td>' +
        '<td style="font-weight:700;color:#0d0d14">' + pts + '</td>' +
        '<td>' + cell(warPct) + '</td>' +
        '<td>' + cell(rtng) + '</td>' +
        '<td>' + cell(imp) + '</td>' +
      '</tr>';
    }).join('');
    return '<table class="player-table">' +
      '<thead><tr>' +
        '<th>PLAYER</th>' +
        '<th style="text-align:center">TM</th>' +
        '<th style="text-align:center">POS</th>' +
        '<th style="text-align:right">GP</th>' +
        '<th style="text-align:right">G</th>' +
        '<th style="text-align:right">A</th>' +
        '<th style="text-align:right">P</th>' +
        '<th style="text-align:center">WAR%</th>' +
        '<th style="text-align:center">RTNG%</th>' +
        '<th style="text-align:center">IMP%</th>' +
      '</tr></thead>' +
      '<tbody>' + rows + '</tbody>' +
    '</table>';
  }

  function renderDraftStack(teams, allPicks) {
    if (!teams.length) return '<div style="color:var(--ink-48);font-size:13px;padding:12px 0;">No teams followed. <a href="/account">Add teams →</a></div>';
    return teams.map(function(abbrev) {
      var picks = allPicks.filter(function(p) { return p.team === abbrev; }).sort(function(a,b){ return a.overall - b.overall; });
      var color = tc(abbrev);
      var fullName = TEAM_NAMES[abbrev] || abbrev;
      var firstPick = picks[0];
      var top64 = picks.filter(function(p) { return p.overall <= 64; }).length;
      var acquired = picks.filter(function(p) { return p.is_traded; }).length;
      var picksHtml = picks.map(function(p) {
        return '<div class="draft-pick-chip">' +
          '<span class="draft-pick-overall">#' + p.overall + '</span>' +
          '<span class="draft-pick-round">R' + p.round + '</span>' +
          (p.is_traded ? '<span class="draft-pick-source" title="' + p.original_team_name + '">from ' + p.original_team + '</span>' : '<span class="draft-pick-source">own</span>') +
        '</div>';
      }).join('');
      var heroHtml = firstPick ? (
        '<div class="draft-hero-grid">' +
          '<div class="draft-pick-col">' +
            '<div class="draft-col-label">First Pick</div>' +
            '<div class="draft-hero-number">#' + firstPick.overall + '</div>' +
            '<div class="draft-hero-meta">R' + firstPick.round + ' · ' + (firstPick.is_traded ? 'from ' + firstPick.original_team : 'own') + '</div>' +
          '</div>' +
          '<div class="draft-inv-col">' +
            '<div class="draft-col-label">Pick Inventory</div>' +
            '<div class="draft-inv-row"><span class="draft-inv-val">' + picks.length + '</span><span class="draft-inv-lbl">Picks</span></div>' +
            '<div class="draft-inv-row"><span class="draft-inv-val">' + top64 + '</span><span class="draft-inv-lbl">Top-64</span></div>' +
            (acquired ? '<div class="draft-inv-net">+' + acquired + ' acquired</div>' : '') +
          '</div>' +
        '</div>' +
        '<div class="draft-picks-list">' + picksHtml + '</div>'
      ) : '<div class="draft-picks-list" style="color:var(--ink-32);font-family:var(--body);font-size:12px;">No 2026 picks currently owned</div>';
      return '<div class="draft-team-card">' +
        '<div class="draft-team-bar" style="background:' + color + '"></div>' +
        '<div class="draft-team-head">' +
          '<img src="https://assets.nhle.com/logos/nhl/svg/' + abbrev + '_light.svg" alt="' + abbrev + '" class="draft-team-logo">' +
          '<div class="draft-team-name">' + fullName + '</div>' +
        '</div>' +
        heroHtml +
      '</div>';
    }).join('');
  }

  async function loadPersonalized() {
    var headers = { 'Authorization': 'Bearer ' + token };
    var results = await Promise.all([
      fetch(API + '/v1/account/prefs', { headers: headers, credentials: 'include' }).then(function(r){ return r.ok ? r.json() : {}; }).catch(function(){ return {}; }),
      fetch(API + '/v1/stats/draft-picks').then(function(r){ return r.ok ? r.json() : {}; }).catch(function(){ return {}; }),
    ]);
    var prefs = results[0], draftsData = results[1];
    var trackedTeams = prefs.tracked_teams || [];
    var allPicks = draftsData.picks || [];

    // Teams + Players + Trending handled by self-fetching React components.

    // Render draft stacks
    var draftStacks = document.querySelectorAll('.personal-draft-stack');
    draftStacks.forEach(function(el) {
      el.innerHTML = renderDraftStack(trackedTeams, allPicks);
    });

    // Done — remove spinner
    var pw = document.getElementById('personal-wrap');
    if (pw) pw.classList.remove('is-loading');
  }

  loadPersonalized().catch(function(err) {
    // On failure, still remove spinner so mock data shows
    var pw = document.getElementById('personal-wrap');
    if (pw) pw.classList.remove('is-loading');
  });
})();
</script>

</body>
</html>
