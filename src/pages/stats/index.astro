---
import { loadPlayers, loadLeaderboard } from '../../lib/stats-loader';
import { pickTeamColor } from '../../lib/team-colors';

const players = loadPlayers();

// HGB Rating leaderboard — RAPM ×60, sorted descending
const ratingLeaders = players
  .filter(p => p.rapm != null)
  .sort((a, b) => (b.rapm ?? 0) - (a.rapm ?? 0))
  .slice(0, 5)
  .map(p => ({
    slug:        p.slug,
    display_name: p.display_name,
    team_abbrev: p.team_abbrev,
    pos:         p.pos,
    gp:          p.gp,
    value:       (p.rapm ?? 0) * 60,
  }));

const xgLeaders = loadLeaderboard('xg').slice(0, 5);

// Lightweight search index for client-side search
const searchIndex = players.map(p => ({
  slug: p.slug,
  name: `${p.first_name} ${p.last_name}`,
  team: p.team_abbrev,
  pos:  p.pos,
  gp:   p.gp,
}));

function sign(n: number): string { return n >= 0 ? '+' : ''; }
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>HGB Stats — HockeyGameBot</title>
  <meta name="description" content="Advanced hockey analytics — HGB Rating, expected goals, percentiles, and every-player leaderboards. Updated nightly." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:      #EFEEE8;
      --ink:     #0d0d14;
      --red:     #E8002D;
      --surface: #FFFFFF;
      --ink-06:  rgba(13,13,20,0.06);
      --ink-10:  rgba(13,13,20,0.10);
      --ink-14:  rgba(13,13,20,0.14);
      --ink-20:  rgba(13,13,20,0.20);
      --ink-32:  rgba(13,13,20,0.32);
      --ink-48:  rgba(13,13,20,0.48);
      --display: 'Barlow Condensed', sans-serif;
      --body:    'Barlow', sans-serif;
      --mono:    'JetBrains Mono', monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; }

    /* Nav */
    .nav { background: var(--bg); border-bottom: 1px solid var(--ink-14); position: sticky; top: 0; z-index: 50; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 32px; height: 52px; display: flex; align-items: center; gap: 20px; }
    .wordmark { font-family: var(--display); font-weight: 800; font-size: 20px; letter-spacing: 0.04em; text-transform: uppercase; text-decoration: none; color: var(--ink); display: inline-flex; align-items: center; }
    .wordmark .dot { width: 6px; height: 6px; background: var(--red); border-radius: 50%; margin: 0 6px; display: inline-block; }
    .nav-links { margin-left: auto; display: flex; align-items: center; gap: 0; font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; }
    .nav-links a { padding: 5px 12px; color: var(--ink-48); text-decoration: none; }
    .nav-links a:hover, .nav-links a.active { color: var(--ink); }
    .nav-links .sep { color: var(--ink-20); }

    /* Layout */
    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

    /* Hero */
    .hero { padding: 48px 0 40px; border-bottom: 2px solid var(--ink); }
    .hero-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-32); margin-bottom: 12px; }
    .hero-headline { font-family: var(--display); font-weight: 800; font-size: clamp(48px, 7vw, 80px); text-transform: uppercase; line-height: 0.9; letter-spacing: -0.02em; color: var(--ink); margin-bottom: 24px; }
    .hero-headline em { color: var(--red); font-style: normal; }

    /* Search */
    .search-wrap { position: relative; max-width: 560px; }
    .search-input {
      width: 100%; padding: 14px 48px 14px 18px;
      font-family: var(--body); font-size: 16px; font-weight: 500;
      background: var(--surface); color: var(--ink);
      border: 2px solid var(--ink-20); outline: none;
      transition: border-color 0.15s;
    }
    .search-input::placeholder { color: var(--ink-32); }
    .search-input:focus { border-color: var(--ink); }
    .search-icon { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: var(--ink-48); pointer-events: none; font-size: 14px; font-family: var(--mono); }
    .search-results {
      position: absolute; top: calc(100% + 2px); left: 0; right: 0; z-index: 40;
      background: var(--surface); border: 2px solid var(--ink);
      display: none; flex-direction: column;
      box-shadow: 4px 4px 0 rgba(13,13,20,0.10);
    }
    .search-results.open { display: flex; }
    .search-result {
      display: flex; align-items: center; gap: 14px;
      padding: 11px 16px; border-bottom: 1px solid var(--ink-10);
      text-decoration: none; color: var(--ink);
    }
    .search-result:last-child { border-bottom: 0; }
    .search-result:hover, .search-result.focused { background: var(--bg); }
    .sr-name { font-family: var(--body); font-weight: 600; font-size: 15px; color: var(--ink); flex: 1; }
    .sr-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.05em; white-space: nowrap; }
    .sr-empty { padding: 14px 16px; font-family: var(--mono); font-size: 11px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* Content */
    .content { padding: 40px 0; display: flex; flex-direction: column; gap: 40px; }

    /* White surface card (matches player page) */
    .card { background: var(--surface); border: 1px solid var(--ink-14); box-shadow: 0 1px 3px rgba(13,13,20,0.06); }
    .card-head { padding: 14px 18px 12px; border-bottom: 1px solid var(--ink-06); display: flex; align-items: baseline; justify-content: space-between; }
    .card-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-32); }
    .card-eyebrow .accent { color: var(--red); }
    .card-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* Leaders grid */
    .leaders-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    @media (max-width: 700px) { .leaders-grid { grid-template-columns: 1fr; } }

    /* Leader rows */
    .lb-row { display: flex; align-items: center; gap: 12px; padding: 12px 18px; border-bottom: 1px solid var(--ink-06); text-decoration: none; color: inherit; border-left: 3px solid transparent; transition: background 0.1s; }
    .lb-row:last-of-type { border-bottom: 0; }
    .lb-row:hover { background: var(--bg); }
    .lb-rank { font-family: var(--mono); font-size: 11px; color: var(--ink-32); min-width: 16px; font-variant-numeric: tabular-nums; flex-shrink: 0; }
    .lb-logo { width: 28px; height: 28px; object-fit: contain; flex-shrink: 0; }
    .lb-info { flex: 1; min-width: 0; }
    .lb-name { font-family: var(--body); font-weight: 700; font-size: 15px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--ink); }
    .lb-meta { font-family: var(--mono); font-size: 10.5px; color: var(--ink-48); letter-spacing: 0.04em; margin-top: 2px; }
    .lb-val { font-family: var(--mono); font-weight: 700; font-size: 16px; font-variant-numeric: tabular-nums; text-align: right; flex-shrink: 0; min-width: 48px; color: var(--ink); }
    .lb-val.pos { color: #14803c; }
    .view-all { display: block; padding: 10px 18px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-32); text-decoration: none; text-align: right; border-top: 1px solid var(--ink-06); }
    .view-all:hover { color: var(--red); }

    /* Browse CTA */
    .browse-cta { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; background: var(--surface); border: 1px solid var(--ink-14); }
    .browse-text { font-family: var(--display); font-weight: 700; font-size: 18px; text-transform: uppercase; letter-spacing: 0.02em; }
    .browse-link { font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); text-decoration: none; padding: 10px 18px; border: 2px solid var(--red); }
    .browse-link:hover { background: var(--red); color: #fff; }

    /* Methodology */
    .method-grid { display: grid; grid-template-columns: repeat(3, 1fr); background: var(--surface); border: 1px solid var(--ink-14); }
    @media (max-width: 700px) { .method-grid { grid-template-columns: 1fr; } }
    .method-item { padding: 20px 20px 18px; border-right: 1px solid var(--ink-06); }
    .method-item:last-child { border-right: 0; }
    .method-label { font-family: var(--display); font-weight: 800; font-size: 14px; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 6px; }
    .method-desc { font-family: var(--mono); font-size: 11px; color: var(--ink-48); line-height: 1.65; letter-spacing: 0.02em; }

    footer { background: var(--ink); padding: 32px 0; font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.24); letter-spacing: 0.06em; text-align: center; }
  </style>
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="wordmark">Hockey<span class="dot"></span>Gamebot</a>
    <nav class="nav-links">
      <a href="/">Home</a><span class="sep"> · </span>
      <a href="/scoreboard">Scoreboard</a><span class="sep"> · </span>
      <a href="/playoffs/2026">Playoffs</a><span class="sep"> · </span>
      <a href="/stats" class="active">Stats</a><span class="sep"> · </span>
      <a href="/teams">Teams</a><span class="sep"> · </span>
      <a href="/support">Support</a>
    </nav>
  </div>
</nav>

<div class="wrap">

  <!-- HERO + SEARCH -->
  <div class="hero">
    <div class="hero-eyebrow">HGB Stats · 2025–26 NHL Season</div>
    <h1 class="hero-headline">Every skater.<br><em>Measured.</em></h1>
    <div class="search-wrap" id="search-wrap">
      <input
        type="search"
        class="search-input"
        id="player-search"
        placeholder="Search players — MacKinnon, Draisaitl, ..."
        autocomplete="off"
        spellcheck="false"
      />
      <span class="search-icon">↗</span>
      <div class="search-results" id="search-results" role="listbox"></div>
    </div>
  </div>

  <div class="content">

    <!-- LEADERBOARDS -->
    <div class="leaders-grid">

      <!-- HGB RATING (RAPM ×60) -->
      <div class="card">
        <div class="card-head">
          <span class="card-eyebrow">Season Leaders &nbsp;<span class="accent">HGB Rating</span></span>
          <span class="card-meta">per 60 min · 2025–26</span>
        </div>
        {ratingLeaders.map((entry, i) => {
          const tc = pickTeamColor(entry.team_abbrev);
          return (
            <a class="lb-row" href={`/stats/player/${entry.slug}`} style={`border-left-color:${tc}`}>
              <span class="lb-rank">{i + 1}</span>
              <img class="lb-logo" src={`https://assets.nhle.com/logos/nhl/svg/${entry.team_abbrev}_light.svg`} alt={entry.team_abbrev} width="28" height="28" loading="lazy" />
              <div class="lb-info">
                <div class="lb-name">{entry.display_name}</div>
                <div class="lb-meta">{entry.pos} · {entry.team_abbrev} · {entry.gp} GP</div>
              </div>
              <span class={`lb-val${entry.value >= 0 ? ' pos' : ''}`}>{sign(entry.value)}{entry.value.toFixed(2)}</span>
            </a>
          );
        })}
        <a href="/stats/leaderboards" class="view-all">Full leaderboard →</a>
      </div>

      <!-- xG / 60 -->
      <div class="card">
        <div class="card-head">
          <span class="card-eyebrow">Season Leaders &nbsp;<span class="accent">xG / 60</span></span>
          <span class="card-meta">5v5 · 2025–26</span>
        </div>
        {xgLeaders.map((entry, i) => {
          const tc = pickTeamColor(entry.team_abbrev);
          return (
            <a class="lb-row" href={`/stats/player/${entry.slug}`} style={`border-left-color:${tc}`}>
              <span class="lb-rank">{i + 1}</span>
              <img class="lb-logo" src={`https://assets.nhle.com/logos/nhl/svg/${entry.team_abbrev}_light.svg`} alt={entry.team_abbrev} width="28" height="28" loading="lazy" />
              <div class="lb-info">
                <div class="lb-name">{entry.display_name}</div>
                <div class="lb-meta">{entry.pos} · {entry.team_abbrev} · {entry.gp} GP</div>
              </div>
              <span class="lb-val">{entry.value.toFixed(2)}</span>
            </a>
          );
        })}
        <a href="/stats/leaderboards" class="view-all">Full leaderboard →</a>
      </div>

    </div>

    <!-- BROWSE ALL -->
    <div class="browse-cta">
      <span class="browse-text">{players.length} skaters · full season data</span>
      <a href="/stats/leaderboards" class="browse-link">Browse all players →</a>
    </div>

    <!-- METHODOLOGY -->
    <div>
      <div class="method-grid">
        <div class="method-item">
          <div class="method-label">HGB Rating</div>
          <p class="method-desc">Regularized Adjusted Plus/Minus (RAPM) — goals above a replacement player per 60 min, controlling for linemates and opponents via ridge regression on shift data.</p>
        </div>
        <div class="method-item">
          <div class="method-label">Expected Goals</div>
          <p class="method-desc">Probability a shot scores based on location, angle, and context. Better signal than raw shot count for measuring shot quality and deployment.</p>
        </div>
        <div class="method-item">
          <div class="method-label">HGBScore V2</div>
          <p class="method-desc">Per-game blend of goals, assists, shots, xG, and two-way play — rate-adjusted per 60 minutes. Formula undergoing revision; use HGB Rating for cross-player comparisons.</p>
        </div>
      </div>
    </div>

  </div>
</div>

<footer>hockeygamebot.com · HGB Stats · 2025–26</footer>

<script define:vars={{ searchIndex }}>
  const input   = document.getElementById('player-search');
  const results = document.getElementById('search-results');
  let focusedIdx = -1;
  let lastQuery  = '';

  function render(query) {
    lastQuery = query;
    const q = query.trim().toLowerCase();
    if (!q) { results.classList.remove('open'); return; }

    const hits = searchIndex
      .filter(p => p.name.toLowerCase().includes(q))
      .slice(0, 8);

    if (!hits.length) {
      results.innerHTML = '<div class="sr-empty">No players found</div>';
      results.classList.add('open');
      focusedIdx = -1;
      return;
    }

    results.innerHTML = hits.map((p, i) =>
      `<a class="search-result" href="/stats/player/${p.slug}" role="option" data-idx="${i}">
        <span class="sr-name">${p.name}</span>
        <span class="sr-meta">${p.team} &middot; ${p.pos} &middot; ${p.gp} GP</span>
      </a>`
    ).join('');
    results.classList.add('open');
    focusedIdx = -1;
  }

  function moveFocus(dir) {
    const items = results.querySelectorAll('.search-result');
    if (!items.length) return;
    items[focusedIdx]?.classList.remove('focused');
    focusedIdx = (focusedIdx + dir + items.length) % items.length;
    const el = items[focusedIdx];
    el.classList.add('focused');
    el.scrollIntoView({ block: 'nearest' });
  }

  input.addEventListener('input', e => render(e.target.value));
  input.addEventListener('keydown', e => {
    if (e.key === 'ArrowDown')  { e.preventDefault(); moveFocus(1); }
    if (e.key === 'ArrowUp')    { e.preventDefault(); moveFocus(-1); }
    if (e.key === 'Enter') {
      const focused = results.querySelector('.search-result.focused');
      if (focused) { window.location.href = focused.href; }
    }
    if (e.key === 'Escape') { results.classList.remove('open'); input.blur(); }
  });

  document.addEventListener('click', e => {
    if (!e.target.closest('#search-wrap')) results.classList.remove('open');
  });

  input.addEventListener('focus', () => { if (lastQuery) render(lastQuery); });
</script>

</body>
</html>
