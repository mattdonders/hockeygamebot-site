---
import '../../styles/stats-tokens.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>HGB Stats — Coming Soon</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--site-bg);
      color: var(--site-white);
      font-family: var(--font-site-display);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      -webkit-font-smoothing: antialiased;
    }

    .wordmark {
      font-size: 3rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      line-height: 1;
    }

    .accent {
      width: 100%;
      height: 3px;
      background: var(--hgb-red);
      margin-top: 0.5rem;
    }

    .coming-soon {
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--site-muted);
      margin-top: 1.25rem;
      font-family: var(--font-site-body);
    }

    footer {
      position: fixed;
      bottom: 1rem;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--site-muted);
      font-family: var(--font-mono);
    }
  </style>
</head>
<body>
  <h1 class="wordmark">HOCKEYGAMEBOT STATS</h1>
  <div class="accent"></div>
  <p class="coming-soon">Coming Soon</p>
  <footer>SS-2 &middot; rewrite branch &middot; 2026-04-22</footer>
</body>
</html>
