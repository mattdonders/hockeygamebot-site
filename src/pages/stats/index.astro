---
import '../../styles/stats-tokens.css';
import PageHeader from '../../components/stats/PageHeader.astro';
import SectionEyebrow from '../../components/stats/SectionEyebrow.astro';
import PlayerHero from '../../components/stats/PlayerHero.astro';
import PercentileTile from '../../components/stats/PercentileTile.astro';
import StatsSEO from '../../components/StatsSEO.astro';
import { loadLeaderboard, loadPlayerOfTheWeek } from '../../lib/stats-loader';
import { pickTeamColor } from '../../lib/team-colors';

const potw = loadPlayerOfTheWeek();
const skaterLeaders = loadLeaderboard('game_score').slice(0, 5);
const xgLeaders = loadLeaderboard('xg').slice(0, 5);

function hexToRgba(hex: string, alpha: number): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}
function dotColor(pct: number): string {
  return pct >= 90 ? '#00c078' : pct >= 70 ? '#60a5fa' : pct >= 40 ? '#8a8a82' : '#e8002d';
}
function rankStr(n: number): string {
  return String(n).padStart(2, '0');
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Anti-FOUC: sets html[data-mode] before CSS renders — zero flash.
       keep in sync with stats/dev/components.astro; extract to shared layout in SS-8. -->
  <script is:inline>
    (function() {
      try {
        var saved = localStorage.getItem('hgb-mode');
        var system = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.dataset.mode = saved || system;
      } catch (_) {
        document.documentElement.dataset.mode = 'dark';
      }
    })();
  </script>
  <meta name="color-scheme" content="light dark">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <StatsSEO
    title="HGB Stats — HockeyGameBot"
    description="Advanced hockey analytics — HGBScore v2, expected goals, percentiles, and every-player leaderboards. Updated nightly after every NHL game."
  />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { min-height: 100vh; -webkit-font-smoothing: antialiased; }
    body {
      background: var(--site-bg);
      color: var(--site-white);
      font-family: var(--font-site-body, 'Space Grotesk', sans-serif);
    }

    /* ── Page shell ─────────────────────────────────────────────────── */
    .stats-main {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 24px 64px;
    }

    /* ── Hero ────────────────────────────────────────────────────────── */
    .stats-hero {
      padding: 28px 0 20px;
      border-bottom: 1px solid var(--site-border);
    }
    .stats-hero-headline {
      font-family: var(--font-card-display, 'Barlow Condensed', sans-serif);
      font-size: clamp(36px, 5vw, 48px);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.01em;
      line-height: 1.05;
      margin-top: 10px;
      color: var(--site-white);
    }
    .stats-hero-sub {
      margin-top: 12px;
      font-size: 14px;
      font-weight: 400;
      color: var(--site-muted);
      line-height: 1.55;
      max-width: 400px;
    }

    /* ── Sections ────────────────────────────────────────────────────── */
    .stats-section {
      padding: 32px 0;
      border-bottom: 1px solid var(--site-border);
    }
    .stats-section:last-child { border-bottom: none; }
    .section-body { margin-top: 14px; }

    /* ── Featured section ────────────────────────────────────────────── */
    /* No rule below — whitespace before the leaders grid does the separation (fix 5) */
    .featured-section { border-bottom: none; }
    /* Eyebrow gets one extra size step and tighter tracking to signal importance (fix 3) */
    .featured-label :global(.eyebrow) {
      font-size: 13px;
      letter-spacing: 0.22em;
      font-weight: 800;
    }

    /* ── Featured player card (Season Leader) ────────────────────────── */
    /* Override --site-card so PlayerHero (which reads var(--site-card) for its bg)
       shares the same surface as the card background — no specificity battle needed. */
    .featured-card {
      background: var(--card-bg);
      border: 1px solid var(--card-rule);
      border-radius: var(--radius-md);
      overflow: hidden;
      --site-card: var(--card-bg); /* dark: #0d0d14 — unified surface both halves */
    }
    [data-mode="light"] .featured-card {
      background: #ffffff;
      border-color: var(--site-border);
      --site-card: #ffffff; /* light: white — unified surface both halves */
    }
    /* Remove PlayerHero's own radius — card provides the clip */
    .featured-card :global(.ph-hero) { border-radius: 0; }
    .featured-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
    }
    /* Dual-render tile sets: PercentileTile gradient is baked at build time
       (TypeScript, not CSS), so we render both modes and CSS-toggle visibility.
       The anti-FOUC script sets html[data-mode] before CSS evaluates — no flash. */
    .stat-tiles {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      padding: 16px;
      align-content: start;
    }
    .tiles-dark  { display: grid; }
    .tiles-light { display: none; }
    [data-mode="light"] .tiles-dark  { display: none; }
    [data-mode="light"] .tiles-light { display: grid; }
    @media (max-width: 620px) {
      .featured-inner { grid-template-columns: 1fr; }
    }

    /* ── Leaders grid (side-by-side) ─────────────────────────────────── */
    .leaders-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      margin-top: 14px;
    }
    @media (max-width: 640px) {
      .leaders-grid { grid-template-columns: 1fr; gap: 28px; }
    }
    .leaders-col-header { margin-bottom: 10px; }

    /* ── Leader list card + editorial roster rows ────────────────────── */
    .leaders-list {
      background: #141414;
      border: 1px solid var(--site-border);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    [data-mode="light"] .leaders-list { background: var(--site-card); }
    .leaders-list .lb-row:last-child { border-bottom: none; }
    .leaders-list .lb-row:hover,
    .leaders-list .lb-row--top:hover { background: #1e1e1e; }
    [data-mode="light"] .leaders-list .lb-row:hover,
    [data-mode="light"] .leaders-list .lb-row--top:hover { background: var(--site-dim); }

    .lb-row {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px;
      border-left: 3px solid transparent;
      border-bottom: 1px solid var(--site-border);
      text-decoration: none; color: inherit;
      background: transparent; transition: background 0.12s;
    }
    .lb-row--top { padding: 13px 14px; background: var(--row-tint, transparent); }
    .lb-rank {
      font-family: var(--font-card-display); font-size: 18px; font-weight: 900;
      color: rgba(255,255,255,0.16); min-width: 26px; text-align: right;
      letter-spacing: -0.01em; font-variant-numeric: tabular-nums; flex-shrink: 0;
    }
    [data-mode="light"] .lb-rank { color: rgba(13,13,20,0.18); }
    .lb-row--top .lb-rank { color: rgba(255,255,255,0.5); font-size: 22px; }
    [data-mode="light"] .lb-row--top .lb-rank { color: rgba(13,13,20,0.5); }
    .lb-logo { width: 20px; height: 20px; object-fit: contain; flex-shrink: 0; opacity: 0.88; }
    .lb-row--top .lb-logo { width: 26px; height: 26px; opacity: 1; }
    .lb-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .lb-name {
      font-family: var(--font-site-body); font-size: 13px; font-weight: 600;
      color: var(--site-white); white-space: nowrap; overflow: hidden;
      text-overflow: ellipsis; line-height: 1.2;
    }
    .lb-row--top .lb-name { font-size: 14px; }
    .lb-meta {
      font-family: var(--font-card-display); font-size: 10px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--site-muted);
    }
    .lb-val {
      font-family: var(--font-site-display); font-size: 15px; font-weight: 700;
      font-variant-numeric: tabular-nums; color: var(--site-white);
      min-width: 40px; text-align: right; flex-shrink: 0;
    }
    .lb-row--top .lb-val { font-size: 18px; min-width: 46px; }
    .lb-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    .view-all {
      display: block;
      margin-top: 8px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--site-muted);
      text-decoration: none;
      text-align: right;
      transition: color 0.12s;
    }
    .view-all:hover { color: var(--site-white); }

    /* ── Methodology card ────────────────────────────────────────────── */
    .method-card {
      background: var(--site-card);
      border: 1px solid var(--site-border);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .method-item {
      display: flex;
      flex-direction: column;
      gap: 5px;
      padding: 14px 18px;
      border-bottom: 1px solid var(--site-border);
    }
    .method-label {
      font-family: var(--font-card-display, 'Barlow Condensed', sans-serif);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--site-white);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .coming-badge {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--site-muted);
      background: var(--site-border);
      border: 1px solid var(--site-border2, #252525);
      padding: 2px 6px;
      border-radius: var(--radius-pill);
    }
    .method-desc {
      font-size: 12px;
      color: var(--site-muted);
      line-height: 1.55;
    }
    /* Light mode: gray text hits harder on cream — drop one size step (fix 6) */
    [data-mode="light"] .method-desc { font-size: 11px; }
    .method-link {
      display: block;
      padding: 10px 18px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--site-muted);
      text-decoration: none;
      text-align: right;
      transition: color 0.12s;
    }
    .method-link:hover { color: var(--site-white); }

    /* ── Footer ──────────────────────────────────────────────────────── */
    .stats-footer {
      text-align: center;
      padding: 20px 0;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--site-muted);
      font-family: var(--font-mono);
    }
  </style>
</head>
<body>
  <PageHeader activePage="stats" />

  <main class="stats-main">

    <!-- HERO -->
    <section class="stats-hero">
      <SectionEyebrow label="STATS" />
      <h1 class="stats-hero-headline">
        Every skater.<br>
        Every shift.<br>
        Measured.
      </h1>
      <p class="stats-hero-sub">Plain-English advanced hockey stats. Updated nightly after every game.</p>
    </section>

    <!-- SEASON LEADER -->
    <!-- TODO: When hgb-bot scripts/export_stats_data.py writes _meta.player_of_the_week
         (7-day rolling, min 3 GP, min 40 min TOI), read it in loadPlayerOfTheWeek() and
         switch this eyebrow label to "PLAYER OF THE WEEK". -->
    <section class="stats-section featured-section">
      <div class="featured-label">
        <SectionEyebrow label="SEASON LEADER · HGBSCORE V2" />
      </div>
      <div class="section-body">
        <div class="featured-card">
          <div class="featured-inner">
            <PlayerHero
              firstName={potw.first_name}
              lastName={potw.last_name}
              displayName={potw.display_name}
              teamAbbrev={potw.team_abbrev}
              pos={potw.pos}
              teamColor={pickTeamColor(potw.team_abbrev)}
            />
            <div class="stat-tiles tiles-dark">
              <PercentileTile label="HGBScore V2" rawVal={potw.avg_gs_display.toFixed(2)}    pct={potw.gs_pct}                      mode="dark" />
              <PercentileTile label="Goals / 60"  rawVal={potw.rates_per_60.goals.toFixed(2)} pct={potw.percentiles_vs_pos.goals}    mode="dark" />
              <PercentileTile label="xG / 60"     rawVal={potw.rates_per_60.ixg.toFixed(2)}   pct={potw.percentiles_vs_pos.ixg}     mode="dark" />
              <PercentileTile label="A1 / 60"     rawVal={potw.rates_per_60.a1.toFixed(2)}    pct={potw.percentiles_vs_pos.a1}      mode="dark" />
            </div>
            <div class="stat-tiles tiles-light">
              <PercentileTile label="HGBScore V2" rawVal={potw.avg_gs_display.toFixed(2)}    pct={potw.gs_pct}                      mode="light" />
              <PercentileTile label="Goals / 60"  rawVal={potw.rates_per_60.goals.toFixed(2)} pct={potw.percentiles_vs_pos.goals}    mode="light" />
              <PercentileTile label="xG / 60"     rawVal={potw.rates_per_60.ixg.toFixed(2)}   pct={potw.percentiles_vs_pos.ixg}     mode="light" />
              <PercentileTile label="A1 / 60"     rawVal={potw.rates_per_60.a1.toFixed(2)}    pct={potw.percentiles_vs_pos.a1}      mode="light" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CURRENT LEADERS: side-by-side grid -->
    <section class="stats-section">
      <div class="leaders-grid">

        <!-- SKATERS (HGBScore V2) -->
        <div>
          <div class="leaders-col-header">
            <SectionEyebrow label="CURRENT LEADERS · SKATERS" />
          </div>
          <div class="leaders-list">
            {skaterLeaders.map((entry, i) => {
              const tc = pickTeamColor(entry.team_abbrev);
              const isTop = i === 0;
              return (
                <a
                  class={`lb-row${isTop ? ' lb-row--top' : ''}`}
                  href={`/stats/player/${entry.slug}`}
                  style={`border-left-color:${tc};${isTop ? `--row-tint:${hexToRgba(tc, 0.08)};` : ''}`}
                >
                  <span class="lb-rank">{rankStr(i + 1)}</span>
                  <img class="lb-logo" src={`https://assets.nhle.com/logos/nhl/svg/${entry.team_abbrev}_light.svg`} alt={entry.team_abbrev} width="26" height="26" loading="lazy" />
                  <div class="lb-info">
                    <span class="lb-name">{entry.display_name}</span>
                    <span class="lb-meta">{entry.pos} · {entry.team_abbrev} · {entry.gp} GP</span>
                  </div>
                  <span class="lb-val">{entry.value.toFixed(2)}</span>
                  <span class="lb-dot" style={`background:${dotColor(entry.pct)}`} title={`${Math.round(entry.pct)}th pct`}></span>
                </a>
              );
            })}
          </div>
          <a href="/stats/leaderboards" class="view-all">View full leaderboard →</a>
        </div>

        <!-- EXPECTED GOALS -->
        <!-- SS-FUTURE: Replace with CURRENT LEADERS · GOALIES once GSAx data lands in
             export pipeline (hgb-bot scripts/export_stats_data.py → leaderboards.json).
             Swap: metric 'xg' → 'gsax', update SectionEyebrow label, everything else stays. -->
        <div>
          <div class="leaders-col-header">
            <SectionEyebrow label="CURRENT LEADERS · EXPECTED GOALS" />
          </div>
          <div class="leaders-list">
            {xgLeaders.map((entry, i) => {
              const tc = pickTeamColor(entry.team_abbrev);
              const isTop = i === 0;
              return (
                <a
                  class={`lb-row${isTop ? ' lb-row--top' : ''}`}
                  href={`/stats/player/${entry.slug}`}
                  style={`border-left-color:${tc};${isTop ? `--row-tint:${hexToRgba(tc, 0.08)};` : ''}`}
                >
                  <span class="lb-rank">{rankStr(i + 1)}</span>
                  <img class="lb-logo" src={`https://assets.nhle.com/logos/nhl/svg/${entry.team_abbrev}_light.svg`} alt={entry.team_abbrev} width="26" height="26" loading="lazy" />
                  <div class="lb-info">
                    <span class="lb-name">{entry.display_name}</span>
                    <span class="lb-meta">{entry.pos} · {entry.team_abbrev} · {entry.gp} GP</span>
                  </div>
                  <span class="lb-val">{entry.value.toFixed(2)}</span>
                  <span class="lb-dot" style={`background:${dotColor(entry.pct)}`} title={`${Math.round(entry.pct)}th pct`}></span>
                </a>
              );
            })}
          </div>
          <a href="/stats/leaderboards" class="view-all">View full leaderboard →</a>
        </div>

      </div>
    </section>

    <!-- HOW WE MEASURE -->
    <section class="stats-section">
      <SectionEyebrow label="HOW WE MEASURE" />
      <div class="section-body">
        <div class="method-card">
          <div class="method-item">
            <span class="method-label">HGBScore V2</span>
            <span class="method-desc">Per-game blend of goals, assists, shots, xG, and two-way play — scaled so 1.0 is a solid game.</span>
          </div>
          <div class="method-item">
            <span class="method-label">Expected Goals (xG)</span>
            <span class="method-desc">Probability a shot scores, based on location, angle, and context — better signal than raw shot count.</span>
          </div>
          <div class="method-item">
            <span class="method-label">RAPM <span class="coming-badge">coming</span></span>
            <span class="method-desc">Isolates a player's true on-ice impact by controlling for linemates and opponents.</span>
          </div>
          <a href="/stats/methodology" class="method-link">Read the full methodology →</a>
        </div>
      </div>
    </section>

  </main>

  <footer class="stats-footer">SS-3 &middot; rewrite branch &middot; 2026-04-23</footer>
</body>
</html>
