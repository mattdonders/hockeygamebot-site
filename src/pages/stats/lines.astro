---
// HockeyGameBot — /stats/lines — Forward Lines + D Pairs
// Client-side interactive table. Data from /v1/stats/lines (R2 via hgb-api).
// URL params: ?game_type=3 (playoff), ?season=playoff (alias), ?team=MTL, ?type=forwards|defense, ?toi=N
import StatsLayout from '../../layouts/StatsLayout.astro';
import StatsMasthead from '../../components/StatsMasthead.astro';
import LinesTable from '../../components/react/LinesTable';
import { loadMeta, loadLines, loadIsPlayoffSeason } from '../../lib/stats-loader';
const allLines = loadLines();
const _meta     = loadMeta();
const isPlayoffSeason = loadIsPlayoffSeason();
const _statsDate = (() => { const d = new Date(_meta.generated_at); return d.getFullYear() >= 2020 ? d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : null; })();

---
<StatsLayout
  title="Line Combinations — HockeyGameBot"
  description="NHL forward line and defensive pair stats. xGoals%, xGoals For/Against per 60, filterable by team, season, and line type."
  ogImage="/og/default.png"
  currentPath={Astro.url.pathname}
>

<StatsMasthead slot="mast" eyebrow="HGB Stats · Lines" ghost="LINES">
  <Fragment slot="headline">Lines that<br /><em>tilt the ice.</em></Fragment>
  <Fragment slot="lede">
    Forward lines and defensive pairs at 5v5, including historical seasons. Ranked by <span class="mono">xGoals%</span>. Minimum TOI slider filters noise.
  </Fragment>
</StatsMasthead>

<div class="wrap">
  <div class="section-block">
    <div class="section-head">
      <h2>Lines &amp; Pairs</h2>
    </div>
    <LinesTable rows={allLines} statsDate={_statsDate} isPlayoffSeason={isPlayoffSeason} client:load />
  </div>
</div>

</StatsLayout>

<style is:global>
  .section-block { padding: 40px 0 0; }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 6px; }
  .section-head h2 { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px); text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
  .section-meta { font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32); }
  .section-lede { font-size: 13px; color: var(--ink-48); max-width: 780px; line-height: 1.6; margin-bottom: 16px; }

  .controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }

  select {
    background: var(--surface); border: 1px solid var(--ink-14);
    padding: 6px 10px; font-family: var(--body); font-weight: 600;
    font-size: 11.5px; letter-spacing: 0.04em; color: var(--ink);
    cursor: pointer; outline: none;
  }

  .slider-wrap { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; color: var(--ink-48); }
  .team-chip { display: inline-flex; align-items: center; gap: 5px; background: var(--ink); color: var(--bg); font-family: var(--body); font-weight: 600; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 8px 4px 10px; }
  .team-chip-x { cursor: pointer; opacity: 0.6; font-size: 13px; line-height: 1; background: none; border: none; color: inherit; padding: 0; }
  .team-chip-x:hover { opacity: 1; }
  #team-add-select:disabled { opacity: 0.35; }
  .slider-wrap input[type=range] { width: 120px; accent-color: var(--red); }

  .tbl-more { border-top: 1px solid var(--ink-14); padding: 12px; text-align: center; }
  .tbl-more button { background: none; border: 1px solid var(--ink-20); padding: 6px 20px; cursor: pointer; font-family: var(--body); font-weight: 600; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-48); transition: all 0.15s; }
  .tbl-more button:hover { border-color: var(--ink); color: var(--ink); }
  .tbl-count { font-family: var(--mono); font-size: 10.5px; color: var(--ink-32); letter-spacing: 0.06em; margin-top: 8px; }
</style>
