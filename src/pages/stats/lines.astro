---
// HockeyGameBot — /stats/lines — Forward Lines + D Pairs
// Client-side interactive table. Data from /v1/stats/lines (R2 via hgb-api).
// URL params: ?game_type=3 (playoff), ?season=playoff (alias), ?team=MTL, ?type=forwards|defense, ?toi=N
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import Table from '../../components/Table.astro';

// SSR column schema. Rows are fetched client-side, so initial rows are empty.
const columns = [
  { key: '_rank',    label: '#',      type: 'rank' as const, sortable: false },
  { key: 'players',  label: 'Line',   type: 'label' as const },
  { key: 'type',     label: 'Type',   type: 'position' as const },
  { key: 'team',     label: 'Team',   type: 'team' as const },
  { key: 'toi_min',  label: 'Minutes',type: 'number' as const },
  { key: 'min_per_g',label: 'Min/G',  type: 'number' as const },
  { key: 'xgf_pct',  label: 'xG%',    type: 'number' as const, bold: true },
  { key: 'xgf',      label: 'xGF',    type: 'number' as const },
  { key: 'xga',      label: 'xGA',    type: 'number' as const },
  { key: 'xgf_60',   label: 'xGF/60', type: 'number' as const },
  { key: 'xga_60',   label: 'xGA/60', type: 'number' as const },
];
---
<!doctype html>
<html lang="en">
<head>
<ThemeScript />
<Fonts />
<meta charset="utf-8" />
<title>Line Combinations — HockeyGameBot</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="description" content="NHL forward line and defensive pair stats. xGoals%, xGoals For/Against per 60, filterable by team, season, and line type." />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
<link rel="apple-touch-icon" href="/favicon-180x180.png" />

<style is:global>
:root {
  --bg:      #EFEEE8;
  --bg-2:    #E8E7E0;
  --surface: #FFFFFF;
  --ink:     #0d0d14;
  --ink-86:  rgba(13,13,20,0.86);
  --ink-72:  rgba(13,13,20,0.72);
  --ink-56:  rgba(13,13,20,0.56);
  --ink-48:  rgba(13,13,20,0.48);
  --ink-32:  rgba(13,13,20,0.32);
  --ink-20:  rgba(13,13,20,0.20);
  --ink-14:  rgba(13,13,20,0.14);
  --ink-10:  rgba(13,13,20,0.10);
  --ink-06:  rgba(13,13,20,0.06);
  --ink-04:  rgba(13,13,20,0.04);
  --red:     #E8002D;
  --green:   #4ade80;
  --stats-pos: #166534;
  --stats-neg: #991b1b;
  --grid-line: rgba(13,13,20,0.04);
  --display: "Barlow Condensed", sans-serif;
  --body:    "Barlow", sans-serif;
  --mono:    "JetBrains Mono", monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; overflow-x: hidden; min-height: 100vh; }
a { color: inherit; text-decoration: none; }

.mast { position: relative; overflow: hidden; padding: 0; border-bottom: 2px solid var(--ink); background-color: var(--bg); background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px); background-size: 96px 96px; }
.mast-ghost { position: absolute; pointer-events: none; user-select: none; z-index: 0; font-family: var(--display); font-weight: 800; font-size: 260px; line-height: 0.86; text-transform: uppercase; letter-spacing: -0.02em; white-space: nowrap; color: rgba(13,13,20,0.07); top: 50%; left: 50%; transform: translate(-50%, -50%); }
.mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.mast-corners .corner { position: absolute; width: 16px; height: 16px; }
.mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-inner { position: relative; z-index: 2; max-width: 1280px; margin: 0 auto; padding: 48px 32px 40px; }
.mast-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 16px; }
.mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
.mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
.mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px); text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px; }
.mast-lede { font-size: 14px; line-height: 1.65; color: var(--ink-56); max-width: 640px; }
.mast-lede .mono { font-family: var(--mono); font-size: 12px; color: var(--ink-72); }

.wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

#loading-state { padding: 80px 0; text-align: center; font-family: var(--mono); font-size: 13px; color: var(--ink-48); letter-spacing: 0.06em; }
#loading-state .spinner { width: 20px; height: 20px; border: 2px solid var(--ink-14); border-top-color: var(--red); border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 14px; }
@keyframes spin { to { transform: rotate(360deg); } }
#main-content { display: none; }

.section-block { padding: 40px 0 0; }
.section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 6px; }
.section-head h2 { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px); text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
.section-meta { font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32); }
.section-lede { font-size: 13px; color: var(--ink-48); max-width: 780px; line-height: 1.6; margin-bottom: 16px; }

.controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
.btn-group { display: inline-flex; border: 1px solid var(--ink-14); }
.btn-group button { background: var(--surface); border: none; border-right: 1px solid var(--ink-14); padding: 6px 14px; cursor: pointer; font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-48); transition: background 0.1s, color 0.1s; }
.btn-group button:last-child { border-right: none; }
.btn-group button.active { background: var(--ink); color: var(--bg); }
.btn-group button:hover:not(.active) { background: var(--ink-06); color: var(--ink); }

select {
  background: var(--surface); border: 1px solid var(--ink-14);
  padding: 6px 10px; font-family: var(--body); font-weight: 600;
  font-size: 11.5px; letter-spacing: 0.04em; color: var(--ink);
  cursor: pointer; outline: none;
}

.slider-wrap { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; color: var(--ink-48); }
.team-chip { display: inline-flex; align-items: center; gap: 5px; background: var(--ink); color: var(--bg); font-family: var(--body); font-weight: 600; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 8px 4px 10px; }
.team-chip-x { cursor: pointer; opacity: 0.6; font-size: 13px; line-height: 1; background: none; border: none; color: inherit; padding: 0; }
.team-chip-x:hover { opacity: 1; }
#team-add-select:disabled { opacity: 0.35; }
.slider-wrap input[type=range] { width: 120px; accent-color: var(--red); }

.tbl-more { border-top: 1px solid var(--ink-14); padding: 12px; text-align: center; }
.tbl-more button { background: none; border: 1px solid var(--ink-20); padding: 6px 20px; cursor: pointer; font-family: var(--body); font-weight: 600; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-48); transition: all 0.15s; }
.tbl-more button:hover { border-color: var(--ink); color: var(--ink); }
.tbl-count { font-family: var(--mono); font-size: 10.5px; color: var(--ink-32); letter-spacing: 0.06em; margin-top: 8px; }

.foot { border-top: 1px solid var(--ink-14); padding: 32px 0; font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; }
.foot-inner { max-width: 1280px; margin: 0 auto; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
.foot-wordmark { font-family: var(--display); font-weight: 800; font-size: 18px; letter-spacing: 0.04em; text-transform: uppercase; display: inline-flex; align-items: center; }
.foot-wordmark .dot { width: 5px; height: 5px; background: var(--red); border-radius: 50%; margin: 0 6px; display: inline-block; }

@media (max-width: 680px) {
  .mast-inner { padding: 32px 20px 28px; }
  .wrap { padding: 0 20px 60px; }
  .mast-ghost { font-size: 120px; }
}
</style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<section class="mast">
  <div class="mast-ghost">LINES</div>
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-eyebrow"><span class="pip"></span>HockeyGameBot Analytics</div>
    <div class="mast-card">
      <h1 class="mast-headline">Line Combinations</h1>
      <p class="mast-lede" id="mast-lede">
        Forward lines (3-man) and defensive pairs at 5v5 · 2022–23 through 2025–26 regular season ·
        Ranked by <span class="mono">xGoals%</span>. Minimum TOI slider filters noise.
      </p>
    </div>
  </div>
</section>

<div class="wrap">
  <div id="loading-state">
    <div class="spinner"></div>
    Loading line data...
  </div>

  <div id="main-content">
    <div class="section-block">
      <div class="section-head">
        <h2>Lines &amp; Pairs</h2>
        <div style="display:flex;align-items:center;gap:12px">
          <span class="section-meta" id="tbl-meta"></span>
        </div>
      </div>
      <p class="section-lede">
        All combinations at <strong>5v5</strong> with qualifying ice time. Click column headers to sort. xG% &gt;55% highlighted green, &lt;45% red.
      </p>

      <div class="controls">
        <div class="btn-group" id="gametype-filter">
          <button class="active" data-gametype="2">Regular Season</button>
          <button data-gametype="3">Playoffs</button>
        </div>
        <div class="btn-group" id="type-filter">
          <button class="active" data-type="all">All</button>
          <button data-type="F">Forwards</button>
          <button data-type="D">Defense</button>
        </div>
        <select id="season-filter">
          <option value="all">All Seasons</option>
          <option value="20252026">2025–26</option>
          <option value="20242025">2024–25</option>
          <option value="20232024">2023–24</option>
          <option value="20222023">2022–23</option>
        </select>
        <select id="team-add-select" style="min-width:140px">
          <option value="">Add team…</option>
        </select>
        <div id="team-chips" style="display:flex;gap:5px;flex-wrap:wrap;align-items:center"></div>
        <div class="slider-wrap">
          Min TOI: <span id="toi-label">150</span>m
          <input type="range" id="toi-slider" min="20" max="400" value="150" step="10" />
        </div>
      </div>

      <Table
        columns={columns}
        rows={[]}
        defaultSort={{ column: 'xgf_pct', direction: 'desc' }}
        scrollable
        maxHeight={700}
        loadingMessage="Loading line data..."
        exportFilename="hgb-lines.png"
        exportTitle="Lines & Pairs"
        ariaLabel="NHL line combinations leaderboard"
      />
      <div class="tbl-more" id="tbl-more-row" style="display:none">
        <button id="tbl-show-all-btn">Show All</button>
        <div class="tbl-count" id="tbl-count-label"></div>
      </div>
    </div>
  </div>
</div>

<footer class="foot">
  <div class="foot-inner">
    <span class="foot-wordmark">Hockey<span class="dot"></span>Gamebot</span>
    <span>5v5 · Regular Season · 2022–26 · Data via HGB Analytics</span>
  </div>
</footer>

<script is:inline src="/js/table-export.js"></script>
<script is:inline>
(function () {
  'use strict';

  const REG_DEFAULT_TOI = 150;
  const PO_DEFAULT_TOI  = 30;
  const TOP_N = 100;

  let allLines = [];
  let gameTypeFilter = 2;
  let typeFilter    = 'all';
  let seasonFilter  = 'all';
  const MAX_TEAMS = 3;
  let selectedTeams = [];
  let minToi        = REG_DEFAULT_TOI;
  let showAll       = false;
  let playerFilter  = null;

  function readUrlParams() {
    const p = new URLSearchParams(window.location.search);
    const gt = p.get('game_type');
    const seasonParam = p.get('season');
    if (gt === '3' || seasonParam === 'playoff') {
      gameTypeFilter = 3;
      minToi = PO_DEFAULT_TOI;
    }
    const team = p.get('team');
    if (team) selectedTeams = team.split(',').filter(Boolean).slice(0, MAX_TEAMS);
    const s = p.get('s');
    if (s) seasonFilter = s;
    const type = p.get('type');
    if (type && ['all','F','D'].includes(type)) typeFilter = type;
    const toi = p.get('toi');
    if (toi && !isNaN(parseInt(toi, 10))) minToi = parseInt(toi, 10);
    const pid = p.get('player');
    if (pid && !isNaN(parseInt(pid, 10))) playerFilter = parseInt(pid, 10);
  }

  function updateUrl() {
    const p = new URLSearchParams();
    if (gameTypeFilter === 3) p.set('game_type', '3');
    if (selectedTeams.length > 0) p.set('team', selectedTeams.join(','));
    if (seasonFilter !== 'all') p.set('s', seasonFilter);
    if (typeFilter !== 'all') p.set('type', typeFilter);
    const defaultToi = gameTypeFilter === 3 ? PO_DEFAULT_TOI : REG_DEFAULT_TOI;
    if (minToi !== defaultToi) p.set('toi', minToi);
    if (playerFilter != null) p.set('player', playerFilter);
    const qs = p.toString();
    history.replaceState(null, '', qs ? `?${qs}` : window.location.pathname);
  }

  function applyFilters() {
    return allLines.filter(r => {
      const rowGt = r.game_type != null ? r.game_type : 2;
      return rowGt === gameTypeFilter &&
        (typeFilter === 'all' || r.type === typeFilter) &&
        (seasonFilter === 'all' || r.season === seasonFilter) &&
        (selectedTeams.length === 0 || selectedTeams.includes(r.team)) &&
        (r.toi_min >= minToi) &&
        (playerFilter == null || (r.player_ids && r.player_ids.includes(playerFilter)));
    });
  }

  function fmt(v, decimals = 1) { return v != null ? v.toFixed(decimals) : '—'; }
  function esc(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function _sd(s) { return s.normalize('NFD').replace(/\p{M}/gu, ''); }
  function toLineSlug(line) {
    const team  = line.team.toLowerCase();
    const names = line.players.split('–').map(p => {
      const parts = _sd(p.trim()).split(/\s+/);
      return (parts[parts.length - 1] || 'unknown').toLowerCase().replace(/[^a-z0-9]/g, '');
    }).sort();
    const season = line.season.slice(0,4) + '-' + line.season.slice(6);
    const gt     = line.game_type === 3 ? 'playoffs' : 'regular';
    return [team].concat(names).concat([season, gt]).join('-');
  }

  function xgfColor(v) {
    if (v == null) return '';
    if (v >= 55) return 'var(--stats-pos)';
    if (v <= 45) return 'var(--stats-neg)';
    return '';
  }

  // Build a <tr> matching Table.astro's expected output shape.
  function rowHtml(r, rank) {
    const slug = toLineSlug(r);
    const href = `/stats/lines/${slug}`;
    const teamAbbr = esc(r.team || '');
    const xgfCol = xgfColor(r.xgf_pct);

    const cells = [];
    cells.push(`<td class="tbl-td td-rk align-right">${String(rank).padStart(2, '0')}</td>`);
    cells.push(`<td class="tbl-td type-label align-left">${esc(r.players)}</td>`);
    cells.push(`<td class="tbl-td align-center"><span class="pos-badge">${esc(r.type)}</span></td>`);
    // Team cell
    cells.push(
      `<td class="tbl-td td-team align-left" data-team-abbr="${teamAbbr}">` +
      `<div class="td-team-inner">` +
      (teamAbbr ? `<img class="td-logo" src="https://assets.nhle.com/logos/nhl/svg/${teamAbbr}_light.svg" width="26" height="26" alt="${teamAbbr}" loading="lazy" onerror="this.style.display='none'" />` : '') +
      `<span class="td-abbr">${teamAbbr}</span>` +
      `</div></td>`
    );
    cells.push(`<td class="tbl-td align-center type-number">${fmt(r.toi_min)}</td>`);
    cells.push(`<td class="tbl-td align-center type-number">${r.min_per_g ?? '—'}</td>`);
    const xgfStyle = xgfCol ? ` style="color:${xgfCol}"` : '';
    cells.push(`<td class="tbl-td align-center type-number bold"${xgfStyle}>${r.xgf_pct != null ? r.xgf_pct.toFixed(1) + '%' : '—'}</td>`);
    cells.push(`<td class="tbl-td align-center type-number">${fmt(r.xgf, 2)}</td>`);
    cells.push(`<td class="tbl-td align-center type-number">${fmt(r.xga, 2)}</td>`);
    cells.push(`<td class="tbl-td align-center type-number">${fmt(r.xgf_60, 2)}</td>`);
    cells.push(`<td class="tbl-td align-center type-number">${fmt(r.xga_60, 2)}</td>`);

    return `<tr class="tbl-tr clickable" tabindex="0" data-href="${href}" role="link">${cells.join('')}</tr>`;
  }

  const wrap = document.querySelector('.tbl-wrap[data-tbl-id]');
  const tbody = wrap ? wrap.querySelector('tbody') : null;

  function renderTable() {
    if (!wrap || !tbody) return;
    const filtered = applyFilters();
    // Default sort by xgf_pct desc.
    const sorted = filtered.slice().sort((a, b) => (b.xgf_pct ?? -Infinity) - (a.xgf_pct ?? -Infinity));
    const shown = showAll ? sorted : sorted.slice(0, TOP_N);

    if (filtered.length === 0) {
      const msg = gameTypeFilter === 3
        ? 'No playoff data yet — check back during the postseason'
        : 'No lines match current filters';
      tbody.innerHTML = `<tr class="tbl-empty"><td colspan="11">${msg}</td></tr>`;
      document.getElementById('tbl-meta').textContent = '0 lines';
      document.getElementById('tbl-more-row').style.display = 'none';
      wrap.dispatchEvent(new CustomEvent('tbl:rows-changed'));
      return;
    }

    tbody.innerHTML = shown.map((r, i) => rowHtml(r, i + 1)).join('');
    document.getElementById('tbl-meta').textContent = `${shown.length} of ${filtered.length} lines`;

    const moreRow = document.getElementById('tbl-more-row');
    if (!showAll && filtered.length > TOP_N) {
      moreRow.style.display = '';
      document.getElementById('tbl-count-label').textContent = `Showing top ${TOP_N} — ${filtered.length - TOP_N} more`;
    } else {
      moreRow.style.display = 'none';
    }

    wrap.dispatchEvent(new CustomEvent('tbl:rows-changed'));
  }

  function syncUiToState() {
    document.querySelectorAll('#gametype-filter button').forEach(btn => {
      btn.classList.toggle('active', parseInt(btn.dataset.gametype) === gameTypeFilter);
    });
    document.querySelectorAll('#type-filter button').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.type === typeFilter);
    });
    const seasonSel = document.getElementById('season-filter');
    if (seasonSel) seasonSel.value = seasonFilter;
    renderTeamChips();
    const slider = document.getElementById('toi-slider');
    const label  = document.getElementById('toi-label');
    slider.step  = gameTypeFilter === 3 ? '5' : '10';
    slider.min   = gameTypeFilter === 3 ? '5' : '20';
    slider.value = minToi;
    label.textContent = minToi;
    const lede = document.getElementById('mast-lede');
    if (lede) {
      lede.innerHTML = gameTypeFilter === 3
        ? 'Forward lines (3-man) and defensive pairs at 5v5 · 2025–26 playoffs · Ranked by <span class="mono">xGoals%</span>. Minimum TOI slider filters noise.'
        : 'Forward lines (3-man) and defensive pairs at 5v5 · 2022–23 through 2025–26 regular season · Ranked by <span class="mono">xGoals%</span>. Minimum TOI slider filters noise.';
    }
  }

  function renderTeamChips() {
    const container = document.getElementById('team-chips');
    const sel = document.getElementById('team-add-select');
    if (!container) return;
    container.innerHTML = selectedTeams.map(t =>
      `<span class="team-chip">${t}<button class="team-chip-x" data-team="${t}" aria-label="Remove ${t}">×</button></span>`
    ).join('');
    container.querySelectorAll('.team-chip-x').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedTeams = selectedTeams.filter(t => t !== btn.dataset.team);
        renderTeamChips();
        updateUrl();
        renderTable();
      });
    });
    if (sel) sel.disabled = selectedTeams.length >= MAX_TEAMS;
  }

  function populateTeams() {
    const teams = [...new Set(allLines.map(r => r.team))].sort();
    const sel = document.getElementById('team-add-select');
    teams.forEach(t => {
      const opt = document.createElement('option');
      opt.value = t; opt.textContent = t;
      sel.appendChild(opt);
    });
    renderTeamChips();
  }

  function wireEvents() {
    document.querySelectorAll('#gametype-filter button').forEach(btn => {
      btn.addEventListener('click', () => {
        const gt = parseInt(btn.dataset.gametype);
        if (gt === gameTypeFilter) return;
        gameTypeFilter = gt;
        minToi = gt === 3 ? PO_DEFAULT_TOI : REG_DEFAULT_TOI;
        showAll = false;
        syncUiToState();
        updateUrl();
        renderTable();
      });
    });
    document.querySelectorAll('#type-filter button').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('#type-filter button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        typeFilter = btn.dataset.type;
        showAll = false;
        updateUrl();
        renderTable();
      });
    });
    document.getElementById('season-filter').addEventListener('change', e => {
      seasonFilter = e.target.value;
      showAll = false;
      updateUrl();
      renderTable();
    });
    document.getElementById('team-add-select').addEventListener('change', e => {
      const t = e.target.value;
      if (t && !selectedTeams.includes(t) && selectedTeams.length < MAX_TEAMS) {
        selectedTeams = [...selectedTeams, t];
        renderTeamChips();
        showAll = false;
        updateUrl();
        renderTable();
      }
      e.target.value = '';
    });
    const slider = document.getElementById('toi-slider');
    const label  = document.getElementById('toi-label');
    slider.addEventListener('input', e => {
      minToi = parseInt(e.target.value, 10);
      label.textContent = minToi;
      showAll = false;
      renderTable();
    });
    document.getElementById('tbl-show-all-btn').addEventListener('click', () => {
      showAll = true;
      document.getElementById('tbl-more-row').style.display = 'none';
      renderTable();
    });
  }

  async function init() {
    readUrlParams();
    try {
      const res = await fetch('https://api.hockeygamebot.com/v1/stats/lines');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      allLines = (await res.json()).map(r => ({
        ...r,
        min_per_g: r.games > 0 ? +(r.toi_min / r.games).toFixed(1) : null,
      }));
    } catch (err) {
      document.getElementById('loading-state').innerHTML =
        `<p style="font-family:var(--mono);font-size:13px;color:var(--red)">Failed to load: ${err.message}</p>`;
      return;
    }
    document.getElementById('loading-state').style.display = 'none';
    document.getElementById('main-content').style.display = 'block';
    populateTeams();
    syncUiToState();
    wireEvents();
    renderTable();
  }

  init();
})();
</script>
</body>
</html>
