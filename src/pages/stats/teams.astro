---
// HockeyGameBot — /stats/teams — League-wide NHL Team Leaderboard
// =============================================================================
// FIRST CONSUMER of Table.astro (the new shared table component shipped on
// 2026-05-27). Mirrors the pattern used in /stats/skaters for the page shell
// (masthead + filter toolbar + table) but delegates ALL row rendering, sort
// behavior, sticky-header, mobile scroll, and PNG export to <Table>.
//
// Data sourced from api.hockeygamebot.com/v1/stats/teams (R2-backed JSON).
// Pipeline: hgb-analytics/scripts/export_teams_json.py → upload_stats_r2.py.
//
// CANONICAL SPEC: hgb-docs/TABLES.md
// TICKET:         prompts/2026-05-27-teams-stats-page.md
// =============================================================================

import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import StatsSEO from '../../components/StatsSEO.astro';
import Table from '../../components/Table.astro';

interface TeamRow {
  team_abbrev: string;
  team_name_full: string;
  team_name_city: string;
  team_name_nickname: string;
  division: string;
  conference: string;
  season: string;
  gp: number;
  wins: number;
  losses: number;
  ot_losses: number;
  points: number;
  gf: number;
  ga: number;
  xgf_all: number;
  xga_all: number;
  xgf_pct_all: number;
  toi_all_sec: number;
  toi_5v5_sec: number;
  gf_5v5: number;
  ga_5v5: number;
  gf_pct_5v5: number;
  xgf_5v5: number;
  xga_5v5: number;
  xgf_pct_5v5: number;
  sf_5v5: number;
  sa_5v5: number;
  sf_pct_5v5: number;
  sh_pct_5v5: number;
  sv_pct_5v5: number;
  pdo_5v5: number;
  pp_pct: number;
  pk_pct: number;
  pp_xgf_60: number;
  pk_xga_60: number;
}

// ── R2 data fetch ─────────────────────────────────────────────────────────────
// Defensive: the /v1/stats/teams endpoint is part of the in-flight pipeline
// ticket. If the response is missing or malformed we fall back to empty
// arrays so the SSR build doesn't crash. The on-page UI will show "no data"
// until the pipeline ships.
let _teamsData: { regular: TeamRow[]; playoffs: TeamRow[] } = { regular: [], playoffs: [] };
try {
  const res = await fetch('https://api.hockeygamebot.com/v1/stats/teams');
  if (res.ok) {
    const parsed = await res.json();
    _teamsData = {
      regular: Array.isArray(parsed?.regular) ? parsed.regular : [],
      playoffs: Array.isArray(parsed?.playoffs) ? parsed.playoffs : [],
    };
  }
} catch {
  // network/parse failure — fall through to empty arrays
}
const mockTeamsReg      = _teamsData.regular  as TeamRow[];
const mockTeamsPlayoff  = _teamsData.playoffs as TeamRow[];

// ── Resolve initial filter state from URL (build-time safe defaults) ────────
// We can read URL params here too so SSR-default lookups don't blink; the
// inline <script> below still owns runtime re-renders for chip clicks.
const url = new URL(Astro.url.href);
const initialGameType = url.searchParams.get('game_type') === 'playoffs' ? 'playoffs' : 'regular';
const initialDisplay  = url.searchParams.get('display')  === 'per60'    ? 'per60'    : 'totals';
const initialStrength = url.searchParams.get('strength') === '5v5'      ? '5v5'      : 'all';
const initialConf     = url.searchParams.get('conf')     ?? 'all';
const initialDiv      = url.searchParams.get('div')      ?? 'all';

// Extract available seasons from combined data, newest first.
const availableSeasons = [...new Set([
  ...mockTeamsReg.map(t => t.season),
  ...mockTeamsPlayoff.map(t => t.season),
])].sort().reverse();
const defaultSeason = availableSeasons[0] ?? '2025-26';
const initialSeason = url.searchParams.get('season') ?? defaultSeason;

const baseTeams = (initialGameType === 'playoffs' ? mockTeamsPlayoff : mockTeamsReg)
  .filter(t => t.season === initialSeason);

// ── Per-60 + strength transform ─────────────────────────────────────────────
// Fix 3 (Round 3, 2026-05-27): the previous build only crossed (gameType × display)
// = 4 variants. The strength toggle now actually swaps which stat-set is rendered,
// so we cross (gameType × strength × display) = 8 variants. For the "all"
// strength bucket the mock data exposes `gf`/`ga`/`xgf_5v5`/`xga_5v5`/`sf_5v5`
// (xG and SF only have 5v5 fields in the mock — when teams.json ships those
// will be backed by all-situations columns too; the placeholder behavior is to
// fall back to the 5v5 number for now so the toggle visibly does something).
function toRow(
  t: TeamRow,
  display: 'totals' | 'per60',
  strength: 'all' | '5v5',
): TeamRow & {
  rank: number;
  record: string;
  season: string;
  gf_display: number;
  ga_display: number;
  xgf_display: number;
  xga_display: number;
  gf_pct: number;
  xgf_pct: number;
  sf_pct: number;
} {
  const is5v5 = strength === '5v5';
  const isPer60 = display === 'per60';
  // Use all-sit TOI as per-60 denominator when viewing all-sit numbers.
  const toiSec = is5v5 ? t.toi_5v5_sec : (t.toi_all_sec ?? t.toi_5v5_sec);
  const hours = toiSec / 3600;

  // Pick the source values for each metric based on strength state.
  const gfRaw  = is5v5 ? t.gf_5v5 : t.gf;
  const gaRaw  = is5v5 ? t.ga_5v5 : t.ga;
  // xGF/xGA: real all-sit values from pipeline; fall back to 5v5 if field absent
  // (old cached JSON from before the pipeline fix).
  const xgfRaw = is5v5
    ? t.xgf_5v5
    : (t.xgf_all ?? t.xgf_5v5);
  const xgaRaw = is5v5
    ? t.xga_5v5
    : (t.xga_all ?? t.xga_5v5);

  // Derived rate stats
  const gfPct  = is5v5 ? t.gf_pct_5v5 : +(gfRaw / (gfRaw + gaRaw) || 0.5).toFixed(3);
  const xgfPct = is5v5
    ? t.xgf_pct_5v5
    : (t.xgf_pct_all ?? +(xgfRaw / (xgfRaw + xgaRaw) || 0.5).toFixed(3));
  // SF%: all-sit not yet in pipeline; use 5v5 value for both buckets
  const sfPct  = t.sf_pct_5v5;

  return {
    ...t,
    rank: 0, // assigned after sort
    record: `${t.wins}-${t.losses}-${t.ot_losses}`,
    season: t.season,
    // Per-60 versions of counting stats. Both 5v5 and all-sit divide by the
    // same `hours` for now — when teams.json ships an all-situations TOI it
    // should be used as the denominator for the all-sit branch.
    gf_display:  isPer60 ? +(gfRaw  / hours).toFixed(2) : gfRaw,
    ga_display:  isPer60 ? +(gaRaw  / hours).toFixed(2) : gaRaw,
    xgf_display: isPer60 ? +(xgfRaw / hours).toFixed(2) : +xgfRaw.toFixed(1),
    xga_display: isPer60 ? +(xgaRaw / hours).toFixed(2) : +xgaRaw.toFixed(1),
    // Strength-aware rate columns. The Table consumes these by key so we keep
    // the original `*_5v5` keys (the columns array still reads from those)
    // and ALSO expose new neutral keys for clients that want the bucketed
    // value. We overwrite the *_5v5 fields with the strength-appropriate
    // value so existing column lookups Just Work without renaming.
    gf_pct_5v5:  gfPct,
    xgf_pct_5v5: xgfPct,
    sf_pct_5v5:  sfPct,
    gf_pct:  gfPct,
    xgf_pct: xgfPct,
    sf_pct:  sfPct,
  };
}

// ── Apply non-toggle filters at build time ──────────────────────────────────
// baseTeams is already filtered by season (see above).
let filtered = baseTeams;
if (initialConf !== 'all') filtered = filtered.filter(t => t.conference.toLowerCase().startsWith(initialConf.toLowerCase().charAt(0)));
if (initialDiv  !== 'all') filtered = filtered.filter(t => t.division.toLowerCase() === initialDiv.toLowerCase());

// ── Pre-sort by xGF% desc + rank-assign ─────────────────────────────────────
const rows = filtered
  .map(t => toRow(t, initialDisplay, initialStrength))
  .sort((a, b) => b.xgf_pct_5v5 - a.xgf_pct_5v5)
  .map((r, i) => ({ ...r, rank: i + 1 }));

const teamCount = rows.length;
const totalCount = baseTeams.length;
const timestamp = new Date().toISOString().slice(0, 10);

// ── Client-side data payload (Issue 7 + Fix 3 / Round 3) ────────────────────
// Ship every (gameType × strength × display) permutation = 8 variants. The
// client script swaps the visible row set in place when the user changes any
// toggle — no page reload. This is what makes Per60 / game type / strength
// chips actually change data instead of just decorating a URL.
const clientPayload = {
  regular: {
    all: {
      totals: mockTeamsReg.map(t => toRow(t, 'totals', 'all')),
      per60:  mockTeamsReg.map(t => toRow(t, 'per60',  'all')),
    },
    fivev5: {
      totals: mockTeamsReg.map(t => toRow(t, 'totals', '5v5')),
      per60:  mockTeamsReg.map(t => toRow(t, 'per60',  '5v5')),
    },
  },
  playoffs: {
    all: {
      totals: mockTeamsPlayoff.map(t => toRow(t, 'totals', 'all')),
      per60:  mockTeamsPlayoff.map(t => toRow(t, 'per60',  'all')),
    },
    fivev5: {
      totals: mockTeamsPlayoff.map(t => toRow(t, 'totals', '5v5')),
      per60:  mockTeamsPlayoff.map(t => toRow(t, 'per60',  '5v5')),
    },
  },
};

// ── Column definitions (consumed by <Table>) ────────────────────────────────
// Threshold callback: ≥0.55 green, ≤0.45 red. PP%/PK% have higher midpoints
// so they don't use the universal threshold — they're informational only.
const pctColor = (v: number | null | undefined, _row: any, tok?: { pos: string; neg: string }): string | undefined => {
  if (v == null) return undefined;
  if (v >= 0.55) return tok?.pos;
  if (v <= 0.45) return tok?.neg;
  return undefined;
};

const fmtPct = (v: number | null | undefined): string =>
  v == null ? '—' : (v * 100).toFixed(1) + '%';

const fmtFloat1 = (v: number | null | undefined): string =>
  v == null ? '—' : Number(v).toFixed(1);

const fmtInt = (v: number | null | undefined): string =>
  v == null ? '—' : String(Math.round(Number(v)));

// Render number (count vs rate) based on display mode at build.
const fmtCount = (v: number | null | undefined): string => {
  if (v == null) return '—';
  // If it's already a small decimal (per-60 transformed), show one decimal;
  // otherwise show as integer.
  return Number.isInteger(v) ? String(v) : Number(v).toFixed(2);
};

// ── Per-60 label helper (Fix 2 / Round 3) ──────────────────────────────────
// Counting-stat columns swap their label between e.g. "GF" and "GF/60" based
// on the active display mode. Percentage columns (GF%, xGF%, SF%, PP%, PK%)
// are already rates — they never change label. The label list lives in the
// columns array (SSR initial paint) AND in the client-side `LABEL_MAPS`
// constant below — keep both in sync.
const labelFor = (base: string, display: 'totals' | 'per60'): string =>
  display === 'per60' ? `${base}/60` : base;

// ── Season formatter ────────────────────────────────────────────────────────
// Pipeline writes "2025-26"; display as "25-26" to save column width.
const fmtSeason = (v: any): string => {
  const s = String(v ?? '');
  const m = s.match(/^(\d{2})(\d{2})-(\d{2})$/);  // "2025-26"
  return m ? `${m[2]}-${m[3]}` : s;
};

// Column order: identity → percentages (the territorial story) → raw counts → special teams
// Percentages lead because they're the first question: "who controlled play?"
// Raw counts (GF, GA, xGF, xGA) follow as context. Per-60 toggle transforms them.
// SF% renamed CF% — correct analytics abbreviation (Corsi For %).
const columns = [
  {
    key: 'rank',
    label: '#',
    type: 'rank' as const,
    sortable: false,
  },
  {
    key: 'team_abbrev',
    label: 'Team',
    type: 'team' as const,
  },
  {
    key: 'season',
    label: 'Season',
    type: 'number' as const,
    format: fmtSeason,
  },
  {
    key: 'gp',
    label: 'GP',
    type: 'number' as const,
  },
  {
    key: 'record',
    label: 'Record',
    type: 'number' as const,
  },
  // ── Percentages first — the territorial story ─────────────────────────────
  {
    key: 'gf_pct_5v5',
    label: 'GF%',
    type: 'number' as const,
    format: fmtPct,
    color: pctColor,
  },
  {
    key: 'xgf_pct_5v5',
    label: 'xGF%',
    type: 'number' as const,
    format: fmtPct,
    color: pctColor,
    bold: true,
  },
  {
    key: 'sf_pct_5v5',
    label: 'CF%',
    type: 'number' as const,
    format: fmtPct,
    color: pctColor,
  },
  // ── Raw counts — context behind the percentages ───────────────────────────
  {
    key: 'gf_display',
    label: labelFor('GF', initialDisplay),
    type: 'number' as const,
    format: fmtCount,
  },
  {
    key: 'ga_display',
    label: labelFor('GA', initialDisplay),
    type: 'number' as const,
    format: fmtCount,
  },
  {
    key: 'xgf_display',
    label: labelFor('xGF', initialDisplay),
    type: 'number' as const,
    format: fmtFloat1,
  },
  {
    key: 'xga_display',
    label: labelFor('xGA', initialDisplay),
    type: 'number' as const,
    format: fmtFloat1,
  },
  // ── Special teams ─────────────────────────────────────────────────────────
  {
    key: 'pp_pct',
    label: 'PP%',
    type: 'number' as const,
    format: fmtPct,
  },
  {
    key: 'pk_pct',
    label: 'PK%',
    type: 'number' as const,
    format: fmtPct,
  },
];

const pageDescription = 'League-wide NHL team leaderboard — sort all 32 teams by xGF%, GF%, SF%, and special-teams stats. 5v5 + all-situations aggregates for the 2025-26 season.';
---
<!doctype html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <StatsSEO
    title="NHL Team Stats — HockeyGameBot"
    description={pageDescription}
  />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/favicon-180x180.png" />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:        #EFEEE8;
      --ink:       #0d0d14;
      --red:       #E8002D;
      --surface:   #FFFFFF;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04:    rgba(13,13,20,0.04);
      --ink-06:    rgba(13,13,20,0.06);
      --ink-10:    rgba(13,13,20,0.10);
      --ink-14:    rgba(13,13,20,0.14);
      --ink-20:    rgba(13,13,20,0.20);
      --ink-32:    rgba(13,13,20,0.32);
      --ink-48:    rgba(13,13,20,0.48);
      --ink-56:    rgba(13,13,20,0.56);
      --ink-72:    rgba(13,13,20,0.72);
      --display:   'Barlow Condensed', sans-serif;
      --body:      'Barlow', sans-serif;
      --mono:      'JetBrains Mono', monospace;
      --stats-pos: #166534;
      --stats-neg: #991b1b;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }

    /* ── Masthead ───────────────────────────────────────────────────────── */
    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1280px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
      margin-bottom: 20px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-eyebrow { font-family: var(--mono); font-weight: 500; font-size: 11px; letter-spacing: 0.12em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px);
      text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px; }
    .mast-headline em { color: var(--red); font-style: normal; }
    .mast-lede { font-size: 13.5px; line-height: 1.6; color: var(--ink-56); max-width: 720px; }

    /* ── Layout ─────────────────────────────────────────────────────────── */
    .wrap { max-width: 1280px; margin: 0 auto; padding: 0 32px 80px; }

    /* ── Section header + toolbar ───────────────────────────────────────── */
    .lb-section { padding: 40px 0 0; position: relative; }
    .lb-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px;
      margin-bottom: 14px; flex-wrap: wrap; }
    .lb-title { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px);
      text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
    .lb-meta { font-family: var(--mono); font-size: 10.5px; color: var(--ink-32);
      letter-spacing: 0.12em; text-transform: uppercase; }

    /* ── Filter chip toolbar ─────────────────────────────────────────────── */
    .lb-controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
    .btn-group { display: inline-flex; border: 1px solid var(--ink-14); }
    .btn-group button { background: var(--surface); border: none; border-right: 1px solid var(--ink-14);
      padding: 6px 14px; cursor: pointer; font-family: var(--body); font-weight: 600;
      font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--ink-48); transition: background 0.1s, color 0.1s; }
    .btn-group button:last-child { border-right: none; }
    .btn-group button.active { background: var(--ink); color: var(--bg); }
    .btn-group button:hover:not(.active) { background: var(--ink-06); color: var(--ink); }
    select.lb-select { background: var(--surface); border: 1px solid var(--ink-14); padding: 6px 10px;
      font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em;
      color: var(--ink); cursor: pointer; outline: none; }
    .lb-spacer { flex: 1 1 auto; }
    #team-search { background: var(--surface); border: 1px solid var(--ink-14); padding: 6px 10px;
      font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em;
      color: var(--ink); outline: none; width: 180px; }
    #team-search::placeholder { color: var(--ink-32); font-weight: 400; }

    /* ── Footer ─────────────────────────────────────────────────────────── */
    .lb-footer { text-align: center; margin-top: 56px; color: var(--ink-32);
      font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }

    /* ── Responsive masthead ────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .mast-inner { padding: 28px 20px; }
      .mast-card  { padding: 24px 20px 20px; }
      .wrap { padding: 0 20px 60px; }
      #team-search { width: 140px; }
    }
    @media (max-width: 480px) {
      .mast-inner { padding: 20px 16px; }
      .mast-card  { padding: 18px 14px 16px; }
      .wrap { padding: 0 16px 48px; }
    }
  </style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<!-- MASTHEAD -->
<section class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div class="mast-eyebrow"><span class="pip"></span> HGB Stats / Teams</div>
      <div>{totalCount} teams · 2025–26 · {timestamp}</div>
    </div>
    <div class="mast-card">
      <h1 class="mast-headline">NHL Team Stats</h1>
      <p class="mast-lede">Forward lines, defensive pairs, and team-level 5v5 + all-situations aggregates. Sort by any column.</p>
    </div>
  </div>
</section>

<main class="wrap">

  <section class="lb-section">
    <div class="lb-head">
      <span class="lb-title">Team Leaderboard</span>
      <span class="lb-meta" id="lb-count">{teamCount} teams · default sort: xGF% desc</span>
    </div>

    <!-- FILTER TOOLBAR -->
    <div class="lb-controls">
      <div class="btn-group" id="gametype-filter">
        <button class={initialGameType === 'regular'  ? 'active' : ''} data-gametype="regular">Regular Season</button>
        <button class={initialGameType === 'playoffs' ? 'active' : ''} data-gametype="playoffs">Playoffs</button>
      </div>
      <div class="btn-group" id="strength-filter">
        <button class={initialStrength === 'all' ? 'active' : ''} data-strength="all">All</button>
        <button class={initialStrength === '5v5' ? 'active' : ''} data-strength="5v5">5v5</button>
      </div>
      <div class="btn-group" id="display-filter">
        <button class={initialDisplay === 'totals' ? 'active' : ''} data-display="totals">Totals</button>
        <button class={initialDisplay === 'per60'  ? 'active' : ''} data-display="per60">Per 60</button>
      </div>
      <select class="lb-select" id="conf-filter">
        <option value="all"  selected={initialConf === 'all'}>All Conferences</option>
        <option value="east" selected={initialConf === 'east'}>East</option>
        <option value="west" selected={initialConf === 'west'}>West</option>
      </select>
      <select class="lb-select" id="div-filter">
        <option value="all"          selected={initialDiv === 'all'}>All Divisions</option>
        <option value="metropolitan" selected={initialDiv === 'metropolitan'}>Metro</option>
        <option value="atlantic"     selected={initialDiv === 'atlantic'}>Atlantic</option>
        <option value="central"      selected={initialDiv === 'central'}>Central</option>
        <option value="pacific"      selected={initialDiv === 'pacific'}>Pacific</option>
      </select>
      <select class="lb-select" id="season-filter">
        {availableSeasons.map(s => (
          <option value={s} selected={s === initialSeason}>{s}</option>
        ))}
      </select>
      <div class="lb-spacer"></div>
      <input type="search" id="team-search" placeholder="Search team…" autocomplete="off" />
    </div>

    <Table
      columns={columns}
      rows={rows}
      rowHref={(r) => `/teams/${r.team_abbrev.toLowerCase()}`}
      defaultSort={{ column: 'xgf_pct_5v5', direction: 'desc' }}
      scrollable
      maxHeight={760}
      exportFilename="hgb-team-stats.png"
      exportTitle="NHL Team Stats"
      ariaLabel="NHL teams leaderboard for 2025-26"
    />
  </section>

</main>

<footer class="lb-footer">HOCKEYGAMEBOT.COM · HGB STATS · 2025–2026 · TEAMS V1</footer>

<!-- Client-side data: both datasets × both display modes; the script below
     swaps in-place when toggles change so no page reload is needed. -->
<script type="application/json" id="teams-data" set:html={JSON.stringify(clientPayload)}></script>

<script is:inline src="/js/table-export.js"></script>

<script>
  // ── /stats/teams — fully client-side filter/toggle pipeline ──────────────
  // Every toggle (game type, per-60, strength, conf, div, search) now swaps
  // the tbody contents IN PLACE. Zero page reloads — see issue #7. URL params
  // mirror state via `history.replaceState` so the page is still shareable.
  //
  // Data flow on any toggle change:
  //   1. update `state`
  //   2. mirror state → URL
  //   3. pick the right dataset from `payload[gameType][display]`
  //   4. apply conf/div/search filters
  //   5. re-render tbody HTML
  //   6. dispatch `tbl:rows-changed` on the wrap so Table.astro re-snapshots
  //      its sort state and re-applies the active sort
  (function() {
    'use strict';

    type GameType = 'regular' | 'playoffs';
    type Display  = 'totals' | 'per60';
    type Strength = 'all' | '5v5';
    interface PayloadRow {
      team_abbrev: string; team_name_full: string; team_name_city: string; team_name_nickname: string;
      division: string; conference: string; season: string;
      gp: number; wins: number; losses: number; ot_losses: number; points: number;
      gf: number; ga: number;
      xgf_all?: number; xga_all?: number; xgf_pct_all?: number;
      toi_all_sec?: number; toi_5v5_sec: number;
      gf_5v5: number; ga_5v5: number; gf_pct_5v5: number;
      xgf_5v5: number; xga_5v5: number; xgf_pct_5v5: number;
      sf_5v5: number; sa_5v5: number; sf_pct_5v5: number;
      sh_pct_5v5: number; sv_pct_5v5: number; pdo_5v5: number;
      pp_pct: number; pk_pct: number; pp_xgf_60: number; pk_xga_60: number;
      rank: number; record: string;
      gf_display: number; ga_display: number; xgf_display: number; xga_display: number;
    }
    // Fix 3 (Round 3): payload is now 8 variants (gameType × strength × display)
    // The strength key is `fivev5` (not `5v5`) because identifiers can't start
    // with a digit — the toggle button still reads "5v5" to the user.
    interface Payload {
      regular: {
        all:    { totals: PayloadRow[]; per60: PayloadRow[] };
        fivev5: { totals: PayloadRow[]; per60: PayloadRow[] };
      };
      playoffs: {
        all:    { totals: PayloadRow[]; per60: PayloadRow[] };
        fivev5: { totals: PayloadRow[]; per60: PayloadRow[] };
      };
    }

    // ── Reactive label map (Fix 2 / Round 3) ────────────────────────────
    // Counting-stat column labels swap based on display mode. Percentage
    // columns stay the same — they're already rates. Keys MUST match the
    // column `key`s in the frontmatter columns array.
    const LABEL_MAPS: Record<Display, Record<string, string>> = {
      totals: {
        gf_display:  'GF',
        ga_display:  'GA',
        xgf_display: 'xGF',
        xga_display: 'xGA',
      },
      per60: {
        gf_display:  'GF/60',
        ga_display:  'GA/60',
        xgf_display: 'xGF/60',
        xga_display: 'xGA/60',
      },
    };

    const wrap = document.querySelector<HTMLElement>('.tbl-wrap[data-tbl-id]');
    if (!wrap) return;
    const tbody = wrap.querySelector<HTMLTableSectionElement>('tbody');
    if (!tbody) return;

    const dataEl = document.getElementById('teams-data') as HTMLScriptElement | null;
    if (!dataEl) return;
    let payload: Payload;
    try {
      payload = JSON.parse(dataEl.textContent || '{}');
    } catch (e) {
      console.error('[teams] failed to parse payload', e);
      return;
    }

    const params = new URLSearchParams(window.location.search);

    // Derive available seasons from payload (newest first) for dropdown wiring.
    const allSeasons: string[] = [...new Set([
      ...payload.regular.all.totals.map((r: PayloadRow) => r.season),
      ...payload.playoffs.all.totals.map((r: PayloadRow) => r.season),
    ] as string[])].sort().reverse();
    const defaultSeason = allSeasons[0] ?? '2025-26';

    const state = {
      gameType: (params.get('game_type') === 'playoffs' ? 'playoffs' : 'regular') as GameType,
      display:  (params.get('display')  === 'per60'    ? 'per60'    : 'totals')   as Display,
      strength: (params.get('strength') === '5v5'      ? '5v5'      : 'all')      as Strength,
      conf:     params.get('conf') ?? 'all',
      div:      params.get('div')  ?? 'all',
      season:   params.get('season') ?? defaultSeason,
      search:   '',
    };

    function writeUrl(): void {
      const p = new URLSearchParams();
      if (state.gameType !== 'regular')      p.set('game_type', state.gameType);
      if (state.display  !== 'totals')       p.set('display',  state.display);
      if (state.strength !== 'all')          p.set('strength', state.strength);
      if (state.conf     !== 'all')          p.set('conf',     state.conf);
      if (state.div      !== 'all')          p.set('div',      state.div);
      if (state.season   !== defaultSeason)  p.set('season',   state.season);
      const qs = p.toString();
      history.replaceState(null, '', qs ? `?${qs}` : window.location.pathname);
    }

    // ── Formatters (mirror the build-time helpers in the frontmatter) ─────
    const fmtSeasonDisplay = (s: string): string => {
      const m = s.match(/^(\d{2})(\d{2})-(\d{2})$/);
      return m ? `${m[2]}-${m[3]}` : s;
    };
    const fmtPct = (v: number | null | undefined) =>
      v == null ? '—' : (v * 100).toFixed(1) + '%';
    const fmtFloat1 = (v: number | null | undefined) =>
      v == null ? '—' : Number(v).toFixed(1);
    const fmtCount = (v: number | null | undefined) => {
      if (v == null) return '—';
      return Number.isInteger(v) ? String(v) : Number(v).toFixed(2);
    };
    const formatRank = (n: number) => String(n).padStart(2, '0');
    function pctColor(v: number | null | undefined): string | undefined {
      if (v == null) return undefined;
      if (v >= 0.55) return 'var(--stats-pos)';
      if (v <= 0.45) return 'var(--stats-neg)';
      return undefined;
    }
    function esc(s: string): string {
      return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'} as Record<string, string>)[c]);
    }

    // ── Row HTML builder — must match Table.astro's server-side output ─────
    function rowHtml(r: PayloadRow): string {
      const href = `/teams/${r.team_abbrev.toLowerCase()}`;
      const abbr = esc(r.team_abbrev);
      const cells: string[] = [];

      // Rank
      cells.push(`<td class="tbl-td td-rk align-right">${formatRank(r.rank)}</td>`);

      // Team cell — mirrors Table.astro's stacked city/nickname lockup so
      // SSR rows and JS-rendered rows are visually identical.
      const city = esc(r.team_name_city);
      const nick = esc(r.team_name_nickname);
      const hasStack = !!(city && nick);
      const teamInner = hasStack
        ? `<div class="td-team-meta"><span class="td-team-city">${city}</span><span class="td-team-nick">${nick}</span></div>`
        : `<span class="td-abbr">${abbr}</span>`;
      cells.push(
        `<td class="tbl-td td-team align-left" data-team-abbr="${abbr}" data-team-city="${city}" data-team-nick="${nick}">` +
        `<div class="td-team-inner">` +
        `<img class="td-logo" src="https://assets.nhle.com/logos/nhl/svg/${abbr}_light.svg" ` +
        `width="26" height="26" alt="${abbr}" loading="lazy" onerror="this.style.display='none'" />` +
        teamInner +
        `</div></td>`
      );

      // Numeric cells — ORDER MUST match the columns[] array in the frontmatter.
      // Current order: Season, GP, Record, GF%, xGF%, CF%, GF, GA, xGF, xGA, PP%, PK%
      const numericCells: Array<{ text: string; bold?: boolean; color?: string }> = [
        { text: fmtSeasonDisplay(r.season) },
        { text: String(r.gp) },
        { text: r.record },
        // ── Percentages first ─────────────────────────────────────────────────
        { text: fmtPct(r.gf_pct_5v5),  color: pctColor(r.gf_pct_5v5) },
        { text: fmtPct(r.xgf_pct_5v5), bold: true, color: pctColor(r.xgf_pct_5v5) },
        { text: fmtPct(r.sf_pct_5v5),  color: pctColor(r.sf_pct_5v5) },
        // ── Raw counts ────────────────────────────────────────────────────────
        { text: fmtCount(r.gf_display) },
        { text: fmtCount(r.ga_display) },
        { text: fmtFloat1(r.xgf_display) },
        { text: fmtFloat1(r.xga_display) },
        // ── Special teams ─────────────────────────────────────────────────────
        { text: fmtPct(r.pp_pct) },
        { text: fmtPct(r.pk_pct) },
      ];
      // Number cells are center-aligned per the 2026-05-27 design call —
      // mirrors `defaultAlign()` in Table.astro.
      for (const c of numericCells) {
        const cls = ['tbl-td', 'align-center', 'type-number', c.bold ? 'bold' : ''].filter(Boolean).join(' ');
        const style = c.color ? ` style="color:${c.color}"` : '';
        cells.push(`<td class="${cls}"${style}>${esc(c.text)}</td>`);
      }

      // TR — clickable, with data attributes used by client-side filters
      const trAttrs = [
        `class="tbl-tr clickable"`,
        `tabindex="0"`,
        `data-href="${href}"`,
        `role="link"`,
        // Search/filter metadata (Issue 6) — match against any of these
        `data-team-abbrev="${esc(r.team_abbrev.toLowerCase())}"`,
        `data-team-full="${esc(r.team_name_full.toLowerCase())}"`,
        `data-team-city="${esc(r.team_name_city.toLowerCase())}"`,
        `data-team-nickname="${esc(r.team_name_nickname.toLowerCase())}"`,
        `data-conference="${esc(r.conference.toLowerCase())}"`,
        `data-division="${esc(r.division.toLowerCase())}"`,
      ].join(' ');

      return `<tr ${trAttrs}>${cells.join('')}</tr>`;
    }

    // Fix 2 (Round 3): apply the active per-60/totals label set to the table
    // header. Reads from LABEL_MAPS and uses the Table.astro-exposed updater
    // (`window.HGB_Table.updateColumnLabels`) so the change is in-place.
    function applyLabels(): void {
      const tblId = wrap!.dataset.tblId;
      const updater = (window as any).HGB_Table?.updateColumnLabels;
      if (!tblId || typeof updater !== 'function') return;
      updater(tblId, LABEL_MAPS[state.display]);
    }

    // ── Render the active view ────────────────────────────────────────────
    function render(): void {
      // Fix 3 (Round 3): pick (gameType × strength × display) — strength uses
      // the `fivev5` key in the payload to keep identifiers valid.
      const strengthKey = state.strength === '5v5' ? 'fivev5' : 'all';
      const dataset = payload[state.gameType][strengthKey][state.display];
      // Apply season + conf + div filters
      let filtered = dataset.filter(r => {
        if (r.season !== state.season) return false;
        if (state.conf !== 'all') {
          // matches if conference starts with the filter letter (e/w)
          const confLetter = state.conf.charAt(0).toLowerCase();
          if (!r.conference.toLowerCase().startsWith(confLetter)) return false;
        }
        if (state.div !== 'all') {
          if (r.division.toLowerCase() !== state.div.toLowerCase()) return false;
        }
        return true;
      });
      // Re-sort by xGF% desc + reassign ranks so the # column is contiguous
      filtered = filtered
        .slice()
        .sort((a, b) => b.xgf_pct_5v5 - a.xgf_pct_5v5)
        .map((r, i) => ({ ...r, rank: i + 1 }));

      tbody!.innerHTML = filtered.map(rowHtml).join('');
      // Sync header labels with the active display mode (Fix 2 / Round 3).
      applyLabels();
      // Tell Table.astro to re-snapshot rows + re-apply its sort
      wrap!.dispatchEvent(new CustomEvent('tbl:rows-changed'));
      applySearch(); // re-apply search filter on the new row set
      updateCount(filtered.length, dataset.length);
    }

    function updateCount(visible: number, total: number): void {
      const countEl = document.getElementById('lb-count');
      if (!countEl) return;
      if (state.search) {
        countEl.textContent = `${visible} of ${total} teams · search: "${state.search}"`;
      } else if (visible < total) {
        countEl.textContent = `${visible} of ${total} teams · default sort: xGF% desc`;
      } else {
        countEl.textContent = `${total} teams · default sort: xGF% desc`;
      }
    }

    // ── Search (Issue 6) — match across abbrev + full + city + nickname ───
    function applySearch(): void {
      const q = state.search;
      const trs = tbody!.querySelectorAll<HTMLTableRowElement>('tr.tbl-tr');
      let visible = 0;
      trs.forEach(tr => {
        if (!q) {
          tr.style.display = '';
          visible++;
          return;
        }
        const haystack = [
          tr.dataset.teamAbbrev ?? '',
          tr.dataset.teamFull ?? '',
          tr.dataset.teamCity ?? '',
          tr.dataset.teamNickname ?? '',
        ].join(' ');
        const matches = haystack.includes(q);
        tr.style.display = matches ? '' : 'none';
        if (matches) visible++;
      });
      updateCount(visible, trs.length);
    }

    // ── Toggle wiring (all client-side, no reloads) ───────────────────────
    function setActiveButton(groupSel: string, attr: string, value: string) {
      document.querySelectorAll<HTMLButtonElement>(`${groupSel} button`).forEach(b => {
        b.classList.toggle('active', b.dataset[attr] === value);
      });
    }

    document.querySelectorAll<HTMLButtonElement>('#gametype-filter button').forEach(btn => {
      btn.addEventListener('click', () => {
        const gt = btn.dataset.gametype as GameType;
        if (gt === state.gameType) return;
        state.gameType = gt;
        setActiveButton('#gametype-filter', 'gametype', gt);
        writeUrl();
        render();
      });
    });

    document.querySelectorAll<HTMLButtonElement>('#display-filter button').forEach(btn => {
      btn.addEventListener('click', () => {
        const d = btn.dataset.display as Display;
        if (d === state.display) return;
        state.display = d;
        setActiveButton('#display-filter', 'display', d);
        writeUrl();
        render();
      });
    });

    // Strength toggle — Fix 3 (Round 3): now actually swaps the underlying
    // dataset (all-situations vs 5v5) instead of only decorating the URL.
    document.querySelectorAll<HTMLButtonElement>('#strength-filter button').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = btn.dataset.strength as Strength;
        if (s === state.strength) return;
        state.strength = s;
        setActiveButton('#strength-filter', 'strength', s);
        writeUrl();
        render();
      });
    });

    const confSel = document.getElementById('conf-filter') as HTMLSelectElement | null;
    if (confSel) confSel.addEventListener('change', () => {
      state.conf = confSel.value;
      writeUrl();
      render();
    });
    const divSel = document.getElementById('div-filter') as HTMLSelectElement | null;
    if (divSel) divSel.addEventListener('change', () => {
      state.div = divSel.value;
      writeUrl();
      render();
    });

    const seasonSel = document.getElementById('season-filter') as HTMLSelectElement | null;
    if (seasonSel) seasonSel.addEventListener('change', () => {
      state.season = seasonSel.value;
      writeUrl();
      render();
    });

    // Search — pure DOM filter, no reload
    const searchInput = document.getElementById('team-search') as HTMLInputElement | null;
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        state.search = searchInput.value.trim().toLowerCase();
        applySearch();
      });
    }

    // Initial paint: if URL params don't match the SSR-rendered initial state
    // (e.g., user lands on `?display=per60` but the static build is `totals`),
    // re-render to honor the URL. Always-render approach is simpler than
    // computing diffs and is fast (<5ms for 32 rows).
    render();
  })();
</script>

</body>
</html>
