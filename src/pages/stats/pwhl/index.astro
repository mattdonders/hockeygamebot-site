---
import StatsLayout from '../../../layouts/StatsLayout.astro';
import StatsMasthead from '../../../components/StatsMasthead.astro';
import PwhlSkaterTable from '../../../components/react/PwhlSkaterTable';
import { loadPwhlPlayers } from '../../../lib/stats-loader';

const players = loadPwhlPlayers();
const totalCount = players.length;
---

<StatsLayout
  title="PWHL Player Stats — HockeyGameBot"
  description="PWHL skater stats including goals, assists, points, and more. 2024–25 season."
  ogImage="/og/default.png"
  currentPath={Astro.url.pathname}
>

<StatsMasthead slot="mast" eyebrow="HGB Stats · PWHL" statLine={`${totalCount} skaters · 2024–25`}>
  <Fragment slot="headline">PWHL Player Stats</Fragment>
  <Fragment slot="lede">2024–25 season skater stats: goals, assists, points, power-play production, and estimated individual expected goals.</Fragment>
</StatsMasthead>

<main class="wrap">
  <section class="lb-section">
    <div class="lb-head">
      <span class="lb-title">Skater Leaderboard</span>
    </div>
    <PwhlSkaterTable data={players} client:load />
  </section>
</main>

</StatsLayout>

<style is:global>
  .lb-section { margin-top: 24px; }
  .lb-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; gap: 12px; flex-wrap: wrap; }
  .lb-title { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); }
  .pwhl-subnav { display: flex; gap: 16px; padding: 0 32px 0; margin-top: 12px; }
  .pwhl-subnav a { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-48); text-decoration: none; }
  .pwhl-subnav a.active { color: var(--ink); border-bottom: 2px solid var(--red); padding-bottom: 2px; }
</style>
