---
import StatsLayout from '../../../layouts/StatsLayout.astro';
import StatsMasthead from '../../../components/StatsMasthead.astro';
import PwhlSkaterTable from '../../../components/react/PwhlSkaterTable';
import { loadPwhlPlayers } from '../../../lib/stats-loader';

const players = loadPwhlPlayers();
const totalCount = players.length;
---

<StatsLayout
  title="PWHL Player Stats — HockeyGameBot"
  description="PWHL skater stats including goals, assists, points, and more. 2024–25 season."
  ogImage="/og/default.png"
  currentPath={Astro.url.pathname}
>

<StatsMasthead slot="mast" eyebrow="HGB PWHL · Skaters" statLine={`${totalCount} skaters`}>
  <Fragment slot="headline">PWHL skaters.<br /><em>Every stat.</em></Fragment>
  <Fragment slot="lede">PWHL skater leaderboard with goals, assists, points, power-play production, and estimated individual expected goals.</Fragment>
</StatsMasthead>

<main class="wrap">
  <section class="lb-section">
    <div class="lb-head">
      <span class="lb-title">Skater Leaderboard</span>
    </div>
    <PwhlSkaterTable data={players} client:load />
  </section>
</main>

</StatsLayout>

<style is:global>
  .lb-section { padding: 0; }
  .lb-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 8px; }
  .lb-title { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px); text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
</style>
