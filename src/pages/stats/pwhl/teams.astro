---
import Nav from '../../../components/Nav.astro';
import StatsSubnav from '../../../components/StatsSubnav.astro';
import ThemeScript from '../../../components/ThemeScript.astro';
import Fonts from '../../../components/Fonts.astro';
import PwhlTeamsTable from '../../../components/react/PwhlTeamsTable';
import { loadPwhlTeams } from '../../../lib/stats-loader';
import { cardFooterText, SITE_DISCLAIMER } from '../../../lib/card-footer';

const teams = loadPwhlTeams();
---

<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>PWHL Team Stats — HockeyGameBot</title>
  <meta name="description" content="PWHL team standings, special teams, and estimated expected goals. 2024–25 season." />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/favicon-180x180.png" />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:        #EFEEE8;
      --ink:       #0d0d14;
      --red:       #E8002D;
      --surface:   #FFFFFF;
      --grid-line: rgba(13,13,20,0.04);
      --ink-04:    rgba(13,13,20,0.04);
      --ink-06:    rgba(13,13,20,0.06);
      --ink-10:    rgba(13,13,20,0.10);
      --ink-14:    rgba(13,13,20,0.14);
      --ink-20:    rgba(13,13,20,0.20);
      --ink-32:    rgba(13,13,20,0.32);
      --ink-48:    rgba(13,13,20,0.48);
      --ink-56:    rgba(13,13,20,0.56);
      --ink-72:    rgba(13,13,20,0.72);
      --display:   'Barlow Condensed', sans-serif;
      --body:      'Barlow', sans-serif;
      --mono:      'JetBrains Mono', monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }

    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
    .mast-corners .corner { position: absolute; width: 16px; height: 16px; }
    .mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
    .mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
    .mast-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 36px 32px; }
    .mast-top { display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
      margin-bottom: 20px; font-family: var(--body); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48); }
    .mast-eyebrow { font-family: var(--body); font-weight: 500; font-size: 11px; letter-spacing: 0.12em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px);
      text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px; }
    .mast-lede { font-size: 14px; color: var(--ink-72); line-height: 1.5; }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 24px 32px 64px; }
    .lb-section { margin-top: 24px; }
    .lb-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; gap: 12px; flex-wrap: wrap; }
    .lb-title { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-48); }
    .lb-footer { border-top: 1px solid var(--ink-10); padding: 16px 32px; font-family: var(--mono); font-size: 10px; color: var(--ink-32); text-align: center; }
    .lb-disclaimer { padding: 4px 32px 16px; font-family: var(--mono); font-size: 9px; color: var(--ink-32); text-align: center; }
    .pwhl-subnav { display: flex; gap: 16px; padding: 0 32px 0; margin-top: 12px; }
    .pwhl-subnav a { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-48); text-decoration: none; }
    .pwhl-subnav a.active { color: var(--ink); border-bottom: 2px solid var(--red); padding-bottom: 2px; }
  </style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<section class="mast">
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-top">
      <div class="mast-eyebrow"><span class="pip"></span> HGB Stats · PWHL</div>
      <div>{teams.length} teams · 2024–25</div>
    </div>
    <div class="mast-card">
      <h1 class="mast-headline">PWHL Team Stats</h1>
      <p class="mast-lede">2024–25 team standings, special teams efficiency, and estimated expected goals percentage.</p>
    </div>
  </div>
</section>
<StatsSubnav currentPath={Astro.url.pathname} />

<main class="wrap">
  <section class="lb-section">
    <div class="lb-head">
      <span class="lb-title">Team Standings</span>
    </div>
    <PwhlTeamsTable data={teams} client:load />
  </section>
</main>

<footer class="lb-footer">{cardFooterText()}</footer>
<div class="lb-disclaimer">{SITE_DISCLAIMER}</div>

</body>
</html>
