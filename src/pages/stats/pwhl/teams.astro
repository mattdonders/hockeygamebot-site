---
import StatsLayout from '../../../layouts/StatsLayout.astro';
import StatsMasthead from '../../../components/StatsMasthead.astro';
import PwhlTeamsTable from '../../../components/react/PwhlTeamsTable';
import { loadPwhlTeams } from '../../../lib/stats-loader';

const teams = loadPwhlTeams();
---

<StatsLayout
  title="PWHL Team Stats — HockeyGameBot"
  description="PWHL team standings, special teams, and estimated expected goals. 2024–25 season."
  ogImage="/og/default.png"
  currentPath={Astro.url.pathname}
>

<StatsMasthead slot="mast" eyebrow="HGB PWHL · Teams" statLine={`${teams.length} teams`}>
  <Fragment slot="headline">Six teams.<br /><em>Full picture.</em></Fragment>
  <Fragment slot="lede">PWHL team results with standings, special teams, goal differential, and estimated expected goals percentage.</Fragment>
</StatsMasthead>

<main class="wrap">
  <section class="lb-section">
    <div class="lb-head">
      <span class="lb-title">Team Standings</span>
    </div>
    <PwhlTeamsTable data={teams} client:load />
  </section>
</main>

</StatsLayout>

<style is:global>
  .lb-section { padding: 0; }
  .lb-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 8px; }
  .lb-title { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px); text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
</style>
