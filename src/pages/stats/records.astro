---
import StatsLayout from '../../layouts/StatsLayout.astro';
import StatsMasthead from '../../components/StatsMasthead.astro';
import SeriesRecordsTable from '../../components/react/SeriesRecordsTable';
import { loadSeriesRecords } from '../../lib/stats-loader';

const data = loadSeriesRecords();
const series = (data.series ?? []) as any[];
const scope = data.scope ?? 'HGB Model Era';
const totalSeries = data.total_series ?? series.length;
---
<StatsLayout
  title="Playoff Series Records — HockeyGameBot Analytics"
  description="All-time NHL playoff series dominance rankings by 5v5 xGF%. Covers 2022-23 through present — HGB Model Era."
  ogImage="/og/default.png"
  currentPath={Astro.url.pathname}
>

<StatsMasthead eyebrow="HGB Stats · Playoffs">
  <Fragment slot="headline">Playoff Series Records</Fragment>
  <Fragment slot="lede">{scope} · 5v5 only · {totalSeries} series</Fragment>
</StatsMasthead>

<main class="wrap">
  <SeriesRecordsTable
    series={series}
    scope={scope}
    totalSeries={totalSeries}
    client:load
  />
</main>

</StatsLayout>
