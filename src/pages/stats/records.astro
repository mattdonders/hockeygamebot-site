---
import Nav from '../../components/Nav.astro';
import StatsSubnav from '../../components/StatsSubnav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import SeriesRecordsTable from '../../components/react/SeriesRecordsTable';
import { loadSeriesRecords } from '../../lib/stats-loader';

const data = loadSeriesRecords();
const series = (data.series ?? []) as any[];
const scope = data.scope ?? 'HGB Model Era';
const totalSeries = data.total_series ?? series.length;
---
<!doctype html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Playoff Series Records — HockeyGameBot Analytics</title>
  <meta name="description" content="All-time NHL playoff series dominance rankings by 5v5 xGF%. Covers 2022-23 through present — HGB Model Era." />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" href="/favicon-180x180.png" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #EFEEE8; --surface: #FFFFFF; --ink: #0d0d14; --red: #E8002D;
      --ink-04: rgba(13,13,20,0.04); --ink-06: rgba(13,13,20,0.06);
      --ink-14: rgba(13,13,20,0.14); --ink-20: rgba(13,13,20,0.20);
      --ink-32: rgba(13,13,20,0.32); --ink-48: rgba(13,13,20,0.48);
      --ink-72: rgba(13,13,20,0.72); --stats-pos: #166534; --stats-neg: #991b1b;
      --display: "Barlow Condensed", sans-serif; --body: "Barlow", sans-serif; --mono: "JetBrains Mono", monospace;
      --grid-line: rgba(13,13,20,0.04);
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; min-height: 100vh; }

    .mast { position: relative; border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
      background-size: 96px 96px; }
    .mast-inner { max-width: 1200px; margin: 0 auto; padding: 48px 32px 40px; position: relative; z-index: 1; }
    .mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-48); display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
    .mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5vw, 56px); text-transform: uppercase; line-height: 1; color: var(--ink); margin-bottom: 10px; }
    .mast-sub { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.08em; }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 32px 32px 80px; }

    @media (max-width: 640px) { .mast-inner, .wrap { padding-left: 16px; padding-right: 16px; } }
  </style>
</head>
<body>
<Nav currentPath="/stats/records" />

<header class="mast">
  <div class="mast-inner">
    <div class="mast-eyebrow"><span class="pip"></span>HGB Stats · Playoffs</div>
    <div class="mast-card">
      <h1 class="mast-headline">Playoff Series Records</h1>
      <p class="mast-sub">{scope} · 5v5 only · {totalSeries} series</p>
    </div>
  </div>
</header>

<main class="wrap">
  <SeriesRecordsTable
    series={series}
    scope={scope}
    totalSeries={totalSeries}
    client:load
  />
</main>
</body>
</html>
