---
// HockeyGameBot — /internal/shot-map-poc
// Proof-of-concept page for the interactive React ShotMap component.
// Fetches CAR vs MTL playoff series shots client-side and renders
// the scatter/density map. Not linked from production navigation.
// noindex,nofollow — internal tool only.
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import ShotMapDemo from '../../components/react/ShotMapDemo';
---
<!doctype html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Shot Map POC · HGB Internal</title>
  <meta name="robots" content="noindex,nofollow" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #EFEEE8; --ink: #0d0d14; --red: #E8002D; --surface: #FFFFFF;
      --ink-06: rgba(13,13,20,0.06); --ink-10: rgba(13,13,20,0.10);
      --ink-14: rgba(13,13,20,0.14); --ink-20: rgba(13,13,20,0.20);
      --ink-32: rgba(13,13,20,0.32); --ink-48: rgba(13,13,20,0.48);
      --ink-72: rgba(13,13,20,0.72);
      --display: 'Barlow Condensed', sans-serif;
      --body:    'Barlow', sans-serif;
      --mono:    'JetBrains Mono', monospace;
    }
    html, body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--body);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    .page-mast {
      border-bottom: 2px solid var(--ink);
      padding: 28px 32px 24px;
      background: var(--bg);
    }
    .mast-eyebrow {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .internal-pip {
      width: 6px;
      height: 6px;
      background: var(--red);
      border-radius: 50%;
    }
    .mast-title {
      font-family: var(--display);
      font-weight: 800;
      font-size: clamp(28px, 4vw, 44px);
      text-transform: uppercase;
      letter-spacing: -0.005em;
    }
    .mast-meta {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--ink-48);
      letter-spacing: 0.06em;
      margin-top: 6px;
    }

    .page-body {
      max-width: 900px;
      margin: 0 auto;
      padding: 32px 32px 80px;
    }

    @media (max-width: 640px) {
      .page-mast { padding: 20px 16px; }
      .page-body  { padding: 20px 16px 60px; }
    }
  </style>
</head>
<body>
<Nav currentPath="/internal/shot-map-poc" />

<div class="page-mast">
  <div class="mast-eyebrow">
    <span class="internal-pip"></span>
    Internal · Not Public · noindex
  </div>
  <h1 class="mast-title">Shot Map POC</h1>
  <div class="mast-meta">
    React interactive scatter / density toggle · api.hockeygamebot.com/v1/series/car-mtl/shots
  </div>
</div>

<div class="page-body">
  <ShotMapDemo client:only="react" />
</div>
</body>
</html>
