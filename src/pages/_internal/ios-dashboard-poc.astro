---
<!doctype html>
<html lang="en">
<head>
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>HGB iOS App — Dashboard POC</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Mode tokens ── */
    :root {
      --m-body-bg:    #1a1a1a;
      --m-screen-bg:  #0d0d0d;
      --m-surface:    #1a1a1a;
      --m-surface-2:  #222;
      --m-border:     rgba(255,255,255,0.08);
      --m-ink:        #ffffff;
      --m-ink-50:     rgba(255,255,255,0.50);
      --m-ink-35:     rgba(255,255,255,0.35);
      --m-ink-28:     rgba(255,255,255,0.28);
      --m-tabbar-bg:  rgba(18,18,18,0.95);
      --m-tabbar-border: rgba(255,255,255,0.08);
      --m-status-ink: #ffffff;
      --m-wordmark:   #ffffff;
      --m-eyebrow:    rgba(255,255,255,0.4);
      --m-hero-bg:    linear-gradient(135deg, #1a1f2e 0%, #111520 100%);
    }
    :root.light {
      --m-body-bg:    #d8d7d1;
      --m-screen-bg:  #EFEEE8;
      --m-surface:    #ffffff;
      --m-surface-2:  #f5f4ee;
      --m-border:     rgba(13,13,20,0.12);
      --m-ink:        #0d0d14;
      --m-ink-50:     rgba(13,13,20,0.50);
      --m-ink-35:     rgba(13,13,20,0.40);
      --m-ink-28:     rgba(13,13,20,0.28);
      --m-tabbar-bg:  rgba(239,238,232,0.95);
      --m-tabbar-border: rgba(13,13,20,0.12);
      --m-status-ink: #0d0d14;
      --m-wordmark:   #0d0d14;
      --m-eyebrow:    rgba(13,13,20,0.45);
      --m-hero-bg:    linear-gradient(135deg, #ffffff 0%, #f0efe9 100%);
    }

    body {
      background: var(--m-body-bg);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 40px 20px 60px;
      font-family: -apple-system, "SF Pro Display", "Helvetica Neue", sans-serif;
      -webkit-font-smoothing: antialiased;
      transition: background 0.3s;
    }

    /* ── Page chrome ── */
    .page-label {
      font-family: "JetBrains Mono", monospace;
      font-size: 10px;
      letter-spacing: 0.18em;
      color: rgba(255,255,255,0.35);
      text-transform: uppercase;
      margin-bottom: 20px;
    }
    .mode-toggle-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 28px;
    }
    .mode-toggle {
      display: flex;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 20px;
      padding: 3px;
      gap: 2px;
    }
    .mode-btn {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 16px;
      border: none;
      cursor: pointer;
      color: rgba(255,255,255,0.4);
      background: transparent;
      transition: all 0.2s;
    }
    .mode-btn.active {
      background: #fff;
      color: #0d0d14;
    }
    .mode-hint {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      color: rgba(255,255,255,0.25);
      letter-spacing: 0.1em;
    }

    /* ── iPhone frame ── */
    .iphone-frame {
      position: relative;
      width: 393px;
      height: 852px;
      background: #000;
      border-radius: 54px;
      box-shadow:
        0 0 0 2px #3a3a3a,
        0 0 0 4px #1a1a1a,
        0 0 0 6px #4a4a4a,
        0 32px 80px rgba(0,0,0,0.6),
        inset 0 0 0 2px #2a2a2a;
      overflow: hidden;
      flex-shrink: 0;
    }

    /* Dynamic Island */
    .dynamic-island {
      position: absolute;
      top: 12px;
      left: 50%;
      transform: translateX(-50%);
      width: 126px;
      height: 36px;
      background: #000;
      border-radius: 20px;
      z-index: 100;
    }

    /* Side buttons */
    .iphone-frame::before {
      content: '';
      position: absolute;
      right: -3px;
      top: 160px;
      width: 4px;
      height: 80px;
      background: #3a3a3a;
      border-radius: 2px 0 0 2px;
    }
    .iphone-frame::after {
      content: '';
      position: absolute;
      left: -3px;
      top: 130px;
      width: 4px;
      height: 40px;
      background: #3a3a3a;
      border-radius: 0 2px 2px 0;
      box-shadow: 0 58px 0 #3a3a3a, 0 108px 0 #3a3a3a;
    }

    /* ── Screen ── */
    .screen {
      position: absolute;
      inset: 0;
      background: var(--m-screen-bg);
      border-radius: 52px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: background 0.3s;
    }

    /* ── Status bar ── */
    .status-bar {
      height: 59px;
      padding: 14px 28px 0;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-shrink: 0;
      padding-bottom: 8px;
    }
    .status-time {
      font-size: 15px;
      font-weight: 600;
      color: var(--m-status-ink);
      letter-spacing: -0.3px;
    }
    .status-icons {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--m-status-ink);
    }
    .status-icons svg { width: 16px; height: 12px; }
    .battery {
      width: 25px;
      height: 12px;
      border: 1.5px solid var(--m-ink-35);
      border-radius: 3px;
      position: relative;
      padding: 2px;
    }
    .battery::after {
      content: '';
      position: absolute;
      right: -4px;
      top: 50%;
      transform: translateY(-50%);
      width: 2px;
      height: 5px;
      background: var(--m-ink-35);
      border-radius: 0 1px 1px 0;
    }
    .battery-fill {
      height: 100%;
      width: 80%;
      background: var(--m-ink);
      border-radius: 1px;
    }

    /* ── App header ── */
    .app-header {
      padding: 4px 20px 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .app-wordmark {
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 800;
      font-size: 22px;
      color: var(--m-wordmark);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .app-wordmark span { color: #E8002D; }
    .notif-btn {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--m-border);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--m-ink-50);
      font-size: 17px;
    }

    /* ── Scrollable content ── */
    .scroll-content {
      flex: 1;
      overflow-y: auto;
      padding: 0 0 16px;
      scrollbar-width: none;
    }
    .scroll-content::-webkit-scrollbar { display: none; }

    /* ── Section label ── */
    .section-label {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--m-ink-35);
      padding: 16px 20px 8px;
    }

    /* ── Tonight hero card ── */
    .game-hero {
      margin: 0 16px 4px;
      background: var(--m-hero-bg);
      border: 1px solid var(--m-border);
      border-radius: 16px;
      padding: 16px;
      position: relative;
      overflow: hidden;
    }
    .game-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: #CC0000;
    }
    .game-hero-eyebrow {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--m-eyebrow);
      margin-bottom: 12px;
    }
    .game-matchup {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .team-side {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      flex: 1;
    }
    .team-logo-wrap {
      width: 52px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .team-logo-wrap img {
      width: 48px;
      height: 48px;
      object-fit: contain;
    }
    .team-abbrev {
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 800;
      font-size: 18px;
      color: var(--m-ink);
      letter-spacing: 0.08em;
    }
    .vs-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      padding: 0 8px;
    }
    .vs-text {
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 700;
      font-size: 13px;
      color: var(--m-ink-35);
      letter-spacing: 0.1em;
    }
    .game-time-small {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      color: var(--m-ink-35);
      letter-spacing: 0.06em;
      white-space: nowrap;
    }
    /* Win probability bar */
    .wp-bar-wrap {
      margin-top: 4px;
    }
    .wp-label-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 5px;
    }
    .wp-label {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      color: var(--m-ink-35);
      letter-spacing: 0.06em;
    }
    .wp-pct {
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 700;
      font-size: 14px;
      color: var(--m-ink);
    }
    .wp-pct.home { color: #CC0000; }
    .wp-bar {
      height: 4px;
      background: var(--m-border);
      border-radius: 2px;
      overflow: hidden;
    }
    .wp-fill {
      height: 100%;
      background: #CC0000;
      border-radius: 2px;
    }
    .wp-model-note {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      color: var(--m-ink-28);
      margin-top: 6px;
      letter-spacing: 0.04em;
    }

    /* ── Signal cards ── */
    .signals-scroll {
      display: flex;
      gap: 10px;
      padding: 0 16px;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .signals-scroll::-webkit-scrollbar { display: none; }

    .signal-card {
      flex-shrink: 0;
      width: 220px;
      background: var(--m-surface);
      border: 1px solid var(--m-border);
      border-radius: 14px;
      padding: 13px 14px;
      position: relative;
      overflow: hidden;
    }
    .signal-card-accent {
      position: absolute;
      top: 0; left: 0;
      width: 3px;
      height: 100%;
      border-radius: 14px 0 0 14px;
    }
    .signal-rule {
      font-family: "JetBrains Mono", monospace;
      font-size: 8px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--m-ink-35);
      margin-bottom: 6px;
      padding-left: 6px;
    }
    .signal-headline {
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 700;
      font-size: 15px;
      color: var(--m-ink);
      line-height: 1.1;
      margin-bottom: 6px;
      padding-left: 6px;
    }
    .signal-body {
      font-family: -apple-system, sans-serif;
      font-size: 11px;
      line-height: 1.45;
      color: var(--m-ink-50);
      padding-left: 6px;
    }
    .signal-cta {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      margin-top: 10px;
      margin-left: 6px;
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--m-ink-35);
    }

    /* severity dot */
    .sig-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 4px;
      position: relative;
      top: -0px;
    }
    .sig-dot.positive { background: #34C759; }
    .sig-dot.negative { background: #FF3B30; }
    .sig-dot.neutral  { background: #636366; }
    .sig-dot.movement { background: #007AFF; }

    /* ── Team chips ── */
    .teams-row {
      display: flex;
      gap: 10px;
      padding: 0 16px;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .teams-row::-webkit-scrollbar { display: none; }
    .team-chip {
      flex-shrink: 0;
      background: var(--m-surface);
      border: 1px solid var(--m-border);
      border-radius: 14px;
      padding: 12px 14px;
      min-width: 130px;
      position: relative;
      overflow: hidden;
    }
    .team-chip-bar {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
    }
    .team-chip-abbrev {
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 800;
      font-size: 22px;
      color: var(--m-ink);
      letter-spacing: 0.06em;
      line-height: 1;
      margin-bottom: 2px;
    }
    .team-chip-record {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      color: var(--m-ink-35);
      letter-spacing: 0.06em;
      margin-bottom: 8px;
    }
    .team-chip-stat {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .team-chip-stat-val {
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 700;
      font-size: 20px;
      color: var(--m-ink);
    }
    .team-chip-stat-label {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      color: var(--m-ink-35);
      letter-spacing: 0.06em;
    }
    .team-chip-signal {
      margin-top: 8px;
      font-family: "JetBrains Mono", monospace;
      font-size: 8px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--m-ink-35);
    }

    /* ── Players list ── */
    .player-list {
      padding: 0 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .player-row {
      background: var(--m-surface);
      border: 1px solid var(--m-border);
      border-radius: 12px;
      padding: 11px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .player-avatar {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 800;
      font-size: 12px;
      color: rgba(255,255,255,0.9);
      flex-shrink: 0;
    }
    .player-info { flex: 1; min-width: 0; }
    .player-name {
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 700;
      font-size: 15px;
      color: var(--m-ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .player-meta {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      color: var(--m-ink-35);
      letter-spacing: 0.06em;
      margin-top: 1px;
    }
    .player-stats {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 3px;
    }
    .player-pts {
      font-family: "Barlow Condensed", sans-serif;
      font-weight: 700;
      font-size: 18px;
      color: var(--m-ink);
      line-height: 1;
    }
    .player-impact {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      letter-spacing: 0.04em;
    }
    .player-impact.pos { color: #34C759; }
    .player-impact.neg { color: #FF3B30; }

    /* ── Bottom tab bar ── */
    .tab-bar {
      flex-shrink: 0;
      height: 83px;
      padding: 0 8px;
      background: var(--m-tabbar-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-top: 0.5px solid var(--m-tabbar-border);
      display: flex;
      align-items: flex-start;
      justify-content: space-around;
      padding-top: 10px;
    }
    .tab-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      min-width: 60px;
      padding: 0 4px;
    }
    .tab-icon {
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .tab-icon svg {
      width: 22px;
      height: 22px;
    }
    .tab-label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.01em;
    }
    .tab-item.active .tab-label { color: #E8002D; }
    .tab-item.active .tab-icon svg path,
    .tab-item.active .tab-icon svg rect { fill: #E8002D; }
    .tab-item:not(.active) .tab-label { color: var(--m-ink-35); }
    .tab-item:not(.active) .tab-icon svg path,
    .tab-item:not(.active) .tab-icon svg rect { fill: var(--m-ink-35); }

    /* Home indicator */
    .home-indicator {
      width: 134px;
      height: 5px;
      background: var(--m-ink-28);
      border-radius: 3px;
      position: absolute;
      bottom: 8px;
      left: 50%;
      transform: translateX(-50%);
    }

    /* ── Side-by-side layout ── */
    .outer {
      display: flex;
      align-items: flex-start;
      gap: 48px;
      max-width: 900px;
    }
    .annotation-col {
      padding-top: 80px;
      width: 260px;
      flex-shrink: 0;
    }
    .annotation {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 12px 14px;
      margin-bottom: 14px;
    }
    .annotation h4 {
      font-family: "JetBrains Mono", monospace;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #E8002D;
      margin-bottom: 6px;
    }
    .annotation p {
      font-size: 11px;
      line-height: 1.5;
      color: rgba(255,255,255,0.5);
      font-family: -apple-system, sans-serif;
    }
    .connector {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 2px;
    }
    .connector-line {
      flex: 1;
      height: 1px;
      background: rgba(255,255,255,0.12);
    }
  </style>
</head>
<body>

<p class="page-label">HGB · iOS App · Dashboard POC · Local Only</p>

<div class="mode-toggle-row">
  <div class="mode-toggle">
    <button class="mode-btn active" id="btn-dark" onclick="setMode('dark')">Dark</button>
    <button class="mode-btn" id="btn-light" onclick="setMode('light')">Light</button>
  </div>
  <span class="mode-hint" id="mode-hint">Dark dominates mobile — toggle to see our cream editorial feel</span>
</div>

<div class="outer">
  <!-- Left annotations -->
  <div class="annotation-col">
    <div class="annotation" style="margin-top: 59px;">
      <h4>Not a scores app</h4>
      <p>No scroll of every game. Open to YOUR context: what the model says about your teams tonight, before puck drop.</p>
    </div>
    <div class="annotation" style="margin-top: 88px;">
      <h4>Model signals feed</h4>
      <p>Rule-triggered. Horizontal scroll. Each card is a specific threshold that fired — xG/60, role change, finishing divergence. No LLM at runtime.</p>
    </div>
    <div class="annotation" style="margin-top: 118px;">
      <h4>Your teams — process first</h4>
      <p>xGF% is the headline stat, not W-L record. Odds as context. Tap for full team page.</p>
    </div>
    <div class="annotation" style="margin-top: 60px;">
      <h4>Followed players</h4>
      <p>Impact delta in green/red tells you what changed last game, not just cumulative pts.</p>
    </div>
  </div>

  <!-- iPhone frame -->
  <div class="iphone-frame">
    <div class="dynamic-island"></div>

    <div class="screen">
      <!-- Status bar -->
      <div class="status-bar">
        <div class="status-time">9:41</div>
        <div class="status-icons">
          <!-- Signal bars -->
          <svg viewBox="0 0 17 12" xmlns="http://www.w3.org/2000/svg">
            <rect x="0" y="6" width="3" height="6" rx="1" fill="white"/>
            <rect x="4.5" y="4" width="3" height="8" rx="1" fill="white"/>
            <rect x="9" y="2" width="3" height="10" rx="1" fill="white"/>
            <rect x="13.5" y="0" width="3" height="12" rx="1" fill="white"/>
          </svg>
          <!-- WiFi -->
          <svg viewBox="0 0 16 12" xmlns="http://www.w3.org/2000/svg" style="width:15px;height:11px">
            <path d="M8 9.5a1.5 1.5 0 100 3 1.5 1.5 0 000-3zM3.6 6.9a6 6 0 018.8 0l1.4-1.5A8 8 0 002.2 5.4L3.6 6.9zM0 4.3l1.4 1.5a10 10 0 0113.2 0L16 4.3A12 12 0 000 4.3z" fill="white"/>
          </svg>
          <!-- Battery -->
          <div class="battery"><div class="battery-fill"></div></div>
        </div>
      </div>

      <!-- App header -->
      <div class="app-header">
        <div class="app-wordmark">Hockey<span>Game</span>Bot</div>
        <div class="notif-btn">🔔</div>
      </div>

      <!-- Scrollable content -->
      <div class="scroll-content">

        <!-- Tonight section -->
        <div class="section-label">Tonight · {tonight.time}</div>
        <div class="game-hero">
          <div class="game-hero-eyebrow">YOUR TEAM IS PLAYING · PRUDENTIAL CENTER</div>
          <div class="game-matchup">
            <div class="team-side">
              <div class="team-logo-wrap">
                <img src="https://assets.nhle.com/logos/nhl/svg/NYR_light.svg" alt="NYR" data-logo />
              </div>
              <div class="team-abbrev">NYR</div>
            </div>
            <div class="vs-col">
              <div class="vs-text">VS</div>
              <div class="game-time-small">7:00 PM ET</div>
            </div>
            <div class="team-side">
              <div class="team-logo-wrap">
                <img src="https://assets.nhle.com/logos/nhl/svg/NJD_light.svg" alt="NJD" data-logo />
              </div>
              <div class="team-abbrev">NJD</div>
            </div>
          </div>
          <div class="wp-bar-wrap">
            <div class="wp-label-row">
              <div>
                <div class="wp-label">NYR WIN%</div>
                <div class="wp-pct">46%</div>
              </div>
              <div style="text-align:right">
                <div class="wp-label">NJD WIN%</div>
                <div class="wp-pct home">54%</div>
              </div>
            </div>
            <div class="wp-bar">
              <div class="wp-fill" style="width:54%"></div>
            </div>
            <div class="wp-model-note">Model favors NJD · Pre-game · 5v5 xGF% weighted</div>
          </div>
        </div>

        <!-- Signals section -->
        <div class="section-label">Model Signals · {signals.length} active</div>
        <div class="signals-scroll">
          {signals.map(s => (
            <div class="signal-card">
              <div class="signal-card-accent" style={`background: ${s.color}`}></div>
              <div class="signal-rule">
                <span class={`sig-dot ${s.type === 'movement' ? 'movement' : s.severity}`}></span>
                {s.rule}
              </div>
              <div class="signal-headline">{s.headline}</div>
              <div class="signal-body">{s.body}</div>
              <div class="signal-cta">View → {s.player ?? s.team}</div>
            </div>
          ))}
        </div>

        <!-- Teams section -->
        <div class="section-label">Your Teams</div>
        <div class="teams-row">
          {followedTeams.map(t => (
            <div class="team-chip">
              <div class="team-chip-bar" style={`background: ${t.color}`}></div>
              <div class="team-chip-abbrev">{t.abbrev}</div>
              <div class="team-chip-record">{t.record}</div>
              <div class="team-chip-stat">
                <div class="team-chip-stat-val">{t.xgf}%</div>
                <div class="team-chip-stat-label">xGF%</div>
              </div>
              <div class="team-chip-stat" style="margin-top:4px">
                <div class="team-chip-stat-val" style="font-size:15px">{t.odds}%</div>
                <div class="team-chip-stat-label">Playoff odds</div>
              </div>
              <div class="team-chip-signal">{t.signal}</div>
            </div>
          ))}
        </div>

        <!-- Players section -->
        <div class="section-label">Your Players</div>
        <div class="player-list">
          {followedPlayers.map(p => (
            <div class="player-row">
              <div class="player-avatar" style={`background: ${p.color}22; border: 1px solid ${p.color}44`}>
                {p.name.split(' ').map((n: string) => n[0]).join('')}
              </div>
              <div class="player-info">
                <div class="player-name">{p.name}</div>
                <div class="player-meta">{p.team} · {p.pos} · {p.toi}/gm</div>
              </div>
              <div class="player-stats">
                <div class="player-pts">{p.p}P</div>
                <div class={`player-impact ${p.form === '+' ? 'pos' : 'neg'}`}>
                  {p.form}{p.formVal} Impact
                </div>
              </div>
            </div>
          ))}
        </div>

        <div style="height: 8px;"></div>
      </div>

      <!-- Bottom tab bar -->
      <div class="tab-bar">
        <!-- Home (active) -->
        <div class="tab-item active">
          <div class="tab-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none">
              <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <span class="tab-label">Home</span>
        </div>
        <!-- Teams -->
        <div class="tab-item">
          <div class="tab-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="tab-label">Teams</span>
        </div>
        <!-- Players -->
        <div class="tab-item">
          <div class="tab-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none">
              <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/>
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="tab-label">Players</span>
        </div>
        <!-- Stats -->
        <div class="tab-item">
          <div class="tab-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none">
              <path d="M18 20V10M12 20V4M6 20v-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="tab-label">Stats</span>
        </div>
        <!-- Search -->
        <div class="tab-item">
          <div class="tab-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none">
              <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
              <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="tab-label">Search</span>
        </div>
      </div>

      <div class="home-indicator"></div>
    </div>
  </div>
</div>

<script is:inline>
// Auto-apply mode from URL param on load
(function() {
  const p = new URLSearchParams(location.search).get('mode');
  if (p === 'light') {
    document.documentElement.classList.add('light');
    // sync buttons after DOM ready
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('btn-dark').classList.remove('active');
      document.getElementById('btn-light').classList.add('active');
      const hint = document.getElementById('mode-hint');
      if (hint) hint.textContent = 'Cream editorial — our web design language on iOS';
    });
  }
})();

function setMode(mode) {
  const root = document.documentElement;
  const btnDark = document.getElementById('btn-dark');
  const btnLight = document.getElementById('btn-light');
  const hint = document.getElementById('mode-hint');

  if (mode === 'light') {
    root.classList.add('light');
    btnDark.classList.remove('active');
    btnLight.classList.add('active');
    hint.textContent = 'Cream editorial — our web design language on iOS';
    // swap to dark logos for light background
    document.querySelectorAll('img[data-logo]').forEach(img => {
      img.src = img.src.replace('_light.svg', '_dark.svg');
    });
  } else {
    root.classList.remove('light');
    btnDark.classList.add('active');
    btnLight.classList.remove('active');
    hint.textContent = 'Dark dominates mobile — toggle to see our cream editorial feel';
    document.querySelectorAll('img[data-logo]').forEach(img => {
      img.src = img.src.replace('_dark.svg', '_light.svg');
    });
  }
}
</script>
</body>
</html>
