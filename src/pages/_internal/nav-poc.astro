---
// Internal POC — Stats sub-navigation concepts
// Test at localhost:4321/internal/nav-poc
// NOT linked from main nav, not in sitemap
const currentPath = '/stats/skaters'; // simulate being on skaters page

const statsLinks = [
  { href: '/stats',         label: 'Overview'       },
  { href: '/stats/skaters', label: 'Skaters'        },
  { href: '/stats/goalies', label: 'Goalies'        },
  { href: '/stats/teams',   label: 'Teams'          },
  { href: '/stats/lines',   label: 'Lines'          },
  { href: '/stats/impact',  label: 'Impact'         },
  { href: '/stats/records', label: 'Series Records' },
  { href: '/stats/wowy',    label: 'WOWY'           },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Nav POC · Internal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #EFEEE8; --surface: #fff; --ink: #0d0d14; --red: #E8002D;
      --ink-14: rgba(13,13,20,0.14); --ink-32: rgba(13,13,20,0.32);
      --ink-48: rgba(13,13,20,0.48); --display: "Barlow Condensed", sans-serif;
      --body: "Barlow", sans-serif; --mono: "JetBrains Mono", monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }

    .poc-header { background: var(--ink); color: #EFEEE8; padding: 10px 32px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; display: flex; align-items: center; gap: 16px; }
    .poc-header .pill { background: var(--red); color: #fff; padding: 2px 8px; font-size: 9px; font-weight: 700; letter-spacing: 0.12em; }

    .poc-section { max-width: 1100px; margin: 40px auto; padding: 0 32px; }
    .poc-label { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 12px; }
    .poc-card { background: var(--surface); border: 1px solid var(--ink-14); margin-bottom: 40px; }
    .poc-card-inner { padding: 0; }
    .fake-page { padding: 24px 32px; border-top: 1px solid var(--ink-14); background: var(--bg); min-height: 120px; }
    .fake-page-hint { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* ── OPTION A: Underline tabs (NST/EH style) ── */
    .subnav-a { display: flex; gap: 0; border-bottom: 2px solid var(--ink-14); padding: 0 32px; background: var(--surface); overflow-x: auto; }
    .subnav-a a { font-family: var(--display); font-weight: 700; font-size: 13px; letter-spacing: 0.04em; text-transform: uppercase; padding: 14px 16px 12px; color: var(--ink-48); border-bottom: 2px solid transparent; margin-bottom: -2px; white-space: nowrap; transition: color 0.1s; }
    .subnav-a a:hover { color: var(--ink); }
    .subnav-a a.active { color: var(--ink); border-bottom-color: var(--red); }

    /* ── OPTION B: Chip strip (matches filter chips) ── */
    .subnav-b { display: flex; flex-wrap: wrap; gap: 0; padding: 16px 32px; background: var(--surface); border-bottom: 1px solid var(--ink-14); }
    .subnav-b a { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; padding: 5px 12px; border: 1px solid var(--ink-14); border-right: none; color: var(--ink-48); white-space: nowrap; }
    .subnav-b a:last-child { border-right: 1px solid var(--ink-14); }
    .subnav-b a:hover { background: rgba(13,13,20,0.04); color: var(--ink); }
    .subnav-b a.active { background: var(--ink); color: #EFEEE8; border-color: var(--ink); }

    /* ── OPTION C: Condensed bold tabs with accent (custom HGB) ── */
    .subnav-c { display: flex; gap: 0; background: var(--surface); border-bottom: 2px solid var(--ink); overflow-x: auto; }
    .subnav-c a { font-family: var(--display); font-weight: 800; font-size: 12px; letter-spacing: 0.10em; text-transform: uppercase; padding: 12px 20px; color: var(--ink-48); position: relative; white-space: nowrap; transition: color 0.1s; }
    .subnav-c a:hover { color: var(--ink); background: rgba(13,13,20,0.04); }
    .subnav-c a.active { color: var(--ink); background: var(--bg); }
    .subnav-c a.active::after { content: ''; position: absolute; bottom: -2px; left: 0; right: 0; height: 2px; background: var(--red); }

    /* ── OPTION D: Compact pill row (mobile-friendly) ── */
    .subnav-d { display: flex; flex-wrap: wrap; gap: 6px; padding: 12px 32px; background: var(--surface); border-bottom: 1px solid var(--ink-14); }
    .subnav-d a { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 12px; border-radius: 2px; color: var(--ink-48); white-space: nowrap; }
    .subnav-d a:hover { background: rgba(13,13,20,0.06); color: var(--ink); }
    .subnav-d a.active { background: var(--ink); color: #EFEEE8; }

    .divider { border: none; border-top: 1px solid var(--ink-14); margin: 0 0 40px; }
  </style>
</head>
<body>

<div class="poc-header">
  <span>⚙ INTERNAL POC</span>
  <span class="pill">LOCAL ONLY</span>
  <span>Stats Sub-Navigation concepts — simulating /stats/skaters</span>
</div>

<!-- OPTION A -->
<div class="poc-section">
  <div class="poc-label">Option A — Underline tabs (NST / EH style)</div>
  <div class="poc-card">
    <nav class="subnav-a">
      {statsLinks.map(l => (
        <a href={l.href} class={currentPath === l.href || (l.href !== '/stats' && currentPath.startsWith(l.href)) ? 'active' : ''}>{l.label}</a>
      ))}
    </nav>
    <div class="fake-page"><p class="fake-page-hint">↑ Underline shows current page · familiar to analytics users · red accent</p></div>
  </div>

  <!-- OPTION B -->
  <div class="poc-label">Option B — Chip strip (matches existing filter chips)</div>
  <div class="poc-card">
    <nav class="subnav-b">
      {statsLinks.map(l => (
        <a href={l.href} class={currentPath === l.href || (l.href !== '/stats' && currentPath.startsWith(l.href)) ? 'active' : ''}>{l.label}</a>
      ))}
    </nav>
    <div class="fake-page"><p class="fake-page-hint">↑ Consistent with skaters filter chips · feels like part of the table UI · very HGB</p></div>
  </div>

  <!-- OPTION C -->
  <div class="poc-label">Option C — Condensed bold tabs with red underline (custom HGB)</div>
  <div class="poc-card">
    <nav class="subnav-c">
      {statsLinks.map(l => (
        <a href={l.href} class={currentPath === l.href || (l.href !== '/stats' && currentPath.startsWith(l.href)) ? 'active' : ''}>{l.label}</a>
      ))}
    </nav>
    <div class="fake-page"><p class="fake-page-hint">↑ Barlow Condensed 800 + heavy 2px bottom border + red tab indicator · most editorial</p></div>
  </div>

  <!-- OPTION D -->
  <div class="poc-label">Option D — Compact pill row (minimal, mobile-first)</div>
  <div class="poc-card">
    <nav class="subnav-d">
      {statsLinks.map(l => (
        <a href={l.href} class={currentPath === l.href || (l.href !== '/stats' && currentPath.startsWith(l.href)) ? 'active' : ''}>{l.label}</a>
      ))}
    </nav>
    <div class="fake-page"><p class="fake-page-hint">↑ Smallest footprint · wraps gracefully on mobile · lowest visual weight</p></div>
  </div>

  <div class="poc-label" style="margin-top: 8px; color: var(--red);">→ Pick one and I'll wire it into StatsSubnav.astro and drop it on all /stats/* pages.</div>
</div>

</body>
</html>
