---
// /internal/game-charts — WP + xG charts demo with real playoff game data
// noindex, local dev only
import Nav from '../../components/Nav.astro';
import GameChartsDemo from '../../components/react/GameChartsDemo';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Game Charts POC · HGB Internal</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #EFEEE8; color: #0d0d14; font-family: 'Barlow', sans-serif; -webkit-font-smoothing: antialiased; }
    .page { max-width: 900px; margin: 0 auto; padding: 32px 32px 80px; }
    .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #E8002D; margin-bottom: 6px; display: flex; align-items: center; gap: 8px; }
    .pip { width: 5px; height: 5px; background: #E8002D; border-radius: 50%; }
    h1 { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 32px; text-transform: uppercase; margin-bottom: 4px; }
    .sub { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(13,13,20,0.48); margin-bottom: 28px; border-bottom: 2px solid #0d0d14; padding-bottom: 16px; }
  </style>
</head>
<body>
<Nav currentPath="/internal" />
<div class="page">
  <div class="eyebrow"><span class="pip"></span> Internal · noindex</div>
  <h1>WP + xG Charts POC</h1>
  <p class="sub">Recharts React islands · real playoff flow data · 3 games to compare</p>
  <GameChartsDemo client:only="react" />
</div>
</body>
</html>
