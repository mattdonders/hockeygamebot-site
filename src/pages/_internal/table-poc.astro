---
// /internal/table-poc — HGBTable V2 demo (generic TanStack component)
// noindex, never linked from nav. Run locally with `npm run dev`.
import { loadPlayers } from '../../lib/stats-loader';
import SkaterTableV2 from '../../components/poc/SkaterTableV2.astro';

const players = loadPlayers().filter(p => p.gp > 0);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>HGBTable V2 POC · HGB Internal</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700&family=Barlow+Condensed:wght@700;800&family=JetBrains+Mono:wght@400;700&display=swap" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #EFEEE8; color: #0d0d14; font-family: 'Barlow', sans-serif; -webkit-font-smoothing: antialiased; }
    .page { max-width: 1200px; margin: 0 auto; padding: 32px; }
    .header { border-bottom: 2px solid #0d0d14; padding-bottom: 16px; margin-bottom: 28px; }
    .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(13,13,20,0.48); margin-bottom: 6px; display: flex; align-items: center; gap: 8px; }
    .pip { width: 5px; height: 5px; background: #E8002D; border-radius: 50%; }
    h1 { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 32px; text-transform: uppercase; letter-spacing: -0.01em; }
    h1 em { color: #E8002D; font-style: normal; }
    .sub { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(13,13,20,0.48); margin-top: 6px; }
    .card { background: #fff; border: 1px solid rgba(13,13,20,0.14); padding: 20px; }
    .feature-list { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(13,13,20,0.48); letter-spacing: 0.06em; margin-top: 4px; }
    .feature-list span { margin-right: 12px; }
  </style>
</head>
<body>
  <div class="page">
    <div class="header">
      <div class="eyebrow"><span class="pip"></span> Internal · POC · noindex</div>
      <h1>HGBTable <em>V2</em></h1>
      <p class="sub">{players.length} skaters · Generic React component · HGBTable + TanStack Table</p>
      <p class="feature-list">
        <span>✓ Sorting</span>
        <span>✓ Search</span>
        <span>✓ Position chips</span>
        <span>✓ Min GP filter</span>
        <span>✓ Row click nav</span>
        <span>✓ CSV export</span>
        <span>✓ Column toggles (WAR, Rating)</span>
        <span>✓ Mobile column hiding</span>
        <span>✓ Empty state</span>
      </p>
    </div>
    <div class="card">
      <SkaterTableV2 players={players} />
    </div>
  </div>
</body>
</html>
