---
// INTERNAL POC — Logged-out stats landing
// localhost:4321/internal/stats-loggedout-poc
// DO NOT commit, DO NOT push

const tonightGames = [
  { away: 'VGK', home: 'CAR', time: '8:00 PM ET', wp_away: 46, wp_home: 54, xg_edge: 'CAR +0.4', round: 'SCF Game 1' },
];

const topPerformers = [
  { name: 'Mitch Marner', team: 'VGK', stat: '21 pts', label: 'Points Leader' },
  { name: 'Lane Hutson', team: 'MTL', stat: '+14.59 GSAx', label: 'Goalie GSAx Leader' },
  { name: 'Macklin Celebrini', team: 'SJS', stat: '0.74 xG/60', label: 'Rookie xG/60' },
];

const previewTeams = [
  { abbr: 'CAR', name: 'Carolina Hurricanes', xgf: '58.3%', war_rank: '1st', record: '52-22-8' },
  { abbr: 'VGK', name: 'Vegas Golden Knights', xgf: '52.6%', war_rank: '12th', record: '49-24-9' },
  { abbr: 'EDM', name: 'Edmonton Oilers', xgf: '55.1%', war_rank: '5th', record: '50-26-6' },
  { abbr: 'NJD', name: 'New Jersey Devils', xgf: '52.3%', war_rank: '8th', record: '42-28-12' },
];

const statLinks = [
  { href: '/stats/skaters', label: 'Skaters', desc: 'WAR, xG, Impact for all 715 players' },
  { href: '/stats/goalies', label: 'Goalies', desc: 'GSAx, SV%, xSV% leaders' },
  { href: '/stats/teams',   label: 'Teams',   desc: 'xGF%, GF/60, special teams' },
  { href: '/stats/lines',   label: 'Lines',   desc: '4,444 line combos across 4 seasons' },
  { href: '/stats/impact',  label: 'Impact',  desc: 'Per-game HGBScore with L10 sparklines' },
  { href: '/stats/records', label: 'Series Records', desc: 'All-time playoff dominance rankings' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Stats Dashboard (Logged Out) · POC</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #EFEEE8; --surface: #fff; --ink: #0d0d14; --red: #E8002D;
      --ink-06: rgba(13,13,20,0.06); --ink-14: rgba(13,13,20,0.14);
      --ink-32: rgba(13,13,20,0.32); --ink-48: rgba(13,13,20,0.48);
      --display: "Barlow Condensed", sans-serif;
      --body: "Barlow", sans-serif; --mono: "JetBrains Mono", monospace;
    }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }

    /* POC banner */
    .poc-bar { background: var(--ink); color: #EFEEE8; padding: 8px 32px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; display: flex; align-items: center; gap: 12px; }
    .poc-pill { background: var(--red); padding: 2px 8px; font-size: 9px; font-weight: 700; letter-spacing: 0.12em; }
    .poc-links { display: flex; gap: 16px; margin-left: auto; }
    .poc-links a { color: rgba(239,238,232,0.6); }
    .poc-links a:hover { color: #EFEEE8; }

    /* Mast */
    .mast { border-bottom: 2px solid var(--ink); background-color: var(--bg);
      background-image: linear-gradient(rgba(13,13,20,0.04) 1px, transparent 1px),
        linear-gradient(90deg,rgba(13,13,20,0.04) 1px,transparent 1px);
      background-size: 96px 96px; }
    .mast-inner { max-width: 1100px; margin: 0 auto; padding: 48px 32px 40px; }
    .mast-eyebrow { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-48); display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
    .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(32px,5vw,52px); text-transform: uppercase; line-height: 1; margin-bottom: 12px; }
    .mast-sub { font-size: 13px; color: var(--ink-48); margin-bottom: 20px; }
    .cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .cta-btn { font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; padding: 10px 24px; background: var(--ink); color: #EFEEE8; cursor: pointer; border: none; }
    .cta-btn.outline { background: transparent; color: var(--ink); border: 1.5px solid var(--ink); }
    .cta-hint { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

    /* Subnav */
    .subnav { display: flex; flex-wrap: wrap; gap: 0; background: var(--surface); border-bottom: 1px solid var(--ink-14); padding: 0 32px; overflow-x: auto; }
    .subnav a { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; padding: 8px 14px; border: 1px solid var(--ink-14); border-right: none; color: var(--ink-48); white-space: nowrap; }
    .subnav a:last-child { border-right: 1px solid var(--ink-14); }
    .subnav a.disabled { opacity: 0.35; cursor: default; }
    .subnav a.highlight { background: rgba(232,0,45,0.08); color: var(--red); border-color: rgba(232,0,45,0.2); }

    /* Main layout */
    .wrap { max-width: 1100px; margin: 0 auto; padding: 32px 32px 80px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px; }
    @media(max-width:720px) { .grid-2 { grid-template-columns: 1fr; } }

    /* Sections */
    .section-label { font-family: var(--mono); font-weight: 700; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 12px; padding-bottom: 6px; border-bottom: 1px solid var(--ink-14); }

    /* Tonight module */
    .tonight-card { background: var(--surface); border: 1px solid var(--ink-14); padding: 20px 24px; margin-bottom: 20px; }
    .tonight-matchup { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px; }
    .tonight-team { display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .tonight-team img { width: 48px; height: 48px; object-fit: contain; }
    .tonight-team-abbr { font-family: var(--display); font-weight: 800; font-size: 18px; }
    .tonight-center { text-align: center; }
    .tonight-time { font-family: var(--mono); font-size: 11px; color: var(--ink-48); }
    .tonight-round { font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--red); margin-bottom: 4px; }
    .wp-bar { height: 6px; border-radius: 3px; overflow: hidden; display: flex; margin: 12px 0; }
    .wp-bar-away { background: #C8A400; }
    .wp-bar-home { background: #CC0000; }
    .wp-labels { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10px; color: var(--ink-48); }
    .tonight-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 14px; }
    .tonight-stat { text-align: center; }
    .tonight-stat-val { font-family: var(--display); font-weight: 700; font-size: 15px; }
    .tonight-stat-lbl { font-family: var(--mono); font-size: 9px; color: var(--ink-32); letter-spacing: 0.06em; }
    .tonight-cta { display: block; text-align: center; font-family: var(--display); font-weight: 800; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; padding: 8px; background: var(--ink); color: #EFEEE8; }

    /* Preview teams */
    .team-preview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 32px; }
    .team-preview-card { background: var(--surface); border: 1px solid var(--ink-14); padding: 14px 16px; display: flex; align-items: center; gap: 12px; position: relative; overflow: hidden; }
    .team-preview-card::after { content: 'FOLLOW'; position: absolute; right: 12px; top: 50%; transform: translateY(-50%); font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.12em; color: var(--ink-32); border: 1px solid var(--ink-14); padding: 3px 8px; }
    .team-preview-card img { width: 36px; height: 36px; object-fit: contain; flex-shrink: 0; }
    .team-preview-name { font-family: var(--body); font-weight: 600; font-size: 13px; }
    .team-preview-stat { font-family: var(--mono); font-size: 10px; color: var(--ink-48); }
    .team-preview-lock { font-family: var(--mono); font-size: 9px; color: var(--red); letter-spacing: 0.06em; margin-top: 2px; }

    /* Top performers */
    .performers { display: flex; flex-direction: column; gap: 0; background: var(--surface); border: 1px solid var(--ink-14); }
    .performer { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-bottom: 1px solid var(--ink-06); }
    .performer:last-child { border-bottom: 0; }
    .performer-name { font-family: var(--body); font-weight: 600; font-size: 13px; flex: 1; }
    .performer-team { font-family: var(--mono); font-size: 10px; color: var(--ink-48); width: 32px; }
    .performer-stat { font-family: var(--mono); font-size: 11px; font-weight: 700; }
    .performer-label { font-family: var(--mono); font-size: 9px; color: var(--ink-32); }

    /* Stats grid */
    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
    @media(max-width:640px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-card { background: var(--surface); border: 1px solid var(--ink-14); padding: 16px; }
    .stat-card-label { font-family: var(--display); font-weight: 800; font-size: 15px; text-transform: uppercase; letter-spacing: 0.02em; margin-bottom: 4px; }
    .stat-card-desc { font-family: var(--mono); font-size: 9px; color: var(--ink-48); letter-spacing: 0.04em; line-height: 1.4; }
    .stat-card:hover { border-color: var(--ink); }

    /* Personalization CTA */
    .personalize-bar { background: var(--ink); color: #EFEEE8; padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; margin-bottom: 32px; }
    .personalize-bar-text { }
    .personalize-bar-headline { font-family: var(--display); font-weight: 800; font-size: 22px; text-transform: uppercase; }
    .personalize-bar-sub { font-family: var(--mono); font-size: 10px; color: rgba(239,238,232,0.5); margin-top: 4px; letter-spacing: 0.06em; }
    .personalize-bar-cta { font-family: var(--display); font-weight: 800; font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; padding: 10px 24px; background: var(--red); color: #fff; border: none; cursor: pointer; white-space: nowrap; }
  </style>
</head>
<body>

<div class="poc-bar">
  <span>⚙ INTERNAL POC</span>
  <span class="poc-pill">LOGGED OUT</span>
  <span>Stats Dashboard — anonymous visitor state</span>
  <div class="poc-links">
    <a href="/internal/stats-dashboard-poc">→ Logged-in version</a>
    <a href="/internal/stats-leaderboards-poc">→ Leaderboards POC</a>
    <a href="/internal/nav-poc">→ Nav POC</a>
  </div>
</div>

<header class="mast">
  <div class="mast-inner">
    <div class="mast-eyebrow"><span class="pip"></span>HockeyGameBot Analytics</div>
    <div class="mast-card">
      <h1 class="mast-headline">Stats <em style="color:var(--red)">Dashboard</em></h1>
      <p class="mast-sub">Skater stats, goalie performance, team xG, line combos — all free, all 5v5. Follow teams and players for your personalized view.</p>
      <div class="cta-row">
        <button class="cta-btn">Personalize Your Dashboard</button>
        <button class="cta-btn outline">Sign In</button>
        <span class="cta-hint">Free account · Follow teams + players · Create your command center</span>
      </div>
    </div>
  </div>
</header>

<nav class="subnav">
  <a href="#" class="highlight">+ Follow Teams</a>
  <a href="/stats/skaters">Skaters</a>
  <a href="/stats/goalies">Goalies</a>
  <a href="/stats/teams">Teams</a>
  <a href="/stats/lines">Lines</a>
  <a href="/stats/impact">Impact</a>
  <a href="/stats/records">Series Records</a>
</nav>

<main class="wrap">

  <!-- TONIGHT -->
  <div style="margin-bottom:32px">
    <div class="section-label">Tonight · Stanley Cup Final</div>
    <div class="tonight-card">
      <div class="tonight-round">Stanley Cup Final · Game 1</div>
      <div class="tonight-matchup">
        <div class="tonight-team">
          <img src="/logos/nhl/VGK_light.svg" alt="VGK" />
          <div class="tonight-team-abbr">VGK</div>
        </div>
        <div class="tonight-center">
          <div style="font-family:var(--display);font-weight:800;font-size:28px;letter-spacing:-0.02em;color:var(--ink-32)">VS</div>
          <div class="tonight-time">8:00 PM ET · ABC</div>
        </div>
        <div class="tonight-team">
          <img src="/logos/nhl/CAR_light.svg" alt="CAR" />
          <div class="tonight-team-abbr">CAR</div>
        </div>
      </div>
      <div class="wp-bar">
        <div class="wp-bar-away" style="width:46%"></div>
        <div class="wp-bar-home" style="width:54%"></div>
      </div>
      <div class="wp-labels"><span>VGK 46%</span><span>HGB Win Probability</span><span>CAR 54%</span></div>
      <div class="tonight-stats" style="margin-top:16px">
        <div class="tonight-stat"><div class="tonight-stat-val">CAR +0.4</div><div class="tonight-stat-lbl">xG Edge</div></div>
        <div class="tonight-stat"><div class="tonight-stat-val">3-2</div><div class="tonight-stat-lbl">VGK Last 5</div></div>
        <div class="tonight-stat"><div class="tonight-stat-val">4-1</div><div class="tonight-stat-lbl">CAR Last 5</div></div>
      </div>
      <a href="/games" class="tonight-cta">Game Center →</a>
    </div>
  </div>

  <div class="grid-2">
    <!-- LEFT: Preview teams + personalization prompt -->
    <div>
      <div class="section-label">Top Teams This Season</div>
      <div class="team-preview-grid">
        {previewTeams.map(t => (
          <div class="team-preview-card">
            <img src={`/logos/nhl/${t.abbr}_light.svg`} alt={t.abbr} />
            <div>
              <div class="team-preview-name">{t.abbr}</div>
              <div class="team-preview-stat">{t.xgf_pct} xGF%</div>
              <div class="team-preview-lock">Follow to track</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- RIGHT: Top performers -->
    <div>
      <div class="section-label">League Highlights</div>
      <div class="performers">
        {topPerformers.map(p => (
          <div class="performer">
            <div>
              <div class="performer-name">{p.name}</div>
              <div class="performer-label">{p.label}</div>
            </div>
            <div class="performer-team">{p.team}</div>
            <div class="performer-stat">{p.stat}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Personalization CTA bar -->
  <div class="personalize-bar">
    <div class="personalize-bar-text">
      <div class="personalize-bar-headline">Make it yours</div>
      <div class="personalize-bar-sub">Follow NJD, SJS, or any team → get your personalized command center with player stats, game previews, and model notes.</div>
    </div>
    <button class="personalize-bar-cta">Personalize Your Dashboard →</button>
  </div>

  <!-- Stats quick access -->
  <div style="margin-bottom:16px">
    <div class="section-label">All Stats — Free Access</div>
  </div>
  <div class="stats-grid">
    {statLinks.map(l => (
      <a href={l.href} class="stat-card">
        <div class="stat-card-label">{l.label}</div>
        <div class="stat-card-desc">{l.desc}</div>
      </a>
    ))}
  </div>

</main>
</body>
</html>
