---
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('analysis', ({ data }) => data.status === 'published');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(d: string): string {
  return new Date(d + 'T12:00:00Z').toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}

function readingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}

const { title, description, date, tags, og_image, author } = post.data;
const canonicalUrl = `https://hockeygamebot.com/analysis/${post.slug}`;
const ogImage = og_image ? `https://hockeygamebot.com${og_image}` : 'https://hockeygamebot.com/og/default.png';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} · HockeyGameBot</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="HockeyGameBot" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="article:published_time" content={date} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@hockeygamebot" />
  <meta name="twitter:creator" content="@mattdonders" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/favicon-180x180.png" />

  <style is:global>
    :root {
      --bg: #EFEEE8; --bg-2: #E8E7E0; --surface: #FFFFFF;
      --ink: #0d0d14; --red: #E8002D;
      --ink-72: rgba(13,13,20,.72); --ink-48: rgba(13,13,20,.48);
      --ink-32: rgba(13,13,20,.32); --ink-20: rgba(13,13,20,.20);
      --ink-14: rgba(13,13,20,.14); --ink-06: rgba(13,13,20,.06);
      --ink-04: rgba(13,13,20,.04);
      --display: "Barlow Condensed", sans-serif;
      --body: "Barlow", sans-serif;
      --mono: "JetBrains Mono", monospace;
    }
    html[data-theme="dark"] {
      --bg: #0D0D14; --bg-2: #14141E; --surface: #1A1A26;
      --ink: #EFEEE8; --red: #FF3355;
      --ink-72: rgba(239,238,232,.72); --ink-48: rgba(239,238,232,.48);
      --ink-32: rgba(239,238,232,.32); --ink-20: rgba(239,238,232,.20);
      --ink-14: rgba(239,238,232,.14); --ink-06: rgba(239,238,232,.06);
      --ink-04: rgba(239,238,232,.04);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; }
    a { color: var(--red); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { display: block; max-width: 100%; }

    .wrap { max-width: 860px; margin: 0 auto; padding: 0 32px; }

    /* Masthead */
    .mast {
      border-bottom: 2px solid var(--ink);
      background-color: var(--bg);
      background-image: linear-gradient(rgba(13,13,20,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(13,13,20,.04) 1px, transparent 1px);
      background-size: 96px 96px;
    }
    .mast-inner { max-width: 860px; margin: 0 auto; padding: 36px 32px; }
    .mast-nav {
      font-family: var(--mono); font-size: 10.5px; color: var(--ink-32);
      letter-spacing: 0.08em; text-transform: uppercase;
      display: flex; align-items: center; gap: 8px; margin-bottom: 20px;
    }
    .mast-nav a { color: var(--ink-48); text-decoration: none; }
    .mast-nav a:hover { color: var(--red); text-decoration: none; }
    .mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
    .mast-headline {
      font-family: var(--display); font-weight: 800;
      font-size: clamp(28px, 4vw, 52px);
      text-transform: uppercase; line-height: 1.05; letter-spacing: -0.005em;
      margin-bottom: 16px;
    }
    .mast-meta {
      display: flex; align-items: center; flex-wrap: wrap; gap: 16px;
      font-family: var(--mono); font-size: 10.5px; color: var(--ink-48);
      letter-spacing: 0.06em;
    }
    .mast-meta .sep { color: var(--ink-20); }
    .mast-meta a { color: var(--ink-48); }
    .mast-meta a:hover { color: var(--red); text-decoration: none; }
    .tag {
      font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.10em;
      text-transform: uppercase; color: var(--ink-48);
      border: 1px solid var(--ink-14); padding: 2px 6px;
    }

    /* Article body — centered reading column inside the full-width wrap */
    .article-outer { padding: 56px 0 80px; }
    .article-body {
      max-width: 740px; margin: 0 auto;
      font-size: 16px; line-height: 1.75; color: var(--ink-72);
    }

    /* Markdown prose styles */
    .article-body p { margin-bottom: 1.4em; }
    .article-body h2 {
      font-family: var(--display); font-weight: 800; font-size: 26px;
      text-transform: uppercase; letter-spacing: 0.01em;
      color: var(--ink); margin: 2em 0 0.6em;
    }
    .article-body h3 {
      font-family: var(--display); font-weight: 700; font-size: 20px;
      text-transform: uppercase; color: var(--ink); margin: 1.6em 0 0.5em;
    }
    .article-body a { color: var(--red); }
    .article-body strong { font-weight: 700; color: var(--ink); }
    .article-body em { font-style: italic; }
    .article-body blockquote {
      border-left: 3px solid var(--red); margin: 1.6em 0;
      padding: 0.5em 0 0.5em 1.2em;
      font-family: var(--display); font-weight: 700; font-size: 20px;
      line-height: 1.4; color: var(--ink); font-style: normal;
    }
    .article-body ul, .article-body ol {
      padding-left: 1.5em; margin-bottom: 1.4em;
    }
    .article-body li { margin-bottom: 0.4em; }
    .article-body img {
      border: 1px solid var(--ink-14); margin: 2em 0; max-width: 100%;
    }
    .article-body table {
      width: 100%; border-collapse: collapse;
      font-family: var(--mono); font-size: 12px;
      margin: 1.6em 0;
    }
    .article-body th {
      text-align: left; padding: 6px 10px;
      border-bottom: 2px solid var(--ink); font-weight: 700;
    }
    .article-body td {
      padding: 6px 10px; border-bottom: 1px solid var(--ink-06);
    }
    .article-body code {
      font-family: var(--mono); font-size: 13px;
      background: var(--bg-2); padding: 1px 5px; border-radius: 2px;
    }
    .article-body pre {
      background: var(--bg-2); border: 1px solid var(--ink-14);
      padding: 16px; overflow-x: auto; margin: 1.6em 0;
    }
    .article-body pre code { background: none; padding: 0; }
    .article-body hr {
      border: none; border-top: 1px solid var(--ink-14); margin: 2em 0;
    }

    /* Footer */
    .article-footer {
      max-width: 740px; margin: 56px auto 0;
      padding-top: 24px; border-top: 1px solid var(--ink-14);
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 12px;
    }
    .article-footer a {
      font-family: var(--display); font-weight: 700; font-size: 11px;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--ink-48); text-decoration: none;
    }
    .article-footer a:hover { color: var(--red); text-decoration: none; }

    @media (max-width: 640px) {
      .mast-inner { padding: 24px 20px; }
      .mast-card { padding: 20px; }
      .wrap { padding: 0 20px; }
      .article-body { font-size: 15px; }
    }
  </style>
</head>
<body>

<Nav currentPath="/analysis" />

<section class="mast">
  <div class="mast-inner">
    <div class="mast-nav">
      <a href="/analysis">← Analysis</a>
    </div>
    <div class="mast-card">
      <h1 class="mast-headline">{title}</h1>
      <div class="mast-meta">
        <span>{formatDate(date)}</span>
        <span class="sep">·</span>
        <span>{readingTime(post.body)}</span>
        <span class="sep">·</span>
        <span>By <a href="https://x.com/mattdonders" target="_blank" rel="noopener">{author}</a></span>
        {tags.length > 0 && <span class="sep">·</span>}
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </div>
  </div>
</section>

<main class="wrap">
  <div class="article-outer">
    <div class="article-body">
      <Content />
    </div>
    <footer class="article-footer">
      <a href="/analysis">← All articles</a>
      <span style="font-family:var(--mono);font-size:10px;color:var(--ink-32);letter-spacing:0.08em">
        Matt Donders ·
        <a href="https://x.com/mattdonders" target="_blank" rel="noopener">X</a> ·
        <a href="https://bsky.app/profile/mattdonders.com" target="_blank" rel="noopener">Bluesky</a> ·
        <a href="https://www.threads.net/@mattdonders" target="_blank" rel="noopener">Threads</a>
      </span>
    </footer>
  </div>
</main>

</body>
</html>
