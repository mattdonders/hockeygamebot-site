---
import Nav from '../../components/Nav.astro';
import ThemeScript from '../../components/ThemeScript.astro';
import Fonts from '../../components/Fonts.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('analysis', ({ data }) => data.status === 'published');
allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(d: string): string {
  return new Date(d + 'T12:00:00Z').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <ThemeScript />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Analysis · HockeyGameBot</title>
  <meta name="description" content="Long-form hockey analysis from HockeyGameBot. Model-backed breakdowns of playoff matchups, player performance, and more." />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="HockeyGameBot" />
  <meta property="og:title" content="Analysis · HockeyGameBot" />
  <meta property="og:description" content="Model-backed hockey analysis from HockeyGameBot." />
  <meta property="og:url" content="https://hockeygamebot.com/analysis" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@hockeygamebot" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/favicon-180x180.png" />
  <style is:global>
    :root {
      --bg: #EFEEE8; --bg-2: #E8E7E0; --surface: #FFFFFF;
      --ink: #0d0d14; --red: #E8002D;
      --ink-72: rgba(13,13,20,.72); --ink-48: rgba(13,13,20,.48);
      --ink-32: rgba(13,13,20,.32); --ink-20: rgba(13,13,20,.20);
      --ink-14: rgba(13,13,20,.14); --ink-06: rgba(13,13,20,.06);
      --ink-04: rgba(13,13,20,.04);
      --display: "Barlow Condensed", sans-serif;
      --body: "Barlow", sans-serif;
      --mono: "JetBrains Mono", monospace;
    }
    html[data-theme="dark"] {
      --bg: #0D0D14; --bg-2: #14141E; --surface: #1A1A26;
      --ink: #EFEEE8; --red: #FF3355;
      --ink-72: rgba(239,238,232,.72); --ink-48: rgba(239,238,232,.48);
      --ink-32: rgba(239,238,232,.32); --ink-20: rgba(239,238,232,.20);
      --ink-14: rgba(239,238,232,.14); --ink-06: rgba(239,238,232,.06);
      --ink-04: rgba(239,238,232,.04);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }

    .wrap { max-width: 1280px; margin: 0 auto; padding: 0 32px; }

    /* Masthead */
    .mast {
      border-bottom: 2px solid var(--ink);
      background-color: var(--bg);
      background-image: linear-gradient(rgba(13,13,20,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(13,13,20,.04) 1px, transparent 1px);
      background-size: 96px 96px;
    }
    .mast-inner { max-width: 1280px; margin: 0 auto; padding: 36px 32px; }
    .mast-eyebrow {
      font-family: var(--display); font-weight: 700; font-size: 11px;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--ink-48); display: flex; align-items: center; gap: 8px; margin-bottom: 20px;
    }
    .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
    .mast-card {
      background: var(--surface); border: 1px solid var(--ink);
      padding: 28px 32px 24px;
    }
    .mast-headline {
      font-family: var(--display); font-weight: 800;
      font-size: clamp(36px, 5.5vw, 64px);
      text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; margin-bottom: 10px;
    }
    .mast-headline em { color: var(--red); font-style: normal; }
    .mast-lede { font-size: 13.5px; line-height: 1.6; color: var(--ink-48); max-width: 600px; }

    /* Article grid */
    .section { padding: 48px 0 80px; }
    .section-head {
      display: flex; align-items: baseline; justify-content: space-between;
      margin-bottom: 32px; gap: 16px;
    }
    .section-title {
      font-family: var(--display); font-weight: 800; font-size: 22px;
      text-transform: uppercase; letter-spacing: 0.01em;
    }
    .section-meta { font-family: var(--mono); font-size: 10.5px; color: var(--ink-32); letter-spacing: 0.06em; }

    .articles { display: flex; flex-direction: column; gap: 0; }
    .article-card {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 0 28px;
      padding: 24px 0;
      border-bottom: 1px solid var(--ink-14);
      text-decoration: none;
      color: inherit;
      transition: background 0.1s;
    }
    .article-card:first-child { border-top: 1px solid var(--ink-14); }
    .article-card:hover { background: var(--ink-04); margin: 0 -32px; padding-left: 32px; padding-right: 32px; }
    .article-date {
      font-family: var(--mono); font-size: 10.5px; color: var(--ink-32);
      letter-spacing: 0.06em; padding-top: 4px; white-space: nowrap;
    }
    .article-body { min-width: 0; }
    .article-title {
      font-family: var(--display); font-weight: 800; font-size: clamp(18px, 2.5vw, 24px);
      text-transform: uppercase; letter-spacing: 0.01em; line-height: 1.15;
      margin-bottom: 6px; color: var(--ink);
    }
    .article-card:hover .article-title { color: var(--red); }
    .article-desc {
      font-size: 13.5px; line-height: 1.55; color: var(--ink-72);
      margin-bottom: 10px; max-width: 680px;
    }
    .article-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.10em;
      text-transform: uppercase; color: var(--ink-48);
      border: 1px solid var(--ink-14); padding: 2px 6px;
    }

    /* Empty state */
    .empty {
      padding: 80px 0; text-align: center;
      font-family: var(--mono); font-size: 13px; color: var(--ink-32);
      letter-spacing: 0.06em;
    }

    @media (max-width: 640px) {
      .article-card { grid-template-columns: 1fr; gap: 4px 0; }
      .article-date { padding-top: 0; }
      .mast-inner { padding: 28px 20px; }
      .mast-card { padding: 20px; }
      .wrap { padding: 0 20px; }
      .article-card:hover { margin: 0 -20px; padding-left: 20px; padding-right: 20px; }
    }
  </style>
</head>
<body>

<Nav currentPath="/analysis" />

<section class="mast">
  <div class="mast-inner">
    <div class="mast-eyebrow"><span class="pip"></span> HGB Analysis</div>
    <div class="mast-card">
      <h1 class="mast-headline">Model-backed<br><em>analysis.</em></h1>
      <p class="mast-lede">Long-form breakdowns of playoff matchups, player performance, and what the underlying numbers actually say.</p>
    </div>
  </div>
</section>

<main class="wrap">
  <section class="section">
    <div class="section-head">
      <span class="section-title">All articles</span>
      <span class="section-meta">{allPosts.length} {allPosts.length === 1 ? 'article' : 'articles'}</span>
    </div>

    {allPosts.length === 0 ? (
      <div class="empty">No articles yet — check back soon.</div>
    ) : (
      <div class="articles">
        {allPosts.map(post => (
          <a class="article-card" href={`/analysis/${post.slug}`}>
            <span class="article-date">{formatDate(post.data.date)}</span>
            <div class="article-body">
              <div class="article-title">{post.data.title}</div>
              <p class="article-desc">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="article-tags">
                  {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</main>

</body>
</html>
