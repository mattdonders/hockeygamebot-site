.bc.bb-goal-flash { border-color: var(--red); box-shadow: 0 0 0 1px var(--red), inset 0 0 16px rgba(232,0,45,0.06); animation: bbFlash 4s ease forwards; }
@keyframes bbFlash { 0%,60% { border-color: var(--red); box-shadow: 0 0 0 1px var(--red), inset 0 0 16px rgba(232,0,45,0.06); } 100% { border-color: var(--ink-14); box-shadow: none; } }

/* ── CATCHUP PILL ── */
