function _generateMockGames(n, mode) {
  const pairs = [
    ['NJD','NYR'],['BOS','TOR'],['MTL','TBL'],['WPG','CHI'],
    ['DAL','BOS'],['OTT','FLA'],['CAR','CBJ'],['SEA','EDM'],
    ['PIT','DET'],['VGK','LAK'],['COL','STL'],['SJS','ANA'],
    ['PHI','WSH'],['BUF','NYI'],['NSH','MIN'],['CGY','VAN'],
  ];
  const isFinal = mode === 'recap';
  return Array.from({ length: n }, (_, i) => {
    const [away, home] = pairs[i % pairs.length];
    const awayScore = Math.floor(Math.random() * 5);
    const homeScore = Math.floor(Math.random() * 5);
    const period    = isFinal ? 3 : (Math.floor(Math.random() * 3) + 1);
    const secs      = Math.floor(Math.random() * 1200);
    const mm = String(Math.floor(secs / 60)).padStart(2,'0');
    const ss = String(secs % 60).padStart(2,'0');
    return {
      game_id: `mock_${i}`,
      status: isFinal ? 'final' : 'live',
      period,
      time_remaining: `${mm}:${ss}`,
      in_intermission: false,
      start_time: new Date(Date.now() - 3600000).toISOString(),
      away_team: { abbrev: away, short_name: away, score: awayScore },
      home_team: { abbrev: home, short_name: home, score: homeScore },
      win_probability: 0.4 + Math.random() * 0.2,
      home_sog: 10 + Math.floor(Math.random() * 20),
      away_sog: 10 + Math.floor(Math.random() * 20),
      xg_home: +(1 + Math.random() * 3).toFixed(1),
      xg_away: +(1 + Math.random() * 3).toFixed(1),
      xg_home_5v5: +(0.5 + Math.random() * 2).toFixed(1),
      xg_away_5v5: +(0.5 + Math.random() * 2).toFixed(1),
      last_event: `${home} - Shot P${period} ${mm}:${ss}`,
      recent_events: [],
      three_stars: isFinal ? [
        { player_last_name: 'Hughes',    team_abbrev: home, star: 3 },
        { player_last_name: 'MacKinnon', team_abbrev: away, star: 2 },
        { player_last_name: 'Draisaitl', team_abbrev: home, star: 1 },
      ] : null,
      clock_at: null,
    };
  });
}

async function fetchGames() {
  if (_mockN > 0) return { games: _generateMockGames(_mockN, _mockMode) };
  const resp = await fetch(`${API_BASE}/v1/games/today`, { cache: 'no-store' });
  if (!resp.ok) throw new Error(`API ${resp.status}`);
  return resp.json();
}

async function fetchYesterdayData() {
