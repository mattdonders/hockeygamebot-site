}
</style>
<body>

<div id="catchup-pill">CATCHING UP TO LIVE…</div>

<!-- ── EDITORIAL NAV ── -->
<nav class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="wordmark">Hockey<span class="dot"></span>Gamebot</a>
    <div class="nav-status" id="nav-status">
      <span class="pip" id="nav-pip" style="display:none"></span>
      <span id="nav-status-text">— live · — tonight</span>
    </div>
    <nav class="nav-links">
      <a href="/">Home</a><span class="sep"> · </span>
      <a href="/scoreboard" class="active">Scoreboard</a><span class="sep"> · </span>
      <a href="/playoffs/2026">Playoffs</a><span class="sep"> · </span>
      <a href="/teams">Teams</a><span class="sep"> · </span>
      <a href="/support">Support</a>
    </nav>
  </div>
</nav>

{playoffActive && (
  <a class="playoff-strip" href="/playoffs/2026" aria-label="Open 2026 playoff predictions">
    <span class="playoff-strip__tag">★ 2026 Playoffs · Round 1</span>
    {playoffNext ? (
      <span class="playoff-strip__mid" data-iso={playoffNext.gameDateISO}>
        Next: <strong>{playoffNext.snap.team_a}</strong> vs <strong>{playoffNext.snap.team_b}</strong>
        <span class="playoff-strip__time" data-iso={playoffNext.gameDateISO}>—</span>
        · {playoffNext.snap.team_a} {playoffNext.snap.win_pct_a}%
      </span>
    ) : (
      <span class="playoff-strip__mid">Predictions updated daily</span>
    )}
    <span class="playoff-strip__cta">Full bracket →</span>
  </a>
)}

<div class="ticker-strip">
  <div class="ticker-lbl" id="ticker-lbl">⚡ LIVE</div>
  <div class="ticker-content">
    <div class="ticker-inner" id="ticker-inner">
      <span>Loading game data…</span>
    </div>
  </div>
</div>

