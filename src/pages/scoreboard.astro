// ─────────────────────────────────────────────────────────────────────────────
// TAB VISIBILITY — throttle when hidden, catchup indicator on return
// ─────────────────────────────────────────────────────────────────────────────
let pollTimer = null;
let hiddenAt = null;
const STALE_THRESHOLD_MS = 10_000; // show catchup pill if hidden >10s

function startPolling(interval) {
  clearInterval(pollTimer);
  pollTimer = setInterval(pollAndUpdate, interval);
}

function showCatchupPill() {
  const pill = document.getElementById('catchup-pill');
  pill.classList.add('show');
  setTimeout(() => pill.classList.remove('show'), 1500);
}

// ── API error UI ──────────────────────────────────────────────────────────────
function _fmtAgo(ms) {
  const s = Math.round(ms / 1000);
  return s < 60 ? `${s}s ago` : `${Math.floor(s / 60)}m ago`;
}

function showApiError(isStale) {
  document.getElementById('api-error-banner')?.remove();
  document.getElementById('api-stale-bar')?.remove();
  clearTimeout(_countdownTimer);

  const wrapper = document.getElementById('grid-wrapper');
  if (!wrapper) return;

  if (isStale) {
    // Keep existing cards visible — amber bar above them
    const bar = document.createElement('div');
    bar.id = 'api-stale-bar';
    bar.setAttribute('role', 'status'); // polite: don't interrupt screen readers
    bar.style.cssText = 'padding:6px 14px;background:rgba(255,202,40,0.1);color:#ffca28;font-size:12px;text-align:center;letter-spacing:0.04em;border-bottom:1px solid rgba(255,202,40,0.2);';
    const ago = _fmtAgo(Date.now() - _lastSuccessAt);
    bar.textContent = `Scores last updated ${ago}. Retrying…`;
    wrapper.prepend(bar);
  } else {
    // Cold-start: nothing to show — replace content with error banner
    const secs = Math.round(_retryDelay / 1000);
    const banner = document.createElement('div');
    banner.id = 'api-error-banner';
    banner.setAttribute('role', 'alert'); // assertive: announce immediately
    banner.style.cssText = 'padding:40px 16px;text-align:center;';
    banner.innerHTML = `
      <div style="font-size:14px;font-weight:700;color:#ff3d3d;letter-spacing:0.06em;margin-bottom:8px;">UNABLE TO LOAD SCORES</div>
      <div style="font-size:12px;color:#555;margin-bottom:14px;">Retrying in <span id="api-error-countdown">${secs}s</span>.</div>
      <button id="api-error-retry" style="background:#ff3d3d;color:#fff;border:none;padding:7px 18px;border-radius:4px;cursor:pointer;font-size:12px;font-family:inherit;font-weight:700;letter-spacing:0.08em;">RETRY NOW</button>`;
    wrapper.innerHTML = '';
    wrapper.appendChild(banner);

    // Manual retry — treat as a fresh attempt (reset backoff)
    document.getElementById('api-error-retry').addEventListener('click', () => {
      clearTimeout(_countdownTimer);
      clearInterval(pollTimer);
      _consecutiveFailures = 0;
      _retryDelay = 4_000;
      clearApiError();
      pollAndUpdate();
    });

    let remaining = secs;
    const countEl = document.getElementById('api-error-countdown');
    function tick() {
      remaining--;
      if (countEl && remaining > 0) {
        countEl.textContent = `${remaining}s`;
        _countdownTimer = setTimeout(tick, 1_000);
      }
    }
    _countdownTimer = setTimeout(tick, 1_000);
  }
}

function clearApiError() {
  document.getElementById('api-error-banner')?.remove();
  document.getElementById('api-stale-bar')?.remove();
  clearTimeout(_countdownTimer);
  _countdownTimer = null;
}


document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'hidden') {
    hiddenAt = Date.now();
    startPolling(60_000); // slow down while backgrounded
  } else {
    const wasHiddenMs = hiddenAt ? Date.now() - hiddenAt : 0;
    hiddenAt = null;
    if (wasHiddenMs > STALE_THRESHOLD_MS) showCatchupPill();
    pollAndUpdate(); // immediate refresh
    startPolling(_recapMode ? 60_000 : POLL_INTERVAL); // resume normal cadence
  }
});

// ─────────────────────────────────────────────────────────────────────────────
// SSE PUSH — bot events trigger immediate poll instead of waiting for interval
// ─────────────────────────────────────────────────────────────────────────────
const SSE_URL = 'https://push.hockeygamebot.com/events';
const sseIndicator = document.getElementById('sse-indicator');

let _sse = null;
function connectSSE() {
  // Always close any existing connection first — EventSource also auto-reconnects
  // natively, so without this we'd accumulate duplicate connections on each error.
  if (_sse) { _sse.close(); _sse = null; }

  _sse = new EventSource(SSE_URL);

  _sse.onopen = () => {
    sseIndicator?.classList.add('connected');
    sseIndicator?.classList.remove('error');
  };

  _sse.onmessage = (e) => {
    let data;
    try { data = JSON.parse(e.data); } catch { return; }
    if (data.type === 'connected') {
      sseIndicator?.classList.add('connected');
      sseIndicator?.classList.remove('error');
      return;
    }
    if (data.type === 'goal' || data.type === 'period_end' || data.type === 'game_end') {
      pollAndUpdate();
    }
    if (data.type === 'goal') {
      // Refresh goals ticker ~3s after goal — give D1 time to have the new row
      setTimeout(fetchGoals, 3000);
    }
  };

  _sse.onerror = () => {
    sseIndicator?.classList.remove('connected');
    sseIndicator?.classList.add('error');
    if (_sse) { _sse.close(); _sse = null; }
    setTimeout(connectSSE, 10_000);
  };
}

connectSSE();

