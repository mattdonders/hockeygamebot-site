---
// HockeyGameBot live scoreboard — editorial light-mode re-skin of index.astro

type PlayoffSnap = {
  series_id: string;
  team_a: string; team_b: string;
  win_pct_a: number; win_pct_b: number;
  next_game_utc: string | null;
  is_complete: boolean;
};
let playoffNext: { snap: PlayoffSnap; gameDateISO: string } | null = null;
let playoffActive = false;
try {
  const res = await fetch('https://api.hockeygamebot.com/v1/playoffs/round/1');
  if (res.ok) {
    const data = await res.json();
    const active: PlayoffSnap[] = (data.series ?? []).filter((s: PlayoffSnap) => !s.is_complete);
    playoffActive = active.length > 0;
    const withTime = active.filter(s => s.next_game_utc);
    withTime.sort((a, b) => a.next_game_utc! < b.next_game_utc! ? -1 : 1);
    if (withTime[0]) playoffNext = { snap: withTime[0], gameDateISO: withTime[0].next_game_utc! };
  }
} catch (_) { /* no banner */ }
---
<!DOCTYPE html>
