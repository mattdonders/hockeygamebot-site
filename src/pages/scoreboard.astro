<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #EFEEE8;
  --surface: #FFFFFF;
  --ink: #0d0d14;
  --ink-86: rgba(13,13,20,0.86);
  --ink-72: rgba(13,13,20,0.72);
  --ink-48: rgba(13,13,20,0.48);
  --ink-32: rgba(13,13,20,0.32);
  --ink-20: rgba(13,13,20,0.20);
  --ink-14: rgba(13,13,20,0.14);
  --ink-10: rgba(13,13,20,0.10);
  --ink-06: rgba(13,13,20,0.06);
  --red: #E8002D;
  --green: #16a34a;
  --yellow: #b45309;
  --orange: #c2410c;
  --blue: #1d4ed8;
  --cyan: #0284c7;
  --display: "Barlow Condensed", sans-serif;
  --body: "Barlow", sans-serif;
  --mono: "JetBrains Mono", monospace;
}
html, body {
  width: 100%; height: 100vh; overflow: hidden;
  background: var(--bg); font-family: var(--body); color: var(--ink);
  display: flex; flex-direction: column;
  -webkit-font-smoothing: antialiased;
}
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }

/* ── NAV ── */
.wrap { max-width: 1400px; margin: 0 auto; padding: 0 32px; }
.nav { background: var(--bg); border-bottom: 1px solid var(--ink-14); flex-shrink: 0; z-index: 50; }
.nav-inner { display: flex; align-items: center; height: 52px; gap: 0; }
.wordmark { font-family: var(--display); font-weight: 800; font-size: 20px; letter-spacing: 0.04em; text-transform: uppercase; display: inline-flex; align-items: center; line-height: 1; color: var(--ink); }
.wordmark .dot { width: 6px; height: 6px; background: var(--red); border-radius: 50%; margin: 0 7px; display: inline-block; transform: translateY(-1px); }
.nav-status { display: inline-flex; align-items: center; gap: 7px; margin-left: 18px; font-family: var(--mono); font-size: 10.5px; color: var(--ink-48); letter-spacing: 0.04em; }
.nav-status .pip { width: 6px; height: 6px; background: var(--red); border-radius: 50%; animation: pip 1.4s infinite; }
.nav-links { margin-left: auto; display: flex; align-items: center; gap: 0; font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; }
.nav-links a { padding: 5px 12px; color: var(--ink-48); transition: color .15s; }
.nav-links a:hover, .nav-links a.active { color: var(--ink); }
.nav-links .sep { color: var(--ink-20); }
@keyframes pip { 0%,100% { opacity:1; } 50% { opacity:0.25; } }

/* ── PLAYOFF STRIP ── */
.playoff-strip {
  display: flex; align-items: center; gap: 14px;
  padding: 6px 20px;
  background: linear-gradient(90deg, rgba(232,0,45,0.08), rgba(232,0,45,0.02) 60%, transparent);
  border-bottom: 1px solid rgba(232,0,45,0.14);
  color: var(--ink-72);
  text-decoration: none;
  font: 500 11px/1 var(--mono);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  transition: background 160ms ease;
  flex-shrink: 0;
}
.playoff-strip:hover { background: linear-gradient(90deg, rgba(232,0,45,0.13), rgba(232,0,45,0.04) 60%, transparent); }
.playoff-strip__tag { color: var(--red); font-weight: 700; letter-spacing: 0.12em; flex-shrink: 0; }
.playoff-strip__mid { flex: 1; color: var(--ink-48); font-weight: 500; text-transform: none; letter-spacing: 0.02em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.playoff-strip__mid strong { color: var(--ink-72); font-weight: 600; }
.playoff-strip__time { margin: 0 4px; color: var(--ink-32); }
.playoff-strip__cta { color: var(--ink-48); font-weight: 600; letter-spacing: 0.1em; flex-shrink: 0; }
.playoff-strip:hover .playoff-strip__cta { color: var(--red); }
@media (max-width: 700px) {
  .playoff-strip { padding: 6px 14px; gap: 10px; font-size: 10px; }
  .playoff-strip__mid { display: none; }
}

/* ── TICKER ── */
.ticker-strip { height: 30px; background: var(--ink); display: flex; align-items: center; overflow: hidden; flex-shrink: 0; }
.ticker-lbl { flex-shrink: 0; height: 100%; background: rgba(0,0,0,0.3); border-right: 2px solid var(--red); padding: 0 14px; display: flex; align-items: center; font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.16em; color: var(--red); white-space: nowrap; transition: color 0.3s, border-color 0.3s; }
.ticker-lbl.recap { color: rgba(255,255,255,0.4); border-right-color: rgba(255,255,255,0.2); }
.ticker-content { flex: 1; overflow: hidden; white-space: nowrap; }
.ticker-inner { display: inline-block; animation: scroll 60s linear infinite; padding-left: 40%; }
@keyframes scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.ticker-inner span { display: inline-block; font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.55); margin-right: 56px; }
.ticker-inner span strong { color: rgba(255,255,255,0.9); }
.ti-goal strong { color: #7dd3fc; }
.ti-goal em { font-style: normal; color: #fde68a; font-size: 10px; font-weight: 700; vertical-align: middle; }
.ti-penalty strong { color: #fde68a; }
.ti-final strong { color: rgba(255,255,255,0.4); }
.ti-sep { color: rgba(255,255,255,0.2); margin: 0 20px; font-size: 8px; }

/* ── GRID WRAPPER ── */
#grid-wrapper { flex: 1; background: var(--bg); padding: 4px; position: relative; overflow: hidden; min-height: 0; }

/* Base grid container */
.gg { width: 100%; height: 100%; gap: 4px; }

/* Layout variants */
.gg-1 { display: grid; grid-template-columns: 1fr; grid-template-rows: 1fr; }
.gg-2 { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr; }
.gg-3 { display: grid; grid-template-columns: 3fr 2fr; grid-template-rows: 1fr 1fr; }
.gg-3 #g-0 { grid-row: 1 / 3; }
.gg-4 { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
.gg-5 { display: flex; height: 100%; }
.gg-left  { flex: 1; display: flex; flex-direction: column; gap: 4px; }
.gg-right { flex: 1; display: flex; flex-direction: column; gap: 4px; margin-left: 4px; }
.gg-left .hcard, .gg-right .hcard { flex: 1; min-height: 0; }
.gg-6  { display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr; }
.gg-8r  { display: grid; grid-template-columns: repeat(4, 1fr); grid-template-rows: 1fr 1fr; }
.gg-9r  { display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: 1fr 1fr 1fr; }
.gg-12r { display: grid; grid-template-columns: repeat(4, 1fr); grid-template-rows: 1fr 1fr 1fr; }
.gg-15r { display: grid; grid-template-columns: repeat(5, 1fr); grid-template-rows: 1fr 1fr 1fr; }
.gg-7r { display: flex; height: 100%; gap: 4px; }
.gg-7r-left  { flex: 2; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 4px; }
.gg-7r-right { flex: 1; display: grid; grid-template-columns: 1fr; grid-template-rows: 1fr 1fr 1fr; gap: 4px; }
.gg-11r { display: flex; height: 100%; gap: 4px; }
.gg-11r-left  { flex: 1; display: grid; grid-template-columns: 1fr; grid-template-rows: 1fr 1fr; gap: 4px; }
.gg-11r-right { flex: 2; display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr 1fr; gap: 4px; }
.gg-13r { display: flex; height: 100%; gap: 4px; }
.gg-13r-left  { flex: 1; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 4px; }
.gg-13r-right { flex: 1; display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr 1fr; gap: 4px; }
.gg-10 { display: flex; height: 100%; gap: 4px; }
.gg-10-left  { flex: 1; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 4px; }
.gg-10-right { flex: 1; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr 1fr; gap: 4px; }

.hcard:empty { background: rgba(13,13,20,0.025); border-color: rgba(13,13,20,0.06); }

.gg-13r-right .hc-logo { width: 56px !important; height: 56px !important; }
.gg-13r-right .hc-abbr { font-size: 22px !important; }
.gg-13r-right .hc-n    { font-size: 48px !important; }
.gg-13r-right .hc-sep  { font-size: 26px !important; }
.gg-13r-right .hc-score-center { min-width: 88px !important; gap: 4px !important; }
.gg-13r-right .hc-sb-row { gap: 4px !important; }
.gg-13r-right .hc-star-name { font-size: 10px !important; }
.gg-13r-right .hc-status    { font-size: 12px !important; }
.gg-15r .hc-logo { width: 60px !important; height: 60px !important; }
.gg-15r .hc-abbr { font-size: 24px !important; }
.gg-15r .hc-n    { font-size: 50px !important; }
.gg-15r .hc-sep  { font-size: 27px !important; }
.gg-15r .hc-score-center { min-width: 92px !important; gap: 4px !important; }
.gg-15r .hc-sb-row { gap: 4px !important; }
.gg-15r .hc-star-name { font-size: 10px !important; }
.gg-15r .hc-status    { font-size: 13px !important; }
.hcard.compact .hc-last { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ── HERO CARD ── */
.hcard {
  background: var(--surface); border: 1px solid var(--ink-14);
  position: relative; overflow: hidden;
  display: grid; grid-template-rows: 4px auto 1fr auto;
  transform-origin: center center; cursor: pointer;
}
.hcard::after {
  content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(13,13,20,0.02) 0%, transparent 55%);
}
.hcard:hover { border-color: rgba(13,13,20,0.28); }
.hcard--loading { display: flex; align-items: center; justify-content: center; }
.hcard--loading::before {
  content: ''; width: 32px; height: 32px; border: 2px solid var(--ink-14);
  border-top-color: var(--ink-32); border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── GOAL WASH ── */
.goal-wash {
  position: absolute; inset: 0; z-index: 20;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
  opacity: 0; pointer-events: none;
}
.goal-wash.active { animation: washCycle 5s ease forwards; }
@keyframes washCycle { 0%{opacity:0} 8%{opacity:1} 80%{opacity:1} 100%{opacity:0} }
.gwo-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.22em; color: rgba(255,255,255,0.85); text-transform: uppercase; }
.gwo-scorer  { font-family: var(--display); font-size: clamp(32px, 5vw, 56px); font-weight: 800; line-height: 1; color: #fff; text-shadow: 0 2px 16px rgba(0,0,0,0.4); }
.gwo-goal-num { font-family: var(--display); font-size: clamp(14px, 2vw, 22px); color: rgba(255,255,255,0.7); letter-spacing: 0.06em; }
.gwo-assists  { font-size: clamp(10px, 1.2vw, 14px); color: rgba(255,255,255,0.75); }
.gwo-divider  { width: 48px; height: 1px; background: rgba(255,255,255,0.3); margin: 4px 0; }
.gwo-score    { font-family: var(--display); font-size: clamp(20px, 3vw, 32px); font-weight: 700; color: #fff; }
.gwo-context  { font-family: var(--mono); font-size: 11px; color: rgba(255,255,255,0.65); letter-spacing: 0.1em; }

/* ── CARD TRANSITIONS ── */
.hcard.exiting { opacity: 0; transform: scale(0.96); transition: opacity 0.35s ease, transform 0.35s ease; }
.hcard.entering { animation: cardEnter 0.45s ease forwards; }
@keyframes cardEnter { from { opacity: 0; transform: scale(1.025); } to { opacity: 1; transform: scale(1); } }

/* ── CARD SUB-ELEMENTS ── */
.hc-accent { width: 100%; }
.hc-head { display: flex; align-items: center; justify-content: space-between; padding: 10px 20px 0; position: relative; z-index: 2; }
.hc-status { font-family: var(--display); font-size: clamp(13px, 1.2vw, 17px); font-weight: 700; letter-spacing: 0.08em; display: flex; align-items: center; gap: 8px; color: var(--ink-48); }
.hc-status.live { color: var(--cyan); }
.hc-status.final { color: var(--ink-32); }
.hc-status.ot { color: var(--orange); }
.hc-status.scheduled { color: var(--ink-48); }
.hc-status.intermission { color: var(--blue); }
.status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cyan); position: relative; flex-shrink: 0; }
.status-dot::after { content: ''; position: absolute; inset: -2px; border-radius: 50%; border: 1.5px solid var(--cyan); animation: ringPulse 1.8s ease-out infinite; }
.hc-status.final .status-dot { background: var(--ink-32); }
.hc-status.final .status-dot::after,
.hc-status.scheduled .status-dot::after { display: none; }
.hc-status.scheduled .status-dot { background: var(--ink-32); }
.hc-status.intermission .status-dot { background: var(--blue); }
.hc-status.intermission .status-dot::after { display: none; }
@keyframes ringPulse { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(1.9); opacity: 0; } }
.hc-badges { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; align-items: center; }
.badge { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.08em; padding: 2px 8px; border-radius: 0; border: 1px solid; display: inline-flex; align-items: center; line-height: 1; }
.badge.pp   { color: #92400e; border-color: rgba(146,64,14,0.3); background: rgba(146,64,14,0.07); }
.badge.pk   { color: var(--red); border-color: rgba(232,0,45,0.3); background: rgba(232,0,45,0.06); }
.badge.adv  { color: #166534; border-color: rgba(22,101,52,0.3); background: rgba(22,101,52,0.06); }
.badge.en   { color: #c2410c; border-color: rgba(194,65,12,0.3); background: rgba(194,65,12,0.07); }
.badge.hot  { color: #c2410c; border-color: rgba(194,65,12,0.3); background: rgba(194,65,12,0.06); }
.badge.close{ color: var(--red); border-color: rgba(232,0,45,0.3); background: rgba(232,0,45,0.05); }
.badge.ot   { color: #c2410c; border-color: rgba(194,65,12,0.35); background: rgba(194,65,12,0.08); }

/* ── WIN PROBABILITY TEXT ── */
.hc-wp-text { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 0 2px; }
.hc-wp-away, .hc-wp-home { font-family: var(--mono); font-size: clamp(12px, 1.4vw, 16px); font-weight: 700; color: var(--ink); font-variant-numeric: tabular-nums; white-space: nowrap; }
.hc-wp-mid { font-family: var(--mono); font-size: clamp(7px, 0.8vw, 9px); font-weight: 600; letter-spacing: 0.1em; color: var(--ink-32); text-transform: uppercase; }

/* ── STAT BARS ── */
.hc-stat-wrap { display: flex; flex-direction: column; gap: 2px; width: 100%; }
.hc-stat-bar { display: flex; align-items: center; gap: 5px; width: 100%; }
.hc-sb-val { font-family: var(--mono); font-size: clamp(10px, 1.1vw, 13px); font-weight: 700; color: var(--ink-48); min-width: 20px; font-variant-numeric: tabular-nums; }
.hc-sb-val.away { text-align: right; }
.hc-sb-val.home { text-align: left; }
.hc-sb-track { flex: 1; height: 5px; overflow: hidden; background: var(--ink-10); }
.hc-sb-fill { height: 100%; }
.hc-sb-label { font-family: var(--mono); font-size: 9px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-20); text-align: center; }

/* ── CARD BODY ── */
.hc-body { display: flex; align-items: center; justify-content: center; padding: 4px 28px 0; position: relative; z-index: 2; }
.hc-team { display: flex; flex-direction: column; align-items: center; gap: 8px; flex: 1; }
.hc-logo { width: clamp(56px, 8vw, 100px); height: clamp(56px, 8vw, 100px); object-fit: contain; }
.hc-logo.dim { opacity: 0.22; filter: grayscale(0.4); }
.hc-abbr { font-family: var(--display); font-size: clamp(22px, 3.5vw, 40px); font-weight: 800; }
.hc-abbr.lead { color: var(--ink); }
.hc-abbr.trail { color: var(--ink-32); }
.hc-abbr.tie { color: var(--ink); }
.hc-name { font-family: var(--display); font-size: clamp(8px, 0.9vw, 10px); color: var(--ink-32); text-transform: uppercase; letter-spacing: 0.08em; }
.hc-score-center { display: flex; flex-direction: column; align-items: center; gap: 8px; min-width: clamp(100px, 14vw, 180px); }
.hc-nums { display: flex; align-items: center; gap: 12px; }
.hc-n { font-family: var(--display); font-size: clamp(52px, 8vw, 100px); font-weight: 800; line-height: 1; font-variant-numeric: tabular-nums; }
.hc-n.lead { color: var(--ink); }
.hc-n.trail { color: var(--ink-32); }
.hc-n.tie { color: var(--ink); }
.hc-sep { font-family: var(--display); font-size: clamp(28px, 4vw, 50px); color: var(--ink-20); font-weight: 800; }

/* ── CARD FOOT ── */
.hc-foot { padding: 6px 20px 10px; display: flex; flex-direction: column; gap: 4px; position: relative; z-index: 2; }
.hc-last-label { display: flex; align-items: center; gap: 8px; }
.hc-last-label span { font-family: var(--mono); font-size: 7px; font-weight: 700; letter-spacing: 0.16em; color: var(--ink-20); text-transform: uppercase; white-space: nowrap; }
.hc-last-label::before, .hc-last-label::after { content: ''; flex: 1; height: 1px; background: var(--ink-10); }
.hc-last { font-family: var(--body); font-size: clamp(10px, 1.1vw, 12px); color: var(--ink-48); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hc-last strong { color: var(--ink-72); }
.hc-stars { display: flex; justify-content: space-around; padding: 4px 0 2px; }
.hc-star { display: flex; flex-direction: column; align-items: center; gap: 2px; flex: 1; }
.hc-star-num { font-size: 9px; color: var(--ink-20); }
.hc-star-name { font-family: var(--mono); font-size: clamp(9px, 1vw, 11px); font-weight: 600; color: var(--ink-72); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 95%; text-align: center; }

/* ── RECENT EVENTS ── */
.hc-recent { padding: 6px 20px 10px; display: flex; flex-direction: column; gap: 4px; position: relative; z-index: 2; }
.hc-recent-label { display: flex; align-items: center; gap: 8px; margin-bottom: 2px; }
.hc-recent-label span { font-family: var(--mono); font-size: 7px; font-weight: 700; letter-spacing: 0.16em; color: var(--ink-20); text-transform: uppercase; white-space: nowrap; }
.hc-recent-label::before, .hc-recent-label::after { content: ''; flex: 1; height: 1px; background: var(--ink-10); }
.hc-recent-row { display: flex; align-items: center; gap: 6px; }
.hc-recent-row:nth-child(2) { opacity: 1.0; }
.hc-recent-row:nth-child(3) { opacity: 0.65; }
.hc-recent-row:nth-child(4) { opacity: 0.35; }
.hc-recent-icon { font-size: 12px; width: 16px; flex-shrink: 0; }
