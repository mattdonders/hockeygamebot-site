}
#catchup-pill.show { opacity: 1; }

/* ── DEBUG OVERLAY ── */
.dbg-chip {
  position: absolute; top: 6px; right: 8px; z-index: 50;
  background: rgba(13,13,20,0.08); border: 1px solid rgba(146,64,14,0.4);
