</html>
<script>
// Playoff banner: hydrate the next-game datetime into browser-local time.
// Server-side rendered the ISO string into data-iso on .playoff-strip__time.
(function hydratePlayoffStrip() {
  const el = document.querySelector('.playoff-strip__time');
  if (!el) return;
  const iso = el.getAttribute('data-iso');
  if (!iso) return;
  const dt = new Date(iso);
  const mon = dt.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  const time = dt.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
  const tz = (dt.toLocaleTimeString(undefined, { timeZoneName: 'short' }).split(' ').pop()) || '';
  el.textContent = `${mon} ${time} ${tz}`;
})();

