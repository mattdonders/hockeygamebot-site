---
// HockeyGameBot — /analytics/wowy — With Or Without You (player pairs)
// Client-side interactive leaderboard + PNG export. Data from /v1/stats/wowy.
import Nav from '../../components/Nav.astro';
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>WOWY — With Or Without You · HockeyGameBot</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="description" content="NHL player-pair WOWY stats. Compare how any two teammates perform together at 5v5. xGoals%, xGF/60, xGA/60 filterable by team, season, and TOI." />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
<link rel="apple-touch-icon" href="/favicon-180x180.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style is:global>
:root {
  --bg:      #EFEEE8;
  --bg-2:    #E8E7E0;
  --surface: #FFFFFF;
  --ink:     #0d0d14;
  --ink-86:  rgba(13,13,20,0.86);
  --ink-72:  rgba(13,13,20,0.72);
  --ink-56:  rgba(13,13,20,0.56);
  --ink-48:  rgba(13,13,20,0.48);
  --ink-32:  rgba(13,13,20,0.32);
  --ink-20:  rgba(13,13,20,0.20);
  --ink-14:  rgba(13,13,20,0.14);
  --ink-10:  rgba(13,13,20,0.10);
  --ink-06:  rgba(13,13,20,0.06);
  --ink-04:  rgba(13,13,20,0.04);
  --red:     #E8002D;
  --green:   #4ade80;
  --grid-line: rgba(13,13,20,0.04);
  --display: "Barlow Condensed", sans-serif;
  --body:    "Barlow", sans-serif;
  --mono:    "JetBrains Mono", monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; overflow-x: hidden; min-height: 100vh; }
a { color: inherit; text-decoration: none; }

.mast { position: relative; overflow: hidden; padding: 0; border-bottom: 2px solid var(--ink); background-color: var(--bg); background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px); background-size: 96px 96px; }
.mast-ghost { position: absolute; pointer-events: none; user-select: none; z-index: 0; font-family: var(--display); font-weight: 800; font-size: 260px; line-height: 0.86; text-transform: uppercase; letter-spacing: -0.02em; white-space: nowrap; color: rgba(13,13,20,0.07); top: 50%; left: 50%; transform: translate(-50%, -50%); }
.mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.mast-corners .corner { position: absolute; width: 16px; height: 16px; }
.mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-inner { position: relative; z-index: 2; max-width: 1280px; margin: 0 auto; padding: 48px 32px 40px; }
.mast-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-48); margin-bottom: 16px; }
.mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
.mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
.mast-headline { font-family: var(--display); font-weight: 800; font-size: clamp(36px, 5.5vw, 64px); text-transform: uppercase; line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px; }
.mast-lede { font-size: 14px; line-height: 1.65; color: var(--ink-56); max-width: 640px; }
.mast-lede .mono { font-family: var(--mono); font-size: 12px; color: var(--ink-72); }

.wrap { max-width: 1280px; margin: 0 auto; padding: 0 32px 80px; }

#loading-state { padding: 80px 0; text-align: center; font-family: var(--mono); font-size: 13px; color: var(--ink-48); letter-spacing: 0.06em; }
#loading-state .spinner { width: 20px; height: 20px; border: 2px solid var(--ink-14); border-top-color: var(--red); border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 14px; }
@keyframes spin { to { transform: rotate(360deg); } }
#main-content { display: none; }

.section-block { padding: 40px 0 0; }
.section-head { display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 6px; }
.section-head h2 { font-family: var(--display); font-weight: 800; font-size: clamp(20px, 2.5vw, 28px); text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
.section-meta { font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-32); }
.section-lede { font-size: 13px; color: var(--ink-48); max-width: 780px; line-height: 1.6; margin-bottom: 16px; }

.controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
.btn-group { display: inline-flex; border: 1px solid var(--ink-14); }
.btn-group button { background: var(--surface); border: none; border-right: 1px solid var(--ink-14); padding: 6px 14px; cursor: pointer; font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-48); transition: background 0.1s, color 0.1s; }
.btn-group button:last-child { border-right: none; }
.btn-group button.active { background: var(--ink); color: var(--bg); }
.btn-group button:hover:not(.active) { background: var(--ink-06); color: var(--ink); }

select { background: var(--surface); border: 1px solid var(--ink-14); padding: 6px 10px; font-family: var(--body); font-weight: 600; font-size: 11.5px; letter-spacing: 0.04em; color: var(--ink); cursor: pointer; outline: none; }

.search-wrap { display: inline-flex; align-items: center; border: 1px solid var(--ink-14); background: var(--surface); padding: 0 10px; gap: 6px; min-width: 200px; }
.search-wrap svg { flex-shrink: 0; color: var(--ink-32); }
#search-input { border: none; background: transparent; outline: none; font-family: var(--body); font-size: 13px; color: var(--ink); width: 100%; padding: 6px 0; }
#search-input::placeholder { color: var(--ink-32); }

.slider-wrap { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; color: var(--ink-48); }
.slider-wrap input[type=range] { width: 120px; accent-color: var(--red); }

.export-btn { background: var(--ink); color: var(--bg); border: none; padding: 6px 16px; cursor: pointer; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; transition: opacity 0.15s; }
.export-btn:hover { opacity: 0.8; }

.tbl-wrap { background: var(--surface); border: 1px solid var(--ink-14); overflow-x: auto; overflow-y: auto; max-height: 700px; }
table { width: 100%; border-collapse: collapse; font-family: var(--body); font-size: 13px; }
thead { position: sticky; top: 0; z-index: 20; background: var(--surface); box-shadow: 0 2px 0 var(--ink); }
thead tr { border-bottom: 2px solid var(--ink); }
th { padding: 9px 12px; text-align: right; font-family: var(--display); font-weight: 700; font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-48); white-space: nowrap; cursor: pointer; user-select: none; transition: color 0.1s; }
th:first-child, th:nth-child(2), th:nth-child(3), th:nth-child(4) { text-align: left; }
th:hover { color: var(--ink); }
th.sorted { color: var(--ink); }
th .sort-arrow { display: inline-block; margin-left: 4px; opacity: 0.4; font-size: 9px; }
th.sorted .sort-arrow { opacity: 1; color: var(--red); }
tbody tr { border-bottom: 1px solid var(--ink-06); transition: background 0.1s; }
tbody tr:last-child { border-bottom: none; }
tbody tr:hover { background: var(--ink-04); }
td { padding: 8px 12px; text-align: right; font-family: var(--mono); font-size: 12px; color: var(--ink); white-space: nowrap; }
td:first-child { text-align: center; font-family: var(--mono); font-size: 11px; color: var(--ink-48); width: 40px; }
td:nth-child(2), td:nth-child(3) { text-align: left; font-family: var(--body); font-weight: 600; font-size: 13px; }
td:nth-child(4) { text-align: left; }

.xgf-hi  { color: #166534; font-weight: 700; }
.xgf-mid { color: var(--ink); }
.xgf-lo  { color: #991b1b; font-weight: 700; }

.tbl-more { border-top: 1px solid var(--ink-14); padding: 12px; text-align: center; }
.tbl-more button { background: none; border: 1px solid var(--ink-20); padding: 6px 20px; cursor: pointer; font-family: var(--body); font-weight: 600; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-48); transition: all 0.15s; }
.tbl-more button:hover { border-color: var(--ink); color: var(--ink); }
.tbl-count { font-family: var(--mono); font-size: 10.5px; color: var(--ink-32); letter-spacing: 0.06em; margin-top: 8px; }

.foot { border-top: 1px solid var(--ink-14); padding: 32px 0; font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; }
.foot-inner { max-width: 1280px; margin: 0 auto; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
.foot-wordmark { font-family: var(--display); font-weight: 800; font-size: 18px; letter-spacing: 0.04em; text-transform: uppercase; display: inline-flex; align-items: center; }
.foot-wordmark .dot { width: 5px; height: 5px; background: var(--red); border-radius: 50%; margin: 0 6px; display: inline-block; }

@media (max-width: 680px) {
  .mast-inner { padding: 32px 20px 28px; }
  .wrap { padding: 0 20px 60px; }
  .mast-ghost { font-size: 120px; }
  th, td { padding: 7px 8px; }
}
</style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<section class="mast">
  <div class="mast-ghost">WOWY</div>
  <div class="mast-corners">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>
  </div>
  <div class="mast-inner">
    <div class="mast-eyebrow"><span class="pip"></span>HockeyGameBot Analytics</div>
    <div class="mast-card">
      <h1 class="mast-headline">With Or Without You</h1>
      <p class="mast-lede">
        Every teammate pair with qualifying 5v5 ice time together · 2022–23 through 2025–26 regular season ·
        Ranked by <span class="mono">xGoals%</span>. Search by player name to find a specific pair.
      </p>
    </div>
  </div>
</section>

<div class="wrap">
  <div id="loading-state">
    <div class="spinner"></div>
    Loading WOWY data...
  </div>

  <div id="main-content">
    <div class="section-block">
      <div class="section-head">
        <h2>Player Pairs</h2>
        <span class="section-meta" id="tbl-meta"></span>
      </div>
      <p class="section-lede">
        Pairs ranked by xGoals% together at 5v5. Search by player name. xGF% &gt;55% green, &lt;45% red.
        Export button saves the current filtered view as PNG.
      </p>

      <div class="controls">
        <select id="season-filter">
          <option value="all">All Seasons</option>
          <option value="20252026">2025–26</option>
          <option value="20242025">2024–25</option>
          <option value="20232024">2023–24</option>
          <option value="20222023">2022–23</option>
        </select>
        <select id="team-filter">
          <option value="all">All Teams</option>
        </select>
        <div class="search-wrap">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" id="search-input" placeholder="Search player..." autocomplete="off" />
        </div>
        <div class="slider-wrap">
          Min TOI: <span id="toi-label">50</span>m
          <input type="range" id="toi-slider" min="10" max="400" value="50" step="10" />
        </div>
        <button class="export-btn" id="export-btn">Export PNG</button>
      </div>

      <div class="tbl-wrap" id="export-target">
        <table id="wowy-table">
          <thead>
            <tr>
              <th data-col="rank"># <span class="sort-arrow"></span></th>
              <th data-col="player1">Player 1 <span class="sort-arrow"></span></th>
              <th data-col="player2">Player 2 <span class="sort-arrow"></span></th>
              <th data-col="team">Team <span class="sort-arrow"></span></th>
              <th data-col="toi_min">Minutes <span class="sort-arrow"></span></th>
              <th data-col="games">Games <span class="sort-arrow"></span></th>
              <th data-col="xgf_pct">xGoals% <span class="sort-arrow"></span></th>
              <th data-col="xgf">xGF <span class="sort-arrow"></span></th>
              <th data-col="xga">xGA <span class="sort-arrow"></span></th>
              <th data-col="xgf_60">xGF/60 <span class="sort-arrow"></span></th>
              <th data-col="xga_60">xGA/60 <span class="sort-arrow"></span></th>
              <th data-col="gf_pct">GF% <span class="sort-arrow"></span></th>
            </tr>
          </thead>
          <tbody id="wowy-tbody"></tbody>
        </table>
        <div class="tbl-more" id="tbl-more-row" style="display:none">
          <button id="tbl-show-all-btn">Show All</button>
          <div class="tbl-count" id="tbl-count-label"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<footer class="foot">
  <div class="foot-inner">
    <span class="foot-wordmark">Hockey<span class="dot"></span>Gamebot</span>
    <span>5v5 · Regular Season · 2022–26 · Data via HGB Analytics</span>
  </div>
</footer>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<script is:inline>
(function () {
  'use strict';

  let allPairs = [];
  let seasonFilter = 'all';
  let teamFilter   = 'all';
  let searchQuery  = '';
  let minToi       = 50;
  let sortCol      = 'xgf_pct';
  let sortAsc      = false;
  let showAll      = false;
  const TOP_N      = 100;

  function applyFilters() {
    const q = searchQuery.toLowerCase();
    return allPairs.filter(r =>
      (seasonFilter === 'all' || r.season === seasonFilter) &&
      (teamFilter === 'all' || r.team === teamFilter) &&
      (r.toi_min >= minToi) &&
      (!q || (r.player1 || '').toLowerCase().includes(q) || (r.player2 || '').toLowerCase().includes(q))
    );
  }

  function sortRows(rows) {
    return [...rows].sort((a, b) => {
      const av = a[sortCol] ?? (sortAsc ? Infinity : -Infinity);
      const bv = b[sortCol] ?? (sortAsc ? Infinity : -Infinity);
      if (typeof av === 'string') return sortAsc ? av.localeCompare(bv) : bv.localeCompare(av);
      return sortAsc ? av - bv : bv - av;
    });
  }

  function xgfClass(v) {
    if (v == null) return '';
    if (v >= 55) return 'xgf-hi';
    if (v <= 45) return 'xgf-lo';
    return 'xgf-mid';
  }

  function fmt(v, d = 1) { return v != null ? v.toFixed(d) : '—'; }
  function esc(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function renderTable() {
    const filtered = applyFilters();
    const sorted   = sortRows(filtered);
    const shown    = showAll ? sorted : sorted.slice(0, TOP_N);

    const tbody = document.getElementById('wowy-tbody');
    const frag  = document.createDocumentFragment();

    shown.forEach((r, i) => {
      const tr = document.createElement('tr');
      const rank = i + 1;
      const pc = xgfClass(r.xgf_pct);
      tr.innerHTML = `
        <td>${rank}</td>
        <td>${esc(r.player1)}</td>
        <td>${esc(r.player2)}</td>
        <td>${esc(r.team)}</td>
        <td>${fmt(r.toi_min)}</td>
        <td>${r.games ?? '—'}</td>
        <td class="${pc}">${r.xgf_pct != null ? r.xgf_pct.toFixed(1) + '%' : '—'}</td>
        <td>${fmt(r.xgf, 2)}</td>
        <td>${fmt(r.xga, 2)}</td>
        <td>${fmt(r.xgf_60, 2)}</td>
        <td>${fmt(r.xga_60, 2)}</td>
        <td>${r.gf_pct != null ? r.gf_pct.toFixed(1) + '%' : '—'}</td>
      `;
      frag.appendChild(tr);
    });

    tbody.innerHTML = '';
    tbody.appendChild(frag);

    document.getElementById('tbl-meta').textContent =
      `${shown.length} of ${filtered.length} pairs`;

    const moreRow = document.getElementById('tbl-more-row');
    if (!showAll && filtered.length > TOP_N) {
      moreRow.style.display = '';
      document.getElementById('tbl-count-label').textContent =
        `Showing top ${TOP_N} — ${filtered.length - TOP_N} more`;
    } else {
      moreRow.style.display = 'none';
    }

    document.querySelectorAll('#wowy-table th').forEach(th => {
      const col = th.dataset.col;
      const arrow = th.querySelector('.sort-arrow');
      if (col === sortCol) {
        th.classList.add('sorted');
        if (arrow) arrow.textContent = sortAsc ? ' ↑' : ' ↓';
      } else {
        th.classList.remove('sorted');
        if (arrow) arrow.textContent = '';
      }
    });
  }

  function populateTeams() {
    const teams = [...new Set(allPairs.map(r => r.team))].sort();
    const sel = document.getElementById('team-filter');
    teams.forEach(t => {
      const opt = document.createElement('option');
      opt.value = t; opt.textContent = t;
      sel.appendChild(opt);
    });
  }

  function wireEvents() {
    document.getElementById('season-filter').addEventListener('change', e => {
      seasonFilter = e.target.value; showAll = false; renderTable();
    });
    document.getElementById('team-filter').addEventListener('change', e => {
      teamFilter = e.target.value; showAll = false; renderTable();
    });
    document.getElementById('search-input').addEventListener('input', e => {
      searchQuery = e.target.value.trim(); showAll = false; renderTable();
    });

    const slider = document.getElementById('toi-slider');
    slider.addEventListener('input', e => {
      minToi = parseInt(e.target.value, 10);
      document.getElementById('toi-label').textContent = minToi;
      showAll = false; renderTable();
    });

    document.querySelectorAll('#wowy-table th[data-col]').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.col;
        if (sortCol === col) { sortAsc = !sortAsc; }
        else { sortCol = col; sortAsc = col === 'player1' || col === 'player2' || col === 'team'; }
        showAll = false; renderTable();
      });
    });

    document.getElementById('tbl-show-all-btn').addEventListener('click', () => {
      showAll = true;
      document.getElementById('tbl-more-row').style.display = 'none';
      renderTable();
    });

    document.getElementById('export-btn').addEventListener('click', async () => {
      const btn = document.getElementById('export-btn');
      btn.textContent = 'Exporting…';
      btn.disabled = true;
      try {
        const target = document.getElementById('export-target');
        const canvas = await html2canvas(target, {
          backgroundColor: '#FFFFFF',
          scale: 2,
          useCORS: true,
          logging: false,
        });
        const link = document.createElement('a');
        link.download = `hgb-wowy-${seasonFilter}-${teamFilter}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      } catch (err) {
        alert('Export failed: ' + err.message);
      } finally {
        btn.textContent = 'Export PNG';
        btn.disabled = false;
      }
    });
  }

  async function init() {
    try {
      const res = await fetch('https://api.hockeygamebot.com/v1/stats/wowy');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      allPairs = await res.json();
    } catch (err) {
      document.getElementById('loading-state').innerHTML =
        `<p style="font-family:var(--mono);font-size:13px;color:var(--red)">Failed to load: ${err.message}</p>`;
      return;
    }

    document.getElementById('loading-state').style.display = 'none';
    document.getElementById('main-content').style.display = 'block';

    populateTeams();
    wireEvents();
    renderTable();
  }

  init();
})();
</script>
</body>
</html>
