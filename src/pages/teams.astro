---
// HockeyGameBot — /teams page — static bot directory

// Fetch standings from NHL API at build time.
// clinchIndicator: "x" = clinched spot, "y" = clinched division,
//                  "z" = Presidents' Trophy, "e" = ELIMINATED, "p" = possible (not yet).
// playoffMode = true when at least one team has clinched → show status badges.
// Otherwise show W-L-OT record for all teams.
interface TeamStats { clinch: string | null; record: string; }
const teamStats = new Map<string, TeamStats>();
let playoffMode = false;

try {
  const res = await fetch('https://api-web.nhle.com/v1/standings/now');
  if (res.ok) {
    const data = await res.json();
    for (const t of data.standings ?? []) {
      const abbr: string = t.teamAbbrev?.default ?? '';
      const clinch: string | null = t.clinchIndicator ?? null;
      const record = `${t.wins ?? 0}-${t.losses ?? 0}-${t.otLosses ?? 0}`;
      teamStats.set(abbr, { clinch, record });
      if (clinch === 'x' || clinch === 'y' || clinch === 'z') playoffMode = true;
    }
  }
} catch (e) {
  // Build-time fetch failed — status row will be omitted rather than wrong.
  console.warn('[teams] Failed to fetch NHL standings:', e);
}

const teams = [
  { abbr: 'ANA', name: 'Anaheim Ducks' },
  { abbr: 'BOS', name: 'Boston Bruins' },
  { abbr: 'BUF', name: 'Buffalo Sabres' },
  { abbr: 'CGY', name: 'Calgary Flames' },
  { abbr: 'CAR', name: 'Carolina Hurricanes' },
  { abbr: 'CHI', name: 'Chicago Blackhawks' },
  { abbr: 'COL', name: 'Colorado Avalanche' },
  { abbr: 'CBJ', name: 'Columbus Blue Jackets' },
  { abbr: 'DAL', name: 'Dallas Stars' },
  { abbr: 'DET', name: 'Detroit Red Wings' },
  { abbr: 'EDM', name: 'Edmonton Oilers' },
  { abbr: 'FLA', name: 'Florida Panthers' },
  { abbr: 'LAK', name: 'Los Angeles Kings' },
  { abbr: 'MIN', name: 'Minnesota Wild' },
  { abbr: 'MTL', name: 'Montreal Canadiens' },
  { abbr: 'NSH', name: 'Nashville Predators' },
  { abbr: 'NJD', name: 'New Jersey Devils' },
  { abbr: 'NYI', name: 'New York Islanders' },
  { abbr: 'NYR', name: 'New York Rangers' },
  { abbr: 'OTT', name: 'Ottawa Senators' },
  { abbr: 'PHI', name: 'Philadelphia Flyers' },
  { abbr: 'PIT', name: 'Pittsburgh Penguins' },
  { abbr: 'SJS', name: 'San Jose Sharks' },
  { abbr: 'SEA', name: 'Seattle Kraken' },
  { abbr: 'STL', name: 'St. Louis Blues' },
  { abbr: 'TBL', name: 'Tampa Bay Lightning' },
  { abbr: 'TOR', name: 'Toronto Maple Leafs' },
  { abbr: 'UTA', name: 'Utah Hockey Club' },
  { abbr: 'VAN', name: 'Vancouver Canucks' },
  { abbr: 'VGK', name: 'Vegas Golden Knights', xHandle: 'VGKGameBot_' },
  { abbr: 'WSH', name: 'Washington Capitals' },
  { abbr: 'WPG', name: 'Winnipeg Jets' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Team Bots · HockeyGameBot</title>
  <meta name="description" content="32 team-specific bots posting live game updates to Twitter / X and Bluesky. Find your team bot below.">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="HockeyGameBot">
  <meta property="og:title" content="Team Bots · HockeyGameBot">
  <meta property="og:description" content="32 team-specific bots posting live game updates to Twitter / X and Bluesky. Find your team bot below.">
  <meta property="og:url" content="https://hockeygamebot.com/teams">
  <meta property="og:image" content="https://s3.us-west-000.backblazeb2.com/hockeygamebot-media/hockeygamebot/static/og_image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@hockeygamebot">
  <meta name="twitter:title" content="Team Bots · HockeyGameBot">
  <meta name="twitter:description" content="32 team-specific bots posting live game updates to Twitter / X and Bluesky.">
  <meta name="twitter:image" content="https://s3.us-west-000.backblazeb2.com/hockeygamebot-media/hockeygamebot/static/og_image.png">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <a href="/" class="brand">HGB</a>
  <div class="brand-sub">HockeyGameBot</div>
  <div class="topbar-right">
    <nav class="topbar-nav">
      <a href="/" class="topbar-link">SCORES</a>
      <a href="/teams" class="topbar-link topbar-link--active" aria-current="page">TEAMS</a>
      <a href="/support" class="topbar-link topbar-link--support">
        <svg class="support-heart" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        <span class="support-label">SUPPORT</span>
      </a>
    </nav>
  </div>
</div>

<main>

  <!-- ── HERO ──────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-wordmark">HGB</div>
      <h1 class="hero-headline">Find Your Team Bot</h1>
      <p class="hero-sub">32 team-specific bots posting live game updates to Twitter&nbsp;/&nbsp;X and Bluesky. Find yours below.</p>
    </div>
  </section>

  <!-- ── MAIN ACCOUNT CARD ─────────────────────────────────────────── -->
  <section class="teams-section">
    <div class="teams-inner">

      <div class="main-card">
        <div class="main-card-brand">
          <span class="main-card-wordmark">HGB</span>
          <div>
            <div class="main-card-name">HockeyGameBot</div>
            <div class="main-card-desc">The main account — news, updates, and announcements</div>
          </div>
        </div>
        <div class="main-card-links">
          <a href="https://x.com/hockey_gamebot" class="team-link team-link--x" target="_blank" rel="noopener">
            <svg class="link-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <span class="link-label">@hockey_gamebot</span>
          </a>
          <a href="https://bsky.app/profile/hockeygamebot.com" class="team-link team-link--bsky" target="_blank" rel="noopener">
            <svg class="link-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/>
            </svg>
            <span class="link-label">@hockeygamebot.com</span>
          </a>
        </div>
      </div>

      <!-- ── TEAM GRID ──────────────────────────────────────────────── -->
      <div class="teams-grid">
        {teams.map((team) => {
          const xHandle = team.xHandle ?? `${team.abbr}GameBot`;
          const xUrl = `https://x.com/${xHandle}`;
          const bskyHandle = `${team.abbr.toLowerCase()}.hockeygamebot.com`;
          const bskyUrl = `https://bsky.app/profile/${bskyHandle}`;
          const logoUrl = `https://assets.nhle.com/logos/nhl/svg/${team.abbr}_light.svg`;
          const stats = teamStats.get(team.abbr);
          const clinch = stats?.clinch ?? null;
          const isPlayoff = clinch === 'x' || clinch === 'y' || clinch === 'z';
          const isEliminated = clinch === 'e';
          return (
            <div class="team-card">
              <div class="team-card-top">
                <img
                  src={logoUrl}
                  alt={`${team.name} logo`}
                  class="team-logo"
                  width="48"
                  height="48"
                  loading="lazy"
                />
                <span class="team-name">{team.name}</span>
              </div>
              <div class="team-links">
                <a href={xUrl} class="team-link team-link--x" target="_blank" rel="noopener" aria-label={`${team.name} on X`}>
                  <svg class="link-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                  <span class="link-label">@{xHandle}</span>
                </a>
                <a href={bskyUrl} class="team-link team-link--bsky" target="_blank" rel="noopener" aria-label={`${team.name} on Bluesky`}>
                  <svg class="link-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/>
                  </svg>
                  <span class="link-label">@{bskyHandle}</span>
                </a>
              </div>
              {stats && (
                <div class={`team-status ${isPlayoff ? 'team-status--playoffs' : isEliminated ? 'team-status--eliminated' : 'team-status--record'}`}>
                  {playoffMode
                    ? (isPlayoff ? '★ PLAYOFFS' : isEliminated ? 'ELIMINATED' : stats.record)
                    : stats.record}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>

</main>

<footer class="site-footer">
  <div class="footer-inner">
    <span class="footer-brand">HGB</span>
    <span class="footer-sep">·</span>
    <a href="/" class="footer-link">Scores</a>
    <a href="/teams" class="footer-link">Teams</a>
    <a href="https://ko-fi.com/hockeygamebot" class="footer-link" target="_blank" rel="noopener">Ko-fi</a>
    <span class="footer-copy">Built with 🏒 by <a href="https://twitter.com/mattdonders" class="footer-link" target="_blank" rel="noopener">@mattdonders</a></span>
  </div>
</footer>

</body>
</html>

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #090909;
  --card: #111;
  --border: #1c1c1c;
  --border2: #252525;
  --muted: #555;
  --text: #999;
  --text-secondary: #777;
  --white: #f5f5f5;
  --red: #ff3d3d;
  --red-dim: rgba(255, 61, 61, 0.12);
  --red-border: rgba(255, 61, 61, 0.3);
}

html, body {
  background: var(--bg);
  font-family: 'Space Grotesk', sans-serif;
  color: var(--text);
  line-height: 1.65;
  min-height: 100vh;
}

/* ── TOP BAR ────────────────────────────────────────────────────── */
.topbar {
  height: 44px;
  background: var(--red);
  display: flex;
  align-items: center;
  padding: 0 24px;
  gap: 16px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.brand {
  font-family: 'Oswald', sans-serif;
  font-size: 22px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.1em;
  text-decoration: none;
}
.brand-sub {
  font-size: 11px;
  color: rgba(255,255,255,0.65);
  letter-spacing: 0.14em;
}
.topbar-right {
  margin-left: auto;
  display: flex;
  align-items: center;
}
.topbar-nav {
  display: flex;
  gap: 6px;
}
.topbar-link {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.7);
  text-decoration: none;
  padding: 4px 10px;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 3px;
  transition: color 0.15s, border-color 0.15s;
}
.topbar-link:hover { color: #fff; border-color: rgba(255,255,255,0.5); }
.topbar-link--active { color: #fff; border-color: rgba(255,255,255,0.5); }
.topbar-link--support {
  display: flex;
  align-items: center;
  gap: 5px;
}
.support-heart { flex-shrink: 0; opacity: 0.9; }
.support-label { display: inline; }

@media (max-width: 640px) {
  .topbar { height: 48px; padding: 0 16px; gap: 10px; }
  .brand-sub { display: none; }
  .support-label { display: none; }
}

/* ── HERO ───────────────────────────────────────────────────────── */
.hero {
  padding: 72px 24px 64px;
  text-align: center;
  border-bottom: 1px solid var(--border);
}
.hero-inner {
  max-width: 640px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}
.hero-wordmark {
  font-family: 'Oswald', sans-serif;
  font-size: 48px;
  font-weight: 700;
  color: var(--red);
  letter-spacing: 0.08em;
  line-height: 1;
}
.hero-headline {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(26px, 5vw, 40px);
  font-weight: 700;
  color: var(--white);
  letter-spacing: 0.02em;
  line-height: 1.15;
  text-wrap: balance;
}
.hero-sub {
  font-size: clamp(14px, 2vw, 16px);
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 480px;
}

/* ── TEAMS SECTION ──────────────────────────────────────────────── */
.teams-section {
  padding: 48px 24px 80px;
}
.teams-inner {
  max-width: 1100px;
  margin: 0 auto;
}

/* ── TEAM GRID ──────────────────────────────────────────────────── */
.teams-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}

/* ── TEAM CARD ──────────────────────────────────────────────────── */
.team-card {
  background: var(--card);
  border: 1px solid var(--border2);
  border-radius: 8px;
  padding: 18px 16px 14px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  transition: border-color 0.15s;
}
.team-card:hover {
  border-color: #333;
}

/* ── MAIN ACCOUNT CARD ──────────────────────────────────────────── */
.main-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  background: var(--card);
  border: 1px solid #2a2a2a;
  border-left: 3px solid var(--red);
  border-radius: 8px;
  padding: 20px 24px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}
.main-card-brand {
  display: flex;
  align-items: center;
  gap: 16px;
}
.main-card-wordmark {
  font-family: 'Oswald', sans-serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--red);
  letter-spacing: 0.08em;
  line-height: 1;
  flex-shrink: 0;
}
.main-card-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--white);
  line-height: 1.3;
}
.main-card-desc {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 2px;
}
.main-card-links {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

/* ── TEAM STATUS ROW ────────────────────────────────────────────── */
.team-status {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  padding: 4px 8px;
  border-radius: 4px;
  text-align: center;
  border-top: 1px solid var(--border);
  padding-top: 10px;
  margin-top: 2px;
}
.team-status--playoffs {
  color: #4ade80;
}
.team-status--eliminated {
  color: #ff6b6b;
}
.team-status--record {
  color: var(--muted);
  letter-spacing: 0.06em;
  font-weight: 500;
}

@media (max-width: 640px) {
  .main-card { padding: 16px; gap: 14px; }
  .main-card-wordmark { font-size: 22px; }
  .main-card-name { font-size: 14px; }
  .main-card-links { gap: 6px; }
}

.team-card-top {
  display: flex;
  align-items: center;
  gap: 12px;
}
.team-logo {
  width: 44px;
  height: 44px;
  object-fit: contain;
  flex-shrink: 0;
}
.team-name {
  font-size: 13px;
  font-weight: 600;
  color: var(--white);
  line-height: 1.3;
}

/* ── SOCIAL LINKS ───────────────────────────────────────────────── */
.team-links {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.team-link {
  display: flex;
  align-items: center;
  gap: 7px;
  text-decoration: none;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.02em;
  padding: 5px 8px;
  border-radius: 4px;
  border: 1px solid transparent;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}
.link-icon {
  width: 13px;
  height: 13px;
  flex-shrink: 0;
}
.link-label {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-link--x {
  color: #aaa;
  border-color: var(--border2);
}
.team-link--x:hover {
  color: var(--white);
  background: rgba(255,255,255,0.05);
  border-color: #333;
}

.team-link--bsky {
  color: #aaa;
  border-color: var(--border2);
}
.team-link--bsky:hover {
  color: #5bb8ff;
  background: rgba(91,184,255,0.07);
  border-color: rgba(91,184,255,0.25);
}

/* ── FOOTER ─────────────────────────────────────────────────────── */
.site-footer {
  background: #050505;
  border-top: 1px solid var(--border);
  padding: 28px 24px;
}
.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.footer-brand {
  font-family: 'Oswald', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--red);
  letter-spacing: 0.1em;
}
.footer-sep { color: var(--border2); }
.footer-link {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.15s;
}
.footer-link:hover { color: var(--white); }
.footer-copy {
  margin-left: auto;
  font-size: 12px;
  color: var(--muted);
}

/* ── RESPONSIVE ─────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .teams-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 640px) {
  .hero { padding: 52px 20px 44px; }
  .hero-wordmark { font-size: 38px; }
  .teams-section { padding: 32px 16px 60px; }
  .teams-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .team-card { padding: 14px 12px 12px; gap: 10px; }
  .team-logo { width: 36px; height: 36px; }
  .team-name { font-size: 12px; }
  .team-link { font-size: 10px; padding: 4px 7px; }
  .link-icon { width: 12px; height: 12px; }
  .footer-copy { margin-left: 0; width: 100%; }
}
</style>
