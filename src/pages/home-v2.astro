---
import '../styles/site-tokens.css';
import Topbar from '../components/home/Topbar.astro';
import PlayoffStrip from '../components/home/PlayoffStrip.astro';
import PageHero from '../components/home/PageHero.astro';
import ModeBar from '../components/home/ModeBar.astro';
import LiveHero from '../components/home/LiveHero.astro';
import LiveMomentStrip from '../components/home/LiveMomentStrip.astro';
import GameTile from '../components/home/GameTile.astro';

import RecapHero from '../components/home/RecapHero.astro';
import RecapScoreStrip from '../components/home/RecapScoreStrip.astro';
import RecapFilterBar from '../components/home/RecapFilterBar.astro';
import RecapWall from '../components/home/RecapWall.astro';
import TweetEcho from '../components/home/TweetEcho.astro';
import ModelRetrospective from '../components/home/ModelRetrospective.astro';

// Layer 5 additions — tomorrow + offseason chrome.
import TomorrowHero from '../components/home/TomorrowHero.astro';
import TomorrowSlateStrip from '../components/home/TomorrowSlateStrip.astro';
import PredictionsGrid from '../components/home/PredictionsGrid.astro';
import ArtifactMatchup from '../components/home/artifacts/ArtifactMatchup.astro';
import ArtifactHot from '../components/home/artifacts/ArtifactHot.astro';
import ArtifactCold from '../components/home/artifacts/ArtifactCold.astro';
import ArtifactMilestone from '../components/home/artifacts/ArtifactMilestone.astro';
import OffseasonHero from '../components/home/OffseasonHero.astro';
import LastPlayedCard from '../components/home/LastPlayedCard.astro';
import SummerStorylines from '../components/home/SummerStorylines.astro';

import liveMockRaw from '../data/home-mock/live.json';
import liveShootoutMockRaw from '../data/home-mock/live.shootout.json';
import liveShootoutLongMockRaw from '../data/home-mock/live.shootout-long.json';
import recapMockRaw from '../data/home-mock/recap.json';
import tomorrowMockRaw from '../data/home-mock/tomorrow.json';
import offseasonMockRaw from '../data/home-mock/offseason.json';
import scheduleVariantsRaw from '../data/home-mock/schedule.json';

import { parseLiveMockOrThrow } from '../lib/live-mock-schemas';
import { parseRecapMockOrThrow } from '../lib/recap-mock-schemas';
import {
  parseTomorrowMockOrThrow,
  parseOffseasonMockOrThrow,
  parseScheduleVariantsOrThrow,
} from '../lib/auto-mode-schemas';
import { pickHero } from '../lib/excitement';
import { HOME_MODES } from '../lib/auto-mode';

// Validate all live fixtures at build time.
const liveMock = parseLiveMockOrThrow(liveMockRaw, 'home-mock/live.json');
const liveShootoutMock = parseLiveMockOrThrow(
  liveShootoutMockRaw,
  'home-mock/live.shootout.json',
);
const liveShootoutLongMock = parseLiveMockOrThrow(
  liveShootoutLongMockRaw,
  'home-mock/live.shootout-long.json',
);

// Layer 5 mocks.
const tomorrowMock = parseTomorrowMockOrThrow(
  tomorrowMockRaw,
  'home-mock/tomorrow.json',
);
const offseasonMock = parseOffseasonMockOrThrow(
  offseasonMockRaw,
  'home-mock/offseason.json',
);
const scheduleVariants = parseScheduleVariantsOrThrow(
  scheduleVariantsRaw,
  'home-mock/schedule.json',
);

// ── Hero selection (existing live-mode logic — unchanged) ──────────────────
const PRIOR_HERO_ID = '2026030124'; // BOS @ BUF
type GridGame = (typeof liveMock.games extends infer T
  ? T extends Array<infer U>
    ? U
    : never
  : never);
function gridToExcitement(g: GridGame) {
  const status =
    g.state === 'live' || g.state === 'intermission'
      ? 'live'
      : g.state === 'final' || g.state === 'ot'
      ? 'final'
      : 'scheduled';
  return {
    id: g.id,
    status,
    period: g.period,
    time_remaining: g.clock,
    home_team: { score: g.home.score ?? 0 },
    away_team: { score: g.away.score ?? 0 },
  };
}
const heroPick = liveMock.games
  ? pickHero(liveMock.games.map(gridToExcitement), { currentHeroId: PRIOR_HERO_ID })
  : null;
const featured = liveMock.featured_game;
const heroPickedId = heroPick?.id ?? null;
const heroIsStickyChosen = heroPickedId === featured.id;

const heroIdToExclude = heroPickedId ?? featured.id;
const subgridGames = (liveMock.games ?? []).filter(g => g.id !== heroIdToExclude);

const featuredSO = liveShootoutMock.featured_game;
const subgridSO = (liveShootoutMock.games ?? []).filter(
  g => g.id !== featuredSO.id,
);
const featuredSOLong = liveShootoutLongMock.featured_game;
const subgridSOLong = (liveShootoutLongMock.games ?? []).filter(
  g => g.id !== featuredSOLong.id,
);

const playoffStrip = liveMock.playoff_strip;
const playoffStripSO = liveShootoutMock.playoff_strip;
const playoffStripSOLong = liveShootoutLongMock.playoff_strip;
const recapMock = parseRecapMockOrThrow(recapMockRaw, 'home-mock/recap.json');
const recapPlayoffStrip = recapMock.playoff_strip;
const tomorrowPlayoffStrip = tomorrowMock.playoff_strip;
const liveEyebrow = liveMock.hero_eyebrow;
const liveEyebrowSO = liveShootoutMock.hero_eyebrow;
const liveEyebrowSOLong = liveShootoutLongMock.hero_eyebrow;
const recapEyebrow = recapMock.hero_eyebrow;
const tomorrowEyebrow = tomorrowMock.hero_eyebrow;
const offseasonEyebrow = offseasonMock.hero_eyebrow;
const liveDate = liveMock.date_label;
const recapDate = recapMock.date_label;
const tomorrowDate = tomorrowMock.date_label;
const offseasonDate = offseasonMock.date_label;

// ── Recap-mode body data (existing logic — unchanged) ───────────────────
const recapWall = recapMock.wall;
const recapCounts = {
  all: recapWall.length,
  games: recapWall.filter(c => c.slug === 'game').length,
  hot: recapWall.filter(c => c.slug === 'hot').length,
  cold: recapWall.filter(c => c.slug === 'cold').length,
  milestones:
    recapWall.filter(c => c.slug === 'milestone').length +
    recapWall.filter(c => c.slug === 'hattrick').length,
  lines: recapWall.filter(c => c.slug === 'line').length,
  clinches: recapWall.filter(c => c.slug === 'clinch').length,
  stars:
    recapWall.filter(c => c.slug === 'stars').length +
    recapWall.filter(c => c.slug === 'goalie').length,
};

function countByState(games: typeof liveMock.games | undefined): {
  total: number;
  live: number;
  final: number;
  pre: number;
} {
  const list = games ?? [];
  return {
    total: list.length,
    live: list.filter(g => g.state === 'live' || g.state === 'intermission').length,
    final: list.filter(g => g.state === 'final' || g.state === 'ot').length,
    pre: list.filter(g => g.state === 'pre').length,
  };
}
const grid = countByState(liveMock.games);
const gridSO = countByState(liveShootoutMock.games);
const gridSOLong = countByState(liveShootoutLongMock.games);

const artifactsCount = (liveMock.live_moments ?? []).length;

// Hero copy variants — eyebrow + h1 + sub vary by mode. All other modes
// fall through to the existing default in PageHero.
const offseasonHeroCopy = {
  eyebrow: offseasonMock.hero_eyebrow,
  title: 'Hockey returns Oct 8.',
  sub: "Until then — countdown, last season's wrap, and the moves shaping next year.",
};
const tomorrowHeroCopy = {
  eyebrow: tomorrowMock.hero_eyebrow,
  title: 'Tomorrow night, picked apart.',
  sub: "Predictions, key matchups, milestone watches and the storylines we're tracking — refreshed at 4 AM ET.",
};

// Inline data the head + body scripts need. Serialised as JSON-strings
// inside the <html> so the auto-mode resolver can run before first paint
// without an extra fetch.
const scheduleVariantsJson = JSON.stringify(scheduleVariants);
const homeModesJson = JSON.stringify(HOME_MODES);
---
<!DOCTYPE html>
<html lang="en" data-home-mode="live" data-fixture="default">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="dark">
  <meta name="robots" content="noindex,nofollow">
  <title>HockeyGameBot — Home (v2 preview)</title>
  <meta name="description" content="Rebuild preview of the HockeyGameBot home page. Not linked from the production scoreboard.">

  <!--
    Mode swap (Layer 5 rewrite of the Layer 1 head script):

    Resolution order (matches src/lib/auto-mode.ts/resolveMode):
      1. sessionStorage[hgb-mode-override] — sticky in-tab manual choice
      2. ?mode=<mode>                      — direct-link / share URL
      3. detectMode(schedule, now)         — auto fallback (live | recap)

    The schedule snapshot the resolver uses can be swapped via
    `?schedule=morning|afternoon|evening|night|offseason` — falls back
    to `default` when absent or unknown.

    All four mode body sections render at build time; CSS rules below
    show the active one only.
  -->
  <script is:inline define:vars={{ scheduleVariantsJson, homeModesJson }}>
    (function () {
      try {
        var modes = JSON.parse(homeModesJson);
        var variants = JSON.parse(scheduleVariantsJson);

        var params = new URLSearchParams(window.location.search);
        var schedKey = params.get('schedule') || 'default';
        var schedule = variants[schedKey] || variants.default;

        // Inline detectMode — keep this in sync with src/lib/auto-mode.ts.
        // Pure JS so it can run before module hydration.
        function detectMode(sched, now) {
          var liveLike = ['live', 'intermission', 'shootout'];
          var states = (sched && sched.today && sched.today.games_states) || [];
          for (var i = 0; i < states.length; i++) {
            if (liveLike.indexOf(states[i]) !== -1) return 'live';
          }
          if (
            sched && sched.today &&
            sched.today.games_count > 0 &&
            sched.today.first_game_start_iso
          ) {
            var firstStart = Date.parse(sched.today.first_game_start_iso);
            if (isFinite(firstStart)) {
              var windowOpens = firstStart - 60 * 60 * 1000;
              var allFinal = states.every(function (s) { return s === 'final'; });
              if (now.getTime() >= windowOpens && !allFinal) return 'live';
            }
          }
          return 'recap';
        }

        // 1. sessionStorage override
        var override = null;
        try { override = window.sessionStorage.getItem('hgb-mode-override'); } catch (e) {}

        var mode, source;
        if (override && modes.indexOf(override) !== -1) {
          mode = override;
          source = 'override';
        } else {
          // 2. URL param
          var raw = params.get('mode');
          if (raw && modes.indexOf(raw) !== -1) {
            mode = raw;
            source = 'url';
          } else {
            // 3. Auto-detect
            mode = detectMode(schedule, new Date());
            source = 'auto';
          }
        }

        document.documentElement.setAttribute('data-home-mode', mode);
        document.documentElement.setAttribute('data-mode-source', source);
        document.documentElement.setAttribute('data-schedule-variant', schedKey);

        // Fixture variant — unchanged from Layer 3.
        var fixture = params.get('fixture');
        var resolvedFixture =
          fixture === 'shootout'      ? 'shootout'
          : fixture === 'shootout-long' ? 'shootout-long'
          : fixture === 'empty'       ? 'empty'
          : 'default';
        document.documentElement.setAttribute('data-fixture', resolvedFixture);
        if (resolvedFixture === 'empty') {
          document.documentElement.setAttribute('data-strip-empty', '1');
        }
      } catch (e) {
        document.documentElement.setAttribute('data-home-mode', 'live');
        document.documentElement.setAttribute('data-mode-source', 'auto');
        document.documentElement.setAttribute('data-fixture', 'default');
      }
    })();
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    body {
      background: var(--site-bg);
      color: var(--site-text);
      font-family: var(--font-site-body);
    }
    a { color: inherit; }
    img { display: block; max-width: 100%; }

    /* ── Page shell ─────────────────────────────────────────────── */
    .home-page {
      padding: 22px 20px 80px;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* ── Mode-gated views ───────────────────────────────────────── */
    /*
      Each [data-mode-view] block renders at build time and is hidden
      via CSS when the active mode doesn't match. This keeps SSR clean
      and avoids hydration flicker.
    */
    html[data-home-mode="live"]      [data-mode-view]:not([data-mode-view~="live"])      { display: none; }
    html[data-home-mode="recap"]     [data-mode-view]:not([data-mode-view~="recap"])     { display: none; }
    html[data-home-mode="tomorrow"]  [data-mode-view]:not([data-mode-view~="tomorrow"])  { display: none; }
    html[data-home-mode="offseason"] [data-mode-view]:not([data-mode-view~="offseason"]) { display: none; }

    /* Playoff strip is hidden in offseason mode — handled via the same
       per-mode rules (the strip lives inside [data-mode-view] containers). */

    /* ── Fixture-gated views (default vs shootout vs shootout-long) ──── */
    html[data-fixture="default"] [data-fixture-view="shootout"],
    html[data-fixture="default"] [data-fixture-view="shootout-long"] { display: none; }
    html[data-fixture="shootout"] [data-fixture-view="default"],
    html[data-fixture="shootout"] [data-fixture-view="shootout-long"] { display: none; }
    html[data-fixture="shootout-long"] [data-fixture-view="default"],
    html[data-fixture="shootout-long"] [data-fixture-view="shootout"] { display: none; }
    html[data-fixture="empty"] [data-fixture-view="shootout"],
    html[data-fixture="empty"] [data-fixture-view="shootout-long"] { display: none; }
    html[data-strip-empty="1"] .live-moment-strip { display: none; }

    /* ── Section headers (mirrors design's .sec-h pattern) ─────── */
    .home-sec-h {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin: 36px 0 12px;
    }
    .home-sec-h h2 {
      font-family: var(--font-site-display);
      font-weight: 700;
      font-size: 22px;
      color: var(--site-white);
      margin: 0;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .home-sec-h .count {
      color: var(--site-muted);
      font-family: var(--font-site-body);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 600;
    }

    /* ── 3×2×1 grid (live mode) ─────────────────────────────────── */
    .home-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    @media (max-width: 1024px) {
      .home-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .home-grid { grid-template-columns: 1fr; }
    }

    /* Tomorrow + Offseason wall grids reuse the same chrome but break
       at narrower thresholds — matchup wall is denser, storylines wider. */
    .home-wall {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    @media (max-width: 900px) { .home-wall { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .home-wall { grid-template-columns: 1fr; } }

    /* ── Recap-mode placeholder (Layer 4) ───────────────────────── */
    .hv2-placeholder {
      border: 1px dashed var(--site-border2);
      border-radius: var(--radius-md);
      min-height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--site-muted);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: center;
      padding: 20px;
      background: repeating-linear-gradient(
        135deg,
        transparent,
        transparent 10px,
        rgba(255, 255, 255, 0.01) 10px,
        rgba(255, 255, 255, 0.01) 20px
      );
    }

    .hv2-placeholder.tall { min-height: 320px; }

    @media (max-width: 720px) {
      .home-page { padding: 16px 12px 60px; }
    }
  </style>
</head>
<body class="hgb-site">
  <Topbar active="scores" dateLabel={liveDate} />

  <!--
    Playoff strip — live + recap + tomorrow modes carry it; offseason
    explicitly omits it (per spec: "no playoffs in offseason"). Each
    mode passes its own series array because round/series state evolves
    night-to-night.
  -->
  {playoffStrip && (
    <div data-mode-view="live" data-fixture-view="default">
      <PlayoffStrip eyebrow={playoffStrip.eyebrow} series={playoffStrip.series} />
    </div>
  )}
  {playoffStripSO && (
    <div data-mode-view="live" data-fixture-view="shootout">
      <PlayoffStrip eyebrow={playoffStripSO.eyebrow} series={playoffStripSO.series} />
    </div>
  )}
  {playoffStripSOLong && (
    <div data-mode-view="live" data-fixture-view="shootout-long">
      <PlayoffStrip eyebrow={playoffStripSOLong.eyebrow} series={playoffStripSOLong.series} />
    </div>
  )}
  {recapPlayoffStrip && (
    <div data-mode-view="recap">
      <PlayoffStrip eyebrow={recapPlayoffStrip.eyebrow} series={recapPlayoffStrip.series} />
    </div>
  )}
  {tomorrowPlayoffStrip && (
    <div data-mode-view="tomorrow">
      <PlayoffStrip eyebrow={tomorrowPlayoffStrip.eyebrow} series={tomorrowPlayoffStrip.series} />
    </div>
  )}

  <main class="home-page">
    <!--
      PageHero — eyebrow + h1 + sub vary by mode. Live + recap use the
      page-default copy (same baseline as Layer 1). Tomorrow + offseason
      get their own framing.
    -->
    <div data-mode-view="live" data-fixture-view="default">
      <PageHero eyebrow={liveEyebrow} />
    </div>
    <div data-mode-view="live" data-fixture-view="shootout">
      <PageHero eyebrow={liveEyebrowSO} />
    </div>
    <div data-mode-view="live" data-fixture-view="shootout-long">
      <PageHero eyebrow={liveEyebrowSOLong} />
    </div>
    <div data-mode-view="recap">
      <PageHero eyebrow={recapEyebrow} />
    </div>
    <div data-mode-view="tomorrow">
      <PageHero
        eyebrow={tomorrowHeroCopy.eyebrow}
        title={tomorrowHeroCopy.title}
        sub={tomorrowHeroCopy.sub}
      />
    </div>
    <div data-mode-view="offseason">
      <PageHero
        eyebrow={offseasonHeroCopy.eyebrow}
        title={offseasonHeroCopy.title}
        sub={offseasonHeroCopy.sub}
      />
    </div>

    <!--
      ModeBar — Astro renders it once with `mode="live"` because the
      page is statically built. The page script below patches the active
      pill + telemetry source stamp after resolveMode() runs. This
      avoids needing 4 ModeBar SSR copies.
    -->
    <ModeBar mode="live" artifactsCount={artifactsCount} />

    <!-- ════════════════════════════════════════════════════════════════
         LIVE MODE (existing — unchanged structurally)
    ════════════════════════════════════════════════════════════════ -->
    <section
      data-mode-view="live"
      data-fixture-view="default"
      aria-label="Live view"
    >
      <LiveHero game={featured} />
      <LiveMomentStrip moments={liveMock.live_moments ?? []} />

      <div class="home-sec-h">
        <h2>Tonight's Games</h2>
        <span class="count">
          {grid.total} games · {grid.live} live · {grid.final} final · {grid.pre} upcoming
        </span>
      </div>
      <div class="home-grid">
        {subgridGames.map(g => (
          <GameTile {...g} />
        ))}
      </div>
    </section>

    <section
      data-mode-view="live"
      data-fixture-view="shootout"
      aria-label="Live view (shootout fixture)"
    >
      <LiveHero game={featuredSO} />
      <LiveMomentStrip moments={liveShootoutMock.live_moments ?? []} />

      <div class="home-sec-h">
        <h2>Tonight's Games</h2>
        <span class="count">
          {gridSO.total} games · {gridSO.live} live · {gridSO.final} final · {gridSO.pre} upcoming
        </span>
      </div>
      <div class="home-grid">
        {subgridSO.map(g => (
          <GameTile {...g} />
        ))}
      </div>
    </section>

    <section
      data-mode-view="live"
      data-fixture-view="shootout-long"
      aria-label="Live view (long shootout fixture)"
    >
      <LiveHero game={featuredSOLong} />
      <LiveMomentStrip moments={liveShootoutLongMock.live_moments ?? []} />

      <div class="home-sec-h">
        <h2>Tonight's Games</h2>
        <span class="count">
          {gridSOLong.total} games · {gridSOLong.live} live · {gridSOLong.final} final · {gridSOLong.pre} upcoming
        </span>
      </div>
      <div class="home-grid">
        {subgridSOLong.map(g => (
          <GameTile {...g} />
        ))}
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         RECAP MODE (existing — unchanged)
    ════════════════════════════════════════════════════════════════ -->
    <section data-mode-view="recap" aria-label="Recap view">
      <RecapHero
        game={recapMock.game_of_night}
        supporting={recapMock.supporting_hero ?? null}
      />

      {recapMock.final_scores && recapMock.final_scores.length > 0 && (
        <RecapScoreStrip tiles={recapMock.final_scores} />
      )}

      <RecapFilterBar
        target=".recap-wall"
        initial="all"
        initialSort="impact"
        counts={recapCounts}
      />

      <RecapWall cards={recapMock.wall} defaultSort="impact" />

      <TweetEcho tweets={recapMock.tweet_echo} />

      {recapMock.model_retrospective && (
        <ModelRetrospective
          last_night={recapMock.model_retrospective.last_night}
          season={recapMock.model_retrospective.season}
        />
      )}
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         TOMORROW MODE (Layer 5)
         Section order:
           1. TomorrowHero            — date + featured matchup
           2. TomorrowSlateStrip      — all scheduled games
           3. Matchup previews wall   — top 3-4 ArtifactMatchup cards
           4. PredictionsGrid         — per-game model projections
           5. Storylines wall         — Hot/Cold/Milestone "could fire tomorrow"
    ════════════════════════════════════════════════════════════════ -->
    <section data-mode-view="tomorrow" aria-label="Tomorrow's slate view">
      <TomorrowHero
        date_label={tomorrowMock.date_label}
        featured={tomorrowMock.featured_matchup}
      />

      <TomorrowSlateStrip tiles={tomorrowMock.slate} />

      {tomorrowMock.matchup_previews.length > 0 && (
        <>
          <div class="home-sec-h">
            <h2>Matchup previews</h2>
            <span class="count">{tomorrowMock.matchup_previews.length} games highlighted</span>
          </div>
          <div class="home-wall">
            {tomorrowMock.matchup_previews.map((m) => (
              <ArtifactMatchup {...m} />
            ))}
          </div>
        </>
      )}

      {tomorrowMock.predictions.length > 0 && (
        <PredictionsGrid predictions={tomorrowMock.predictions} />
      )}

      {tomorrowMock.storylines.length > 0 && (
        <>
          <div class="home-sec-h">
            <h2>Storylines to watch</h2>
            <span class="count">{tomorrowMock.storylines.length} could fire tomorrow</span>
          </div>
          <div class="home-wall">
            {tomorrowMock.storylines.map((s) => {
              if (s.kind === 'hot') return <ArtifactHot {...s.data} />;
              if (s.kind === 'cold') return <ArtifactCold {...s.data} />;
              if (s.kind === 'milestone') return <ArtifactMilestone {...s.data} />;
              return null;
            })}
          </div>
        </>
      )}
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         OFFSEASON MODE (Layer 5 — basic V1)
         Section order:
           1. OffseasonHero       — countdown + camp/opening dates
           2. LastPlayedCard      — memorial wrap of ArtifactGame
           3. SummerStorylines    — placeholder card grid
           4. "We'll be back" footnote
    ════════════════════════════════════════════════════════════════ -->
    <section data-mode-view="offseason" aria-label="Offseason view">
      <OffseasonHero
        eyebrow={offseasonMock.hero_eyebrow}
        countdown={offseasonMock.countdown}
      />

      <LastPlayedCard
        memorial_eyebrow={offseasonMock.last_played.memorial_eyebrow}
        game_data={offseasonMock.last_played.game_data}
        kind={offseasonMock.last_played.kind}
      />

      <SummerStorylines storylines={offseasonMock.summer_storylines} />

      <footer class="oh-footer">
        <span class="oh-footer-tick" aria-hidden="true">▍</span>
        <span class="oh-footer-text">
          We'll be back. <a href="?mode=live">Live mode →</a> when the puck drops.
        </span>
      </footer>
    </section>
  </main>

  <style is:global>
    /* ── Offseason "we'll be back" footnote ──────────────────────── */
    .oh-footer {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 18px 0 0;
      border-top: 1px dashed #1c1c1c;
      margin-top: 12px;
    }
    .oh-footer-tick {
      color: var(--hgb-red);
      font-size: 14px;
      line-height: 1;
    }
    .oh-footer-text {
      font-family: var(--font-site-body);
      font-size: 12.5px;
      color: #888;
    }
    .oh-footer-text a {
      color: var(--site-white);
      text-decoration: none;
      font-weight: 700;
      border-bottom: 1px solid var(--status-live);
    }
    .oh-footer-text a:hover { color: var(--status-live); }
  </style>

  <!--
    Hero-pick debug stamp — useful for screenshotting the stickiness
    behaviour on the live fixture.
  -->
  <script is:inline define:vars={{ heroPickedId, heroIsStickyChosen }}>
    (function () {
      try {
        var hero = document.querySelector('[data-fixture-view="default"] .live-hero');
        if (hero) {
          hero.setAttribute('data-hero-id', heroPickedId || '');
          hero.setAttribute('data-hero-sticky', heroIsStickyChosen ? '1' : '0');
        }
      } catch (e) { /* no-op */ }
    })();
  </script>

  <!--
    Page-level hydration script (Layer 5 rewrite of Layer 1 binding):

    1. Sync ModeBar pills + source stamp + reset button to the resolved
       mode + source attrs the head script wrote.
    2. Wire ModeBar pill clicks → setOverride() → reload.
    3. Wire ↻ AUTO reset button → clearOverride() → reload (drops
       ?mode= from URL on the way so auto-detect runs clean).
    4. Topbar date pill swap (per-mode date label).
    5. Hydrate the existing LiveHero stats carousel + goal-chip clamp
       (unchanged from Layer 1.9 / Layer 3).
  -->
  <script is:inline define:vars={{ liveDate, recapDate, tomorrowDate, offseasonDate }}>
    (function () {
      var mode = document.documentElement.getAttribute('data-home-mode') || 'live';
      var source = document.documentElement.getAttribute('data-mode-source') || 'auto';

      // ── ModeBar active pill ──────────────────────────────────────
      var toggles = document.querySelectorAll('.mode-bar [data-mode-toggle]');
      toggles.forEach(function (node) {
        var key = node.getAttribute('data-mode-toggle');
        var isActive = key === mode;
        node.classList.toggle('active', isActive);
        node.setAttribute('aria-selected', isActive ? 'true' : 'false');
        var dotSpan = node.querySelector('.dot');
        if (dotSpan) dotSpan.textContent = isActive ? '●' : '○';
      });

      // ── Source stamp + reset link ────────────────────────────────
      var sourceStamp = document.querySelector('[data-mode-source]');
      var resetBtn = document.querySelector('[data-mode-reset]');

      function paintSource(s) {
        if (!sourceStamp) return;
        if (s === 'override') {
          sourceStamp.textContent = ' · MANUAL';
          sourceStamp.setAttribute('data-source', 'manual');
        } else if (s === 'url') {
          sourceStamp.textContent = ' · LINK';
          sourceStamp.setAttribute('data-source', 'url');
        } else {
          sourceStamp.textContent = ' · AUTO MODE';
          sourceStamp.setAttribute('data-source', 'auto');
        }
        if (resetBtn) {
          // Reset button only meaningful when an override is in effect.
          // For 'url' we leave it hidden — the URL itself is the
          // user-visible reset (delete the param).
          resetBtn.hidden = s !== 'override';
        }
      }
      paintSource(source);

      // ── ModeBar click → setOverride + reload ────────────────────
      toggles.forEach(function (node) {
        node.addEventListener('click', function (e) {
          e.preventDefault();
          var key = node.getAttribute('data-mode-toggle');
          if (!key) return;
          try { window.sessionStorage.setItem('hgb-mode-override', key); } catch (e2) {}
          // Drop ?mode= from the URL so the manual choice owns the source.
          // Keep ?schedule=N if present so QA stays sticky across clicks.
          var url = new URL(window.location.href);
          url.searchParams.delete('mode');
          window.location.href = url.toString();
        });
      });

      // ── Reset button → clearOverride + reload ────────────────────
      if (resetBtn) {
        resetBtn.addEventListener('click', function () {
          try { window.sessionStorage.removeItem('hgb-mode-override'); } catch (e2) {}
          var url = new URL(window.location.href);
          url.searchParams.delete('mode');
          window.location.href = url.toString();
        });
      }

      // ── Topbar date ──────────────────────────────────────────────
      var dateEl = document.querySelector('.hgb-topbar .date');
      if (dateEl) {
        dateEl.textContent =
          mode === 'recap'     ? recapDate
        : mode === 'tomorrow'  ? tomorrowDate
        : mode === 'offseason' ? offseasonDate
        :                        liveDate;
      }

      // ── LiveHero stats carousel (unchanged from Layer 1.9) ──────
      (function hydrateStatsCarousel() {
        var zones = document.querySelectorAll('.live-hero .lh-right[data-stats-active]');
        zones.forEach(function (zone) {
          var tabs = zone.querySelectorAll('[data-stats-target]');
          if (!tabs.length) return;

          function applyPanel(target) {
            var panel = target === 'b' ? 'b' : 'a';
            zone.setAttribute('data-stats-active', panel);
            tabs.forEach(function (t) {
              var match = t.getAttribute('data-stats-target') === panel;
              t.setAttribute('aria-selected', match ? 'true' : 'false');
            });
          }

          try {
            var saved = window.sessionStorage.getItem('hgb-stats-panel');
            if (saved === 'a' || saved === 'b') applyPanel(saved);
          } catch (e) { /* sessionStorage blocked — fall back to default */ }

          tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
              var target = tab.getAttribute('data-stats-target') || 'a';
              applyPanel(target);
              try {
                window.sessionStorage.setItem('hgb-stats-panel', target);
              } catch (e) { /* ignore */ }
            });
          });
        });
      })();

      // ── LiveHero footer goal-chip clamp (unchanged from Layer 3) ─
      (function hydrateGoalFooter() {
        var feeds = document.querySelectorAll('.live-hero .goal-feed');
        if (!feeds.length) return;

        var params = new URLSearchParams(window.location.search);
        var goalsRaw = params.get('goals');

        feeds.forEach(function (feed) {
          var totalGoals = parseInt(feed.getAttribute('data-goal-count') || '0', 10);

          var visibleGoals;
          if (goalsRaw === null || goalsRaw === 'all') {
            visibleGoals = totalGoals;
          } else {
            var parsed = parseInt(goalsRaw, 10);
            visibleGoals = isNaN(parsed)
              ? totalGoals
              : Math.max(0, Math.min(parsed, totalGoals));
          }

          var goalChips = feed.querySelectorAll('[data-chip-kind="goal"]');
          goalChips.forEach(function (chip) {
            var idx = parseInt(chip.getAttribute('data-chip-idx') || '0', 10);
            chip.hidden = idx >= visibleGoals;
          });

          feed.setAttribute('data-rendered-goals', String(visibleGoals));
        });
      })();
    })();
  </script>
</body>
</html>
