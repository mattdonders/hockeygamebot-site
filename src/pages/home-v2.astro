---
import '../styles/site-tokens.css';
import Topbar from '../components/home/Topbar.astro';
import PlayoffStrip from '../components/home/PlayoffStrip.astro';
import PageHero from '../components/home/PageHero.astro';
import ModeBar from '../components/home/ModeBar.astro';
import LiveHero from '../components/home/LiveHero.astro';
import type { FeaturedGame } from '../components/home/LiveHero.astro';

import liveMock from '../data/home-mock/live.json';
import recapMock from '../data/home-mock/recap.json';

// Both mode bodies are rendered to the DOM at build time. A small inline
// script in <head> reads ?mode= and swaps which view is visible + updates
// the ModeBar active state, PageHero eyebrow, and Topbar date pill. This
// pattern avoids Cloudflare Pages SSR while still supporting query-param
// mode switching on a static build.
const featured = liveMock.featured_game as FeaturedGame;
const playoffStrip = liveMock.playoff_strip;

// Eyebrow + date values for both modes are shipped as data-* so the
// tiny head script can swap them without re-rendering.
const liveEyebrow = liveMock.hero_eyebrow;
const recapEyebrow = recapMock.hero_eyebrow;
const liveDate = liveMock.date_label;
const recapDate = recapMock.date_label;
---
<!DOCTYPE html>
<html lang="en" data-home-mode="live">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="dark">
  <!-- Dev: keep /home-v2 out of search indices while the rebuild is in-progress -->
  <meta name="robots" content="noindex,nofollow">
  <title>HockeyGameBot — Home (v2 preview)</title>
  <meta name="description" content="Rebuild preview of the HockeyGameBot home page. Not linked from the production scoreboard.">

  <!--
    Mode swap — runs before first paint to avoid a live→recap flash.
    Keeps SSR/static compatibility (Astro output: 'static') while still
    letting /home-v2?mode=recap reach the right view. Safe no-op on the
    default live view.
  -->
  <script is:inline>
    (function () {
      try {
        var params = new URLSearchParams(window.location.search);
        var raw = params.get('mode');
        var mode = raw === 'recap' ? 'recap' : 'live';
        document.documentElement.setAttribute('data-home-mode', mode);
      } catch (e) {
        document.documentElement.setAttribute('data-home-mode', 'live');
      }
    })();
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    body {
      background: var(--site-bg);
      color: var(--site-text);
      font-family: var(--font-site-body);
    }
    a { color: inherit; }
    img { display: block; max-width: 100%; }

    /* ── Page shell ─────────────────────────────────────────────── */
    .home-page {
      padding: 22px 20px 80px;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* ── Mode-gated views ───────────────────────────────────────── */
    html[data-home-mode="live"] [data-mode-view="recap"] { display: none; }
    html[data-home-mode="recap"] [data-mode-view="live"] { display: none; }

    /* ── Placeholder boxes for layer-N deliverables ─────────────── */
    .hv2-placeholder {
      border: 1px dashed var(--site-border2);
      border-radius: var(--radius-md);
      min-height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--site-muted);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: center;
      padding: 20px;
      background: repeating-linear-gradient(
        135deg,
        transparent,
        transparent 10px,
        rgba(255, 255, 255, 0.01) 10px,
        rgba(255, 255, 255, 0.01) 20px
      );
    }

    .hv2-placeholder.tall { min-height: 320px; }

    .hv2-placeholders-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 28px;
    }

    @media (max-width: 720px) {
      .home-page { padding: 16px 12px 60px; }
      .hv2-placeholders-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body class="hgb-site">
  <Topbar active="scores" dateLabel={liveDate} />
  {playoffStrip && (
    <div data-mode-view="live">
      <PlayoffStrip eyebrow={playoffStrip.eyebrow} series={playoffStrip.series} />
    </div>
  )}

  <main class="home-page">
    <div data-mode-view="live">
      <PageHero eyebrow={liveEyebrow} />
    </div>
    <div data-mode-view="recap">
      <PageHero eyebrow={recapEyebrow} />
    </div>

    <ModeBar mode="live" />

    <section data-mode-view="live" aria-label="Live view">
      <LiveHero game={featured} />
      <div class="hv2-placeholders-grid" aria-hidden="true">
        <div class="hv2-placeholder">Game grid · Layer 2</div>
        <div class="hv2-placeholder">Artifacts inline · Layer 2</div>
        <div class="hv2-placeholder">Model predictions · Layer 3</div>
        <div class="hv2-placeholder">Goal wash overlays · Layer 3</div>
      </div>
    </section>

    <section data-mode-view="recap" aria-label="Recap view">
      <div class="hv2-placeholder tall" aria-hidden="true">
        Recap layout · Layer 4 — coming soon
      </div>
    </section>
  </main>

  <!--
    Client-side mode binding:
      1. Sync the ModeBar toggle `.active` state to the current URL mode.
         (The Astro-rendered ModeBar always ships with `mode="live"` since
         we pre-render once at build time.)
      2. Date pill on the topbar is swapped if the mock diverges between
         live + recap.
      3. Decide the visible chip set in the LiveHero footer strip:
           • no param / goals=all → full goal chips, no last-events
           • ?goals=0             → last-events only
           • ?goals=1             → 1 goal + up to 3 last-events
           • ?goals=N             → first N goals (clamped); fill with
                                    last-events if visible < 2
         Also handles "+ N more" overflow when goal count exceeds MAX.
         MIN_SLOTS=4, MAX_SLOTS=6 from data-* on the footer.
  -->
  <script is:inline define:vars={{ liveDate, recapDate }}>
    (function () {
      var mode = document.documentElement.getAttribute('data-home-mode') || 'live';

      // ── ModeBar active state ─────────────────────────────────────
      var toggles = document.querySelectorAll('.mode-bar .toggle');
      toggles.forEach(function (node) {
        var href = node.getAttribute('href') || '';
        var key = href.indexOf('mode=recap') !== -1 ? 'recap'
                : href.indexOf('mode=live')  !== -1 ? 'live'
                : 'tomorrow';
        var isActive = key === mode;
        node.classList.toggle('active', isActive);
        if (!node.classList.contains('disabled')) {
          node.setAttribute('aria-selected', isActive ? 'true' : 'false');
        }
        var dotSpan = node.querySelector('.dot');
        if (dotSpan) dotSpan.textContent = isActive ? '●' : '○';
      });

      // ── Topbar date ──────────────────────────────────────────────
      var dateEl = document.querySelector('.hgb-topbar .date');
      if (dateEl) {
        dateEl.textContent = mode === 'recap' ? recapDate : liveDate;
      }

      // ── LiveHero footer strip: goal/last-events slot allocation ─
      //
      // Footer layout (Layer 1.6):
      //   [ goal/PBP chips … ] [ + N more? ] [ Latest Activity ]
      //
      // The Latest Activity card is rendered server-side and never
      // toggled by this script — it always occupies the rightmost slot.
      // Effective capacity for chips + more = MAX - 1 (reserved slot).
      (function hydrateFooterStrip() {
        var feed = document.querySelector('.live-hero .goal-feed');
        if (!feed) return;

        var params = new URLSearchParams(window.location.search);
        var goalsRaw = params.get('goals'); // null | 'all' | string-int

        var MAX_ALL = parseInt(feed.getAttribute('data-max-slots') || '6', 10);
        var MIN = parseInt(feed.getAttribute('data-min-slots') || '4', 10);
        var MAX = MAX_ALL - 1; // reserve rightmost slot for Latest Activity
        var totalGoals = parseInt(feed.getAttribute('data-goal-count') || '0', 10);
        var totalLast  = parseInt(feed.getAttribute('data-last-count') || '0', 10);

        // Resolve how many goal chips to show.
        //   default | 'all' → totalGoals (clamped later by MAX)
        //   '0' / '1' / 'N' → that many
        var goalsToShow;
        if (goalsRaw === null || goalsRaw === 'all') {
          goalsToShow = totalGoals;
        } else {
          var parsed = parseInt(goalsRaw, 10);
          goalsToShow = isNaN(parsed) ? totalGoals : Math.max(0, Math.min(parsed, totalGoals));
        }

        // Cap goals at MAX (one slot becomes the "+ N more" chip when overflow).
        var hasOverflow = goalsToShow > MAX;
        var goalSlots = hasOverflow ? (MAX - 1) : goalsToShow;

        // Decide if last-events fill is needed (only when < 2 goals visible).
        var lastNeeded = 0;
        if (goalSlots < 2) {
          // Fill up to MIN slots minimum, up to MAX ceiling.
          // MIN counts the Latest Activity card too, so subtract 1.
          var desired = Math.max((MIN - 1) - goalSlots, 0);
          // Honor the spec's explicit rule for goals=1: "up to 3 last-events"
          if (goalsRaw === '1') desired = 3;
          if (goalsRaw === '0') desired = Math.max(4, MIN - 1); // aim for 4, cap at MAX
          lastNeeded = Math.min(desired, totalLast, MAX - goalSlots);
        }

        // Apply visibility to goal chips.
        var goalChips = feed.querySelectorAll('[data-chip-kind="goal"]');
        goalChips.forEach(function (chip) {
          var idx = parseInt(chip.getAttribute('data-chip-idx') || '0', 10);
          chip.hidden = idx >= goalSlots;
        });

        // "+ N more" placeholder.
        var moreChip = feed.querySelector('[data-chip-kind="more"]');
        if (moreChip) {
          if (hasOverflow) {
            var remaining = totalGoals - goalSlots;
            var countEl = moreChip.querySelector('[data-more-n]');
            if (countEl) countEl.textContent = String(remaining);
            moreChip.hidden = false;
          } else {
            moreChip.hidden = true;
          }
        }

        // Last-events chips fill whatever remains.
        var lastChips = feed.querySelectorAll('[data-chip-kind="last"]');
        lastChips.forEach(function (chip) {
          var idx = parseInt(chip.getAttribute('data-chip-idx') || '0', 10);
          chip.hidden = idx >= lastNeeded;
        });
      })();
    })();
  </script>
</body>
</html>
