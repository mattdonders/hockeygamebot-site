---
import '../styles/site-tokens.css';
import Topbar from '../components/home/Topbar.astro';
import PlayoffStrip from '../components/home/PlayoffStrip.astro';
import PageHero from '../components/home/PageHero.astro';
import ModeBar from '../components/home/ModeBar.astro';
import LiveHero from '../components/home/LiveHero.astro';
import LiveMomentStrip from '../components/home/LiveMomentStrip.astro';
import GameTile from '../components/home/GameTile.astro';

import liveMockRaw from '../data/home-mock/live.json';
import liveShootoutMockRaw from '../data/home-mock/live.shootout.json';
import recapMock from '../data/home-mock/recap.json';

import { parseLiveMockOrThrow } from '../lib/live-mock-schemas';
import { pickHero } from '../lib/excitement';

// Validate both live fixtures at build time so any drift between the
// JSON shape and the Layer 3 contract fails the build with a path-aware
// error rather than rendering broken markup.
const liveMock = parseLiveMockOrThrow(liveMockRaw, 'home-mock/live.json');
const liveShootoutMock = parseLiveMockOrThrow(
  liveShootoutMockRaw,
  'home-mock/live.shootout.json',
);

// ── Hero selection ──────────────────────────────────────────────────────────
//
// Layer 3 introduces a shared `pickHero()` (in src/lib/excitement.ts) that
// applies hero-stickiness rules. For the static mock we hardcode the prior
// hero id to the BOS@BUF playoff featured game — this exercises the sticky
// path: even if a tighter game existed, the "I'm broadcast + 30" bonus
// keeps the hero put. The real-time wiring in Layer 6 will read the prior
// hero id from session state.
const PRIOR_HERO_ID = '2026030124'; // BOS @ BUF
// Build an ExcitementGame view from the games[] grid entries so pickHero
// can score them. The mock games array carries `state` not `status`, so we
// translate here at the boundary.
type GridGame = (typeof liveMock.games extends infer T
  ? T extends Array<infer U>
    ? U
    : never
  : never);
function gridToExcitement(g: GridGame) {
  const status =
    g.state === 'live' || g.state === 'intermission'
      ? 'live'
      : g.state === 'final' || g.state === 'ot'
      ? 'final'
      : 'scheduled';
  return {
    id: g.id,
    status,
    period: g.period,
    time_remaining: g.clock,
    home_team: { score: g.home.score ?? 0 },
    away_team: { score: g.away.score ?? 0 },
  };
}
const heroPick = liveMock.games
  ? pickHero(liveMock.games.map(gridToExcitement), { currentHeroId: PRIOR_HERO_ID })
  : null;
// Resolve the actual featured game payload (with full stats / goal_feed /
// last_events) — `featured_game` in the JSON is the rich payload; `games[]`
// is the compact tile shape. We pickHero from the tiles, then look up the
// matching rich payload. If the picked id matches the JSON's existing
// featured_game.id, we use it as-is.
const featured = liveMock.featured_game;
// In a future layer the rich payload would be fetched per-pick; for the
// mock, we always show liveMock.featured_game (BOS @ BUF) and let the
// stickiness *decision* be observable via game-tile selection.
const heroPickedId = heroPick?.id ?? null;
const heroIsStickyChosen = heroPickedId === featured.id;

// Sub-grid: every game EXCEPT the picked hero. If pickHero returned null
// (no games), fall back to "everything except featured_game.id".
const heroIdToExclude = heroPickedId ?? featured.id;
const subgridGames = (liveMock.games ?? []).filter(g => g.id !== heroIdToExclude);

// Shootout-fixture variant — same layout, different mock. Both are SSR'd
// to the page; a head script reads `?fixture=shootout` and toggles which
// one is visible.
const featuredSO = liveShootoutMock.featured_game;
const subgridSO = (liveShootoutMock.games ?? []).filter(
  g => g.id !== featuredSO.id,
);

const playoffStrip = liveMock.playoff_strip;
const playoffStripSO = liveShootoutMock.playoff_strip;
const liveEyebrow = liveMock.hero_eyebrow;
const liveEyebrowSO = liveShootoutMock.hero_eyebrow;
const recapEyebrow = recapMock.hero_eyebrow;
const liveDate = liveMock.date_label;
const recapDate = recapMock.date_label;

// Section header counts.
function countByState(games: typeof liveMock.games | undefined): {
  total: number;
  live: number;
  final: number;
  pre: number;
} {
  const list = games ?? [];
  return {
    total: list.length,
    live: list.filter(g => g.state === 'live' || g.state === 'intermission').length,
    final: list.filter(g => g.state === 'final' || g.state === 'ot').length,
    pre: list.filter(g => g.state === 'pre').length,
  };
}
const grid = countByState(liveMock.games);
const gridSO = countByState(liveShootoutMock.games);

// Telemetry artifact count — feeds ModeBar's "N ARTIFACTS FIRED TONIGHT"
// line. Same ModeBar is rendered once across both fixtures, so we pull
// from the default fixture (the shootout fixture is a swap-in variant
// for QA, not a separate page state).
const artifactsCount = (liveMock.live_moments ?? []).length;
---
<!DOCTYPE html>
<html lang="en" data-home-mode="live" data-fixture="default">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="dark">
  <!-- Dev: keep /home-v2 out of search indices while the rebuild is in-progress -->
  <meta name="robots" content="noindex,nofollow">
  <title>HockeyGameBot — Home (v2 preview)</title>
  <meta name="description" content="Rebuild preview of the HockeyGameBot home page. Not linked from the production scoreboard.">

  <!--
    Mode swap — runs before first paint to avoid a live→recap flash.
    Keeps SSR/static compatibility (Astro output: 'static') while still
    letting /home-v2?mode=recap reach the right view. Safe no-op on the
    default live view.

    Layer 3 also reads `?fixture=shootout` and stamps `data-fixture` on
    the html root. Both live-fixture variants render at build time; CSS
    rules below show/hide the right one.
  -->
  <script is:inline>
    (function () {
      try {
        var params = new URLSearchParams(window.location.search);
        var raw = params.get('mode');
        var mode = raw === 'recap' ? 'recap' : 'live';
        document.documentElement.setAttribute('data-home-mode', mode);

        var fixture = params.get('fixture');
        var resolvedFixture =
          fixture === 'shootout' ? 'shootout'
          : fixture === 'empty'  ? 'empty'
          : 'default';
        document.documentElement.setAttribute('data-fixture', resolvedFixture);
        // The 'empty' variant reuses the default mock but suppresses the
        // LiveMomentStrip — same data, different presentation. Stamp a
        // body-level data attr so the strip's CSS knows to hide.
        if (resolvedFixture === 'empty') {
          document.documentElement.setAttribute('data-strip-empty', '1');
        }
      } catch (e) {
        document.documentElement.setAttribute('data-home-mode', 'live');
        document.documentElement.setAttribute('data-fixture', 'default');
      }
    })();
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    body {
      background: var(--site-bg);
      color: var(--site-text);
      font-family: var(--font-site-body);
    }
    a { color: inherit; }
    img { display: block; max-width: 100%; }

    /* ── Page shell ─────────────────────────────────────────────── */
    .home-page {
      padding: 22px 20px 80px;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* ── Mode-gated views ───────────────────────────────────────── */
    html[data-home-mode="live"] [data-mode-view="recap"] { display: none; }
    html[data-home-mode="recap"] [data-mode-view="live"] { display: none; }

    /* ── Fixture-gated views (default vs shootout) ──────────────── */
    html[data-fixture="default"] [data-fixture-view="shootout"] { display: none; }
    html[data-fixture="shootout"] [data-fixture-view="default"] { display: none; }
    /* `?fixture=empty` reuses the default fixture but suppresses the
       LiveMomentStrip — verifies the empty-state hide behaviour. */
    html[data-fixture="empty"] [data-fixture-view="shootout"] { display: none; }
    html[data-strip-empty="1"] .live-moment-strip { display: none; }

    /* ── Section headers (mirrors design's .sec-h pattern) ─────── */
    .home-sec-h {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin: 36px 0 12px;
    }
    .home-sec-h h2 {
      font-family: var(--font-site-display);
      font-weight: 700;
      font-size: 22px;
      color: var(--site-white);
      margin: 0;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .home-sec-h .count {
      color: var(--site-muted);
      font-family: var(--font-site-body);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 600;
    }

    /* ── 3×2×1 grid (live mode) ─────────────────────────────────── */
    .home-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    @media (max-width: 1024px) {
      .home-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .home-grid { grid-template-columns: 1fr; }
    }

    /* ── Recap-mode placeholder (Layer 4) ───────────────────────── */
    .hv2-placeholder {
      border: 1px dashed var(--site-border2);
      border-radius: var(--radius-md);
      min-height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--site-muted);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: center;
      padding: 20px;
      background: repeating-linear-gradient(
        135deg,
        transparent,
        transparent 10px,
        rgba(255, 255, 255, 0.01) 10px,
        rgba(255, 255, 255, 0.01) 20px
      );
    }

    .hv2-placeholder.tall { min-height: 320px; }

    @media (max-width: 720px) {
      .home-page { padding: 16px 12px 60px; }
    }
  </style>
</head>
<body class="hgb-site">
  <Topbar active="scores" dateLabel={liveDate} />
  {playoffStrip && (
    <div data-mode-view="live" data-fixture-view="default">
      <PlayoffStrip eyebrow={playoffStrip.eyebrow} series={playoffStrip.series} />
    </div>
  )}
  {playoffStripSO && (
    <div data-mode-view="live" data-fixture-view="shootout">
      <PlayoffStrip eyebrow={playoffStripSO.eyebrow} series={playoffStripSO.series} />
    </div>
  )}

  <main class="home-page">
    <div data-mode-view="live" data-fixture-view="default">
      <PageHero eyebrow={liveEyebrow} />
    </div>
    <div data-mode-view="live" data-fixture-view="shootout">
      <PageHero eyebrow={liveEyebrowSO} />
    </div>
    <div data-mode-view="recap">
      <PageHero eyebrow={recapEyebrow} />
    </div>

    <ModeBar mode="live" artifactsCount={artifactsCount} />

    <!--
      LIVE MODE — default fixture (regulation BOS @ BUF in P3, 8 other games)
      Hero is selected via pickHero() with PRIOR_HERO_ID hardcoded for the
      mock; in production Layer 6 will read prior id from session state.
    -->
    <section
      data-mode-view="live"
      data-fixture-view="default"
      aria-label="Live view"
    >
      <LiveHero game={featured} />
      <LiveMomentStrip moments={liveMock.live_moments ?? []} />

      <div class="home-sec-h">
        <h2>Tonight's Games</h2>
        <span class="count">
          {grid.total} games · {grid.live} live · {grid.final} final · {grid.pre} upcoming
        </span>
      </div>
      <div class="home-grid">
        {subgridGames.map(g => (
          <GameTile {...g} />
        ))}
      </div>
    </section>

    <!--
      LIVE MODE — shootout fixture (BOS @ BUF SHOOTOUT, 5 other games).
      Same layout, different mock data. Both are SSR'd; the head script
      sets data-fixture and CSS swaps which one renders.
    -->
    <section
      data-mode-view="live"
      data-fixture-view="shootout"
      aria-label="Live view (shootout fixture)"
    >
      <LiveHero game={featuredSO} />
      <LiveMomentStrip moments={liveShootoutMock.live_moments ?? []} />

      <div class="home-sec-h">
        <h2>Tonight's Games</h2>
        <span class="count">
          {gridSO.total} games · {gridSO.live} live · {gridSO.final} final · {gridSO.pre} upcoming
        </span>
      </div>
      <div class="home-grid">
        {subgridSO.map(g => (
          <GameTile {...g} />
        ))}
      </div>
    </section>

    <section data-mode-view="recap" aria-label="Recap view">
      <div class="hv2-placeholder tall" aria-hidden="true">
        Recap layout · Layer 4 — coming soon
      </div>
    </section>
  </main>

  <!--
    Hero-pick debug stamp — useful for screenshotting the stickiness
    behaviour. data-hero-* attrs on the LiveHero root identify which game
    pickHero() chose and whether stickiness preserved the prior hero.
  -->
  <script is:inline define:vars={{ heroPickedId, heroIsStickyChosen }}>
    (function () {
      try {
        var hero = document.querySelector('[data-fixture-view="default"] .live-hero');
        if (hero) {
          hero.setAttribute('data-hero-id', heroPickedId || '');
          hero.setAttribute('data-hero-sticky', heroIsStickyChosen ? '1' : '0');
        }
      } catch (e) { /* no-op */ }
    })();
  </script>

  <!--
    Client-side mode binding:
      1. Sync the ModeBar toggle `.active` state to the current URL mode.
         (The Astro-rendered ModeBar always ships with `mode="live"` since
         we pre-render once at build time.)
      2. Date pill on the topbar is swapped if the mock diverges between
         live + recap.
      3. LiveHero footer goal-chip clamp via `?goals=N`:
           • no param / 'all' → render all
           • ?goals=N         → render min(N, total) chips
           • ?goals=0         → footer collapses entirely (CSS rule via
                                data-rendered-goals="0")
         No "+ N more" placeholder, no Latest Activity card. Goal-list
         overflow will be handled by the Layer 3 game modal.
  -->
  <script is:inline define:vars={{ liveDate, recapDate }}>
    (function () {
      var mode = document.documentElement.getAttribute('data-home-mode') || 'live';

      // ── ModeBar active state ─────────────────────────────────────
      var toggles = document.querySelectorAll('.mode-bar .toggle');
      toggles.forEach(function (node) {
        var href = node.getAttribute('href') || '';
        var key = href.indexOf('mode=recap') !== -1 ? 'recap'
                : href.indexOf('mode=live')  !== -1 ? 'live'
                : 'tomorrow';
        var isActive = key === mode;
        node.classList.toggle('active', isActive);
        if (!node.classList.contains('disabled')) {
          node.setAttribute('aria-selected', isActive ? 'true' : 'false');
        }
        var dotSpan = node.querySelector('.dot');
        if (dotSpan) dotSpan.textContent = isActive ? '●' : '○';
      });

      // ── Topbar date ──────────────────────────────────────────────
      var dateEl = document.querySelector('.hgb-topbar .date');
      if (dateEl) {
        dateEl.textContent = mode === 'recap' ? recapDate : liveDate;
      }

      // ── LiveHero stats carousel (Layer 1.9) ──────────────────────
      // Two panels (a=GAME stat bars, b=PBP feed). User's choice
      // persists in sessionStorage under `hgb-stats-panel`. Toggle is
      // the tab pill row inside `.lh-right`. Layer 1.9 collapsed the
      // top/bottom split — `data-stats-active` now lives on `.lh-right`
      // directly. CSS handles the 200ms fade.
      //
      // Layer 3: when the featured game is in shootout, the right pane
      // is replaced by ShootoutTracker (no `.lh-right[data-stats-active]`
      // is rendered) so this hydration is a no-op for that path.
      (function hydrateStatsCarousel() {
        // Hydrate every visible LiveHero. SSR ships both fixture
        // variants, but the inactive one is display:none'd via CSS.
        var zones = document.querySelectorAll('.live-hero .lh-right[data-stats-active]');
        zones.forEach(function (zone) {
          var tabs = zone.querySelectorAll('[data-stats-target]');
          if (!tabs.length) return;

          function applyPanel(target) {
            var panel = target === 'b' ? 'b' : 'a';
            zone.setAttribute('data-stats-active', panel);
            tabs.forEach(function (t) {
              var match = t.getAttribute('data-stats-target') === panel;
              t.setAttribute('aria-selected', match ? 'true' : 'false');
            });
          }

          // Restore choice from session if present.
          try {
            var saved = window.sessionStorage.getItem('hgb-stats-panel');
            if (saved === 'a' || saved === 'b') applyPanel(saved);
          } catch (e) { /* sessionStorage blocked — fall back to default */ }

          tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
              var target = tab.getAttribute('data-stats-target') || 'a';
              applyPanel(target);
              try {
                window.sessionStorage.setItem('hgb-stats-panel', target);
              } catch (e) { /* ignore */ }
            });
          });
        });
      })();

      // ── LiveHero footer goal-chip clamp ──────────────────────────
      // Resolve `?goals=N`, hide chips beyond the requested count.
      // When zero chips render, stamp data-rendered-goals="0" so the
      // CSS rule collapses the footer.
      (function hydrateGoalFooter() {
        var feeds = document.querySelectorAll('.live-hero .goal-feed');
        if (!feeds.length) return;

        var params = new URLSearchParams(window.location.search);
        var goalsRaw = params.get('goals'); // null | 'all' | string-int

        feeds.forEach(function (feed) {
          var totalGoals = parseInt(feed.getAttribute('data-goal-count') || '0', 10);

          var visibleGoals;
          if (goalsRaw === null || goalsRaw === 'all') {
            visibleGoals = totalGoals;
          } else {
            var parsed = parseInt(goalsRaw, 10);
            visibleGoals = isNaN(parsed)
              ? totalGoals
              : Math.max(0, Math.min(parsed, totalGoals));
          }

          var goalChips = feed.querySelectorAll('[data-chip-kind="goal"]');
          goalChips.forEach(function (chip) {
            var idx = parseInt(chip.getAttribute('data-chip-idx') || '0', 10);
            chip.hidden = idx >= visibleGoals;
          });

          feed.setAttribute('data-rendered-goals', String(visibleGoals));
        });
      })();
    })();
  </script>
</body>
</html>
