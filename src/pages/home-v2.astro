---
import '../styles/site-tokens.css';
import Topbar from '../components/home/Topbar.astro';
import PlayoffStrip from '../components/home/PlayoffStrip.astro';
import PageHero from '../components/home/PageHero.astro';
import ModeBar from '../components/home/ModeBar.astro';
import LiveHero from '../components/home/LiveHero.astro';
import LiveMomentStrip from '../components/home/LiveMomentStrip.astro';
import GameTile from '../components/home/GameTile.astro';

import RecapHero from '../components/home/RecapHero.astro';
import RecapScoreStrip from '../components/home/RecapScoreStrip.astro';
import RecapFilterBar from '../components/home/RecapFilterBar.astro';
import RecapWall from '../components/home/RecapWall.astro';
import TweetEcho from '../components/home/TweetEcho.astro';
import ModelRetrospective from '../components/home/ModelRetrospective.astro';

// Layer 2.3 — unified TodayHero replaces the competing TomorrowHero + ArtifactMatchup.
import TodayHero from '../components/home/TodayHero.astro';
// TomorrowHero kept for now as a fallback path (pre-2.3 QA only — will be removed post-merge).
import TomorrowHero from '../components/home/TomorrowHero.astro';
import TomorrowSlateStrip from '../components/home/TomorrowSlateStrip.astro';
// PredictionsGrid import removed in Layer 5.7 — predictions inlined into matchup cards.
import ArtifactMatchup from '../components/home/artifacts/ArtifactMatchup.astro';
import ArtifactHot from '../components/home/artifacts/ArtifactHot.astro';
import ArtifactCold from '../components/home/artifacts/ArtifactCold.astro';
import ArtifactMilestone from '../components/home/artifacts/ArtifactMilestone.astro';
import OffseasonHero from '../components/home/OffseasonHero.astro';
import LastPlayedCard from '../components/home/LastPlayedCard.astro';
import SummerStorylines from '../components/home/SummerStorylines.astro';

import liveMockRaw from '../data/home-mock/live.json';
import liveShootoutMockRaw from '../data/home-mock/live.shootout.json';
import liveShootoutLongMockRaw from '../data/home-mock/live.shootout-long.json';
import recapMockRaw from '../data/home-mock/recap.json';
import tomorrowMockRaw from '../data/home-mock/tomorrow.json';
import offseasonMockRaw from '../data/home-mock/offseason.json';
// Layer 1.8: schedule.json drives auto-mode (TODAY/YESTERDAY/OFFSEASON detection).
// Its variants (default/morning/afternoon/evening/night/yesterday/offseason) correspond
// to real-world scoreboard states. The inline detectMode script picks 'today',
// 'yesterday', or 'offseason' based on games[].length + previous_day.games[].length.
import scheduleVariantsRaw from '../data/home-mock/schedule.json';

import { parseLiveMockOrThrow } from '../lib/live-mock-schemas';
import { parseRecapMockOrThrow } from '../lib/recap-mock-schemas';
import {
  parseTomorrowMockOrThrow,
  parseOffseasonMockOrThrow,
  parseScoreboardVariantsOrThrow,
  ScoreboardSchema,
} from '../lib/auto-mode-schemas';
import { pickHero } from '../lib/excitement';
import { HOME_MODES } from '../lib/auto-mode';
// Layer 2.3 — hero selection
import { pickHeroGame, detectSubState } from '../lib/hero-selection';

// Validate all live fixtures at build time.
const liveMock = parseLiveMockOrThrow(liveMockRaw, 'home-mock/live.json');
const liveShootoutMock = parseLiveMockOrThrow(
  liveShootoutMockRaw,
  'home-mock/live.shootout.json',
);
const liveShootoutLongMock = parseLiveMockOrThrow(
  liveShootoutLongMockRaw,
  'home-mock/live.shootout-long.json',
);

// Layer 5 mocks.
const tomorrowMock = parseTomorrowMockOrThrow(
  tomorrowMockRaw,
  'home-mock/tomorrow.json',
);
const offseasonMock = parseOffseasonMockOrThrow(
  offseasonMockRaw,
  'home-mock/offseason.json',
);

// ── Layer 2.0: Build-time fetch from real API ──────────────────────────────
// Fetches /v1/scoreboard at Astro build time to bake real game data into the
// static HTML. CF Pages rebuilds on deployment (or can be triggered via webhook)
// so the baked data is fresh-as-of-last-build.
//
// Fallback: if fetch fails (network issue, API down), falls back to the
// mock schedule so the build never breaks. A data-api-error banner is shown
// to users when running on stale mock data.
const SCOREBOARD_URL = 'https://api.hockeygamebot.com/v1/scoreboard';
const SLATE_URL = 'https://api.hockeygamebot.com/v1/slate';

let realScoreboard: import('../lib/auto-mode-schemas').Scoreboard | null = null;
let realSlate: unknown = null;
let apiFetchError: string | null = null;

try {
  const scoreboardRes = await fetch(SCOREBOARD_URL);
  if (scoreboardRes.ok) {
    const raw = await scoreboardRes.json();
    const parsed = ScoreboardSchema.safeParse(raw);
    if (parsed.success) {
      realScoreboard = parsed.data;
      console.log(`[home-v2] Scoreboard: ${realScoreboard.games.length} game(s) for ${realScoreboard.date}`);
    } else {
      const issueCount = parsed.error.issues.length;
      apiFetchError = `Scoreboard schema validation failed (${issueCount} issue(s)): ${parsed.error.issues[0]?.message}`;
      console.warn('[home-v2] Scoreboard schema validation failed:', parsed.error.issues);
    }
  } else {
    apiFetchError = `Scoreboard fetch failed: HTTP ${scoreboardRes.status}`;
    console.warn('[home-v2]', apiFetchError);
  }
} catch (e) {
  apiFetchError = `Scoreboard fetch threw: ${e instanceof Error ? e.message : String(e)}`;
  console.warn('[home-v2]', apiFetchError);
}

try {
  const slateRes = await fetch(SLATE_URL);
  if (slateRes.ok) {
    realSlate = await slateRes.json();
    console.log('[home-v2] Slate: fetched successfully');
  } else if (slateRes.status === 404) {
    console.log('[home-v2] Slate: 404 — not yet written for today (pre-8 AM ET cron)');
    realSlate = null;
  } else {
    console.warn(`[home-v2] Slate fetch failed: HTTP ${slateRes.status}`);
    realSlate = null;
  }
} catch (e) {
  console.warn('[home-v2] Slate fetch threw:', e);
  realSlate = null;
}
// ─────────────────────────────────────────────────────────────────────────────

// ── Layer 2.1: Extract real API data for component consumption ─────────────
//
// The real slate doc is wrapped: { hockey_date, doc, generated_at, updated_at }
// We extract doc.* fields here and build component-ready data from the join
// of scoreboard + slate. Falls through to mock when API data is absent.

/** Raw slate doc extracted from the API envelope. */
type SlateDoc = {
  hockey_date?: string;
  predictions?: Array<{ game_id: string; home_wp: number; away_wp: number }>;
  matchup_previews?: Array<{
    game_id: string;
    headline: string;
    key_matchup?: { home_player: string; away_player: string; context: string };
    x_factor?: string;
  }>;
  storylines?: Array<{
    type: string;
    player?: string;
    team?: string;
    headline: string;
    context: string;
  }>;
  featured_matchup?: {
    game_id: string;
    tag?: { label: string; kind: string };
    reasoning?: string;
    byline?: { left: string; right: string };
  };
};

const slateDoc: SlateDoc | null = (() => {
  if (!realSlate || typeof realSlate !== 'object') return null;
  const raw = realSlate as Record<string, unknown>;
  // API returns { hockey_date, doc, generated_at, updated_at }
  if (raw.doc && typeof raw.doc === 'object') return raw.doc as SlateDoc;
  // Fallback: maybe already the flat doc
  return raw as SlateDoc;
})();

/** Quick lookup: game_id → ScoreboardGame. */
type ScoreboardGame = import('../lib/auto-mode-schemas').Scoreboard['games'][number];
const gameById = new Map<string, ScoreboardGame>(
  (realScoreboard?.games ?? []).map(g => [g.game_id, g])
);

/**
 * Format a UTC ISO string as "H:MM PM ET" (Eastern Time).
 * Used at build time (Node.js) where Intl.DateTimeFormat works.
 */
function fmtStartTimeET(utc: string | null): string {
  if (!utc) return '';
  try {
    return new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/New_York',
      hour: 'numeric',
      minute: '2-digit',
      hour12: true,
    }).format(new Date(utc)) + ' ET';
  } catch {
    return '';
  }
}

/**
 * Build TomorrowSlateTile array from real scoreboard games, enriched with
 * WP predictions from the slate doc if available.
 */
type SlateTileShape = {
  gameId: string;
  start_time: string;
  series_status?: string;
  home: { abbrev: string; logo?: string };
  away: { abbrev: string; logo?: string };
  home_wp?: number;
  away_wp?: number;
};

function buildSlateTiles(): SlateTileShape[] {
  if (!realScoreboard) return [];
  const predMap = new Map(
    (slateDoc?.predictions ?? []).map(p => [p.game_id, p])
  );
  return realScoreboard.games.map(g => {
    const pred = predMap.get(g.game_id);
    return {
      gameId: g.game_id,
      start_time: fmtStartTimeET(g.start_time_utc),
      home: { abbrev: g.home_team.abbrev },
      away: { abbrev: g.away_team.abbrev },
      ...(pred ? { home_wp: pred.home_wp, away_wp: pred.away_wp } : {}),
    };
  });
}

const realSlateTiles = buildSlateTiles();

/**
 * Build the TODAY pre-state hero data from real scoreboard.
 * Finds the earliest game by start_time_utc.
 */
const firstGame = realScoreboard?.games.length
  ? [...realScoreboard.games].sort((a, b) => {
      const at = a.start_time_utc ? Date.parse(a.start_time_utc) : Infinity;
      const bt = b.start_time_utc ? Date.parse(b.start_time_utc) : Infinity;
      return at - bt;
    })[0]
  : null;

const firstGameUtc = firstGame?.start_time_utc ?? null;
const firstGameLabel = firstGame
  ? `${firstGame.away_team.abbrev} @ ${firstGame.home_team.abbrev} · ${fmtStartTimeET(firstGame.start_time_utc)}`
  : null;

// Today label for the hero eyebrow (e.g. "TODAY · APR 26 · 2026")
const todayApiDateLabel = realScoreboard
  ? (() => {
      const d = new Date(realScoreboard.date + 'T12:00:00Z');
      const month = d.toLocaleString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
      const day = d.getUTCDate();
      const year = d.getUTCFullYear();
      return `TODAY · ${month} ${day} · ${year}`;
    })()
  : tomorrowMock.date_label;

// Game count label for eyebrow
const todayGameCount = realScoreboard ? realScoreboard.games.length : 0;
const todayEyebrowLine = realScoreboard
  ? `Today · ${todayGameCount} game${todayGameCount !== 1 ? 's' : ''} scheduled`
  : tomorrowMock.hero_eyebrow;

/**
 * Build featured matchup card props from slate.featured_matchup + scoreboard.
 * The slate only has game_id + tag + byline + reasoning.
 * We join with scoreboard for team identity and predictions for WP.
 */
function buildFeaturedMatchupProps(): (typeof tomorrowMock.featured_matchup) | null {
  if (!slateDoc?.featured_matchup) return null;
  const fm = slateDoc.featured_matchup;
  const game = gameById.get(fm.game_id);
  if (!game) return null;

  const predMap = new Map(
    (slateDoc?.predictions ?? []).map(p => [p.game_id, p])
  );
  const pred = predMap.get(fm.game_id);
  const timeLabel = fmtStartTimeET(game.start_time_utc);
  const venueUpper = game.venue ? game.venue.toUpperCase() : '';

  // Find matchup preview for this game for key_matchup content
  const preview = slateDoc?.matchup_previews?.find(p => p.game_id === fm.game_id);
  const km = preview?.key_matchup;

  return {
    gameId: fm.game_id,
    tag: fm.tag as { label: string; kind: string } | undefined,
    byline: fm.byline as { left: string; right: string } | undefined,
    eyebrow: `${fm.byline?.right ?? 'GAME OF THE NIGHT'} · ${venueUpper}`,
    home: {
      abbrev: game.home_team.abbrev,
      name: game.home_team.short_name.toUpperCase(),
      record: '',
      accentColor: '#888888',
    },
    away: {
      abbrev: game.away_team.abbrev,
      name: game.away_team.short_name.toUpperCase(),
      record: '',
      accentColor: '#888888',
    },
    timeLabel,
    venue: venueUpper,
    keyMatchupTitle: km ? 'Key matchup · HGB edge' : (preview?.headline ?? 'Key matchup'),
    matchups: km
      ? [
          {
            left: { name: km.home_player, meta: game.home_team.abbrev },
            right: { name: km.away_player, meta: game.away_team.abbrev },
            centerLabel: 'vs',
          },
        ]
      : [
          {
            left: { name: game.home_team.short_name, meta: game.home_team.abbrev },
            right: { name: game.away_team.short_name, meta: game.away_team.abbrev },
            centerLabel: 'vs',
          },
        ],
    ...(pred ? { home_wp: pred.home_wp, away_wp: pred.away_wp } : {}),
  } as typeof tomorrowMock.featured_matchup;
}

const realFeaturedMatchup = buildFeaturedMatchupProps();

// Decide which featured matchup and slate data to use (real or mock fallback)
const activeFeatured = realFeaturedMatchup ?? tomorrowMock.featured_matchup;
const activeSlateTiles = realSlateTiles.length > 0 ? realSlateTiles : tomorrowMock.slate;
const activeGameCount = realScoreboard ? realScoreboard.games.length : tomorrowMock.slate.length;
// ─────────────────────────────────────────────────────────────────────────────

// ── Layer 2.3: TodayHero selection — unified hero game + sub-state ─────────
//
// pickHeroGame() selects the hero game based on TODAY sub-state:
//   PRE  → next chronological game
//   LIVE → highest excitement-scored live game (with stickiness)
//   FINAL → highest narrative-scored finished game
//
// The result is rendered once at build time (SSR bake-in). After page load,
// the hydration loop re-runs this logic client-side and swaps the hero block
// when the selected game changes.

// Detect TODAY sub-state from real scoreboard data.
const todaySubState = realScoreboard?.games.length
  ? detectSubState(realScoreboard.games)
  : 'pre';

// Pick hero game (null when no real scoreboard data).
const heroPick23 = realScoreboard
  ? pickHeroGame(realScoreboard, slateDoc, null)
  : null;

// Build TodayHero props from the picked game + slate.
function buildTodayHeroProps() {
  if (!heroPick23) return null;
  const g = heroPick23.game;
  const fm = slateDoc?.featured_matchup;
  const preview = slateDoc?.matchup_previews?.find(p => p.game_id === g.game_id);
  const predMap = new Map((slateDoc?.predictions ?? []).map(p => [p.game_id, p]));
  const pred = predMap.get(g.game_id);

  return {
    heroGame: g,
    subState: heroPick23.subState,
    isFeaturedMatchup: heroPick23.isFeaturedMatchup,
    slateMatchup: preview
      ? {
          headline: preview.headline,
          key_matchup: preview.key_matchup,
          x_factor: preview.x_factor,
          reasoning: fm?.reasoning,
        }
      : null,
    prediction: pred ? { home_wp: pred.home_wp, away_wp: pred.away_wp } : null,
    countdownUtc: heroPick23.subState === 'pre' ? (g.start_time_utc ?? null) : null,
  };
}
const todayHeroProps = buildTodayHeroProps();

// Game of the Night ID for slate strip star badge.
const featuredMatchupId = slateDoc?.featured_matchup?.game_id ?? undefined;
// ─────────────────────────────────────────────────────────────────────────────
// Build the scheduleVariants object used by the inline detectMode script.
// When real API data is available, the `default` variant is replaced with
// live data so the mode resolver reflects actual game states (pre/live/final).
// All other variant keys (morning/afternoon/evening/night/yesterday/offseason)
// remain as mock data for QA testing via ?schedule= param.
const scheduleVariantsMockBase = parseScoreboardVariantsOrThrow(
  scheduleVariantsRaw,
  'home-mock/schedule.json',
);
const scheduleVariants = realScoreboard
  ? { ...scheduleVariantsMockBase, default: realScoreboard }
  : scheduleVariantsMockBase;

// ── Hero selection (existing live-mode logic — unchanged) ──────────────────
const PRIOR_HERO_ID = '2026030124'; // BOS @ BUF
type GridGame = (typeof liveMock.games extends infer T
  ? T extends Array<infer U>
    ? U
    : never
  : never);
function gridToExcitement(g: GridGame) {
  const status =
    g.state === 'live' || g.state === 'intermission'
      ? 'live'
      : g.state === 'final' || g.state === 'ot'
      ? 'final'
      : 'scheduled';
  return {
    id: g.id,
    status,
    period: g.period,
    time_remaining: g.clock,
    home_team: { score: g.home.score ?? 0 },
    away_team: { score: g.away.score ?? 0 },
  };
}
const heroPick = liveMock.games
  ? pickHero(liveMock.games.map(gridToExcitement), { currentHeroId: PRIOR_HERO_ID })
  : null;
const featured = liveMock.featured_game;
const heroPickedId = heroPick?.id ?? null;
const heroIsStickyChosen = heroPickedId === featured.id;

const heroIdToExclude = heroPickedId ?? featured.id;
const subgridGames = (liveMock.games ?? []).filter(g => g.id !== heroIdToExclude);

const featuredSO = liveShootoutMock.featured_game;
const subgridSO = (liveShootoutMock.games ?? []).filter(
  g => g.id !== featuredSO.id,
);
const featuredSOLong = liveShootoutLongMock.featured_game;
const subgridSOLong = (liveShootoutLongMock.games ?? []).filter(
  g => g.id !== featuredSOLong.id,
);

const playoffStrip = liveMock.playoff_strip;
const playoffStripSO = liveShootoutMock.playoff_strip;
const playoffStripSOLong = liveShootoutLongMock.playoff_strip;
const recapMock = parseRecapMockOrThrow(recapMockRaw, 'home-mock/recap.json');
const recapPlayoffStrip = recapMock.playoff_strip;
const tomorrowPlayoffStrip = tomorrowMock.playoff_strip;
// Layer 1.8: TODAY mode has sub-states — live/pre/final sub-states reuse the
// existing live + tomorrow eyebrows. YESTERDAY mode reuses the recap eyebrow.
const liveEyebrow = liveMock.hero_eyebrow;
const liveEyebrowSO = liveShootoutMock.hero_eyebrow;
const liveEyebrowSOLong = liveShootoutLongMock.hero_eyebrow;
const recapEyebrow = recapMock.hero_eyebrow;           // used for YESTERDAY mode
const tomorrowEyebrow = tomorrowMock.hero_eyebrow;     // used for TODAY pre sub-state
const offseasonEyebrow = offseasonMock.hero_eyebrow;
// Date labels — today/yesterday/offseason map to their respective mock sources.
const todayDate = liveMock.date_label;    // live mock == "tonight" date label
const yesterdayDate = recapMock.date_label;
const tomorrowDate = todayApiDateLabel;                 // TODAY pre sub-state label (real or mock)
const offseasonDate = offseasonMock.date_label;

// ── Recap-mode body data (existing logic — unchanged) ───────────────────
const recapWall = recapMock.wall;
const recapCounts = {
  all: recapWall.length,
  games: recapWall.filter(c => c.slug === 'game').length,
  hot: recapWall.filter(c => c.slug === 'hot').length,
  cold: recapWall.filter(c => c.slug === 'cold').length,
  milestones:
    recapWall.filter(c => c.slug === 'milestone').length +
    recapWall.filter(c => c.slug === 'hattrick').length,
  lines: recapWall.filter(c => c.slug === 'line').length,
  clinches: recapWall.filter(c => c.slug === 'clinch').length,
  stars:
    recapWall.filter(c => c.slug === 'stars').length +
    recapWall.filter(c => c.slug === 'goalie').length,
};

function countByState(games: typeof liveMock.games | undefined): {
  total: number;
  live: number;
  final: number;
  pre: number;
} {
  const list = games ?? [];
  return {
    total: list.length,
    live: list.filter(g => g.state === 'live' || g.state === 'intermission').length,
    final: list.filter(g => g.state === 'final' || g.state === 'ot').length,
    pre: list.filter(g => g.state === 'pre').length,
  };
}
const grid = countByState(liveMock.games);
const gridSO = countByState(liveShootoutMock.games);
const gridSOLong = countByState(liveShootoutLongMock.games);

const artifactsCount = (liveMock.live_moments ?? []).length;

// Hero copy variants — eyebrow + h1 + sub vary by mode/sub-state.
const offseasonHeroCopy = {
  eyebrow: offseasonMock.hero_eyebrow,
  title: 'Hockey returns Oct 8.',
  sub: "Until then — countdown, last season's wrap, and the moves shaping next year.",
};
// TODAY pre sub-state (was "tomorrow mode")
// Layer 2.1: use real game count + "Today" copy when scoreboard data is live.
const todayPreHeroCopy = {
  eyebrow: todayEyebrowLine,
  title: 'Today, picked apart.',
  sub: "Predictions, key matchups, milestone watches and the storylines we're tracking — refreshed at 8 AM ET.",
};

// TODAY live/final sub-state hero copy — real eyebrow from scoreboard.
// Layer 2.4: replaces the mock liveEyebrow for live/final sub-states.
const liveGameCount = realScoreboard
  ? realScoreboard.games.filter(g => ['live', 'intermission', 'shootout'].includes(g.game_state)).length
  : 0;
const todayLiveHeroCopy = {
  eyebrow: realScoreboard
    ? liveGameCount > 0
      ? `Live Now · ${liveGameCount} game${liveGameCount !== 1 ? 's' : ''} in progress · ${todayGameCount} total`
      : `Final · ${todayGameCount} game${todayGameCount !== 1 ? 's' : ''} today`
    : liveEyebrow,
  title: 'Today, picked apart.',
  sub: "Real-time scores with shots on goal, expected goals (xG) and win probability — updated on every poll.",
};

/**
 * Layer 2.4: Build GameTile props from a ScoreboardGame.
 * Maps the rich scoreboard shape to the compact GameTile interface.
 */
function buildGameTileProps(g: ScoreboardGame) {
  const gs = g.game_state;
  const isLive = gs === 'live' || gs === 'intermission' || gs === 'shootout';
  const isFinal = gs === 'final';
  const state: 'live' | 'final' | 'ot' | 'pre' | 'intermission' =
    gs === 'intermission' ? 'intermission'
    : gs === 'shootout' ? 'live'
    : gs === 'final' ? 'final'
    : gs === 'live' ? 'live'
    : 'pre';

  const homeScore = g.home_team.score ?? 0;
  const awayScore = g.away_team.score ?? 0;
  const period = g.clock.period ?? undefined;
  const timeRemaining = g.clock.time_remaining ?? undefined;

  const xgBar = (isLive || isFinal) && (g.stats.xg_5v5.home !== null || g.stats.xg_5v5.away !== null)
    ? { home: g.stats.xg_5v5.home ?? 0, away: g.stats.xg_5v5.away ?? 0, label: '5v5 xG' }
    : (gs === 'pre' && (g.stats.win_probability.home !== null || g.stats.win_probability.away !== null))
    ? { home: g.stats.win_probability.home ?? 0.5, away: g.stats.win_probability.away ?? 0.5, label: 'Win%' }
    : undefined;

  const chips = [];
  if (g.strength_state && g.strength_state !== '5v5' && g.strength_state !== 'unknown' && isLive) {
    chips.push({ label: g.strength_state.toUpperCase(), kind: 'pp' });
  }

  return {
    gameId: g.game_id,
    state,
    period,
    clock: timeRemaining ?? undefined,
    startTime: fmtStartTimeET(g.start_time_utc),
    home: {
      abbrev: g.home_team.abbrev,
      score: (isLive || isFinal) ? g.home_team.score : null,
      sog: g.stats.shots_on_goal.home ?? undefined,
      xg_5v5: g.stats.xg_5v5.home ?? undefined,
      record: '',
    },
    away: {
      abbrev: g.away_team.abbrev,
      score: (isLive || isFinal) ? g.away_team.score : null,
      sog: g.stats.shots_on_goal.away ?? undefined,
      xg_5v5: g.stats.xg_5v5.away ?? undefined,
      record: '',
    },
    chips,
    xgBar,
    footNote: g.venue ?? undefined,
  };
}

// Real game tiles for live/final grid — all today's games from scoreboard.
const realGameTiles = realScoreboard?.games.map(buildGameTileProps) ?? [];

// Inline data the head + body scripts need. Serialised as JSON-strings
// inside the <html> so the auto-mode resolver can run before first paint
// without an extra fetch.
const scheduleVariantsJson = JSON.stringify(scheduleVariants);
const homeModesJson = JSON.stringify(HOME_MODES);
// Layer 2.0: real slate doc (null when not yet written — pre-8 AM ET cron).
// Serialised for inline access by the body script if needed.
const realSlateJson = realSlate ? JSON.stringify(realSlate) : 'null';
const apiDataSourceJson = JSON.stringify({
  scoreboard: realScoreboard ? 'live' : 'mock',
  slate: realSlate ? 'live' : 'none',
  scoreboard_date: realScoreboard?.date ?? null,
  fetch_error: apiFetchError,
});
// Layer 2.2: build-time scoreboard + slate serialised for hydration bootstrap.
// The client-side hydration loop reads this as the initial state, then polls
// for updates. Embedding at build time avoids a blank-flash on first load.
const initScoreboardJson = realScoreboard ? JSON.stringify(realScoreboard) : 'null';
const initSlateJson = slateDoc ? JSON.stringify(slateDoc) : 'null';
---
<!DOCTYPE html>
<html lang="en" data-home-mode="today" data-fixture="default" data-today-substate="live">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="dark">
  <meta name="robots" content="noindex,nofollow">
  <title>HockeyGameBot — Home (v2 preview)</title>
  <meta name="description" content="Rebuild preview of the HockeyGameBot home page. Not linked from the production scoreboard.">

  <!--
    Mode swap (Layer 1.8 — collapsed from 4 to 3 modes):

    Resolution order (matches src/lib/auto-mode.ts/resolveMode):
      1. sessionStorage[hgb-mode-override] — sticky in-tab manual choice
      2. ?mode=<mode>                      — direct-link / share URL
      3. detectMode(schedule)              — auto fallback (today|yesterday|offseason)

    The schedule snapshot the resolver uses can be swapped via
    `?schedule=morning|afternoon|evening|night|yesterday|offseason` — falls back
    to `default` when absent or unknown.

    New: for TODAY mode, data-today-substate is also stamped based on
    the distribution of game_state values in games[]. The TODAY sections
    in the body use [data-today-substate] CSS rules to show the right
    sub-view (live | pre | final).

    All mode body sections render at build time; CSS rules below
    show the active one only.
  -->
  <script is:inline define:vars={{ scheduleVariantsJson, homeModesJson, apiDataSourceJson }}>
    (function () {
      try {
        var modes = JSON.parse(homeModesJson);
        var variants = JSON.parse(scheduleVariantsJson);

        var params = new URLSearchParams(window.location.search);
        var schedKey = params.get('schedule') || 'default';
        var schedule = variants[schedKey] || variants.default;

        // Inline detectMode — keep in sync with src/lib/auto-mode.ts.
        // Layer 1.8: 3-rule collapse. `now` is no longer needed.
        function detectMode(sched) {
          var games = (sched && sched.games) || [];
          var prevGames = (sched && sched.previous_day && sched.previous_day.games) || [];
          if (games.length > 0) return 'today';
          if (prevGames.length > 0) return 'yesterday';
          return 'offseason';
        }

        // Compute TODAY sub-state for CSS gating of sub-views within today mode.
        // live  — any game in {live, intermission, shootout} → live sub-state
        // pre   — all games pre                             → pre sub-state
        // final — all games final                           → final sub-state
        // mixed — some live, some final, some pre           → live treatment
        function detectTodaySubstate(sched) {
          var games = (sched && sched.games) || [];
          if (games.length === 0) return 'live'; // fallback — won't be shown
          var liveLike = ['live', 'intermission', 'shootout'];
          var hasLive = games.some(function (g) { return liveLike.indexOf(g.game_state) !== -1; });
          if (hasLive) return 'live';
          var allFinal = games.every(function (g) { return g.game_state === 'final'; });
          if (allFinal) return 'final';
          var allPre = games.every(function (g) { return g.game_state === 'pre'; });
          if (allPre) return 'pre';
          return 'live'; // mixed → live treatment
        }

        // 1. sessionStorage override
        var override = null;
        try { override = window.sessionStorage.getItem('hgb-mode-override'); } catch (e) {}

        var mode, source;
        if (override && modes.indexOf(override) !== -1) {
          mode = override;
          source = 'override';
        } else {
          // 2. URL param
          var raw = params.get('mode');
          if (raw && modes.indexOf(raw) !== -1) {
            mode = raw;
            source = 'url';
          } else {
            // 3. Auto-detect
            mode = detectMode(schedule);
            source = 'auto';
          }
        }

        document.documentElement.setAttribute('data-home-mode', mode);
        document.documentElement.setAttribute('data-mode-source', source);
        document.documentElement.setAttribute('data-schedule-variant', schedKey);

        // Layer 2.0: stamp API data source info for debugging + analytics.
        try {
          var apiSource = JSON.parse(apiDataSourceJson);
          document.documentElement.setAttribute('data-api-scoreboard', apiSource.scoreboard || 'unknown');
          document.documentElement.setAttribute('data-api-slate', apiSource.slate || 'none');
          if (apiSource.scoreboard_date) {
            document.documentElement.setAttribute('data-api-date', apiSource.scoreboard_date);
          }
        } catch (e) { /* non-fatal */ }

        // TODAY sub-state stamp (only meaningful when mode === 'today').
        var todaySubstate = detectTodaySubstate(schedule);
        document.documentElement.setAttribute('data-today-substate', todaySubstate);

        // Fixture variant — unchanged from Layer 3.
        var fixture = params.get('fixture');
        var resolvedFixture =
          fixture === 'shootout'      ? 'shootout'
          : fixture === 'shootout-long' ? 'shootout-long'
          : fixture === 'empty'       ? 'empty'
          : 'default';
        document.documentElement.setAttribute('data-fixture', resolvedFixture);
        if (resolvedFixture === 'empty') {
          document.documentElement.setAttribute('data-strip-empty', '1');
        }
      } catch (e) {
        document.documentElement.setAttribute('data-home-mode', 'today');
        document.documentElement.setAttribute('data-mode-source', 'auto');
        document.documentElement.setAttribute('data-fixture', 'default');
        document.documentElement.setAttribute('data-today-substate', 'live');
      }
    })();
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    body {
      background: var(--site-bg);
      color: var(--site-text);
      font-family: var(--font-site-body);
    }
    a { color: inherit; }
    img { display: block; max-width: 100%; }

    /* ── Page shell ─────────────────────────────────────────────── */
    .home-page {
      padding: 22px 20px 80px;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* ── Mode-gated views ───────────────────────────────────────── */
    /*
      Layer 1.8: 3 top-level modes (today/yesterday/offseason). Each
      [data-mode-view] block renders at build time and is hidden via CSS
      when the active mode doesn't match. This keeps SSR clean and avoids
      hydration flicker.

      TODAY mode further gates sub-views via [data-today-substate] on <html>:
        live  — games in-progress or mixed states
        pre   — all games pre-game (slate written)
        final — all games final
    */
    html[data-home-mode="today"]     [data-mode-view]:not([data-mode-view~="today"])     { display: none; }
    html[data-home-mode="yesterday"] [data-mode-view]:not([data-mode-view~="yesterday"]) { display: none; }
    html[data-home-mode="offseason"] [data-mode-view]:not([data-mode-view~="offseason"]) { display: none; }

    /* TODAY sub-state gating — within today mode, show only the matching sub-view */
    html[data-home-mode="today"][data-today-substate="live"]  [data-today-view]:not([data-today-view~="live"])  { display: none; }
    html[data-home-mode="today"][data-today-substate="pre"]   [data-today-view]:not([data-today-view~="pre"])   { display: none; }
    html[data-home-mode="today"][data-today-substate="final"] [data-today-view]:not([data-today-view~="final"]) { display: none; }

    /* Playoff strip is hidden in offseason mode — handled via the same
       per-mode rules (the strip lives inside [data-mode-view] containers). */

    /* ── Fixture-gated views (default vs shootout vs shootout-long) ──── */
    html[data-fixture="default"] [data-fixture-view="shootout"],
    html[data-fixture="default"] [data-fixture-view="shootout-long"] { display: none; }
    html[data-fixture="shootout"] [data-fixture-view="default"],
    html[data-fixture="shootout"] [data-fixture-view="shootout-long"] { display: none; }
    html[data-fixture="shootout-long"] [data-fixture-view="default"],
    html[data-fixture="shootout-long"] [data-fixture-view="shootout"] { display: none; }
    html[data-fixture="empty"] [data-fixture-view="shootout"],
    html[data-fixture="empty"] [data-fixture-view="shootout-long"] { display: none; }
    html[data-strip-empty="1"] .live-moment-strip { display: none; }

    /* ── Section headers (mirrors design's .sec-h pattern) ───────
       Margin-top bumped 36→44 (Layer 5.5 polish) so MATCHUP PREVIEWS
       has more breathing room from the slate strip above and STORYLINES
       TO WATCH separates cleanly from the model projections grid. */
    .home-sec-h {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin: 44px 0 12px;
    }
    .home-sec-h h2 {
      font-family: var(--font-site-display);
      font-weight: 700;
      font-size: 22px;
      color: var(--site-white);
      margin: 0;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .home-sec-h .count {
      color: var(--site-muted);
      font-family: var(--font-site-body);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 600;
    }

    /* ── 3×2×1 grid (live mode) ─────────────────────────────────── */
    .home-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    @media (max-width: 1024px) {
      .home-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .home-grid { grid-template-columns: 1fr; }
    }

    /* Tomorrow + Offseason wall grids reuse the same chrome but break
       at narrower thresholds — matchup wall is denser, storylines wider.
       margin-bottom adds explicit symmetric spacing before the next
       .home-sec-h so MATCHUP PREVIEWS → MODEL PROJECTIONS doesn't crowd. */
    .home-wall {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 8px;
    }
    @media (max-width: 900px) { .home-wall { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .home-wall { grid-template-columns: 1fr; } }

    /* ── Recap-mode placeholder (Layer 4) ───────────────────────── */
    .hv2-placeholder {
      border: 1px dashed var(--site-border2);
      border-radius: var(--radius-md);
      min-height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--site-muted);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: center;
      padding: 20px;
      background: repeating-linear-gradient(
        135deg,
        transparent,
        transparent 10px,
        rgba(255, 255, 255, 0.01) 10px,
        rgba(255, 255, 255, 0.01) 20px
      );
    }

    .hv2-placeholder.tall { min-height: 320px; }

    @media (max-width: 720px) {
      .home-page { padding: 16px 12px 60px; }
    }

    /* ── Layer 5.7 model attribution ────────────────────────────── */
    .model-attribution {
      font-family: var(--font-mono);
      font-size: 9.5px;
      color: #3a3a3a;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-align: center;
      margin: 14px 0 0;
      padding-top: 12px;
      border-top: 1px dashed #1a1a1a;
    }

    /* ── Layer 2.1 — slate storyline card (real API shape) ───────── */
    /*
     * Renders the real slate.storylines[] which have a flat shape
     * {type, player/team, headline, context} — not the rich structured
     * data that ArtifactHot/Cold/Milestone need. This simpler card
     * presents the same content legibly until the bot populates the
     * full artifact-compatible structure.
     */
    .slate-storyline-card {
      background: #0b0b0b;
      border: 1px solid var(--site-border);
      padding: 22px 22px 26px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      min-height: 200px;
    }
    .ssc-type-badge {
      font-family: var(--font-site-display);
      font-weight: 700;
      font-size: 9.5px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 1px;
      display: inline-block;
      width: fit-content;
    }
    .ssc-type--mile {
      background: #ffd54a;
      color: #2b1f00;
    }
    .ssc-type--hot {
      background: #00e676;
      color: #041d0f;
    }
    .ssc-who {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #888;
      margin-top: 4px;
    }
    .ssc-headline {
      font-family: var(--font-site-display);
      font-weight: 700;
      font-size: 18px;
      color: var(--site-white);
      letter-spacing: 0.02em;
      line-height: 1.2;
      margin: 0;
    }
    .ssc-context {
      font-family: var(--font-site-body);
      font-size: 12.5px;
      color: #888;
      line-height: 1.5;
      margin: 0;
    }
  </style>
</head>
<body class="hgb-site">
  <Topbar active="scores" dateLabel={todayDate} />

  <!--
    Layer 2.0: API data status banner.
    Shown only when build-time fetch failed and we fell back to mock data.
    Hidden when real API data rendered successfully (apiFetchError === null).
  -->
  {apiFetchError && (
    <div style="background:#1a0a0a;border-bottom:1px solid #8b1a1a;padding:8px 20px;font-family:var(--font-mono,monospace);font-size:11px;color:#e07070;letter-spacing:0.12em;text-transform:uppercase;">
      Data temporarily unavailable — showing preview data. ({apiFetchError})
    </div>
  )}
  {!apiFetchError && realScoreboard && (
    <div
      id="hgb-live-banner"
      style="background:#0a1a0a;border-bottom:1px solid #1a4a1a;padding:6px 20px;font-family:var(--font-mono,monospace);font-size:10px;color:#4a9a4a;letter-spacing:0.12em;text-transform:uppercase;display:flex;justify-content:space-between;align-items:center;"
    >
      <span>Live data — {realScoreboard.games.length} game{realScoreboard.games.length !== 1 ? 's' : ''} · {realScoreboard.date}</span>
      <span style="display:flex;gap:12px;align-items:center;">
        {realSlate && <span>Slate: ready</span>}
        {!realSlate && <span style="color:#6a6a4a;">Slate: pending (pre-8 AM ET)</span>}
        {/* Layer 2.2: hydration last-updated indicator (ticked by client-side script) */}
        <span id="hgb-hydration-stamp" style="color:#2a5a2a;" title="Client-side poll cadence: scoreboard 60s / slate 5min">
          Hydration: starting…
        </span>
      </span>
    </div>
  )}

  <!--
    Playoff strip — Layer 2.1: TODAY mode strips removed entirely.
    No real /v1/series-state endpoint exists yet; showing mock series data
    alongside real scoreboard games would be confusing. Re-add when
    a real series-state source is available.
    YESTERDAY mode keeps its recap strip (mock data for that mode is fine).
  -->
  {recapPlayoffStrip && (
    <div data-mode-view="yesterday">
      <PlayoffStrip eyebrow={recapPlayoffStrip.eyebrow} series={recapPlayoffStrip.series} />
    </div>
  )}

  <main class="home-page">
    <!--
      PageHero — eyebrow + h1 + sub vary by mode/sub-state.

      Layer 1.8:
        - TODAY mode live/final sub-states use the live eyebrow (fixtures)
        - TODAY mode pre sub-state uses todayPreHeroCopy (was "tomorrow")
        - YESTERDAY mode uses the recap eyebrow
        - OFFSEASON uses its own copy
    -->
    {/* Layer 2.4: live/final sub-states — real eyebrow + "Today, picked apart." title */}
    <div data-mode-view="today" data-today-view="live final">
      <PageHero
        eyebrow={todayLiveHeroCopy.eyebrow}
        title={todayLiveHeroCopy.title}
        sub={todayLiveHeroCopy.sub}
      />
    </div>
    <div data-mode-view="today" data-today-view="pre">
      <PageHero
        eyebrow={todayPreHeroCopy.eyebrow}
        title={todayPreHeroCopy.title}
        sub={todayPreHeroCopy.sub}
      />
    </div>
    <div data-mode-view="yesterday">
      <PageHero eyebrow={recapEyebrow} />
    </div>
    <div data-mode-view="offseason">
      <PageHero
        eyebrow={offseasonHeroCopy.eyebrow}
        title={offseasonHeroCopy.title}
        sub={offseasonHeroCopy.sub}
      />
    </div>

    <!--
      ModeBar — Astro renders it once with `mode="today"` because the
      page is statically built. The page script below patches the active
      pill + telemetry source stamp after resolveMode() runs. This
      avoids needing 3 ModeBar SSR copies.
    -->
    <ModeBar mode="today" artifactsCount={artifactsCount} />

    <!--
      Layer 2.4: Unified TodayHero mount — shown in TODAY mode for ALL sub-states.
      A single #today-hero-mount div ensures the hydration loop always has one
      clean target regardless of which sub-state (live/pre/final) is active.
      The hero content adapts to the sub-state via TodayHero's internal logic.
    -->
    <div data-mode-view="today" id="today-hero-mount">
      {todayHeroProps ? (
        <TodayHero
          heroGame={todayHeroProps.heroGame}
          subState={todayHeroProps.subState}
          isFeaturedMatchup={todayHeroProps.isFeaturedMatchup}
          slateMatchup={todayHeroProps.slateMatchup}
          prediction={todayHeroProps.prediction}
          countdownUtc={todayHeroProps.countdownUtc}
        />
      ) : (
        <div class="hv2-placeholder" style="min-height:280px">
          <span>Loading game data…</span>
        </div>
      )}
    </div>

    <!-- ════════════════════════════════════════════════════════════════
         TODAY MODE — LIVE + FINAL sub-states: real games grid
         Layer 2.4: mock-driven LiveHero + LiveMomentStrip + GameTile
         sections removed. Now uses real games from /v1/scoreboard.
    ════════════════════════════════════════════════════════════════ -->
    <section
      data-mode-view="today"
      data-today-view="live final"
      aria-label="Today's games — live/final view"
    >
      {/* Real games grid — all today's games from /v1/scoreboard */}
      {realGameTiles.length > 0 ? (
        <>
          <div class="home-sec-h">
            <h2>Today's Games</h2>
            <span class="count">
              {realGameTiles.length} game{realGameTiles.length !== 1 ? 's' : ''} ·{' '}
              {realGameTiles.filter(t => t.state === 'live' || t.state === 'intermission').length} live ·{' '}
              {realGameTiles.filter(t => t.state === 'final').length} final ·{' '}
              {realGameTiles.filter(t => t.state === 'pre').length} upcoming
            </span>
          </div>
          <div class="home-grid">
            {realGameTiles.map(props => (
              <GameTile {...props} />
            ))}
          </div>
        </>
      ) : (
        <div class="hv2-placeholder" style="margin-top:24px">
          <span>No game data available</span>
        </div>
      )}
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         YESTERDAY MODE (was RECAP) — Layer 1.8
         Same components, now wired to data-mode-view="yesterday"
    ════════════════════════════════════════════════════════════════ -->
    <section data-mode-view="yesterday" aria-label="Yesterday's recap view">
      <RecapHero
        game={recapMock.game_of_night}
        supporting={recapMock.supporting_hero ?? null}
      />

      {recapMock.final_scores && recapMock.final_scores.length > 0 && (
        <RecapScoreStrip tiles={recapMock.final_scores} />
      )}

      <RecapFilterBar
        target=".recap-wall"
        initial="all"
        initialSort="impact"
        counts={recapCounts}
      />

      <RecapWall cards={recapMock.wall} defaultSort="impact" />

      <TweetEcho tweets={recapMock.tweet_echo} />

      {recapMock.model_retrospective && (
        <ModelRetrospective
          last_night={recapMock.model_retrospective.last_night}
          season={recapMock.model_retrospective.season}
        />
      )}
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         TODAY MODE — PRE sub-state (was TOMORROW MODE, Layer 5 / Layer 5.9)
         Shown when all games are pre-game and slate doc is available.
         Section order:
           1. TodayHero (unified)   — Layer 2.3: countdown LEFT + matchup RIGHT
                                     (replaces TomorrowHero + separate ArtifactMatchup hero)
           2. TomorrowSlateStrip    — all scheduled games, chip WP + ★ GOTN badge
           3. Matchup previews wall — chip WP
           4. Model attribution footer
           5. Storylines wall       — Hot/Cold/Milestone "could fire tonight"
         Layer 1.8: mode-view="today" + today-view="pre"
    ════════════════════════════════════════════════════════════════ -->
    <section data-mode-view="today" data-today-view="pre" aria-label="Today's games — pre-game slate view">
      {/*
        Layer 2.4: TodayHero is rendered in the shared #today-hero-mount above
        (visible across all TODAY sub-states). The PRE section provides the
        slate strip, matchup previews, and storylines wall below the hero.
        TomorrowHero is kept as fallback when no real scoreboard data
        (pre-8AM ET before first API fetch builds scoreboard).
      */}
      {!todayHeroProps && (
        <TomorrowHero
          date_label={todayApiDateLabel}
          featured={activeFeatured}
          firstGameUtc={firstGameUtc}
          firstGameLabel={firstGameLabel}
        />
      )}

      {/*
        Layer 2.3: Slate strip now receives featuredMatchupId for ★ star badge.
        Layer 2.1: also uses real scoreboard games + slate WP predictions.
        heading prop overrides the default "Tomorrow's slate · N games" label.
      */}
      <TomorrowSlateStrip
        tiles={activeSlateTiles}
        heading={`Today's slate · ${activeGameCount} game${activeGameCount !== 1 ? 's' : ''}`}
        featuredMatchupId={featuredMatchupId}
      />

      {/*
        Layer 2.1: Matchup previews — use real slate.matchup_previews when
        available. Real shape is {game_id, headline, key_matchup, x_factor}
        which differs from the full ArtifactMatchup props the mock used.
        We build ArtifactMatchup-compatible props via joinRealMatchupPreviews().
      */}
      {slateDoc?.matchup_previews && slateDoc.matchup_previews.length > 0 ? (
        <>
          <div class="home-sec-h">
            <h2>Matchup previews</h2>
            <span class="count">{slateDoc.matchup_previews.length} games highlighted</span>
          </div>
          <div class="home-wall">
            {slateDoc.matchup_previews.map((preview) => {
              const game = gameById.get(preview.game_id);
              if (!game) return null;
              const predMap = new Map((slateDoc?.predictions ?? []).map(p => [p.game_id, p]));
              const pred = predMap.get(preview.game_id);
              const km = preview.key_matchup;
              const timeLabel = fmtStartTimeET(game.start_time_utc);
              const venueUpper = game.venue ? game.venue.toUpperCase() : '';
              const matchupProps = {
                gameId: preview.game_id,
                eyebrow: `${game.away_team.abbrev} @ ${game.home_team.abbrev} · ${timeLabel}`,
                home: { abbrev: game.home_team.abbrev, name: game.home_team.short_name.toUpperCase(), record: '', accentColor: '#888888' },
                away: { abbrev: game.away_team.abbrev, name: game.away_team.short_name.toUpperCase(), record: '', accentColor: '#888888' },
                timeLabel,
                venue: venueUpper,
                keyMatchupTitle: km ? 'Key matchup · HGB edge' : preview.headline,
                matchups: km
                  ? [{ left: { name: km.home_player, meta: game.home_team.abbrev }, right: { name: km.away_player, meta: game.away_team.abbrev }, centerLabel: 'vs' }]
                  : [{ left: { name: game.home_team.short_name, meta: '' }, right: { name: game.away_team.short_name, meta: '' }, centerLabel: 'vs' }],
                ...(pred ? { home_wp: pred.home_wp, away_wp: pred.away_wp } : {}),
                variant: 'chip' as const,
              };
              return <ArtifactMatchup {...matchupProps} />;
            })}
          </div>
          <p class="model-attribution">MODEL · BLENDED ELO + XG · UPDATED 8 AM ET</p>
        </>
      ) : tomorrowMock.matchup_previews.length > 0 ? (
        <>
          <div class="home-sec-h">
            <h2>Matchup previews</h2>
            <span class="count">{tomorrowMock.matchup_previews.length} games highlighted</span>
          </div>
          <div class="home-wall">
            {tomorrowMock.matchup_previews.map((m) => (
              <ArtifactMatchup {...m} variant="chip" />
            ))}
          </div>
          <p class="model-attribution">MODEL · BLENDED ELO + XG · UPDATED 8 AM ET</p>
        </>
      ) : null}

      {/*
        Layer 2.1: Storylines — use real slate.storylines when available.
        Real shape is {type, player/team, headline, context} — a flat narrative
        format. Render via inline SlateStorylineCard style rather than the
        full ArtifactHot/Cold/Milestone (which require rich structured data
        the bot doesn't yet populate for the storylines array).
        Falls back to mock when real data is absent.
      */}
      {slateDoc?.storylines && slateDoc.storylines.length > 0 ? (
        <>
          <div class="home-sec-h">
            <h2>Storylines to watch</h2>
            <span class="count">{slateDoc.storylines.length} to watch tonight</span>
          </div>
          <div class="home-wall">
            {slateDoc.storylines.map((s) => (
              <article class="slate-storyline-card">
                <span class:list={[
                  'ssc-type-badge',
                  s.type === 'milestone-watch' ? 'ssc-type--mile' : 'ssc-type--hot',
                ]}>
                  {s.type === 'milestone-watch' ? '⌛ MILESTONE WATCH'
                    : s.type === 'hot-streak' ? '🔥 HOT STREAK'
                    : s.type === 'x-factor' ? '★ X-FACTOR'
                    : s.type.toUpperCase()}
                </span>
                <div class="ssc-who">
                  {s.player ?? s.team ?? ''}
                </div>
                <h3 class="ssc-headline">{s.headline}</h3>
                <p class="ssc-context">{s.context}</p>
              </article>
            ))}
          </div>
        </>
      ) : tomorrowMock.storylines.length > 0 ? (
        <>
          <div class="home-sec-h">
            <h2>Storylines to watch</h2>
            <span class="count">{tomorrowMock.storylines.length} could fire tonight</span>
          </div>
          <div class="home-wall">
            {tomorrowMock.storylines.map((s) => {
              if (s.kind === 'hot') return <ArtifactHot {...s.data} />;
              if (s.kind === 'cold') return <ArtifactCold {...s.data} />;
              if (s.kind === 'milestone') return <ArtifactMilestone {...s.data} />;
              return null;
            })}
          </div>
        </>
      ) : null}
    </section>

    <!-- ════════════════════════════════════════════════════════════════
         OFFSEASON MODE (Layer 5 — basic V1)
         Section order:
           1. OffseasonHero       — countdown + camp/opening dates
           2. LastPlayedCard      — memorial wrap of ArtifactGame
           3. SummerStorylines    — placeholder card grid
           4. "We'll be back" footnote
    ════════════════════════════════════════════════════════════════ -->
    <section data-mode-view="offseason" aria-label="Offseason view">
      <OffseasonHero
        eyebrow={offseasonMock.hero_eyebrow}
        countdown={offseasonMock.countdown}
      />

      <LastPlayedCard
        memorial_eyebrow={offseasonMock.last_played.memorial_eyebrow}
        game_data={offseasonMock.last_played.game_data}
        kind={offseasonMock.last_played.kind}
      />

      <SummerStorylines storylines={offseasonMock.summer_storylines} />

      <footer class="oh-footer">
        <span class="oh-footer-tick" aria-hidden="true">▍</span>
        <span class="oh-footer-text">
          We'll be back. <a href="?mode=today">Today's games →</a> when the puck drops.
        </span>
      </footer>
    </section>
  </main>

  <style is:global>
    /* ── Offseason "we'll be back" footnote ──────────────────────── */
    .oh-footer {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 18px 0 0;
      border-top: 1px dashed #1c1c1c;
      margin-top: 12px;
    }
    .oh-footer-tick {
      color: var(--hgb-red);
      font-size: 14px;
      line-height: 1;
    }
    .oh-footer-text {
      font-family: var(--font-site-body);
      font-size: 12.5px;
      color: #888;
    }
    .oh-footer-text a {
      color: var(--site-white);
      text-decoration: none;
      font-weight: 700;
      border-bottom: 1px solid var(--status-live);
    }
    .oh-footer-text a:hover { color: var(--status-live); }
  </style>

  <!--
    Layer 2.2: Hydration bootstrap data.
    Build-time scoreboard + slate serialised as JSON in hidden elements.
    The hydration module script reads these as the initial state.
  -->
  <script
    id="hgb-init-scoreboard"
    type="application/json"
    set:html={initScoreboardJson}
  ></script>
  <script
    id="hgb-init-slate"
    type="application/json"
    set:html={initSlateJson}
  ></script>

  <!--
    Hero-pick debug stamp — useful for screenshotting the stickiness
    behaviour on the live fixture.
  -->
  <script is:inline define:vars={{ heroPickedId, heroIsStickyChosen }}>
    (function () {
      try {
        var hero = document.querySelector('[data-fixture-view="default"] .live-hero');
        if (hero) {
          hero.setAttribute('data-hero-id', heroPickedId || '');
          hero.setAttribute('data-hero-sticky', heroIsStickyChosen ? '1' : '0');
        }
      } catch (e) { /* no-op */ }
    })();
  </script>

  <!--
    Page-level hydration script (Layer 1.8 update):

    1. Sync ModeBar pills + source stamp + reset button to the resolved
       mode + source attrs the head script wrote.
    2. Wire ModeBar pill clicks → setOverride() → reload.
    3. Wire ↻ AUTO reset button → clearOverride() → reload (drops
       ?mode= from URL on the way so auto-detect runs clean).
    4. Topbar date pill swap (per-mode / sub-state date label).
    5. Hydrate the existing LiveHero stats carousel + goal-chip clamp
       (unchanged from Layer 1.9 / Layer 3).
  -->
  <script is:inline define:vars={{ todayDate, yesterdayDate, tomorrowDate, offseasonDate }}>
    (function () {
      // Layer 1.8: 3 modes — today/yesterday/offseason
      var mode = document.documentElement.getAttribute('data-home-mode') || 'today';
      var source = document.documentElement.getAttribute('data-mode-source') || 'auto';

      // ── ModeBar active pill ──────────────────────────────────────
      var toggles = document.querySelectorAll('.mode-bar [data-mode-toggle]');
      toggles.forEach(function (node) {
        var key = node.getAttribute('data-mode-toggle');
        var isActive = key === mode;
        node.classList.toggle('active', isActive);
        node.setAttribute('aria-selected', isActive ? 'true' : 'false');
        var dotSpan = node.querySelector('.dot');
        if (dotSpan) dotSpan.textContent = isActive ? '●' : '○';
      });

      // ── Source stamp + reset link ────────────────────────────────
      var sourceStamp = document.querySelector('[data-mode-source-stamp]');
      var resetBtn = document.querySelector('[data-mode-reset]');

      function paintSource(s) {
        if (!sourceStamp) return;
        if (s === 'override') {
          sourceStamp.textContent = ' · MANUAL';
          sourceStamp.setAttribute('data-source', 'manual');
        } else if (s === 'url') {
          sourceStamp.textContent = ' · LINK';
          sourceStamp.setAttribute('data-source', 'url');
        } else {
          sourceStamp.textContent = ' · AUTO MODE';
          sourceStamp.setAttribute('data-source', 'auto');
        }
        if (resetBtn) {
          // Reset button only meaningful when an override is in effect.
          // For 'url' we leave it hidden — the URL itself is the
          // user-visible reset (delete the param).
          resetBtn.hidden = s !== 'override';
        }
      }
      paintSource(source);

      // ── ModeBar click → setOverride + reload ────────────────────
      toggles.forEach(function (node) {
        node.addEventListener('click', function (e) {
          e.preventDefault();
          var key = node.getAttribute('data-mode-toggle');
          if (!key) return;
          try { window.sessionStorage.setItem('hgb-mode-override', key); } catch (e2) {}
          // Drop ?mode= from the URL so the manual choice owns the source.
          // Keep ?schedule=N if present so QA stays sticky across clicks.
          var url = new URL(window.location.href);
          url.searchParams.delete('mode');
          window.location.href = url.toString();
        });
      });

      // ── Reset button → clearOverride + reload ────────────────────
      if (resetBtn) {
        resetBtn.addEventListener('click', function () {
          try { window.sessionStorage.removeItem('hgb-mode-override'); } catch (e2) {}
          var url = new URL(window.location.href);
          url.searchParams.delete('mode');
          window.location.href = url.toString();
        });
      }

      // ── Topbar date ──────────────────────────────────────────────
      // Layer 1.8: today uses todayDate (live/final sub-states),
      // pre sub-state uses tomorrowDate as "tonight" label.
      var dateEl = document.querySelector('.hgb-topbar .date');
      if (dateEl) {
        var todaySubstate = document.documentElement.getAttribute('data-today-substate') || 'live';
        dateEl.textContent =
          mode === 'yesterday'  ? yesterdayDate
        : mode === 'offseason'  ? offseasonDate
        : (todaySubstate === 'pre') ? tomorrowDate
        :                         todayDate;
      }

      // ── LiveHero stats carousel (unchanged from Layer 1.9) ──────
      (function hydrateStatsCarousel() {
        var zones = document.querySelectorAll('.live-hero .lh-right[data-stats-active]');
        zones.forEach(function (zone) {
          var tabs = zone.querySelectorAll('[data-stats-target]');
          if (!tabs.length) return;

          function applyPanel(target) {
            var panel = target === 'b' ? 'b' : 'a';
            zone.setAttribute('data-stats-active', panel);
            tabs.forEach(function (t) {
              var match = t.getAttribute('data-stats-target') === panel;
              t.setAttribute('aria-selected', match ? 'true' : 'false');
            });
          }

          try {
            var saved = window.sessionStorage.getItem('hgb-stats-panel');
            if (saved === 'a' || saved === 'b') applyPanel(saved);
          } catch (e) { /* sessionStorage blocked — fall back to default */ }

          tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
              var target = tab.getAttribute('data-stats-target') || 'a';
              applyPanel(target);
              try {
                window.sessionStorage.setItem('hgb-stats-panel', target);
              } catch (e) { /* ignore */ }
            });
          });
        });
      })();

      // ── LiveHero footer goal-chip clamp (unchanged from Layer 3) ─
      (function hydrateGoalFooter() {
        var feeds = document.querySelectorAll('.live-hero .goal-feed');
        if (!feeds.length) return;

        var params = new URLSearchParams(window.location.search);
        var goalsRaw = params.get('goals');

        feeds.forEach(function (feed) {
          var totalGoals = parseInt(feed.getAttribute('data-goal-count') || '0', 10);

          var visibleGoals;
          if (goalsRaw === null || goalsRaw === 'all') {
            visibleGoals = totalGoals;
          } else {
            var parsed = parseInt(goalsRaw, 10);
            visibleGoals = isNaN(parsed)
              ? totalGoals
              : Math.max(0, Math.min(parsed, totalGoals));
          }

          var goalChips = feed.querySelectorAll('[data-chip-kind="goal"]');
          goalChips.forEach(function (chip) {
            var idx = parseInt(chip.getAttribute('data-chip-idx') || '0', 10);
            chip.hidden = idx >= visibleGoals;
          });

          feed.setAttribute('data-rendered-goals', String(visibleGoals));
        });
      })();

      // ── TodayHero countdown ticker (Layer 2.3) ──────────────────
      // Ticks any [data-hero-countdown-utc] element on the page.
      // The TodayHero component stamps this attribute on the countdown block.
      (function heroCountdownTick() {
        var el = document.querySelector('[data-hero-countdown-utc]');
        if (!el) return;
        var utcStr = el.getAttribute('data-hero-countdown-utc');
        if (!utcStr) return;
        var target = Date.parse(utcStr);
        if (isNaN(target)) return;
        var display = el.querySelector('.th-countdown-time');
        if (!display) return;

        function tick() {
          var now = Date.now();
          var diff = target - now;
          if (diff <= 0) {
            display.textContent = 'Game starting now';
            return;
          }
          var totalSec = Math.floor(diff / 1000);
          var h = Math.floor(totalSec / 3600);
          var m = Math.floor((totalSec % 3600) / 60);
          var s = totalSec % 60;
          display.textContent = h + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
        }
        tick();
        setInterval(tick, 1000);
      })();

    })();
  </script>

  <!--
    Layer 2.2: Client-side hydration loop.

    This module script imports the hydration helpers and wires them to
    the page. After the SSR bake-in renders at build time, this script
    polls /v1/scoreboard every 60s and /v1/slate every 5min, then
    re-renders the TodayHero section when data changes.

    Strategy: innerHTML-rebuild of #today-hero-mount on each poll
    (simpler than data-hydrate-key targeted updates; hero section is
    self-contained and cheap to rebuild).

    Visibility gating: polling pauses when the tab is hidden.
  -->
  <script>
    // Layer 2.2: Hydration loop wire-up
    // Uses bundled module imports (Astro compiles this).
    import { startHydrationLoop } from '../lib/hydration';
    import { pickHeroGame } from '../lib/hero-selection';

    // ── Helpers ────────────────────────────────────────────────────
    function fmtStartTimeET(utc) {
      if (!utc) return '';
      try {
        return new Intl.DateTimeFormat('en-US', {
          timeZone: 'America/New_York',
          hour: 'numeric',
          minute: '2-digit',
          hour12: true,
        }).format(new Date(utc)) + ' ET';
      } catch { return ''; }
    }

    function fmtWp(v) {
      if (v === null || v === undefined) return '–';
      return `${Math.round(v * 100)}%`;
    }

    function pct(a, b) {
      const av = a ?? 0, bv = b ?? 0, sum = av + bv;
      if (sum <= 0) return ['50%', '50%'];
      return [`${(av / sum) * 100}%`, `${(bv / sum) * 100}%`];
    }

    // ── Render hero HTML ──────────────────────────────────────────
    function renderHeroHtml(scoreboard, slate) {
      const pick = pickHeroGame(scoreboard, slate, window._hgbHeroId || null);
      if (!pick) return null;
      window._hgbHeroId = pick.game.game_id;

      const g = pick.game;
      const subState = pick.subState;
      const home = g.home_team, away = g.away_team;
      const clock = g.clock, stats = g.stats;
      const isFeatured = pick.isFeaturedMatchup;
      const period = clock.period ?? 0;
      const inIntermission = clock.in_intermission ?? false;

      // Sub-state header
      let eyebrowHtml = '';
      if (subState === 'pre') {
        eyebrowHtml = `<span class="th-eyebrow-badge th-eyebrow-badge--pre">UPCOMING · TODAY</span>`;
      } else if (subState === 'live') {
        let liveLine = '';
        if (inIntermission) liveLine = `INTERMISSION · After P${period}`;
        else if (period === 0) liveLine = 'PRE-GAME';
        else {
          const pl = period <= 3 ? `PERIOD ${period}` : period === 4 ? 'OVERTIME' : `OT${period-3}`;
          liveLine = `LIVE · ${pl} · ${clock.time_remaining ?? ''}`;
        }
        eyebrowHtml = `<span class="th-eyebrow-badge th-eyebrow-badge--live"><span class="th-live-dot" aria-hidden="true"></span>${liveLine}</span>`;
      } else {
        eyebrowHtml = `<span class="th-eyebrow-badge th-eyebrow-badge--final">FINAL</span>`;
      }

      const gotnBadge = isFeatured
        ? `<span class="th-gotn-badge" title="Game of the Night">★ GAME OF THE NIGHT</span>`
        : '';

      const header = `
        <div class="th-header">
          <div class="th-header-left">${eyebrowHtml}</div>
          <div class="th-header-right">
            ${gotnBadge}
            <span class="th-matchup-label">${away.abbrev} @ ${home.abbrev}</span>
          </div>
        </div>`;

      // LEFT card
      const timeLabel = fmtStartTimeET(g.start_time_utc);
      const venue = g.venue ? g.venue.toUpperCase() : '';
      let leftCard = '';

      if (subState === 'pre') {
        const countdownUtc = g.start_time_utc || '';
        leftCard = `
          <div class="th-card th-card--left th-card--pre">
            <div class="th-pre-teams">
              <div class="th-pre-team">
                <img src="https://assets.nhle.com/logos/nhl/svg/${away.abbrev}_dark.svg" width="64" height="64" alt="${away.abbrev}" loading="lazy" />
                <span class="th-pre-abbr">${away.abbrev}</span>
              </div>
              <div class="th-pre-vs">VS</div>
              <div class="th-pre-team">
                <img src="https://assets.nhle.com/logos/nhl/svg/${home.abbrev}_dark.svg" width="64" height="64" alt="${home.abbrev}" loading="lazy" />
                <span class="th-pre-abbr">${home.abbrev}</span>
              </div>
            </div>
            ${countdownUtc ? `
              <div class="th-countdown-block" data-hero-countdown-utc="${countdownUtc}">
                <div class="th-countdown-lbl">Next puck drop in</div>
                <div class="th-countdown-time" aria-live="polite">–:––:––</div>
              </div>
            ` : `
              <div class="th-time-block">
                <span class="th-time-lbl">Start time</span>
                <span class="th-time-val">${timeLabel}</span>
              </div>
            `}
            ${venue ? `<div class="th-venue">${venue}</div>` : ''}
          </div>`;
      } else {
        const gameIsOver = subState === 'final';
        const homeLoser = gameIsOver && home.score < away.score;
        const awayLoser = gameIsOver && away.score < home.score;
        const finalBadge = subState === 'final'
          ? `<div class="th-final-badge">FINAL${period >= 4 ? (period === 4 ? ' · OT' : ' · SO') : ''}</div>`
          : '';
        const lastEvHtml = g.last_event && subState === 'live' ? `
          <div class="th-last-event">
            <span class="th-last-event-type">${g.last_event.type}</span>
            <span class="th-last-event-desc">${g.last_event.description}</span>
            ${g.last_event.time_ago ? `<span class="th-last-event-when">${g.last_event.time_ago}</span>` : ''}
          </div>` : '';
        leftCard = `
          <div class="th-card th-card--left ${subState === 'live' ? 'th-card--live' : 'th-card--final'}">
            ${finalBadge}
            <div class="th-score-row">
              <div class="th-team-score${homeLoser ? ' loser' : ''}">
                <img src="https://assets.nhle.com/logos/nhl/svg/${home.abbrev}_dark.svg" width="60" height="60" alt="${home.abbrev}" loading="lazy" />
                <div class="th-team-info"><span class="th-team-abbr">${home.abbrev}</span></div>
                <span class="th-score-num">${home.score}</span>
              </div>
              <div class="th-score-sep">·</div>
              <div class="th-team-score th-team-score--right${awayLoser ? ' loser' : ''}">
                <span class="th-score-num">${away.score}</span>
                <div class="th-team-info th-team-info--right"><span class="th-team-abbr">${away.abbrev}</span></div>
                <img src="https://assets.nhle.com/logos/nhl/svg/${away.abbrev}_dark.svg" width="60" height="60" alt="${away.abbrev}" loading="lazy" />
              </div>
            </div>
            ${lastEvHtml}
          </div>`;
      }

      // RIGHT card
      let rightCard = '';
      if (subState === 'pre') {
        // Find slate details for this game
        const preview = slate?.matchup_previews?.find(p => p.game_id === g.game_id);
        const pred = slate?.predictions?.find(p => p.game_id === g.game_id);
        const km = preview?.key_matchup;
        const eyebrow = venue ? `${venue} · ${timeLabel}` : timeLabel;
        const [wpL] = pct(pred?.home_wp ?? null, pred?.away_wp ?? null);

        rightCard = `
          <div class="th-card th-card--right th-card--pre-r">
            <div class="th-r-eyebrow">${eyebrow}</div>
            ${preview ? `
              <div class="th-r-km-label">${km ? 'Key matchup · HGB edge' : (preview.headline || 'Featured matchup')}</div>
              ${km ? `
                <div class="th-r-km-pair">
                  <span class="th-r-km-side">
                    ${km.home_player}
                    <span class="th-r-km-team">${home.abbrev}</span>
                  </span>
                  <span class="th-r-km-vs">vs</span>
                  <span class="th-r-km-side th-r-km-side--right">
                    <span class="th-r-km-team">${away.abbrev}</span>
                    ${km.away_player}
                  </span>
                </div>
              ` : ''}
              ${preview.x_factor ? `
                <div class="th-r-xfactor">
                  <span class="th-r-xfactor-label">X-FACTOR</span>
                  <span class="th-r-xfactor-val">${preview.x_factor}</span>
                </div>
              ` : ''}
              ${pred ? `
                <div class="th-r-wp-row">
                  <div class="th-r-wp-team">
                    <span class="th-r-wp-abbr">${home.abbrev}</span>
                    <span class="th-r-wp-pct">${fmtWp(pred.home_wp)}</span>
                  </div>
                  <div class="th-r-wp-bar">
                    <div class="th-r-wp-bar-fill" style="width:${wpL}"></div>
                  </div>
                  <div class="th-r-wp-team th-r-wp-team--right">
                    <span class="th-r-wp-pct">${fmtWp(pred.away_wp)}</span>
                    <span class="th-r-wp-abbr">${away.abbrev}</span>
                  </div>
                </div>
              ` : ''}
            ` : `
              <div class="th-r-no-slate">
                <div class="th-r-team-row">
                  <img src="https://assets.nhle.com/logos/nhl/svg/${away.abbrev}_dark.svg" width="72" height="72" alt="${away.abbrev}" loading="lazy" />
                  <span class="th-r-vs-label">@</span>
                  <img src="https://assets.nhle.com/logos/nhl/svg/${home.abbrev}_dark.svg" width="72" height="72" alt="${home.abbrev}" loading="lazy" />
                </div>
                <div class="th-r-pending">Predictions coming after 8 AM ET</div>
              </div>
            `}
          </div>`;
      } else if (subState === 'live') {
        const [shotsL, shotsR] = pct(stats.shots_on_goal.home, stats.shots_on_goal.away);
        const [xg5L, xg5R] = pct(stats.xg_5v5.home, stats.xg_5v5.away);
        const [xgL, xgR] = pct(stats.xg.home, stats.xg.away);
        const [wpL2, wpR2] = pct(stats.win_probability.home, stats.win_probability.away);
        rightCard = `
          <div class="th-card th-card--right th-card--live-r">
            <div class="th-r-stat">
              <div class="th-r-stat-val">${stats.shots_on_goal.home ?? '–'}</div>
              <div class="th-r-stat-lbl">Shots on Goal</div>
              <div class="th-r-stat-val">${stats.shots_on_goal.away ?? '–'}</div>
              <div class="th-r-stat-bar"><div class="th-r-bar-l" style="width:${shotsL}"></div><div class="th-r-bar-r" style="width:${shotsR}"></div></div>
            </div>
            <div class="th-r-stat">
              <div class="th-r-stat-val">${stats.xg_5v5.home !== null ? stats.xg_5v5.home.toFixed(2) : '–'}</div>
              <div class="th-r-stat-lbl">5v5 xG</div>
              <div class="th-r-stat-val">${stats.xg_5v5.away !== null ? stats.xg_5v5.away.toFixed(2) : '–'}</div>
              <div class="th-r-stat-bar"><div class="th-r-bar-l" style="width:${xg5L}"></div><div class="th-r-bar-r" style="width:${xg5R}"></div></div>
            </div>
            <div class="th-r-stat">
              <div class="th-r-stat-val">${stats.xg.home !== null ? stats.xg.home.toFixed(2) : '–'}</div>
              <div class="th-r-stat-lbl">xG · All</div>
              <div class="th-r-stat-val">${stats.xg.away !== null ? stats.xg.away.toFixed(2) : '–'}</div>
              <div class="th-r-stat-bar th-r-stat-bar--cyan"><div class="th-r-bar-l" style="width:${xgL}"></div><div class="th-r-bar-r" style="width:${xgR}"></div></div>
            </div>
            <div class="th-r-stat">
              <div class="th-r-stat-val">${fmtWp(stats.win_probability.home)}</div>
              <div class="th-r-stat-lbl">Win Probability</div>
              <div class="th-r-stat-val">${fmtWp(stats.win_probability.away)}</div>
              <div class="th-r-stat-bar"><div class="th-r-bar-l" style="width:${wpL2}"></div><div class="th-r-bar-r" style="width:${wpR2}"></div></div>
            </div>
          </div>`;
      } else {
        // Final
        const stars = (g.three_stars || []).slice(0, 3);
        const starsHtml = stars.length > 0
          ? `<div class="th-r-stars-label">Three Stars</div>
             <ol class="th-r-stars-list">
               ${stars.map((s, i) => `
                 <li class="th-r-star-row">
                   <span class="th-r-star-num">${i+1}</span>
                   <span class="th-r-star-name">${s.name || s.player || '—'}</span>
                   ${s.team_abbrev ? `<span class="th-r-star-team">${s.team_abbrev}</span>` : ''}
                   ${s.stat_line ? `<span class="th-r-star-stat">${s.stat_line}</span>` : ''}
                 </li>`).join('')}
             </ol>`
          : `<div class="th-r-no-stars">Three stars pending</div>`;
        const [wpLf, wpRf] = pct(stats.win_probability.home, stats.win_probability.away);
        const wpHtml = (stats.win_probability.home !== null || stats.win_probability.away !== null)
          ? `<div class="th-r-final-wp">
               <div class="th-r-wp-row">
                 <div class="th-r-wp-team"><span class="th-r-wp-abbr">${home.abbrev}</span><span class="th-r-wp-pct">${fmtWp(stats.win_probability.home)}</span></div>
                 <div class="th-r-wp-bar"><div class="th-r-wp-bar-fill" style="width:${wpLf}"></div></div>
                 <div class="th-r-wp-team th-r-wp-team--right"><span class="th-r-wp-pct">${fmtWp(stats.win_probability.away)}</span><span class="th-r-wp-abbr">${away.abbrev}</span></div>
               </div>
               <div class="th-r-wp-caption">Final win probability</div>
             </div>`
          : '';
        rightCard = `
          <div class="th-card th-card--right th-card--final-r">
            ${starsHtml}
            ${wpHtml}
          </div>`;
      }

      return `<section class="today-hero" data-sub-state="${subState}" data-game-id="${g.game_id}" aria-label="Featured game: ${away.abbrev} @ ${home.abbrev}">
        ${header}
        <div class="th-body">${leftCard}${rightCard}</div>
      </section>`;
    }

    // ── Update sub-state CSS attribute on <html> ──────────────────
    function updateSubState(games) {
      if (!games || games.length === 0) return;
      const liveLike = new Set(['live', 'intermission', 'shootout']);
      const hasLive = games.some(g => liveLike.has(g.game_state));
      if (hasLive) {
        document.documentElement.setAttribute('data-today-substate', 'live');
        return;
      }
      const allFinal = games.every(g => g.game_state === 'final');
      document.documentElement.setAttribute(
        'data-today-substate',
        allFinal ? 'final' : 'pre'
      );
    }

    // ── Countdown ticker after innerHTML swap ─────────────────────
    function wireCountdown() {
      const el = document.querySelector('[data-hero-countdown-utc]');
      if (!el) return;
      if (el._countdownWired) return;
      el._countdownWired = true;
      const utcStr = el.getAttribute('data-hero-countdown-utc');
      if (!utcStr) return;
      const target = Date.parse(utcStr);
      if (isNaN(target)) return;
      const display = el.querySelector('.th-countdown-time');
      if (!display) return;
      function tick() {
        const diff = target - Date.now();
        if (diff <= 0) { display.textContent = 'Game starting now'; return; }
        const ts = Math.floor(diff / 1000);
        const h = Math.floor(ts / 3600);
        const m = Math.floor((ts % 3600) / 60);
        const s = ts % 60;
        display.textContent = h + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
      }
      tick();
      setInterval(tick, 1000);
    }

    // ── Last-updated stamp ─────────────────────────────────────────
    let _lastScoreboardUpdate = null;
    function updateStamp() {
      const stamp = document.getElementById('hgb-hydration-stamp');
      if (!stamp || !_lastScoreboardUpdate) return;
      const ageSec = Math.round((Date.now() - _lastScoreboardUpdate) / 1000);
      stamp.textContent = ageSec < 5 ? 'Updated just now' : `Updated ${ageSec}s ago`;
    }
    setInterval(updateStamp, 5000);

    // ── Main update handler ───────────────────────────────────────
    let _currentSlate = null;

    function onScoreboardUpdate(scoreboard) {
      _lastScoreboardUpdate = Date.now();
      // 1. Update sub-state gating
      const mode = document.documentElement.getAttribute('data-home-mode');
      if (mode === 'today') {
        updateSubState(scoreboard.games);
      }
      // 2. Re-render TodayHero if in today mode + pre sub-state (or live)
      const mount = document.getElementById('today-hero-mount');
      if (mount && mode === 'today') {
        const html = renderHeroHtml(scoreboard, _currentSlate);
        if (html) {
          mount.innerHTML = html;
          wireCountdown();
        }
      }
      // 3. Update stamp
      const stamp = document.getElementById('hgb-hydration-stamp');
      if (stamp) stamp.textContent = 'Updated just now';
    }

    function onSlateUpdate(slate) {
      _currentSlate = slate;
    }

    // ── Bootstrap: load initial data from embedded JSON ──────────
    try {
      const initSb = JSON.parse(document.getElementById('hgb-init-scoreboard')?.textContent || 'null');
      const initSl = JSON.parse(document.getElementById('hgb-init-slate')?.textContent || 'null');
      if (initSl) _currentSlate = initSl;
      // Don't call onScoreboardUpdate here — SSR already rendered correctly.
      // Just store for hero-id tracking.
      if (initSb && document.getElementById('today-hero-mount')) {
        const pick = initSb && pickHeroGame ? pickHeroGame(initSb, initSl, null) : null;
        if (pick) window._hgbHeroId = pick.game.game_id;
      }
    } catch (e) {
      console.warn('[hydration] Bootstrap parse error:', e);
    }

    // ── Start the loop (only in today mode, or when mode changes) ─
    const currentMode = document.documentElement.getAttribute('data-home-mode');
    if (currentMode === 'today') {
      startHydrationLoop({ onScoreboardUpdate, onSlateUpdate });
    }
  </script>
</body>
</html>
