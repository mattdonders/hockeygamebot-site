---
// HockeyGameBot — /teams/[abbr] — per-team bot landing page
// Generates one static page per team at build time.
// Tonight's game is fetched client-side from hgb-api.

export async function getStaticPaths() {
  const teams = [
    { abbr: 'ANA', name: 'Anaheim Ducks' },
    { abbr: 'BOS', name: 'Boston Bruins' },
    { abbr: 'BUF', name: 'Buffalo Sabres' },
    { abbr: 'CGY', name: 'Calgary Flames' },
    { abbr: 'CAR', name: 'Carolina Hurricanes' },
    { abbr: 'CHI', name: 'Chicago Blackhawks' },
    { abbr: 'COL', name: 'Colorado Avalanche' },
    { abbr: 'CBJ', name: 'Columbus Blue Jackets' },
    { abbr: 'DAL', name: 'Dallas Stars' },
    { abbr: 'DET', name: 'Detroit Red Wings' },
    { abbr: 'EDM', name: 'Edmonton Oilers' },
    { abbr: 'FLA', name: 'Florida Panthers' },
    { abbr: 'LAK', name: 'Los Angeles Kings' },
    { abbr: 'MIN', name: 'Minnesota Wild' },
    { abbr: 'MTL', name: 'Montreal Canadiens' },
    { abbr: 'NSH', name: 'Nashville Predators' },
    { abbr: 'NJD', name: 'New Jersey Devils' },
    { abbr: 'NYI', name: 'New York Islanders' },
    { abbr: 'NYR', name: 'New York Rangers' },
    { abbr: 'OTT', name: 'Ottawa Senators' },
    { abbr: 'PHI', name: 'Philadelphia Flyers' },
    { abbr: 'PIT', name: 'Pittsburgh Penguins' },
    { abbr: 'SJS', name: 'San Jose Sharks' },
    { abbr: 'SEA', name: 'Seattle Kraken' },
    { abbr: 'STL', name: 'St. Louis Blues' },
    { abbr: 'TBL', name: 'Tampa Bay Lightning' },
    { abbr: 'TOR', name: 'Toronto Maple Leafs' },
    { abbr: 'UTA', name: 'Utah Hockey Club' },
    { abbr: 'VAN', name: 'Vancouver Canucks' },
    { abbr: 'VGK', name: 'Vegas Golden Knights', xHandle: 'VGKGameBot_' },
    { abbr: 'WSH', name: 'Washington Capitals' },
    { abbr: 'WPG', name: 'Winnipeg Jets' },
  ];

  // Fetch standings once for all pages
  const teamStats = new Map<string, { clinch: string | null; record: string }>();
  let playoffMode = false;
  try {
    const res = await fetch('https://api-web.nhle.com/v1/standings/now');
    if (res.ok) {
      const data = await res.json();
      for (const t of data.standings ?? []) {
        const a: string = t.teamAbbrev?.default ?? '';
        const clinch: string | null = t.clinchIndicator ?? null;
        teamStats.set(a, { clinch, record: `${t.wins ?? 0}-${t.losses ?? 0}-${t.otLosses ?? 0}` });
        if (clinch === 'x' || clinch === 'y' || clinch === 'z') playoffMode = true;
      }
    }
  } catch {}

  return teams.map((team) => ({
    params: { abbr: team.abbr.toLowerCase() },
    props: {
      abbr: team.abbr,
      name: team.name,
      xHandle: team.xHandle ?? `${team.abbr}GameBot`,
      stats: teamStats.get(team.abbr) ?? null,
      playoffMode,
    },
  }));
}

const { abbr, name, xHandle, stats, playoffMode } = Astro.props;
const bskyHandle = `${abbr.toLowerCase()}.hockeygamebot.com`;
const xUrl    = `https://x.com/${xHandle}`;
const bskyUrl = `https://bsky.app/profile/${bskyHandle}`;
const logoUrl = `https://assets.nhle.com/logos/nhl/svg/${abbr}_light.svg`;

const clinch = stats?.clinch ?? null;
const isPlayoff   = clinch === 'x' || clinch === 'y' || clinch === 'z';
const isEliminated = clinch === 'e';
const statusLabel = isPlayoff ? '★ PLAYOFFS' : isEliminated ? 'ELIMINATED' : (stats?.record ?? null);
const statusClass = isPlayoff ? 'badge--playoffs' : isEliminated ? 'badge--eliminated' : 'badge--record';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{name} Bot | HockeyGameBot</title>
  <meta name="description" content={`Follow ${name} live game updates on X and Bluesky via HockeyGameBot.`}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="HockeyGameBot">
  <meta property="og:title" content={`${name} Bot | HockeyGameBot`}>
  <meta property="og:description" content={`Live ${name} game updates on X (@${xHandle}) and Bluesky.`}>
  <meta property="og:url" content={`https://hockeygamebot.com/teams/${abbr.toLowerCase()}`}>
  <meta property="og:image" content="https://hockeygamebot.com/og/teams.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content={`@${xHandle}`}>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <a href="/" class="brand">HGB</a>
  <div class="brand-sub">HockeyGameBot</div>
  <div class="topbar-right">
    <nav class="topbar-nav">
      <a href="/" class="topbar-link">SCORES</a>
      <a href="/teams" class="topbar-link topbar-link--active">TEAMS</a>
      <a href="/support" class="topbar-link topbar-link--support">
        <svg class="support-heart" width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        <span class="support-label">SUPPORT</span>
      </a>
    </nav>
  </div>
</div>

<main>
  <section class="hero">
    <div class="hero-inner">
      <a href="/teams" class="back-link">← All Teams</a>
      <img src={logoUrl} alt={`${name} logo`} class="hero-logo" width="96" height="96" />
      <h1 class="hero-name">{name}</h1>
      {statusLabel && (
        <span class={`badge ${statusClass}`}>{statusLabel}</span>
      )}
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      <!-- Follow section -->
      <div class="card">
        <div class="card-label">Follow the Bot</div>
        <div class="follow-links">
          <a href={xUrl} class="follow-btn follow-btn--x" target="_blank" rel="noopener">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <div>
              <div class="btn-platform">X / Twitter</div>
              <div class="btn-handle">@{xHandle}</div>
            </div>
          </a>
          <a href={bskyUrl} class="follow-btn follow-btn--bsky" target="_blank" rel="noopener">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>
            <div>
              <div class="btn-platform">Bluesky</div>
              <div class="btn-handle">@{bskyHandle}</div>
            </div>
          </a>
        </div>
      </div>

      <!-- Tonight's game — client-side -->
      <div class="card" id="game-card">
        <div class="card-label">Tonight's Game</div>
        <div id="game-content" class="game-loading">Loading…</div>
      </div>

      <!-- Support -->
      <div class="card card--support">
        <div class="card-label">Support HockeyGameBot</div>
        <p class="app-desc">32 bots, running every game night. If HGB adds to your game-day experience, a coffee goes a long way.</p>
        <a href="https://ko-fi.com/hockeygamebot" class="app-btn app-btn--kofi" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          Support on Ko-fi
        </a>
      </div>

    </div>
  </section>
</main>

<footer class="site-footer">
  <div class="footer-inner">
    <span class="footer-brand">HGB</span>
    <span class="footer-sep">·</span>
    <a href="/" class="footer-link">Scores</a>
    <a href="/teams" class="footer-link">Teams</a>
    <a href="/support" class="footer-link">Support</a>
    <span class="footer-copy">Built with 🏒 by <a href="https://twitter.com/mattdonders" class="footer-link" target="_blank" rel="noopener">@mattdonders</a></span>
  </div>
</footer>

<script define:vars={{ abbr }}>
  const API = 'https://api.hockeygamebot.com';

  async function loadGame() {
    const el = document.getElementById('game-content');
    try {
      const res = await fetch(`${API}/v1/games/today`);
      if (!res.ok) throw new Error('API error');
      const games = await res.json();

      const game = games.find(g =>
        g.awayTeam?.abbrev === abbr || g.homeTeam?.abbrev === abbr
      );

      if (!game) {
        el.innerHTML = '<span class="game-none">No game scheduled today</span>';
        return;
      }

      const away = game.awayTeam;
      const home = game.homeTeam;
      const state = game.gameState ?? '';
      const isLive = state === 'LIVE' || state === 'CRIT';
      const isFinal = state === 'OFF' || state === 'FINAL';

      const awayLogo = `https://assets.nhle.com/logos/nhl/svg/${away.abbrev}_light.svg`;
      const homeLogo = `https://assets.nhle.com/logos/nhl/svg/${home.abbrev}_light.svg`;

      let statusHtml = '';
      if (isLive) {
        const period = game.periodDescriptor?.number ?? '';
        const periodLabel = period === 4 ? 'OT' : period === 5 ? 'SO' : `P${period}`;
        const clock = game.clock?.timeRemaining ?? '';
        statusHtml = `<span class="game-live">● LIVE ${periodLabel}${clock ? ' ' + clock : ''}</span>`;
      } else if (isFinal) {
        statusHtml = `<span class="game-final">FINAL</span>`;
      } else {
        const startUtc = game.startTimeUTC;
        const time = startUtc
          ? new Date(startUtc).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZoneName: 'short' })
          : '';
        statusHtml = `<span class="game-time">${time}</span>`;
      }

      const awayScore = away.score ?? '';
      const homeScore = home.score ?? '';
      const showScore = isLive || isFinal;

      el.innerHTML = `
        <div class="game-matchup">
          <div class="game-team">
            <img src="${awayLogo}" class="game-logo" width="40" height="40" alt="${away.abbrev}" />
            <span class="game-abbr">${away.abbrev}</span>
            ${showScore ? `<span class="game-score">${awayScore}</span>` : ''}
          </div>
          <div class="game-vs">
            ${statusHtml}
          </div>
          <div class="game-team game-team--home">
            ${showScore ? `<span class="game-score">${homeScore}</span>` : ''}
            <span class="game-abbr">${home.abbrev}</span>
            <img src="${homeLogo}" class="game-logo" width="40" height="40" alt="${home.abbrev}" />
          </div>
        </div>
        <a href="/" class="game-link">Watch live on hockeygamebot.com →</a>
      `;
    } catch {
      el.innerHTML = '<span class="game-none">Unable to load game data</span>';
    }
  }

  loadGame();
</script>

</body>
</html>

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #090909;
  --card: #111;
  --border: #1c1c1c;
  --border2: #252525;
  --muted: #555;
  --text: #999;
  --text-secondary: #777;
  --white: #f5f5f5;
  --red: #ff3d3d;
}
html, body {
  background: var(--bg);
  font-family: 'Space Grotesk', sans-serif;
  color: var(--text);
  line-height: 1.65;
  min-height: 100vh;
}

/* ── TOP BAR ── */
.topbar { height: 44px; background: var(--red); display: flex; align-items: center; padding: 0 24px; gap: 16px; position: sticky; top: 0; z-index: 100; }
.brand { font-family: 'Oswald', sans-serif; font-size: 22px; font-weight: 700; color: #fff; letter-spacing: 0.1em; text-decoration: none; }
.brand-sub { font-size: 11px; color: rgba(255,255,255,0.65); letter-spacing: 0.14em; }
.topbar-right { margin-left: auto; }
.topbar-nav { display: flex; gap: 6px; }
.topbar-link { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; color: rgba(255,255,255,0.7); text-decoration: none; padding: 4px 10px; border: 1px solid rgba(255,255,255,0.2); border-radius: 3px; transition: color 0.15s, border-color 0.15s; }
.topbar-link:hover, .topbar-link--active { color: #fff; border-color: rgba(255,255,255,0.5); }
.topbar-link--support { display: flex; align-items: center; gap: 5px; }
.support-heart { flex-shrink: 0; opacity: 0.9; }

/* ── HERO ── */
.hero { padding: 56px 24px 48px; text-align: center; border-bottom: 1px solid var(--border); }
.hero-inner { max-width: 480px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 16px; }
.back-link { font-size: 12px; font-weight: 600; letter-spacing: 0.06em; color: var(--muted); text-decoration: none; align-self: flex-start; transition: color 0.15s; }
.back-link:hover { color: var(--white); }
.hero-logo { width: 88px; height: 88px; object-fit: contain; }
.hero-name { font-family: 'Oswald', sans-serif; font-size: clamp(24px, 5vw, 38px); font-weight: 700; color: var(--white); letter-spacing: 0.02em; line-height: 1.1; }
.badge { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; padding: 4px 12px; border-radius: 4px; }
.badge--playoffs { color: #4ade80; background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.25); }
.badge--eliminated { color: #ff6b6b; background: rgba(255,107,107,0.1); border: 1px solid rgba(255,107,107,0.25); }
.badge--record { color: var(--muted); background: var(--card); border: 1px solid var(--border2); }

/* ── CONTENT ── */
.content-section { padding: 40px 24px 80px; }
.content-inner { max-width: 480px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px; }

/* ── CARDS ── */
.card { background: var(--card); border: 1px solid var(--border2); border-radius: 10px; padding: 22px; }
.card-label { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; }

/* ── FOLLOW BUTTONS ── */
.follow-links { display: flex; flex-direction: column; gap: 10px; }
.follow-btn { display: flex; align-items: center; gap: 14px; padding: 14px 16px; border-radius: 8px; border: 1px solid var(--border2); text-decoration: none; transition: border-color 0.15s, background 0.15s; }
.follow-btn:hover { background: rgba(255,255,255,0.03); border-color: #333; }
.follow-btn--bsky:hover { border-color: rgba(91,184,255,0.3); }
.btn-icon { width: 20px; height: 20px; flex-shrink: 0; color: var(--muted); }
.follow-btn--bsky .btn-icon { color: #5bb8ff; }
.btn-platform { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: var(--text-secondary); margin-bottom: 2px; }
.btn-handle { font-size: 14px; font-weight: 600; color: var(--white); }

/* ── TONIGHT'S GAME ── */
.game-loading { color: var(--muted); font-size: 13px; }
.game-none { color: var(--muted); font-size: 13px; }
.game-matchup { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px; }
.game-team { display: flex; align-items: center; gap: 10px; }
.game-team--home { flex-direction: row-reverse; }
.game-logo { width: 40px; height: 40px; object-fit: contain; }
.game-abbr { font-family: 'Oswald', sans-serif; font-size: 22px; font-weight: 700; color: var(--white); letter-spacing: 0.04em; }
.game-score { font-family: 'Oswald', sans-serif; font-size: 28px; font-weight: 700; color: var(--white); min-width: 24px; text-align: center; }
.game-vs { display: flex; flex-direction: column; align-items: center; gap: 4px; }
.game-live { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; color: #4ade80; background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.25); padding: 4px 10px; border-radius: 4px; }
.game-final { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; color: var(--muted); }
.game-time { font-size: 13px; font-weight: 600; color: var(--text-secondary); }
.game-link { font-size: 12px; font-weight: 600; color: var(--red); text-decoration: none; display: block; transition: opacity 0.15s; }
.game-link:hover { opacity: 0.8; }

/* ── SUPPORT CARD ── */
.card--support { border-color: rgba(255,61,61,0.15); }
.app-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 16px; }
.app-btn { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; color: var(--white); background: var(--red); padding: 10px 18px; border-radius: 6px; text-decoration: none; transition: opacity 0.15s; }
.app-btn:hover { opacity: 0.85; }
.app-btn--kofi { background: #ff5e5b; }

/* ── FOOTER ── */
.site-footer { background: #050505; border-top: 1px solid var(--border); padding: 28px 24px; }
.footer-inner { max-width: 480px; margin: 0 auto; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
.footer-brand { font-family: 'Oswald', sans-serif; font-size: 16px; font-weight: 700; color: var(--red); letter-spacing: 0.1em; }
.footer-sep { color: var(--border2); }
.footer-link { font-size: 12px; font-weight: 600; letter-spacing: 0.08em; color: var(--muted); text-decoration: none; transition: color 0.15s; }
.footer-link:hover { color: var(--white); }
.footer-copy { margin-left: auto; font-size: 12px; color: var(--muted); }

@media (max-width: 640px) {
  .topbar { padding: 0 16px; gap: 10px; }
  .brand-sub, .support-label { display: none; }
  .hero { padding: 40px 20px 36px; }
  .content-section { padding: 28px 16px 60px; }
  .footer-copy { margin-left: 0; width: 100%; }
}
</style>
