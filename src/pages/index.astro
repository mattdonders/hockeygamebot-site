---
// HockeyGameBot live scoreboard — wired to hgb-api /v1/games/today
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>HockeyGameBot · Live NHL Scores, Win Probability & Analytics</title>
  <meta name="description" content="Live NHL scores and game cards with real-time win probability, xG flow charts, play-by-play, and advanced analytics. Every game, every night.">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="HockeyGameBot">
  <meta property="og:title" content="HockeyGameBot · Live NHL Scores, Win % & Analytics">
  <meta property="og:description" content="Live NHL scores and game cards with real-time win probability, xG flow charts, play-by-play, and advanced analytics. Every game, every night.">
  <meta property="og:url" content="https://hockeygamebot.com/">
  <meta property="og:image" content="https://s3.us-west-000.backblazeb2.com/hockeygamebot-media/hockeygamebot/static/og_image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="HockeyGameBot — Live NHL Scores & Analytics">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@hockeygamebot">
  <meta name="twitter:title" content="HockeyGameBot · Live NHL Scores & Analytics">
  <meta name="twitter:description" content="Live NHL scores and game cards with real-time win probability, xG flow charts, play-by-play, and advanced analytics. Every game, every night.">
  <meta name="twitter:image" content="https://s3.us-west-000.backblazeb2.com/hockeygamebot-media/hockeygamebot/static/og_image.png">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
</head>
<body>

<div id="catchup-pill">CATCHING UP TO LIVE…</div>

<div class="topbar">
  <div class="brand">HGB</div>
  <div class="brand-sub" id="topbar-date">Live Tonight</div>
  <div class="topbar-right">
    <span class="topbar-live" id="live-count">– LIVE</span>
    <span id="total-games">– GAMES</span>
    <span id="wall-clock">--:--:--</span>
    <span id="sse-indicator" title="Push connection">📡</span>
    <span class="topbar-divider"></span>
    <nav class="topbar-nav">
      <a href="/teams/" class="topbar-link">TEAMS</a>
      <a href="https://twitch.tv/hockeygamebot" target="_blank" rel="noopener" class="topbar-link topbar-link--twitch">▶ TWITCH</a>
    </nav>
  </div>
</div>

<div class="ticker-strip">
  <div class="ticker-lbl" id="ticker-lbl">⚡ LIVE</div>
  <div class="ticker-content">
    <div class="ticker-inner" id="ticker-inner">
      <span>Loading game data…</span>
    </div>
  </div>
</div>

<div id="grid-wrapper"></div>

<div class="bottombar">
  <div id="bb-container" style="display:flex;flex:1;gap:8px;justify-content:center;"></div>
</div>

<div id="game-modal" class="modal-overlay" style="display:none" aria-modal="true" role="dialog">
  <div class="modal-backdrop" id="modal-backdrop"></div>
  <div class="modal-panel">
    <button class="modal-close" id="modal-close" aria-label="Close">✕</button>
    <div id="modal-content"><div class="modal-loading">Loading…</div></div>
  </div>
</div>

</body>
</html>

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #090909; --card: #0f0f0f; --border: #1c1c1c; --border2: #252525;
  --dim: #2e2e2e; --muted: #555; --text: #999; --white: #f5f5f5;
  --cyan: #00e5ff; --red: #ff3d3d; --green: #00e676; --yellow: #ffca28;
  --purple: #ce93d8; --blue: #60a5fa; --orange: #ff9800;
}
html, body {
  width: 100%; height: 100vh; overflow: hidden;
  background: var(--bg); font-family: 'Space Grotesk', sans-serif; color: var(--text);
  display: flex; flex-direction: column;
}

/* TOP BAR */
.topbar {
  height: 44px; background: var(--red); display: flex; align-items: center;
  padding: 0 24px; gap: 16px;
}
.brand { font-family: 'Oswald', sans-serif; font-size: 22px; font-weight: 700; color: #fff; letter-spacing: 0.1em; }
.brand-sub { font-size: 11px; color: rgba(255,255,255,0.65); letter-spacing: 0.14em; }
.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 20px; font-size: 12px; color: rgba(255,255,255,0.75); }
.topbar-live { color: #fff; font-weight: 700; letter-spacing: 0.06em; }
#sse-indicator { font-size: 14px; opacity: 0.3; transition: opacity 0.4s, filter 0.4s; }
#sse-indicator.connected { opacity: 1; filter: drop-shadow(0 0 4px #00e676); }
#sse-indicator.error { opacity: 0.6; filter: drop-shadow(0 0 4px #ff3d3d); }
.topbar-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.2); }
.topbar-nav { display: flex; gap: 6px; }
.topbar-link { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; color: rgba(255,255,255,0.7); text-decoration: none; padding: 4px 10px; border: 1px solid rgba(255,255,255,0.2); border-radius: 3px; transition: color 0.15s, border-color 0.15s; }
.topbar-link:hover { color: #fff; border-color: rgba(255,255,255,0.5); }
.topbar-link--twitch:hover { color: #9146ff; border-color: #9146ff; }

/* DYNAMIC GRID WRAPPER */
#grid-wrapper { flex: 1; background: #000; padding: 4px; position: relative; overflow: hidden; min-height: 0; }

/* Base grid container */
.gg { width: 100%; height: 100%; gap: 4px; }

/* Layout variants */
.gg-1 { display: grid; grid-template-columns: 1fr; grid-template-rows: 1fr; }
.gg-2 { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr; }
.gg-3 { display: grid; grid-template-columns: 3fr 2fr; grid-template-rows: 1fr 1fr; }
.gg-3 #g-0 { grid-row: 1 / 3; }
.gg-4 { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
.gg-5 { display: flex; height: 100%; }
.gg-left  { flex: 1; display: flex; flex-direction: column; gap: 4px; }
.gg-right { flex: 1; display: flex; flex-direction: column; gap: 4px; margin-left: 4px; }
.gg-left .hcard, .gg-right .hcard { flex: 1; min-height: 0; }
.gg-6  { display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr; }
.gg-10 { display: grid; grid-template-columns: repeat(5, 1fr); grid-template-rows: 1fr 1fr; }

/* Compact slot — truncate last event to single line, keep stat bars */
.hcard.compact .hc-last { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* HERO CARD */
.hcard {
  background: var(--card); border: 1px solid var(--border);
  position: relative; overflow: hidden;
  display: grid; grid-template-rows: 4px auto 1fr auto;
  transform-origin: center center;
}
.hcard::after {
  content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.025) 0%, transparent 55%);
}
.hcard--loading { display: flex; align-items: center; justify-content: center; }
.hcard--loading::before {
  content: ''; width: 32px; height: 32px; border: 2px solid var(--border2);
  border-top-color: var(--muted); border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* CARD GOAL WASH */
.goal-wash {
  position: absolute; inset: 0; z-index: 20;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
  opacity: 0; pointer-events: none;
}
.goal-wash.active { animation: washCycle 5s ease forwards; }
@keyframes washCycle {
  0%   { opacity: 0; }
  8%   { opacity: 1; }
  80%  { opacity: 1; }
  100% { opacity: 0; }
}
.gwo-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.22em; color: rgba(255,255,255,0.75); text-transform: uppercase; }
.gwo-scorer  { font-family: 'Oswald', sans-serif; font-size: clamp(32px, 5vw, 56px); font-weight: 700; line-height: 1; color: #fff; text-shadow: 0 2px 16px rgba(0,0,0,0.5); }
.gwo-goal-num { font-family: 'Oswald', sans-serif; font-size: clamp(14px, 2vw, 22px); color: rgba(255,255,255,0.7); letter-spacing: 0.06em; }
.gwo-assists  { font-size: clamp(10px, 1.2vw, 14px); color: rgba(255,255,255,0.75); }
.gwo-divider  { width: 48px; height: 1px; background: rgba(255,255,255,0.3); margin: 4px 0; }
.gwo-score    { font-family: 'Oswald', sans-serif; font-size: clamp(20px, 3vw, 32px); font-weight: 700; color: #fff; }
.gwo-context  { font-size: 11px; color: rgba(255,255,255,0.6); letter-spacing: 0.1em; }

/* CARD ENTER/EXIT TRANSITIONS */
.hcard.exiting { opacity: 0; transform: scale(0.96); transition: opacity 0.35s ease, transform 0.35s ease; }
.hcard.entering { animation: cardEnter 0.45s ease forwards; }
@keyframes cardEnter { from { opacity: 0; transform: scale(1.025); } to { opacity: 1; transform: scale(1); } }

/* Card sub-elements */
.hc-accent { width: 100%; }
.hc-head { display: flex; align-items: center; justify-content: space-between; padding: 10px 20px 0; position: relative; z-index: 2; }
.hc-status { font-size: clamp(13px, 1.2vw, 17px); font-weight: 700; letter-spacing: 0.08em; display: flex; align-items: center; gap: 8px; }
.hc-status.live { color: var(--cyan); }
.hc-status.final { color: var(--muted); }
.hc-status.ot { color: var(--orange); }
.hc-status.scheduled { color: var(--yellow); }
.hc-status.intermission { color: var(--blue); }
.status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cyan); position: relative; flex-shrink: 0; }
.status-dot::after { content: ''; position: absolute; inset: -2px; border-radius: 50%; border: 1.5px solid var(--cyan); animation: ringPulse 1.8s ease-out infinite; }
.hc-status.final .status-dot,
.hc-status.scheduled .status-dot { background: var(--muted); }
.hc-status.final .status-dot::after,
.hc-status.scheduled .status-dot::after { display: none; }
/* Intermission: amber dot, no pulse (game is paused) */
.hc-status.intermission .status-dot { background: var(--yellow); }
.hc-status.intermission .status-dot::after { display: none; }
@keyframes ringPulse { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(1.9); opacity: 0; } }
.hc-badges { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
.badge { font-size: 9px; font-weight: 700; letter-spacing: 0.08em; padding: 2px 8px; border-radius: 10px; border: 1px solid; display: inline-flex; align-items: center; line-height: 1; }
.badge.pp   { color: var(--yellow); border-color: rgba(255,202,40,0.35); background: rgba(255,202,40,0.07); }
.badge.pk   { color: var(--red);    border-color: rgba(255,61,61,0.4);   background: rgba(255,61,61,0.08);  }
.badge.adv  { color: var(--green);  border-color: rgba(0,230,118,0.4);  background: rgba(0,230,118,0.08);  }
.badge.en   { color: var(--orange); border-color: rgba(255,152,0,0.4);  background: rgba(255,152,0,0.10);  }
.badge.hot  { color: var(--orange); border-color: rgba(255,152,0,0.35);  background: rgba(255,152,0,0.07);  }
.badge.close{ color: var(--red);    border-color: rgba(255,61,61,0.35);  background: rgba(255,61,61,0.07);  }
.badge.ot   { color: var(--orange); border-color: rgba(255,152,0,0.5);  background: rgba(255,152,0,0.12);  }

/* WIN PROBABILITY TEXT */
.hc-wp-text { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 0 2px; }
.hc-wp-away, .hc-wp-home { font-size: clamp(12px, 1.4vw, 16px); font-weight: 800; color: var(--text); font-variant-numeric: tabular-nums; white-space: nowrap; }
.hc-wp-mid { font-size: clamp(7px, 0.8vw, 9px); font-weight: 600; letter-spacing: 0.1em; color: var(--muted); text-transform: uppercase; }
/* STAT BARS (SOG / xG) */
.hc-stat-wrap { display: flex; flex-direction: column; gap: 2px; width: 100%; }
.hc-stat-bar { display: flex; align-items: center; gap: 5px; width: 100%; }
.hc-sb-val { font-family: 'Oswald', sans-serif; font-size: clamp(10px, 1.1vw, 13px); font-weight: 700; color: var(--text); min-width: 20px; font-variant-numeric: tabular-nums; }
.hc-sb-val.away { text-align: right; }
.hc-sb-val.home { text-align: left; }
.hc-sb-track { flex: 1; height: 5px; border-radius: 3px; overflow: hidden; background: var(--border2); }
.hc-sb-fill { height: 100%; }
.hc-sb-label { font-size: 7px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.28); text-align: center; }
.hc-body { display: flex; align-items: center; justify-content: center; padding: 4px 28px 0; position: relative; z-index: 2; }
.hc-team { display: flex; flex-direction: column; align-items: center; gap: 8px; flex: 1; }
.hc-logo { width: clamp(56px, 8vw, 100px); height: clamp(56px, 8vw, 100px); object-fit: contain; }
.hc-logo.dim { opacity: 0.3; filter: grayscale(0.3); }
.hc-abbr { font-family: 'Oswald', sans-serif; font-size: clamp(22px, 3.5vw, 40px); font-weight: 700; }
.hc-abbr.lead { color: var(--white); } .hc-abbr.trail { color: var(--muted); } .hc-abbr.tie { color: var(--white); }
.hc-name { font-size: clamp(8px, 0.9vw, 10px); color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
.hc-score-center { display: flex; flex-direction: column; align-items: center; gap: 8px; min-width: clamp(100px, 14vw, 180px); }
.hc-nums { display: flex; align-items: center; gap: 12px; }
.hc-n { font-family: 'Oswald', sans-serif; font-size: clamp(52px, 8vw, 100px); font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums; }
.hc-n.lead { color: var(--white); } .hc-n.trail { color: var(--muted); } .hc-n.tie { color: var(--white); }
.hc-sep { font-family: 'Oswald', sans-serif; font-size: clamp(28px, 4vw, 50px); color: var(--border2); }
.hc-foot { padding: 6px 20px 10px; display: flex; flex-direction: column; gap: 4px; position: relative; z-index: 2; }
.hc-last-label { display: flex; align-items: center; gap: 8px; }
.hc-last-label span { font-size: 7px; font-weight: 700; letter-spacing: 0.16em; color: var(--dim); text-transform: uppercase; white-space: nowrap; }
.hc-last-label::before, .hc-last-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }
.hc-last { font-size: clamp(10px, 1.1vw, 12px); color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hc-last strong { color: var(--text); }
.hc-stars { display: flex; justify-content: space-around; padding: 4px 0 2px; }
.hc-star { display: flex; flex-direction: column; align-items: center; gap: 2px; flex: 1; }
.hc-star-num { font-size: 9px; color: var(--dim); }
.hc-star-name { font-size: clamp(9px, 1vw, 11px); font-weight: 700; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 95%; text-align: center; }

/* RECENT EVENTS FEED */
.hc-recent { padding: 6px 20px 10px; display: flex; flex-direction: column; gap: 3px; position: relative; z-index: 2; }
.hc-recent-label { display: flex; align-items: center; gap: 8px; margin-bottom: 2px; }
.hc-recent-label span { font-size: 7px; font-weight: 700; letter-spacing: 0.16em; color: var(--dim); text-transform: uppercase; white-space: nowrap; }
.hc-recent-label::before, .hc-recent-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }
.hc-recent-row { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
.hc-recent-row:nth-child(2) { opacity: 1.0; }
.hc-recent-row:nth-child(3) { opacity: 0.65; }
.hc-recent-row:nth-child(4) { opacity: 0.35; }
.hc-recent-icon { font-size: 9px; width: 14px; flex-shrink: 0; }
.hc-recent-desc { font-size: clamp(9px, 1vw, 11px); color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
.hc-recent-time { font-size: 9px; color: var(--dim); white-space: nowrap; flex-shrink: 0; }

/* TICKER */
.ticker-strip { height: 28px; background: #000; display: flex; align-items: center; overflow: hidden; border-top: 1px solid #1a1a1a; border-bottom: 1px solid #1a1a1a; }
.ticker-lbl { flex-shrink: 0; height: 100%; background: #111; border-right: 2px solid var(--red); padding: 0 14px; display: flex; align-items: center; font-size: 9px; font-weight: 700; letter-spacing: 0.16em; color: var(--red); white-space: nowrap; transition: color 0.3s, border-color 0.3s; }
.ticker-lbl.recap { color: var(--muted); border-right-color: #444; }
.ticker-content { flex: 1; overflow: hidden; white-space: nowrap; }
.ticker-inner { display: inline-block; animation: scroll 60s linear infinite; padding-left: 40%; }
@keyframes scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.ticker-inner span { display: inline-block; font-size: 12px; color: #aaa; margin-right: 56px; }
.ticker-inner span strong { color: #fff; }
.ti-goal strong { color: var(--cyan); }
.ti-goal em { font-style: normal; color: var(--yellow); font-size: 10px; font-weight: 700; vertical-align: middle; }
.ti-penalty strong { color: var(--yellow); }
.ti-final strong { color: var(--muted); }
.ti-sep { color: #444; margin: 0 20px; font-size: 8px; }

/* BOTTOM BAR */
.bottombar { height: 96px; background: #0a0a0a; border-top: 1px solid var(--border); display: flex; align-items: center; padding: 0 16px; gap: 8px; overflow-x: auto; overflow-y: hidden; }
.bb-label { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; color: var(--muted); white-space: nowrap; margin-right: 4px; flex-shrink: 0; }
.bc { flex: 0 0 220px; height: 72px; background: #111; border: 1px solid var(--border); border-radius: 3px; display: flex; flex-direction: column; overflow: hidden; }
.bc.entering-bb { animation: bbEnter 0.45s ease forwards; }
@keyframes bbEnter { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.bc-wpbar { height: 3px; width: 100%; flex-shrink: 0; }
.bc-inner { display: flex; align-items: center; padding: 0 8px; flex: 1; }
.bc-team { flex: 0 0 60px; display: flex; align-items: center; justify-content: center; }
.bc-logo { width: 52px; height: 52px; object-fit: contain; }
.bc-logo.dim { opacity: 0.28; filter: grayscale(0.4); }
.bc-center { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; }
.bc-scores { display: flex; align-items: center; gap: 5px; }
.bc-n { font-family: 'Oswald', sans-serif; font-size: 26px; font-weight: 500; color: var(--white); line-height: 1; font-variant-numeric: tabular-nums; }
.bc-n.dim { color: var(--muted); }
.bc-dash { font-family: 'Oswald', sans-serif; font-size: 17px; font-weight: 500; color: var(--border2); }
.bc-status { font-size: 9px; font-weight: 600; letter-spacing: 0.08em; }
.bc-status.live { color: var(--cyan); }
.bc-status.ot   { color: var(--orange); }
.bc-status.int  { color: var(--blue); }
.bc-status.pre  { color: var(--yellow); font-size: 11px; letter-spacing: 0.03em; }
.bc-status.final { color: var(--muted); }
.bc-status.goal  { color: var(--cyan); }
.bc.bb-goal-flash { border-color: var(--cyan); box-shadow: 0 0 0 1px var(--cyan), inset 0 0 16px rgba(0,229,255,0.08); animation: bbFlash 4s ease forwards; }
@keyframes bbFlash { 0%,60% { border-color: var(--cyan); box-shadow: 0 0 0 1px var(--cyan), inset 0 0 16px rgba(0,229,255,0.08); } 100% { border-color: var(--border); box-shadow: none; } }


/* CATCHUP INDICATOR */
#catchup-pill {
  position: fixed; top: 12px; left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,0.85); border: 1px solid var(--border2);
  color: var(--muted); font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
  padding: 6px 16px; border-radius: 20px; z-index: 200;
  opacity: 0; transition: opacity 0.2s ease; pointer-events: none;
  white-space: nowrap;
}
#catchup-pill.show { opacity: 1; }

/* DEBUG OVERLAY */
.dbg-chip {
  position: absolute; top: 6px; right: 8px; z-index: 50;
  background: rgba(0,0,0,0.75); border: 1px solid rgba(255,202,40,0.4);
  color: var(--yellow); font-size: 10px; font-weight: 700; letter-spacing: 0.06em;
  padding: 2px 6px; border-radius: 4px; pointer-events: none; font-family: monospace;
}
#dbg-panel {
  position: fixed; bottom: 60px; right: 12px; z-index: 500;
  background: rgba(0,0,0,0.88); border: 1px solid var(--border2);
  border-radius: 8px; padding: 10px 12px; min-width: 280px; max-height: 320px; overflow-y: auto;
  font-family: monospace; font-size: 11px; color: var(--muted);
}
.dbg-title { font-weight: 700; color: var(--yellow); letter-spacing: 0.1em; margin-bottom: 8px; font-size: 10px; }
#dbg-panel table { border-collapse: collapse; width: 100%; }
#dbg-panel td { padding: 2px 6px 2px 0; white-space: nowrap; }
#dbg-panel td:first-child { color: var(--cyan); font-weight: 700; width: 28px; }
#dbg-panel td:nth-child(3) { color: var(--white); text-align: right; width: 52px; }
#dbg-panel td:nth-child(4) { color: var(--muted); font-size: 9px; max-width: 120px; overflow: hidden; text-overflow: ellipsis; }
.dbg-grid td:nth-child(2) { color: var(--white); }
.dbg-bench td:nth-child(2) { color: #555; }

/* ── MODAL ─────────────────────────────────────────────── */
.modal-overlay { position:fixed; inset:0; z-index:500; display:flex; align-items:flex-end; justify-content:center; }
.modal-backdrop { position:absolute; inset:0; background:rgba(0,0,0,0.82); }
