---
import Nav from '../components/Nav.astro';
import ThemeScript from '../components/ThemeScript.astro';
import SentryInit from '../components/SentryInit.astro';
import Fonts from '../components/Fonts.astro';
import { pickTeamColor } from '../lib/team-colors';
import GameModal from '../components/GameModal.astro';
import StatusPill from '../components/StatusPill.astro';
import Badge from '../components/Badge.astro';
import GlobalPlayerSearch, { type PlayerSearchItem } from '../components/react/GlobalPlayerSearch';
import { loadPlayers, loadGoalies } from '../lib/stats-loader';
import { getScoreboard, getGameFlow } from '../lib/hgb-api-client';

// Combined skater + goalie index (mirrors StatsLayout's Cmd+K omni-box so the
// home-page search matches it — goalies were previously missing here).
const playerSearchIndex: PlayerSearchItem[] = [
  ...loadPlayers().map(p => ({
    display_name: p.display_name,
    first_name:   p.first_name,
    last_name:    p.last_name,
    team_abbrev:  p.team_abbrev,
    pos:          p.pos,
    gp:           p.gp,
    slug:         p.slug,
    search_text:  `${p.first_name} ${p.last_name} ${p.display_name} ${p.team_abbrev}`.toLowerCase(),
    type:         'skater' as const,
  })),
  ...loadGoalies().map(g => ({
    display_name: g.name,
    first_name:   g.first_name,
    last_name:    g.last_name,
    team_abbrev:  g.team_abbrev,
    pos:          'G',
    gp:           g.gp ?? 0,
    slug:         g.slug || `goalie-${g.goalie_id}`,
    search_text:  `${g.first_name} ${g.last_name} ${g.name} ${g.team_abbrev} goalie g`.toLowerCase(),
    type:         'goalie' as const,
  })),
];

// ── Types ─────────────────────────────────────────────────────────────────────

type SBGame = {
  game_id: string; game_state: string; venue: string | null; start_time_utc: string | null;
  away_team: { abbrev: string; score: number; short_name: string; name: string };
  home_team: { abbrev: string; score: number; short_name: string; name: string };
  clock: { period: number | null; time_remaining: string | null; in_intermission: boolean | null };
  stats: { win_probability: { away: number | null; home: number | null }; xg_5v5: { away: number | null; home: number | null } };
  xg_home: number | null;
  xg_away: number | null;
  three_stars: { star: number; player_name: string; player_last_name: string; team_abbrev: string }[] | null;
};
type Scoreboard = { date: string; games: SBGame[]; previous_day: { hockey_date: string; games: SBGame[] } };
type FlowPoint = { t: number; wp: number | null };
type FlowGoal  = { t: number; is_home: boolean; score: string; scorer: string; strength: string; wp_delta?: number };
type FlowData  = { game_id: string; points: FlowPoint[]; goals: FlowGoal[] };
type GoalieLead = { last_name: string; record: string };
type TonightEntry = { game_id: string; awayAbbr: string; homeAbbr: string; startET: string; awayGoalie: GoalieLead | null; homeGoalie: GoalieLead | null };

// ── Helpers ───────────────────────────────────────────────────────────────────

const fmtDate = (iso: string) => new Date(iso + 'T12:00:00Z').toLocaleDateString('en-US', { weekday: 'short', month: 'long', day: 'numeric', timeZone: 'UTC' });
const fmtET   = (utc: string | null) => utc ? new Intl.DateTimeFormat('en-US', { timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit', hour12: true }).format(new Date(utc)) : '';
const gsl = (g: SBGame) => { const s = g.game_state; if (s === 'live') return 'live'; if (s === 'intermission') return 'intermission'; if (s === 'final' || s === 'game-end') return 'final'; return 'pre'; };

// ── Fetch scoreboard ──────────────────────────────────────────────────────────

let sb: Scoreboard | null = null;
sb = (await getScoreboard()) as Scoreboard | null;

const todayGames = sb?.games ?? [];
const prevGames  = sb?.previous_day?.games ?? [];
const todayDate  = sb?.date ?? new Date().toISOString().slice(0, 10);
const prevDate   = sb?.previous_day?.hockey_date ?? '';

// ── Goalie leaders for tonight's pre-game games ───────────────────────────────

async function fetchGoalies(gameId: string, awayAbbr: string, homeAbbr: string): Promise<TonightEntry> {
  const base: TonightEntry = { game_id: gameId, awayAbbr, homeAbbr, startET: '', awayGoalie: null, homeGoalie: null };
  try {
    const r = await fetch(`https://api-web.nhle.com/v1/gamecenter/${gameId}/landing`);
    if (!r.ok) return base;
    const d = await r.json() as Record<string, unknown>;
    const gc = ((d.matchup as Record<string,unknown> ?? {}).goalieComparison ?? {}) as Record<string, unknown>;
    const extract = (side: Record<string, unknown>): GoalieLead | null => {
      const leaders = (side.leaders ?? []) as Array<Record<string, unknown>>;
      const g = leaders.find(l => l.gamesPlayed) ?? leaders[0];
      if (!g) return null;
      return { last_name: ((g.lastName as Record<string,string>|undefined)?.default ?? String(g.player_last_name ?? '')), record: String(g.record ?? '') };
    };
    return { ...base, awayGoalie: extract((gc.awayTeam ?? {}) as Record<string,unknown>), homeGoalie: extract((gc.homeTeam ?? {}) as Record<string,unknown>) };
  } catch { return base; }
}

const tonightGames: TonightEntry[] = await Promise.all(
  todayGames.filter(g => gsl(g) === 'pre').map(g =>
    fetchGoalies(g.game_id, g.away_team.abbrev, g.home_team.abbrev).then(e => ({ ...e, startET: fmtET(g.start_time_utc) }))
  )
);

// ── Featured game (yesterday's best by WP swing) ──────────────────────────────

const wpSwing = (g: SBGame) => { const w = g.stats.win_probability; return (w.away !== null && w.home !== null) ? Math.abs(w.away - 0.5) : 0; };
let featGame: SBGame | null = null;
const pool = prevGames.length > 0 ? prevGames : todayGames;
if (pool.length > 0) {
  const withStars = pool.filter(g => g.three_stars?.length);
  const candidates = withStars.length > 0 ? withStars : pool;
  featGame = candidates.reduce((best, g) => wpSwing(g) > wpSwing(best) ? g : best, candidates[0]);
}

let flowData: FlowData | null = null;
if (featGame) {
  flowData = (await getGameFlow(featGame.game_id)) as FlowData | null;
}

// ── WP chart computation ──────────────────────────────────────────────────────

const SVG_W = 760, SVG_H = 240, GSECS = 3600;
const wpPts: Array<{ x: number; y: number }> = [];
if (flowData) {
  const seen = new Map<number, FlowPoint>();
  [...flowData.points].filter(p => p.wp !== null && p.t >= 0 && p.t <= GSECS).sort((a, b) => a.t - b.t).forEach(p => seen.set(p.t, p));
  for (const p of [...seen.values()].sort((a, b) => a.t - b.t)) {
    wpPts.push({ x: +((p.t / GSECS) * SVG_W).toFixed(1), y: +((1 - (p.wp ?? 0.5)) * SVG_H).toFixed(1) });
  }
}

const polyStr = wpPts.map(p => `${p.x},${p.y}`).join(' ');
const pFirst = wpPts[0], pLast = wpPts[wpPts.length - 1];

// Two-color fills: away color fills from top down to WP line; home fills from WP line to bottom
const awayFill = wpPts.length >= 2
  ? `M${pFirst.x},0 ${wpPts.map(p => `L${p.x},${p.y}`).join(' ')} L${pLast.x},0 Z`
  : '';
const homeFill = wpPts.length >= 2
  ? `M${pFirst.x},${pFirst.y} ${wpPts.slice(1).map(p => `L${p.x},${p.y}`).join(' ')} L${pLast.x},${SVG_H} L${pFirst.x},${SVG_H} Z`
  : '';

const P1x = +((1200 / GSECS) * SVG_W).toFixed(1);
const P2x = +((2400 / GSECS) * SVG_W).toFixed(1);

// Goal dots
const featAC = featGame ? pickTeamColor(featGame.away_team.abbrev) : '#0d0d14';
const featHC = featGame ? pickTeamColor(featGame.home_team.abbrev) : '#0d0d14';
type GDot = { cx: number; cy: number; color: string; delta: number | null; label: string; isAbove: boolean };
const goalDots: GDot[] = [];
if (flowData && featGame) {
  for (const g of flowData.goals) {
    const cx = +((g.t / GSECS) * SVG_W).toFixed(1);
    let best = wpPts[0];
    for (const p of wpPts) { if ((p.x / SVG_W) * GSECS <= g.t) best = p; }
    const cy = best?.y ?? SVG_H / 2;
    const delta = g.wp_delta != null ? Math.round(g.wp_delta * 100) : null;
    const isAbove = delta === null || delta >= 0;
    const abbrev = g.is_home ? featGame.home_team.abbrev : featGame.away_team.abbrev;
    const label = `${abbrev} ${g.score ?? ''}${delta != null ? ` · ${delta >= 0 ? '+' : ''}${delta}%` : ''}`;
    goalDots.push({ cx, cy, color: g.is_home ? featHC : featAC, delta, label, isAbove });
  }
}

// ── Editorial copy ────────────────────────────────────────────────────────────

function editCopy(g: SBGame, contested = false) {
  const aw = g.away_team.score > g.home_team.score;
  const win = aw ? g.away_team.abbrev : g.home_team.abbrev;
  const lose = aw ? g.home_team.abbrev : g.away_team.abbrev;
  const xgW = aw ? (g.xg_away ?? g.stats.xg_5v5.away ?? 0) : (g.xg_home ?? g.stats.xg_5v5.home ?? 0);
  const xgL = aw ? (g.xg_home ?? g.stats.xg_5v5.home ?? 0) : (g.xg_away ?? g.stats.xg_5v5.away ?? 0);
  const winWP = Math.round(((aw ? g.stats.win_probability.away : g.stats.win_probability.home) ?? 0.5) * 100);
  const isOT = (g.clock?.period ?? 0) >= 4;
  const isUpset = xgL > xgW + 0.3;
  if (isOT) return { tag: 'Overtime thriller', hed: `${win} SURVIVES IN OVERTIME`, dek: `${win} needed extra time to close it out, finishing with a ${winWP}% win probability after sixty tight minutes couldn't decide it.` };
  if (isUpset) return { tag: 'Upset by xG', hed: `${win} WINS THE GAME. ${lose} WINS THE CHANCES.`, dek: `${lose} out-chanced ${win} on expected goals ${xgL.toFixed(2)} to ${xgW.toFixed(2)}, but the scoreboard disagreed. The model flagged this one all night.` };
  if (winWP >= 90 && !contested) return { tag: 'Dominant win', hed: `${win} NEVER GAVE IT A CHANCE`, dek: `Wire-to-wire — ${win} built an early lead and pushed their win probability past ${winWP}% before the third period began.` };
  if (winWP >= 90 && contested) return { tag: 'Dominant finish', hed: `${win} TAKES CONTROL LATE`, dek: `${win} faced real pressure during regulation — the lead changed hands — but pulled away to finish at ${winWP}% win probability.` };
  return { tag: 'Competitive game', hed: `${win} HOLDS OFF ${lose}`, dek: `${win} finished at ${winWP}% win probability in a competitive game the model tracked closely from start to finish.` };
}

// Was the winner ever trailing on WP? (loser's WP > 50% at any point)
const awayWonFeat = featGame ? featGame.away_team.score > featGame.home_team.score : false;
const wasContested = wpPts.length >= 5 && (
  awayWonFeat
    ? wpPts.some(p => p.y > SVG_H / 2)  // away won — was home ever favored?
    : wpPts.some(p => p.y < SVG_H / 2)  // home won — was away ever favored?
);
const featCopy = featGame ? editCopy(featGame, wasContested) : null;
const featWpAway = featGame?.stats.win_probability.away != null ? Math.round(featGame.stats.win_probability.away * 100) : null;
const featWpHome = featGame?.stats.win_probability.home != null ? Math.round(featGame.stats.win_probability.home * 100) : null;
const featXgA = featGame?.xg_away ?? featGame?.stats.xg_5v5.away ?? null;
const featXgH = featGame?.xg_home ?? featGame?.stats.xg_5v5.home ?? null;
const featStars = featGame?.three_stars ?? [];
const featXgTotal = (featXgA ?? 0) + (featXgH ?? 0);
const awayXgShare = featXgTotal > 0 ? Math.round((featXgA ?? 0) / featXgTotal * 100) : 50;
const homeXgShare = 100 - awayXgShare;
const featIsOT = (featGame?.clock?.period ?? 0) >= 4;
const featAwayWins = (featGame?.away_team.score ?? 0) > (featGame?.home_team.score ?? 0);
const featDateLabel = prevDate ? fmtDate(prevDate) : 'Last night';

// ── Init data for client ──────────────────────────────────────────────────────

const initData = {
  date: todayDate,
  games: todayGames.map(g => ({ game_id: g.game_id, game_state: g.game_state, venue: g.venue, start_time_utc: g.start_time_utc, away_team: g.away_team, home_team: g.home_team, clock: g.clock, stats: g.stats })),
  previous_day: { hockey_date: prevDate, games: prevGames.map(g => ({ game_id: g.game_id, game_state: g.game_state, away_team: g.away_team, home_team: g.home_team, clock: g.clock, stats: g.stats })) },
  tonight: tonightGames,
};
---
<!doctype html>
<html lang="en">
<head>
<ThemeScript />
<SentryInit />
<Fonts />
<meta charset="utf-8" />
<title>HockeyGameBot — 32 bots, every game, all season</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="description" content="Live NHL scores and advanced analytics from 32 automated bots — win probability, expected goals, and more." />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="HockeyGameBot" />
<meta property="og:title" content="HockeyGameBot · 32 Bots, Every Game, All Season" />
<meta property="og:description" content="Live NHL scores and advanced analytics from 32 automated bots." />
<meta property="og:url" content="https://hockeygamebot.com/" />
<meta property="og:image" content="https://hockeygamebot.com/og/default.png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@hockeygamebot" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
<link rel="apple-touch-icon" href="/favicon-180x180.png" />
<style is:global>
/* ── TOKENS ──────────────────────────────────────────────────────────────────── */
:root {
  --bg:      #EFEEE8;
  --bg-2:    #E8E7E0;
  --surface: #FFFFFF;
  --ink:     #0d0d14;
  --ink-86:  rgba(13,13,20,0.86);
  --ink-72:  rgba(13,13,20,0.72);
  --ink-56:  rgba(13,13,20,0.56);
  --ink-48:  rgba(13,13,20,0.48);
  --ink-32:  rgba(13,13,20,0.32);
  --ink-20:  rgba(13,13,20,0.20);
  --ink-14:  rgba(13,13,20,0.14);
  --ink-10:  rgba(13,13,20,0.10);
  --ink-06:  rgba(13,13,20,0.06);
  --ink-03:  rgba(13,13,20,0.03);
  --red:     #E8002D;
  /* Status pill color tokens — consumed by StatusPill.astro / Badge.astro */
  --status-live:      #00E5FF;
  --status-final:     var(--ink-48);
  --status-ot:        #FF9800;
  --status-scheduled: var(--ink-48);
  --grid-line: rgba(13,13,20,0.04);
  --display: "Barlow Condensed", sans-serif;
  --body:    "Barlow", sans-serif;
  --mono:    "JetBrains Mono", monospace;
  /* Type scale — shared across all editorial pages */
  --type-jumbo:   clamp(52px, 8vw, 96px);
  --type-display: clamp(40px, 5vw, 64px);
  --type-section: clamp(26px, 3.5vw, 44px);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { background: var(--bg); color: var(--ink); font-family: var(--body); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }
.wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

/* ── TICKER ──────────────────────────────────────────────────────────────────── */
.ticker { background: var(--ink); overflow: hidden; border-bottom: 1px solid rgba(255,255,255,0.06); height: 38px; display: flex; align-items: center; }
.ticker-track { display: inline-flex; white-space: nowrap; animation: ticker 90s linear infinite; }
.ticker-track:hover { animation-play-state: paused; }
@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.tk-item { display: inline-flex; align-items: center; gap: 7px; font-family: var(--mono); font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.48); letter-spacing: 0.04em; padding: 0 24px; border-right: 1px solid rgba(255,255,255,0.06); }
.tk-item .live-pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; animation: pip 1.4s infinite; }
.tk-item .t-away, .tk-item .t-home { font-weight: 600; }
.tk-item .score  { color: #fff; font-weight: 600; }
.tk-item .sep    { color: rgba(255,255,255,0.20); }
.tk-item .live   { color: var(--red); font-weight: 600; }
.tk-item .final  { color: rgba(255,255,255,0.36); }

/* ── HERO ────────────────────────────────────────────────────────────────────── */
.hero {
  position: relative; overflow: hidden;
  padding: 48px 0 56px;
  border-bottom: 2px solid var(--ink);
  background-color: var(--bg);
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 96px 96px;
  transition: background-color .4s ease;
}
/* dark flip removed — hero stays editorial light in all states */

.hero-ghost {
  position: absolute; pointer-events: none; user-select: none; z-index: 0;
  font-family: var(--display); font-weight: 800; font-size: 520px; line-height: 0.86;
  text-transform: uppercase; letter-spacing: -0.02em; white-space: nowrap;
  color: rgba(13,13,20,0.07);
  top: 50%; left: 50%; transform: translate(-50%, -50%);
  transition: color .4s;
}
/* corner registration marks */
.hero-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.corner { position: absolute; width: 16px; height: 16px; }
.corner.tl { top: 16px; left: 16px; border-top: 1px solid rgba(13,13,20,0.20); border-left: 1px solid rgba(13,13,20,0.20); }
.corner.tr { top: 16px; right: 16px; border-top: 1px solid rgba(13,13,20,0.20); border-right: 1px solid rgba(13,13,20,0.20); }
.corner.bl { bottom: 16px; left: 16px; border-bottom: 1px solid rgba(13,13,20,0.20); border-left: 1px solid rgba(13,13,20,0.20); }
.corner.br { bottom: 16px; right: 16px; border-bottom: 1px solid rgba(13,13,20,0.20); border-right: 1px solid rgba(13,13,20,0.20); }

.hero-inner { position: relative; z-index: 2; }
.hero-top {
  display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
  margin-bottom: 28px;
  font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em;
  color: var(--ink-48);
}
.hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--body); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; }
.hero-meta { font-size: 10px; opacity: 0.6; }
#hero-slot { position: relative; z-index: 2; }

@keyframes pip { 0%,100% { opacity:1; } 50% { opacity:0.25; } }

/* ── STATE WRAPPER ───────────────────────────────────────────────────────────── */
.state-empty { background: var(--surface); border: 1px solid var(--ink-14); padding: 52px 40px; text-align: center; position: relative; }
.state-big { font-family: var(--display); font-weight: 800; font-size: var(--type-jumbo); line-height: 0.92; letter-spacing: -0.01em; text-transform: uppercase; margin-bottom: 16px; }
.state-big em { font-style: normal; color: var(--ink-32); }
.state-lead { font-size: 16px; color: var(--ink-72); max-width: 520px; margin: 0 auto 18px; line-height: 1.5; }
.state-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.06em; }

/* ── PRE-GAME CARD GRID ──────────────────────────────────────────────────────── */
.pregame-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 10px; margin-top: 24px; align-items: stretch; }
.pregame-card { background: var(--surface); border: 1px solid var(--ink-14); box-shadow: 0 1px 3px rgba(13,13,20,0.06); display: flex; flex-direction: column; overflow: hidden; min-height: 168px; }
.pregame-card-bar { height: 3px; display: flex; flex-shrink: 0; }
.pregame-card-bar .a, .pregame-card-bar .h { flex: 1; }
.pregame-card-inner { padding: 13px 14px 10px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
.pregame-card-matchup { display: flex; align-items: center; justify-content: space-between; gap: 4px; }
.pregame-card-team { display: flex; align-items: center; gap: 6px; flex: 1; }
.pregame-card-team.right { justify-content: flex-end; }
.pregame-logo { width: 30px; height: 30px; object-fit: contain; flex-shrink: 0; }
.pregame-card-abbr { font-family: var(--display); font-weight: 800; font-size: 24px; letter-spacing: 0.02em; line-height: 1; }
.pregame-card-mid { text-align: center; flex-shrink: 0; padding: 0 6px; }
.pregame-card-time { font-family: var(--display); font-weight: 800; font-size: 16px; color: var(--ink); line-height: 1; letter-spacing: 0.02em; white-space: nowrap; }
.pregame-card-tz { font-family: var(--mono); font-size: 8.5px; color: var(--ink-32); margin-top: 3px; letter-spacing: 0.08em; text-transform: uppercase; }
.pregame-card-goalies { font-family: var(--mono); font-size: 12px; color: var(--ink-48); letter-spacing: 0.02em; display: flex; flex-direction: column; gap: 3px; border-top: 1px solid var(--ink-06); padding-top: 6px; }
.pregame-card-goalies .gl-row { display: flex; justify-content: space-between; align-items: baseline; }
.pregame-card-goalies .gl-name { color: var(--ink-72); }
.pregame-card-goalies .gl-rec  { color: var(--ink-32); font-size: 10.5px; }
.pregame-card-goalies .gl-tbd .gl-name,
.pregame-card-goalies .gl-tbd .gl-rec  { color: var(--ink-32); font-style: italic; }
.pregame-card-wp { margin-top: auto; display: flex; flex-direction: column; gap: 5px; padding-top: 8px; }
.pregame-card-wp-pcts { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10.5px; color: var(--ink-48); letter-spacing: 0.02em; }
.pregame-card-wp-pcts b { font-weight: 600; }
.pregame-card-foot { flex-shrink: 0; border-top: 1px solid var(--ink-06); padding: 6px 14px; font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.04em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ── POST-GAME FINALS GRID ───────────────────────────────────────────────────── */
.finals-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(195px, 1fr)); gap: 10px; margin-top: 24px; }
/* Game cards as <a> elements — block, no underline, inherit color */
a.bigcard, a.also-tile, a.final-card, a.result-card, a.feat-card, a.pregame-card { display: block; text-decoration: none; color: inherit; }
.final-card { background: var(--surface); border: 1px solid var(--ink-14); box-shadow: 0 1px 3px rgba(13,13,20,0.06); padding: 13px 15px 11px; position: relative; overflow: hidden; }
.final-card-bar { position: absolute; top: 0; left: 0; right: 0; height: 3px; display: flex; }
.final-card-bar .a, .final-card-bar .h { flex: 1; }
.final-card-tag { font-family: var(--body); font-weight: 700; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-48); display: flex; justify-content: space-between; margin-bottom: 9px; }
.final-row { display: flex; align-items: center; gap: 10px; padding: 3px 0; }
.final-logo { width: 36px; height: 36px; object-fit: contain; flex-shrink: 0; }
.final-abbr { font-family: var(--display); font-weight: 800; font-size: 16px; letter-spacing: 0.02em; }
.final-score { font-family: var(--mono); font-weight: 700; font-size: 28px; font-variant-numeric: tabular-nums; margin-left: auto; }
.final-score.win { color: var(--ink); }
.final-score.lose { color: var(--ink-32); }
.final-xg { font-family: var(--mono); font-size: 9.5px; color: var(--ink-48); letter-spacing: 0.02em; margin-top: 2px; }
.final-wp { margin-top: 10px; }
.final-wp-bar { height: 4px; background: var(--ink-06); overflow: hidden; }
.final-wp-label { font-family: var(--mono); font-size: 9.5px; color: var(--ink-48); letter-spacing: 0.03em; margin-bottom: 4px; }

/* ── LIVE BIGCARD ────────────────────────────────────────────────────────────── */
.bigcard { background: var(--surface); border: 1px solid var(--ink-14); overflow: hidden; }
.bigcard-accent { height: 3px; display: flex; flex-shrink: 0; }
.bigcard-accent .a, .bigcard-accent .h { flex: 1; }
.bigcard-head { display: flex; align-items: center; justify-content: space-between; padding: 12px 22px; border-bottom: 1px solid var(--ink-10); }
.bigcard-flag { font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; background: var(--red); color: #fff; padding: 4px 9px; }
.bigcard-clock { font-family: var(--mono); font-size: 12px; color: var(--ink-48); letter-spacing: 0.06em; }
.bigcard-clock .period { font-weight: 600; color: var(--ink); }

.score-block { display: grid; grid-template-columns: 1fr 1fr; position: relative; border-bottom: 1px solid var(--ink-10); }
.score-block::before { content: ""; position: absolute; left: 50%; top: 20px; bottom: 20px; width: 1px; background: var(--ink-10); }
.score-side { padding: 24px 28px 22px; display: grid; grid-template-columns: 76px 1fr; column-gap: 18px; align-items: center; }
.score-side.home { padding-left: 28px; }
.team-mark { width: 76px; height: 76px; background: var(--bg); border: 1px solid var(--ink-10); display: grid; place-items: center; position: relative; overflow: hidden; }
.team-mark img { width: 56px; height: 56px; object-fit: contain; }
.team-mark .swatch { position: absolute; left: 0; right: 0; bottom: 0; height: 3px; }
.team-id { display: flex; flex-direction: column; gap: 3px; }
.team-abbr { font-family: var(--display); font-weight: 800; font-size: 34px; line-height: 0.92; letter-spacing: 0.02em; }
.team-name { font-family: var(--display); font-weight: 700; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-32); }
.score-num {
  font-family: var(--display); font-weight: 800;
  font-size: 96px; line-height: 0.86; letter-spacing: -0.01em;
  font-variant-numeric: tabular-nums; justify-self: end;
}
.score-side.away .score-num { justify-self: end; padding-right: 24px; }
.score-side.home .score-num { justify-self: start; padding-left: 24px; }
.score-num.lead { color: var(--ink); }
.score-num.trail { color: var(--ink-32); }

.bigcard-body { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1px solid var(--ink-10); }
.bc-panel { padding: 18px 22px; }
.bc-panel.left { border-right: 1px solid var(--ink-10); }
.bc-panel-label { font-family: var(--display); font-weight: 700; font-size: 10px; letter-spacing: 0.20em; text-transform: uppercase; color: var(--ink-32); border-bottom: 1px solid var(--ink-06); padding-bottom: 8px; margin-bottom: 12px; }
.wp-stat-row { display: grid; grid-template-columns: 36px 40px 1fr; align-items: center; gap: 8px; margin-bottom: 8px; }
.wp-stat-abbr { font-family: var(--display); font-weight: 800; font-size: 14px; letter-spacing: 0.02em; }
.wp-stat-pct { font-family: var(--mono); font-weight: 600; font-size: 13px; color: var(--ink); }
.wp-stat-track { height: 5px; background: var(--ink-06); overflow: hidden; }
.wp-stat-fill { height: 100%; }
.xg-row { display: flex; align-items: baseline; gap: 10px; font-family: var(--mono); font-weight: 600; font-size: 18px; color: var(--ink); margin-bottom: 4px; }
.xg-row .vs { font-weight: 400; font-size: 11px; color: var(--ink-32); }

.bot-feed { display: flex; flex-direction: column; }
.feed-item { padding: 8px 0; border-bottom: 1px solid var(--ink-06); }
.feed-item:last-child { border-bottom: 0; }
.feed-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 2px; }
.feed-who { font-family: var(--mono); font-weight: 600; font-size: 10.5px; color: var(--ink); }
.feed-ts  { font-family: var(--mono); font-size: 9.5px; color: var(--ink-32); }
.feed-action { font-family: var(--mono); font-size: 10px; color: var(--ink-48); }
.feed-links { display: inline-flex; gap: 5px; margin-top: 3px; }
.feed-link { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; padding: 2px 6px; border: 1px solid var(--ink-14); color: var(--ink-32); text-decoration: none; }
.feed-link:hover { color: var(--ink); border-color: var(--ink); }

.bigcard-foot { display: flex; align-items: center; justify-content: space-between; padding: 10px 22px; border-top: 1px solid var(--ink-06); }
.publishers { display: flex; align-items: center; gap: 14px; }
.botchip { display: inline-flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 10.5px; font-weight: 600; color: var(--ink-48); }
.botchip .chip-dot { width: 5px; height: 5px; background: var(--red); border-radius: 50%; animation: pip 1.4s infinite; }
.foot-bots { font-family: var(--mono); font-size: 10px; color: var(--ink-32); letter-spacing: 0.06em; }

/* ── ALSO-LIVE TILES ─────────────────────────────────────────────────────────── */
.also-section { margin-top: 12px; }
.also-head { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; font-family: var(--body); font-weight: 700; font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-32); }
.also-rule { flex: 1; height: 1px; background: var(--ink-10); }
.also-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 8px; }
.also-tile { background: var(--surface); border: 1px solid var(--ink-14); padding: 11px 14px; }
.also-tile-matchup { display: flex; align-items: center; gap: 6px; font-family: var(--display); font-weight: 800; font-size: 16px; color: var(--ink); letter-spacing: 0.02em; margin-bottom: 4px; }
.also-tile-score { font-family: var(--mono); font-weight: 600; font-size: 13px; color: var(--ink); margin-left: auto; }
.also-tile-status { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.04em; }
.also-tile-status.live { color: var(--red); }

/* ── ANALYTICS ENTRY POINTS ─────────────────────────────────────────────────── */
.explore-section { padding: 56px 0 64px; border-bottom: 1px solid var(--ink-14); }
.explore-search { margin-bottom: 24px; }
.explore-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--ink-14); border: 1px solid var(--ink-14); }
.explore-tile { display: flex; flex-direction: column; gap: 0; padding: 28px 24px 24px; background: var(--surface); text-decoration: none; color: var(--ink); transition: background 0.15s; }
.explore-tile:hover { background: var(--bg); }
.explore-tile-label { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; }
.explore-tile-hed { font-family: var(--display); font-weight: 900; font-size: 28px; line-height: 0.95; text-transform: uppercase; letter-spacing: -0.01em; color: var(--ink); margin-bottom: 14px; }
.explore-tile-sub { font-size: 13px; color: var(--ink-72); line-height: 1.55; flex: 1; margin-bottom: 20px; }
.explore-tile-cta { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.08em; color: var(--ink-48); text-transform: uppercase; border-top: 1px solid var(--ink-10); padding-top: 14px; transition: color 0.15s; }
.explore-tile:hover .explore-tile-cta { color: var(--ink); }
@media (max-width: 860px) { .explore-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .explore-grid { grid-template-columns: 1fr; } }

/* ── FEATURED GAME ───────────────────────────────────────────────────────────── */
.featured { padding: 56px 0; border-bottom: 2px solid var(--ink); }
.section-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; margin-bottom: 32px; }
.section-title { font-family: var(--display); font-weight: 800; text-transform: uppercase; font-size: var(--type-section); line-height: 0.95; letter-spacing: -0.005em; }
.section-title .accent { color: var(--red); }
.section-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.06em; text-align: right; line-height: 1.6; }

.feature { display: grid; grid-template-columns: minmax(0,1fr) 320px; border: 1px solid var(--ink); background: var(--surface); }
.feature-main { padding: 28px 32px 32px; border-right: 1px solid var(--ink-14); }
.feature-side { padding: 28px 24px 32px; }

.feat-tag-pos { position:absolute; top:14px; left:16px; z-index:2; pointer-events:none; }
.feat-hed { font-family: var(--display); font-weight: 800; text-transform: uppercase; font-size: 34px; line-height: 0.98; margin-bottom: 10px; }
.feat-dek { font-size: 15px; color: var(--ink-72); max-width: 540px; margin-bottom: 22px; line-height: 1.55; }

.scoreline { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 20px; padding: 20px 0; border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink); margin-bottom: 16px; }
.sl-team { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 6px; }
.sl-logo { width: 80px; height: 80px; object-fit: contain; display: block; }
.sl-xg { font-family: var(--mono); font-size: 11px; color: var(--ink-48); letter-spacing: 0.04em; }
.sl-mid { font-family: var(--mono); font-size: 11px; color: var(--ink-48); text-transform: uppercase; letter-spacing: 0.1em; text-align: center; }
.sl-mid b { display: block; font-family: var(--display); font-weight: 800; color: var(--ink); font-size: 56px; line-height: 0.9; letter-spacing: -0.02em; margin: 6px 0; }

/* ── COUNTDOWN ───────────────────────────────────────────────────────────────── */
.countdown-inline { color: var(--ink); font-weight: 700; font-variant-numeric: tabular-nums; letter-spacing: 0; }

.breakdown { border-top: 1px solid var(--ink-14); margin-top: 4px; }
.breakdown summary { list-style: none; cursor: pointer; padding: 11px 0; display: flex; align-items: center; justify-content: space-between; font-family: var(--display); font-weight: 700; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--red); user-select: none; }
.breakdown summary::-webkit-details-marker { display: none; }
.chev { font-style: normal; transition: transform .2s; }
.breakdown[open] .chev { transform: rotate(180deg); }
.breakdown-body { padding-top: 16px; }

.wp-chart-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px; }
.wp-chart-label { font-family: var(--display); font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; font-size: 12px; }
.wp-chart-label .red { color: var(--red); }
.wp-chart-legend { font-family: var(--mono); font-size: 11px; color: var(--ink-48); display: flex; gap: 14px; }
.wp-chart-legend .swatch { display: inline-block; width: 9px; height: 9px; margin-right: 5px; vertical-align: middle; border-radius: 1px; }
.wp-svg { width: 100%; height: auto; display: block; }

.wp-readout { display: grid; grid-template-columns: repeat(3,1fr); border-top: 1px solid var(--ink-14); border-bottom: 1px solid var(--ink-14); margin: 12px 0; }
.wp-readout > div { padding: 12px 14px; border-right: 1px solid var(--ink-14); }
.wp-readout > div:last-child { border-right: 0; }
.wp-readout .lbl { font-family: var(--display); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; font-size: 10px; color: var(--ink-48); margin-bottom: 3px; }
.wp-readout .val { font-family: var(--mono); font-weight: 700; font-size: 20px; letter-spacing: -0.01em; }
.wp-readout .sub { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.04em; margin-top: 1px; }

.goals-impact h4 { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-48); padding: 8px 0 6px; }
.goal-row { display: grid; grid-template-columns: 80px 1fr auto; gap: 10px; align-items: baseline; padding: 6px 0; border-bottom: 1px solid var(--ink-06); font-size: 13px; }
.goal-row:last-child { border-bottom: 0; }
.goal-clock { font-family: var(--mono); font-size: 10px; color: var(--ink-48); letter-spacing: 0.04em; }
.goal-desc { color: var(--ink-72); }
.goal-desc small { font-family: var(--mono); font-size: 10px; color: var(--ink-32); margin-left: 6px; }
.goal-delta { font-family: var(--mono); font-weight: 600; font-size: 12px; white-space: nowrap; }
.goal-delta.pos { color: #16a34a; }
.goal-delta.neg { color: var(--red); }

.stars-hed { font-family: var(--display); font-weight: 800; text-transform: uppercase; font-size: 20px; letter-spacing: 0.02em; margin-bottom: 4px; }
.stars-sub { font-family: var(--mono); font-size: 10.5px; color: var(--ink-48); letter-spacing: 0.04em; margin-bottom: 20px; }
.star { display: grid; grid-template-columns: 4px 28px 1fr; column-gap: 12px; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--ink-06); }
.star:last-child { border-bottom: 0; }
.star-pip { height: 40px; }
.star-num { font-family: var(--display); font-weight: 800; font-size: 24px; line-height: 1; }
.star-name { font-family: var(--display); font-weight: 700; font-size: 17px; line-height: 1; color: var(--ink); }
.star-meta { font-family: var(--mono); font-size: 10.5px; color: var(--ink-48); margin-top: 2px; }

/* ── YESTERDAY REST ──────────────────────────────────────────────────────────── */
.yesterday-rest { padding: 40px 0; border-bottom: 2px solid var(--ink); }
.yesterday-rest .section-title { font-size: clamp(28px, 3vw, 40px); }

/* ── BOT CARDS ───────────────────────────────────────────────────────────────── */
.botzone { padding: 56px 0 80px; }
.botzone-head { margin-bottom: 28px; }
.cards-rail-wrap { position: relative; margin: 0 calc(50% - 50vw); padding-left: max(32px, calc(50vw - 640px + 32px)); }
.cards-rail { display: flex; gap: 16px; overflow-x: auto; overflow-y: hidden; padding: 4px 32px 20px 0; scroll-snap-type: x proximity; scrollbar-width: thin; scrollbar-color: var(--ink-14) transparent; }
.cards-rail::-webkit-scrollbar { height: 7px; }
.cards-rail::-webkit-scrollbar-thumb { background: var(--ink-14); border-radius: 3px; }
.botcard { flex: 0 0 auto; background: var(--surface); border: 1px solid var(--ink-10); height: 260px; display: flex; flex-direction: column; overflow: hidden; scroll-snap-align: start; transition: transform .2s, box-shadow .2s; box-shadow: 0 1px 2px rgba(13,13,20,0.04), 0 12px 24px -16px rgba(13,13,20,0.14); }
.botcard:hover { transform: translateY(-2px); box-shadow: 0 1px 2px rgba(13,13,20,0.04), 0 20px 36px -16px rgba(13,13,20,0.22); }
.botcard-img { flex: 1; border-bottom: 1px solid var(--ink-06); background: repeating-linear-gradient(135deg, rgba(13,13,20,0.04) 0 8px, transparent 8px 16px), var(--surface); display: grid; place-items: center; font-family: var(--mono); font-size: 10.5px; color: var(--ink-32); letter-spacing: 0.04em; }
.botcard-foot { display: flex; justify-content: space-between; align-items: center; padding: 9px 13px 10px; font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-72); }
.botcard-foot .ts { font-family: var(--mono); font-weight: 400; color: var(--ink-32); font-size: 10px; }
.botcard-foot .kind { display: inline-flex; align-items: center; gap: 6px; }
.botcard-foot .kind::before { content: ""; width: 5px; height: 5px; background: var(--red); display: inline-block; }

/* ── FOOTER ──────────────────────────────────────────────────────────────────── */
footer { background: var(--ink); color: #fff; border-top: 2px solid var(--ink); padding: 48px 0 24px; }
.foot-inner { display: grid; grid-template-columns: auto 1fr auto; align-items: end; gap: 32px; padding-bottom: 32px; }
.foot-wordmark { font-family: var(--display); font-weight: 800; font-size: 30px; letter-spacing: 0.04em; text-transform: uppercase; display: inline-flex; align-items: center; }
.foot-wordmark .dot { width: 6px; height: 6px; background: var(--red); border-radius: 50%; margin: 0 7px; display: inline-block; transform: translateY(-1px); }
.foot-ghost { font-family: var(--display); font-weight: 800; font-size: 38px; line-height: 0.95; text-transform: uppercase; color: rgba(255,255,255,0.07); text-align: center; white-space: nowrap; }
.foot-tag { font-family: var(--display); font-weight: 700; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.32); text-align: right; line-height: 1.8; }
.foot-bar { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 16px; display: flex; justify-content: space-between; font-family: var(--mono); font-size: 10.5px; color: rgba(255,255,255,0.24); letter-spacing: 0.04em; }

/* ── FEATURED CARD (new design) ── */
.feat-card { background:var(--surface); border:1px solid var(--ink-14); cursor:pointer; position:relative; transition:border-color 0.15s; }
.feat-card:hover { border-color:var(--ink-32); }
.feat-accent { height:4px; display:flex; }
.feat-accent > div { flex:1; }
.feat-body { padding:24px 28px 20px; }
.feat-cta { position:absolute; top:14px; right:16px; font-family:var(--mono); font-size:9px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-32); transition:color 0.15s; pointer-events:none; }
.feat-card:hover .feat-cta { color:var(--ink-72); }
.feat-score-zone { display:grid; grid-template-columns:1fr auto 1fr; align-items:center; gap:20px; margin-bottom:16px; }
.feat-team { display:flex; flex-direction:column; align-items:center; gap:6px; }
.feat-logo { width:64px; height:64px; object-fit:contain; }
.feat-abbr { font-family:var(--display); font-size:28px; font-weight:800; letter-spacing:0.02em; line-height:1; }
.feat-abbr.lead { color:var(--ink); }
.feat-abbr.trail { color:var(--ink-48); }
.feat-score-center { display:flex; flex-direction:column; align-items:center; gap:8px; }
.feat-scores { display:flex; align-items:baseline; gap:14px; line-height:0.85; }
.feat-n { font-family:var(--display); font-size:72px; font-weight:800; line-height:0.85; letter-spacing:-0.02em; }
.feat-n.lead { color:var(--ink); }
.feat-n.trail { color:var(--ink-48); }
.feat-sep { font-family:var(--display); font-size:72px; color:var(--ink-20); font-weight:800; line-height:0.85; }
.feat-period { font-family:var(--mono); font-size:10px; font-weight:700; letter-spacing:0.18em; color:var(--ink); text-transform:uppercase; padding:3px 10px; border:1px solid var(--ink-32); }
.feat-xg-wrap { margin-bottom:4px; }
.feat-xg-strip { display:flex; align-items:center; gap:12px; }
.feat-xg-side { display:flex; flex-direction:column; gap:2px; align-items:center; min-width:48px; }
.feat-xg-num { font-family:var(--display); font-size:18px; font-weight:800; line-height:1; }
.feat-xg-pct { font-family:var(--mono); font-size:9px; font-weight:700; letter-spacing:0.06em; opacity:0.7; line-height:1; }
.feat-xg-bar { flex:1; height:8px; overflow:hidden; }
.feat-xg-lbl { font-family:var(--mono); font-size:8px; font-weight:700; letter-spacing:0.18em; color:var(--ink-48); text-transform:uppercase; text-align:center; margin-top:8px; }
.feat-stars-strip { display:flex; align-items:stretch; border-top:1px solid var(--ink-06); }
.feat-star-item { flex:1; display:flex; align-items:center; gap:10px; padding:12px 14px; border-right:1px solid var(--ink-06); }
.feat-star-item:last-child { border-right:none; }
.feat-star-rank { font-family:var(--display); font-size:52px; font-weight:800; line-height:0.85; letter-spacing:-0.04em; color:var(--ink); flex-shrink:0; }
.feat-star-info { display:flex; flex-direction:column; gap:2px; min-width:0; }
.feat-star-name { font-family:var(--display); font-size:18px; font-weight:700; color:var(--ink); line-height:1.05; letter-spacing:0.01em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.feat-star-team { font-family:var(--mono); font-size:10px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; }
@media (max-width:640px) {
  .feat-n { font-size:52px; }
  .feat-logo { width:48px; height:48px; }
