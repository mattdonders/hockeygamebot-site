.gh-stat .sub { font-family: var(--mono); font-size: 10.5px; color: var(--ink-32); letter-spacing: 0.04em; margin-top: 2px; }
@media (max-width: 900px) {
  .gamehero { grid-template-columns: 1fr; }
  .gh-main { border-right: none; border-bottom: 1px solid var(--ink-14); padding: 36px 22px 24px; }
}
@media (max-width: 600px) {
  .gh-score { font-size: 64px; }
  .gh-score .dash { font-size: 32px; }
  .gh-logo { width: 64px; height: 64px; }
  .gh-stats { grid-template-columns: 1fr 1fr; }
  .bracket { grid-template-columns: repeat(7, 1fr); gap: 2px; }
  .bracket-cell { padding: 6px 2px; }
  .bracket-cell .winner { font-size: 11px; }
  .bracket-cell .bscore { font-size: 7px; }
  .sd-head { flex-direction: column; align-items: flex-start; justify-content: flex-start; gap: 8px; }
  .sd-meta { text-align: left; }
  .wrap.sd-section { padding-top: 32px; padding-bottom: 40px; }
  .gh-side { padding: 20px 20px 24px; }
  .gh-series-wp-lbl { font-size: 9px; }
}
</style>
</head>
<body>

<Nav currentPath={Astro.url.pathname} />

<!-- ── TICKER ── -->
