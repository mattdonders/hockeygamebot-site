<!-- ── CLIENT JS ── -->
<!-- Bridge the shared auth-client onto window so the (untyped, is:inline)
     client script below can use it without ESM imports. -->
<script>
import { getPrefs, getSessionToken } from '../lib/auth-client';
(window as any).__hgbAuth = { getPrefs, getSessionToken };
</script>

<!-- Bridge the shared hgb-api-client onto window for the same reason. -->
<script>
import { getGoals, getGameSeries, getTeamHistory } from '../lib/hgb-api-client';
(window as any).__hgbApi = { getGoals, getGameSeries, getTeamHistory };
</script>

<script is:inline>
(function () {
  // ── hgb-api-client bridge ─────────────────────────────────────────────────────
  // Waits for the deferred `__hgbApi` module bridge (see the <script> block
  // above) to attach onto window — mirrors the existing __hgbAuth wait pattern.
  async function _getHgbApi() {
    for (let i = 0; i < 50 && !window.__hgbApi; i++) {
      await new Promise(r => setTimeout(r, 20));
    }
    return window.__hgbApi;
  }

  // ── Team colors ─────────────────────────────────────────────────────────────
  const TC = {
    ANA:['#F47A38','#B09862'], BOS:['#FFB81C','#000000'], BUF:['#002654','#FDBB30'],
    CAR:['#CC0000','#000000'], CBJ:['#002654','#CE1126'], CGY:['#C8102E','#F1BE48'],
    CHI:['#CF0A2C','#000000'], COL:['#6F263D','#236192'], DAL:['#006847','#8F8F8C'],
    DET:['#CE1126','#FFFFFF'], EDM:['#FF4C00','#041E42'], FLA:['#041E42','#C8102E'],
    LAK:['#111111','#A2AAAD'], MIN:['#154734','#A6192E'], MTL:['#AF1E2D','#00205B'],
    NSH:['#FFB81C','#041E42'], NJD:['#CE1126','#000000'], NYI:['#00539B','#F47D30'],
    NYR:['#0038A8','#CE1126'], OTT:['#DA1A32','#000000'], PHI:['#FA4616','#000000'],
    PIT:['#000000','#FCB514'], SEA:['#001628','#99D9D9'], SJS:['#006D75','#EA7200'],
    STL:['#002F87','#FDB827'], TBL:['#00205B','#FFFFFF'], TOR:['#00205B','#FFFFFF'],
    UTA:['#71AFE5','#090909'], VAN:['#00205B','#00843D'], VGK:['#B4975A','#333F48'],
    WSH:['#041E42','#C8102E'], WPG:['#041E42','#004C97'],
  };
  function clr(abbrev) {
    const c = TC[abbrev] ?? ['#E8002D','#555'];
    const p = c[0], r=parseInt(p.slice(1,3),16)/255, g=parseInt(p.slice(3,5),16)/255, b=parseInt(p.slice(5,7),16)/255;
    return ((Math.max(r,g,b)+Math.min(r,g,b))/2) < 0.15 ? c[1] : c[0];
  }

  // Probability team A wins the series from state (aW wins, bW wins), assuming 50/50 per game.
  function calcSeriesWinProb(aW, bW) {
    if (aW >= 4) return 1.0;
    if (bW >= 4) return 0.0;
    return 0.5 * calcSeriesWinProb(aW + 1, bW) + 0.5 * calcSeriesWinProb(aW, bW + 1);
  }

  // ── Helpers ──────────────────────────────────────────────────────────────────
  const fmtET = utc => utc ? new Intl.DateTimeFormat('en-US',{timeZone:'America/New_York',hour:'numeric',minute:'2-digit',hour12:true}).format(new Date(utc)) : '';
  const fmtLocalTime = utc => { try { return utc ? new Date(utc).toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',hour12:true}) : ''; } catch { return ''; } };
  const localTZ = (() => { try { return new Intl.DateTimeFormat('en-US',{timeZoneName:'short'}).formatToParts(new Date()).find(p=>p.type==='timeZoneName')?.value ?? ''; } catch { return ''; } })();
  const fmtDate = iso => new Date(iso+'T12:00:00Z').toLocaleDateString('en-US',{weekday:'short',month:'long',day:'numeric',timeZone:'UTC'});

  // ── Countdown ─────────────────────────────────────────────────────────────────
  // ── Gamehero pregame countdown (.gh-cd elements) ─────────────────────────────
  let ghCdTimer = null;
  function startGhCountdown() {
    if (ghCdTimer) return;
    function tick() {
      document.querySelectorAll('.gh-cd[data-puckdrop]').forEach(el => {
        const t = new Date(el.dataset.puckdrop).getTime();
        if (!t) return;
        const diff = t - Date.now();
        if (diff <= 0) { el.textContent = 'PUCK DROP'; return; }
        const h = Math.floor(diff / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);
        el.textContent = h > 0
          ? `In ${h}h ${String(m).padStart(2,'0')}m`
          : m > 0
            ? `In ${m}m ${String(s).padStart(2,'0')}s`
            : `In ${s}s`;
      });
    }
    tick();
    ghCdTimer = setInterval(tick, 1000);
  }

  let countdownTimer = null;
  function startCountdown(firstUtc) {
    if (countdownTimer) { clearInterval(countdownTimer); countdownTimer = null; }
    const target = new Date(firstUtc).getTime();
    function tick() {
      const diff = target - Date.now();
      if (diff <= 0) { clearInterval(countdownTimer); setText('countdown', 'PUCK DROP!'); return; }
      const h = Math.floor(diff / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      setText('countdown', h > 0
        ? `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`
        : `${m}:${String(s).padStart(2,'0')}`);
    }
    tick();
    countdownTimer = setInterval(tick, 1000);
  }
  function stopCountdown() { if (countdownTimer) { clearInterval(countdownTimer); countdownTimer = null; } }
  const pLabel = p => !p ? '' : p===4?'OT':p>=5?'SO':`P${p}`;
  const gs = g => { const s=g.game_state; if(s==='live') return 'live'; if(s==='intermission') return 'intermission'; if(s==='final'||s==='game-end') return 'final'; return 'pre'; };
  const wpPct = (g,side) => { const v=g.stats?.win_probability?.[side]; return v!=null?Math.round(v*100):50; };
  const xgFmt = (g,side) => { const v=g.stats?.xg_5v5?.[side]; return v!=null?v.toFixed(2):'—'; };
  const setText = (id,v) => { const el=document.getElementById(id); if(el) el.textContent=v; };
  const setHtml = (id,v) => { const el=document.getElementById(id); if(el) el.innerHTML=v; };

  // Current page state — updated by render functions so tracked section can gate on it
  let _pageState = 'pre';
  // Shared across render + prefs load
  let _prefs = null;
  let _lastData = null;

  // ── State detection ──────────────────────────────────────────────────────────
  function pageState(data) {
    const games = data.games ?? [];
    if (games.some(g => gs(g)==='live'||gs(g)==='intermission')) return 'live';
    if (games.length===0 || games.every(g => gs(g)==='final'||gs(g)==='game-end')) return 'post';
    return 'pre';
  }

  function pickLive(games) {
    const live = games.filter(g => gs(g)==='live'||gs(g)==='intermission');
    if (!live.length) return null;
    return live.reduce((best,g) => {
      const d = Math.abs((g.stats?.win_probability?.home??0.5)-0.5);
      const bd = Math.abs((best.stats?.win_probability?.home??0.5)-0.5);
      return d < bd ? g : best;
    }, live[0]);
  }

  // ── YOUR GAME TONIGHT ─────────────────────────────────────────────────────────

  function getPin() {
    try {
      const s = localStorage.getItem('hgb_hero_override');
      if (!s) return null;
      const p = JSON.parse(s);
      if (p?.expires_at && Date.now() > p.expires_at) { localStorage.removeItem('hgb_hero_override'); return null; }
      return p?.game_id ? p : null;
    } catch { return null; }
  }

  function setPin(gameId) {
    const now = new Date(), exp = new Date(now);
    exp.setHours(3, 0, 0, 0);
    if (exp <= now) exp.setDate(exp.getDate() + 1);
    try { localStorage.setItem('hgb_hero_override', JSON.stringify({ game_id: String(gameId), expires_at: exp.getTime() })); } catch {}
  }

  function clearPin() { try { localStorage.removeItem('hgb_hero_override'); } catch {} }

  function togglePin(gameId) {
    const p = getPin();
    if (p?.game_id === String(gameId)) clearPin(); else setPin(gameId);
    if (_lastData) renderYourGameSection(_lastData, _prefs ?? {});
    requestAnimationFrame(() => updatePinBtnStates(getPin()?.game_id));
  }

  function updatePinBtnStates(activePinId) {
    document.querySelectorAll('.pin-btn').forEach(btn => {
      const card = btn.closest('a[href]');
      const m = card?.getAttribute('href')?.match(/\/games\/([^?#\/]+)/);
      if (!m) return;
      const isPinned = String(m[1]) === String(activePinId);
      btn.className = 'pin-btn' + (isPinned ? ' active' : '');
      btn.textContent = isPinned ? '📌 Pinned' : '📌 Pin';
    });
  }

  function buildCascade(games, prefs) {
    const raw = prefs?.tracked_teams ?? [];
    const tracked = raw.map(t => typeof t === 'string' ? t : t?.abbrev).filter(Boolean);
    const pin = getPin();

    // 1. Pin override
    if (pin) {
      const g = games.find(gg => String(gg.game_id) === String(pin.game_id));
      if (g) return { game: g, source: 'pin', tracked };
    }

    // 2-4. Tracked teams by rank (array order = rank)
    for (let i = 0; i < Math.min(3, tracked.length); i++) {
      const abbrev = tracked[i];
      const g = games.find(gg => gg.away_team.abbrev === abbrev || gg.home_team.abbrev === abbrev);
      if (g) return { game: g, source: `tracked${i + 1}`, tracked };
    }

    // 5. Model's pick — most evenly-matched active game (WP closest to 50%)
    const active = games.filter(g => gs(g) !== 'final' && gs(g) !== 'game-end');
    const pool = active.length ? active : games;
    if (pool.length) {
      const pick = pool.reduce((best, g) => {
        const d = Math.abs((g.stats?.win_probability?.away ?? 0.5) - 0.5);
        const bd = Math.abs((best.stats?.win_probability?.away ?? 0.5) - 0.5);
        return d < bd ? g : best;
      }, pool[0]);
      return { game: pick, source: 'model', tracked };
    }

    return { game: null, source: 'identity', tracked };
  }

  function buildFeaturedCardHtml(g, source, pinGameId) {
    const a = g.away_team.abbrev, h = g.home_team.abbrev;
    const ac = clr(a), hc = clr(h);
    const state = gs(g);
    const aWP = g.stats?.win_probability?.away;
    const hWP = g.stats?.win_probability?.home;
    const aWPp = aWP != null ? Math.round(aWP * 100) : null;
    const hWPp = hWP != null ? Math.round(hWP * 100) : null;
    const xgA = g.stats?.xg_5v5?.away ?? null;
    const xgH = g.stats?.xg_5v5?.home ?? null;
    const awayWins = g.away_team.score > g.home_team.score;
    const isPinned = String(g.game_id) === String(pinGameId);
    const isFinal = state === 'final' || state === 'game-end';
    const isOT = (g.clock?.period ?? 0) >= 4;

    const barHtml = `<div class="featured-bar"><div class="a" style="background:${ac}"></div><div class="h" style="background:${hc}"></div></div>`;
    const pinBadge = isPinned ? `<span style="position:absolute;top:9px;right:10px;background:var(--red);color:#fff;font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:0.1em;padding:2px 7px;z-index:5;pointer-events:none">📌 PINNED</span>` : '';

    // Status eye row
    let eyeHtml;
    if (state === 'live') {
      const per = pLabel(g.clock?.period), clk = g.clock?.time_remaining ?? '';
      eyeHtml = `<div class="featured-eye"><span class="live"><span class="pip"></span> LIVE</span><span>${per} · ${clk}</span>${g.venue ? `<span class="arena">${g.venue}</span>` : ''}</div>`;
    } else if (state === 'intermission') {
      eyeHtml = `<div class="featured-eye"><span class="tag">Intermission</span><span>End of ${pLabel(g.clock?.period)}</span>${g.venue ? `<span class="arena">${g.venue}</span>` : ''}</div>`;
    } else if (isFinal) {
      eyeHtml = `<div class="featured-eye"><span class="tag">FINAL${isOT ? ' · OT' : ''}</span></div>`;
    } else {
      const time = fmtET(g.start_time_utc) || 'TBD';
      eyeHtml = `<div class="featured-eye"><span>Puck drop · ${time} ET</span>${g.venue ? `<span class="arena">${g.venue}</span>` : ''}</div>`;
    }

    // Score / matchup
    const inGame = isFinal || state === 'live' || state === 'intermission';
    const aFade = inGame && !awayWins ? 'opacity:0.35;filter:grayscale(0.4)' : '';
    const hFade = inGame && awayWins ? 'opacity:0.35;filter:grayscale(0.4)' : '';
    const logoBase = 'https://assets.nhle.com/logos/nhl/svg/';

    let centerHtml;
    if (state === 'pre') {
      const t = fmtET(g.start_time_utc) || 'TBD';
      centerHtml = `<div class="featured-score"><div class="pregame-time">${t} ET</div></div>`;
    } else {
      centerHtml = `<div class="featured-score"><div class="nums"><span class="${awayWins?'lead':'trail'}">${g.away_team.score}</span><span class="dash">–</span><span class="${awayWins?'trail':'lead'}">${g.home_team.score}</span></div></div>`;
    }

    const matchupHtml = `<div class="featured-matchup">
      <div class="featured-team">
        <img class="featured-logo" src="${logoBase}${a}_light.svg" alt="${a}" onerror="this.style.display='none'" style="${aFade}">
        <div class="name">${a}</div>${aWPp != null && state === 'pre' ? `<div class="rec">${aWPp}% WP</div>` : ''}
      </div>
      ${centerHtml}
      <div class="featured-team">
        <img class="featured-logo" src="${logoBase}${h}_light.svg" alt="${h}" onerror="this.style.display='none'" style="${hFade}">
        <div class="name">${h}</div>${hWPp != null && state === 'pre' ? `<div class="rec">${hWPp}% WP</div>` : ''}
      </div>
    </div>`;

    // WP bar
    let wpBarHtml = '';
    if (aWPp != null && !isFinal) {
      const label = state === 'pre' ? 'PRE-GAME WP' : 'WIN PROBABILITY';
      wpBarHtml = `<div class="featured-wp">
        <div class="featured-wp-head"><b style="color:${ac}">${a}</b><span>${label}</span><b style="color:${hc}">${h}</b></div>
        <div class="featured-wp-track"><div class="featured-wp-fill" style="width:${aWPp}%;background:${ac}"></div></div>
        <div class="featured-wp-pcts"><b style="color:${ac}">${aWPp}%</b><b style="color:${hc}">${hWPp}%</b></div>
      </div>`;
    }

    // Side panel
    let sideHtml = '';
    if (state === 'pre') {
      sideHtml = `<div class="featured-side-head">Pre-game</div>`;
      if (aWPp != null) {
        sideHtml += `<div class="featured-stats">
          <div class="featured-stat"><div class="lbl">${a} Win Prob.</div><div class="val" style="color:${ac}">${aWPp}%</div></div>
          <div class="featured-stat"><div class="lbl">${h} Win Prob.</div><div class="val" style="color:${hc}">${hWPp}%</div></div>
        </div>`;
      }
      sideHtml += `<div class="featured-bot-strip">
        <div class="featured-bot-handle">@${a}GameBot</div>
        <div class="featured-bot-handle">@${h}GameBot</div>
      </div>`;
    } else if (state === 'live' || state === 'intermission') {
      sideHtml = `<div class="featured-side-head">Live Stats · 5v5</div>`;
      if (xgA != null && xgH != null) {
        const tot = xgA + xgH;
        const aShare = tot > 0 ? Math.round(xgA / tot * 100) : 50;
        sideHtml += `<div class="featured-stats">
          <div class="featured-stat"><div class="lbl">${a} xG</div><div class="val" style="color:${ac}">${xgA.toFixed(2)}</div></div>
          <div class="featured-stat"><div class="lbl">${h} xG</div><div class="val" style="color:${hc}">${xgH.toFixed(2)}</div></div>
          <div class="featured-stat"><div class="lbl">${a} xGF%</div><div class="val">${aShare}%</div></div>
        </div>`;
      }
      sideHtml += `<div class="featured-bot-strip">
        <div class="featured-bot-handle"><span class="bpip"></span>@${a}GameBot</div>
        <div class="featured-bot-handle"><span class="bpip"></span>@${h}GameBot</div>
      </div>`;
    } else {
      // FINAL
      const stars = g.three_stars ?? [];
      if (stars.length) {
        sideHtml = `<div class="featured-side-head">Three Stars</div><div class="featured-stars">`;
        stars.slice(0, 3).forEach(s => {
          sideHtml += `<div class="featured-star"><span class="star-n">${s.star}★</span><span class="star-name">${s.player_last_name || s.player_name || ''}</span><span class="star-team">${s.team_abbrev}</span></div>`;
        });
        sideHtml += `</div>`;
      } else {
        sideHtml = `<div class="featured-side-head">Final</div>`;
        if (xgA != null && xgH != null) {
          sideHtml += `<div class="featured-stats">
            <div class="featured-stat"><div class="lbl">${a} xG</div><div class="val" style="color:${ac}">${xgA.toFixed(2)}</div></div>
            <div class="featured-stat"><div class="lbl">${h} xG</div><div class="val" style="color:${hc}">${xgH.toFixed(2)}</div></div>
          </div>`;
        }
      }
      sideHtml += `<a class="featured-recap-link" href="/games/${g.game_id}">Full recap →</a>`;
    }

    return `<a class="featured-card${isPinned ? ' pinned' : ''}" href="/games/${g.game_id}" style="${isPinned ? 'border-color:var(--red);border-width:2px;' : ''}">
      ${barHtml}
      ${pinBadge}
      <div class="featured-main">
        ${eyeHtml}
        ${matchupHtml}
        ${wpBarHtml}
      </div>
      <div class="featured-side">
        ${sideHtml}
      </div>
    </a>`;
  }

  function renderTrackedStripSection(games, tracked, featuredId) {
    const slot = document.getElementById('tracked-strip-slot');
    const grid = document.getElementById('tracked-strip-grid');
    if (!slot || !grid) return;

    const entries = [];
    for (let i = 0; i < Math.min(3, tracked.length); i++) {
      const abbrev = tracked[i];
      const g = games.find(gg => String(gg.game_id) !== String(featuredId) && (gg.away_team.abbrev === abbrev || gg.home_team.abbrev === abbrev));
      if (g) entries.push({ rank: i + 1, abbrev, g });
    }

    if (!entries.length) { slot.style.display = 'none'; return; }
    slot.style.display = '';

    grid.innerHTML = entries.map(({ rank, abbrev, g }) => {
      const a = g.away_team.abbrev, h = g.home_team.abbrev;
      const ac = clr(a), hc = clr(h);
      const st = gs(g);
      const aWins = g.away_team.score > g.home_team.score;
      const aWPp = g.stats?.win_probability?.away != null ? Math.round(g.stats.win_probability.away * 100) : null;

      let scoreHtml;
      if (st === 'pre') {
        scoreHtml = `<div class="tcard-score" style="font-size:16px;font-family:var(--mono);color:var(--ink-48)">${fmtET(g.start_time_utc) || '—'} ET</div>`;
      } else {
        scoreHtml = `<div class="tcard-score"><span style="color:${aWins ? ac : 'var(--ink-32)'}">${g.away_team.score}</span> – <span style="color:${aWins ? 'var(--ink-32)' : hc}">${g.home_team.score}</span></div>`;
      }

      return `<a class="tcard" href="/games/${g.game_id}">
        <div class="tcard-bar"><div class="a" style="background:${ac}"></div><div class="h" style="background:${hc}"></div></div>
        <div class="tcard-eye">// #${rank} · ${abbrev}</div>
        <div class="tcard-teams">${a} @ ${h}</div>
        ${scoreHtml}
        ${aWPp != null ? `<div class="tcard-wp">${aWPp}% / ${100 - aWPp}% WP</div>` : ''}
        <div class="tcard-follow" onclick="event.stopPropagation();window.open('https://x.com/${abbrev}GameBot','_blank')">@${abbrev}GameBot →</div>
      </a>`;
    }).join('');
  }

  function injectPinButtons(games, activePinId) {
    document.querySelectorAll('a.pregame-card[href*="/games/"]').forEach(card => {
      if (card.querySelector('.pin-btn')) {
        // Update existing button state
        const btn = card.querySelector('.pin-btn');
        const m = card.getAttribute('href')?.match(/\/games\/([^?#\/]+)/);
        if (m) {
          const isPinned = String(m[1]) === String(activePinId);
          btn.className = 'pin-btn' + (isPinned ? ' active' : '');
          btn.textContent = isPinned ? '📌 Pinned' : '📌 Pin';
        }
        return;
      }
      const m = card.getAttribute('href')?.match(/\/games\/([^?#\/]+)/);
      if (!m) return;
      const gameId = m[1];
      const isPinned = String(gameId) === String(activePinId);
      const btn = document.createElement('button');
      btn.className = 'pin-btn' + (isPinned ? ' active' : '');
      btn.textContent = isPinned ? '📌 Pinned' : '📌 Pin';
      btn.addEventListener('click', ev => { ev.preventDefault(); ev.stopPropagation(); togglePin(gameId); });
      card.appendChild(btn);
    });
  }

  function renderYourGameSection(data, prefs) {
    const games = data?.games ?? [];
    const sec = document.getElementById('your-game-section');
    if (!sec) return;
    if (!games.length) { sec.style.display = 'none'; return; }
    if (pageState(data) === 'post') { sec.style.display = 'none'; return; }

    const { game, source, tracked } = buildCascade(games, prefs);
    if (!game) { sec.style.display = 'none'; return; }

    sec.style.display = '';
    const pin = getPin();

    // Eyebrow
    const eyebrowEl = document.getElementById('yg-eyebrow');
    if (eyebrowEl) {
      if (source === 'pin') {
        eyebrowEl.innerHTML = `// <span class="tag">📌 Pinned</span> · Your Game Tonight`;
      } else if (source.startsWith('tracked')) {
        const abbrev = tracked[parseInt(source.slice(-1)) - 1] || '';
        eyebrowEl.innerHTML = `// Tracking · <span class="tag">${abbrev}</span> · Your Game Tonight`;
      } else {
        eyebrowEl.innerHTML = `// <span class="tag">Model's Pick</span> · Featured Game Tonight`;
      }
    }

    // Meta
    const metaEl = document.getElementById('yg-meta');
    if (metaEl) {
      if (source === 'pin') {
        const exp = pin?.expires_at ? new Date(pin.expires_at).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }) : '3 AM';
        metaEl.innerHTML = `📌 Pinned until ${exp} · <a href="#" id="remove-pin-link">Remove pin</a>`;
        document.getElementById('remove-pin-link')?.addEventListener('click', ev => {
          ev.preventDefault();
          clearPin();
          renderYourGameSection(_lastData, _prefs ?? {});
        });
      } else if (source.startsWith('tracked')) {
        metaEl.innerHTML = `Personalized from Account · <a href="/account">Manage tracked teams →</a>`;
      } else {
        metaEl.innerHTML = `Model's Pick · <a href="/account">Set tracked teams →</a>`;
      }
    }

    // Featured card
    const slot = document.getElementById('featured-card-slot');
    if (slot) slot.innerHTML = buildFeaturedCardHtml(game, source, pin?.game_id);

    // Tracked strip
    renderTrackedStripSection(games, tracked, game.game_id);

    // Pin buttons (after DOM settles)
    requestAnimationFrame(() => injectPinButtons(games, pin?.game_id));
  }

  // ── STATE D: SINGLE GAME ─────────────────────────────────────────────────────

  let _seriesData = null;
  let _narrativesCache = null;
  let _seriesStatsCache = null;

  async function fetchSeriesGames(g) {
    if (!g) return null;
    const a = g.away_team?.abbrev, h = g.home_team?.abbrev;
    try {
      if (!_seriesStatsCache) {
        const r = await fetch('https://api.hockeygamebot.com/v1/stats/series-stats', { signal: AbortSignal.timeout(5000) });
        _seriesStatsCache = r.ok ? await r.json() : {};
      }
      for (const s of (_seriesStatsCache?.series ?? [])) {
        const teams = Object.keys(s.teams ?? {});
        if (teams.includes(a) && teams.includes(h)) return s.games ?? [];
      }
      return null;
    } catch { return null; }
  }

  function _getCachedSeriesGames(g) {
    const a = g.away_team?.abbrev, h = g.home_team?.abbrev;
    for (const s of (_seriesStatsCache?.series ?? [])) {
      const teams = Object.keys(s.teams ?? {});
      if (teams.includes(a) && teams.includes(h)) return s.games ?? [];
    }
    return null;
  }

  async function fetchSeriesNarrative(g) {
    if (!g) return null;
    const a = g.away_team?.abbrev, h = g.home_team?.abbrev;
    try {
      if (!_narrativesCache) {
        const r = await fetch('https://api.hockeygamebot.com/v1/stats/series-narratives', { signal: AbortSignal.timeout(5000) });
        _narrativesCache = r.ok ? await r.json() : {};
      }
      const narratives = _narrativesCache?.narratives ?? {};
      for (const n of Object.values(narratives)) {
        if (n.teams?.includes(a) && n.teams?.includes(h) && n.narrative) return n.narrative;
      }
      return null;
    } catch { return null; }
  }

  function _getCachedNarrative(g) {
    const a = g.away_team?.abbrev, h = g.home_team?.abbrev;
    const narratives = _narrativesCache?.narratives ?? {};
    for (const n of Object.values(narratives)) {
      if (n.teams?.includes(a) && n.teams?.includes(h) && n.narrative) return n.narrative;
    }
    return null;
  }

  async function fetchSeriesInfo(g) {
    if (g.series) return g.series;

    function parseSS(ss, awayAbbrev) {
      if (!ss?.gameNumberOfSeries) return null;
      const topIsAway = ss.topSeedTeamAbbrev === awayAbbrev;
      return {
        awayWins:   topIsAway ? (ss.topSeedWins ?? 0) : (ss.bottomSeedWins ?? 0),
        homeWins:   topIsAway ? (ss.bottomSeedWins ?? 0) : (ss.topSeedWins ?? 0),
        gameNumber: ss.gameNumberOfSeries,
        roundText:  ss.seriesTitle || ss.seriesAbbrev || '',
      };
    }

    // Primary: HGB API series proxy (server-side fetch, no CORS)
    const api = await _getHgbApi();
    if (api) {
      const d = await api.getGameSeries(g.game_id);
      if (d) {
        const result = parseSS(d.seriesStatus, g.away_team?.abbrev);
        if (result) return result;
      }
    }

    // Fallback: direct NHL schedule (may be blocked in some browsers)
    try {
      const today = new Date().toISOString().slice(0, 10);
      const r = await fetch(`https://api-web.nhle.com/v1/schedule/${today}`, { signal: AbortSignal.timeout(5000) });
      if (r.ok) {
        const d = await r.json();
        const todayEntry = (d?.gameWeek ?? []).find(w => w.date === today);
        const games = todayEntry?.games ?? (d?.gameWeek ?? []).flatMap(w => w.games ?? []);
        const found = games.find(sg =>
          String(sg.id) === String(g.game_id) || Number(sg.id) === Number(g.game_id) ||
          (sg.awayTeam?.abbrev === g.away_team?.abbrev && sg.homeTeam?.abbrev === g.home_team?.abbrev)
        );
        return parseSS(found?.seriesStatus, g.away_team?.abbrev);
      }
    } catch {}
    return null;
  }

  function buildStateDHtml(g, series, narrative, seriesGames) {
    const a = g.away_team.abbrev, h = g.home_team.abbrev;
    const ac = clr(a), hc = clr(h);
    const state = gs(g);
    const isFinal = state === 'final' || state === 'game-end';
    const isLive = state === 'live';
    const isInt = state === 'intermission';
    const isPre = state === 'pre';
    const awayWins = g.away_team.score > g.home_team.score;
    const aWP = g.stats?.win_probability?.away;
    const hWP = g.stats?.win_probability?.home;
    const aWPp = aWP != null ? Math.round(aWP * 100) : null;
    const hWPp = hWP != null ? Math.round(hWP * 100) : null;
    const xgA = g.stats?.xg_5v5?.away ?? null;
    const xgH = g.stats?.xg_5v5?.home ?? null;
    const isOT = (g.clock?.period ?? 0) >= 4;

    // ── Title block ──
    let eyeText = '// Tonight';
    let titleHtml = `${a} <span class="accent">@</span> ${h}`;

    if (series) {
      const { awayWins: aW, homeWins: hW, gameNumber: gn, roundText: rt } = series;
      const maxW = Math.max(aW, hW), minW = Math.min(aW, hW);
      const isTied = aW === hW;
      const leader = aW > hW ? a : h;
      const round = rt || 'Playoffs';

      if (gn === 7) {
        eyeText = `// Tonight · ${round} · Game 7`;
        titleHtml = `WINNER<br><span class="accent">TAKE ALL</span>`;
      } else if (maxW === 3) {
        eyeText = `// Tonight · ${round} · ${leader} leads ${maxW}–${minW}`;
        titleHtml = `WIN OR<br><span class="accent">IT'S OVER</span>`;
      } else if (isTied) {
        eyeText = `// Tonight · ${round} · Series tied ${aW}–${hW}`;
        titleHtml = `GAME ${gn} —<br><span class="accent">SERIES ALL SQUARE</span>`;
      } else {
        eyeText = `// Tonight · ${round} · ${leader} leads ${maxW}–${minW}`;
        titleHtml = `GAME ${gn} —<br><span class="accent">RESPOND OR FALL BEHIND</span>`;
      }
    }

    const metaHtml = '';

    // ── Live flag ──
    let flagHtml = '';
    const gn = series?.gameNumber;
    const rt = series?.roundText || '';
    if (isLive) {
      const per = pLabel(g.clock?.period), clk = g.clock?.time_remaining ?? '';
      flagHtml = `<div class="gh-flag"><span class="status-pill" data-state="live"><span class="dot"></span>LIVE · ${per}</span>${gn ? `<span class="gh-round">${rt ? rt + ' · ' : ''}Game ${gn}</span>` : ''}</div>`;
    } else if (isInt) {
      flagHtml = `<div class="gh-flag"><span class="status-pill" data-state="intermission">Intermission · End of ${pLabel(g.clock?.period)}</span>${gn ? `<span class="gh-round">Game ${gn}</span>` : ''}</div>`;
    } else if (isFinal) {
      flagHtml = `<div class="gh-flag"><span class="status-pill" data-state="final">FINAL${isOT ? ' · OT' : ''}</span>${gn ? `<span class="gh-round">Game ${gn}</span>` : ''}</div>`;
    }
    // Pregame: drop the round/game label — it's already in the series panel on the right.

    // ── Clock + Score ──
    let clockHtml;
    if (isLive) {
      const per = pLabel(g.clock?.period), clk = g.clock?.time_remaining ?? '';
      clockHtml = `<div class="gh-clock"><span class="live">● Live</span> · ${per} · ${clk}</div>`;
    } else if (isInt) {
      clockHtml = `<div class="gh-clock">Intermission · End of ${pLabel(g.clock?.period)}</div>`;
    } else if (isFinal) {
      clockHtml = `<div class="gh-clock">FINAL${isOT ? ' · OT' : ''}</div>`;
    } else {
      clockHtml = '';  // replaced by time + countdown inside scoreHtml for pregame
    }

    let scoreHtml;
    if (isPre) {
      scoreHtml = `<div class="gh-score" style="flex-direction:column;gap:8px;align-items:center">
        <span style="font-size:44px;color:var(--ink-20);font-weight:700;line-height:1">VS</span>
        <span class="gh-cd" data-puckdrop="${g.start_time_utc || ''}" style="font-family:var(--mono);font-size:14px;font-weight:700;color:var(--ink);letter-spacing:0.06em;min-height:1.2em;display:block;text-align:center"></span>
      </div>`;
    } else {
      scoreHtml = `<div class="gh-score"><span class="${awayWins ? 'lead' : 'trail'}">${g.away_team.score}</span><span class="dash">–</span><span class="${awayWins ? 'trail' : 'lead'}">${g.home_team.score}</span></div>`;
    }

    const periodHtml = '';

    // ── WP bar ──
    let wpHtml = '';
    if (aWPp != null && !isFinal) {
      const label = isPre ? 'Pre-game win probability' : `Win probability · <b style="color:${ac}">${aWPp}% ${a}</b>`;
      wpHtml = `<div class="gh-wp">
        <div class="gh-wp-head"><span>${label}</span></div>
        <div class="gh-wp-track"><div class="gh-wp-fill" style="width:${aWPp}%;background:${ac}"></div></div>
        <div class="gh-wp-pcts"><b style="color:${ac}">${a} ${aWPp}%</b><span style="color:${hc}">${h} ${hWPp}%</span></div>
      </div>`;
    }

    // ── Fading effects for winner/loser in finished game ──
    const aFade = (isFinal || isLive || isInt) && !awayWins && !isPre ? 'opacity:0.4;filter:grayscale(0.3)' : '';
    const hFade = (isFinal || isLive || isInt) && awayWins && !isPre ? 'opacity:0.4;filter:grayscale(0.3)' : '';

    // ── Series side ──
    let sideSeries = '';
    if (series) {
      const { awayWins: aW, homeWins: hW, gameNumber: sgn, roundText: srt } = series;
      const leader = aW > hW ? a : (hW > aW ? h : null);
      const leaderColor = aW > hW ? ac : (hW > aW ? hc : 'var(--ink)');
      const isTied = aW === hW;
      const maxW = Math.max(aW, hW), minW = Math.min(aW, hW);

      sideSeries += `<div>
        <div class="gh-series-score">
          <span style="color:${aW > hW ? ac : 'var(--ink)'}">${a}</span><span class="vs">${aW}</span>
          <span style="color:var(--ink-20);font-size:14px">·</span>
          <span class="vs">${hW}</span><span style="color:${hW > aW ? hc : 'var(--ink)'}">${h}</span>
        </div>
        <div class="gh-series-sub">${srt || 'Playoffs'} · Best of 7 · Game ${sgn}</div>
      </div>`;

      // Series win probability bar — assumes 50/50 per game from current state
      // Use model win % if DE has added series_win_pct_away/home to scoreboard game object,
      // otherwise fall back to naive binomial (50/50 at 0-0).
      const aSerWPpct = g.series_win_pct_away ?? Math.round(calcSeriesWinProb(aW, hW) * 100);
      const hSerWPpct = g.series_win_pct_home ?? (100 - aSerWPpct);
      sideSeries += `<div class="gh-series-wp">
        <div class="gh-series-wp-lbl">
          <b style="color:${aSerWPpct >= 50 ? ac : 'var(--ink-48)'}">${a} ${aSerWPpct}%</b>
          <span style="color:var(--ink-32)">Series odds</span>
          <b style="color:${hSerWPpct >= 50 ? hc : 'var(--ink-48)'}">${h} ${hSerWPpct}%</b>
        </div>
        <div class="gh-series-wp-bar" style="background:linear-gradient(to right,${ac} ${aSerWPpct}%,${hc} ${aSerWPpct}%)"></div>
      </div>`;

      // Bracket cells — G1-G7 grid. Use per-game data from series_stats.json when available,
      // fall back to approximation from win counts (away fills first, then home).
      const cells = [];
      const gamesByNum = {};
      if (seriesGames) seriesGames.forEach(g => { gamesByNum[g.game_number] = g; });
      let awayFill = aW, homeFill = hW;
      for (let i = 1; i <= 7; i++) {
        if (i < sgn) {
          const gd = gamesByNum[i];
          let winnerAbbrev, winnerColor, scoreLabel;
          if (gd) {
            winnerAbbrev = gd.winner;
            winnerColor = gd.winner === a ? ac : hc;
            // Show score from winner's perspective: winner score first
            const ws = gd.winner === gd.home ? gd.home_score : gd.away_score;
            const ls = gd.winner === gd.home ? gd.away_score : gd.home_score;
            scoreLabel = `${ws}-${ls}${gd.ot ? ' OT' : ''}`;
          } else {
            // Fallback approximation
            if (awayFill > 0) { winnerAbbrev = a; winnerColor = ac; awayFill--; }
            else { winnerAbbrev = h; winnerColor = hc; homeFill--; }
            scoreLabel = null;
          }
          cells.push(`<div class="bracket-cell" style="background:${winnerColor}18;border-color:${winnerColor}55;color:${winnerColor}"><span class="gno">G${i}</span><span class="winner">${winnerAbbrev}</span>${scoreLabel ? `<span class="bscore">${scoreLabel}</span>` : ''}</div>`);
        } else if (i === sgn) {
          const label = isFinal ? (aW > hW ? a : h) : (isLive ? 'LIVE' : 'TONIGHT');
          const cellStyle = isFinal ? `style="background:${aW>hW?ac:hc}18;border-color:${aW>hW?ac:hc}55;color:${aW>hW?ac:hc}"` : '';
          cells.push(`<div class="bracket-cell ${isFinal ? '' : 'live-cell'}" ${cellStyle}><span class="gno">G${i}</span><span class="winner">${label}</span></div>`);
        } else {
          cells.push(`<div class="bracket-cell" style="opacity:0.2"><span class="gno">G${i}</span><span class="winner">—</span></div>`);
        }
      }
      sideSeries += `<div class="bracket">${cells.join('')}</div>`;

      // Stakes — use Haiku narrative if available, fall back to template text
      let stakesText;
      if (narrative) {
        stakesText = narrative;
      } else if (sgn === 7) {
        stakesText = `The series ends tonight. One team advances to the next round, the other goes home for the summer.`;
      } else if (maxW === 3) {
        const trailTeam = aW < hW ? a : h;
        stakesText = `${trailTeam} faces elimination tonight. Win or go home — ${leader} is one game from advancing.`;
      } else if (isTied && aW === 0) {
        stakesText = `Game 1 of the series. Whoever wins takes an early 1–0 lead.`;
      } else if (isTied) {
        stakesText = `All square at ${aW}–${hW}. Winner takes a series lead heading into Game ${sgn + 1}.`;
      } else {
        stakesText = `${leader} has the upper hand at ${maxW}–${minW}. The trailing team needs a response tonight to stay alive in the series.`;
      }
      sideSeries += `<div class="gh-stakes"><b>// Series picture</b>${stakesText}</div>`;
    } else {
      sideSeries = `<div style="font-family:var(--mono);font-size:11px;color:var(--ink-48)">Playoff game</div>
        <div class="gh-stakes"><b>// Tonight</b>Follow @${a}GameBot and @${h}GameBot for live WP, xG, and goal-by-goal coverage.</div>`;
    }

    // ── Bot strip — inlined directly in return HTML (avoids nested-<a> when gamehero was <a>) ──
    const withPips = isLive || isInt;

    // ── Stat strip ──
    const xgTot = (xgA ?? 0) + (xgH ?? 0);
    const xgfPct = xgTot > 0 ? Math.round((xgA ?? 0) / xgTot * 100) : null;
    let statStrip;
    if (isPre) {
      const timeStr = g.start_time_utc ? `${fmtLocalTime(g.start_time_utc)} ${localTZ}` : 'TBD';
      const venueStr = g.venue || '—';
      const _US_NETS = new Set(['ESPN','ESPN2','ABC','TNT','truTV','MAX','HBO MAX','TBS','NBC','NBCSN']);
      const tvStr = Array.isArray(g.broadcasts) && g.broadcasts.length
        ? (typeof g.broadcasts[0] === 'string'
            ? (g.broadcasts.find(b => _US_NETS.has(b)) ?? g.broadcasts[0])
            : (g.broadcasts.find(b => b.market === 'national')?.network ?? g.broadcasts[0]?.network ?? '—'))
        : '—';
      const gnStr = series?.gameNumber ? `Game ${series.gameNumber}` : 'Playoff';
      const rtStr = series?.roundText || 'Playoffs';
      statStrip = `<div class="gh-stats">
        <div class="gh-stat"><div class="lbl">Puck Drop</div><div class="val">${timeStr}</div><div class="sub">Your time</div></div>
        <div class="gh-stat"><div class="lbl">Venue</div><div class="val gh-stat-long">${venueStr}</div><div class="sub">${h} home</div></div>
        <div class="gh-stat"><div class="lbl">Broadcast</div><div class="val">${tvStr}</div><div class="sub">National TV</div></div>
        <div class="gh-stat"><div class="lbl">Round</div><div class="val gh-stat-long">${rtStr}</div><div class="sub">${gnStr}</div></div>
      </div>`;
    } else {
      statStrip = `<div class="gh-stats">
        <div class="gh-stat"><div class="lbl">xG · 5v5</div><div class="val">${xgA != null ? xgA.toFixed(2) : '—'} · ${xgH != null ? xgH.toFixed(2) : '—'}</div><div class="sub">${a} · ${h}</div></div>
        <div class="gh-stat"><div class="lbl">xGF%</div><div class="val">${xgfPct != null ? xgfPct + '%' : '—'}</div><div class="sub">${a}</div></div>
        <div class="gh-stat"><div class="lbl">Win Prob.</div><div class="val">${aWPp != null ? aWPp + '%' : '—'}</div><div class="sub">${a}</div></div>
        <div class="gh-stat"><div class="lbl">${isFinal ? 'Result' : 'Period'}</div><div class="val">${isFinal ? (isOT ? 'OT' : 'F') : pLabel(g.clock?.period) || '—'}</div><div class="sub">${isLive && g.clock?.time_remaining ? g.clock.time_remaining : isInt ? 'Break' : isFinal ? 'Final' : ''}</div></div>
      </div>`;
    }

    // Logo: actual NHL team logos (gamehero is a <div>, no nested-anchor issue)
    const logoSz = 'width:124px;height:124px';
    const logoA = `<img class="gh-logo" src="https://assets.nhle.com/logos/nhl/svg/${a}_light.svg" alt="${a}" onerror="this.style.display='none'" style="${[logoSz,aFade].filter(Boolean).join(';')}">`;
    const logoH = `<img class="gh-logo" src="https://assets.nhle.com/logos/nhl/svg/${h}_light.svg" alt="${h}" onerror="this.style.display='none'" style="${[logoSz,hFade].filter(Boolean).join(';')}">`;

    return `<div class="sd-head">
      <div>
        <div class="sd-eye">${eyeText}</div>
        <h2 class="sd-title">${titleHtml}</h2>
      </div>
      <div class="sd-meta">${metaHtml}</div>
    </div>
    <div class="gamehero">
      <div class="gh-bar"><span class="a" style="background:${ac}"></span><span class="h" style="background:${hc}"></span></div>
      ${flagHtml}
      <a class="gh-main" href="/games/${g.game_id}"${isPre ? ' style="gap:0"' : ''}>
        ${isPre ? '' : `<div class="gh-eye"><b>${g.away_team.name || a}</b> vs <b>${g.home_team.name || h}</b></div>`}
        <div class="gh-matchup">
          <div class="gh-team">
            ${logoA}
            <div class="gh-name"${isPre ? ' style="font-size:13px;letter-spacing:0.12em;color:var(--ink-72)"' : ''}>${g.away_team.short_name || a}</div>
            ${isPre && series
              ? `<div class="gh-rec-badge" style="color:${series.awayWins > series.homeWins ? ac : 'var(--ink-24)'}">${series.awayWins} - ${series.homeWins}</div>`
              : ''}
          </div>
          <div class="gh-scoreblock">
            ${clockHtml}
            ${scoreHtml}
            ${periodHtml}
          </div>
          <div class="gh-team">
            ${logoH}
            <div class="gh-name"${isPre ? ' style="font-size:13px;letter-spacing:0.12em;color:var(--ink-72)"' : ''}>${g.home_team.short_name || h}</div>
            ${isPre && series
              ? `<div class="gh-rec-badge" style="color:${series.homeWins > series.awayWins ? hc : 'var(--ink-24)'}">${series.homeWins} - ${series.awayWins}</div>`
              : ''}
          </div>
        </div>
        ${wpHtml}
      </a>
      <div class="gh-side">
        <div class="gh-side-head">// SERIES — BEST OF 7</div>
        ${sideSeries}
      </div>
      <div class="gh-bots" style="grid-column:1 / -1">
        <div class="gh-bots-handles">
          <span class="ch">${withPips ? '<span class="pip"></span>' : ''}@${a}GameBot</span>
          <span class="ch">${withPips ? '<span class="pip"></span>' : ''}@${h}GameBot</span>
        </div>
        <a href="/teams" class="cta">Follow both →</a>
      </div>
      ${statStrip}
    </div>`;
  }

  function renderYesterday(data) {
    const prev = data?.previous_day;
    const games = (prev?.games ?? []).filter(g => { const s = gs(g); return s === 'final' || s === 'game-end'; });
    const dynSec  = document.getElementById('yesterday-dynamic');
    const featSec = document.getElementById('featured-section');
    const restSec = document.getElementById('yesterday-rest-section');
    if (featSec) featSec.style.display = 'none';
    if (restSec) restSec.style.display = 'none';
    if (!dynSec || !games.length) return;

    const dateLabel = prev.hockey_date ? fmtDate(prev.hockey_date) : 'Last night';
    setText('yesterday-dynamic-date', dateLabel);

    const cards = games.map(g => {
      const a = g.away_team.abbrev, h = g.home_team.abbrev;
      const ac = clr(a), hc = clr(h);
      const awayWins = g.away_team.score > g.home_team.score;
      const isOT = (g.clock?.period ?? 0) >= 4;
      const xgA = g.stats?.xg_5v5?.away ?? null, xgH = g.stats?.xg_5v5?.home ?? null;
      const xgBar = xgA != null && xgH != null ? (() => {
        const tot = xgA + xgH, aShare = tot > 0 ? Math.round(xgA / tot * 100) : 50;
        return `<div class="result-xg-row"><span class="result-xg-num" style="color:${ac}">${xgA.toFixed(1)}</span><div class="result-xg-bar" style="background:linear-gradient(90deg,${ac} ${aShare}%,${hc} ${aShare}%)"></div><span class="result-xg-num" style="color:${hc}">${xgH.toFixed(1)}</span><span class="result-xg-lbl">xG</span></div>`;
      })() : '';
      return `<a class="result-card" href="/games/${g.game_id}">
        <div class="result-accent"><div style="background:${ac}"></div><div style="background:${hc}"></div></div>
        <div class="result-body">
          <div class="result-score-row">
            <div class="result-team"><img class="result-logo" src="https://assets.nhle.com/logos/nhl/svg/${a}_light.svg" alt="${a}" onerror="this.style.display='none'" style="${awayWins ? '' : 'opacity:0.35;filter:grayscale(0.4)'}"><div class="result-abbr ${awayWins ? 'lead' : 'trail'}">${a}</div></div>
            <div class="result-score-center"><div class="result-scores"><span class="result-n ${awayWins ? 'lead' : 'trail'}">${g.away_team.score}</span><span class="result-sep">–</span><span class="result-n ${awayWins ? 'trail' : 'lead'}">${g.home_team.score}</span></div><div class="result-period">FINAL${isOT ? ' · OT' : ''}</div></div>
            <div class="result-team"><img class="result-logo" src="https://assets.nhle.com/logos/nhl/svg/${h}_light.svg" alt="${h}" onerror="this.style.display='none'" style="${awayWins ? 'opacity:0.35;filter:grayscale(0.4)' : ''}"><div class="result-abbr ${awayWins ? 'trail' : 'lead'}">${h}</div></div>
          </div>${xgBar}
        </div>
      </a>`;
    }).join('');

    setHtml('yesterday-dynamic-grid', cards);
    dynSec.style.display = '';
  }

  async function renderStateD(data) {
    const g = data?.games?.[0];
    if (!g) return;

    // Hide the brand hero and YG personalization section — the game IS the page
    const heroSec = document.getElementById('hero-section');
    const ygSec = document.getElementById('your-game-section');
    if (heroSec) heroSec.style.display = 'none';
    if (ygSec) ygSec.style.display = 'none';

    const sdSec = document.getElementById('state-d-section');
    const sdWrap = document.getElementById('state-d-wrap');
    if (!sdSec || !sdWrap) return;
    sdSec.style.display = '';

    // Render immediately with whatever we have
    sdWrap.innerHTML = buildStateDHtml(g, _seriesData, _narrativesCache ? _getCachedNarrative(g) : null, _seriesStatsCache ? _getCachedSeriesGames(g) : null);
    startGhCountdown();
    renderYesterday(data);

    // Fetch series data + narrative + per-game scores in parallel if not yet loaded
    if (!_seriesData || !_narrativesCache || !_seriesStatsCache) {
      const [series, narrative, seriesGames] = await Promise.all([
        _seriesData ? Promise.resolve(_seriesData) : fetchSeriesInfo(g),
        fetchSeriesNarrative(g),
        _seriesStatsCache ? Promise.resolve(_getCachedSeriesGames(g)) : fetchSeriesGames(g),
      ]);
      if (series) _seriesData = series;
      sdWrap.innerHTML = buildStateDHtml(g, _seriesData, narrative, seriesGames);
      startGhCountdown();
    }

    const state = gs(g);
    setText('nav-status-text', state === 'live' ? 'Game Live' : state === 'final' ? 'Game Final' : 'Game Tonight');
  }

  // ── Ticker ───────────────────────────────────────────────────────────────────
  let _goalsCache = [];
  let _lastGoalsTickerHtml = '';

  async function fetchGoals() {
    const api = await _getHgbApi();
    if (!api) return;
    const data = await api.getGoals();
    const todayGoals = (data?.goals ?? []).filter(g => g.period && g.period <= 5);
    if (todayGoals.length) { _goalsCache = todayGoals; renderGoalsTicker(); return; }
    // Fall back to yesterday
    const yest = new Date(); yest.setDate(yest.getDate() - 1);
    const yd = yest.toISOString().slice(0, 10);
    const yData = await api.getGoals(yd);
    if (yData) { _goalsCache = yData.goals ?? []; renderGoalsTicker(); }
  }

  function renderGoalsTicker() {
    if (!_goalsCache.length) return;
    const EMOJIS = ['🚨', '🥅', '🏒', '🚨', '🏒', '🥅'];
    const shuffled = [..._goalsCache].sort(() => Math.random() - 0.5).slice(0, 30);
    const items = shuffled.map((g, i) => {
      const scorer = g.scorer?.name ? g.scorer.name.split(' ').pop() : null;
      const team = g.scoring_team?.abbrev || '?';
      const away = g.away_team?.abbrev || '?', home = g.home_team?.abbrev || '?';
      const score = `${away} ${g.away_score}–${g.home_score} ${home}`;
      const period = g.period ? (g.period <= 3 ? `P${g.period}` : g.period === 4 ? 'OT' : 'SO') : '';
      const time = g.time_in_period || '';
      const strength = g.strength === 'pp' ? ' <em>PP</em>' : g.strength === 'sh' ? ' <em>SH</em>' : '';
      const who = scorer ? `<strong>${scorer}</strong> (${team})${strength}` : `<strong>${team}</strong>${strength}`;
      const ctx = [period, time].filter(Boolean).join(' ');
      return `<div class="tk-item">${EMOJIS[i % EMOJIS.length]} ${who} <span class="sep">·</span> <span class="score">${score}</span>${ctx ? `<span class="sep">·</span>${ctx}` : ''}</div>`;
    }).join('');
    if (items === _lastGoalsTickerHtml) return;
    _lastGoalsTickerHtml = items;
    const track = document.getElementById('ticker-track');
    if (track) {
      track.innerHTML = items + items;
      track.style.animationDuration = `${Math.max(36, shuffled.length * 6)}s`;
    }
  }

  function renderTicker(data) {
    if (_goalsCache.length) { renderGoalsTicker(); return; }
    const state = pageState(data);
    const source = state==='post' ? (data.previous_day?.games??[]) : (data.games??[]);
    if (!source.length) return;
    const items = source.map(g => {
      const a=g.away_team.abbrev, h=g.home_team.abbrev;
      const ac=clr(a), hc=clr(h), st=gs(g);
      if (st==='pre') return `<div class="tk-item"><span class="t-away" style="color:${ac}">${a}</span><span class="sep">@</span><span class="t-home" style="color:${hc}">${h}</span><span class="sep">·</span>${fmtET(g.start_time_utc)||'Pre'} ET</div>`;
      if (st==='live'||st==='intermission') return `<div class="tk-item"><span class="live-pip"></span><span class="live">LIVE</span><span class="t-away" style="color:${ac}">${a}</span><span class="score">${g.away_team.score}–${g.home_team.score}</span><span class="t-home" style="color:${hc}">${h}</span><span class="sep">·</span><span class="live">${pLabel(g.clock?.period)} ${g.clock?.time_remaining??''}</span></div>`;
      return `<div class="tk-item"><span class="final">FINAL</span><span class="t-away" style="color:${ac}">${a}</span><span class="score">${g.away_team.score}–${g.home_team.score}</span><span class="t-home" style="color:${hc}">${h}</span></div>`;
    }).join('');
    setHtml('ticker-track', items+items);
  }

  // ── Pre-game ─────────────────────────────────────────────────────────────────
  function renderPre(data, tonight) {
    stopCountdown();
    _pageState = 'pre';
    const games = data.games ?? [];
    const date = data.date ? fmtDate(data.date) : 'Tonight';
    setText('hero-ghost', String(games.length || '?'));
    document.getElementById('live-pill').style.display = 'none';
    setText('hero-eyebrow-text', `Tonight · ${date}`);
    setText('hero-meta', `${games.length} game${games.length!==1?'s':''} · ${games.length * 2} bots standing by`);
    document.getElementById('also-section').style.display = 'none';

    const sorted = [...games].sort((a,b) => new Date(a.start_time_utc||0) - new Date(b.start_time_utc||0));
    const firstUtc = sorted[0]?.start_time_utc;

    const cards = games.map(g => {
      const tg = tonight.find(t => t.game_id === g.game_id);
      const a=g.away_team.abbrev, h=g.home_team.abbrev;
      const ac=clr(a), hc=clr(h);
      const awayWP=wpPct(g,'away'), homeWP=wpPct(g,'home');
      const gl = tg ?? null;
      return `<a class="pregame-card" href="/games/${g.game_id}">
        <div class="pregame-card-bar"><div class="a" style="background:${ac}"></div><div class="h" style="background:${hc}"></div></div>
        <div class="pregame-card-inner">
          <div class="pregame-card-matchup">
            <div class="pregame-card-team">
              <img class="pregame-logo" src="https://assets.nhle.com/logos/nhl/svg/${a}_light.svg" alt="${a}" onerror="this.style.display='none'">
              <div class="pregame-card-abbr" style="color:${ac}">${a}</div>
            </div>
            <div class="pregame-card-mid">
              <div class="pregame-card-time">${fmtLocalTime(g.start_time_utc) || tg?.startET || '—'}</div>
              ${localTZ ? `<div class="pregame-card-tz">${localTZ}</div>` : ''}
            </div>
            <div class="pregame-card-team right">
              <div class="pregame-card-abbr" style="color:${hc}">${h}</div>
              <img class="pregame-logo" src="https://assets.nhle.com/logos/nhl/svg/${h}_light.svg" alt="${h}" onerror="this.style.display='none'">
            </div>
          </div>
          <div class="pregame-card-goalies">
            ${gl?.awayGoalie ? `<div class="gl-row"><span class="gl-name">${gl.awayGoalie.last_name}</span><span class="gl-rec">${gl.awayGoalie.record}</span></div>` : ''}
            ${gl?.homeGoalie ? `<div class="gl-row"><span class="gl-name">${gl.homeGoalie.last_name}</span><span class="gl-rec">${gl.homeGoalie.record}</span></div>` : ''}
            ${!gl?.awayGoalie && !gl?.homeGoalie ? `<div class="gl-row gl-tbd"><span class="gl-name">Starters</span><span class="gl-rec">TBD</span></div>` : ''}
          </div>
          <div class="pregame-card-wp">
            <div class="pregame-card-wp-pcts">
              <span><b style="color:${ac}">${awayWP}%</b></span>
              <span style="color:var(--ink-32)">model</span>
              <span><b style="color:${hc}">${homeWP}%</b></span>
            </div>
            <div style="height:5px;background:linear-gradient(to right,${ac} ${awayWP}%,${hc} ${awayWP}%)"></div>
          </div>
        </div>
        <div class="pregame-card-foot">${g.venue || ''}</div>
      </a>`;
    }).join('');

    const hoursUntil = firstUtc ? (new Date(firstUtc) - Date.now()) / 3600000 : 99;
    const headline = hoursUntil < 2 ? `PUCK DROP <em>SOON.</em>` : `GAME <em>DAY.</em>`;
    const subtext = hoursUntil >= 4
      ? `${games.length} game${games.length!==1?'s':''} on the slate tonight. Bots are standing by — pre-game posts ship closer to puck drop.`
      : `${games.length} game${games.length!==1?'s':''} tonight. Pre-game posts shipped — milestone watches, predictions, projected lineups.`;

    setHtml('hero-slot', `<div class="state-empty">
      <div class="state-big">${headline}</div>
      <div class="state-lead">${subtext}</div>
      <div class="state-meta">${games.length} GAMES · ${games.length * 2} BOTS STANDING BY${firstUtc ? ` · <span id="countdown" class="countdown-inline">–:––</span>` : ''}</div>
      <div class="pregame-grid">${cards}</div>
    </div>`);
    if (firstUtc) startCountdown(firstUtc);
  }

  // ── Live ──────────────────────────────────────────────────────────────────────
  function renderLive(data) {
    stopCountdown();
    _pageState = 'live';
    // Hide yesterday sections — live games are the editorial focus
    const featSec = document.getElementById('featured-section');
    const yesterSec = document.getElementById('yesterday-rest-section');
    const trackedSec = document.getElementById('tracked-results-section');
    if (featSec) featSec.style.display = 'none';
    if (yesterSec) yesterSec.style.display = 'none';
    if (trackedSec) trackedSec.style.display = 'none';

    const games = data.games ?? [];
    const feat = pickLive(games);
    if (!feat) { renderPre(data, []); return; }

    setText('hero-ghost', String(games.filter(g=>gs(g)==='live'||gs(g)==='intermission').length));
    document.getElementById('live-pill').style.display = '';
    const period = pLabel(feat.clock?.period);
    const clock = feat.clock?.time_remaining ?? '';
    const isInt = feat.game_state === 'intermission';
    const clockStr = isInt ? `${period} · Intermission` : `${period} · ${clock}`;
    setText('hero-eyebrow-text', `${games.filter(g=>gs(g)==='live'||gs(g)==='intermission').length} Games In Progress · ${clockStr}`);
    setText('hero-meta', `${games.length} tonight · ${new Date().toLocaleTimeString('en-US',{timeZone:'America/New_York',hour:'numeric',minute:'2-digit',hour12:true})} ET`);

    const a=feat.away_team.abbrev, h=feat.home_team.abbrev;
    const ac=clr(a), hc=clr(h);
    const awayWP=wpPct(feat,'away'), homeWP=wpPct(feat,'home');
    const awayWins = feat.away_team.score > feat.home_team.score;

    // Bot feed (mocked until real activity stream exists)
    const botFeed = [
      { who:`${a}GameBot`, ts:'just now', action:'Win Probability card → X & Bluesky', xUrl:`https://x.com/${a}GameBot`, bsUrl:`https://bsky.app/profile/${a.toLowerCase()}.hockeygamebot.com` },
      { who:`${h}GameBot`, ts:'4m ago',   action:`Goal: ${h} leads · WP update`, xUrl:`https://x.com/${h}GameBot`, bsUrl:`https://bsky.app/profile/${h.toLowerCase()}.hockeygamebot.com` },
      { who:`${a}GameBot`, ts:'11m ago',  action:`Period ${pLabel(feat.clock?.period)} xG chart posted`, xUrl:`https://x.com/${a}GameBot`, bsUrl:`https://bsky.app/profile/${a.toLowerCase()}.hockeygamebot.com` },
    ];

    const feedHtml = botFeed.map(f => `<div class="feed-item">
      <div class="feed-head"><span class="feed-who">${f.who}</span><span class="feed-ts">${f.ts}</span></div>
      <div class="feed-action">${f.action}</div>
      <div class="feed-links">
        <a href="${f.xUrl}" target="_blank" rel="noopener" class="feed-link">𝕏</a>
        <a href="${f.bsUrl}" target="_blank" rel="noopener" class="feed-link">Bluesky</a>
      </div>
    </div>`).join('');

    // Also-live: other live games
    const others = games.filter(g => g.game_id!==feat.game_id && (gs(g)==='live'||gs(g)==='intermission'||gs(g)==='pre'||gs(g)==='final'));
    const alsoHtml = others.slice(0,6).map(g => {
      const oa=g.away_team.abbrev, oh=g.home_team.abbrev;
      const oac=clr(oa), ohc=clr(oh), ost=gs(g);
      const isLive  = ost==='live'||ost==='intermission';
      const isFinal = ost==='final';
      return `<a class="also-tile" href="/games/${g.game_id}">
        <div class="also-tile-matchup">
          <span style="color:${oac}">${oa}</span>
          <span style="color:var(--ink-32);font-size:12px;font-family:var(--mono)">@</span>
          <span style="color:${ohc}">${oh}</span>
          ${(isLive||isFinal) ? `<span class="also-tile-score">${g.away_team.score}–${g.home_team.score}</span>` : ''}
        </div>
        <div class="also-tile-status${isLive?' live':''}">
          ${isLive  ? `● ${pLabel(g.clock?.period)} ${g.clock?.time_remaining??''}` :
            isFinal ? `Final` :
                      `${fmtLocalTime(g.start_time_utc)||'Pre-game'} ${localTZ}`}
        </div>
      </a>`;
    }).join('');

    // Team logo URL
    const logoUrl = abbrev => `https://assets.nhle.com/logos/nhl/svg/${abbrev}_light.svg`;

    setHtml('hero-slot', `<a class="bigcard" href="/games/${feat.game_id}">
      <div class="bigcard-accent"><div class="a" style="background:${ac}"></div><div class="h" style="background:${hc}"></div></div>
      <div class="bigcard-head">
        <span class="bigcard-flag">Featured · Tightest Contest</span>
        <span class="bigcard-clock"><span class="period">${period}</span> · ${isInt?'Intermission':clock}</span>
      </div>
      <div class="score-block">
        <div class="score-side away">
          <div class="team-mark">
            <img src="${logoUrl(a)}" alt="${a}" onerror="this.style.display='none'"/>
            <div class="swatch" style="background:${ac}"></div>
          </div>
          <div class="team-id">
            <div class="team-abbr" style="color:${ac}">${a}</div>
            <div class="team-name">${feat.away_team.short_name}</div>
          </div>
          <div class="score-num${awayWins?' lead':' trail'}">${feat.away_team.score}</div>
        </div>
        <div class="score-side home">
          <div class="team-mark">
            <img src="${logoUrl(h)}" alt="${h}" onerror="this.style.display='none'"/>
            <div class="swatch" style="background:${hc}"></div>
          </div>
          <div class="team-id">
            <div class="team-abbr" style="color:${hc}">${h}</div>
            <div class="team-name">${feat.home_team.short_name}</div>
          </div>
          <div class="score-num${!awayWins?' lead':' trail'}">${feat.home_team.score}</div>
        </div>
      </div>
      <div class="bigcard-body">
        <div class="bc-panel left">
          <div class="bc-panel-label">Win Probability</div>
          <div class="wp-stat-row">
            <span class="wp-stat-abbr" style="color:${ac}">${a}</span>
            <span class="wp-stat-pct">${awayWP}%</span>
            <div class="wp-stat-track"><div class="wp-stat-fill" style="width:${awayWP}%;background:${ac}"></div></div>
          </div>
          <div class="wp-stat-row">
            <span class="wp-stat-abbr" style="color:${hc}">${h}</span>
            <span class="wp-stat-pct">${homeWP}%</span>
            <div class="wp-stat-track"><div class="wp-stat-fill" style="width:${homeWP}%;background:${hc}"></div></div>
          </div>
          <div style="margin-top:18px">
            <div class="bc-panel-label">Expected Goals · 5v5</div>
            <div class="xg-row">
              <span style="color:${ac}">${xgFmt(feat,'away')}</span>
              <span class="vs">vs</span>
              <span style="color:${hc}">${xgFmt(feat,'home')}</span>
            </div>
          </div>
        </div>
        <div class="bc-panel">
          <div class="bc-panel-label">Bot Output · Live</div>
          <div class="bot-feed">${feedHtml}</div>
        </div>
      </div>
      <div class="bigcard-foot">
        <div class="publishers">
          <span class="botchip"><span class="chip-dot"></span>${a}GameBot</span>
          <span class="botchip"><span class="chip-dot"></span>${h}GameBot</span>
        </div>
        <span class="foot-bots">2 bots · 0 humans</span>
      </div>
    </a>`);

    const alsoEl = document.getElementById('also-section');
    if (others.length > 0 && alsoEl) {
      alsoEl.style.display = '';
      alsoEl.innerHTML = `<div class="also-head"><span>Also tonight</span><div class="also-rule"></div></div><div class="also-grid">${alsoHtml}</div>`;
    } else if (alsoEl) {
      alsoEl.style.display = 'none';
    }
  }

  // ── Post-game ─────────────────────────────────────────────────────────────────
  function renderPost(data) {
    stopCountdown();
    _pageState = 'post';
    const games = data.games ?? [];
    const prevGames = (data.previous_day?.games ?? []).filter(g => {
      const s = gs(g); return s === 'final' || s === 'game-end';
    });
    const todayDate = data.hockey_date;
    const prevDate = data.previous_day?.hockey_date;
    // On off-days with no games today, fall back to showing previous night's results
    const isOffDay = games.length === 0 && prevGames.length > 0;
    const displayGames = isOffDay ? prevGames : games;
    const dateLabel = isOffDay
      ? (prevDate ? fmtDate(prevDate) : 'Last Night')
      : (todayDate ? fmtDate(todayDate) : 'Last Night');
    setText('hero-ghost', String(displayGames.length || '—'));
    document.getElementById('live-pill').style.display = 'none';
    setText('hero-eyebrow-text', `That's a Wrap · ${dateLabel}`);
    setText('hero-meta', games.length === 0 && !isOffDay ? 'No games tonight' : `${displayGames.length} game${displayGames.length !== 1 ? 's' : ''} · All final`);
    document.getElementById('also-section').style.display = 'none';
    // Hide SSR editorial sections in post state — they show yesterday's data
    // which is now stale. The hero final cards are the full story.
    const featSec = document.getElementById('featured-section');
    const yesterSec = document.getElementById('yesterday-rest-section');
    const trackedSec = document.getElementById('tracked-results-section');
    if (featSec) featSec.style.display = 'none';
    if (yesterSec) yesterSec.style.display = 'none';
    if (trackedSec) trackedSec.style.display = 'none';

    const cardDate = isOffDay ? prevDate : todayDate;
    const cards = displayGames.map(g => {
      const a=g.away_team.abbrev, h=g.home_team.abbrev;
      const ac=clr(a), hc=clr(h);
      const awayWins = g.away_team.score > g.home_team.score;
      const winWP = 100;
      const winC = awayWins ? ac : hc;
      const xgA = g.stats?.xg?.away ?? g.stats?.xg_5v5?.away, xgH = g.stats?.xg?.home ?? g.stats?.xg_5v5?.home;
      return `<a class="final-card" href="/games/${g.game_id}">
        <div class="final-card-bar"><div class="a" style="background:${ac}"></div><div class="h" style="background:${hc}"></div></div>
        <div class="final-card-tag"><span>Final</span><span>${cardDate||''}</span></div>
        <div class="final-row">
          <img class="final-logo" src="https://assets.nhle.com/logos/nhl/svg/${a}_light.svg" alt="${a}" onerror="this.style.display='none'">
          <div><div class="final-abbr" style="color:${ac}">${a}</div>${xgA!=null?`<div class="final-xg">xG ${xgA.toFixed(2)}</div>`:''}</div>
          <div class="final-score ${awayWins?'win':'lose'}">${g.away_team.score}</div>
        </div>
        <div class="final-row" style="margin-top:4px">
          <img class="final-logo" src="https://assets.nhle.com/logos/nhl/svg/${h}_light.svg" alt="${h}" onerror="this.style.display='none'">
          <div><div class="final-abbr" style="color:${hc}">${h}</div>${xgH!=null?`<div class="final-xg">xG ${xgH.toFixed(2)}</div>`:''}</div>
          <div class="final-score ${!awayWins?'win':'lose'}">${g.home_team.score}</div>
        </div>
        <div class="final-wp">
          <div class="final-wp-label">WP ${winWP}% · winner</div>
          <div class="final-wp-bar" style="background:linear-gradient(to right,${winC} ${winWP}%,var(--ink-06) ${winWP}%)"></div>
        </div>
      </a>`;
    }).join('');

    const heroHeadline = (games.length === 0 && !isOffDay) ? `QUIET <em>NIGHT.</em>` : `THAT'S A <em>WRAP.</em>`;
    const heroLead = (games.length === 0 && !isOffDay)
      ? `No games on the NHL schedule tonight. Check back on game days for live xG, win probability, and bot posts.`
      : (isOffDay
        ? `No games today — here's how things finished ${dateLabel}.`
        : (displayGames.length === 1
          ? `Post-game card, three stars, and recap thread are live.`
          : `${displayGames.length} games final. Post-game cards, three stars, and recap threads are live.`));
    const heroMeta = (games.length === 0 && !isOffDay)
      ? `NO GAMES TONIGHT`
      : `${displayGames.length} GAMES FINAL · ${dateLabel.toUpperCase()}`;

    setHtml('hero-slot', `<div class="state-empty">
      <div class="state-big">${heroHeadline}</div>
      <div class="state-lead">${heroLead}</div>
      <div class="state-meta">${heroMeta}</div>
      <div class="finals-grid">${cards}</div>
    </div>`);
  }

  // ── Main render ───────────────────────────────────────────────────────────────
  let _lastHeroKey = null;
  function heroKey(data) {
    const st = pageState(data);
    const ids = (data.games ?? []).map(g => `${g.game_id}:${g.game_state}:${g.away_team?.score}:${g.home_team?.score}:${g.clock?.time_remaining ?? ''}`).join('|');
    return `${st}::${ids}`;
  }

  // Populate window.HGB_GAME_CARDS so game-modal.js can open any game
  function syncGameCards(data) {
    window.HGB_GAME_CARDS = window.HGB_GAME_CARDS || {};
    const all = [...(data.games ?? []), ...(data.previous_day?.games ?? [])];
    for (const g of all) {
      const away = g.away_team || {}, home = g.home_team || {};
      const isFinal = g.status === 'final';
      const period = g.period || 0;
      window.HGB_GAME_CARDS[g.game_id] = {
        id: g.game_id,
        away: away.abbrev || '???', awayCity: away.short_name || '',
        home: home.abbrev || '???', homeCity: home.short_name || '',
        awayScore: away.score || 0, homeScore: home.score || 0,
        period, clock: g.time_remaining || '--:--',
        isFinal, isOT: !isFinal && period >= 4,
        inIntermission: g.in_intermission || false,
        status: g.status,
        teamColor: typeof ensureReadable !== 'undefined' ? ensureReadable(pickTeamColor(away.abbrev), 58) : clr(away.abbrev),
        homeColor: typeof ensureReadable !== 'undefined' ? ensureReadable(pickTeamColor(home.abbrev), 58) : clr(home.abbrev),
        winProbability: g.win_probability ?? null,
        xgHome: g.xg_home != null ? +parseFloat(g.xg_home).toFixed(1) : null,
        xgAway: g.xg_away != null ? +parseFloat(g.xg_away).toFixed(1) : null,
        threeStars: Array.isArray(g.three_stars) ? g.three_stars : null,
        recentEvents: [], lastEvent: '',
      };
    }
  }

  function render(data, tonight) {
    _lastData = data;
    const games = data?.games ?? [];
    syncGameCards(data);

    // ── State D: single game tonight — no hero, no ticker, no slate ──
    if (games.length === 1) {
      const ticker = document.querySelector('.ticker');
      if (ticker) ticker.style.display = 'none';
      const key = heroKey(data);
      if (key !== _lastHeroKey) {
        _lastHeroKey = key;
        renderStateD(data); // async, updates series widget when data arrives
      }
      return; // skip State A hero + YG section for single-game nights
    }

    // ── State A: multiple games ──
    renderTicker(data);
    const sdSec = document.getElementById('state-d-section');
    if (sdSec) sdSec.style.display = 'none';
    const heroSec = document.getElementById('hero-section');
    if (heroSec) heroSec.style.display = '';

    const state = pageState(data);
    const key = heroKey(data);
    const heroChanged = key !== _lastHeroKey;
    _lastHeroKey = key;
    if (heroChanged) {
      if (state === 'live') renderLive(data);
      else if (state === 'post') renderPost(data);
      else renderPre(data, tonight);
      requestAnimationFrame(() => injectPinButtons(data.games ?? [], getPin()?.game_id));
    }
    renderYourGameSection(data, _prefs ?? {});
    setText('nav-status-text', state==='live' ? `${games.filter(g=>gs(g)==='live'||gs(g)==='intermission').length} Games Live` : state==='post' ? 'All Final' : `${games.length} Games Tonight`);
  }

  // ── Fetch + poll ──────────────────────────────────────────────────────────────
  const initEl = document.getElementById('hgb-init');
  let initData = null;
  let tonight = [];
  try { initData = JSON.parse(initEl?.textContent || '{}'); tonight = initData.tonight ?? []; } catch {}

  // ?mock=STATE loads /mock/scoreboard.STATE.json instead of the live API
  const mockState = new URLSearchParams(location.search).get('mock');

  // ?date=YYYY-MM-DD replays a historical night — disables polling, shows banner
  const _dateParam = new URLSearchParams(location.search).get('date');
  let replayDate = null;
  let replayDateInvalid = false;
  if (_dateParam) {
    const todayUtc = new Date().toISOString().slice(0, 10);
    if (/^\d{4}-\d{2}-\d{2}$/.test(_dateParam) && _dateParam >= '2020-10-01' && _dateParam <= todayUtc) {
      replayDate = _dateParam;
    } else {
      replayDateInvalid = true;
    }
  }

  // Inject sticky banner for replay / invalid-date modes
  if (replayDate || replayDateInvalid) {
    const b = document.createElement('div');
    b.id = 'replay-banner';
    b.style.cssText = `position:sticky;top:0;z-index:500;padding:9px 0;text-align:center;font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;${replayDateInvalid ? 'background:var(--red);color:#fff' : 'background:var(--ink);color:var(--cream)'}`;
    b.textContent = replayDateInvalid
      ? 'Invalid date — showing today instead'
      : `Viewing ${fmtDate(replayDate)} — Historical Replay · live updates paused`;
    document.body.prepend(b);
  }

  async function fetchAndRender() {
    try {
      let url;
      if (mockState) url = `/mock/scoreboard.${mockState}.json`;
      else if (replayDate) url = `https://api.hockeygamebot.com/v1/scoreboard?date=${replayDate}`;
      else url = 'https://api.hockeygamebot.com/v1/scoreboard';
      const r = await fetch(url, { cache: 'no-store' });
      if (r.ok) { const d = await r.json(); render(d, tonight); return; }
    } catch {}
    if (initData) render(initData, tonight);
  }

  fetchAndRender();
  fetchGoals();
  // Disable polling for mock mode and historical replay — data is static
  if (!mockState && !replayDate) {
    setInterval(fetchAndRender, 30000);
    setInterval(fetchGoals, 300_000);
  }


  // ── Prefs + tracked teams (all users — prefs improve YG section; results for logged-in) ──
  (async function loadPrefsAndTrackedTeams() {
    // Wait for the auth-client bridge (a deferred module) to attach.
    async function getAuth() {
      for (let i = 0; i < 50 && !window.__hgbAuth; i++) {
        await new Promise(r => setTimeout(r, 20));
      }
      return window.__hgbAuth;
    }
    const auth = await getAuth();
    if (!auth) return; // bridge failed to load — skip prefs personalization

    const token = auth.getSessionToken();
    let prefs = await auth.getPrefs();

    // Save prefs and re-render YG section — only for multi-game nights (single-game uses State D)
    _prefs = prefs ?? {};
    if (_lastData && (_lastData.games ?? []).length !== 1) renderYourGameSection(_lastData, _prefs);

    if (!token) return;

    const rawTracked = prefs?.tracked_teams ?? [];
    const trackedAbbrevs = rawTracked.map(t => typeof t === 'string' ? t : t?.abbrev).filter(Boolean);
    if (!trackedAbbrevs.length) return;

    const A2I = {'ANA':24,'BOS':6,'BUF':7,'CGY':20,'CAR':12,'CHI':16,'COL':21,'CBJ':29,'DAL':25,'DET':17,'EDM':22,'FLA':13,'LAK':26,'MIN':30,'MTL':8,'NSH':18,'NJD':1,'NYI':2,'NYR':3,'OTT':9,'PHI':4,'PIT':5,'SJS':28,'SEA':55,'STL':19,'TBL':14,'TOR':10,'UTA':68,'VAN':23,'VGK':54,'WSH':15,'WPG':52};
    const teamIds = trackedAbbrevs.map(a => A2I[a]).filter(Boolean);
    if (!teamIds.length) return;

    const api = await _getHgbApi();
    const histData = api ? await api.getTeamHistory(teamIds, 20) : null;

    const allGames = (histData?.games ?? []).filter(g => g.status === 'final');
    if (!allGames.length) return;

    // g.date is the DB backfill update date, not the actual game date (game_date is null).
    // During playoffs: show playoff games only (game_id prefix '202503').
    // During regular season: show last 5 games of current season ('202502').
    // If team didn't make playoffs and regular season is over (no games in last ~30 days),
    // hide the section entirely.
    const playoffGames = allGames.filter(g => String(g.game_id || '').startsWith('202503'));
    const regularGames = allGames.filter(g => String(g.game_id || '').startsWith('202502'));
    // In June: if there are playoff games for this team, show those. Otherwise hide.
    const isPlayoffMonth = new Date().getMonth() >= 3 && new Date().getMonth() <= 6; // Apr-Jul
    const recent = playoffGames.length > 0 ? playoffGames.slice(0, 10)
                 : isPlayoffMonth ? [] // regular season over, team eliminated, hide
                 : regularGames.slice(0, 5);
    if (!recent.length) return;

    // Don't show during live or post-game state
    if (_pageState !== 'pre') return;

    const seen = new Set();
    const cards = [];
    for (const g of recent) {
      if (seen.has(g.game_id)) continue;
      seen.add(g.game_id);
      const a = g.away_team?.abbrev, h = g.home_team?.abbrev;
      if (!a || !h) continue;
      // Strip .0 suffix for game modal links
      const cleanId = g.game_id.replace(/\.0$/, '');
      const ac = clr(a), hc = clr(h);
      const awayWins = (g.away_team?.score ?? 0) > (g.home_team?.score ?? 0);
      const [aScore, hScore] = [g.away_team?.score ?? 0, g.home_team?.score ?? 0];
      cards.push(`<a class="result-card" href="/games/${cleanId}">
        <div class="result-accent"><div style="background:${ac}"></div><div style="background:${hc}"></div></div>
        <div class="result-body">
          <div class="result-score-row">
            <div class="result-team">
              <img class="result-logo" src="https://assets.nhle.com/logos/nhl/svg/${a}_light.svg" alt="${a}" onerror="this.style.display='none'" style="${awayWins?'':'opacity:0.35;filter:grayscale(0.4)'}">
              <div class="result-abbr ${awayWins?'lead':'trail'}">${a}</div>
            </div>
            <div class="result-score-center">
              <div class="result-scores">
                <span class="result-n ${awayWins?'lead':'trail'}">${aScore}</span>
                <span class="result-sep">–</span>
                <span class="result-n ${awayWins?'trail':'lead'}">${hScore}</span>
              </div>
              <div class="result-period">FINAL</div>
            </div>
            <div class="result-team">
              <img class="result-logo" src="https://assets.nhle.com/logos/nhl/svg/${h}_light.svg" alt="${h}" onerror="this.style.display='none'" style="${awayWins?'opacity:0.35;filter:grayscale(0.4)':''}">
              <div class="result-abbr ${awayWins?'trail':'lead'}">${h}</div>
            </div>
          </div>
        </div>
      </a>`);
    }
    if (!cards.length) return;

    const gridEl = document.getElementById('tracked-results-grid');
    const metaEl = document.getElementById('tracked-results-meta');
    const sec = document.getElementById('tracked-results-section');
    if (!gridEl || !sec) return;

    gridEl.innerHTML = cards.join('');
    if (metaEl) metaEl.textContent = `${trackedAbbrevs.join(', ')} · Recent games`;
    sec.style.display = '';
  })();

  // Click delegation — navigate directly to the game page
  document.addEventListener('click', e => {
    const card = e.target.closest('[data-game-id]');
    if (!card) return;
    const gameId = card.dataset.gameId;
    if (gameId) window.location.href = `/games/${gameId}`;
  });

  // Deep-link: ?game=ID on load
  const initGameId = new URLSearchParams(location.search).get('game');
  if (initGameId) {
    window.addEventListener('load', () => {
      if (typeof window.openModal === 'function') window.openModal(initGameId, { push: false });
    });
  }
})();
</script>

<GameModal />
<script src="/js/hgb-charts.js" defer></script>
<script src="/js/game-modal.js" defer></script>

</body>
</html>
