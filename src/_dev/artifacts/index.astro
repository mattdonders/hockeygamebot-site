---
/**
 * /_dev/artifacts — internal review gallery for the artifact-card library.
 *
 * Production-visible but noindex,nofollow (per SITE-HOME-02 spec). Not
 * linked from production navigation. Used by the user + designers to
 * review components on the Cloudflare Pages preview URL.
 *
 * Renders all 11 artifact components grouped by category, each at multiple
 * span widths (a-4 / a-6 / a-8) so layout robustness is visible.
 *
 * No real data — all from `src/data/home-mock/artifacts/*.json` via the
 * Zod-validated artifact-loader. JSON-source <details> blocks per card.
 */

import '../../styles/site-tokens.css';
import Topbar from '../../components/home/Topbar.astro';

import ArtifactGame from '../../components/home/artifacts/ArtifactGame.astro';
import ArtifactHot from '../../components/home/artifacts/ArtifactHot.astro';
import ArtifactCold from '../../components/home/artifacts/ArtifactCold.astro';
import ArtifactMilestone from '../../components/home/artifacts/ArtifactMilestone.astro';
import ArtifactLine from '../../components/home/artifacts/ArtifactLine.astro';
import ArtifactMatchup from '../../components/home/artifacts/ArtifactMatchup.astro';
import ArtifactClinch from '../../components/home/artifacts/ArtifactClinch.astro';
import ArtifactSeason from '../../components/home/artifacts/ArtifactSeason.astro';
import ArtifactHatTrick from '../../components/home/artifacts/ArtifactHatTrick.astro';
import ArtifactThreeStars from '../../components/home/artifacts/ArtifactThreeStars.astro';
import ArtifactGoalie from '../../components/home/artifacts/ArtifactGoalie.astro';

import { loadArtifact, ARTIFACT_RAW } from '../../lib/artifact-loader';

const game = loadArtifact('game');
const hot = loadArtifact('hot');
const cold = loadArtifact('cold');
const milestone = loadArtifact('milestone');
const line = loadArtifact('line');
const matchup = loadArtifact('matchup');
const clinch = loadArtifact('clinch');
const season = loadArtifact('season');
const hattrick = loadArtifact('hattrick');
const stars = loadArtifact('stars');
const goalie = loadArtifact('goalie');

// Pretty-print JSON for the <details> blocks below each card.
function pretty(obj: unknown): string {
  return JSON.stringify(obj, null, 2);
}
---
<!DOCTYPE html>
<html lang="en" data-home-mode="today">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="dark">
  {/* CRITICAL — this page is production-visible but must never enter SEO. */}
  <meta name="robots" content="noindex,nofollow">
  <title>Artifact Library — DEV — HockeyGameBot</title>
  <meta name="description" content="Internal review gallery for the artifact-card component library. Not linked from production.">

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: var(--site-bg);
      color: var(--site-text);
      font-family: var(--font-site-body);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>

<Topbar active="scores" />

<main class="dev-wrap">
  <header class="dev-head">
    <div class="dev-crumb"><span class="dev-crumb-cur">Home · Artifact library · DEV</span></div>
    <h1>Artifact Library — <span class="dev-title-tag">DEV</span></h1>
    <p class="dev-sub">
      Internal review only. Not linked from production. Renders the 11 reusable
      artifact components against their Zod-validated mock JSON. Click any card's
      <code>JSON</code> chip to view the prop payload.
    </p>
    <div class="dev-meta">
      <span><b>11</b> components</span>
      <span><b>11</b> mock fixtures</span>
      <span><b>noindex,nofollow</b> — never crawled</span>
    </div>
  </header>

  {/* ═══ GAME MOMENTS ═══════════════════════════════════════════════════════ */}
  <section class="dev-section">
    <div class="dev-section-h">
      <h2>Game moments</h2>
      <span class="dev-section-sub">Postgame artifacts — generated automatically when a game ends.</span>
    </div>
    <div class="dev-wall">
      <div class="dev-card a-6">
        <ArtifactGame {...game} />
        <details class="dev-json"><summary>JSON · game.json</summary><pre>{pretty(ARTIFACT_RAW.game)}</pre></details>
      </div>
      <div class="dev-card a-4">
        <ArtifactHatTrick {...hattrick} />
        <details class="dev-json"><summary>JSON · hattrick.json</summary><pre>{pretty(ARTIFACT_RAW.hattrick)}</pre></details>
      </div>
      <div class="dev-card a-4">
        <ArtifactGoalie {...goalie} />
        <details class="dev-json"><summary>JSON · goalie.json</summary><pre>{pretty(ARTIFACT_RAW.goalie)}</pre></details>
      </div>
      <div class="dev-card a-4">
        <ArtifactThreeStars {...stars} />
        <details class="dev-json"><summary>JSON · stars.json</summary><pre>{pretty(ARTIFACT_RAW.stars)}</pre></details>
      </div>
      <div class="dev-card a-8">
        <ArtifactGame {...game} />
        <span class="dev-card-tag">a-8 width check</span>
      </div>
    </div>
  </section>

  {/* ═══ PLAYER NARRATIVES ══════════════════════════════════════════════════ */}
  <section class="dev-section">
    <div class="dev-section-h">
      <h2>Player narratives</h2>
      <span class="dev-section-sub">Trends + milestones + season summaries — fired by scheduled jobs and event detectors.</span>
    </div>
    <div class="dev-wall">
      <div class="dev-card a-4">
        <ArtifactHot {...hot} />
        <details class="dev-json"><summary>JSON · hot.json</summary><pre>{pretty(ARTIFACT_RAW.hot)}</pre></details>
      </div>
      <div class="dev-card a-4">
        <ArtifactCold {...cold} />
        <details class="dev-json"><summary>JSON · cold.json</summary><pre>{pretty(ARTIFACT_RAW.cold)}</pre></details>
      </div>
      <div class="dev-card a-4">
        <ArtifactMilestone {...milestone} />
        <details class="dev-json"><summary>JSON · milestone.json</summary><pre>{pretty(ARTIFACT_RAW.milestone)}</pre></details>
      </div>
      <div class="dev-card a-6">
        <ArtifactSeason {...season} />
        <details class="dev-json"><summary>JSON · season.json</summary><pre>{pretty(ARTIFACT_RAW.season)}</pre></details>
      </div>
      <div class="dev-card a-6">
        <ArtifactHot {...hot} />
        <span class="dev-card-tag">a-6 width check</span>
      </div>
    </div>
  </section>

  {/* ═══ TEAM NARRATIVES ════════════════════════════════════════════════════ */}
  <section class="dev-section">
    <div class="dev-section-h">
      <h2>Team narratives</h2>
      <span class="dev-section-sub">Pre-game previews, line-combo highlights, clinch alerts.</span>
    </div>
    <div class="dev-wall">
      <div class="dev-card a-6">
        <ArtifactClinch {...clinch} />
        <details class="dev-json"><summary>JSON · clinch.json</summary><pre>{pretty(ARTIFACT_RAW.clinch)}</pre></details>
      </div>
      <div class="dev-card a-6">
        <ArtifactMatchup {...matchup} />
        <details class="dev-json"><summary>JSON · matchup.json</summary><pre>{pretty(ARTIFACT_RAW.matchup)}</pre></details>
      </div>
      <div class="dev-card a-8">
        <ArtifactLine {...line} />
        <details class="dev-json"><summary>JSON · line.json</summary><pre>{pretty(ARTIFACT_RAW.line)}</pre></details>
      </div>
      <div class="dev-card a-4">
        <ArtifactClinch {...clinch} />
        <span class="dev-card-tag">a-4 width check</span>
      </div>
    </div>
  </section>

  <footer class="dev-foot">
    <span>HockeyGameBot · Artifact Library v0.1 · Layer 2 of /home-v2 rebuild</span>
    <span>11 components · 11 mocks · Zod-validated</span>
  </footer>
</main>

<style>
  .dev-wrap {
    max-width: 1400px;
    margin: 0 auto;
    padding: 28px 32px 120px;
  }

  .dev-head {
    margin-bottom: 36px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--site-border);
  }

  .dev-crumb {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--site-muted);
    margin-bottom: 14px;
  }
  .dev-crumb-cur { color: var(--hgb-red); }

  .dev-head h1 {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 38px;
    color: var(--site-white);
    margin: 0 0 6px;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    line-height: 1;
  }
  .dev-title-tag {
    color: var(--hgb-red);
    font-size: 22px;
    letter-spacing: 0.18em;
    vertical-align: middle;
    margin-left: 10px;
  }
  .dev-sub {
    font-size: 13px;
    color: var(--site-text);
    max-width: 720px;
    line-height: 1.6;
    margin: 0 0 14px;
  }
  .dev-sub code {
    font-family: var(--font-mono);
    font-size: 11.5px;
    background: var(--site-card);
    padding: 1px 6px;
    border: 1px solid var(--site-border);
    border-radius: 2px;
  }
  .dev-meta {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--site-muted);
    letter-spacing: 0.06em;
  }
  .dev-meta b { color: var(--site-white); font-weight: 500; }

  .dev-section {
    margin-top: 48px;
  }
  .dev-section-h {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .dev-section-h h2 {
    font-family: var(--font-site-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--site-white);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
  }
  .dev-section-sub {
    font-size: 12px;
    color: var(--site-muted);
    font-style: italic;
  }

  .dev-wall {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }
  .dev-card {
    position: relative;
  }
  .dev-card.a-4  { grid-column: span 4; }
  .dev-card.a-6  { grid-column: span 6; }
  .dev-card.a-8  { grid-column: span 8; }
  .dev-card.a-12 { grid-column: span 12; }

  .dev-card-tag {
    position: absolute;
    bottom: -22px;
    left: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--site-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dev-json {
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    background: var(--site-card);
    border: 1px solid var(--site-border);
    border-radius: 2px;
    color: var(--site-text);
  }
  .dev-json summary {
    cursor: pointer;
    padding: 6px 10px;
    color: var(--site-white);
    font-weight: 500;
    letter-spacing: 0.04em;
    user-select: none;
  }
  .dev-json summary:hover { color: var(--hgb-red); }
  .dev-json[open] summary { border-bottom: 1px solid var(--site-border); }
  .dev-json pre {
    margin: 0;
    padding: 12px;
    overflow-x: auto;
    font-size: 10.5px;
    line-height: 1.55;
    color: #c8c8c8;
    background: #0a0a0a;
    max-height: 360px;
    overflow-y: auto;
  }

  .dev-foot {
    margin-top: 80px;
    padding: 20px 0 0;
    border-top: 1px solid var(--site-border);
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--site-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media (max-width: 880px) {
    .dev-wall { grid-template-columns: 1fr; }
    .dev-card.a-4, .dev-card.a-6, .dev-card.a-8, .dev-card.a-12 { grid-column: span 1; }
    .dev-card-tag { position: static; margin-top: 6px; display: block; }
  }
</style>

</body>
</html>
