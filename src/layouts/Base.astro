---
import Nav from '../components/Nav.astro';
import ThemeScript from '../components/ThemeScript.astro';
import Fonts from '../components/Fonts.astro';
import SentryInit from '../components/SentryInit.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  canonical?: string;
  currentPath: string;
}

const {
  title,
  description = '',
  ogImage = '/og/default.png',
  ogType = 'website',
  canonical,
  currentPath,
} = Astro.props;

const canonicalUrl = canonical
  ? new URL(canonical, Astro.site).href
  : new URL(Astro.url.pathname, Astro.site).href;
const absoluteOgImage = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, Astro.site).href;
---
<!doctype html>
<html lang="en">
<head>
  <ThemeScript />
  <SentryInit />
  <Fonts />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/favicon-180x180.png" />
  <meta property="og:site_name" content="HockeyGameBot" />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={absoluteOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={absoluteOgImage} />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:        #EFEEE8;
      --bg-2:      #E8E7E0;
      --ink:       #0d0d14;
      --red:       #E8002D;
      --surface:   #FFFFFF;
      --green:     #14803c;
      --grid-line: rgba(13,13,20,0.04);
      --ink-03:    rgba(13,13,20,0.03);
      --ink-04:    rgba(13,13,20,0.04);
      --ink-06:    rgba(13,13,20,0.06);
      --ink-10:    rgba(13,13,20,0.10);
      --ink-14:    rgba(13,13,20,0.14);
      --ink-20:    rgba(13,13,20,0.20);
      --ink-32:    rgba(13,13,20,0.32);
      --ink-48:    rgba(13,13,20,0.48);
      --ink-56:    rgba(13,13,20,0.56);
      --ink-64:    rgba(13,13,20,0.64);
      --ink-72:    rgba(13,13,20,0.72);
      --ink-86:    rgba(13,13,20,0.86);
      --stats-pos: #166534;
      --stats-neg: #991b1b;
      --red-bg:    rgba(232,0,45,0.08);
      --green-bg:  rgba(20,128,60,0.08);
      --display:   'Barlow Condensed', sans-serif;
      --body:      'Barlow', sans-serif;
      --mono:      'JetBrains Mono', monospace;
    }
    html, body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--body);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }
    a { color: inherit; text-decoration: none; }
  </style>
  <slot name="head" />
</head>
<body>
  <Nav currentPath={currentPath} />
  <slot name="subnav" />
  <slot />
  <slot name="footer" />
</body>
</html>
