---
import Base from './Base.astro';
import StatsSubnav from '../components/StatsSubnav.astro';
import { cardFooterText, SITE_DISCLAIMER } from '../lib/card-footer';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  currentPath: string;
  footerExtra?: string;
}

const { title, description, ogImage, currentPath, footerExtra } = Astro.props;
---
<Base {title} {description} {ogImage} {currentPath}>
  <script is:inline src="/js/table-export.js" slot="head"></script>
  <slot name="head" slot="head" />

  <slot name="mast" />
  <StatsSubnav {currentPath} />
  <slot />

  <Fragment slot="footer">
    <footer class="lb-footer">{cardFooterText({ domain: 'lower', extra: footerExtra })}</footer>
    <div class="lb-disclaimer">{SITE_DISCLAIMER}</div>
  </Fragment>
</Base>

<style is:global>
/* ── Masthead ── */
.mast {
  position: relative;
  border-bottom: 2px solid var(--ink);
  background-color: var(--bg);
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 96px 96px;
  overflow: hidden;
}
.mast-ghost {
  position: absolute; pointer-events: none; user-select: none; z-index: 0;
  font-family: var(--display); font-weight: 800; font-size: 260px;
  line-height: 0.86; text-transform: uppercase; letter-spacing: -0.02em;
  white-space: nowrap; color: rgba(13,13,20,0.07);
  top: 50%; left: 50%; transform: translate(-50%, -50%);
}
.mast-corners { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
.mast-corners .corner { position: absolute; width: 16px; height: 16px; }
.mast-corners .tl { top: 16px; left: 16px; border-top: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .tr { top: 16px; right: 16px; border-top: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-corners .bl { bottom: 16px; left: 16px; border-bottom: 1px solid var(--ink-20); border-left: 1px solid var(--ink-20); }
.mast-corners .br { bottom: 16px; right: 16px; border-bottom: 1px solid var(--ink-20); border-right: 1px solid var(--ink-20); }
.mast-inner {
  position: relative; z-index: 2;
  max-width: 1200px; margin: 0 auto; padding: 36px 32px;
}
.mast-top {
  display: flex; align-items: baseline; justify-content: space-between;
  gap: 24px; margin-bottom: 20px;
  font-family: var(--body); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-48);
}
.mast-eyebrow {
  font-family: var(--body); font-weight: 500; font-size: 11px;
  letter-spacing: 0.12em; text-transform: uppercase;
  display: inline-flex; align-items: center; gap: 8px;
}
.mast-eyebrow .pip { width: 5px; height: 5px; background: var(--red); border-radius: 50%; }
.mast-card { background: var(--surface); border: 1px solid var(--ink); padding: 28px 32px 24px; }
.mast-headline {
  font-family: var(--display); font-weight: 800;
  font-size: clamp(36px, 5.5vw, 64px); text-transform: uppercase;
  line-height: 1.0; letter-spacing: -0.005em; color: var(--ink); margin-bottom: 14px;
}
.mast-headline em { color: var(--red); font-style: normal; }
.mast-lede { font-size: 13.5px; line-height: 1.6; color: var(--ink-48); max-width: 640px; }
.mast-lede .mono { font-family: var(--mono); font-size: 12px; color: var(--ink-72); }

/* ── Content wrapper ── */
.wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }

/* ── Footer ── */
.lb-footer {
  max-width: 1200px; margin: 0 auto; padding: 20px 32px;
  font-family: var(--body); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(13,13,20,0.55); border-top: 1px solid var(--ink-10); text-align: center;
}
.lb-disclaimer {
  max-width: 1200px; margin: 0 auto; padding: 0 32px 20px;
  font-family: var(--mono); font-size: 9px; color: var(--ink-32); line-height: 1.5; text-align: center;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .mast-inner { padding: 28px 20px; }
  .mast-card  { padding: 24px 20px 20px; }
  .wrap { padding: 0 20px 60px; }
}
@media (max-width: 480px) {
  .mast-inner { padding: 20px 16px; }
  .mast-card  { padding: 18px 14px 16px; }
  .wrap { padding: 0 16px 48px; }
}
</style>
